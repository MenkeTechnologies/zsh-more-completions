#compdef tsh

# Zsh completion for Teleport tsh client

_teleport() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'login:log in to a Teleport cluster'
    'logout:log out of all Teleport clusters'
    'status:display the list of proxy servers and retrieved certificates'
    'ssh:run shell or execute a command on a remote SSH node'
    'scp:transfer files to a remote SSH node'
    'ls:list remote SSH nodes'
    'clusters:list available Teleport clusters'
    'apps:view and control proxied applications'
    'db:view and control proxied databases'
    'kube:manage Kubernetes access'
    'proxy:run local TLS proxy for various protocols'
    'request:manage access requests'
    'config:print OpenSSH configuration details'
    'env:print commands to set Teleport session environment variables'
    'mfa:manage multi-factor authentication devices'
    'headless:manage headless logins'
    'fido2:manage FIDO2 devices'
    'touchid:manage Touch ID credentials'
    'recordings:view and control session recordings'
    'version:print the version of tsh'
    'bench:run benchmarks'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'tsh command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        login)
          _arguments -s -S \
            '--proxy=[Teleport proxy address]:proxy:' \
            '--auth=[authentication connector]:connector:' \
            '--user=[Teleport user name]:user:' \
            '--bind-addr=[bind address for login]:address:' \
            '--browser=[browser to use]:browser:(none)' \
            '--kube-cluster=[Kubernetes cluster]:cluster:' \
            '--request-roles=[request roles]:roles:' \
            '--request-reason=[request reason]:reason:' \
            '-o+[output format]:format:(text json)' \
            '--out=[output format]:format:(text json)' \
            '--format=[output format]:format:(text json)' \
            '--ttl=[time to live for certificates]:duration:' \
            '-i+[identity file]:identity file:_files' \
            '--identity=[identity file]:identity file:_files' \
            '--insecure[do not verify server certificate]' \
            '1:cluster name:' \
            && ret=0
          ;;
        ssh)
          _arguments -s -S \
            '-p+[SSH port]:port:' \
            '--port=[SSH port]:port:' \
            '-l+[remote user name]:user:' \
            '--login=[remote user name]:user:' \
            '-A[forward agent]' \
            '--forward-agent[forward agent]' \
            '-L+[local port forwarding]:spec:' \
            '--local-forward=[local port forwarding]:spec:' \
            '-D+[dynamic port forwarding (SOCKS5)]:port:' \
            '--dynamic-forward=[dynamic port forwarding (SOCKS5)]:port:' \
            '-N[do not execute a shell]' \
            '--no-remote-exec[do not execute a shell]' \
            '-o+[SSH option]:option:' \
            '--option=[SSH option]:option:' \
            '-t[force pseudo-terminal allocation]' \
            '--tty[force pseudo-terminal allocation]' \
            '--cluster=[target cluster]:cluster:' \
            '--enable-escape-sequences[enable \~ escape sequences]' \
            '--no-resume[disable SSH connection resumption]' \
            '(-):host:' \
            '(-)*:command:' \
            && ret=0
          ;;
        scp)
          _arguments -s -S \
            '-p+[SSH port]:port:' \
            '--port=[SSH port]:port:' \
            '-l+[remote user name]:user:' \
            '--login=[remote user name]:user:' \
            '-r[recursive copy]' \
            '--recursive[recursive copy]' \
            '--cluster=[target cluster]:cluster:' \
            '*:files:_files' \
            && ret=0
          ;;
        ls)
          _arguments -s -S \
            '--cluster=[target cluster]:cluster:' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            '-f+[output format]:format:(text json names)' \
            '--format=[output format]:format:(text json names)' \
            '--search=[search query]:query:' \
            '--query=[predicate query]:query:' \
            && ret=0
          ;;
        db)
          _arguments -s -S \
            '1:subcommand:(ls login logout connect env config)' \
            '--cluster=[target cluster]:cluster:' \
            && ret=0
          ;;
        kube)
          _arguments -s -S \
            '1:subcommand:(ls login logout credentials sessions)' \
            '--cluster=[target cluster]:cluster:' \
            && ret=0
          ;;
        apps)
          _arguments -s -S \
            '1:subcommand:(ls login logout config)' \
            '--cluster=[target cluster]:cluster:' \
            && ret=0
          ;;
        proxy)
          _arguments -s -S \
            '1:subcommand:(ssh db kube app aws azure gcp)' \
            && ret=0
          ;;
        request)
          _arguments -s -S \
            '1:subcommand:(new ls show approve deny drop review search)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--proxy=[Teleport proxy address]:proxy:' \
            '--user=[Teleport user name]:user:' \
            '-d[debug mode]' \
            '--debug[debug mode]' \
            '-i+[identity file]:identity file:_files' \
            '--identity=[identity file]:identity file:_files' \
            '--insecure[skip TLS verification]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_teleport "$@"
