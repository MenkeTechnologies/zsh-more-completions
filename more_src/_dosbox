#compdef dosbox

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[execute command before running]:command' \
  '-conf+[use specified config file]:file:_files' \
  '-editconf[edit the config file]' \
  '-eraseconf[erase the config file]' \
  '-erasemapper[erase the mapper file]' \
  '-exit[exit after executing commands]' \
  '-fullscreen[start in fullscreen mode]' \
  '-lang+[use specified language file]:file:_files' \
  '-machine+[emulate specific machine type]:type:(hercules cga tandy pcjr ega vgaonly svga_s3 svga_et3000 svga_et4000 svga_paradise vesa_nolfb vesa_oldvbe)' \
  '-noautoexec[skip AUTOEXEC section in config file]' \
  '-noconsole[start without console window]' \
  '-scaler+[use specified scaler]:scaler:(none normal2x normal3x advmame2x advmame3x advinterp2x advinterp3x hq2x hq3x 2xsai super2xsai supereagle tv2x tv3x rgb2x rgb3x scan2x scan3x)' \
  '-startmapper[start the keymapper]' \
  '-userconf[use user config file]' \
  '-printconf[print config file location]' \
  '-resetconf[reset config file]' \
  '-resetmapper[reset mapper file]' \
  '-socket+[specify socket for null modem]:socket' \
  '*:file or directory:_files'
