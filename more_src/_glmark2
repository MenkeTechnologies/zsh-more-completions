#compdef glmark2 glmark2-es2 glmark2-drm glmark2-wayland
# Documentation: https://man.archlinux.org/search?q=glmark2
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --benchmark)'{-b,--benchmark}'+[benchmark name]:bench:' \
  '(-f --benchmark-file)'{-f,--benchmark-file}'+[benchmark list file]:file:_files' \
  '(-l --list-scenes)'{-l,--list-scenes}'[list scenes and their options]' \
  '(-s --size)'{-s,--size}'+[window size WxH]:WxH:' \
  '--annotate[overlay scene name and FPS]' \
  '--debug[debug output]' \
  '--reuse-context[reuse GL context between scenes]' \
  '--off-screen[render off-screen]' \
  '--fullscreen[fullscreen]' \
  '--show-all-options[list all scene options]' \
  '--validate[validate result]' \
  '--good-config[use good config]' \
  '--frame-end=[frame end action]:action:(swap finish readpix none)' \
  '--swap-mode=[swap mode]:mode:(default fifo mailbox immediate)' \
  '--visual-config=[visual config]:cfg:' \
  '--data-path=[data path]:dir:_files -/' && ret=0

return ret
