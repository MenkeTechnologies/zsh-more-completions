#compdef systemd-measure
# Documentation: https://man7.org/linux/man-pages/man1/systemd-measure.1.html
# Reference accessed: 2026-05-21
# Verified: upstream systemd-measure(1) manpage.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'status:query local TPM2 PCR 11 values'
  'calculate:pre-calculate expected PCR 11 values after UKI boot'
  'sign:pre-calculate PCR values and sign with RSA key'
  'policy-digest:pre-calculate PCR values and compute TPM2 policy digest'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-pager[disable pager]' \
  '--json=[JSON output mode]:mode:(short pretty off)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'systemd-measure command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (calculate|sign|policy-digest)
        _arguments \
          '--linux=[linux kernel image]:kernel:_files' \
          '--osrel=[os-release file]:file:_files' \
          '--cmdline=[kernel command line file]:file:_files' \
          '--initrd=[initrd image]:initrd:_files' \
          '--ucode=[microcode image]:ucode:_files' \
          '--splash=[splash image]:bmp:_files' \
          '--dtb=[device tree]:dtb:_files' \
          '--uname=[uname file]:file:_files' \
          '--sbat=[SBAT file]:file:_files' \
          '--pcrpkey=[PCR public key]:key:_files' \
          '--profile=[profile file]:file:_files' \
          '--dtbauto=[device tree auto-selected]:file:_files' \
          '--hwids=[hwids file]:file:_files' \
          '--current[use current PCR 11 values instead of component files]' \
          '--bank=[PCR bank]:bank:(sha1 sha256 sha384 sha512)' \
          '--tpm2-device=[TPM2 device]:device:(auto list)' \
          '--private-key=[signing private key]:key:' \
          '--public-key=[signing public key]:key:_files' \
          '--certificate=[signing certificate]:cert:' \
          '--private-key-source=[private key source TYPE[:NAME]]:source:' \
          '--certificate-source=[certificate source TYPE[:NAME]]:source:' \
          '--phase=[boot phase]:phase:' \
          '--append=[append previously generated PCR signatures]:path:_files' \
          && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
