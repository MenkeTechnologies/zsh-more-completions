#compdef systemd-measure

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'status:show current PCR values'
  'calculate:calculate expected PCR values'
  'sign:sign PCR policy'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[JSON output]:format:(pretty short off)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'systemd-measure command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (calculate|sign)
        _arguments \
          '--linux[linux kernel image]:kernel:_files' \
          '--initrd[initrd image]:initrd:_files' \
          '--osrel[os-release file]:file:_files' \
          '--cmdline[kernel command line]:cmdline:' \
          '--dtb[device tree]:dtb:_files' \
          '--splash[splash image]:bmp:_files' \
          '--pcrpkey[PCR public key]:key:_files' \
          '--bank[PCR bank]:bank:(sha1 sha256 sha384 sha512)' \
          '--private-key[signing private key]:key:_files' \
          '--public-key[signing public key]:key:_files' \
          '--certificate[signing certificate]:cert:_files' \
          '--phase[boot phase]:phase:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
