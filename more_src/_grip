#compdef grip
# Documentation: https://github.com/joeyespo/grip
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for grip - GitHub Readme Instant Preview

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--user-content[render as user content]' \
  '--context[GitHub repo context for user content]:user/repo' \
  '--user[GitHub username for API auth]:username' \
  '--pass[GitHub password or token for API auth]:password' \
  '--wide[render wide page]' \
  '--clear[clear cached files]' \
  '--quiet[do not print to terminal]' \
  '(-b --browser)'{-b,--browser}'[open browser tab on start]' \
  '--api-url[use specified GitHub API URL]:url' \
  '--title[custom page title]:title' \
  '--norefresh[do not auto-refresh on change]' \
  '--export[export to file]:output file:_files' \
  '1:path or URL:_files' \
  '2:port'
