#compdef smbclient-cli
# _smbclient-cli — Samba smbclient FTP-like client to access SMB/CIFS resources CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_smbclient-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-R+[name resolve order]:str:' \
        '--name-resolve=+[name resolve order]:str:' \
        '-M+[message]:str:' \
        '--message=+[hostname]:host:_hosts' \
        '-I+[ip address]:str:' \
        '--ip-address=+[ip address]:str:' \
        '-E[stderr]' \
        '--stderr[stderr]' \
        '-L+[list services]:host:_hosts' \
        '--list=+[host]:host:_hosts' \
        '-m+[max protocol]:m:(CORE COREPLUS LANMAN1 LANMAN2 NT1 SMB2 SMB2_02 SMB2_10 SMB2_22 SMB2_24 SMB3 SMB3_00 SMB3_02 SMB3_10 SMB3_11)' \
        '--max-protocol=+[max protocol]:m:(CORE COREPLUS LANMAN1 LANMAN2 NT1 SMB2 SMB2_02 SMB2_10 SMB2_22 SMB2_24 SMB3 SMB3_00 SMB3_02 SMB3_10 SMB3_11)' \
        '-T+[tar options]:str:' \
        '--tar=+[tar options]:str:' \
        '-D+[directory]:str:' \
        '--directory=+[directory]:str:' \
        '-c+[commands]:str:' \
        '--command=+[commands]:str:' \
        '-b+[buffer size]:n:' \
        '--send-buffer=+[buffer size]:n:' \
        '-t+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '-p+[port]:port:' \
        '--port=+[port]:port:' \
        '-g[grep mode]' \
        '--grepable[grepable]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-B+[browse]:str:' \
        '--browse[browse]' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[debug level]:n:' \
        '--debug-stdout[debug to stdout]' \
        '-s+[config file]:file:_files -g "smb.conf"' \
        '--configfile=+[config file]:file:_files -g "smb.conf"' \
        '-l+[log basename]:str:' \
        '--log-basename=+[log basename]:str:' \
        '--option=+[name=value]:str:' \
        '-U+[user]:_users' \
        '--user=+[user]:_users' \
        '-N[no password]' \
        '--no-pass[no password]' \
        '-k[use kerberos]' \
        '--use-kerberos=+[mode]:m:(off desired required)' \
        '--use-kerberos-ccache=+[cache]:file:_files' \
        '-A+[auth file]:file:_files' \
        '--authentication-file=+[auth file]:file:_files' \
        '-W+[workgroup]:str:' \
        '--workgroup=+[workgroup]:str:' \
        '-S+[sign]:s:(on off auto required desired)' \
        '--client-protection=+[level]:l:(default sign encrypt)' \
        '-P[machine account]' \
        '--machine-pass[machine account]' \
        '-e[encrypted]' \
        '--encrypt[encrypted]' \
        '*:service:'
}

_smbclient-cli "$@"
