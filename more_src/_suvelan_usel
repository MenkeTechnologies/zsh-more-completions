#compdef suvelan_usel
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/velocity_analysis/suvelan_usel.c
# compute stacking velocity panel for cdp gathers using UnNormalized Selective CrossCorrelation Sum

local ret=1

_arguments -s -S \
  'nx=[number of traces in cdp]:traces' \
  'dx=[offset increment]:dx' \
  'nv=[number of velocities]:n' \
  'dv=[velocity sampling interval]:dv' \
  'fv=[first velocity]:fv' \
  'tau=[threshold for significance values]:tau' \
  'smute=[NMO stretch mute factor]:smute' \
  'dtratio=[ratio of output to input time sampling intervals]:dtratio' \
  'nsmooth=[length of smoothing window]:nsmooth' \
  'pwr=[semblance value to the power]:pwr' \
  'verbose=[=1 for diagnostic print on stderr]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
