#compdef rvlc
# Documentation: https://man.archlinux.org/search?q=rvlc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--verbose)'{-v,--verbose}'[increase verbosity]' \
  '--rc-fake-tty[fake TTY for rc]' \
  '--rc-host=[bind rc host:port]:host:' \
  '--rc-quiet[reduce rc verbosity]' \
  '--play-and-exit[exit after playback]' \
  '--loop[loop playlist]' \
  '--no-video[disable video]' \
  '--no-audio[disable audio]' \
  '*:input:_files' && ret=0

return ret
