#compdef rvlc
# Documentation: https://wiki.videolan.org/VLC_command-line_help
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# rvlc is the "remote control" CLI build of VLC (vlc --intf rc); accepts the
# standard VLC option set plus the rc-interface specific options. Only the
# rc-* options are pinned here; users should consult `vlc --longhelp` for the
# full VLC option set, which is too large to maintain inline.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--longhelp[show long help]' \
  '(- *)--version[show version]' \
  '(--verbose)'{-v,--verbose}'+[verbosity level]:level' \
  '(-q --quiet)'{-q,--quiet}'[suppress messages]' \
  '--rc-fake-tty[fake TTY for the rc interface]' \
  '--rc-host=[host\:port the rc interface listens on]:host\:port:' \
  '--rc-quiet[suppress rc interface output]' \
  '*:input:_files' && ret=0

return ret
