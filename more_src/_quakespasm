#compdef quakespasm darkplaces yamagi-quake2

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-basedir+[base directory]:dir:_files -/' \
  '-game+[mod/gamedir]:gamedir:' \
  '-condebug[log console output to file]' \
  '-conwidth+[console width]:n:' \
  '-conheight+[console height]:n:' \
  '-width+[screen width]:n:' \
  '-height+[screen height]:n:' \
  '-bpp+[color depth bits]:bpp:(16 24 32)' \
  '-window[windowed mode]' \
  '-fullscreen[fullscreen mode]' \
  '-nosound[disable sound]' \
  '-sndspeed+[sound rate Hz]:hz:' \
  '-sndcdrom[disable CD audio]' \
  '-zone+[zone memory KB]:kb:' \
  '-mem+[memory pool MB]:mb:' \
  '-noudp[disable UDP networking]' \
  '-port+[net port]:port:' \
  '-noexit[do not exit on win]' \
  '-protocol+[network protocol version]:n:' \
  '-listen+[max players]:n:' \
  '-dedicated+[dedicated server players]:n:' \
  '-noreloadcfg[do not reload config]' \
  '-nocsqc[disable client QC]' \
  '-particles+[max particles]:n:' \
  '-no-mouse[disable mouse]' \
  '-nojoy[disable joystick]' \
  '*+set[set cvar]:cvar:' \
  '*+exec+[execute cfg]:file:_files' \
  '*+map+[start map]:map:' \
  '*+connect+[connect to server]:addr:' \
  '*: :_files' && ret=0

return ret
