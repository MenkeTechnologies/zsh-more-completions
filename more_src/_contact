#compdef contact
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# CCP4: compute various types of contacts in a structure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input PDB file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  '*:keyword:(MODE ATYPE LIMITS SOURCE TARGET SPACEGROUP SYMM SYMTIT ANGLE HOH METAL BIGSEARCH HEXCLUDE NOLIST TITLE FROM TO)' && ret=0

return ret
