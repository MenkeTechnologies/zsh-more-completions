#compdef bcc
# _bcc — Dev86 Bruce Evans bcc CLI Bruce C Compiler small simple C compiler for 16-bit 8086 8088 80186 80286 targets producing MSDOS COM EXE Minix-86 OS/2-86 ELKS Linux-8086 a.out output ANSI-C subset with built-in assembler-linker for boot-sector code MS-DOS embedded retro programming (Bruce Evans team, C); custom argparse
# upstream: https://github.com/jbruchon/dev86

_bcc() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-A+[assembler arg]:str:' \
        '-B+[backend path]:dir:_files -/' \
        '-C[preserve comments]' \
        '-D+[define]:str:' \
        '-E[stop after preprocess]' \
        '-G[generate gcc-compatible asm]' \
        '-I+[include dir]:dir:_files -/' \
        '-L+[lib dir]:dir:_files -/' \
        '-M[print prototypes]' \
        '-N[no relocation]' \
        '-O[optimize]' \
        '-P+[preprocessor arg]:str:' \
        '-R+[asm rewriter arg]:str:' \
        '-S[stop after compile]' \
        '-T+[temp dir]:dir:_files -/' \
        '-U+[undef]:str:' \
        '-W+[warning level]:n:' \
        '-X+[crt args]:str:' \
        '-Y+[search dirs]:str:' \
        '-Z+[opt level]:n:' \
        '-c[compile only]' \
        '-d[debug]' \
        '-e[print errors]' \
        '-f[no header lines]' \
        '-g+[gcc opt]:str:' \
        '-i+[i compiler arg]:str:' \
        '-k[keep tmp files]' \
        '-l+[library]:str:' \
        '-m+[machine type]:m:(i86 i386 i86-elks i386-elks)' \
        '-o+[output file]:file:_files' \
        '-p+[pass tmp file]:file:_files' \
        '-s[strip output]' \
        '-t[trace mode]' \
        '-u[unsigned chars]' \
        '-v[verbose]' \
        '-w[no warnings]' \
        '-x+[language]:l:(c assembler none)' \
        '-y+[yacc arg]:str:' \
        '-z+[lib]:str:' \
        '-0[8086 mode]' \
        '-1[80186 mode]' \
        '-2[80286 mode]' \
        '-3[80386 mode]' \
        '-Ml[large model]' \
        '-Ms[small model]' \
        '-Mc[compact model]' \
        '-Mm[medium model]' \
        '-Mt[tiny model]' \
        '-Mh[huge model]' \
        '*:source files:_files -g "*.c *.s *.S *.o *.a *.h"'
}

_bcc "$@"
