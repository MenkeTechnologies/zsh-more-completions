#compdef sbcl

# Zsh completion for SBCL - Steel Bank Common Lisp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--core=[use specified core file]:core file:_files' \
  '--dynamic-space-size=[size of dynamic space in MB]:megabytes' \
  '--control-stack-size=[size of control stack in MB]:megabytes' \
  '--tls-limit=[thread-local storage limit]:limit' \
  '--noinform[suppress startup banner]' \
  '--disable-debugger[disable debugger on error]' \
  '--noprint[suppress REPL printing]' \
  '--script=[run FILE as a script]:file:_files -g "*.lisp"' \
  '--quit[quit after processing options]' \
  '--non-interactive[run non-interactively]' \
  '--eval=[evaluate FORM]:form' \
  '--load=[load FILE]:file:_files -g "*.{lisp,fasl,lsp,cl}"' \
  '--sysinit=[system init file]:file:_files' \
  '--userinit=[user init file]:file:_files' \
  '--no-sysinit[do not load system init file]' \
  '--no-userinit[do not load user init file]' \
  '--disable-ldb[disable low-level debugger]' \
  '--lose-on-corruption[exit on memory corruption]' \
  '--end-runtime-options[end runtime options]' \
  '--end-toplevel-options[end toplevel options]' \
  '*:script file:_files -g "*.{lisp,fasl,lsp,cl}"' && ret=0

return ret
