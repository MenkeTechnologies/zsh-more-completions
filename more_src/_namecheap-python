#compdef namecheap
# Documentation: https://github.com/Bemmu/PyNamecheap/blob/master/namecheap-api-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for namecheap (Python version, PyNamecheap CLI)
# https://github.com/Bemmu/PyNamecheap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--add[add a record]' \
  '--delete[remove a record]' \
  '--list[list existing records]' \
  '--domain=[domain to manage]:domain:' \
  '--type=[record type]:type:(A AAAA CNAME MX NS TXT ALIAS)' \
  '--name=[host/subdomain]:name:' \
  '--address=[record value]:address:' \
  '--ttl=[time-to-live]:ttl:' \
  '--sandbox[use Namecheap Sandbox API]' \
  '--debug[enable debug output]' && ret=0

return ret
