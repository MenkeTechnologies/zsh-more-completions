#compdef namecheap
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for namecheap (Python version)
# https://github.com/argos-p/namecheap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--add[add a record]' \
  '--delete[remove a record]' \
  '--list[list existing records]' \
  '--domain=[domain to manage]:domain:' \
  '--type=[record type]:type:(A AAAA CNAME MX NS TXT ALIAS)' \
  '--name=[host/subdomain]:name:' \
  '--address=[record value]:address:' \
  '--ttl=[time-to-live]:ttl:' \
  '--sandbox[use Namecheap Sandbox API]' && ret=0

return ret
