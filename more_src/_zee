#compdef zee
# Documentation: https://man.archlinux.org/search?q=zee
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--theme=[color theme]:theme' \
  '--config-dir=[config directory]:directory:_directories' \
  '*:file:_files' && return 0
