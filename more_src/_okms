#compdef okms
# Documentation: https://github.com/ovh/okms-cli/blob/main/doc/okms.md
# OVHcloud KMS (Key Management Service) command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'+[path to a non default configuration file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[activate debug mode]' \
  '--profile=[name of the profile]:profile:' \
  '--auth-method=[authentication method to use]:method:(mtls)' \
  '--ca=[path to CA bundle]:file:_files' \
  '--cert=[path to certificate]:file:_files' \
  '--key=[path to key file]:file:_files' \
  '--endpoint=[KMS endpoint URL]:url:' \
  '--output=[output formatting style]:format:(text json)' \
  '--retry=[maximum HTTP retries]:count:' \
  '--timeout=[HTTP request timeout]:duration:' \
  '*:command:(completion configure keys kmip version x509)' && ret=0

return ret
