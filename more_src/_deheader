#compdef deheader
# Documentation: https://man.archlinux.org/search?q=deheader
# Reference accessed: 2026-05-16

# Zsh completion for deheader
# Upstream: Analyze C/C++ files for unnecessary headers
# Conservative fallback — run `deheader --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
