#compdef xclbinutil
# Documentation: https://xilinx.github.io/XRT/master/html/xclbintools.html
# AMD XRT utility to create, modify and report on xclbin container files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show tool version]' \
  '(-i --input)'{-i,--input}'=[input xclbin file]:file:_files -g "*.xclbin"' \
  '(-o --output)'{-o,--output}'=[output xclbin file]:file:_files' \
  '--info=[report xclbin metadata]:file:_files' \
  '--list-sections[list known section names]' \
  '--dump-section=[dump a section to file (SECTION:FMT:FILE)]:section:' \
  '--add-section=[add a section from file]:section:' \
  '--add-merge-section=[add or merge a section]:section:' \
  '--add-replace-section=[add or replace a section]:section:' \
  '--remove-section=[remove a named section]:section:' \
  '--replace-section=[replace a named section]:section:' \
  '--add-pskernel=[add a PS kernel]:value:' \
  '--key-value=[set a key-value metadata pair]:keyvalue:' \
  '--remove-key=[remove a metadata key]:key:' \
  '--add-signature=[add a signature from file]:file:_files' \
  '--remove-signature[remove the signature]' \
  '--get-signature[report the signature]' \
  '--validate-signature[validate the signature]' \
  '--private-key=[private key for signing]:file:_files' \
  '--certificate=[certificate for signing]:file:_files' \
  '--digest-algorithm=[signature digest algorithm]:algo:' \
  '--target=[set the target value]:target:' \
  '--migrate-forward[migrate an older xclbin to the current format]' \
  '--file-check[verify file integrity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:file:_files -g "*.xclbin"' && ret=0

return ret
