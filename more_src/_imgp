#compdef imgp

# Zsh completion for imgp (image resizer/optimizer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-x --res)'{-x,--res}'[output resolution (WxH or percentage)]:resolution' \
  '(-o --optimize)'{-o,--optimize}'[optimize image]' \
  '(-q --quality)'{-q,--quality}'[JPEG quality (1-95)]:quality' \
  '(-n --enlarge)'{-n,--enlarge}'[enlarge smaller images]' \
  '(-p --progressive)'{-p,--progressive}'[make JPEG progressive]' \
  '(-c --convert)'{-c,--convert}'[convert between formats]' \
  '(-e --eraseexif)'{-e,--eraseexif}'[erase EXIF metadata]' \
  '(-f --force)'{-f,--force}'[overwrite source images]' \
  '(-r --recursive)'{-r,--recursive}'[process directories recursively]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-m --mute)'{-m,--mute}'[suppress output]' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite output file]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:image file or directory:_files' && ret=0

return ret
