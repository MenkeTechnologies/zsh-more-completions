#compdef tor-browser tor-browser-bundle

# Zsh completion for Tor Browser launcher

_arguments -s -S \
  '--register-app[register Tor Browser as desktop application]' \
  '--unregister-app[unregister Tor Browser desktop application]' \
  '--detach[detach from calling terminal]' \
  '--verbose[enable verbose output]' \
  '--debugger[enable debugger]' \
  '--help[show help]' \
  '-h[show help]' \
  '--version[show version]' \
  '-v[show version]' \
  '*:URL or file:_files'
