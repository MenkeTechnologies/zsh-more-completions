#compdef caddy
# Documentation: https://caddyserver.com/docs/command-line
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for the Caddy v2 web server CLI.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'adapt:adapt a configuration to native Caddy JSON'
  'add-package:install a Caddy plugin (xcaddy build)'
  'build-info:print Go module build information'
  'completion:generate shell completion script'
  'environ:print the environment'
  'file-server:spin up a production-ready file server'
  'fmt:format a Caddyfile'
  'hash-password:hash a password for the basicauth provider'
  'help:show subcommand help'
  'list-modules:list installed Caddy modules'
  'manpage:generate manpages'
  'remove-package:uninstall a Caddy plugin (xcaddy build)'
  'reload:change the config of a running Caddy instance'
  'respond:run a quick HTTP responder'
  'reverse-proxy:run a quick reverse proxy'
  'run:start the Caddy process and block'
  'start:start the Caddy process in the background'
  'stop:stop a running Caddy process'
  'storage:manage Caddy storage (import/export)'
  'trust:install Caddys local CA root into the trust store'
  'untrust:remove Caddys local CA root from the trust store'
  'upgrade:upgrade Caddy to the latest version'
  'validate:test whether a config file is valid'
  'version:print the version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'caddy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "Caddyfile* *.json *.yaml *.yml"' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json yaml)' \
          '--pidfile=[write PID to file]:file:_files' \
          '(-e --environ)'{-e,--environ}'[print environment before starting]' \
          '--envfile=[load env from file]:file:_files' \
          '(-r --resume)'{-r,--resume}'[use last autosaved config]' \
          '(-w --watch)'{-w,--watch}'[watch config file for changes]' && ret=0 ;;
      (start)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "Caddyfile* *.json *.yaml *.yml"' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json yaml)' \
          '--envfile=[load env from file]:file:_files' \
          '--pidfile=[write PID to file]:file:_files' \
          '(-w --watch)'{-w,--watch}'[watch config file for changes]' && ret=0 ;;
      (stop)
        _arguments \
          '--address=[admin API address]:addr:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json yaml)' && ret=0 ;;
      (reload)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file to apply]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[config adapter]:adapter:(caddyfile json yaml)' \
          '--address=[admin API address]:addr:' \
          '(-f --force)'{-f,--force}'[reload even if unchanged]' && ret=0 ;;
      (adapt)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' \
          '(-p --pretty)'{-p,--pretty}'[pretty-print output]' \
          '--validate[validate adapted config]' && ret=0 ;;
      (validate)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' \
          '--envfile=[env file]:file:_files' && ret=0 ;;
      (fmt)
        _arguments \
          '(-w --overwrite)'{-w,--overwrite}'[write result to input file]' \
          '(-d --diff)'{-d,--diff}'[show diff]' \
          '*:Caddyfile:_files -g "Caddyfile*"' && ret=0 ;;
      (file-server)
        _arguments \
          '(-r --root)'{-r+,--root=}'[root path]:dir:_files -/' \
          '--listen=[listener address]:addr:' \
          '(-d --domain)'{-d+,--domain=}'[hostname to serve over HTTPS]:domain:' \
          '(-b --browse)'{-b,--browse}'[enable directory browsing]' \
          '--reveal-symlinks[show symlink targets]' \
          '(-t --templates)'{-t,--templates}'[enable template rendering]' \
          '--access-log[enable request logging]' \
          '(-v --debug)'{-v,--debug}'[verbose logging]' \
          '(-f --file-limit)'{-f+,--file-limit=}'[max files in directory listing]:n:' \
          '--no-compress[disable response compression]' \
          '(-p --precompressed)'{-p+,--precompressed=}'[search for precompressed encodings]:enc:' && ret=0 ;;
      (reverse-proxy)
        _arguments \
          '(-f --from)'{-f+,--from=}'[listen address]:addr:' \
          '(-t --to)*'{-t+,--to=}'[upstream address]:addr:' \
          '(-H --header-up)*'{-H+,--header-up=}'[request header to upstream]:h:' \
          '(-d --header-down)*'{-d+,--header-down=}'[response header to client]:h:' \
          '(-c --change-host-header)'{-c,--change-host-header}'[modify Host header to upstream]' \
          '(-r --disable-redirects)'{-r,--disable-redirects}'[disable HTTP-to-HTTPS redirect]' \
          '(-i --internal-certs)'{-i,--internal-certs}'[use Caddy-issued internal certs]' \
          '(-v --debug)'{-v,--debug}'[verbose logging]' \
          '--access-log[enable request logging]' \
          '--insecure[skip TLS verify on upstream]' && ret=0 ;;
      (respond)
        _arguments \
          '(-s --status)'{-s+,--status=}'[HTTP status code]:n:' \
          '(-H --header)*'{-H+,--header=}'[response header]:h:' \
          '(-b --body)'{-b+,--body=}'[response body]:s:' \
          '(-l --listen)'{-l+,--listen=}'[listener address]:addr:' \
          '(-v --debug)'{-v,--debug}'[verbose logging]' \
          '--access-log[enable request logging]' && ret=0 ;;
      (hash-password)
        _arguments \
          '(-p --plaintext)'{-p+,--plaintext=}'[plaintext password]:pw:' \
          '(-a --algorithm)'{-a+,--algorithm=}'[hash algorithm]:algo:(argon2id bcrypt)' \
          '--bcrypt-cost=[bcrypt cost]:n:' \
          '--argon2id-time=[argon2id iterations]:n:' \
          '--argon2id-memory=[argon2id memory KB]:n:' \
          '--argon2id-threads=[argon2id threads]:n:' \
          '--argon2id-keylen=[argon2id output length]:n:' && ret=0 ;;
      (trust)
        _arguments \
          '--ca=[CA identifier]:id:' \
          '--address=[admin API address]:addr:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' && ret=0 ;;
      (untrust)
        _arguments \
          '(-p --cert)'{-p+,--cert=}'[certificate file]:file:_files' \
          '--ca=[CA identifier]:id:' \
          '--address=[admin API address]:addr:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-a --adapter)'{-a+,--adapter=}'[adapter]:adapter:(caddyfile json yaml)' && ret=0 ;;
      (list-modules)
        _arguments \
          '--packages[include package information]' \
          '--versions[include version information]' \
          '(-s --skip-standard)'{-s,--skip-standard}'[omit standard modules]' \
          '--json[output as JSON]' && ret=0 ;;
      (manpage)
        _arguments \
          '(-o --directory)'{-o+,--directory=}'[output directory]:dir:_files -/' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (storage)
        _arguments \
          '1:subcommand:(export import)' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output tarball]:file:_files' \
          '(-i --input)'{-i+,--input=}'[input tarball]:file:_files' && ret=0 ;;
      (upgrade|add-package|remove-package)
        _arguments \
          '(-k --keep-backup)'{-k,--keep-backup}'[keep backup after upgrade]' \
          '*:package:' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
