#compdef crashlog

local -a arguments

arguments=(
    '-a[Show all threads]'
    '-i[Interactive mode]'
    '-v[Verbose output]'
    '-o[Output to file]:file:_files'
    '--dsym[Path to dSYM bundle]:dsym:_files -g "*.dSYM"'
    '--image[Image to symbolicate]:image:_files'
    '--verbose[Verbose output]'
    '--debug[Debug output]'
    '*:crash log:_files'
)

_arguments -s -S $arguments
