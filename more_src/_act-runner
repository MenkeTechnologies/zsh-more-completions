#compdef act_runner

# Zsh completion for act_runner (Gitea Actions runner)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'cache-server:start a cache server'
      'daemon:run as daemon'
      'exec:execute a workflow locally'
      'generate-config:generate example config'
      'register:register a runner'
    )
    _describe -t commands 'act_runner command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (register)
        _arguments \
          '--instance[Gitea instance URL]:url' \
          '--token[registration token]:token' \
          '--name[runner name]:name' \
          '--labels[runner labels]:labels' \
          '--config[config file]:file:_files -g "*.{yaml,yml}"' \
          '--no-interactive[non-interactive mode]' && ret=0
        ;;
      (daemon)
        _arguments \
          '--config[config file]:file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
      (exec)
        _arguments \
          '-W[workflow directory]:directory:_files -/' \
          '-j[job ID to run]:job' \
          '-e[event file]:file:_files -g "*.json"' \
          '--default-actions-url[default actions URL]:url' \
          '--gitea-instance[Gitea instance]:url' \
          '--network[container network]:network' \
          '--env[environment variable]:var=value' \
          '--env-file[environment file]:file:_files' \
          '--secret[secret]:key=value' \
          '--secret-file[secrets file]:file:_files' \
          '--input[input]:key=value' \
          '-b[bind working directory]' \
          '--artifact-server-path[artifact server path]:path:_files -/' \
          '--artifact-server-addr[artifact server address]:address' \
          '--artifact-server-port[artifact server port]:port' && ret=0
        ;;
      (generate-config)
        _arguments \
          '(-o --output)'{-o,--output}'[output file]:file:_files' && ret=0
        ;;
      (cache-server)
        _arguments \
          '--dir[cache directory]:directory:_files -/' \
          '--host[listen host]:host' \
          '--port[listen port]:port' && ret=0
        ;;
    esac
    ;;
esac

return ret
