#compdef antq
# Documentation: https://man.archlinux.org/search?q=antq
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--skip-installed[skip already installed dependencies]' \
  '--verbose[verbose output]' \
  '--no-colors[disable ANSI colors]' \
  '--deps-file=[path to deps.edn]:file:_files' \
  '--install-dir=[local install directory]:dir:_files -/' \
  '*:alias or coord:'
