#compdef suslowft
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/transforms/suslowft.c
# Fourier Transform of SU data (slow, demo only, not fft based)

local ret=1

_arguments -s -S \
  'sign=[sign in exponent of fft]:sign:(1 -1)' \
  'dt=[sampling interval]:dt' \
  '*:file:_files' && ret=0

return ret
