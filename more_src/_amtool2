#compdef amtool2
# _amtool2 — Prometheus amtool2 CLI command-line frontend wrapping the Alertmanager amtool utility for querying creating silences expiring silences listing alerts adding alerts checking config testing routes cluster-status formatted output JSON YAML simple AMQP-style filtering authentication-bearer-token TLS HTTP-proxy basicauth (Prometheus CNCF team, Go); kingpin
# upstream: https://github.com/prometheus/alertmanager

_amtool2() {
    local -a sub=(
        'alert:alert operations'
        'silence:silence operations'
        'check-config:check config'
        'config:show server config'
        'cluster:cluster operations'
        'template:template operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--alertmanager.url=+[url]:str:' \
        '--http.config.file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--timeout=+[d]:str:' \
        '--tls-config=+[file]:file:_files -g "*.yml *.yaml"' \
        '--author=+[name]:str:' \
        '-a+[author]:str:' \
        '--comment=+[text]:str:' \
        '-c+[comment]:str:' \
        '--output=+[fmt]:f:(simple extended json)' \
        '-o+[output]:f:(simple extended json)' \
        '--date.format=+[fmt]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amtool subcommand' sub ;;
        args)
            case $words[1] in
                alert) _arguments '1:op:(query add)' '*:matcher:' ;;
                silence) _arguments '1:op:(add query expire import update)' '*:matcher:' ;;
                config) _arguments '1:op:(show routes)' '*:arg:' ;;
                cluster) _arguments '1:op:(show)' '*:arg:' ;;
                template) _arguments '1:op:(render)' '*:arg:' ;;
                check-config) _arguments '*:file:_files -g "*.yml *.yaml"' ;;
            esac
            ;;
    esac
}

_amtool2 "$@"
