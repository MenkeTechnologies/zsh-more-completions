#compdef kubectl-exec-cronjob
# kubectl-exec-cronjob (krew plugin): run a CronJob immediately
# https://github.com/thatisuday/kubectl-exec-cronjob

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '1:cronjob name'
