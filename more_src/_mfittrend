#compdef mfittrend
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss115.html
# KAPPA: fit independent trends to data lines in an NDF

local ret=1

_arguments -s \
  'AUTO=[calculate fitting ranges automatically]:auto:(TRUE FALSE)' \
  'AXIS=[axis direction defining the trends]:axis' \
  'CLIP=[clipping limits for range detection]:clip' \
  'FITTYPE=[polynomial or cubic B-spline]:fittype' \
  'FOREST=[special handling for emission lines]:forest:(TRUE FALSE)' \
  'KNOTS=[number of interior knots for spline]:knots' \
  'IN=[input NDF to be processed]:NDF:_files' \
  'INTERPOL=[interpolating or smoothing spline]:interpol:(TRUE FALSE)' \
  'MASK=[output NDF with the feature mask]:NDF:_files' \
  'METHOD=[masking strategy in automatic mode]:method:(Region Single Global)' \
  'MODIFYIN=[modify the input NDF directly]:modifyin:(TRUE FALSE)' \
  'NUMBIN=[number of bins for compressing trends]:numbin' \
  'ORDER=[polynomial order for fitting]:order' \
  'OUT=[output NDF with trends or residuals]:NDF:_files' \
  'POSKNOT=[coordinates of interior knots]:posknot' \
  'PROPBAD=[propagate bad pixels to output]:propbad:(TRUE FALSE)' \
  'RANGES=[coordinate pairs defining fit regions]:ranges' \
  'RMSCLIP=[threshold for rejecting poor fits]:rmsclip' \
  'SECTION=[region for averaging representative lines]:section' \
  'SUBTRACT=[remove fitted trends from data]:subtract:(TRUE FALSE)' \
  'TITLE=[title for the output NDF]:title' \
  'VARIANCE=[use variance weighting]:variance:(TRUE FALSE)' \
  '*:NDF:_files' && ret=0

return ret
