#compdef gomplate

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[input template file]:file:_files' \
  '(-i --in)'{-i,--in}'[input template string]:template' \
  '--input-dir=[input directory]:directory:_directories' \
  '(-o --out)'{-o,--out}'[output file]:file:_files' \
  '--output-dir=[output directory]:directory:_directories' \
  '--output-map=[output mapping template]:template' \
  '(-d --datasource)'{-d,--datasource}'[data source]:alias=url' \
  '(-c --context)'{-c,--context}'[data source for default context]:alias=url' \
  '--datasource-header=[set header for data source]:alias=header=value' \
  '--plugin=[register plugin]:plugin' \
  '--left-delim=[override left delimiter]:delimiter' \
  '--right-delim=[override right delimiter]:delimiter' \
  '--missing-key=[missing key behavior]:behavior:(zero error default invalid)' \
  '--exec-pipe[pipe output to command]' \
  '--chmod=[output file permissions]:mode' \
  '--experimental[enable experimental features]' \
  '--verbose[verbose output]' \
  '*:command:_command_names -e' && ret=0

return ret
