#compdef ESMF_Regrid
# Documentation: https://earthsystemmodeling.org/docs/release/latest/ESMF_refdoc/node3.html
# ESMF: generate and apply interpolation weights to variables in a file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the usage message and exit]' \
  '(-s --source)'{-s,--source}'[source grid file name]:source grid file:_files' \
  '(-d --destination)'{-d,--destination}'[destination grid file name]:destination grid file:_files' \
  '--src_var[source variable name(s) to regrid]:var_name' \
  '--dst_var[destination variable name(s) for output]:var_name' \
  '--srcdatafile[data file for a GRIDSPEC MOSAIC source grid]:file:_files' \
  '--dstdatafile[data file for a GRIDSPEC MOSAIC destination grid]:file:_files' \
  '--tilefile_path[alternative file path for tile files]:path:_files -/' \
  '--dst_loc[destination regridding location]:loc:(center corner)' \
  '(-m --method)'{-m,--method}'[interpolation method]:method:(bilinear patch nearestdtos neareststod conserve conserve2nd)' \
  '(-p --pole)'{-p,--pole}'[pole extrapolation strategy]:pole:(none all teeth 1 2)' \
  '(-i --ignore_unmapped)'{-i,--ignore_unmapped}'[ignore unmapped destination points]' \
  '--ignore_degenerate[ignore degenerate cells in input grids]' \
  '-r[both source and destination grids are regional]' \
  '--src_regional[source grid is regional]' \
  '--dst_regional[destination grid is regional]' \
  '--check[check correctness of the interpolated destination field]' \
  '--no_log[turn off the ESMF error log]' \
  '--version[print ESMF version and license information and exit]' \
  '-V[print ESMF version number and exit]' && ret=0

return ret
