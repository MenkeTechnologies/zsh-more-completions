#compdef qquota
# Documentation: https://github.com/interlynk-io
# Grid Engine: show current resource quota set usage

local ret=1

_arguments -s \
  '-help[print a listing of all options]' \
  '-h+[restrict to quota sets matching the given hosts/hostgroups]:hosts' \
  '-l+[restrict to quota sets matching the given resources]:resources' \
  '-u+[restrict to quota sets matching the given users]:users' \
  '-P+[restrict to quota sets matching the given projects]:projects' \
  '-pe+[restrict to quota sets matching the given parallel environments]:pe' \
  '-q+[restrict to quota sets matching the given cluster queues]:queues' \
  '-xml[produce XML output]' && ret=0

return ret
