#compdef bg5conv
# Documentation: bg5conv (CJK 4.8.5)
# Source: Big5 → CJK macro-friendly preprocessor; reads stdin, writes stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*:tex file (or stdin):_files -g "*.tex"' \
    && ret=0

return ret
