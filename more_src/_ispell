#compdef ispell
# _ispell — International Ispell ispell CLI interactive spell-checker for English Esperanto Czech French German Norwegian Russian etc. on plain text TeX HTML nroff troff with hash-table compiled affix-aware suggestions skip-environment word-list addition private wordlist generation (Geoff Kuenning team, C); getopt
# upstream: https://www.cs.hmc.edu/~geoff/ispell.html

_ispell() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-V[8-bit display]' \
        '-a[ispell pipe mode]' \
        '-A[ispell pipe with #include]' \
        '-b[create backup file]' \
        '-x[do not create backup]' \
        '-B[require run-together words]' \
        '-C[allow run-together words]' \
        '-P[do not generate extra root/affix]' \
        '-m[generate extra root/affix]' \
        '-N[suppress case-sensitivity]' \
        '-S[sort suggestions]' \
        '-T+[input formatter]:t:(latex tex nroff html sgml xml)' \
        '-t[input is TeX]' \
        '-n[input is nroff/troff]' \
        '-H[input is HTML SGML]' \
        '-d+[dict file]:file:_files -g "*.aff *.dict *.hash"' \
        '-p+[personal dict]:file:_files' \
        '-w+[word chars]:str:' \
        '-W+[word len]:n:' \
        '-l[list misspelled words on stdout]' \
        '-c[compute hash table]' \
        '-e[expand affix]' \
        '-e1[expand without verbose]' \
        '-D[dump expanded affix]' \
        '-r+[charset]:str:' \
        '-M[show menu]' \
        '-N[no menu]' \
        '-L+[context lines]:n:' \
        '-k+[skip pattern]:str:' \
        '*:text file:_files'
}

_ispell "$@"
