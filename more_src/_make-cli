#compdef make
# _make-cli — GNU Make build automation (FSF, C); canonical UNIX dependency-driven build runner
# upstream: https://savannah.gnu.org/git/?group=make

_make-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-B[always make]' \
        '--always-make[always make]' \
        '-C+[change to dir]:dir:_files -/' \
        '--directory+[change to dir]:dir:_files -/' \
        '-d[debug mode]' \
        '--debug+[debug level]:level:(b v i j m)' \
        '-e[env-vars beat makefiles]' \
        '--environment-overrides[env-vars beat makefiles]' \
        '-E+[evaluate string]:str:' \
        '--eval+[evaluate string]:str:' \
        '-f+[makefile]:file:_files -g "[Mm]akefile*"' \
        '--file+[makefile]:file:_files -g "[Mm]akefile*"' \
        '--makefile+[makefile]:file:_files -g "[Mm]akefile*"' \
        '-i[ignore errors]' \
        '--ignore-errors[ignore errors]' \
        '-I+[include dir]:dir:_files -/' \
        '--include-dir+[include dir]:dir:_files -/' \
        '-j+[jobs]:n:' \
        '--jobs+[jobs]:n:' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-l+[load avg]:f:' \
        '--load-average+[load avg]:f:' \
        '--max-load+[load avg]:f:' \
        '-L[follow symlinks]' \
        '--check-symlink-times[follow symlinks]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '--just-print[dry run]' \
        '--recon[dry run]' \
        '-o+[old file]:file:_files' \
        '--old-file+[old file]:file:_files' \
        '--assume-old+[old file]:file:_files' \
        '-O+[output sync]:type:(target line recurse none)' \
        '--output-sync+[output sync]:type:(target line recurse none)' \
        '-p[print database]' \
        '--print-data-base[print database]' \
        '-q[question]' \
        '--question[question]' \
        '-r[no built-in rules]' \
        '--no-builtin-rules[no built-in rules]' \
        '-R[no built-in variables]' \
        '--no-builtin-variables[no built-in variables]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--quiet[silent]' \
        '-S[no keep going]' \
        '--no-keep-going[no keep going]' \
        '--stop[no keep going]' \
        '-t[touch]' \
        '--touch[touch]' \
        '--trace[trace]' \
        '-W+[what-if file]:file:_files' \
        '--what-if+[what-if file]:file:_files' \
        '--new-file+[what-if file]:file:_files' \
        '--assume-new+[what-if file]:file:_files' \
        '--warn-undefined-variables[warn undefined vars]' \
        '*:target:'
}

_make-cli "$@"
