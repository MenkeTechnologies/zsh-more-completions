#compdef 1dTsort
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dTsort.html
# Sort each column of the input 1D file and write to stdout

local ret=1

_arguments -s -S \
  '-inc[sort into increasing order (default)]' \
  '-dec[sort into decreasing order]' \
  '-flip[transpose the file before output]' \
  '-col[sort only on column #j and carry rest with it]:j' \
  '-imode[typecast values to integers, return the mode then exit]' \
  '*:file:_files' && ret=0

return ret
