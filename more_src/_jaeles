#compdef jaeles

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'scan:scan URLs against selected signatures'
  'server:start the Jaeles API server'
  'config:configure Jaeles (signatures, plugins, output)'
  'report:generate an HTML report from scan output'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --concurrency)'{-c+,--concurrency=}'[concurrency]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-D --debug)'{-D,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-J --json)'{-J,--json}'[JSON output]' \
  '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
  '--config=[Jaeles config file]:file:_files' \
  '--passive[passive scan only]' \
  '--no-output[disable output]' \
  '--no-db[disable database]' \
  '--show-time[show time]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jaeles command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '(-u --url)'{-u+,--url=}'[target URL]:url:' \
          '(-U --urls)'{-U+,--urls=}'[file with target URLs]:file:_files' \
          '(-r --raw)'{-r+,--raw=}'[raw HTTP request file]:file:_files' \
          '(-s --signature)*'{-s+,--signature=}'[signature pattern]:pattern:' \
          '(-x --exclude)*'{-x+,--exclude=}'[exclude signature pattern]:pattern:' \
          '(-L --level)'{-L+,--level=}'[run signatures of given level]:level:(0 1 2 3 4 5)' \
          '(-G --select)'{-G+,--select=}'[selector for signatures]:selector:' \
          '(-p --params)*'{-p+,--params=}'[scan params (k=v)]:param:' \
          '(-l --filter)*'{-l+,--filter=}'[filter response]:filter:' \
          '(-H --headers)*'{-H+,--headers=}'[custom HTTP header]:header:' \
          '--ba=[basic auth user:pass]:auth:' \
          '--proxy=[HTTP proxy]:url:' \
          '--timeout=[per-request timeout]:seconds:' \
          '--single[single target mode]' \
          '--ssrf=[SSRF callback URL]:url:' \
          '--blc=[Blind XSS callback URL]:url:' \
          '--retry=[retries on failure]:n:' \
          '--mics=[micro-scan flags]:flags:' \
          '--http-port=[port for raw HTTP]:port:' \
          '--save-raw[save raw output]' \
          '--report-name=[report file name]:name:' && ret=0 ;;
      (server)
        _arguments \
          '(-b --bind)'{-b+,--bind=}'[bind address]:address:' \
          '(-A --user)'{-A+,--user=}'[basic auth user]:user:' \
          '(-S --pass)'{-S+,--pass=}'[basic auth password]:pass:' \
          '--no-auth[disable auth]' \
          '--no-cors[disable CORS]' && ret=0 ;;
      (config)
        _arguments '*::sub:(init reload update clean cred)' && ret=0 ;;
      (report)
        _arguments \
          '(-o --output)'{-o+,--output=}'[report output]:file:_files' \
          '--title=[report title]:title:' \
          '--template=[template file]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
