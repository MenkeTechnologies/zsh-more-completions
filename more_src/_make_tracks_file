#compdef make_tracks_file
# Documentation: https://pygenometracks.readthedocs.io/en/latest/content/usage.html
# pyGenomeTracks - generate a tracks.ini configuration file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-f,--trackFiles=}'[files to use for the tracks (type from extension)]:file:_files' \
  '(-o --out)'{-o,--out=}'[location where the configuration file will be saved]:file:_files' \
  '--version[show version]' && ret=0

return ret
