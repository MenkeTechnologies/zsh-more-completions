#compdef sunearcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sunearcsv.c
# SUNEARCSV - assign trace key values from nearest Q-file record

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'keyp=[key names for proximity matching]:k:' \
  'okeys=[output key names to assign]:k:' \
  'maxr=[maximum number of records]:m:' \
  'minr=[minimum number of records]:m:' \
  'sdist=[search distance]:s:' \
  'smult=[search distance multiplier]:s:' \
  'sfunc=[search function]:s:' \
  'nopoint=[value when no point found]:n:' \
  'typer=[record type]:t:' \
  'Type=[input type option]:t:' \
  'dimx=[x dimension]:d:' \
  'dimy=[y dimension]:d:' \
  'dimr=[r dimension]:d:' \
  'dima=[a dimension]:d:' \
  'dimb=[b dimension]:d:' \
  'dimc=[c dimension]:d:' \
  'dimd=[d dimension]:d:' \
  'dime=[e dimension]:d:' \
  'dimf=[f dimension]:d:' \
  '*:SU file:_files' && ret=0

return ret
