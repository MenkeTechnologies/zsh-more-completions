#compdef runtest
# Documentation: https://manpages.debian.org/bookworm/dejagnu/runtest.1.en.html
# Reference accessed: 2026-05-21
# Verified: dejagnu runtest(1) Debian manpage.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[print all output]' \
  '--log_dialog[send Expect output to stdout]' \
  '--debug[enable Expect internal debugging]' \
  '-D+[activate Tcl debugger]:level:(0 1)' \
  '*--ignore=[ignore tests]:test:_files -g "*.exp"' \
  '--objdir=[obj dir]:dir:_files -/' \
  '--outdir=[output dir]:dir:_files -/' \
  '--srcdir=[source dir]:dir:_files -/' \
  '--directory=[run tests from directory]:dir:_files -/' \
  '--build=[build triplet]:triplet:' \
  '--host=[host triplet]:triplet:' \
  '--target=[target triplet]:triplet:' \
  '--target_board=[target board name]:board:' \
  '--host_board=[host board name]:board:' \
  '--tool=[tool name]:tool:' \
  '--tool_exec=[tool exec path]:file:_files' \
  '--tool_opts=[tool options]:opts:' \
  '--global_init=[global init file]:file:' \
  '--local_init=[local init file]:file:' \
  '--mail=[email addresses]:addrs:' \
  '--reboot[reboot target board on init]' \
  '(-x --xml)'{-x,--xml}'[output XML]' \
  '--strace=[strace level]:n:' \
  '*'{-v,--verbose}'[verbose (repeatable)]' \
  '*:test file:_files -g "*.exp"' && ret=0

return ret
