#compdef fluttergen
# Documentation: https://pub.dev/packages/flutter_gen
# fluttergen - generate Dart code for assets, fonts and colors from pubspec.yaml

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '-c+[specify configuration file]:config:_files -g "*.yaml"' \
  '--workspace[treat config as workspace root and generate for each member]' \
  '--build=[inline configuration overrides]:config:' && ret=0

return ret
