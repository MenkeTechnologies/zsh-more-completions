#compdef zz
# ============================================================================
# _zz — zsh completion for the ZetZ programming language compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/zetzit/zz  (mirror: github.com/aep/zz)
#   Author     : Arvid E. Picciani <aep@exys.org>
#   License    : MIT OR Apache-2.0
#   Language   : Rust (compiler) / ZetZ (.zz source files)
#   Crate      : zz v0.1.1
#   Binary     : zz  (Cargo.toml [[bin]] name = "zz")
#   Last push  : 2022-06-17
#
# WHAT IT IS
#   ZetZ (a.k.a. "Drunk Octopus", the App::new() name in the CLI) is "a
#   symbolic verifier and transpiler to bare metal C" — Arvid E. Picciani's
#   experimental low-level systems programming language with a built-in
#   SMT-solver-backed symbolic verifier.  The compiler is implemented in
#   Rust on top of the pest grammar generator, parses `.zz` modules,
#   verifies pre/post-conditions and integer-overflow / out-of-bounds
#   safety using an SMT solver, then transpiles to plain C suitable for
#   compilation on resource-constrained microcontrollers.  The project
#   tagline calls it "the language for the bare metal" — typical
#   deployment targets include embedded firmware and small kernel modules
#   where formal safety proofs help substitute for runtime checks.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap App::new("Drunk Octopus")
#                       chain — clap v2 builder API)
#   zz [GLOBAL] <command> [command-options]
#
#   Global option:
#     --smt-timeout <SECONDS>     Time limit for the SMT solver (sets
#                                 `zz::smt::TIMEOUT` via .store())
#
#   Subcommands (all clap-v2 SubCommand definitions):
#     init                        Init a zz project in the current directory
#     clean                       Remove the target directory
#     check [SOURCEFILE]          Check the current project (type/SMT verify)
#       -0, --slow                Use the slow (more thorough) SMT pipeline
#       -s, --variant <VARIANT>   Build variant selector
#           --release             Use release-mode build settings
#           --debug               Use debug-mode build settings
#     build [ARTIFACT]            Build the current project
#       -0, --slow
#       -s, --variant <VARIANT>
#           --release / --debug
#           --export              Export the generated C sources
#     run [ARGS...]               Build and run
#           --release / --debug
#       -s, --variant <VARIANT>
#     test [TESTNAME]             Execute tests/*.zz
#     bench [TESTNAME]            Benchmark tests/*.zz
#     fuzz [TESTNAME]             Execute tests/*.zz with the afl fuzzer
#
# LANGUAGE-CORPUS POSITION
#   ZetZ is the 142nd programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R837 (_blendr/btleplug
#   Rust=117 opens Axis 62) and continued through R838 (_ringcli/tinygo
#   bluetooth Go=117) and R839 (_am43ctrl/@abandonware/noble TS-Node=117
#   CLOSES Axis 62 Bluetooth Low Energy Library at 1/1/1 + triple-117
#   landmark + 55 axes at 1/1/1).  ZetZ joins the roster of exotic
#   languages already in the corpus including Granule (R836 141st),
#   Sixten (R832 140th — round-number language milestone), Imba (R828
#   139th), Tao (R824 138th), Dada (R820 137th), Acton (R816 136th),
#   Stanza (R812 135th), Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth,
#   Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `zz` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_zz() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--smt-timeout=[SMT solver timeout (seconds)]:seconds:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_zz_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)    _arguments '(- *)'{-h,--help}'[help for init]' && ret=0 ;;
                clean)   _arguments '(- *)'{-h,--help}'[help for clean]' && ret=0 ;;
                check)   _zz_check  && ret=0 ;;
                build)   _zz_build  && ret=0 ;;
                run)     _zz_run    && ret=0 ;;
                test)    _zz_test   && ret=0 ;;
                bench)   _zz_bench  && ret=0 ;;
                fuzz)    _zz_fuzz   && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_zz_commands] )) ||
_zz_commands() {
    local -a commands
    commands=(
        'init:init a zz project in the current directory'
        'clean:remove the target directory'
        'check:check the current project (type + SMT verify)'
        'build:build the current project'
        'run:build and run'
        'test:execute tests/*.zz'
        'bench:benchmark tests/*.zz'
        'fuzz:execute tests/*.zz with the afl fuzzer'
    )
    _describe -t commands 'zz command' commands
}

(( $+functions[_zz_check] )) ||
_zz_check() {
    _arguments \
        '(-0 --slow)'{-0,--slow}'[use the slow (more thorough) SMT pipeline]' \
        '(-s --variant)'{-s+,--variant=}'[build variant selector]:variant:' \
        '--release[release-mode build settings]' \
        '--debug[debug-mode build settings]' \
        '(- *)'{-h,--help}'[help for check]' \
        ':source file:_files -g "*.zz"'
}

(( $+functions[_zz_build] )) ||
_zz_build() {
    _arguments \
        '(-0 --slow)'{-0,--slow}'[use the slow (more thorough) SMT pipeline]' \
        '(-s --variant)'{-s+,--variant=}'[build variant selector]:variant:' \
        '--release[release-mode build settings]' \
        '--debug[debug-mode build settings]' \
        '--export[export the generated C sources]' \
        '(- *)'{-h,--help}'[help for build]' \
        ':artifact name:'
}

(( $+functions[_zz_run] )) ||
_zz_run() {
    _arguments \
        '--release[release-mode build settings]' \
        '--debug[debug-mode build settings]' \
        '(-s --variant)'{-s+,--variant=}'[build variant selector]:variant:' \
        '(- *)'{-h,--help}'[help for run]' \
        '*:program args:'
}

(( $+functions[_zz_test] )) ||
_zz_test() {
    _arguments \
        '(- *)'{-h,--help}'[help for test]' \
        ':test name:'
}

(( $+functions[_zz_bench] )) ||
_zz_bench() {
    _arguments \
        '(- *)'{-h,--help}'[help for bench]' \
        ':test name:'
}

(( $+functions[_zz_fuzz] )) ||
_zz_fuzz() {
    _arguments \
        '(- *)'{-h,--help}'[help for fuzz]' \
        ':test name:'
}

_zz "$@"
