#compdef xenpvnetboot

# xenpvnetboot: PV netboot kernel for Xen
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[command line]:cmdline:' \
  '-k[kernel URL]:url:' \
  '-r[ramdisk URL]:url:' \
  '*::xenpvnetboot args:_files' && ret=0
return ret
