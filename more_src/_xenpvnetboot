#compdef xenpvnetboot
# Documentation: https://man.archlinux.org/search?q=xenpvnetboot
# Reference accessed: 2026-05-16

# xenpvnetboot: PV netboot kernel for Xen
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-c[command line]:cmdline:' \
  '-k[kernel URL]:url:' \
  '-r[ramdisk URL]:url:' \
  '*::xenpvnetboot args:_files' && ret=0
return ret
