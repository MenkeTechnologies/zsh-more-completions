#compdef xenpvnetboot
# Documentation: https://github.com/Xilinx/xen/blob/master/tools/misc/xenpvnetboot
# Reference accessed: 2026-05-21
# Verified: xenpvnetboot Python source (optparse). Note: upstream xen-project
# removed this tool (CHANGELOG: "xenpvnetboot removed as unable to convert to Python 3").

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--location=[base url for kernel and ramdisk files]:url:' \
  '--kernel=[kernel image file]:file:' \
  '--ramdisk=[initial ramdisk file]:file:' \
  '--args=[arguments to pass to the kernel]:args:' \
  '--output=[redirect output to this file]:file:_files' \
  '--output-directory=[output directory]:dir:_directories' \
  '--output-format=[output format]:format:(sxp simple simple0)' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' && ret=0
return ret
