#compdef xyce
# Sandia National Labs parallel electronic circuit simulator (SPICE-compatible)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '-syntax[check netlist syntax only]' \
  '-norun[parse netlist without running simulation]' \
  '-l[log file]:file:_files' \
  '-o[output file]:file:_files' \
  '-r[results file]:file:_files' \
  '-a[append to output files]' \
  '-per[percent error for restarts]:percent:' \
  '-prf[print reference file]:file:_files' \
  '-nox[suppress X11 graphics]' \
  '-delim[output delimiter]:delimiter:(tab comma)' \
  '-quiet[suppress banner output]' \
  '-randseed[random number seed]:seed:' \
  '*:netlist file:_files -g "*.(cir|net|sp)"' \
  && return 0
