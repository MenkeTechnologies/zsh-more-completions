#compdef elasticsearch-reset-password
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/reset-password.html
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  {-u,--username}'[the username to reset password for]:username' \
  {-i,--interactive}'[set password interactively]' \
  {-b,--batch}'[run in batch mode without prompting]' \
  {-f,--force}'[force the command to run against an unhealthy cluster]' \
  {-s,--silent}'[show minimal output]' \
  '-E[configure a setting]:setting' \
  '--url[specify the Elasticsearch URL to connect to]:url' \
  && return 0
