#compdef cargo-tools
# _cargo-tools — cargo extension dispatcher (community); convenience alias around cargo subcommand tools
# upstream: https://github.com/rust-lang/cargo

_cargo-tools() {
    local -a sub=(
        'audit:cargo-audit'
        'bloat:cargo-bloat'
        'clippy:cargo-clippy'
        'criterion:cargo-criterion'
        'deny:cargo-deny'
        'edit:cargo-edit'
        'expand:cargo-expand'
        'flamegraph:cargo-flamegraph'
        'fuzz:cargo-fuzz'
        'generate:cargo-generate'
        'hack:cargo-hack'
        'install:cargo install'
        'list:list installed extensions'
        'machete:cargo-machete'
        'modules:cargo-modules'
        'nextest:cargo-nextest'
        'outdated:cargo-outdated'
        'tarpaulin:cargo-tarpaulin'
        'tree:cargo tree'
        'udeps:cargo-udeps'
        'watch:cargo-watch'
        'workspaces:cargo-workspaces'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cargo-tools subcommand' sub ;;
    esac
}

_cargo-tools "$@"
