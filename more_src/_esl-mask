#compdef esl-mask

# Easel esl-mask: mask regions of a sequence file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-x[mask character]:char:' \
  '-o[output file]:file:_files' \
  '-i[invert mask - mask non-listed regions]' \
  '-R[treat input as reverse-complement coords]' \
  '--informat[input format]:fmt:(fasta embl genbank uniprot)' \
  '--outformat[output format]:fmt:(fasta embl genbank uniprot)' \
  '*:sequence file and mask coords:_files' && ret=0
return ret
