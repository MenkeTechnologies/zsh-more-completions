#compdef ceph-detect-init
# Documentation: https://man.archlinux.org/search?q=ceph-detect-init
# Reference accessed: 2026-05-16

# ceph-detect-init: detect host init system (systemd/upstart/sysvinit/none)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--default=[default if detection fails]:init:(systemd upstart sysvinit none)' \
  '--use-rhceph[Red Hat Ceph mode]' \
  '*::ceph-detect-init args:_files' && ret=0
return ret
