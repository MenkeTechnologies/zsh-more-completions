#compdef sealert

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --browser)'{-b,--browser}'[start in browser]' \
  '(-s --service)'{-s,--service}'[run as service]' \
  '(-S --noservice)'{-S,--noservice}'[do not start service]' \
  '(-l --lookup)'{-l,--lookup}'+[lookup id]:id:' \
  '(-a --analyze)'{-a,--analyze}'+[analyze logfile]:file:_files' \
  '--fix=+[fix id]:id:' \
  '(-u --username)'{-u,--username}'+[username]:user:_users' \
  '(-H --hostname)'{-H,--hostname}'+[hostname]:host:_hosts' \
  '(-p --plugin)'{-p,--plugin}'+[plugin]:plugin:' && ret=0

return ret
