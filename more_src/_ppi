#compdef ppi
# Documentation: https://4ti2.github.io/ppi.html
# 4ti2: compute primitive partition identities (Graver basis of [1..N])

local ret=1

_arguments -s -S \
  '(-b --binary-output)'{-b,--binary-output}'[create binary file ppiN.dat instead of text ppiN.gra]' \
  '*:N:' && ret=0

return ret
