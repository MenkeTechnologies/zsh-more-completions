#compdef vtaclcheck
# _vtaclcheck — Vitess ACL configuration validator
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtaclcheck/cli/vtactlcheck.go on tip.

_vtaclcheck() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--acl-file=[JSON ACL file to check]:file:_files -g "*.json"' \
        '--static-auth-file=[auth_server_static JSON file to check]:file:_files -g "*.json"' \
        '-v[verbosity level]:n:'
}

_vtaclcheck "$@"
