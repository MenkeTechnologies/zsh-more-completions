#compdef systemd-network-generator
# Documentation: https://man.archlinux.org/search?q=systemd-network-generator
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--root=[chroot to root]:dir:_files -/' && ret=0

return ret
