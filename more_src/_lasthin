#compdef lasthin
# Documentation: https://github.com/LAStools/LAStools
# LAStools: thin LAS points by keeping lowest/highest/random point per grid cell

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[report tool version]' \
  '-gui[start with GUI]' \
  '-demo[run in demo mode]' \
  '-step+[grid cell size (default 1)]:size' \
  '-lowest[keep lowest point per grid cell]' \
  '-highest[keep highest point per grid cell]' \
  '-random[keep random point per grid cell]' \
  '-central[keep point closest to cell center]' \
  '-percentile+[select point near elevation percentile]:percentile' \
  '-adaptive+[thin via TIN with vertical tolerance]:tolerance' \
  '-contours+[optimize thinning for contour interval]:interval' \
  '-subcircle+[replicate each point 8 times at radius]:radius' \
  '-classify_as+[classify surviving points with code]:code' \
  '-flag_as_withheld[flag thinned points as withheld]' \
  '-flag_as_keypoint[flag surviving points as keypoint]' \
  '*-ignore_class+[exclude classification codes from thinning]:code' \
  '-sparse[use sparse grid to avoid memory issues]' \
  '-seed+[seed random number generator]:seed' \
  '-cores+[process on N parallel cores]:n' \
  '*-i+[input file or mask]:input:_files -g "*.(las|laz|txt|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-otxt[output as text]' \
  '-iparse+[define text input fields]:parse string' \
  '-oparse+[define text output fields]:parse string' \
  '*:file:_files -g "*.(las|laz|txt|LAS|LAZ)"' && ret=0

return ret
