#compdef bchunk
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-v[verbose mode]' \
  '-w[write WAV format instead of raw]' \
  '-s[swap byte order]' \
  '-p[convert to PSX format]' \
  '1:cue file:_files -g "*.cue(-.)"' \
  '2:bin file:_files -g "*.bin(-.)"' \
  '3:output basename:_files' && ret=0
return ret
