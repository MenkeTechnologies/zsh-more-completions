#compdef hoverfly
# Documentation: https://man.archlinux.org/search?q=hoverfly
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-listen-on-host+[host to listen on]:host:_hosts' \
  '-pp+[proxy port]:port:' \
  '-ap+[admin port]:port:' \
  '-modify[start in modify mode]' \
  '-middleware+[path to middleware binary]:middleware:_files' \
  '-cert+[path to certificate]:certificate file:_files' \
  '-key+[path to key]:key file:_files' \
  '-dest+[specify destination regex]:destination:' \
  '-capture[start in capture mode]' \
  '-synthesize[start in synthesize mode]' \
  '-simulate[start in simulate mode (default)]' \
  '-spy[start in spy mode]' \
  '-diff[start in diff mode]' \
  '-import+[import simulation from file or URL]:simulation:_files' \
  '-response-body-files-path+[path to response body files]:path:_files -/' \
  '-metrics[enable metrics logging]' \
  '-dev[enable CORS for development]' \
  '-disable-tls[disable TLS verification for outgoing requests]' \
  '-generate-ca-cert[generate CA certificate]' \
  '-tls-verification[enable mutual TLS verification]' \
  '-client-authentication-ca-cert+[path to CA cert for client auth]:cert:_files' \
  '-client-authentication-client-cert+[client certificate]:cert:_files' \
  '-client-authentication-client-key+[client key]:key:_files' \
  '-client-authentication-destination+[destination to apply client auth]:destination:' \
  '-upstream-proxy+[upstream proxy URL]:url:' \
  '-pac-file+[path to PAC file]:pac file:_files' \
  '-db-type+[database type]:type:(memory boltdb)' \
  '-db+[database path]:path:_files' \
  '-journal-size+[max number of journal entries]:size:' \
  '-cache[enable request/response caching]' \
  '-cors[enable CORS support]' \
  '-no-import-check[skip import checks]' \
  '-logs+[log level]:level:(panic fatal error warn info debug trace)' \
  '-logs-output+[log output]:output:(console json)' \
  '-add[add new data to existing simulation]' \
  '-v[verbose output]' \
  '-version[print version]' \
  '*:file:_files' && ret=0

return ret
