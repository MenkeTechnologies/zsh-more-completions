#compdef hoverfly
# Documentation: https://github.com/SpectoLabs/hoverfly
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (core/cmd/hoverfly/main.go).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-listen-on-host+[host to listen on]:host:_hosts' \
  '-pp+[proxy port]:port:' \
  '-ap+[admin port]:port:' \
  '-capture[start in capture mode]' \
  '-synthesize[start in synthesize mode]' \
  '-modify[start in modify mode]' \
  '-spy[start in spy mode]' \
  '-diff[start in diff mode]' \
  '-webserver[start in webserver mode]' \
  '-middleware+[path to middleware binary]:middleware:_files' \
  '-cert+[path to CA certificate]:certificate file:_files' \
  '-key+[path to CA key]:key file:_files' \
  '-cert-name+[cert name]:name:' \
  '-cert-org+[organization name for new cert]:org:' \
  '-destination+[regex for intercepted URLs]:destination:' \
  '-generate-ca-cert[generate CA certificate]' \
  '-tls-verification[enable mutual TLS verification]' \
  '-plain-http-tunneling[plain HTTP tunneling]' \
  '-client-authentication-ca-cert+[CA cert for client auth]:cert:_files' \
  '-client-authentication-client-cert+[client certificate]:cert:_files' \
  '-client-authentication-client-key+[client key]:key:_files' \
  '-client-authentication-destination+[destination for client auth]:destination:' \
  '-upstream-proxy+[upstream proxy URL]:url:' \
  '-pac-file+[path to PAC file]:pac file:_files' \
  '-db+[storage backend]:type:(memory boltdb)' \
  '-db-path+[DEPRECATED BoltDB path]:path:_files' \
  '-disable-cache[disable request/response cache]' \
  '-cache-size+[cache size]:n:' \
  '-journal-size+[journal size]:n:' \
  '-cors[enable CORS support]' \
  '-dev[enable CORS for dev]' \
  '-dev-cors-origin+[custom CORS origin]:url:' \
  '-no-import-check[skip import duplicate check]' \
  '-enable-middleware-api[enable middleware admin API]' \
  '-response-body-files-path+[base path for relative bodyFiles]:path:_files -/' \
  '-log-level+[log level]:level:(panic fatal error warn info debug trace)' \
  '-logs+[log format]:format:(plaintext json)' \
  '-logs-size+[in-memory log retention]:n:' \
  '-logs-file+[log file name]:file:_files' \
  '-log-no-color[disable log colors]' \
  '-log-no-quotes[disable log field quoting]' \
  '-metrics[enable metrics logging]' \
  '-add[add new user (with -username/-password)]' \
  '-username+[new user name]:user:' \
  '-password+[new user password]:password:' \
  '-password-hash+[new user password hash]:hash:' \
  '-admin[admin flag for new user]' \
  '-auth[enable authentication]' \
  '-v[verbose proxy logging]' \
  '-version[print version]' \
  '*:simulation file:_files' && ret=0

return ret
