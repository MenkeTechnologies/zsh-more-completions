#compdef keyconjurer
# Documentation: https://github.com/RiotGames/key-conjurer
# keyconjurer - retrieve temporary cloud credentials via Okta as IdP

local ret=1
local context state line

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--oidc-domain=[domain name of your OIDC server]:domain' \
  '--client-id=[OAuth2 client ID registered with your OIDC server]:id' \
  '--timeout=[seconds to wait for keyconjurer to respond]:seconds' \
  '--quiet[suppress human-readable informational messages on stdout]' \
  '1:command:(get login switch accounts roles alias unalias set config-path)' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      get)
        _arguments -s -S \
          '--region=[AWS region to use]:region' \
          '--ttl=[key timeout in hours (1 to 8)]:hours' \
          {-t,--time-remaining=}'[request new keys if current keys expire within N minutes]:minutes' \
          {-r,--role=}'[name of the role to assume]:role' \
          '--role-session-name=[role session name shown in CloudTrail logs]:name' \
          {-o,--output=}'[output format for credentials]:format:(env awscli json)' \
          '--shell=[shell format when output type is env]:shell:(bash powershell infer)' \
          '--bypass-cache[send the application ID as-is to Okta]' \
          '--login[login to Okta before running the command]' \
          '--awscli=[path for directory used by the aws CLI]:dir:_files -/' \
          {-u,--url-only}'[print only the URL to visit]' \
          {-b,--no-browser}'[do not open a browser window, print the URL instead]' \
          {-p,--profile=}'[name of the awscli profile to save credentials]:profile' \
          '*:account name or alias:' && ret=0
        ;;
      login)
        _arguments -s -S \
          {-u,--url-only}'[print only the URL to visit]' \
          {-b,--no-browser}'[do not open a browser window, print the URL instead]' && ret=0
        ;;
      switch)
        _arguments -s -S \
          '--role-session-name=[role session name shown in CloudTrail logs]:name' \
          {-o,--output=}'[output format for credentials]:format:(env awscli json)' \
          '--shell=[shell format when output type is env]:shell:(bash powershell infer)' \
          '--awscli=[path for directory used by the aws CLI]:dir:_files -/' \
          '*:account id:' && ret=0
        ;;
      accounts)
        _arguments -s -S \
          '--no-refresh[do not refresh the account list]' \
          '--server-address=[address of the account server]:address' && ret=0
        ;;
      roles)
        _arguments '*:account name or alias:' && ret=0
        ;;
      alias)
        _arguments '*:account name and alias:' && ret=0
        ;;
      unalias)
        _arguments '*:account name or alias:' && ret=0
        ;;
      set)
        _arguments '1:setting:(ttl time-remaining)' '*:value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
