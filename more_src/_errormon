#compdef errormon
# Documentation: https://difx.readthedocs.io/en/latest/sources/difx_programs.html
# DiFX: print difxError multicast messages to the terminal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information and exit]' \
  '*:max severity:(0 1 2 3 4 5 6 7 8)' && ret=0

return ret
