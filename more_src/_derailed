#compdef derailed
# Documentation: https://github.com/zombocom/derailed_benchmarks
# benchmarks and memory profiling for Rails applications

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'derailed command' \
      'bundle\:mem[memory used by gems at require time]' \
      'bundle\:objects[objects created when dependencies load]' \
      'exec[run a performance benchmark against the app]' && ret=0
    ;;
  args)
    if [[ $line[1] == exec ]]; then
      _values 'perf task' \
        'perf\:allocated_objects[object allocation differences]' \
        'perf\:app[compare performance across recent commits]' \
        'perf\:gc[garbage collection profiler data]' \
        'perf\:heap[generate heap dumps for analysis]' \
        'perf\:heap_diff[create three heap dumps for comparison]' \
        'perf\:ips[measure iterations per second]' \
        'perf\:library[benchmark library changes]' \
        'perf\:mem[memory profiling including app code]' \
        'perf\:mem_over_time[track memory usage across requests]' \
        'perf\:objects[runtime object profiling]' \
        'perf\:stackprof[CPU sampling profiler]' \
        'perf\:test[basic performance testing]' && ret=0
    fi
    ;;
esac

return ret
