#compdef bsdiff bspatch

# Zsh completion for Colin Percival bsdiff/bspatch

local ret=1

case $service in
  bsdiff)
    _arguments -s -S \
      '1:old file:_files' \
      '2:new file:_files' \
      '3:patch output:_files' && ret=0
    ;;
  bspatch)
    _arguments -s -S \
      '1:old file:_files' \
      '2:patch file:_files' \
      '3:output file:_files' && ret=0
    ;;
esac

return ret
