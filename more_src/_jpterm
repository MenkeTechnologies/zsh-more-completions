#compdef jpterm
# Documentation: https://github.com/jmespath-community/jmespath.terminal
# JMESPath exploration tool in the terminal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --output-mode)'{-m+,--output-mode=}'[what is printed to stdout on exit]:mode:(result expression quiet)' \
  '(-o --output-file)'{-o+,--output-file=}'[direct output to a file]:file:_files' \
  '--version[show version]' \
  '*:input json:_files' && ret=0

return ret
