#compdef kubectl-view-utilization
# Documentation: https://github.com/etopeter/kubectl-view-utilization
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '-h[show resources in human readable units]' \
  '(-n --namespace)'{-n+,--namespace=}'[filter by namespace]:namespace:' \
  '(-l --selector)'{-l+,--selector=}'[filter by node label]:selector:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(text json)' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--no-headers[disable printing headers]' \
  '-v[print plugin version]' \
  '1:subcommand:->subcommands' && ret=0

case $state in
  subcommands)
    local -a subcommands=(
      'namespaces:show utilization broken down by namespace'
      'nodes:show utilization broken down by node'
    )
    _describe -t subcommands 'kubectl-view-utilization subcommand' subcommands && ret=0
    ;;
esac

return ret
