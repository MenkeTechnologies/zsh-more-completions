#compdef turbo-metrics
# Documentation: https://github.com/Gui-Yom/turbo-metrics/blob/master/crates/turbo-metrics-cli/README.md
# GPU-accelerated video quality metrics (psnr/ssim/msssim/ssimulacra2)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --metrics)'{-m,--metrics}'[metrics to compute]:metric:(psnr ssim msssim ssimulacra2)' \
  '--every=[only compute metrics every few frames]:n' \
  '--skip=[index of the first frame to start computing at]:n' \
  '--skip-ref=[frame index offset for reference media only]:n' \
  '--skip-dis=[frame index offset for distorted media only]:n' \
  '--frame-count=[amount of frames to compute]:n' \
  '--output=[output format]:format:(default json csv)' \
  ':reference:_files' \
  ':distorted:_files' && ret=0

return ret
