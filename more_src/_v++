#compdef v++
# Documentation: https://docs.amd.com/r/en-US/ug1393-vitis-application-acceleration/v-Command
# AMD Vitis compiler: compile, link and package FPGA kernels and binaries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show tool version]' \
  '(-c --compile)'{-c,--compile}'[compile source into a Xilinx object (.xo) file]' \
  '(-l --link)'{-l,--link}'[link .xo files into an FPGA binary (.xclbin)]' \
  '(-p --package)'{-p,--package}'[package the build into a runnable system]' \
  '(-t --target)'{-t,--target}'=[build target]:target:(sw_emu hw_emu hw)' \
  '--platform=[target acceleration platform]:platform:_files -g "*.xpfm"' \
  '(-o --output)'{-o,--output}'=[output file name]:output:_files' \
  '(-k --kernel)'{-k,--kernel}'=[kernel to compile]:kernel:' \
  '--config=[v++ configuration file]:config:_files -g "*.cfg *.ini"' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:' \
  '-O+[optimization level]:level:(0 1 2 3 s quick)' \
  '(-g --debug)'{-g,--debug}'[generate debug information]' \
  '(-I --include)'{-I,--include}'=[add include search path]:dir:_files -/' \
  '--save-temps[preserve intermediate files]' \
  '--temp_dir=[temporary directory]:dir:_files -/' \
  '--log_dir=[compilation log directory]:dir:_files -/' \
  '--report_dir=[report output directory]:dir:_files -/' \
  '--profile[enable performance profiling]' \
  '--advanced=[advanced compiler settings]:opt:' \
  '--connectivity=[kernel-to-memory connectivity]:opt:' \
  '--clock=[clock frequency settings]:opt:' \
  '--hls=[high-level synthesis options]:opt:' \
  '--vivado=[Vivado integration parameters]:opt:' \
  '*:source:_files' && ret=0

return ret
