#compdef ossec-authd
# Documentation: https://www.ossec.net/docs/programs/ossec-authd.html
# OSSEC agent key provisioning daemon

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-t[test configuration]' \
  '-f[run in foreground]' \
  '-i[use client source IP address]' \
  '-u[run as this user]:user:_users' \
  '-g[run as this group]:group:_groups' \
  '-D[chroot directory]:directory:_directories' \
  '-m[manager IP address]:address:_hosts' \
  '-p[manager port]:port:' \
  '-c[SSL cipher list]:ciphers:' \
  '-v[CA certificate for client verification]:ca cert:_files' \
  '-x[server certificate]:cert:_files' \
  '-k[server key]:key:_files' \
  '-n[disable shared password authentication]' && ret=0

return ret
