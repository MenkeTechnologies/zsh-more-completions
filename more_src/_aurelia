#compdef aurelia au
# _aurelia — Aurelia framework CLI (aurelia/cli)
# upstream: https://github.com/aurelia/cli
# Subcommands from lib/commands/.

_aurelia() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'new:create a new Aurelia application'
                'n:alias for new'
                'generate:scaffold a project resource'
                'g:alias for generate'
                'config:show/edit project configuration'
                'help:show help'
                'h:alias for help'
                'build:build the application (via gulp)'
                'run:run the dev server (via gulp)'
                'test:run tests (via gulp)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                generate|g) _arguments '1:type:(attribute element generator task value-converter binding-behavior)' '2:name:' ;;
            esac
            ;;
    esac
}

_aurelia "$@"
