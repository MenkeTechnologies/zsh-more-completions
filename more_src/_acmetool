#compdef acmetool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'reconcile:reconcile certs'
  'cull:cull old certificates'
  'status:show certificate status'
  'want:want certificate for hostnames'
  'unwant:remove desired hostnames'
  'quickstart:initial setup'
  'redirector:run HTTP redirector'
  'test-notify:test notify hooks'
  'import-jwk-account:import JWK account key'
  'import-pem-account:import PEM account key'
  'import-key:import certificate private key'
  'import-le:import legacy LE state'
  'revoke:revoke certificate'
  'account-thumbprint:print account thumbprint'
  'account-url:print account URL'
)

_arguments -C \
  '--state=[state directory]:dir:_files -/' \
  '*--hooks=[hook directory]:dir:_files -/' \
  '--batch[non-interactive]' \
  '--stdio[stdio mode]' \
  '--response-file=[response file]:file:_files' \
  '--xlog.severity=[log severity]:level:(emerg alert critical error warn notice info debug trace)' \
  '--service.uid=[service uid]:uid:' \
  '--service.gid=[service gid]:gid:' \
  '--service.daemon[run as daemon]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'acmetool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cull)
        _arguments \
          '(-n --simulate)'{-n,--simulate}'[simulate only]' && ret=0
        ;;
      (want)
        _arguments \
          '--reconcile[reconcile after want]' \
          '--no-reconcile[do not reconcile]' \
          '*:hostname:_hosts' && ret=0
        ;;
      (quickstart)
        _arguments '--expert[expert mode]' && ret=0
        ;;
      (redirector)
        _arguments \
          '--path=[document root]:dir:_files -/' \
          '--challenge-gid=[challenge gid]:gid:' \
          '--read-timeout=[read timeout]:duration:' \
          '--write-timeout=[write timeout]:duration:' \
          '--status-code=[redirect status code]:code:' \
          '--bind=[bind addr]:addr:' && ret=0
        ;;
    esac
    ;;
esac

return ret
