#compdef copyblocks
# _copyblocks — Grafana Mimir cross-bucket TSDB block copier (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/copyblocks/main.go on tip.

_copyblocks() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-min-block-duration=[skip blocks shorter than this]:dur:' \
        '-min-time=[only copy blocks with MinTime >= RFC3339 time]:t:' \
        '-max-time=[only copy blocks with MaxTime <= RFC3339 time]:t:' \
        '-tenant-concurrency=[concurrent tenants]:n:' \
        '-block-concurrency=[concurrent blocks per tenant]:n:' \
        '-copy-period=[repeat-copy interval (0 = run once)]:dur:' \
        '-enabled-users=[only copy listed tenants (comma-sep)]:list:' \
        '-disabled-users=[skip listed tenants (comma-sep)]:list:' \
        '-user-mapping=[comma-sep src:dst tenant rename map]:list:' \
        '-dry-run[log changes without copying]' \
        '-skip-no-compact-block-duration-check[ignore min-block-duration for no-compact blocks]' \
        '-clear-copy-markers[delete copy markers instead of copying]' \
        '-http-listen-address=[health/metrics HTTP bind address]:host\:port:' \
        '-source.backend=[source bucket backend]:backend:(s3 gcs azure swift filesystem)' \
        '-source.s3.bucket-name=[source S3 bucket]:name:' \
        '-source.s3.endpoint=[source S3 endpoint]:url:_urls' \
        '-source.s3.region=[source S3 region]:region:' \
        '-source.gcs.bucket-name=[source GCS bucket]:name:' \
        '-source.azure.account-name=[source Azure account]:name:' \
        '-source.azure.container-name=[source Azure container]:name:' \
        '-source.filesystem.dir=[source local directory]:dir:_files -/' \
        '-destination.backend=[destination bucket backend]:backend:(s3 gcs azure swift filesystem)' \
        '-destination.s3.bucket-name=[destination S3 bucket]:name:' \
        '-destination.s3.endpoint=[destination S3 endpoint]:url:_urls' \
        '-destination.s3.region=[destination S3 region]:region:' \
        '-destination.gcs.bucket-name=[destination GCS bucket]:name:' \
        '-destination.azure.account-name=[destination Azure account]:name:' \
        '-destination.azure.container-name=[destination Azure container]:name:' \
        '-destination.filesystem.dir=[destination local directory]:dir:_files -/' \
        '-backfill.sleep-time=[backfill upload-state poll interval]:dur:'
}

_copyblocks "$@"
