_bbgo() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--debug[enable debug logging]'
        '--metrics[enable Prometheus metrics endpoint at /metrics]'
        '--metrics-port=[Prometheus HTTP server port (default 9090)]:port:'
        '--no-dotenv[disable built-in dotenv loader]'
        '--dotenv=[dotenv file to load (default .env.local)]:dotenv file:_files'
        '--config=[bbgo YAML config file (default bbgo.yaml)]:config:_files -g "*.(yaml|yml|YAML|YML)"'
        '--log-formatter=[log formatter override]:formatter:(text json color)'
        '--rollbar-token=[Rollbar token for error tracking]:token:'
        '--slack-token=[Slack bot token for notifications]:token:'
        '--slack-channel=[Slack trading channel (default dev-bbgo)]:channel:'
        '--slack-error-channel=[Slack error channel (default bbgo-error)]:channel:'
        '--telegram-bot-token=[Telegram bot token from BotFather]:token:'
        '--telegram-bot-auth-token=[Telegram auth token]:token:'
        '--binance-api-key=[Binance API key]:key:'
        '--binance-api-secret=[Binance API secret]:secret:'
        '--max-api-key=[MAX exchange API key]:key:'
        '--max-api-secret=[MAX exchange API secret]:secret:'
        '--cpu-profile=[write CPU profile to file]:file:_files'
        '--enable-profile-server[enable net/http/pprof profile server]'
        '--profile-server-bind=[profile server bind address (default localhost:6060)]:addr:'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'account:show exchange account balances/positions/equity snapshot'
                'backtest:run a backtest on historical kline data using a strategy config'
                'balances:list current spot/margin/futures balances across configured exchanges'
                'build:build a custom bbgo binary with strategies compiled in'
                'cancel:cancel active orders'
                'chart:render a candlestick chart in the terminal for a symbol'
                'deposit:list deposits / deposit history'
                'exchangetest:test exchange API connectivity + symbol info'
                'execute-order:execute an order directly from the CLI'
                'hoptimize:hyperparameter optimization for strategy tuning'
                'import:import historical klines into the backtest store'
                'kline:fetch and display klines (candlesticks) for a symbol'
                'margin:show margin account state (positions, debt, interest)'
                'market:show market info for a symbol (lot size, tick size, exchange, status)'
                'optimize:optimize strategy parameters via grid search'
                'orderbook:show current order book depth'
                'orders:list active + recent orders'
                'pnl:profit/loss calculation across trades'
                'pprof:trigger pprof snapshots against running profile server'
                'run:run a strategy live (the primary live-trading subcommand)'
                'strategy:list/inspect available strategies'
                'sync:sync trade/order history from exchanges to local DB'
                'trades:list executed trades'
                'transfer:transfer assets between exchange wallets'
                'userdatastream:subscribe to user data stream and dump events'
                'version:print version and git commit'
            )
            _describe -t commands 'bbgo command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                run|backtest|exchangetest)
                    _arguments \
                        $global_opts \
                        '--no-sync[skip pre-run sync step]' \
                        '--sync[force pre-run sync]' && ret=0
                    ;;
                chart|kline|orderbook|market|deposit|orders|trades|balances|account|margin|pnl|cancel|execute-order)
                    _arguments \
                        $global_opts \
                        '--session=[exchange session name from bbgo.yaml]:session:' \
                        '--symbol=[trading symbol e.g. BTCUSDT]:symbol:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bbgo "$@"
