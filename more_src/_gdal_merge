#compdef gdal_merge gdal_merge.py
# Documentation: https://gdal.org/programs/gdal_merge.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-ot+[output data type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '-ps+[pixel size]:xres yres:' \
  '-tap[align extent to pixel size multiples]' \
  '-ul_lr+[upper-left and lower-right corner]:ulx uly lrx lry:' \
  '-v[verbose]' \
  '-separate[place inputs as separate bands]' \
  '-pct[grab pseudo-color table from first input]' \
  '-n+[input nodata value]:value:' \
  '-a_nodata+[output nodata value]:value:' \
  '-init+[pre-initialize bands with value(s)]:values:' \
  '-createonly[create output file without copying data]' \
  '(-q -quiet)'{-q,-quiet}'[suppress progress messages]' \
  '*:input file:_files' && ret=0

return ret
