#compdef wp

# Zsh completion for WP-CLI - WordPress command line interface

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cache:manage the object cache'
  'cap:manage user capabilities'
  'cli:review WP-CLI info and check for updates'
  'comment:manage comments'
  'config:manage wp-config.php'
  'core:download, install, and update WordPress core'
  'cron:manage WP-Cron events and schedules'
  'db:perform basic database operations'
  'embed:manage oEmbed cache'
  'eval:execute arbitrary PHP code'
  'eval-file:load and execute a PHP file'
  'export:export WordPress content to WXR'
  'help:get help for a command'
  'i18n:internationalization tools'
  'import:import WXR content'
  'language:install, activate, and manage language packs'
  'maintenance-mode:manage maintenance mode'
  'media:import and manage media attachments'
  'menu:manage menus and menu items'
  'network:manage networks in a multi-site install'
  'option:manage options'
  'package:manage WP-CLI packages'
  'plugin:manage plugins'
  'post:manage posts'
  'post-type:manage post types'
  'rewrite:manage rewrite rules'
  'role:manage user roles'
  'scaffold:generate code for themes, plugins, etc.'
  'search-replace:search and replace strings in the database'
  'server:launch built-in PHP web server'
  'shell:open interactive PHP console'
  'sidebar:manage sidebars'
  'site:manage sites in a multi-site install'
  'super-admin:manage super admins'
  'taxonomy:manage taxonomies'
  'term:manage terms'
  'theme:manage themes'
  'transient:manage transients'
  'user:manage users'
  'widget:manage sidebar widgets'
)

_arguments -s -S \
  '--path=[path to WordPress files]:directory:_files -/' \
  '--url=[pretend request came from given URL]:url:' \
  '--ssh=[perform operation against remote server]:ssh spec:' \
  '--http=[perform operation against remote server via HTTP]:url:' \
  '--user=[set the WordPress user]:user:' \
  '--skip-plugins=[skip loading all or specific plugins]:plugins:' \
  '--skip-themes=[skip loading all or specific themes]:themes:' \
  '--skip-packages[skip loading all installed packages]' \
  '--require=[load PHP file before running command]:file:_files -g "*.php"' \
  '--exec=[execute PHP code before running command]:code:' \
  '--context=[load WordPress in given context]:context:' \
  '--color[force colorize output]' \
  '--no-color[disable colorize output]' \
  '--debug=[show all PHP errors]:group:' \
  '--prompt=[prompt the user to enter values for command args]:fields:' \
  '--quiet[suppress informational messages]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'wp command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      plugin)
        local -a plugin_cmds=(
          'activate:activate a plugin'
          'deactivate:deactivate a plugin'
          'delete:delete a plugin'
          'get:get details about a plugin'
          'install:install a plugin'
          'is-active:check if a plugin is active'
          'is-installed:check if a plugin is installed'
          'list:list installed plugins'
          'path:get path to a plugin'
          'search:search the plugin directory'
          'status:show plugin status'
          'toggle:toggle a plugin activation'
          'uninstall:uninstall a plugin'
          'update:update one or more plugins'
          'verify-checksums:verify plugin checksums'
        )
        _describe -t commands 'plugin command' plugin_cmds && ret=0
        ;;
      theme)
        local -a theme_cmds=(
          'activate:activate a theme'
          'delete:delete a theme'
          'disable:disable a theme'
          'enable:enable a theme'
          'get:get details about a theme'
          'install:install a theme'
          'is-active:check if a theme is active'
          'is-installed:check if a theme is installed'
          'list:list installed themes'
          'mod:manage theme mods'
          'path:get path to a theme'
          'search:search the theme directory'
          'status:show theme status'
          'update:update one or more themes'
        )
        _describe -t commands 'theme command' theme_cmds && ret=0
        ;;
      core)
        local -a core_cmds=(
          'check-update:check for WordPress updates'
          'download:download WordPress core files'
          'install:install WordPress'
          'is-installed:check if WordPress is installed'
          'multisite-convert:transform single-site to multisite'
          'multisite-install:install multisite from scratch'
          'update:update WordPress to a newer version'
          'update-db:update the database to latest schema'
          'verify-checksums:verify core files against checksums'
          'version:display the WordPress version'
        )
        _describe -t commands 'core command' core_cmds && ret=0
        ;;
      db)
        local -a db_cmds=(
          'check:check database'
          'cli:open MySQL console'
          'clean:remove all tables from database'
          'columns:list table columns'
          'create:create the database'
          'drop:drop the database'
          'export:export the database'
          'import:import a database'
          'optimize:optimize the database'
          'prefix:display the table prefix'
          'query:execute a SQL query'
          'repair:repair the database'
          'reset:remove all tables and recreate'
          'search:find a string in the database'
          'size:show database size'
          'tables:list database tables'
        )
        _describe -t commands 'db command' db_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
