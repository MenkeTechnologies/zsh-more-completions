#compdef llvm-addr2line
# _llvm-addr2line — LLVM addr2line (LLVM project, C++); GNU addr2line-compatible address->source converter
# upstream: https://github.com/llvm/llvm-project

_llvm-addr2line() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-a[print address]' \
        '--addresses[print address]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-e+[binary]:file:_files' \
        '--exe=+[binary]:file:_files' \
        '-f[print function names]' \
        '--functions[print function names]' \
        '-i[unwind inline functions]' \
        '--inlines[unwind inline functions]' \
        '-j+[section]:section:' \
        '--section=+[section]:section:' \
        '-p[pretty print]' \
        '--pretty-print[pretty print]' \
        '-s[only basename]' \
        '--basenames[only basename]' \
        '--llvm[output LLVM style]' \
        '--gnu[output GNU style]' \
        '--output-style=+[output style]:style:(LLVM GNU)' \
        '*:address:'
}

_llvm-addr2line "$@"
