#compdef samples_from_md
# ============================================================================
#  _samples_from_md — TDEP samples_from_md: choose representative uncorrelated
#                     samples from MD simulations (Temperature Dependent
#                     Effective Potentials toolkit)
#
#  Source-direct extraction from
#    https://github.com/tdep-developers/tdep/blob/master/src/samples_from_md/options.f90
#    https://github.com/szaghi/FLAP (the FLAP library by Stefano Zaghi)
#
#  Maintained by TDEP developers consortium (tdep-developers/tdep).
#  119 GH stars.  TDEP (Temperature Dependent Effective Potentials) is
#  a Fortran code for first-principles atomistic simulation post-
#  processing — extracts force constants, phonon dispersion relations,
#  thermal conductivity, and lattice dynamics from DFT+MD trajectories.
#  Used in materials science research for studying anharmonic phonon
#  effects, finite-temperature lattice dynamics, and thermal transport
#  in crystalline solids.  `samples_from_md` selects uncorrelated
#  representative snapshots from a molecular dynamics trajectory for
#  subsequent training of effective harmonic models.  Sister tools:
#  VASP/Quantum ESPRESSO/Abinit/FHI-Aims/Siesta (DFT codes that
#  produce MD trajectories TDEP consumes; in corpus where packaged),
#  ALAMODE (alternative effective-Hamiltonian code), PHONOPY (in
#  corpus, phonon code), PHONO3PY (in corpus).
#
#  CLI library taxonomy update: 2nd Fortran CLI library — Stefano
#  Zaghi's **FLAP** (Fortran command Line Arguments Parser).  Fortran
#  ecosystem now has 2 documented CLI libraries (R310 M_CLI2 + R385
#  FLAP).
#
#  FLAP (szaghi/FLAP — "Fortran command Line Arguments Parser") is
#  Stefano Zaghi's modern Fortran 2003+ CLI library — uses
#  type-bound-procedure (TBP) OOP design with `type(command_line_interface) ::
#  cli` instance and `cli%init`/`cli%add`/`cli%parse`/`cli%get` method
#  calls.  Distinct from R310 Fortran M_CLI2 (subroutine-based stdlib-
#  style) by providing Python-argparse-equivalent semantics (action
#  variants, choices, type coercion, mutually-exclusive groups,
#  subcommands) plus AUTO-GENERATED man pages and markdown
#  documentation.  Used by TDEP (atomistic simulation toolkit, 119
#  stars), FOODIE (Fortran differential-equations integration, 130
#  stars), wavy (spectral ocean wave model, WaveBit Scientific),
#  fenvelopes (phase envelope calculator, ipqa-research), OFF
#  (Object-oriented Finite-volume CFD by Zaghi himself), VPIC plasma
#  simulation post-analysis, MOHID Lagrangian water modeling, and
#  many academic Fortran codes that want richer CLI parsing than
#  M_CLI2 provides.
#
#  FLAP API:
#    program mytool
#      use flap, only: command_line_interface
#      implicit none
#      type(command_line_interface) :: cli
#      character(len=256) :: output_file
#      integer :: n_iter
#      logical :: verbose
#      integer :: status
#
#      call cli%init(progname='mytool', &
#                    authors='J. Doe', &
#                    version='1.0.0', &
#                    license='GPL', &
#                    help='Usage:', &
#                    description='Do useful things.', &
#                    examples=["mytool --output=foo.txt -n 100"], &
#                    epilog=new_line('a')//'See manual for details.')
#
#      call cli%add(switch='--output',  switch_ab='-o', &
#                   help='Output file path', &
#                   required=.true., act='store', def='out.txt', &
#                   error=status)
#
#      call cli%add(switch='--niter',   switch_ab='-n', &
#                   help='Number of iterations', &
#                   required=.false., act='store', def='10', &
#                   error=status)
#
#      call cli%add(switch='--verbose', switch_ab='-v', &
#                   help='Verbose output', &
#                   required=.false., act='store_true', def='.false.', &
#                   error=status)
#
#      call cli%add(switch='--format',  &
#                   help='Output format', &
#                   required=.false., act='store', def='text', &
#                   choices='text,json,xml', error=status)
#
#      call cli%parse(error=status)
#      if (status /= 0) stop
#
#      call cli%get(switch='--output',  val=output_file)
#      call cli%get(switch='--niter',   val=n_iter)
#      call cli%get(switch='--verbose', val=verbose)
#    end program
#
#  FLAP distinctive features:
#    - MODERN FORTRAN 2003+ OOP — uses TYPE-BOUND PROCEDURES (TBPs)
#      on the `command_line_interface` derived type
#    - INSTANCE-BASED — `type(command_line_interface) :: cli` declared
#      as a local variable; multiple CLI instances possible (vs
#      stdlib's global state approach)
#    - `cli%init(progname=..., authors=..., version=..., license=...,
#      help=..., description=..., examples=..., epilog=...)` — INIT
#      METHOD with KEYWORD ARGUMENTS for all metadata (Fortran 2008+
#      keyword-arg syntax)
#    - `cli%add(switch='--name', switch_ab='-s', help='...', required=.true.,
#      act='store', def='default', choices='a,b,c', error=status)` —
#      ADD METHOD per option with KEYWORD ARGUMENTS
#    - `switch` for LONG NAME (with leading `--`)
#    - `switch_ab` for SHORT NAME / ABBREVIATION (with leading `-`)
#    - `required=.true./.false.` Fortran LOGICAL for required flag
#    - `act='store'/'store_true'/'store_false'/'count'/'append'` —
#      Python-argparse-style ACTION VARIANTS
#    - `def='value'` — default value (always STRING; FLAP coerces to
#      target type via `cli%get`)
#    - `choices='a,b,c'` — comma-separated ENUM values
#    - `error=status` — INTEGER return for error handling (no exceptions
#      in Fortran)
#    - `nargs='?'/'*'/'+'/'N'` — Python-argparse-style nargs
#    - `cli%parse(error=status)` — PARSE METHOD
#    - `cli%get(switch='--name', val=variable)` — TYPED GET METHOD;
#      `val` parameter's Fortran type determines coercion (integer,
#      real, logical, character, real(flyt), etc.)
#    - `cli%save_man_page(filename)` — AUTO-GENERATE roff man page
#      from CLI spec — UNIQUE FLAP FEATURE not in argparse/clap/etc.
#    - `cli%save_usage_to_markdown(filename)` — AUTO-GENERATE markdown
#      documentation — UNIQUE FLAP FEATURE
#    - MUTUALLY EXCLUSIVE GROUPS via `cli%add_group(group_description)`
#      then `cli%add(switch=..., group_name=GROUP)` — Python-argparse
#      add_mutually_exclusive_group equivalent
#    - SUBCOMMANDS via `cli%add_command_line_arguments_group(...)` —
#      compositional design for multi-command tools
#    - AUTO-INJECTED `--help`/`-h` and `--version`/`-v` and `--manpage`
#      flags
#    - AUTO-GENERATED help with TERMINAL-WIDTH-AWARE wrapping +
#      colored output
#    - INTERNALLY uses Fortran derived types + allocatable arrays +
#      type-bound procedures (modern Fortran 2003/2008 OOP idioms)
#  Distinct from R310 Fortran M_CLI2 (stdlib-style with `set_args`/
#  `lget`/`iget`/`sget`/`rget` SUBROUTINE-based parsing — simpler but
#  less Python-argparse-equivalent), R270 Haskell optparse-applicative
#  (functional applicative combinator in Haskell), R272 C POSIX
#  getopt (char-by-char iteration), R382 GNU argp (C struct arrays),
#  R368 PowerShell `param()` block (language feature).  FLAP's
#  approach: MODERN FORTRAN 2003+ OOP via TYPE-BOUND PROCEDURES on
#  `command_line_interface` derived type + INSTANCE-BASED (vs M_CLI2's
#  global state) + KEYWORD-ARG METHOD CALLS for all metadata +
#  Python-argparse-style ACTION/CHOICES/NARGS semantics + `error=status`
#  INTEGER RETURN model (no Fortran exceptions) + UNIQUE
#  AUTO-GENERATED MAN PAGE + AUTO-GENERATED MARKDOWN documentation +
#  MUTUALLY EXCLUSIVE GROUPS + SUBCOMMANDS via add_group — corpus's
#  **first documented modern-Fortran-OOP-with-auto-generated-manpage-
#  and-markdown CLI library**.  Brings cross-language CLI library
#  taxonomy variant count to 124; Fortran ecosystem now has 2
#  documented CLI libraries.
#
#  Surface (verbatim from `src/samples_from_md/options.f90`
#  `subroutine parse(opts)`):
#
#  Options:
#    -n, --nsamples N             Number of samples to extract
#                                 (default: 50)
#    -of, --output_format N       Output format selector:
#                                 1 = VASP POSCAR (default)
#                                 2 = Abinit
#                                 4 = FHI-Aims
#                                 5 = Siesta FDF
#                                 (choices restricted via choices='1,2,4,5')
#
#  Auto-injected by FLAP:
#    -h, --help                   Show help with terminal-width-aware
#                                 wrapping and colored output
#    -v, --version                Show version (lo_version from
#                                 konstanter module)
#        --manpage                Write roff man page to
#                                 samples_from_md.1 AND markdown to
#                                 samples_from_md.md, then exit
#                                 (FLAP-unique feature)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also FLAP users):
#    - phonon_dispersion_relations / extract_forceconstants / thermal_
#      conductivity / lineshape / anharmonic_free_energy / atomic_
#      distribution / canonical_configuration / crystal_structure_info /
#      dump_dynamical_matrices / generate_structure / pack_simulation /
#      phasespace_surface / refine_structure / thermal_conductivity_2023
#      (ALL TDEP sister tools — also use FLAP; samples_from_md chosen
#      as canonical FLAP showcase from TDEP suite)
#    - foodie / FOODIE (Fortran-FOSS-Programmers 130 stars — Fortran
#      Object-Oriented DE integration framework, FUTURE candidate
#      with strong impact for FOODIE-foundation-specific FLAP usage)
#    - wavy (wavebitscientific/wavy 18 stars — spectral ocean wave
#      model, smaller community)
#    - fenvelopes (ipqa-research 8 stars — phase envelope calculator,
#      niche)
#    - watmd (Merck KGaA WATMD — proprietary)
#    - OFF / FORESEER / Lib_VTK_IO (szaghi's own tools — flagship
#      FLAP showcases by the FLAP author himself, FUTURE candidates)
#    - MOHID Lagrangian (Mohid-Water-Modelling-System — large water
#      model, smaller community)
#    - busted (lunarmodules/busted IN CORPUS via _busted — Lua testing
#      framework uses lua-cliargs but already documented under
#      different attribution; FUTURE for Lua 3rd library)
# ============================================================================

_samples_from_md() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-n --nsamples)'{-n,--nsamples}'=[number of samples to extract (default 50)]:n' \
    '(-of --output_format)'{-of,--output_format}'=[output format selector]:format:((1\:"VASP POSCAR (default)" 2\:"Abinit" 4\:"FHI-Aims" 5\:"Siesta FDF"))' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--manpage[write man page + markdown documentation and exit]'
}

_samples_from_md "$@"
