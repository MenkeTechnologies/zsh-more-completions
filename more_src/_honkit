#compdef honkit

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build book'
  'serve:serve as website'
  'parse:parse and debug'
  'init:scaffold book'
  'pdf:build PDF'
  'epub:build EPUB'
  'mobi:build MOBI'
)

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'honkit subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (build|pdf|epub|mobi|parse|init)
        _arguments \
          '--log=[log level]:level:(debug info warn error disabled)' \
          '--format=[format]:fmt:(website json ebook)' \
          '--timing[show timings]' \
          '--reload[prune cache]' \
          '*:book or output:_files -/' && ret=0 ;;
      (serve)
        _arguments \
          '--port=[port]:port:' \
          '--lrport=[livereload port]:port:' \
          '--watch[watch]' \
          '--live[livereload]' \
          '--open[open in browser]' \
          '--browser=[browser]:browser:' \
          '--log=[log level]:level:(debug info warn error disabled)' \
          '--format=[format]:fmt:(website json ebook)' \
          '--reload[prune cache]' \
          '*:book or output:_files -/' && ret=0 ;;
    esac
    ;;
esac

return ret
