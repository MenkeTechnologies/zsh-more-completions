#compdef create-tailwind-plugin
# Documentation: https://www.npmjs.com/package/create-tailwind-plugin
# Reference accessed: 2026-05-24
# Verified: npm view create-tailwind-plugin bin; npm readme Options table.

# Zsh completion for create-tailwind-plugin - Tailwind CSS plugin package scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--name=[plugin package name]:name:' \
  '--description=[plugin description]:description:' \
  '--author=[author name]:author:' \
  '--github-username=[GitHub username for repository URLs]:username:' \
  '--initialize-git[run git init in plugin directory]' \
  '--install-packages[run npm install and format in plugin directory]' \
  '--all[enable --initialize-git and --install-packages]' \
  '--silent[suppress interactive output]' && ret=0

return ret
