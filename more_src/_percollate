#compdef percollate
# Documentation: https://github.com/danburzo/percollate
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_percollate_common() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[help]' \
    '(-V --version)'{-V,--version}'[version]' \
    '--debug[debug parse output]' \
    '(-o --output)'{-o,--output}'=[output path (- for stdout on html/md)]:file:_files' \
    '--template=[custom HTML template]:file:_files' \
    '--style=[custom CSS file]:file:_files' \
    '--css=[inline CSS]:style:' \
    '*'{-u,--url}'+[base URL for stdin HTML]:url:_urls' \
    '*'{-w,--wait}'+[pause seconds between URLs]:seconds' \
    '(-t --title)'{-t,--title}'=[bundle title]:title' \
    '(-a --author)'{-a,--author}'=[bundle author]:author' \
    '--individual[one file per page]' \
    '--toc[table of contents]' \
    '--toc-level=[max ToC heading level 1-6]:level:(1 2 3 4 5 6)' \
    '--cover[generate cover]' \
    '--browser=[renderer browser]:browser:(chrome firefox)' \
    '--hyphenate[enable hyphenation]' \
    '--inline[embed images as data URLs]' \
    '--unsafe[relax JSDOM validation]' \
    '--no-amp[do not prefer AMP]' \
    '--no-toc[disable ToC]' \
    '--no-cover[disable cover]' \
    '--no-hyphenate[disable hyphenation]' \
    '--no-sandbox[Puppeteer: disable sandbox]' \
    '*--md.+[mdast stringifier option name=value]:opt:' \
    '*:URL or stdin (-):_urls'
}

local curcontext="$curcontext" ret=1
local -a line expl

if (( CURRENT == 1 )); then
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[help]' \
    '(-V --version)'{-V,--version}'[version]' \
    '--debug[debug parse output]' \
    '1:command:(pdf epub html md)' && ret=0
elif [[ $words[1] == (pdf|epub|html|md) ]]; then
  curcontext="${curcontext%:*:*}:percollate-$words[1]:"
  _percollate_common && ret=0
else
  _percollate_common && ret=0
fi

return ret
