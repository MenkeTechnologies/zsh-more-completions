#compdef xrtpipeline
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/xrtpipeline.html
# Swift XRT data analysis pipeline: calibrate, screen and extract products

local ret=1

_arguments -s -S \
  'indir=[target archive directory path]:indir:_files -/' \
  'outdir=[output directory]:outdir:_files -/' \
  'steminputs=[stem for FITS input files]:steminputs:' \
  'srcra=[target RA degrees or hh mm ss.s]:srcra:' \
  'srcdec=[target DEC degrees or dd mm ss.s]:srcdec:' \
  'stemoutputs=[stem for output files, DEFAULT for standard]:stemoutputs:' \
  'datamode=[data processing modes]:datamode:(ALL PC WT PD IM)' \
  'obsmode=[observation modes to process]:obsmode:' \
  'entrystage=[pipeline entry stage 1-3]:entrystage:(1 2 3)' \
  'exitstage=[pipeline end stage 1-3]:exitstage:(1 2 3)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'plotdevice=[output image format]:plotdevice:(gif ps)' \
  'display=[display plots on screen]:display:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
