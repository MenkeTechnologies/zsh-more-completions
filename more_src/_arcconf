#compdef arcconf

# arcconf: Adaptec/Microsemi RAID controller CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'GETCONFIG:show controller/array/drive configuration'
  'GETLOGS:retrieve event/diag log'
  'CREATE:create logical device'
  'DELETE:delete logical device'
  'RESCAN:rescan controller'
  'SETSTATE:set physical state'
  'TASK:start/stop tasks (verify, clear, etc.)'
  'IDENTIFY:identify (blink) drive or controller'
  'RESETCONTROLLER:reset controller'
  'GETSTATUS:show controller status'
  'GETPRIORITY:show task priorities'
  'SETPRIORITY:set task priority'
  'SETCACHE:set logical drive cache mode'
  'SETPOWER:set power state'
  'SETALARM:enable/disable alarm'
  'SETNAME:set device name'
  'SETPERFORM:set performance mode'
  'BACKUP:save controller configuration'
  'RESTORE:restore controller configuration'
  'IMAGE:flash firmware image'
  'PHYERRORLOG:show PHY error log'
  'PASSTHROUGH:SCSI passthrough'
  'SLOTCONFIG:slot enabled/disabled'
)
_arguments -C \
  '(- *)?[show help]' \
  '(- *)-?[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'arcconf command' commands && ret=0 ;;
esac
return ret
