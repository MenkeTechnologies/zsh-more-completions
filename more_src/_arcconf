#compdef arcconf

# Adaptec arcconf: command line CLI for Adaptec RAID controllers
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'GETCONFIG:print configuration'
  'GETSTATUS:print current task status'
  'GETLOGS:print event/dead drive/device error logs'
  'GETSMARTSTATS:get S.M.A.R.T. stats'
  'IMAGE:image firmware operations'
  'IDENTIFY:blink drive indicator'
  'CREATE:create logical device'
  'DELETE:delete logical device'
  'MODIFY:modify logical device'
  'TASK:start/stop/suspend background task'
  'SETSTATE:set device state'
  'SETALARM:configure alarm state'
  'SETCACHE:set cache state'
  'SETNAME:set logical device name'
  'SETMAXCACHE:set maxCache state'
  'CONSISTENCYCHECK:start consistency check'
  'INITIALIZATION:start initialization'
  'PASSPHRASE:configure encryption passphrase'
  'KEY:configure encryption key file'
  'GETVERSION:print component versions'
  'RESCAN:rescan all controllers/drives'
  'RESETSTATISTICSCOUNTERS:reset statistics counters'
)

_arguments -C \
  '/?[show help]' \
  '/version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'arcconf command' commands && ret=0 ;;
esac
return ret
