#compdef rtcheck
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=rtcheck&sektion=1
# BRL-CAD overlap checker via raytracing

local ret=1

_arguments -s \
  '-g[grid cell width in millimeters]:width' \
  '-G[grid cell height in millimeters]:height' \
  '-s[rays to fire in X and Y (default 512)]:size' \
  '-a[select azimuth in degrees (with -e)]:azimuth' \
  '-e[select elevation in degrees (with -a)]:elevation' \
  '-r[report unique overlaps at end of view]' \
  '-M[read model2view matrix from stdin]' \
  '-P[max number of processors]:cpus' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
