#compdef janet
# Documentation: https://www.mankier.com/1/janet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Janet language interpreter. Corrected from prior file: -N enables
# (not disables) ANSI; -R disables user profile (not profile.janet);
# -p is the persistent flag (continue after error, not history);
# -r opens a REPL after sources (not raw stdin); -s is raw stdin;
# -i treats the script as an image; -k is compile-only (no arg).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show usage and exit]' \
  '(- *)-v[show version and exit]' \
  '-s[read raw input from stdin, no fancy input]' \
  '-e+[execute a string of Janet source]:code:' \
  '-E+[execute one Janet expression as a short-fn]:code:' \
  '-d[enable debug mode (debugger in REPL)]' \
  '-r[open a REPL after executing all sources]' \
  '-R[do not load the user profile in the REPL]' \
  '-p[persistent: keep executing after an error]' \
  '-q[hide the logo in the REPL]' \
  '-k[compile only (lint) without executing]' \
  '-m+[set :syspath module load directory]:syspath:_directories' \
  '-c[precompile source into an image]:source:_files:output:_files' \
  '-n[disable ANSI colors in the REPL]' \
  '-N[enable ANSI colors in the REPL]' \
  '-l+[import a Janet module before running]:lib:' \
  '-i[treat the script argument as a Janet image]' \
  '-w+[set linting warning level]:level:' \
  '-x+[set linting error level]:level:' \
  '--[stop processing options]' \
  '*:script file:_files -g "*.janet"' && ret=0

return ret
