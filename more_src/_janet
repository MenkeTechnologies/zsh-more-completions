#compdef janet

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[compile to image]:output file:_files' \
  '-d[set debug mode]' \
  '-e+[evaluate expression]:expression' \
  '-E[evaluate expression and print result]:expression' \
  '-i[run repl after handling other args]' \
  '-k[compile to C source]:output file:_files' \
  '-l+[require library]:library' \
  '-m+[set syspath]:syspath:_directories' \
  '-n[disable ANSI color in repl]' \
  '-p[turn on persistent history in repl]' \
  '-q[hide logo in repl]' \
  '-r[raw stdin]' \
  '-s[use raw stdin]' \
  '-w+[set lint warning level]:level:(relaxed normal strict)' \
  '-x+[set lint error level]:level:(relaxed normal strict)' \
  '-R[disable loading profile.janet]' \
  '-N[disable loading init.janet]' \
  '--[stop processing options]' \
  '*:script file:_files -g "*.janet"' && ret=0

return ret
