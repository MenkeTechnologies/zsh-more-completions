#compdef xattr

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-p -w -d -c)-p[print attribute value]' \
  '(-p -w -d -c)-w[write attribute value]' \
  '(-p -w -d -c)-d[delete an attribute]' \
  '(-p -w -d -c)-c[clear all attributes]' \
  '-l[long format]' \
  '-r[recurse into directories]' \
  '-s[act on the symlink itself]' \
  '-v[force filename in output]' \
  '-x[hex representation]' \
  '*:file:_files'
