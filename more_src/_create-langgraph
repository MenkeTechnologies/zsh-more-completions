#compdef create-langgraph
# Documentation: https://github.com/langchain-ai/langgraphjs/tree/main/libs/create-langgraph
# Reference accessed: 2026-05-24
# Verified: npm view create-langgraph bin; npm readme Commands section.

# Zsh completion for create-langgraph - LangGraph.js project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-t --template)'{-t,--template=}'[template to use]:template:(new-langgraph-project-js react-agent-js memory-agent-js retrieval-agent-js data-enrichment-js)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' config && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments -C \
          ':project path:_directories' && ret=0
        ;;
      *)
        _arguments -C \
          '(-t --template)'{-t,--template=}'[template to use]:template:(new-langgraph-project-js react-agent-js memory-agent-js retrieval-agent-js data-enrichment-js)' \
          ':project path:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
