#compdef mitm6
# Documentation: https://man.archlinux.org/search?q=mitm6
# Reference accessed: 2026-05-16

_arguments -s \
  '(-i --interface)'{-i,--interface}'=[interface]:iface:_net_interfaces' \
  '(-l --localdomain)'{-l,--localdomain}'=[local domain]:domain:' \
  '(-4 --ipv4)'{-4,--ipv4}'=[IPv4 address]:addr:' \
  '(-6 --ipv6)'{-6,--ipv6}'=[IPv6 address]:addr:' \
  '(-m --mac)'{-m,--mac}'=[MAC address]:mac:' \
  '(-a --no-ra)'{-a,--no-ra}'[do not send RA packets]' \
  '(-r --relay)'{-r,--relay}'=[relay target]:target:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '--debug[debug logging]' \
  '*'{-d,--domain}'=[allowed domain]:domain:' \
  '*'{-b,--blocklist,--blacklist}'=[blocked domain]:domain:' \
  '*'{-hw,-ha,--host-allowlist,--host-whitelist}'=[allowed host]:host:_hosts' \
  '*'{-hb,--host-blocklist,--host-blacklist}'=[blocked host]:host:_hosts' \
  '--ignore-nofqdn[ignore non-FQDN]' \
  '(- *)'{-h,--help}'[show help]'
