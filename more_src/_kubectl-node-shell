#compdef kubectl-node-shell
# Documentation: https://man.archlinux.org/search?q=kubectl-node-shell
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Pod namespace]:namespace:' \
  '--kubeconfig=[path]:file:_files' \
  '--context=[kube context]:context:' \
  '*::node or pod: _default'
