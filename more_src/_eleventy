#compdef eleventy 11ty

# Zsh completion for eleventy (11ty) - static site generator

_arguments -s -S \
  '--version[show version and exit]' \
  '--help[show help]' \
  '--input=[input directory]:directory:_files -/' \
  '--output=[output directory]:directory:_files -/' \
  '--config=[override the eleventy config file path]:file:_files' \
  '--serve[run web server on --port (default 8080) and serve local changes]' \
  '--watch[wait for files to change and automatically rewrite]' \
  '--port=[run the --serve web server on this port (default 8080)]:port:' \
  '--incremental[only build files that have changed]' \
  '--ignore-initial[do not build on first run, only on subsequent changes]' \
  '--formats=[comma-separated list of input file formats to use]:formats:' \
  '--quiet[do not print anything but build errors]' \
  '--pathprefix=[change all relative URLs in output to use this PATHPREFIX]:prefix:' \
  '--dryrun[do not write any files, just log what would be written]' \
  '--to=[output to format]:format:(json ndjson)'
