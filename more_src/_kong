#compdef kong

# Zsh completion for Kong (API Gateway)

_kong() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'check:check validity of a given Kong configuration'
    'config:manage Kong declarative configuration'
    'health:check if Kong is running'
    'hybrid:manage Kong hybrid mode'
    'migrations:manage database migrations'
    'prepare:prepare the Kong prefix in the configured prefix directory'
    'quit:gracefully quit a running Kong node'
    'reload:reload a Kong node'
    'restart:restart a Kong node'
    'roar:print Kong ASCII art'
    'runner:invoke a function in a kong module'
    'start:start Kong'
    'stop:stop a running Kong node'
    'vault:manage Kong vaults'
    'version:print Kong version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'kong command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        start)
          _arguments -s -S \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            '--db-timeout=[timeout for database operations]:seconds:' \
            '--lock-timeout=[timeout for locks]:seconds:' \
            '--nginx-conf=[custom Nginx configuration template]:template:_files' \
            '--run-migrations[run database migrations]' \
            '--vv[enable verbose mode]' \
            '--v[enable debug mode]' \
            && ret=0
          ;;
        stop)
          _arguments -s -S \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            && ret=0
          ;;
        reload)
          _arguments -s -S \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            '--nginx-conf=[custom Nginx configuration template]:template:_files' \
            && ret=0
          ;;
        restart)
          _arguments -s -S \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            '--nginx-conf=[custom Nginx configuration template]:template:_files' \
            '--run-migrations[run database migrations]' \
            '--db-timeout=[timeout for database operations]:seconds:' \
            && ret=0
          ;;
        check)
          _arguments -s -S \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            '1:configuration file:_files -g "*.conf"' \
            && ret=0
          ;;
        migrations)
          _arguments -s -S \
            '1:subcommand:(bootstrap up finish list reset)' \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            '-y[skip confirmation]' \
            '--yes[skip confirmation]' \
            '-f[force migration]' \
            '--force[force migration]' \
            '--db-timeout=[timeout for database operations]:seconds:' \
            '--lock-timeout=[timeout for locks]:seconds:' \
            && ret=0
          ;;
        config)
          _arguments -s -S \
            '1:subcommand:(db_import db_export init parse)' \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '2:config file:_files -g "*.{yml,yaml,json}"' \
            && ret=0
          ;;
        vault)
          _arguments -s -S \
            '1:subcommand:(get)' \
            '2:vault reference:' \
            '-c+[configuration file]:config file:_files -g "*.conf"' \
            '--conf=[configuration file]:config file:_files -g "*.conf"' \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            && ret=0
          ;;
        health)
          _arguments -s -S \
            '-p+[override prefix directory]:prefix dir:_files -/' \
            '--prefix=[override prefix directory]:prefix dir:_files -/' \
            && ret=0
          ;;
        *)
          _arguments -s -S '*:' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_kong "$@"
