#compdef parmed
# Documentation: https://man.archlinux.org/search?q=parmed
# Reference accessed: 2026-05-16

# ParmEd: parameter/topology file editor (Amber, CHARMM, GROMACS, OpenMM)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[input script]:file:_files' \
  '(-l --logfile)'{-l,--logfile=}'[log file]:file:_files' \
  '(-n --no-splash)'{-n,--no-splash}'[suppress splash banner]' \
  '(-O --overwrite)'{-O,--overwrite}'[overwrite output files]' \
  '(-p --prmtop)'{-p,--prmtop=}'[input topology file]:file:_files' \
  '(-c --coordinates)'{-c,--coordinates=}'[input coordinates]:file:_files' \
  '*::parmed script and args:_files' && ret=0
return ret
