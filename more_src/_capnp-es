#compdef capnp-es capnpc-js capnpc-ts capnpc-dts
# ============================================================================
# _capnp-es — zsh completion for unjs's TypeScript Cap'n Proto compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/unjs/capnp-es
#   Author     : unjs (UnJS — the Nuxt / Nitro tooling collective)
#   License    : MIT
#   Stars      : 177
#   Language   : TypeScript
#   npm        : capnp-es v0.0.14
#   Binaries   : capnp-es / capnpc-js / capnpc-ts / capnpc-dts
#                (package.json bin map, all pointing into ./dist/compiler/)
#   Last push  : 2026 (active)
#
# WHAT IT IS
#   capnp-es is "🔥 TypeScript implementation of the Cap'n Proto
#   serialization" — UnJS's modern fork / successor of jdiaz5513/capnp-ts,
#   shipping a JS/TS runtime *and* a code-generation compiler in a single
#   ESM-only package.  The CLI binaries are Cap'n Proto schema compiler
#   plugins (in the `capnp compile -o<plugin>` sense — the C++ `capnp`
#   front-end pipes schema messages to each plugin's stdin, and the
#   plugin emits target-language source files).  capnp-es plugs into
#   three target slots:
#     - capnpc-js   → JavaScript output  (also reachable as `capnp-es`)
#     - capnpc-ts   → TypeScript source output
#     - capnpc-dts  → TypeScript declaration-only output
#   When invoked directly with file arguments, capnp-es shells out to
#   the system `capnp compile` itself (passing through -I import paths
#   etc.) and forwards the schema bytes to its own compiler.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/compiler/cli.ts `usage` constant +
#                       parseOptions() argv walker + capnpcOptions whitelist)
#   capnp-es [OPTIONS]... <source.capnp>...
#
#   Positional arguments:
#     <source.capnp>...      Cap'n Proto schema files to compile
#
#   Output selection:
#     -o<LANG>[:<DIR>]       Output format and optional output directory
#     --output=<LANG>[:<DIR>]
#                            <LANG> is a comma-separated subset of
#                            "js,ts,dts" (default depends on which binary
#                            name was invoked).  Example:
#                              -ots:./gen        → write .ts to ./gen
#                              --output=js,dts   → emit both .js and .d.ts
#
#   Forwarded to `capnp compile` (passed through unchanged):
#     -I<DIR>                Add <DIR> to the list of directories
#     --import-path=<DIR>    searched for non-relative imports
#     -i                     Generate a new 64-bit unique ID for use in
#     --generate-id          a Cap'n Proto schema
#     --no-standard-import   Do not add any default import paths
#                            (use only those specified by -I)
#     --src-prefix=<PREFIX>  Remove the prefix from output file paths
#     --verbose              Verbose capnpc output
#
#   Standard:
#     --help                 Show usage and exit
#
# AXIS / CORPUS POSITION
#   capnp-es IS the canonical TypeScript Cap'n Proto library + compiler —
#   the modern successor to jdiaz5513/capnp-ts.  The npm package ships
#   both the runtime API (`import { ... } from "capnp-es"`) and the
#   four `bin` entries above as Cap'n Proto schema compiler plugins.
#   Verified via:
#     gh api repos/unjs/capnp-es/contents/package.json
#       → "name": "capnp-es"
#       → "bin": { "capnp-es": "./dist/compiler/capnpc-js.mjs",
#                  "capnpc-js": "./dist/compiler/capnpc-js.mjs",
#                  "capnpc-dts": "./dist/compiler/capnpc-dts.mjs",
#                  "capnpc-ts": "./dist/compiler/capnpc-ts.mjs" }
#     gh api repos/unjs/capnp-es/contents/src/compiler/cli.ts
#       → cliMain() + parseOptions() + capnpcOptions whitelist + usage
#   This entry is the TS-Node=121 leader bump that CLOSES Axis 66
#   (Cap'n Proto RPC Library) at 1/1/1 three-language symmetry:
#     Rust   = capnp + capnp-rpc       (R853, `tanour`, pactus-project)
#     Go     = capnproto.org/go/capnp/v3 (R854, `webfs`,  brendoncarroll)
#     TS-Node = capnp-es (unjs)         (R855, `capnp-es`, unjs)
#   Reaches the triple-121 landmark Rust=Go=TS-Node=121.
#
#   No completion for `capnp-es` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  The
#   adjacent `more_src/_capnp` in this corpus targets the C++ Cap'n Proto
#   reference compiler from Kenton Varda;  capnp-es / capnpc-js /
#   capnpc-ts / capnpc-dts are distinct npm-published binaries.
# ============================================================================

_capnp-es() {
    _arguments -s \
        '-o-[output format and optional output directory (lang[:dir])]:lang:_capnp_es_langs' \
        '--output=-[output format and optional output directory]:lang:_capnp_es_langs' \
        '*-I-[add directory to import search path]:import dir:_files -/' \
        '*--import-path=-[add directory to import search path]:import dir:_files -/' \
        '(-i --generate-id)'{-i,--generate-id}'[generate a new 64-bit unique ID for a Cap'\''n Proto schema]' \
        '--no-standard-import[do not add any default import paths]' \
        '--src-prefix=[remove the prefix from output file paths]:prefix:' \
        '--verbose[verbose capnpc output]' \
        '(- *)--help[show usage and exit]' \
        '*:Cap'\''n Proto schema file:_files -g "*.capnp"'
}

(( $+functions[_capnp_es_langs] )) ||
_capnp_es_langs() {
    _values -s , 'output language' \
        'js[JavaScript]' \
        'ts[TypeScript]' \
        'dts[TypeScript declarations only]'
}

_capnp-es "$@"
