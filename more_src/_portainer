#compdef portainer

# Zsh completion for Portainer - container management UI

_arguments -s -S \
  '--admin-password=[admin password hash]:hash:' \
  '--admin-password-file=[file containing admin password]:file:_files' \
  '--bind=[address and port to serve Portainer]:address:' \
  '--bind-https=[address and port to serve HTTPS]:address:' \
  '--data=[path to data directory]:directory:_files -/' \
  '--edge-compute[enable edge compute features]' \
  '--hide-label=[hide containers with this label]:label:' \
  '--host=[Docker daemon endpoint]:endpoint:' \
  '--http-disabled[disable HTTP]' \
  '--http-enabled[enable HTTP]' \
  '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
  '--log-mode=[log mode]:mode:(PRETTY JSON)' \
  '--logo=[URL to logo]:url:' \
  '--mtlscacert=[mTLS CA certificate]:file:_files' \
  '--mtlscert=[mTLS certificate]:file:_files' \
  '--mtlskey=[mTLS key]:file:_files' \
  '--snapshot-interval=[snapshot interval]:duration:' \
  '--ssl[enable SSL]' \
  '--sslcert=[SSL certificate]:file:_files' \
  '--sslkey=[SSL key]:file:_files' \
  '--templates-url=[templates URL]:url:' \
  '--tlscacert=[TLS CA certificate]:file:_files' \
  '--tlscert=[TLS certificate]:file:_files' \
  '--tlskey=[TLS key]:file:_files' \
  '--tlsskipverify[skip TLS verification]' \
  '--tunnel-addr=[tunnel server address]:address:' \
  '--tunnel-port=[tunnel server port]:port:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
