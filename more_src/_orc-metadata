#compdef orc-metadata
# Documentation: https://orc.apache.org/docs/cpp-tools.html
# orc-metadata - display ORC file metadata as JSON

local ret=1

_arguments -s -S \
  '-v[verbose mode with additional layout information]' \
  '--raw[print the protocol buffers from the ORC file directly]' \
  '*:ORC file:_files' && ret=0

return ret
