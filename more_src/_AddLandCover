#compdef AddLandCover
# Documentation: https://step.esa.int/main/wp-content/help/versions/9.0.0/snap/org.esa.snap.snap.gpf.ui/gpf/org_esa_snap_landcover_gpf_AddLandCoverOp.html
# ESA SNAP gpt AddLandCover operator - add a land cover band to a product

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PlandCoverNames=[the land cover model]:model' \
  '-PexternalFiles=[external landcover files]:files:_files' \
  '-PresamplingMethod=[spatial resampling method]:method' \
  '*:graph xml:_files' && ret=0

return ret
