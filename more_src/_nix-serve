#compdef nix-serve

# Zsh completion for nix-serve - serve Nix store as a binary cache

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --port)'{-p,--port}'[port to listen on]:port' \
  '--host[host to bind to]:host' \
  '(-w --workers)'{-w,--workers}'[number of workers]:number' \
  '--sign[sign narinfo files]' \
  '--store[Nix store URL]:url'
