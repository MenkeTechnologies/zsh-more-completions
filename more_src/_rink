#compdef rink

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-f+[currency file]:file:_files' \
  '--fetch-currency=[currency file]:file:_files' \
  '-e+[expression to evaluate]:expression:' \
  '--expression=[expression to evaluate]:expression:' \
  '--config-path=[config file]:file:_files' \
  '--no-config[ignore config file]' \
  '*:expression:' && ret=0

return ret
