#compdef rink
# Documentation: https://rinkcalc.app/cli-manpage
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-f --file)'{-f+,--file=}'[read expressions from a file, one per line]:file:_files' \
  '--config-path[print path to the config file and exit]' \
  '--fetch-currency[fetch the latest currency data and exit]' \
  '*:expression:' && ret=0

return ret
