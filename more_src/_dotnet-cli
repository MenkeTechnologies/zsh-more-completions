#compdef dotnet
# _dotnet-cli — .NET SDK CLI (Microsoft, C#); build/run/publish .NET projects
# upstream: https://github.com/dotnet/sdk

_dotnet-cli() {
    local -a sub=(
        'add:add reference/package'
        'build:build project'
        'build-server:start/stop build server'
        'clean:clean output'
        'format:format source'
        'help:show help'
        'list:list references'
        'msbuild:run msbuild'
        'new:create new project'
        'nuget:NuGet commands'
        'pack:pack NuGet package'
        'publish:publish project'
        'remove:remove reference/package'
        'restore:restore packages'
        'run:run project'
        'sdk:SDK commands'
        'sln:solution commands'
        'store:store assemblies in cache'
        'test:run tests'
        'tool:tool commands'
        'vstest:run vstest'
        'watch:watch + rebuild'
        'workload:workload commands'
        'fsi:F# interactive'
        'reference:reference commands'
        'package:package commands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--info[show info]' \
        '--list-sdks[list SDKs]' \
        '--list-runtimes[list runtimes]' \
        '--diagnostics[diagnostics]' \
        '-d[diagnostics]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dotnet subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:template:(console classlib mstest nunit3 xunit web mvc razor blazor blazorserver blazorwasm webapi webapp gitignore globaljson sln tool-manifest)' \
                    '--name+[name]:str:' \
                    '-n+[name]:str:' \
                    '-o+[output]:dir:_files -/' \
                    '--output+[output]:dir:_files -/' \
                    '--force[force]' \
                    '--dry-run[dry run]' \
                    '--language+[language]:lang:(C# F# VB)' \
                    '-lang+[language]:lang:(C# F# VB)' ;;
                build|run|publish|test|pack|clean|restore) _arguments \
                    '-c+[configuration]:cfg:(Debug Release)' \
                    '--configuration+[configuration]:cfg:(Debug Release)' \
                    '-f+[framework]:framework:' \
                    '--framework+[framework]:framework:' \
                    '-r+[runtime]:runtime:' \
                    '--runtime+[runtime]:runtime:' \
                    '-o+[output]:dir:_files -/' \
                    '--output+[output]:dir:_files -/' \
                    '--no-restore[no restore]' \
                    '--no-build[no build]' \
                    '--no-dependencies[no dependencies]' \
                    '--verbosity+[verbosity]:level:(quiet minimal normal detailed diagnostic)' \
                    '-v+[verbosity]:level:(quiet minimal normal detailed diagnostic)' \
                    '*:project:_files' ;;
                add) _arguments '1:add cmd:(package reference)' '*:args:' ;;
                sln) _arguments '1:sln cmd:(add list remove migrate)' '*:args:' ;;
                tool) _arguments '1:tool cmd:(install list restore run search uninstall update)' '*:args:' ;;
                workload) _arguments '1:workload cmd:(clean install list repair restore search uninstall update)' '*:args:' ;;
                nuget) _arguments '1:nuget cmd:(add delete disable enable list locals push remove sign sources trust update verify why)' '*:args:' ;;
                format) _arguments \
                    '--include+[paths]:paths:' \
                    '--exclude+[paths]:paths:' \
                    '--verify-no-changes[verify no changes]' \
                    '--no-restore[no restore]' \
                    '--report+[report file]:file:_files' \
                    '*:project:_files' ;;
                watch) _arguments \
                    '--project+[project]:file:_files' \
                    '--no-hot-reload[no hot reload]' \
                    '--no-restore[no restore]' \
                    '--verbose[verbose]' \
                    '*:cmd:' ;;
            esac
            ;;
    esac
}

_dotnet-cli "$@"
