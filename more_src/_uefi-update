#compdef uefi-update
# Documentation: https://man.archlinux.org/search?q=uefi-update
# Reference accessed: 2026-05-16

# uefi-update: stage UEFI firmware capsules for next-boot apply
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--list[list pending capsules]' \
  '--add[stage capsule]:file:_files -g "*.cap"' \
  '--remove[remove pending capsule]:name:' \
  '--apply[apply on next boot]' \
  '*::uefi-update args:_files' && ret=0
return ret
