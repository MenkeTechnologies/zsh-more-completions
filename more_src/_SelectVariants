  '--ignore-non-ref-in-types[If set, NON_REF alleles will be ignored for variant type determination, which is requir...]' \
  '(--keep-ids -ids)'{--keep-ids,-ids}'[List of variant rsIDs to select]' \
  '(--exclude-ids -xl-ids)'{--exclude-ids,-xl-ids}'[List of variant rsIDs to exclude]:value:' \
  '--fully-decode[If true, the incoming VariantContext will be fully decoded]' \
  '--max-indel-size=[Maximum size of indels to include]:value:' \
  '--min-indel-size=[Minimum size of indels to include]:value:' \
  '--max-filtered-genotypes=[Maximum number of samples filtered at the genotype level]:value:' \
  '--min-filtered-genotypes=[Minimum number of samples filtered at the genotype level]:value:' \
  '--max-fraction-filtered-genotypes=[Maximum fraction of samples filtered at the genotype level]:value:' \
