  '-invert-select[Invert the selection criteria for -select]' \
  '--exclude-non-variants[Don'\''t include non-variant sites]' \
  '--exclude-filtered[Don'\''t include filtered sites]' \
  '--preserve-alleles[Preserve original alleles, do not trim]' \
  '--remove-unused-alternates[Remove alternate alleles not present in any genotypes]' \
  '--restrict-alleles-to=[Select only variants of a particular allelicity]:value:' \
  '--keep-original-ac[Store the original AC, AF, and AN values after subsetting]' \
