  '(--concordance -conc)'{--concordance,-conc}'[Output variants also called in this comparison track]:value:' \
  '(--output -O)'{--output,-O}'[Path to which variants should be written]:value:_files' \
  '(--sample-name -sn)'{--sample-name,-sn}'[Include genotypes from this sample]:value:' \
  '(--sample-expressions -se)'{--sample-expressions,-se}'[Regular expression to select multiple samples]:value:' \
  '(--exclude-sample-name -xl-sn)'{--exclude-sample-name,-xl-sn}'[Exclude genotypes from this sample]:value:' \
  '(--exclude-sample-expressions -xl-se)'{--exclude-sample-expressions,-xl-se}'[List of sample expressions to exclude]:value:' \
  '--select=[select]:value:' \
