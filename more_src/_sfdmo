#compdef sfdmo
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mdmo.c
# Madagascar: Kirchhoff DMO with antialiasing by reparameterization

local ret=1

_arguments -s -S \
  'mint=[starting time sample]:mint' \
  'n=[number of offset samples]:n' \
  'adj=[adjoint flag]:adj:(y n)' \
  'inv=[inversion flag]:inv:(y n)' \
  'type=[type of amplitude (0,1,2,3)]:type:(0 1 2 3)' \
  'h=[half-offset (required when n3=1)]:h' \
  'half=[y - third axis is half-offset instead of full offset]:half:(y n)' \
  'velhalf=[half-velocity]:velhalf' \
  '*:RSF file:_files' && ret=0

return ret
