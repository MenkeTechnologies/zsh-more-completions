#compdef kwp64 kwp
# Documentation: https://github.com/hashcat/kwprocessor/blob/master/src/kwp.c
# kwprocessor — keyboard-walk candidate generator (hashcat). Flags from src/kwp.c usage().

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
  '(-b --keyboard-basic)'{-b+,--keyboard-basic=}'[include chars reachable without shift or altgr]:bool:(0 1)' \
  '(-s --keyboard-shift)'{-s+,--keyboard-shift=}'[include chars reachable by holding shift]:bool:(0 1)' \
  '(-a --keyboard-altgr)'{-a+,--keyboard-altgr=}'[include chars reachable by holding altgr (non-english)]:bool:(0 1)' \
  '(-z --keyboard-all)'{-z,--keyboard-all}'[shortcut to enable all --keyboard-* modifiers]' \
  '(-1 --keywalk-south-west)'{-1+,--keywalk-south-west=}'[routes heading diagonale south-west]:bool:(0 1)' \
  '(-2 --keywalk-south)'{-2+,--keywalk-south=}'[routes heading straight south]:bool:(0 1)' \
  '(-3 --keywalk-south-east)'{-3+,--keywalk-south-east=}'[routes heading diagonale south-east]:bool:(0 1)' \
  '(-4 --keywalk-west)'{-4+,--keywalk-west=}'[routes heading straight west]:bool:(0 1)' \
  '(-5 --keywalk-repeat)'{-5+,--keywalk-repeat=}'[routes repeating character]:bool:(0 1)' \
  '(-6 --keywalk-east)'{-6+,--keywalk-east=}'[routes heading straight east]:bool:(0 1)' \
  '(-7 --keywalk-north-west)'{-7+,--keywalk-north-west=}'[routes heading diagonale north-west]:bool:(0 1)' \
  '(-8 --keywalk-north)'{-8+,--keywalk-north=}'[routes heading straight north]:bool:(0 1)' \
  '(-9 --keywalk-north-east)'{-9+,--keywalk-north-east=}'[routes heading diagonale north-east]:bool:(0 1)' \
  '(-c --keywalk-cont)'{-c,--keywalk-cont}'[shortcut to enable adjacent keys (continuous walks)]' \
  '(-0 --keywalk-all)'{-0,--keywalk-all}'[shortcut to enable all --keywalk-* directions]' \
  '(-n --keywalk-distance-min)'{-n+,--keywalk-distance-min=}'[minimum allowed distance between keys]:num:' \
  '(-x --keywalk-distance-max)'{-x+,--keywalk-distance-max=}'[maximum allowed distance between keys]:num:' \
  '1:basechars file:_files' \
  '2:keymap file:_files' \
  '3:routes file:_files' \
  && ret=0

return ret
