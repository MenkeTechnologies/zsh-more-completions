#compdef alignmentSieve
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/alignmentSieve.html
# deepTools: filter alignments in a BAM/CRAM file, optionally output BEDPE

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bam)'{-b,--bam}'[indexed BAM file input]:bam:_files -g "*.bam"' \
  '(-o --outFile)'{-o,--outFile}'[output file for filtered alignments]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '--filterMetrics[save filtering statistics]:file:_files' \
  '--filteredOutReads[output reads failing filters]:file:_files' \
  '(-l --label)'{-l,--label}'[custom label]:label:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '--shift[adjust fragment ends (2 or 4 integers)]:shift:' \
  '--ATACshift[ATAC-seq standard shifting]' \
  '--genomeChunkLength[bases per thread]:n:' \
  '--BED[output BEDPE format instead of BAM]' \
  '--filterRNAstrand[strand selection]:strand:(forward reverse)' \
  '--ignoreDuplicates[skip duplicate reads]' \
  '--minMappingQuality[mapping quality threshold]:qual:' \
  '--samFlagInclude[include by SAM flag]:flag:' \
  '--samFlagExclude[exclude by SAM flag]:flag:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[exclude regions (BED/GTF)]:file:_files' \
  '--minFragmentLength[minimum fragment length]:length:' \
  '--maxFragmentLength[maximum fragment length]:length:' && ret=0

return ret
