#compdef scalafmt

# Zsh completion for scalafmt - Scala code formatter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to .scalafmt.conf]:config file:_files -g "*.conf"' \
  '--config-str[configuration as HOCON string]:config string' \
  '(-f --file)'{-f,--file}'[format specific file]:file:_files -g "*.{scala,sbt,sc}"' \
  '--exclude[regex to exclude files]:regex pattern' \
  '--respect-project-filters[respect project filters in config]' \
  '--check[check if files are formatted (no changes)]' \
  '--test[test mode, return non-zero on unformatted files]' \
  '--diff[format only modified files compared to git ref]' \
  '--diff-branch[format only modified files compared to branch]:branch' \
  '--stdin[read from stdin]' \
  '--stdout[write to stdout]' \
  '--non-interactive[disable interactive mode]' \
  '--quiet[suppress output]' \
  '--debug[enable debug output]' \
  '--mode[formatting mode]:mode:(diff any)' \
  '--assume-filename[filename for stdin mode]:filename' \
  '--list[list files that differ from formatted output]' \
  '--no-stderr[do not write to stderr]' \
  '--runner.debug[enable runner debug mode]' \
  '*:files:_files -g "*.{scala,sbt,sc}"' && ret=0

return ret
