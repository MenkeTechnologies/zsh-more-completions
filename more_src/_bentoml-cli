#compdef bentoml-cli bentoml2
# _bentoml-cli — BentoML bentoml-cli CLI command-line frontend wrapping the BentoML unified AI framework providing build serve push pull list show delete containerize deploy import export tag run start-server gpu-monitor models models-pull models-push start runner local-docker-deploy yatai-deploy openai-compatible (BentoML team, Python); click
# upstream: https://www.bentoml.com/

_bentoml-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'serve:serve a Bento'
        'build:build a Bento'
        'containerize:containerize a Bento'
        'deploy:deploy a Bento'
        'push:push a Bento'
        'pull:pull a Bento'
        'list:list Bentos'
        'show:show Bento'
        'delete:delete a Bento'
        'tag:tag operations'
        'import:import Bento'
        'export:export Bento'
        'models:model store operations'
        'runners:runner operations'
        'start-runner-server:start a runner server'
        'start-server:start a Bento server'
        'yatai:Yatai deploy operations'
        'gpu-monitor:GPU monitor'
        'openllm:OpenLLM operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-server=+[url]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '-h+[host]:_hosts' \
        '--working-dir=+[dir]:dir:_files -/' \
        '--reload[reload on file changes]' \
        '--no-reload[no reload]' \
        '--production[production mode]' \
        '--workers=+[N]:n:' \
        '--worker-class=+[name]:str:' \
        '--backlog=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--bento=+[tag]:str:' \
        '-c+[config file]:file:_files -g "bentoml.yaml bentofile.yaml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bentoml-cli subcommand' sub ;;
        args)
            case $words[1] in
                serve|build|containerize|deploy|push|pull|delete|show|tag|import|export) _arguments '*:bento tag:' ;;
                models) _arguments '1:op:(list get import export push pull delete)' '*:model tag:' ;;
            esac
            ;;
    esac
}

_bentoml-cli "$@"
