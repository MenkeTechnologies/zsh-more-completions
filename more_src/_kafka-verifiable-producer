#compdef kafka-verifiable-producer
# Documentation: https://kafka.apache.org/documentation/ (kafka-verifiable-producer.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '--topic[Produce messages to this topic]:topic:'
    '--max-messages[Produce this many messages (-1 to produce until killed)]:count:'
    '--throughput[Throttle maximum message throughput (-1 to disable)]:throughput:'
    '--acks[Acks required on each produced message]:acks:'
    '--producer.config[(DEPRECATED) Producer config properties file]:file:_files'
    '--message-create-time[Send messages with creation time (ms since epoch)]:ms:'
    '--value-prefix[Prefix each produced value with this number]:prefix:'
    '--repeating-keys[Number of keys to cycle through (0 to disable)]:count:'
    '--command-config[Config properties file]:file:_files'
    '--bootstrap-server[REQUIRED: The server(s) to connect to]:host\:port:'
)

_arguments -s -S $arguments
