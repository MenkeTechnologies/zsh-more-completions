#compdef NormalizeFasta
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#NormalizeFasta
# Picard: normalize lines and names in a FASTA file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input FASTA file to normalize]:fasta:_files -g "*.(fa|fasta|fa.gz|fasta.gz)"' \
  {-O=,--OUTPUT=}'[output FASTA file to write]:fasta:_files -g "*.(fa|fasta)"' \
  '--LINE_LENGTH=[line length for the output FASTA]:int:' \
  '--TRUNCATE_SEQUENCE_NAMES_AT_WHITESPACE=[truncate sequence names at first whitespace]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:fasta file:_files -g "*.(fa|fasta|fa.gz|fasta.gz)"' && ret=0

return ret
