#compdef lazycut
# Documentation: https://github.com/emin-ozata/lazycut
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lazycut is a terminal UI video trimmer (ffmpeg + chafa). It has a default
# TUI mode (taking a media path and optional --fps) plus "trim" and "probe"
# subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'trim:Trim a video non-interactively'
  'probe:Show ffprobe-derived info about a media file'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '--fps=[preview frame rate]:fps:' \
  '1: :->cmd_or_file' \
  '*:: :->args' && ret=0

case $state in
  (cmd_or_file)
    _describe -t commands 'lazycut subcommand' commands
    _files
    ret=0
    ;;
  (args)
    case $line[1] in
      (trim)
        _arguments \
          '--in=[start timestamp (HH:MM:SS)]:time:' \
          '--out=[end timestamp (HH:MM:SS)]:time:' \
          '-o[output file]:file:_files' \
          '*:media:_files' && ret=0
        ;;
      (probe)
        _arguments '*:media:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
