#compdef tuisky
# Documentation: https://man.archlinux.org/search?q=tuisky
# Reference accessed: 2026-05-16

# Zsh completion for tuisky Bluesky TUI (github.com/sugyan/tuisky)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' && ret=0

return ret
