#compdef yggdrasilctl
# Documentation: https://github.com/yggdrasil-network/yggdrasil-go (cmd/yggdrasilctl/main.go)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _cmds
_cmds=(
  'list:show available admin socket commands and their arguments'
  'getSelf:retrieve node info (build, IPv6, routing table size, public key)'
  'getPeers:display peer connections with state, latency, traffic'
  'getTree:show spanning tree (public key, IP, parent, sequence)'
  'getPaths:list paths to other nodes'
  'getSessions:display active sessions (uptime, traffic)'
  'getNodeInfo:retrieve node metadata'
  'getMulticastInterfaces:show multicast interface configuration'
  'getTun:display TUN interface status'
  'addPeer:add a peer connection'
  'removePeer:remove a peer connection'
)

_arguments -C \
  '(- *)-ver[display build name and version information]' \
  '-json[output response as formatted JSON]' \
  '-no-borders[display tables without borders]' \
  '-endpoint=[connection endpoint (unix\:// or tcp\://)]:endpoint:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'yggdrasilctl command' _cmds && ret=0
    ;;
esac

return ret
