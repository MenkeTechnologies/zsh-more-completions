#compdef vespa
# Documentation: https://man.archlinux.org/search?q=vespa
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate:activate package'
  'auth:authentication'
  'clone:clone sample app'
  'completion:generate completion'
  'config:CLI config'
  'curl:proxy curl with creds'
  'deploy:deploy package'
  'destroy:destroy app deployment'
  'document:document operations'
  'feed:feed documents'
  'fetch:fetch package'
  'gendoc:generate docs'
  'help:show help'
  'inspect:inspect application'
  'log:read deployment logs'
  'login:log in'
  'logout:log out'
  'man:show command help'
  'prepare:prepare package'
  'prod:production tasks'
  'query:run a Vespa query'
  'status:check service status'
  'sync:sync data'
  'test:run tests'
  'version:show version'
  'visit:visit documents'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-a+[application]:app:' \
  '*--application=[application]:app:' \
  '*-C+[client cert]:file:_files' \
  '*--cert=[client cert]:file:_files' \
  '*--color=[color]:c:(auto always never)' \
  '*-i+[instance]:i:' \
  '*--instance=[instance]:i:' \
  '*-c+[cluster]:c:' \
  '*--cluster=[cluster]:c:' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-t+[target]:t:(local cloud hosted)' \
  '*--target=[target]:t:(local cloud hosted)' \
  '*-z+[zone]:z:' \
  '*--zone=[zone]:z:' \
  '*--wait=[wait seconds]:s:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vespa command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy|prepare|activate|fetch)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (query)
        _arguments \
          '*--header=[HTTP header]:h:' \
          '*: :' && ret=0 ;;
      (feed)
        _arguments \
          '--max-streams=[max streams]:n:' \
          '--max-connections=[max connections]:n:' \
          '--compression=[compression]:c:(none auto gzip)' \
          '--route=[route]:r:' \
          '--verbose[verbose]' \
          '--dry-run[dry run]' \
          '--show-errors[show errors]' \
          '--summary-period=[summary period]:s:' \
          '*: :_files -g "*.json *.jsonl"' && ret=0 ;;
      (document)
        _arguments \
          '1:subcommand:(get put update remove)' \
          '*: :_files' && ret=0 ;;
      (visit)
        _arguments \
          '--cluster=[cluster]:c:' \
          '--bucket-space=[bucket space]:s:' \
          '--field-set=[field set]:f:' \
          '--selection=[selection]:s:' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(get set unset)' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(api-key cert login logout show)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
