#compdef scatter
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss173.html
# KAPPA: displays a scatter plot between data in two NDFs

local ret=1

_arguments -s \
  'IN1=[NDF on the horizontal axis]:ndf:_files -g "*.sdf"' \
  'IN2=[NDF on the vertical axis]:ndf:_files -g "*.sdf"' \
  'COMP1=[component for horizontal axis]:comp:(Data Variance Error)' \
  'COMP2=[component for vertical axis]:comp:(Data Variance Error)' \
  'COMPRESS=[compression factors before display]:factors' \
  'DEVICE=[graphics device]:device' \
  'AXES=[draw annotated axes]:bool:(TRUE FALSE)' \
  'CLEAR=[clear the device first]:bool:(TRUE FALSE)' \
  'FIT=[calculate and display a linear fit]:bool:(TRUE FALSE)' \
  'MARGIN=[widths of plot margins]:margin' \
  'MARKER=[marker symbol type]:n' \
  'PERC1=[percentiles for default x limits]:perc' \
  'PERC2=[percentiles for default y limits]:perc' \
  'STYLE=[plotting style]:style' \
  'XLEFT=[left horizontal axis value]:value' \
  'XRIGHT=[right horizontal axis value]:value' \
  'YBOT=[bottom vertical axis value]:value' \
  'YTOP=[top vertical axis value]:value' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
