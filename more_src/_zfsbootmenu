#compdef zfsbootmenu generate-zbm
# Documentation: https://github.com/zbm-dev/zfsbootmenu
# Reference accessed: 2026-05-27
# Verified: upstream bin/generate-zbm Getopt::Long table (zbm-dev/zfsbootmenu)

# Zsh completion for generate-zbm (ZFSBootMenu image builder).
# The `zfsbootmenu` binary itself is the boot-time menu and takes no CLI flags
# in the conventional sense, so the option list applies to generate-zbm.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --showver)'{-V,--showver}'[print ZFSBootMenu version and exit]' \
  '--version=[override the ZFSBootMenu version string written into the image]:version:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-c --config)'{-c+,--config=}'[path to a configuration file]:config:_files' \
  '(-k --kernel)'{-k+,--kernel=}'[explicit kernel path]:kernel:_files' \
  '(-K --kver)'{-K+,--kver=}'[explicit kernel version]:kver:' \
  '(-b --bootdir)'{-b+,--bootdir=}'[path to search for kernel files]:directory:_files -/' \
  '(-C --confd)'{-C+,--confd=}'[path to initramfs configuration directory]:directory:_files -/' \
  '(-l --cmdline)'{-l+,--cmdline=}'[override kernel command line]:cmdline:' \
  '(-p --prefix)'{-p+,--prefix=}'[output image filename prefix]:prefix:' \
  '*'{-H+,--hookd=}'[additional mkinitcpio hook directory (repeatable)]:directory:_files -/' \
  '(-i --initcpio --no-initcpio)'{-i,--initcpio}'[force mkinitcpio backend]' \
  '(-i --initcpio --no-initcpio)--no-initcpio[force dracut backend (negation of --initcpio)]' \
  '--enable[force Global.ManageImages on]' \
  '--disable[force Global.ManageImages off]' && ret=0

return ret
