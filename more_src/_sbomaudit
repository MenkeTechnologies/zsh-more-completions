#compdef sbomaudit
# Documentation: https://pypi.org/project/sbomaudit/
# audit the contents of an SBOM for quality and policy compliance

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-file)'{-i,--input-file}'=[SBOM file to process]:file:_files' \
  '--offline[operate without external system access]' \
  '--cpecheck[validate CPE specifications]' \
  '--purlcheck[validate PURL specifications]' \
  '--disable-license-check[skip SPDX license validation]' \
  '--age=[minimum package age in days]:days:' \
  '--maxage=[maximum package age in years]:years:' \
  '--allow=[allowlist file path]:file:_files' \
  '--deny=[denylist file path]:file:_files' \
  '--verbose[detailed reporting]' \
  '--debug[include debug information]' \
  '(-o --output-file)'{-o,--output-file}'=[output destination]:file:_files' \
  '(-V --version)'{-V,--version}'[display version]' && ret=0

return ret
