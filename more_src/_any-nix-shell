#compdef any-nix-shell
# Documentation: https://github.com/haslersn/any-nix-shell
# preserve the current shell when entering a nix-shell or nix shell environment

local ret=1

_arguments -s -S \
  '--info-right[show loaded package info on the right of the prompt]' \
  '1:shell:(fish zsh xonsh)' && ret=0

return ret
