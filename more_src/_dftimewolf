#compdef dftimewolf
# Documentation: https://dftimewolf.readthedocs.io/en/latest/user-manual.html
# dfTimewolf - DFIR orchestration recipe runner

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*::recipe:->recipes' && ret=0

case $state in
  recipes)
    _values 'dftimewolf recipe' \
      'local_plaso[process file paths with plaso to Timesketch]' \
      'plaso_ts[process plaso storage to Timesketch]' \
      'aws_forensics[copy AWS volumes for forensics]' \
      'gcp_forensics[copy GCP disks for forensics]' \
      'gce_disk_export[export GCE disk image]' \
      'grr_artifact_grep[grep GRR artifacts]' \
      'grr_artifact_ts[collect GRR artifacts to Timesketch]' \
      'grr_files_collect[collect files via GRR]' \
      'grr_flow_collect[collect a GRR flow]' \
      'grr_hunt_artifacts[launch a GRR artifact hunt]' \
      'grr_hunt_file[launch a GRR file hunt]' && ret=0
    ;;
esac

return ret
