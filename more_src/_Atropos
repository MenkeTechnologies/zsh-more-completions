#compdef Atropos
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/Atropos.cxx — Bayesian image segmentation via finite mixtures (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '*'{-a+,--intensity-image=}'[intensity image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-b --bspline)'{-b+,--bspline=}'[BSpline smoothing of intensity images]:spec:_default' \
    '(-i --initialization)'{-i+,--initialization=}'[init strategy: Random/Otsu/KMeans/PriorProbability/PriorLabel]:spec:_default' \
    '(-s --partial-volume-label-set)'{-s+,--partial-volume-label-set=}'[partial-volume label set]:spec:_default' \
    '--use-partial-volume-likelihoods=[use partial-volume likelihoods]:n:(0 1)' \
    '(-p --posterior-formulation)'{-p+,--posterior-formulation=}'[posterior formulation]:spec:_default' \
    '(-x --mask-image)'{-x+,--mask-image=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-c --convergence)'{-c+,--convergence=}'[convergence (iters,threshold)]:spec:_default' \
    '(-k --likelihood-model)'{-k+,--likelihood-model=}'[likelihood model]:model:(Gaussian HistogramParzenWindows ManifoldParzenWindows JointShapeAndOrientationProbability LogEuclideanGaussian)' \
    '(-m --mrf)'{-m+,--mrf=}'[MRF parameters [smoothing,radius]]:spec:_default' \
    '(-g --icm)'{-g+,--icm=}'[ICM regularization]:spec:_default' \
    '(-r --use-random-seed)'{-r+,--use-random-seed=}'[use a random seed]:n:(0 1)' \
    '(-o --output)'{-o+,--output=}'[output image / posteriors]:file:_files' \
    '(-u --minimize-memory-usage)'{-u+,--minimize-memory-usage=}'[minimize memory usage]:n:(0 1)' \
    '--winsorize-outliers=[winsorize outliers]:spec:_default' \
    '(- *)'{-v,--version}'[print version]' \
    '--verbose=[verbosity level]:n:(0 1 2)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
