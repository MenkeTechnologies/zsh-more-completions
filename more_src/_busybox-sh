#compdef busybox
# _busybox-sh — BusyBox The Swiss Army Knife of Embedded Linux (Bruce Perens, Erik Andersen et al); single-binary implementation of common UNIX tools
# upstream: https://busybox.net

_busybox-sh() {
    _arguments \
        '--help[show help]' \
        '--list[list applets]' \
        '--list-full[list applets with paths]' \
        '--install[install applet symlinks]' \
        '*:applet:'
}

_busybox-sh "$@"
