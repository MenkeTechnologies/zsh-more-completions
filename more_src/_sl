#compdef sl
# Documentation: https://man.archlinux.org/search?q=sl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'absorb:absorb pending changes'
  'add:track files'
  'addremove:track new and remove missing'
  'amend:amend current commit'
  'annotate:show file authors'
  'backout:reverse a commit'
  'bookmark:create/list/edit bookmarks'
  'cat:show file contents'
  'clean:remove untracked files'
  'clone:clone a repository'
  'commit:create commit'
  'config:edit configuration'
  'diff:show changes'
  'fold:squash commits'
  'forget:untrack files'
  'githelp:translate git command'
  'goto:check out a commit'
  'graft:cherry-pick'
  'help:show help'
  'hide:hide commits'
  'histedit:interactive history editor'
  'init:create a repository'
  'journal:show journal of bookmarks'
  'log:show commits'
  'metaedit:edit metadata'
  'next:check out next commit'
  'pr:GitHub pull request'
  'prev:check out previous commit'
  'pull:pull changes'
  'push:push changes'
  'rebase:rebase commits'
  'redo:redo undo'
  'remove:untrack and delete'
  'restack:restack commits'
  'revert:revert files'
  'root:show repo root'
  'shelve:shelve changes'
  'show:show commit details'
  'split:split commit'
  'ssl:certificate management'
  'status:show modified files'
  'unamend:undo amend'
  'uncommit:undo commit'
  'undo:undo last operation'
  'unhide:unhide commits'
  'unshelve:unshelve changes'
  'web:open ISL web UI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'sapling subcommand' subcommands && ret=0 ;;
esac

return ret
