#compdef act

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-W+[path to workflow file or directory]:path:_files' \
  '--workflows=[path to workflow file or directory]:path:_files' \
  '-j+[run a specific job]:job id' \
  '--job=[run a specific job]:job id' \
  '-l[list available workflows and jobs]' \
  '--list[list available workflows and jobs]' \
  '-n[dry run, do not start containers]' \
  '--dryrun[dry run, do not start containers]' \
  '-b[bind the working directory]' \
  '--bind[bind the working directory]' \
  '-s+[secret to provide]:secret (NAME=VALUE)' \
  '--secret=[secret to provide]:secret (NAME=VALUE)' \
  '--secret-file=[file with secrets]:secret file:_files' \
  '--env-file=[environment file]:env file:_files' \
  '-e+[path to event JSON file]:event file:_files' \
  '--eventpath=[path to event JSON file]:event file:_files' \
  '-P+[custom image for platform]:platform mapping' \
  '--platform=[custom image for platform]:platform mapping' \
  '--privileged[use privileged mode]' \
  '-r[reuse container state]' \
  '--reuse[reuse container state]' \
  '--rm[automatically remove containers]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--container-architecture=[container architecture]:arch:(linux/amd64 linux/arm64)' \
  '--artifact-server-path=[path to artifact server storage]:directory:_directories' \
  '--matrix=[specify matrix values]:matrix (key\:value)' \
  '--input=[action input override]:input (key=value)' \
  '--var=[repository variable]:var (key=value)' \
  '--var-file=[file with variables]:var file:_files' \
  '--action-offline-mode[run with action offline mode]' \
  '--detect-event[use workflow triggers to determine event]' \
  '--container-daemon-socket=[path to Docker daemon socket]:socket:_files' \
  '--graph[draw workflows]' \
  '1:event:(push pull_request pull_request_target workflow_dispatch schedule release issues issue_comment create delete deployment fork watch workflow_call)' && ret=0

return ret
