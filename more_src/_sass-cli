#compdef sass-cli
# _sass-cli — Sass CSS preprocessor (dart-sass) CLI alias (Sass team / Natalie Weizenbaum, Dart); custom argparse
# upstream: https://github.com/sass/dart-sass

_sass-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--stdin[read input from stdin]' \
        '--indented[indented (Sass) syntax]' \
        '--scss[SCSS syntax]' \
        '--no-source-map[no source map]' \
        '--source-map-urls=+[source map URL style]:s:(relative absolute)' \
        '--embed-sources[embed sources in source map]' \
        '--embed-source-map[embed source map in CSS]' \
        '--style=+[output style]:s:(expanded compressed)' \
        '-s+[output style]:s:(expanded compressed)' \
        '--no-charset[no charset]' \
        '--error-css[error CSS]' \
        '--no-error-css[no error CSS]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--quiet-deps[quiet deprecations]' \
        '--fatal-deprecation=+[fatal deprecation]:str:' \
        '--future-deprecation=+[future deprecation]:str:' \
        '--no-trace[no trace]' \
        '--color[force color]' \
        '-c[force color]' \
        '--no-color[no color]' \
        '--no-unicode[no unicode]' \
        '--verbose[verbose]' \
        '--no-watch[no watch]' \
        '--watch[watch and rebuild]' \
        '-w[watch and rebuild]' \
        '--poll[poll]' \
        '--update[update only modified]' \
        '--load-path=+[load path]:list:_files -/' \
        '-I+[load path]:list:_files -/' \
        '--pkg-importer=+[pkg importer]:str:' \
        '--silence-deprecation=+[silence deprecation]:list:' \
        '--no-source-map-urls[no source map urls]' \
        '*:input-output:_files -g "*.sass *.scss *.css"'
}

_sass-cli "$@"
