#compdef radosgw

# radosgw: Ceph RADOS Gateway HTTP server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[gateway id]:id:' \
  '--id=[gateway id]:id:' \
  '-n[name]:name:' \
  '--name=[name]:name:' \
  '-d[foreground (debug)]' \
  '-f[foreground]' \
  '--foreground[foreground]' \
  '--rgw-zone=[zone name]:name:' \
  '--rgw-zonegroup=[zonegroup name]:name:' \
  '--rgw-realm=[realm name]:name:' \
  '--rgw-frontends=[front end config]:fmt:(beast civetweb)' \
  '*::radosgw args:_files' && ret=0
return ret
