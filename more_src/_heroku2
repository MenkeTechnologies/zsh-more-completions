#compdef heroku2
# _heroku2 — Salesforce Heroku heroku2 CLI command-line frontend wrapping the Heroku Salesforce Platform-as-a-Service PaaS for deploying and managing apps providing originally GitHub-hosted now hosted-by-Salesforce-Heroku written in Node TypeScript create destroy apps releases logs ps run config addons buildpacks domains certs labs labs-info maintenance maintenance-on maintenance-off pipelines spaces teams orgs auth login logout authorizations whoami git remote-add features access ai ai-models ai-pipelines run-output integrations apps:transfer space-vpn-tunnel container-registry (Salesforce Heroku team James Lindenbaum Adam Wiggins Orion Henry, Node/TypeScript); oclif
# upstream: https://www.heroku.com/

_heroku2() {
    local -a sub=(
        'access:access operations'
        'addons:add-on operations'
        'ai:Heroku AI operations'
        'apps:app operations'
        'auth:auth operations'
        'autocomplete:auto-completion helpers'
        'buildpacks:buildpack operations'
        'certs:certificate operations'
        'ci:CI operations'
        'commands:list commands'
        'completion:generate shell completion'
        'config:config var operations'
        'container:container operations'
        'create:create an app'
        'destroy:destroy an app'
        'domains:domain operations'
        'drains:log drain operations'
        'features:feature operations'
        'fork:fork an app'
        'git:git remote operations'
        'help:show help'
        'info:show app info'
        'install:install plugins'
        'integrations:integration operations'
        'keys:SSH key operations'
        'labs:labs feature operations'
        'local:run app locally'
        'login:log in'
        'logout:log out'
        'logs:show app logs'
        'maintenance:maintenance mode operations'
        'members:team member operations'
        'notifications:notification operations'
        'orgs:org operations'
        'outbound-rules:outbound rule ops'
        'pg:Postgres operations'
        'pipelines:pipeline operations'
        'plugins:plugin operations'
        'ps:process operations'
        'redis:Redis operations'
        'regions:region info'
        'releases:release operations'
        'rename:rename an app'
        'reviewapps:review app operations'
        'run:run a one-off dyno'
        'sessions:session ops'
        'spaces:Private Spaces ops'
        'stack:stack operations'
        'status:show platform status'
        'teams:team operations'
        'twofactor:2FA operations'
        'update:update CLI'
        'upgrade:upgrade dyno tier'
        'version:show version'
        'webhooks:webhook ops'
        'whoami:show identity'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-a+[app name]:str:' \
        '--app=+[name]:str:' \
        '-r+[git remote]:str:' \
        '--remote=+[name]:str:' \
        '--json[JSON output]' \
        '--no-tty[no TTY]' \
        '--no-color[no color]' \
        '-c+[confirm app name]:str:' \
        '--confirm=+[name]:str:' \
        '-s+[size]:str:' \
        '--size=+[s]:str:' \
        '--type=+[t]:str:' \
        '--region=+[r]:r:(us eu virginia oregon dublin tokyo sydney frankfurt)' \
        '--stack=+[s]:s:(heroku-22 heroku-24 container)' \
        '--space=+[name]:str:' \
        '--team=+[name]:str:' \
        '--org=+[name]:str:' \
        '--addons=+[list]:str:' \
        '--buildpack=+[url]:str:' \
        '--manifest[deploy via app.json]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'heroku subcommand' sub ;;
        args)
            case $words[1] in
                apps|addons|domains|certs|drains|releases|features|keys|labs|spaces|teams|orgs|webhooks|pipelines) _arguments '1:op:(create destroy info list update upgrade remove transfer wait stacks rename)' '*:name:' ;;
                ps) _arguments '1:op:(restart stop scale exec autoscale wait kill resize type)' '*:arg:' ;;
                config) _arguments '1:op:(get set unset edit)' '*:arg:' ;;
                run) _arguments '*:cmd:_command_names' ;;
                autocomplete|completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                logs) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_heroku2 "$@"
