#compdef git-rename-file
# Documentation: https://github.com/tj/git-extras/blob/main/Commands.md#git-rename-file
# git-extras: rename a file or directory and stage the change

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:source:_files' \
  '2:destination:_files' && ret=0

return ret
