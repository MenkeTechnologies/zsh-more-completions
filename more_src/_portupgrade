#compdef portupgrade

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[upgrade all installed packages]' \
  '-A[turn on -a and also follow dependent ports]' \
  '-b[keep backup packages of old versions]' \
  '-B[keep backup packages for all installations]' \
  '-c[run make config before building each port]' \
  '-C[do not run make config]' \
  '-D[force distfile re-fetch]' \
  '-e[specify the pkgdb file to use]:pkgdb file:_files' \
  '-f[force upgrade even if not outdated]' \
  '-F[only fetch distfiles, do not build or install]' \
  '-i[turn on interactive mode]' \
  '-l[specify a log file for the build output]:log file:_files' \
  '-L[specify a format for the log file name]:log format:' \
  '-m[specify make arguments]:make args:' \
  '-M[run make in target]:target:' \
  '-n[do not actually install (dry run)]' \
  '-N[install new ports that are not yet installed]' \
  '-o+[replace an installed port with a different origin]:new origin:' \
  '-O[omit checking for build dependencies]' \
  '-p[use packages instead of ports when possible]' \
  '-P[use packages only, do not build from ports]' \
  '-PP[use packages only, fail if package not available]' \
  '-q[do not display progress]' \
  '-r[upgrade ports that depend on the given port]' \
  '-R[also upgrade ports required by the given port]' \
  '-s[run make checksum before building]' \
  '-S[do not use sudo for installation]' \
  '-u[uninstall old packages after upgrade]' \
  '-v[turn on verbose output]' \
  '-w[use saved options from previous builds]' \
  '-W[do not use saved options]' \
  '-x+[exclude matching ports]:glob pattern:' \
  '-y[answer yes to all questions]' \
  '*:port name or glob pattern:' \
  && ret=0

return ret
