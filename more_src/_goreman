#compdef goreman
# Documentation: https://github.com/mattn/goreman
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for goreman (Go Procfile-based process manager)

_goreman() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help message]' \
    '-f[path to Procfile]:file:_files' \
    '-p[RPC port number]:port:' \
    '-rpc-server[enable RPC server listening]' \
    '-basedir[base directory for operations]:dir:_files -/' \
    '-b[base port number for apps]:port:' \
    '-set-ports[set PORT env var for each subprocess]' \
    '-exit-on-error[exit goreman if a subprocess quits with a nonzero return]' \
    '-exit-on-stop[exit supervisor when all processes stop]' \
    '-logtime[show timestamp in log output]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case $state in
    cmds)
      local -a commands
      commands=(
        'start:start all processes'
        'run:run a specific process'
        'check:display entries from the Procfile'
        'export:export apps to another process manager'
        'version:show goreman version'
        'help:show help'
      )
      _describe -t commands 'goreman command' commands
      ;;
    args)
      case $line[1] in
        run)
          _arguments '1:process name:'
          ;;
        export)
          _arguments \
            '1:format:(upstart runit launchd systemd daemontools)' \
            '2:location:_files -/'
          ;;
      esac
      ;;
  esac
}

_goreman "$@"
