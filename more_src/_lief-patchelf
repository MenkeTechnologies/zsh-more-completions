#compdef lief-patchelf
# Documentation: https://lief.re/blog/2025-07-13-patchelf/
# LIEF reimplementation of patchelf to modify ELF files

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--set-interpreter[change the dynamic loader (ELF interpreter)]:interpreter:_files' \
  '--print-interpreter[print the ELF interpreter]' \
  '--print-os-abi[print the OS ABI of the executable]' \
  '--page-size[use the given page size instead of the default]:size' \
  '--set-rpath[set the DT_RPATH/DT_RUNPATH]:rpath' \
  '--print-rpath[print the runtime search path]' \
  '--remove-rpath[remove the DT_RPATH/DT_RUNPATH]' \
  '--force-rpath[use DT_RPATH instead of DT_RUNPATH]' \
  '--shrink-rpath[remove unneeded rpath directories]' \
  '*--add-needed[add a DT_NEEDED dependency]:lib' \
  '*--remove-needed[remove a DT_NEEDED dependency]:lib' \
  '*--replace-needed[replace a DT_NEEDED entry]:old:lib' \
  '--set-soname[set the DT_SONAME]:soname' \
  '--print-soname[print the DT_SONAME]' \
  '--output[write modified output to file]:file:_files' \
  '*:file:_files' && ret=0

return ret
