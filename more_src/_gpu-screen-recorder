#compdef gpu-screen-recorder
# Documentation: https://man.archlinux.org/man/extra/gpu-screen-recorder/gpu-screen-recorder.1.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# gpu-screen-recorder: GPU-accelerated screen recorder using VAAPI/NVENC (dec05eba)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-w[capture window/source]:source:(screen focused portal)' \
  '-c[output container]:container:(mp4 mkv flv webm hls ts m4a)' \
  '-q[quality preset]:quality:(medium high very_high ultra)' \
  '-f[framerate]:fps:' \
  '-r[replay buffer seconds]:seconds:' \
  '-k[encoder]:encoder:(h264 hevc av1 vp8 vp9 hevc_hdr av1_hdr h264_amf hevc_amf)' \
  '-a[audio source]:src:' \
  '-ac[audio codec]:codec:(opus aac mp3 flac)' \
  '-ab[audio bitrate]:kbps:' \
  '-fm[framerate mode]:mode:(cfr vfr content)' \
  '-pixfmt[pixel format]:fmt:(yuv420 yuv444)' \
  '-bm[bit rate mode]:mode:(qp vbr cbr)' \
  '-encoder[encoder name]:encoder:(gpu cpu)' \
  '-o[output file or - for stdout]:file:_files' \
  '-v[verbose]' \
  '-mf[merge multiple files]' \
  '-s[scaling resolution]:WxH:' \
  '-cursor[show cursor (yes/no)]:bool:(yes no)' \
  '-keyint[keyframe interval seconds]:seconds:' \
  '-restart-replay-on-save[restart replay buffer on save]' \
  '-restore-portal-session[restore portal session]' \
  '-display-server[force display server]:server:(x11 wayland)' \
  '*::gpu-screen-recorder args:_files' && ret=0
return ret
