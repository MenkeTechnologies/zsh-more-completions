#compdef bspwm

# Zsh completion for bspwm - binary space partitioning window manager

_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-c+[use the given configuration file]:config file:_files' \
  '-s+[use the given socket path]:socket:_files' \
  '-o+[use the given paths for status FIFOs]:fifo:_files'
