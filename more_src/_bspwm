#compdef bspwm
# Documentation: https://github.com/baskerville/bspwm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bspwm - binary space partitioning window manager
_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-c+[use the given configuration file]:config file:_files' \
  '-s+[use the given socket path]:socket:_files' \
  '-o+[use the given paths for status FIFOs]:fifo:_files' \
  '--print-socket-path[print bspwm socket path and exit]'
