#compdef force-higher-level
# Documentation: https://force-eo.readthedocs.io/en/latest/components/higher-level/index.html
# FORCE higher-level processing (selects submodule from parameter file)

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '*:parameter file:_files' && ret=0

return ret
