#compdef pcp_pool_status
# Documentation: https://man.archlinux.org/search?q=pcp_pool_status
# Reference accessed: 2026-05-16

# pcp_pool_status: print Pgpool-II config parameters
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "(- *)-V[show version]" \
  "--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[debug]" \
  "--debug[debug]" \
  "-v[verbose]" \
  "--verbose[verbose]" \
  "-U[username]:user:_users" \
  "--username=[username]:user:_users" \
  "-H[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[pcp port]:port:" \
  "--port=[pcp port]:port:" \
  "-s[scope]:scope:" \
  "--scope=[scope]:scope:" \
   \
  '*::pcp_pool_status args:_files' && ret=0
return ret
