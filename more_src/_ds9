#compdef ds9
# Documentation: https://ds9.si.edu/doc/ref/command.html
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-file+[load a file]:file:_files' \
  '-fits+[load a FITS file]:fits file:_files -g "*.fits"' \
  '-regions+[load a regions file]:regions file:_files' \
  '-colorbar+[show or hide colorbar]:toggle:(yes no)' \
  '-scale+[set image scale]:scale:(linear log sqrt squared histequ)' \
  '-zoom+[set zoom level]:level:' \
  '-pan+[pan to coordinates]:coordinates:' \
  '-frame+[frame command]:command:(new delete reset refresh clear first prev next last)' \
  '-cmap+[set colormap]:colormap:(grey heat cool rainbow bb he aips a)' \
  '-width+[window width in pixels]:width:' \
  '-height+[window height in pixels]:height:' \
  '-geometry+[window geometry WxH+X+Y]:geometry:' \
  '-title+[set window title]:title:' \
  '-view+[configure view settings]:setting:' \
  '-export+[export image to file]:format file:' \
  '-print[print current view]' \
  '-exit[exit after processing commands]' \
  '-vo[enable virtual observatory support]' \
  '-analysis+[load analysis file]:analysis file:_files' \
  '-rgb[start in RGB mode]' \
  '-mosaic+[load mosaic]:mosaic type:' \
  '-tile[tile frames]' \
  '-log[use log scale]' \
  '-linear[use linear scale]' \
  '-zscale[use zscale algorithm]' \
  '*:FITS file:_files -g "*.(fits|fit|fts|fits.gz|fit.gz)"' && ret=0

return ret
