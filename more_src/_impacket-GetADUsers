#compdef impacket-GetADUsers

# Impacket GetADUsers.py: enumerate Active Directory users via LDAP
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-all[show all users (default lastLogon only)]' \
  '-user[query single user]:user:' \
  '-target-domain[target domain]:domain:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '*:domain/user[:password]:' && ret=0
return ret
