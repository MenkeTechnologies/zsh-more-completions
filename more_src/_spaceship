#compdef spaceship
# _spaceship — Spaceship fastlane App Store Connect / Apple Developer API client (Ruby); programmatic provisioning, devices, certs, apps, app metadata
# upstream: https://github.com/fastlane/fastlane/tree/master/spaceship

_spaceship() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-u --username)'{-u,--username}'+[apple id]:email:' \
        '(-p --password)'{-p,--password}'+[password]:pass:' \
        '(-t --team-id)'{-t,--team-id}'+[team id]:id:' \
        '(-n --team-name)'{-n,--team-name}'+[team name]:name:' \
        '(-i --itc-team-id)'{-i,--itc-team-id}'+[App Store Connect team id]:id:' \
        '(-N --itc-team-name)'{-N,--itc-team-name}'+[App Store Connect team name]:name:' \
        '(-2 --2fa)'{-2,--2fa}'[force 2FA]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '*:command:'
}

_spaceship "$@"
