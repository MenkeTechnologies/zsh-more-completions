#compdef dxf2gcode
# Documentation: https://sourceforge.net/p/dxf2gcode/wiki/Home/
# dxf2gcode - convert DXF drawings into CNC g-code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --export)'{-e,--export}'=[export data to FILENAME]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[run with no GUI]' \
  '*:dxf file:_files -g "*.dxf"' && ret=0

return ret
