#compdef pbsdsh
# Documentation: https://man.archlinux.org/search?q=pbsdsh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[verbose]' \
  '-c+[copies of program to run]:n:' \
  '-n+[task index]:n:' \
  '-s[serially - run on one node at a time]' \
  '-o[capture stdout/stderr]' \
  '-u[only run on unique hosts]' \
  '*:command:_command_names' && ret=0

return ret
