#compdef pbsdsh
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/pbsdsh.1B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c+[spawn on the first N allocated nodes]:n:' \
  '-n+[spawn on the n-th allocated node]:n:' \
  '-h+[spawn on the specified hostname]:host:_hosts' \
  '-o[capture stdout of spawned program]' \
  '-s[run on each node serially]' \
  '-u[run once per unique node]' \
  '-v[verbose error/exit reporting]' \
  '*:command:_command_names' && ret=0

return ret
