#compdef trdsql
# Documentation: https://github.com/noborus/trdsql
# Reference accessed: 2026-05-21
# Verified: upstream docs (cmd/cmd.go flag declarations).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-config=[configuration file]:file:_files' \
  '-db=[specify db name from config]:db' \
  '-dblist[display db information]' \
  '-driver=[database driver]:driver:(mysql postgres sqlite3 sqlite)' \
  '-dsn=[database driver DSN]:dsn' \
  '-ig[guess format from extension]' \
  '-q=[read query from file]:file:_files' \
  '-a=[analyze file and suggest SQL]:file:_files' \
  '-A=[analyze file but only suggest SQL]:file:_files' \
  '-t=[read table name from file]:file:_files' \
  '-help[display usage]' \
  '-version[display version]' \
  '-debug[debug print]' \
  '-id=[input field delimiter]:delim' \
  '-ih[first line as header (CSV only)]' \
  '-is=[skip header rows]:rows' \
  '-ir=[number of rows to preread]:rows' \
  '-ilr=[limited number of rows to read]:rows' \
  '-ijq=[jq expression for JSON/JSONL]:expr' \
  '-inull=[value to convert to null on input]:value' \
  '-inum[add row number column]' \
  '-icsv[CSV format input]' \
  '-iltsv[LTSV format input]' \
  '-ijson[JSON format input]' \
  '-iyaml[YAML format input]' \
  '-itbln[TBLN format input]' \
  '-iwidth[width specification format input]' \
  '-itext[text format input]' \
  '-out=[output file]:file:_files' \
  '-out-without-guess[disable format guessing for -out]' \
  '-od=[output field delimiter]:delim' \
  '-oq=[output quote character]:char' \
  '-oaq[enclose all fields in quotes on output]' \
  '-ocrlf[use CRLF line endings on output]' \
  '-onowrap[do not wrap long lines (at/md only)]' \
  '-oh[output column names as header]' \
  '-oz=[output compression]:fmt:(gz bz2 zstd lz4 xz)' \
  '-onull=[value to convert from null on output]:value' \
  '-ocsv[CSV format output]' \
  '-oltsv[LTSV format output]' \
  '-oat[ASCII table output]' \
  '-omd[Markdown output]' \
  '-ovf[vertical format output]' \
  '-oraw[raw output]' \
  '-ojson[JSON output]' \
  '-otbln[TBLN output]' \
  '-ojsonl[JSON lines output]' \
  '-oyaml[YAML output]' \
  '-otsv[TSV output]' \
  '*:file:_files' && ret=0
return ret
