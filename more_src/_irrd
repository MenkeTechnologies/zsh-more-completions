#compdef irrd
# Documentation: https://github.com/irrdnet/irrd (irrd/daemon/main.py argparse)
# Reference accessed: 2026-05-30
# irrd — Internet Routing Registry Daemon. Serves RPSL objects + RPKI integration.
# Daemon is minimal — only 2 CLI flags; everything else is YAML-config driven.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[use an alternative IRRd config file]:file:_files -g "*.(yaml|yml)"' \
  '--foreground[run IRRd in the foreground (do not detach)]' \
  && ret=0

return ret
