#compdef glslang glslangValidator

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '-c[print configuration]' \
  '-d[default precision highp]' \
  '-D[shader source is HLSL]' \
  '-e+[entry point name]:name:' \
  '-E[output preprocessed source]' \
  '-G+[output SPIR-V for OpenGL]:flag:' \
  '-H[print AST]' \
  '-l[link multi-file shaders into single module]' \
  '-m[memory leak mode]' \
  '-o+[output file]:file:_files' \
  '-q[show active uniform/attrib variables]' \
  '-r[relaxed semantic checks]' \
  '-s[silent]' \
  '-S+[stage]:stage:(vert tesc tese geom frag comp rgen rint rahit rchit rmiss rcall mesh task)' \
  '-t[multi-threaded]' \
  '-u+[set input attribute as uniform]:attr=val:' \
  '-V+[output SPIR-V for Vulkan]:flag:' \
  '-w[suppress warnings]' \
  '--client[client]:client:(opengl vulkan)' \
  '--define-macro[define]:macro:' \
  '--depfile[dependency file]:file:_files' \
  '--enhanced-msgs[enhanced messages]' \
  '--error-column-zero-based[zero-based column reporting]' \
  '--flatten-uniform-arrays[flatten uniform arrays]' \
  '--glsl-version[GLSL version]:ver:' \
  '--hlsl-iomap[HLSL IO map]' \
  '--invert-y[invert Y in vertex shader]' \
  '--keep-uncalled[keep uncalled functions]' \
  '--no-storage-format[no storage format]' \
  '--quiet[quiet]' \
  '--reflect-strict-array-suffix[strict reflection array suffix]' \
  '--source-entrypoint[source entry point]:name:' \
  '--spirv-dis[disassemble SPIR-V]' \
  '--spirv-val[validate SPIR-V]' \
  '--stdin[read from stdin]' \
  '--target-env=[target env]:env:(opengl opengl4 vulkan1.0 vulkan1.1 vulkan1.2 vulkan1.3 spirv1.0 spirv1.1 spirv1.2 spirv1.3 spirv1.4 spirv1.5 spirv1.6)' \
  '--variable-name[output variable name]:name:' \
  '*:shader:_files -g "*.{vert,tesc,tese,geom,frag,comp,rgen,rint,rahit,rchit,rmiss,rcall,mesh,task,glsl,hlsl}"' && ret=0

return ret
