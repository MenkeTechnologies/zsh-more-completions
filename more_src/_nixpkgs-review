#compdef nixpkgs-review

_nixpkgs-review_commands() {
  local -a commands=(
    'pr:Review a pull request'
    'rev:Review a git revision'
    'wip:Review uncommitted changes'
    'merge:Merge a pull request'
    'help:Show help'
  )
  _describe 'command' commands
}

_nixpkgs-review() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--build-graph=[build graph]:graph:(parallel sequential)' \
    '--no-shell[do not open interactive shell]' \
    '--run=[command to run in shell]:command' \
    '--sandbox[build in sandbox]' \
    '--cachix=[push to cachix cache]:cache' \
    '--extra-nixpkgs-config=[extra nixpkgs config]:config' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:_nixpkgs-review_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        pr)
          _arguments \
            '--eval=[evaluation mode]:mode:(local ofborg)' \
            '--checkout=[checkout strategy]:strategy:(merge commit)' \
            '--post-result[post result as PR comment]' \
            '--token=[GitHub token]:token' \
            '(-h --help)'{-h,--help}'[help for pr]' \
            '1:pr number'
          ;;
        rev)
          _arguments \
            '(-b --branch)'{-b,--branch}'=[branch to compare against]:branch' \
            '(-h --help)'{-h,--help}'[help for rev]' \
            '1:commit or branch'
          ;;
        wip)
          _arguments \
            '(-s --staged)'{-s,--staged}'[only review staged changes]' \
            '(-h --help)'{-h,--help}'[help for wip]'
          ;;
      esac
      ;;
  esac
}

_nixpkgs-review "$@"
