#compdef dockerfilelint
# Documentation: https://github.com/replicatedhq/dockerfilelint
# dockerfilelint: rule-based linter for Dockerfiles

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version number]' \
  '(-o --output)'{-o,--output}'[output format (json or cli)]:format:(json cli)' \
  '(-j --json)'{-j,--json}'[output linting results as JSON]' \
  '*:file:_files' && ret=0

return ret
