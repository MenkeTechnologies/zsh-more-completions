#compdef llscheck
# Documentation: https://github.com/jeffzi/llscheck
# llscheck - convert Lua Language Server diagnostics for human and CI friendly interpretation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--completion[output a shell completion script]:shell:(bash zsh fish)' \
  '--checklevel[minimum diagnostic level to log]:level:(Error Warning Information Hint)' \
  '--configpath[path to a LuaLS config file]:configpath:_files' \
  '*:workspace:_files -/' && ret=0

return ret
