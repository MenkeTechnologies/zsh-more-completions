#compdef ssdeep-update
# Documentation: https://man.archlinux.org/search?q=ssdeep-update
# Reference accessed: 2026-05-16

# ssdeep-update: rebuild ssdeep fuzzy hash signature databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-f[force]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '*::ssdeep-update args:_files' && ret=0
return ret
