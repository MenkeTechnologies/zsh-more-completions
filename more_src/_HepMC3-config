#compdef HepMC3-config
# Documentation: https://gitlab.cern.ch/hepmc/HepMC3/-/blob/master/HepMC3-config.in
# report build configuration of the installed HepMC3 library

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--version[show release version number]' \
  '--prefix[show installation prefix]' \
  '--includedir[show path to HepMC3 headers directory]' \
  '--libdir[show path to HepMC3 libraries directory]' \
  '--interfacesdir[show path to interfaces directory]' \
  '--cflags[show -I string for CPPFLAGS/CXXFLAGS]' \
  '--cppflags[show -I string for CPPFLAGS/CXXFLAGS]' \
  '--ldflags[show -L/-l string for LIBS/LIBADD]' \
  '--libs[show -L/-l string for LIBS/LIBADD]' \
  '--rootIO[show -L/-l string with rootIO support]' \
  '--protobufIO[show -L/-l string with protobufIO support]' \
  '--search[show -L/-l string with search support]' \
  '--static[show static library linkage string]' \
  '--features[list enabled features in the build]' && ret=0

return ret
