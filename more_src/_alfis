#compdef alfis
# ============================================================================
#  _alfis — alfis: Alternative Free Identity System
#           (Revertron / Alfis project — peer-to-peer blockchain-
#           based DNS / identity system in Rust)
#
#  Source-direct extraction from
#    https://github.com/Revertron/Alfis/blob/master/src/main.rs
#    https://github.com/rust-lang/getopts (the OFFICIAL rust-lang
#    getopts library — Rust port of C getopt(3))
#
#  Maintained by Revertron (Alfis core team).  407 GH stars.
#  ALFIS is the "Alternative Free Identity System" — a peer-to-
#  peer BLOCKCHAIN-based alternative to ICANN's DNS for
#  registering and resolving domain names without any central
#  authority.  Operates its own consensus chain where ANY .anon /
#  .btn / .ygg / .conf / .crypto / .glate-style TLD can be
#  registered by mining a block.  Built-in DNS server resolves
#  registered names locally; the rest of the world's DNS
#  continues to work normally.  Includes a TRAY-ICON GUI mode (on
#  by default for GUI builds; --nogui for headless servers).
#  Sister tools: namecoin (the ORIGINAL blockchain-DNS project on
#  Bitcoin's chain), handshake (Handshake Network — root-zone
#  alt-DNS), unstoppable-domains (.crypto / .x / .wallet ENS-like
#  domains on Ethereum), ens (Ethereum Name Service — in corpus
#  via _ens), yggdrasil-go (Yggdrasil mesh network — in corpus
#  via _yggdrasil), i2p (in corpus via _i2pd + STOCK on
#  Debian/Ubuntu via _i2p), tor (in corpus + STOCK via _tor).
#
#  CLI library taxonomy update: 14th Rust CLI library — the
#  OFFICIAL **rust-lang/getopts** crate.  Rust ecosystem now has
#  14 documented CLI libraries — RE-TAKING THE SOLO LEAD as the
#  MOST-DOCUMENTED CLI LANGUAGE in the cross-language taxonomy
#  ahead of Go (13) and TypeScript-Node (13).  🎉 Rust BREAKS the
#  THREE-WAY TIE.
#
#  getopts (rust-lang/getopts) is the OFFICIAL Rust port of the
#  C/POSIX `getopt(3)` family — maintained UNDER THE rust-lang
#  GITHUB ORG (alongside libc, regex, log, etc.), originally
#  extracted from rustc itself before getopts/clap/etc. were
#  factored out as crates.  HISTORICAL NOTE: rustc, early cargo
#  (pre-docopt-rs era), early rustfmt, and many older Rust
#  binaries used getopts before clap/clap_derive supplanted it.
#  Today getopts is maintained for backward compat and for tools
#  that want EXTREMELY MINIMAL POSIX-getopt-faithful parsing
#  without any of clap's modern features (ANSI color, suggest-
#  similar-flag, derive macros, shell completion gen).  Used by
#  Revertron/Alfis (Alternative Free Identity System, 407 stars),
#  Luminarys/synapse (Synapse BitTorrent Daemon, 849 stars),
#  nachoparker/dutree (file system usage analyzer, 872 stars —
#  IN CORPUS via _dutree), mbrubeck/robinson (toy web rendering
#  engine, 1641 stars — Matt Brubeck's educational browser
#  series), theseus-os/Theseus (Theseus OS — Rust experimental
#  microkernel; uses getopts in `less`/userland coreutils),
#  sunriseos/SunriseOS (Sunrise OS coreutils — Rust mknod et al),
#  hypercube-lab/hypercube (Hypercube blockchain — fullnode), smoltcp
#  examples (smoltcp embedded TCP/IP), lifegpc/ldd-rust (Rust ldd
#  port), Toqozz/wired-notify (wired notification daemon, 694
#  stars), winebarrel/lee (CloudWatch Logs tee tool), and many
#  other older or minimal Rust binaries that want POSIX-faithful
#  short+long flag parsing without clap's weight.
#
#  getopts API:
#    use getopts::{Matches, Options};
#    use std::env;
#    use std::process::exit;
#
#    fn main() {
#      let args: Vec<String> = env::args().collect();
#      let program = args[0].clone();
#
#      let mut opts = Options::new();
#      // BOOLEAN FLAG (no value): -f / --flag
#      opts.optflag("f", "flag", "Flag description");
#
#      // OPTION WITH REQUIRED VALUE: -c FILE / --config FILE
#      // signature: (short, long, desc, hint)
#      opts.optopt("c", "config", "Use config file.", "FILE");
#
#      // OPTION WITH OPTIONAL VALUE (rarely used): -v[VAL]
#      opts.optflagopt("v", "verbose", "Verbose mode.", "LEVEL");
#
#      // REPEATING OPTION (each occurrence appends):
#      // -I path1 -I path2 -> Vec<String>
#      opts.optmulti("I", "include", "Include path.", "PATH");
#
#      // MULTIPLE FLAGS (each occurrence counts):
#      // -vvv -> count=3
#      opts.optflagmulti("v", "verbose", "Verbose (repeat: -vvv).");
#
#      // PARSE: parse(&args[1..]) -> Result<Matches, Error>
#      let matches = match opts.parse(&args[1..]) {
#        Ok(m) => m,
#        Err(f) => panic!("{}", f.to_string()),
#      };
#
#      // QUERY: matches.opt_present(name), opt_str(name),
#      // opt_strs(name), opt_count(name)
#      if matches.opt_present("h") {
#        let brief = format!("Usage: {} [options]", program);
#        println!("{}", opts.usage(&brief));
#        exit(0);
#      }
#      let config = matches.opt_str("c");  // Option<String>
#      let includes = matches.opt_strs("I"); // Vec<String>
#      let verbose_count = matches.opt_count("v");
#
#      // POSITIONALS: matches.free is Vec<String>
#      let free_args = &matches.free;
#    }
#
#  getopts distinctive features:
#    - POSIX/C GETOPT(3) FAITHFUL — `opts.parse(&args[1..])`
#      mirrors `getopt_long(3)` semantics: `-abc` short-cluster
#      expands to `-a -b -c`, `-fvalue`/`-f value`/`-f=value` all
#      valid, `--name=value`/`--name value` both valid, `--`
#      separator terminates option parsing
#    - OPTION-TYPE METHODS — `optflag` (bool), `optopt` (required
#      value), `optflagopt` (optional value), `optmulti` (repeating
#      value-bearing), `optflagmulti` (repeating bool — count),
#      `reqopt` (required option that errors if missing)
#    - SHORT+LONG IN ONE CALL — `optopt("c", "config", "desc",
#      "HINT")` registers both `-c` AND `--config`; passing empty
#      string `""` for either disables that form
#    - PER-METHOD HINT — last arg is the placeholder shown in
#      auto-generated --usage (e.g. "FILE" or "PATH")
#    - QUERY API on Matches:
#      * `opt_present(name)` — was flag given?
#      * `opt_str(name)` — Option<String> first value
#      * `opt_strs(name)` — Vec<String> all values
#      * `opt_count(name)` — usize occurrence count
#      * `opt_default(name, default)` — value or default
#      * `free` — Vec<String> POSITIONAL args (after parsing)
#    - `Options::usage(&brief)` — generate POSIX-style usage
#      string from registered options
#    - PARSE ERRORS — `getopts::Fail` enum with variants for
#      ArgumentMissing / UnrecognizedOption / OptionMissing /
#      OptionDuplicated / UnexpectedArgument
#    - NO auto --help (caller registers `optflag("h", "help",
#      "...")` and checks `matches.opt_present("h")` to print usage)
#    - NO auto --version (caller writes manually)
#    - NO subcommand framework (caller dispatches by inspecting
#      `matches.free[0]` and dispatching to per-subcommand
#      Options::new() instances)
#    - NO type-coerced parsing — all values are String; caller
#      does `.parse::<u32>()` manually
#    - NO derive macros, NO proc-macros, NO heavy compile-time
#      machinery — getopts is plain runtime function calls
#    - MAINTAINED UNDER rust-lang/ org (alongside libc, regex,
#      log, hashbrown, etc.) — has the "blessed by rust-lang core
#      team" status as the OFFICIAL POSIX-getopt port
#    - INSPIRED BY POSIX getopt_long(3) — the ABI surface mirrors
#      C's `<getopt.h>` API one-for-one
#  Distinct from R275 Rust clap-derive (Kevin K.'s clap_derive
#  proc-macro `#[derive(Parser)]` — heavy compile-time machinery,
#  full ANSI rendering, suggest-similar-flag, shell completion;
#  ripgrep/bat/exa/fd), R330 Rust bpaf (functional applicative
#  combinator), R344 Rust google/argh (Google Fuchsia-OS derive-
#  on-struct), R347 Rust RazrFalcon/pico-args (LOW-LEVEL imperative
#  pull parser — `args.value_from_str("--flag")?` iterative API
#  contrasts getopts's declarative Options::new() registration),
#  R404 Rust matklad/xflags (declarative MACRO block syntax),
#  R407 Rust blyxxyz/lexopt (MINIMAL iterator-based pull parser
#  — match-on-Arg-enum style; lexopt is the modern minimal
#  alternative to getopts but with DIFFERENT API: lexopt is
#  iterator-driven, getopts is declarative-registration-driven),
#  R410 Rust murarth/gumdrop (zero-dependency derive-macro), R413
#  Rust docopt/docopt.rs (BurntSushi USAGE-STRING-IS-SPEC parser).
#  Rust documented libraries so far: clap-derive, bpaf, argh,
#  pico-args, xflags, lexopt, gumdrop, docopt.rs, getopts (this
#  round) plus older clap-builder, structopt (deprecated, now
#  clap_derive).  getopts's distinguishing feature vs ALL other
#  Rust libs: getopts is the ONLY ONE BLESSED BY rust-lang CORE
#  TEAM (lives under rust-lang/ GitHub org) and ONLY ONE that is
#  a 1:1 POSIX getopt_long(3) C-ABI port (faithful to the C API
#  surface).  Conceptually similar to R408 Go pborman/getopt
#  (also a POSIX getopt(3) port — to Go).  getopts's approach:
#  POSIX-GETOPT(3)-FAITHFUL with `Options::new()` builder +
#  declarative `optflag`/`optopt`/`optflagopt`/`optmulti`/
#  `optflagmulti`/`reqopt` registration + `(short, long, desc,
#  hint)` per-option signature + `opts.parse(&args[1..])` returns
#  `Matches` + `opt_present`/`opt_str`/`opt_strs`/`opt_count`/
#  `opt_default` query API + `free: Vec<String>` for positionals
#  + STRICT short-cluster `-abc` -> `-a -b -c` + `--name=value`
#  and `--name value` both valid + `--` separator + NO subcommand
#  framework + NO automatic --help/--version + NO type-coerced
#  parsing (caller does Number parsing) + MAINTAINED UNDER
#  rust-lang/ ORG — corpus's **first documented OFFICIAL-rust-
#  lang-team-blessed Rust CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 155; Rust ecosystem now
#  has 14 documented CLI libraries — RE-TAKING THE SOLO LEAD as
#  the MOST-DOCUMENTED CLI LANGUAGE in the cross-language taxonomy
#  ahead of Go (13) and TypeScript-Node (13).
#
#  Surface (verbatim from `src/main.rs` getopts registrations):
#
#  Usage:
#    alfis [options]
#
#  Boolean flags:
#    -h, --help                     Print this help menu and exit
#    -n, --nogui                    Run without graphic user
#                                   interface (default for no-gui
#                                   builds; explicit override
#                                   forces headless even on gui
#                                   builds)
#    -v, --version                  Print version and exit
#    -d, --debug                    Show debug messages, more than
#                                   usual
#    -t, --trace                    Show trace messages, more than
#                                   debug (sets log level to
#                                   TRACE — VERY VERBOSE)
#        --hide                     Hide UI, show only tray icon
#                                   (GUI builds only)
#    -b, --blocks                   List blocks from DB and exit
#                                   (diagnostic — dumps the chain)
#    -g, --generate                 Generate new config file
#                                   (printed to stdout; redirect
#                                   to alfis.toml)
#
#  Windows-only flags (only available when compiled on Windows):
#        --install                  Install self as Windows service
#                                   (creates %PROGRAMDATA%\ALFIS
#                                   and seeds alfis.toml)
#        --uninstall                Uninstall self as Windows
#                                   service
#        --service                  Run as Windows service (used
#                                   internally by Windows Service
#                                   Manager — not for direct user
#                                   invocation)
#
#  Value-bearing options:
#    -k, --gen-key FILE             Generate new keys and save them
#                                   to FILE (creates a new
#                                   Alfis identity keypair)
#    -l, --log FILE                 Write log to FILE (in addition
#                                   to stdout / Windows event log)
#    -s, --status FILE              Write status to FILE (machine-
#                                   readable status dump — for
#                                   monitoring integrations)
#    -c, --config FILE              Path to config file (default:
#                                   ./alfis.toml or
#                                   %PROGRAMDATA%\ALFIS\alfis.toml
#                                   on Windows service)
#    -w, --work-dir DIRECTORY       Path to working directory
#                                   (chain DB / keystore live here)
#    -u, --upgrade FILE             Path to config file that you
#                                   want to upgrade (upgraded
#                                   config will be printed to
#                                   console — used after schema
#                                   changes between alfis versions)
#
#  Examples:
#    alfis                                       # Run with default config (GUI if compiled with gui feature)
#    alfis --nogui                               # Headless mode (server)
#    alfis -c /etc/alfis/alfis.toml              # Custom config path
#    alfis -w /var/lib/alfis                     # Custom working directory
#    alfis -g > /etc/alfis/alfis.toml            # Generate new config to file
#    alfis -k ~/.alfis/keys.bin                  # Generate new keypair
#    alfis -d                                    # Debug logging
#    alfis -t                                    # Trace logging (very verbose)
#    alfis -b                                    # Dump chain blocks
#    alfis --hide                                # GUI mode but tray-only
#    alfis -u old-alfis.toml > new-alfis.toml    # Upgrade config schema
#    alfis -l /var/log/alfis.log -s /var/run/alfis.status   # Log + status files
#    alfis --version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also rust-lang/getopts users):
#    - dutree (IN CORPUS via _dutree — nachoparker file system
#      usage analyzer 872 stars; uses getopts; previously
#      documented but getopts library not formally entered into
#      taxonomy)
#    - synapse (Luminarys/synapse 849 stars — Synapse BitTorrent
#      Daemon; SKIP due to NAME COLLISION with matrix-org/synapse
#      Matrix homeserver in Python — would confuse Matrix users)
#    - robinson (mbrubeck/robinson 1641 stars — TOY web rendering
#      engine, Matt Brubeck's educational browser series; only
#      ~3 getopts flags, FUTURE candidate)
#    - wired-notify (Toqozz/wired-notify 694 stars — wired
#      notification daemon; uses getopts ONLY for socket-message
#      parsing, not argv parsing — main binary has no flags)
#    - lee (winebarrel/lee 1 star CloudWatch Logs tee tool —
#      too niche)
#    - hypercube (hypercube-lab — uses getopts in fullnode binary)
#    - theseus-os/Theseus — Theseus microkernel coreutils
# ============================================================================

_alfis() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[print help menu and exit]' \
    '(-v --version)'{-v,--version}'[print version and exit]' \
    '(-n --nogui)'{-n,--nogui}'[run without graphic user interface]' \
    '(-d --debug)'{-d,--debug}'[show debug messages]' \
    '(-t --trace)'{-t,--trace}'[show trace messages (very verbose)]' \
    '--hide[hide UI, show only tray icon]' \
    '(-b --blocks)'{-b,--blocks}'[list blocks from DB and exit]' \
    '(-g --generate)'{-g,--generate}'[generate new config file to stdout]' \
    '--install[(Windows) install self as Windows service]' \
    '--uninstall[(Windows) uninstall self as Windows service]' \
    '--service[(Windows) run as Windows service (internal)]' \
    '(-k --gen-key)'{-k,--gen-key}'[generate new keys and save them to file]:file:_files' \
    '(-l --log)'{-l,--log}'[write log to file]:file:_files' \
    '(-s --status)'{-s,--status}'[write status to file]:file:_files' \
    '(-c --config)'{-c,--config}'[path to config file]:file:_files -g "*.toml"' \
    '(-w --work-dir)'{-w,--work-dir}'[path to working directory]:dir:_directories' \
    '(-u --upgrade)'{-u,--upgrade}'[path to config file to upgrade]:file:_files -g "*.toml"'
}

_alfis "$@"
