#compdef tfenv

# Zsh completion for tfenv (Terraform version manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a specific version of Terraform'
  'use:switch to a version of Terraform'
  'uninstall:uninstall a specific version of Terraform'
  'list:list all installed Terraform versions'
  'list-remote:list all installable Terraform versions'
  'version-name:print current Terraform version'
  'init:update environment to use tfenv'
  'pin:pin the current Terraform version to .terraform-version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tfenv command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install|use|uninstall)
        local -a versions
        if [[ ${line[1]} == install ]]; then
          _arguments '1:version:(latest latest\:)' && ret=0
        else
          versions=(${(f)"$(tfenv list 2>/dev/null | sed 's/^[* ]*//')"})
          _describe -t versions 'terraform version' versions && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
