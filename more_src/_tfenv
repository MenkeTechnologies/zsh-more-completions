#compdef tfenv
# Documentation: https://github.com/tfutils/tfenv
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tfenv (Terraform version manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a specific version of Terraform'
  'use:switch to a version of Terraform'
  'uninstall:uninstall a specific version of Terraform'
  'list:display all installed Terraform versions'
  'list-remote:list all installable Terraform versions'
  'pin:write currently-active version to .terraform-version'
)

_arguments -s -S \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tfenv command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install|use|uninstall)
        local -a versions
        if [[ ${line[1]} == install ]]; then
          _arguments '1:version:(latest latest-allowed min-required)' && ret=0
        else
          versions=(${(f)"$(tfenv list 2>/dev/null | sed 's/^[* ]*//')"})
          _describe -t versions 'terraform version' versions && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
