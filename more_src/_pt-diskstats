#compdef pt-diskstats
# Documentation: https://docs.percona.com/percona-toolkit/pt-diskstats.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--buffer-stdout[enable STDOUT buffering (default)]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '--columns-regex=[columns to display (Perl regex)]:regex' \
  '*--config=[comma-separated config files]:file:_files' \
  '--devices-regex=[devices to display (Perl regex)]:regex' \
  '--group-by=[aggregation mode]:mode:(all disk sample)' \
  '--headers=[header formatting (default group,scroll)]:hash:(group scroll group,scroll)' \
  '--interval=[seconds between samples]:seconds' \
  '--iterations=[stop after N samples]:count' \
  '--sample-time=[seconds of samples per group in sample mode]:seconds' \
  '--save-samples=[file to save diskstats samples]:file:_files' \
  '--show-inactive[show inactive devices]' \
  '--show-timestamps[show HH:MM:SS in #ts column]' \
  '--version-check[check for software updates (default)]' \
  '--no-version-check[skip version update check]' \
  '*:diskstats file:_files' && ret=0

return ret
