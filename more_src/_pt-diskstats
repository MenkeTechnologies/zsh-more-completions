#compdef pt-diskstats

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--columns-regex=[columns to display]:regex:' \
  '--config=[config file]:config file:_files' \
  '--devices-regex=[devices to display]:regex:' \
  '--group-by=[group by]:attribute:(all disk sample)' \
  '--headers[show column headers]' \
  '--interval=[collection interval]:seconds:' \
  '--iterations=[number of iterations]:count:' \
  '--sample-time=[sampling time]:seconds:' \
  '--save-samples=[save samples to file]:file:_files' \
  '--show-inactive[show inactive devices]' \
  '*:diskstats files:_files' && ret=0

return ret
