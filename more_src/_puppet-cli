#compdef puppet-cli
# _puppet-cli — Puppet Labs Puppet declarative configuration management CLI alias (puppetlabs team, Ruby); custom argparse
# upstream: https://github.com/puppetlabs/puppet

_puppet-cli() {
    local -a sub=(
        'agent:run puppet agent'
        'apply:apply manifest locally'
        'catalog:catalog commands'
        'cert:certificate management (legacy)'
        'certificate:certificate management'
        'config:configuration management'
        'describe:describe resource types'
        'device:manage network devices'
        'doc:generate documentation'
        'epp:EPP template commands'
        'face:face commands'
        'filebucket:file bucket'
        'generate:generate puppet types'
        'help:show help'
        'lookup:lookup data via hiera'
        'master:run puppetmaster (legacy)'
        'module:module commands'
        'module install:install module'
        'module list:list modules'
        'module search:search modules'
        'module uninstall:uninstall module'
        'module upgrade:upgrade module'
        'module build:build module'
        'module changes:show changes'
        'module generate:generate module'
        'node:node commands'
        'parser:parser commands'
        'parser validate:validate manifest'
        'plugin:plugin commands'
        'plugin download:download plugins'
        'resource:manage resources'
        'script:run script'
        'ssl:SSL management'
        'ssl bootstrap:bootstrap SSL'
        'ssl submit_request:submit CSR'
        'ssl download_cert:download cert'
        'ssl verify:verify cert'
        'ssl clean:clean SSL'
        'status:show status'
        'wikileak:???'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--confdir=+[dir]:dir:_files -/' \
        '--vardir=+[dir]:dir:_files -/' \
        '--codedir=+[dir]:dir:_files -/' \
        '--logdest=+[dest]:str:' \
        '-l+[dest]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--noop[noop]' \
        '--no-noop[no noop]' \
        '--detailed-exitcodes[detailed exit codes]' \
        '--logdir=+[dir]:dir:_files -/' \
        '--rundir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'puppet subcommand' sub ;;
        args)
            case $words[1] in
                apply) _arguments \
                    '*:manifest:_files -g "*.pp"' \
                    '--catalog=+[catalog]:file:_files' \
                    '--environment=+[env]:str:' \
                    '-e+[code string]:str:' \
                    '--execute=+[code string]:str:' \
                    '--detailed-exitcodes[detailed exit codes]' \
                    '--noop[noop]' \
                    '--no-noop[no noop]' \
                    '--write-catalog-summary[write catalog summary]' \
                    '--debug[debug]' \
                    '--test[test mode]' \
                    '-t[test mode]' \
                    '--certname=+[certname]:str:' \
                    '--node_name_fact=+[fact]:str:' \
                    '--node_name_value=+[value]:str:' \
                    '--graph[graph]' \
                    '--graphdir=+[dir]:dir:_files -/' ;;
                agent) _arguments \
                    '--server=+[server]:host:_hosts' \
                    '--certname=+[certname]:str:' \
                    '--environment=+[env]:str:' \
                    '--no-daemonize[no daemonize]' \
                    '--onetime[onetime]' \
                    '-o[onetime]' \
                    '--test[test mode]' \
                    '-t[test mode]' \
                    '--debug[debug]' \
                    '--noop[noop]' \
                    '--show_diff[show diff]' \
                    '--detailed-exitcodes[detailed exit codes]' \
                    '--waitforcert=+[seconds]:n:' \
                    '--logdest=+[dest]:str:' ;;
                resource) _arguments \
                    '1:type:' \
                    '*:title:' \
                    '--edit[edit resource]' \
                    '-e[edit resource]' \
                    '--debug[debug]' \
                    '--verbose[verbose]' \
                    '--types[list types]' \
                    '--param=+[name]:str:' ;;
                lookup) _arguments \
                    '*:keys:' \
                    '--node=+[node]:str:' \
                    '--environment=+[env]:str:' \
                    '--explain[explain]' \
                    '--explain-options[explain options]' \
                    '--merge=+[strategy]:s:(first hash deep unique)' \
                    '--default=+[default]:str:' \
                    '--type=+[type]:t:(yaml json s)' \
                    '--render-as=+[type]:t:(s yaml json binary)' \
                    '--facts=+[facts file]:file:_files' \
                    '--compile[compile]' ;;
                module) _arguments \
                    '1:cmd:(install list search uninstall upgrade build changes generate)' \
                    '*:module:' ;;
            esac
            ;;
    esac
}

_puppet-cli "$@"
