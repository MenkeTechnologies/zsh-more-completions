#compdef cargo-tarpaulin

# Zsh completion for cargo-tarpaulin (Rust code coverage tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '-v[Use verbose output]' \
  '--verbose[Use verbose output]' \
  '--debug[Show debug output]' \
  '--color=[Coloring]:when:(auto always never)' \
  '--config=[Path to a toml file specifying a list of options]:file:_files' \
  '--root=[Path to project root]:dir:_directories' \
  '--manifest-path=[Path to Cargo.toml]:file:_files' \
  '-p+[Package to test]:package' \
  '--packages=[Package to test]:package' \
  '-e+[Packages to exclude]:package' \
  '--exclude=[Packages to exclude]:package' \
  '--workspace[Test all packages in workspace]' \
  '--all[Alias for --workspace]' \
  '--lib[Test only library targets]' \
  '--bin=[Test only the specified binary]:name' \
  '--bins[Test all binary targets]' \
  '--example=[Test only the specified example]:name' \
  '--examples[Test all example targets]' \
  '--test=[Test only the specified test target]:name' \
  '--tests[Test all test targets]' \
  '--bench=[Test only the specified bench target]:name' \
  '--benches[Test all bench targets]' \
  '--doc[Test only documentation tests]' \
  '--all-targets[Test all targets]' \
  '--release[Build in release mode]' \
  '--profile=[Build with the specified profile]:profile' \
  '-j+[Number of parallel jobs]:jobs' \
  '--jobs=[Number of parallel jobs]:jobs' \
  '--features=[Features to compile]:features' \
  '--all-features[Activate all features]' \
  '--no-default-features[Do not activate the default feature]' \
  '--target=[Target triple]:target' \
  '--target-dir=[Directory for all generated artifacts]:dir:_directories' \
  '--frozen[Require Cargo.lock and cache are up to date]' \
  '--locked[Require Cargo.lock is up to date]' \
  '--offline[Run without accessing the network]' \
  '--ignore-tests[Ignore lines of test functions]' \
  '--ignore-panics[Ignore panic macros in coverage]' \
  '--count[Count the number of hits a line has]' \
  '--force-clean[Recompile all code for coverage]' \
  '--branch[Count branches in coverage]' \
  '--forward[Show forward looking uncovered lines]' \
  '--skip-clean[Do not clean before building]' \
  '--no-dead-code[Do not include dead code in coverage]' \
  '--line[Line coverage mode (default)]' \
  '--fail-under=[Fail if coverage is below threshold]:percent' \
  '--exclude-files=[Glob patterns to exclude from coverage]:pattern' \
  '--include-files=[Glob patterns to include in coverage]:pattern' \
  '--out=[Output format]:format:(Json Stdout Xml Html Lcov)' \
  '-o+[Output format]:format:(Json Stdout Xml Html Lcov)' \
  '--output-dir=[Output directory for coverage report]:dir:_directories' \
  '--engine=[Coverage engine]:engine:(auto llvm ptrace)' \
  '--follow-exec[Follow executed programs for coverage]' \
  '--post-test-delay=[Delay between test ending and report generation]:seconds' \
  '--implicit-test-threads[Set test threads to 1 if not specified]' \
  '--command=[Cargo subcommand to run]:command:(test build)' \
  '-r+[Deprecated alias for --run-types]' \
  '--run-types=[Types of tests to run]:type:(Tests Doctests Benchmarks Examples Lib Bins)' \
  '--timeout=[Maximum time per test in seconds]:seconds' \
  '-t+[Maximum time per test in seconds]:seconds' \
  '--no-run[Compile but do not run tests]' \
  '--fail-immediately[Fail immediately on first test failure]' \
  '--ciserver=[Name of CI server]:name' \
  '--coveralls=[Coveralls.io token]:token' \
  '--report-uri=[URI to upload results to]:uri' \
  '-Z+[Unstable features]:feature' \
  '*:args' && ret=0

return ret
