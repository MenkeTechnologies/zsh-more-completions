#compdef slit
# Documentation: https://github.com/tigrawap/slit
# slit - interactive log file pager with filters and search

local ret=1

_arguments -s -S \
  '(-f --follow)'{-f,--follow}'[follow file/stdin, applying filters to new data]' \
  '--filters=[file path or inline filters separated by semicolons]:filters:_files' \
  '(-K --keep-chars)'{-K+,--keep-chars=}'[predefined number of kept chars]:n:' \
  '(-O --output)'{-O+,--output=}'[stdin cache location]:file:_files' \
  '--short-stdin-timeout=[max ms to wait for delayed short stdin]:ms:' \
  '--always-term[always open in term mode even if output is short]' \
  '--debug[enable debug messages written to /tmp/slit.log]' \
  '--version[display version]' \
  '*:file:_files' && ret=0

return ret
