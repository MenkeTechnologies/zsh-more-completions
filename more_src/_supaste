#compdef supaste
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/supaste.c
# SUPASTE - paste existing SU headers on existing binary data

local ret=1

_arguments -s -S \
  'ns=[number of samples per trace]:n:' \
  'head=[file with segy headers]:f:_files' \
  'ftn=[Fortran flag (0 = C, 1 = Fortran)]:f:(0 1)' \
  'verbose=[1 = echo number of traces pasted]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
