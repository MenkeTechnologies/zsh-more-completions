#compdef sutsq
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/stretching_moveout_resamp/sutsq.c
# Time-squared stretch (t to t^2 and inverse) of SU data

local ret=1

_arguments -s -S \
  'tmin=[minimum time sample of interest]:tmin' \
  'dt=[time sampling interval]:dt' \
  'flag=[1 forward t to t^2, otherwise inverse]:flag:(1 -1)' \
  '*:file:_files' && ret=0

return ret
