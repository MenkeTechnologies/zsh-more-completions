#compdef cargo-typeshare typeshare
# _cargo-typeshare — emit Kotlin/Swift/Scala/TS types from Rust (1Password/typeshare)
# upstream: https://github.com/1Password/typeshare
# Subcommands & flags from cli/src/args.rs (clap).

_cargo-typeshare() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-l --lang)'{-l+,--lang=}'[output language]:lang:(kotlin scala swift typescript go python)' \
        '(-s --swift-prefix)'{-s+,--swift-prefix=}'[Swift type prefix]:prefix:' \
        '(-k --kotlin-prefix)'{-k+,--kotlin-prefix=}'[Kotlin type prefix]:prefix:' \
        '(-j --java-package)'{-j+,--java-package=}'[Java package name]:pkg:' \
        '(-m --module-name)'{-m+,--module-name=}'[Kotlin serializer module]:name:' \
        '--scala-package=[Scala package name]:pkg:' \
        '--scala-module-name=[Scala serializer module]:name:' \
        '--go-package=[Go package name]:pkg:' \
        '(-c --config-file)'{-c+,--config-file=}'[typeshare config file]:file:_files -g "*.toml"' \
        '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
        '(-d --output-folder)'{-d+,--output-folder=}'[output folder]:dir:_files -/' \
        '(-g --generate-config)'{-g,--generate-config}'[generate template config and exit]' \
        '(-L --follow-links)'{-L,--follow-links}'[follow symlinks]' \
        '(-t --target-os)*'{-t+,--target-os=}'[restrict to target_os]:os:(linux macos windows ios android)' \
        '1: :->cmd' \
        '*:directories:_files -/'

    case $state in
        cmd)
            local -a cmds=(
                'completions:generate shell completion script'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_cargo-typeshare "$@"
