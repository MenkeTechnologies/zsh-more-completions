#compdef tsv-append
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-append.md
# tsv-append - concatenate TSV files, optionally tracking the source file

local ret=1

_arguments -s -S \
  '(-h --help --help-verbose)'{-h,--help}'[print help]' \
  '(-h --help --help-verbose)--help-verbose[print detailed help]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '(-H --header)'{-H,--header}'[treat first line of each file as a header]' \
  '(-t --track-source)'{-t,--track-source}'[track the source file; adds a column with the source name]' \
  '(-s --source-header)'{-s,--source-header}'=[use STR as the header for the source column]:header string:' \
  '(-f --file)'{-f,--file}'=[read FILE using STR as the source value]:str=file:_files' \
  '(-d --delimiter)'{-d,--delimiter}'=[field delimiter (default: TAB)]:delimiter char:' \
  '--line-buffered[immediately output every line]' \
  '*:file:_files' && ret=0

return ret
