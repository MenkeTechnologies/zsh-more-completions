#compdef carta_backend
# Documentation: https://carta.readthedocs.io/en/latest/installation_and_configuration.html
# CARTA: backend image-visualization server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--verbosity=[display verbose logging from this level (default 4)]:level' \
  '--no_log[do not log output to a log file]' \
  '--log_performance[enable performance debug logs]' \
  '--log_protocol_messages[enable protocol message debug logs]' \
  '--no_frontend[disable built-in HTTP frontend interface]' \
  '--no_database[disable built-in HTTP database interface]' \
  '--no_browser[do not open the frontend URL in a browser on startup]' \
  '--browser=[custom browser command]:browser' \
  '--host=[only listen on the specified interface]:interface:_hosts' \
  '(-p --port)'{-p,--port}'=[manually set the HTTP and WebSocket port (default 3002)]:port' \
  '(-t --omp_threads)'{-t,--omp_threads}'=[manually set OpenMP thread pool count]:threads' \
  '--top_level_folder=[set top-level folder for data files]:dir:_files -/' \
  '--frontend_folder=[set folder from which frontend files are served]:dir:_files -/' \
  '--exit_timeout=[seconds to stay alive after last session exits]:sec' \
  '--initial_timeout=[seconds to stay alive at start if no clients connect]:sec' \
  '--idle_timeout=[seconds to keep idle sessions alive]:sec' \
  '--read_only_mode[disable write requests]' \
  '--enable_scripting[enable HTTP scripting interface]' \
  '--no_user_config[ignore user configuration file]' \
  '--no_system_config[ignore system configuration file]' \
  '--debug_no_auth[accept all incoming WebSocket connections on the specified port(s)]' \
  '--no_runtime_config[do not send a runtime config object to frontend clients]' \
  '--controller_deployment[used when the backend is launched by carta-controller]' \
  '--threads=[deprecated: manually set number of event processing threads]:threads' \
  '--base=[deprecated: set starting folder for data files]:dir:_files -/' \
  '--root=[deprecated: use top_level_folder instead]:dir:_files -/' \
  '--no_http[deprecated: disable built-in HTTP frontend and database interfaces]' \
  '*:image:_files' && ret=0

return ret
