#compdef mkiraf
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/mkiraf.1.html
# Set up the IRAF environment for a user (uparm, login.cl)

local ret=1

_arguments -s -S \
  '(-d --default)'{-d,--default}'[create upar in ${HOME}/.iraf instead of local directory]' \
  '(-i --init)'{-i,--init}'[initialize uparm, removing old parameter settings]' \
  '(-n --noinit)'{-n,--noinit}'[do not initialize uparm if it exists]' \
  '(-c --copy)'{-c,--copy}'[create a copy of the login.cl file]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output messages]' && ret=0

return ret
