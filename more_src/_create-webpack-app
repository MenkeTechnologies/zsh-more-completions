#compdef create-webpack-app
# Documentation: https://github.com/webpack/webpack-cli/tree/main/packages/create-webpack-app
# Reference accessed: 2026-05-24
# Verified: npm view create-webpack-app bin; create-webpack-app README at the URL above.

# Zsh completion for create-webpack-app - webpack project/plugin/loader scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-f --force)'{-f,--force}'[generate with default answers]' \
  '--template=[project template name]:template:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' init loader plugin && ret=0
    ;;
  args)
    case $line[1] in
      init|loader|plugin)
        _arguments -C \
          '(-f --force)'{-f,--force}'[generate with default answers]' \
          '--template=[template name]:template:' \
          ':generation path:_directories' && ret=0
        ;;
      *)
        _arguments -C \
          '(-f --force)'{-f,--force}'[generate with default answers]' \
          '--template=[template name]:template:' \
          ':generation path:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
