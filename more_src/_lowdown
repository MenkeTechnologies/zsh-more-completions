#compdef lowdown
# Documentation: https://manpages.ubuntu.com/manpages/noble/en/man1/lowdown.1.html
# Reference accessed: 2026-05-19
# Verified: upstream lowdown(1) manual page at the URL above.

# Zsh completion for lowdown - Markdown to various formats

_arguments -s -S \
  '-L[list metadata keys]' \
  '-s[standalone document]' \
  '--out-standalone[standalone document]' \
  '*-M+[metadata key=value (overrides document)]:key=value:' \
  '*-m+[metadata key=value (overridden by document)]:key=value:' \
  '(-o)-o+[output file]:file:_files' \
  '(-t -T)-t+[output type]:type:(html latex gemini ms man mdoc fodt term null tree)' \
  '(-t -T)-T+[output type]:type:(html latex gemini ms man mdoc fodt term null tree)' \
  '-X+[extract metadata value for keyword]:keyword:' \
  '--parse-hilite[enable highlight span support]' \
  '--parse-math[recognize mathematics equations]' \
  '--parse-maxdepth=[set nesting depth limit]:depth:' \
  '--parse-no-autolink[disable automatic link parsing]' \
  '--parse-no-cmark[disable CommonMark constraints]' \
  '--parse-no-codeindent[disable indented code blocks]' \
  '--parse-no-callouts[disable GFM callouts]' \
  '--parse-no-deflists[disable definition lists]' \
  '--parse-no-ext-attrs[disable extended attributes]' \
  '--parse-no-fenced[disable fenced code blocks]' \
  '--parse-no-footnotes[disable footnotes]' \
  '--parse-no-intraemph[disable emphasis within words]' \
  '--parse-no-mantitle[disable manpage title parsing]' \
  '--parse-no-metadata[disable metadata parsing]' \
  '--parse-no-strike[disable strikethroughs]' \
  '--parse-no-super[disable superscripts/subscripts]' \
  '--parse-no-tables[disable GFM tables]' \
  '--parse-no-tasklists[disable task lists]' \
  '--parse-super-short[use traditional superscript syntax]' \
  '--out-no-smarty[disable smart typography]' \
  '--html-callout-mdn[use MDN-style callouts]' \
  '--html-callout-gfm[use GFM-style callouts]' \
  '--html-hardwrap[hard-wrap paragraphs]' \
  '--html-no-escapehtml[output HTML verbatim]' \
  '--html-no-head-ids[omit header ID attributes]' \
  '--html-no-owasp[minimal HTML escaping]' \
  '--html-no-num-ent[preserve HTML entities]' \
  '--html-no-skiphtml[include embedded HTML]' \
  '--nroff-code-font=[override code fonts]:fonts:' \
  '--nroff-no-groff[traditional troff compatibility]' \
  '--nroff-no-numbered[disable numbered headings (MS)]' \
  '--nroff-no-skiphtml[include embedded HTML]' \
  '--nroff-nolinks[hide link URLs]' \
  '--nroff-shortlinks[shorten URLs to domain/path]' \
  '--term-all-metadata[show all metadata in standalone mode]' \
  '--term-columns=[set screen width]:columns:' \
  '--term-hmargin=[left margin]:margin:' \
  '--term-no-ansi[disable ANSI styling]' \
  '--term-no-colour[disable colors]' \
  '--term-nolinks[hide link URLs]' \
  '--term-shortlinks[shorten URLs]' \
  '--term-vmargin=[top/bottom margins]:margin:' \
  '--term-width=[line character limit]:width:' \
  '--gemini-link-end[emit links at document end]' \
  '--gemini-link-inline[render links inline]' \
  '--gemini-link-noref[do not format link labels]' \
  '--gemini-link-roman[use Roman numerals for labels]' \
  '--gemini-metadata[print metadata block]' \
  '--latex-no-numbered[disable section numbering]' \
  '--latex-no-skiphtml[include embedded HTML]' \
  '--odt-no-skiphtml[include embedded HTML]' \
  '--odt-style=[custom style file]:file:_files' \
  '*:Markdown file:_files -g "*.{md,markdown,mkd,mdown}"'
