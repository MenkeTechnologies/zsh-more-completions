#compdef lowdown

# Zsh completion for lowdown - Markdown to various formats

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-T --out-type -t)'{-T,--out-type,-t}'[output type]:type:(html latex gemini ms man fodt term tree null)' \
  '(-X --extract-metadata)'{-X,--extract-metadata}'[extract metadata key]:key:' \
  '-s[standalone document]' \
  '--standalone[standalone document]' \
  '--parse-no-autolink[disable autolinks]' \
  '--parse-no-cmark[disable CommonMark]' \
  '--parse-no-codeindent[disable indented code blocks]' \
  '--parse-no-deflist[disable definition lists]' \
  '--parse-no-fenced[disable fenced code blocks]' \
  '--parse-no-footnotes[disable footnotes]' \
  '--parse-no-img[disable images]' \
  '--parse-no-intraemph[disable intra-word emphasis]' \
  '--parse-no-math[disable math]' \
  '--parse-no-metadata[disable metadata]' \
  '--parse-no-strike[disable strikethrough]' \
  '--parse-no-super[disable superscripts]' \
  '--parse-no-tables[disable tables]' \
  '--parse-no-tasklist[disable task lists]' \
  '--html-no-escapehtml[disable HTML escaping]' \
  '--html-no-head-ids[disable heading IDs]' \
  '--html-no-owasp[disable OWASP sanitising]' \
  '--html-no-num-ent[disable numeric entities]' \
  '--html-no-skiphtml[do not skip raw HTML]' \
  '--html-hardwrap[hard line breaks]' \
  '--nroff-no-groff[disable groff extensions]' \
  '--nroff-no-numbered[disable numbered sections]' \
  '--nroff-no-skiphtml[do not skip raw HTML]' \
  '--nroff-hardwrap[hard line breaks]' \
  '--term-columns=[terminal width]:columns:' \
  '--term-no-ansi[disable ANSI formatting]' \
  '--term-no-colour[disable colour output]' \
  '--term-hmargin=[horizontal margin]:margin:' \
  '--term-vmargin=[vertical margin]:margin:' \
  '*:Markdown file:_files -g "*.{md,markdown,mkd,mdown}"'
