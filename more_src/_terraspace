#compdef terraspace
# Documentation: https://man.archlinux.org/search?q=terraspace
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      all:'aggregate helpers'
      build:'compile Terraform stacks'
      bundle:'install modules from Terrafile'
      check:'validate the environment'
      clean:'remove caches'
      completion:'print completion words'
      completion_script:'emit completion setup script'
      console:'open terraform console'
      down:'destroy stacks'
      fmt:'run terraform fmt'
      force_unlock:'clear stale state locks'
      import:'import existing cloud resources'
      info:'describe stacks'
      list:'list stacks and modules'
      logs:'inspect terraspace logs'
      new:'scaffold projects'
      output:'show terraform outputs'
      plan:'run terraform plan'
      providers:'inspect provider versions'
      refresh:'refresh terraform state'
      seed:'create starter tfvars'
      setup:'bootstrap tooling'
      show:'run terraform show'
      state:'state subcommands'
      summary:'summarize tracked resources'
      taint:'taint addresses'
      tfc:'Terraform Cloud helpers'
      test:'run automated tests'
      untaint:'clear taints'
      up:'apply stacks'
      validate:'terraform validate'
      version:'print version'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '(-y --yes)'{-y,--yes}'[auto-approve destructive actions]' \
      '(-i --instance)'{-i+,--instance=}'[stack instance name]:' \
      '--plan=[plan file to reuse]:file:_files' \
      '*:stack or extra args:_default' && ret=0
    ;;
esac

return ret
