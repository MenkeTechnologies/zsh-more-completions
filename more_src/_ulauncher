#compdef ulauncher
# _ulauncher — GTK application launcher with extensions (Ulauncher/Ulauncher)
# upstream: https://github.com/Ulauncher/Ulauncher
# Subcommands + flags from ulauncher/cli/__init__.py + ulauncher/cli/commands/*.py.

_ulauncher() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '--with-debugger[start a debugpy listener on the runtime]' \
        '1: :_ulauncher_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                show)
                    _arguments \
                        '--query=[pre-fill the search bar with this query]:query:'
                    ;;
                install|i)
                    _arguments '1:extension URL or path:_files -/'
                    ;;
                uninstall|rm)
                    _arguments '1:extension ID or URL:'
                    ;;
                upgrade|up)
                    _arguments '1:extension ID (omit to upgrade all):'
                    ;;
                preview|pr)
                    _arguments '1:extension source dir:_files -/'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ulauncher_commands] )) ||
_ulauncher_commands() {
    local -a commands
    commands=(
        'start:start the Ulauncher background process'
        'show:show the Ulauncher window (default)'
        'toggle:toggle the Ulauncher window'
        'extensions:list installed extensions (alias: e)'
        'install:install an extension from URL/path (alias: i)'
        'uninstall:uninstall an extension (alias: rm)'
        'upgrade:upgrade one / all extensions (alias: up)'
        'preview:run a local extension for development (alias: pr)'
    )
    _describe -t commands 'ulauncher command' commands
}

_ulauncher "$@"
