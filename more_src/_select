#compdef gmx-select
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-select.html
# Write out basic data about dynamic selections from trajectories

local ret=1

_arguments -s -S \
  '-f+[input trajectory or configuration]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[input structure file]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[extra index groups]:index file:_files -g "*.ndx"' \
  '-os+[number of positions in each selection]:xvg file:_files -g "*.xvg"' \
  '-oc+[covered fraction for each selection]:xvg file:_files -g "*.xvg"' \
  '-oi+[indices selected by each selection]:dat file:_files -g "*.dat"' \
  '-on+[index file from the selection]:index file:_files -g "*.ndx"' \
  '-om+[mask for selected positions]:xvg file:_files -g "*.xvg"' \
  '-of+[occupied fraction for selected positions]:xvg file:_files -g "*.xvg"' \
  '-ofpdb+[PDB file with occupancy fractions]:pdb file:_files -g "*.pdb"' \
  '-olt+[lifetime histogram]:xvg file:_files -g "*.xvg"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-fgroup+[atoms stored in trajectory file]:selection:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-sf+[selections from file]:file:_files' \
  '-selrpos+[selection reference positions]:position:' \
  '-seltype+[default selection output positions]:position:' \
  '-select+[selections to analyze]:selection:' \
  '-resnr+[residue number output type]:type:' \
  '-pdbatoms+[atoms to write in PDB output]:type:' \
  '-rmpbc[make molecules whole per frame]' \
  '-pbc[use periodic boundary conditions]' \
  '-norm[normalize by total positions]' \
  '-cfnorm[normalize by covered fraction]' \
  '-cumlt[cumulate subintervals in lifetime histogram]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
