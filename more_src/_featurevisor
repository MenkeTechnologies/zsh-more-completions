#compdef featurevisor

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new Featurevisor project'
  'lint:lint definition files for errors'
  'build:build per-environment/tag JSON datafiles'
  'test:run tests for features and segments'
  'find-duplicate-segments:find segments with identical conditions'
  'find-usage:find where segments/attributes/features are used'
  'generate-code:generate strongly-typed code (TS/JS/etc.)'
  'evaluate:debug feature evaluation against a context'
  'benchmark:measure SDK evaluation performance'
  'assess-distribution:simulate traffic distribution'
  'list:list features/segments/attributes/tests'
  'config:show project configuration'
  'info:show entity counts'
  'site:static status site (export/serve)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--projectDirectoryPath=[path to project]:dir:_files -/' \
  '--pretty[pretty-print output]' \
  '--verbose[verbose output]' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'featurevisor command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--example=[example template]:example:' \
          '*::dir:_files -/' && ret=0 ;;
      (build)
        _arguments \
          '--environment=[target environment]:env:' \
          '--tag=[target tag]:tag:' \
          '--feature=[target feature]:feature:' \
          '--revision=[revision string]:revision:' \
          '--state-files-only[only emit state files]' \
          '--inflate=[inflate factor]:n:' && ret=0 ;;
      (lint)
        _arguments \
          '--keyPattern=[key pattern]:regex:' \
          '*::entity:(features segments attributes groups tests)' && ret=0 ;;
      (test)
        _arguments \
          '--keyPattern=[key pattern]:regex:' \
          '--assertionPattern=[assertion pattern]:regex:' \
          '--quick[quick mode]' \
          '*::testfile:_files' && ret=0 ;;
      (find-duplicate-segments)
        _arguments '--authors[show segment authors]' && ret=0 ;;
      (find-usage)
        _arguments \
          '--segment=[segment name]:name:' \
          '--attribute=[attribute name]:name:' \
          '--feature=[feature name]:name:' \
          '--unusedSegments[only unused segments]' \
          '--unusedAttributes[only unused attributes]' && ret=0 ;;
      (generate-code)
        _arguments \
          '--language=[output language]:language:(typescript javascript rust go python ruby)' \
          '--out-dir=[output directory]:dir:_files -/' \
          '--package-name=[generated package name]:name:' && ret=0 ;;
      (evaluate)
        _arguments \
          '--environment=[environment]:env:' \
          '--feature=[feature]:feature:' \
          '--context=[context JSON]:json:' \
          '--schema-version=[schema version]:version:' && ret=0 ;;
      (benchmark)
        _arguments \
          '--feature=[feature]:feature:' \
          '--variation[also evaluate variation]' \
          '--variable=[variable name]:variable:' \
          '--n=[iteration count]:n:' \
          '--context=[context JSON]:json:' && ret=0 ;;
      (assess-distribution)
        _arguments \
          '--feature=[feature]:feature:' \
          '--populateUuid=[populate context attributes]:attrs:' \
          '--context=[context JSON]:json:' \
          '--n=[iteration count]:n:' && ret=0 ;;
      (list)
        _arguments \
          '--keyPattern=[key pattern]:regex:' \
          '--feature=[feature name filter]:name:' \
          '--segment=[segment name filter]:name:' \
          '--attribute=[attribute name filter]:name:' \
          '--tag=[tag filter]:tag:' \
          '--environment=[environment filter]:env:' \
          '--archived[show archived only]' \
          '--applicableForCustomFields[only entities with custom fields]' \
          '*::entity:(features segments attributes tests)' && ret=0 ;;
      (site)
        _arguments \
          '*::sub:(export serve)' \
          '(-p --port)'{-p+,--port=}'[serve port]:port:' && ret=0 ;;
    esac ;;
esac

return ret
