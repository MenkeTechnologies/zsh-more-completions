#compdef cargo-features
# Documentation: https://github.com/ToBinio/cargo-features-manager
# Reference accessed: 2026-05-27
# Verified: upstream src/main.rs FeaturesArgs and PruneArgs clap derive definitions
# on master branch. Invoked as `cargo features` (this binary is the cargo
# subcommand shim for cargo-features-manager).

local curcontext="$curcontext" state line ret=1
local -a _cf_subcommands

_cf_subcommands=(
  'prune:prune unused features from the project'
)

_arguments -C \
  '--generate=[generate shell completion]:shell:(bash elvish fish powershell zsh)' \
  '(-p --package)'{-p+,--package=}'[select package]:name:' \
  '(-d --dependency)'{-d+,--dependency=}'[select dependency]:name:' \
  '(- 1 *)'{-h,--help}'[print help]' \
  '(- 1 *)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cargo-features subcommand' _cf_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      prune)
        _arguments \
          '--dry-run[do not modify files]' \
          '--skip-tests[skip running tests]' \
          '(-t --no-tmp)'{-t,--no-tmp}'[do not copy project into a temporary directory]' \
          '(-c --clean)'{-c+,--clean=}'[run cargo clean at given level]:level:(never package dependency)' \
          '(-d --only-dependency)'{-d,--only-dependency}'[only check features that enable extra dependencies]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
