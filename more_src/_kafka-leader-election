#compdef kafka-leader-election

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--admin.config[Property file with configs to pass to Admin Client]:file:_files'
    '--election-type[Type of election to run]:type:(preferred unclean)'
    '--topic[Topic name]:topic:'
    '--partition[Partition number]:partition:'
    '--all-topic-partitions[Perform election on all topic partitions]'
    '--path-to-json-file[JSON file with topic partitions]:file:_files'
)

_arguments -s -S $arguments
