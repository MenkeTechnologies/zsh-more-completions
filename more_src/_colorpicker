#compdef colorpicker
# Documentation: https://github.com/Jack12816/colorpicker
# Click on a pixel on your screen and print its color value

local ret=1

_arguments -s -S \
  '--one-shot[quit after the first click]' \
  '--short[print only the hexadecimal value]' \
  '--preview[show a color preview rectangle while hovering]' && ret=0

return ret
