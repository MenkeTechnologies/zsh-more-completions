#compdef vault-cli2
# Documentation: https://developer.hashicorp.com/vault/docs/commands
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# NOTE: vault-cli2 is an alias wrapper for the vault CLI (see Vault docs).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'agent:start a Vault agent'
  'audit:audit device commands'
  'auth:auth method commands'
  'debug:run debug bundle'
  'delete:delete secrets/configuration'
  'events:event subscription commands'
  'kv:KV secrets engine'
  'lease:lease commands'
  'list:list data or secrets'
  'login:authenticate locally'
  'monitor:stream Vault server logs'
  'namespace:namespace commands'
  'operator:operator commands'
  'patch:patch existing data'
  'path-help:show help for a path'
  'pki:PKI engine commands'
  'plugin:plugin commands'
  'policy:policy commands'
  'print:print server addr/token'
  'proxy:run a Vault proxy'
  'read:read data'
  'secrets:secrets engine commands'
  'server:start a Vault server'
  'ssh:initiate SSH connection'
  'status:show seal status'
  'token:token management'
  'transform:transform engine commands'
  'transit:transit engine commands'
  'unwrap:unwrap a wrapped secret'
  'version:show version'
  'version-history:show version history'
  'write:write data'
  'wrap:wrap a value'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version -v)'{-v,--version}'[show version]' \
  '*--address=[Vault addr]:url:' \
  '*--ca-cert=[CA cert]:file:_files' \
  '*--ca-path=[CA path]:dir:_files -/' \
  '*--client-cert=[client cert]:file:_files' \
  '*--client-key=[client key]:file:_files' \
  '*--header=[header]:h:' \
  '*--mfa=[mfa]:m:' \
  '*--namespace=[namespace]:n:' \
  '*--non-interactive[non-interactive]' \
  '*--output-curl-string[output curl]' \
  '*--output-policy[output policy]' \
  '*--policy-override[policy override]' \
  '*--tls-server-name=[server name]:s:' \
  '*--tls-skip-verify[skip verify]' \
  '*--token=[token]:t:' \
  '*--unlock-key=[unlock key]:k:' \
  '*--wrap-ttl=[wrap TTL]:t:' \
  '*--format=[format]:f:(table json yaml jsonx)' \
  '*--field=[field]:f:' \
  '*--detailed[detailed output]' \
  '*--no-color[no color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vault command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (kv)
        _arguments \
          '1:subcommand:(delete destroy enable-versioning get list metadata patch put rollback undelete)' \
          '*: :' && ret=0 ;;
      (auth)
        _arguments \
          '1:subcommand:(disable enable help list move tune)' \
          '*: :' && ret=0 ;;
      (secrets)
        _arguments \
          '1:subcommand:(disable enable list move tune)' \
          '*: :' && ret=0 ;;
      (operator)
        _arguments \
          '1:subcommand:(diagnose generate-root init key-status members migrate raft rekey rekey-recovery-key rotate seal step-down unseal usage utilization)' \
          '*: :' && ret=0 ;;
      (lease)
        _arguments \
          '1:subcommand:(lookup renew revoke)' \
          '*: :' && ret=0 ;;
      (token)
        _arguments \
          '1:subcommand:(capabilities create lookup renew revoke)' \
          '*: :' && ret=0 ;;
      (policy)
        _arguments \
          '1:subcommand:(delete fmt list read write)' \
          '*: :' && ret=0 ;;
      (namespace)
        _arguments \
          '1:subcommand:(api-lock-status api-lock-unlock create delete list lookup patch)' \
          '*: :' && ret=0 ;;
      (pki)
        _arguments \
          '1:subcommand:(health-check issue list-intermediates reissue verify-sign)' \
          '*: :' && ret=0 ;;
      (transform|transit)
        _arguments \
          '1:subcommand:(import import-version)' \
          '*: :' && ret=0 ;;
      (events)
        _arguments \
          '1:subcommand:(subscribe)' \
          '*: :' && ret=0 ;;
      (ssh)
        _arguments \
          '--mode=[mode]:m:(ca otp)' \
          '--mount-point=[mount]:m:' \
          '--no-exec[no exec]' \
          '--strict-host-key-checking=[opt]:o:' \
          '--user-known-hosts-file=[file]:file:_files' \
          '--port=[port]:p:' \
          '--role=[role]:r:' \
          '*: :' && ret=0 ;;
      (login)
        _arguments \
          '--method=[method]:m:(approle aws azure cert cf gcp github jwt kerberos kubernetes ldap oci oidc okta pcf radius saml token userpass)' \
          '--no-print[no print]' \
          '--no-store[no store]' \
          '--token-only[token only]' \
          '--path=[path]:p:' \
          '*: :' && ret=0 ;;
      (server)
        _arguments \
          '--config=[file]:file:_files -g "*.hcl *.json"' \
          '--dev[dev mode]' \
          '--dev-listen-address=[addr]:a:' \
          '--dev-root-token-id=[token]:t:' \
          '--dev-no-store-token[no store token]' \
          '--dev-three-node[three node cluster]' \
          '--dev-tls[dev with TLS]' \
          '--dev-cluster-json=[file]:file:_files' \
          '--dev-leased-kv[leased kv]' \
          '--dev-skip-init[skip init]' \
          '--dev-plugin-dir=[dir]:dir:_files -/' \
          '--log-level=[level]:l:(trace debug info warn error)' \
          '--log-format=[format]:f:(standard json)' \
          '--log-rotate-bytes=[bytes]:n:' \
          '--log-rotate-duration=[duration]:t:' \
          '--log-rotate-max-files=[n]:n:' \
          '*: :' && ret=0 ;;
      (debug)
        _arguments \
          '--compress=[compress]:b:(true false)' \
          '--duration=[duration]:t:' \
          '--interval=[interval]:t:' \
          '--metrics-interval=[interval]:t:' \
          '--output=[output dir]:dir:_files -/' \
          '--target=[target csv]:list:' \
          '*: :' && ret=0 ;;
      (plugin)
        _arguments \
          '1:subcommand:(deregister info list register reload reload-status runtime)' \
          '*: :' && ret=0 ;;
      (audit)
        _arguments \
          '1:subcommand:(disable enable list)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
