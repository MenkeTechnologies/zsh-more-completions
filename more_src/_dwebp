#compdef dwebp
# Documentation: https://developers.google.com/speed/webp/docs/dwebp
# Source: WebM Project libwebp — WebP image decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '(- *)-version[show version]' \
    '-o[output file (default PNG)]:file:_files' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-bmp[output BMP]' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-tiff[output TIFF]' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-pam[output PAM (keeps alpha)]' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-ppm[output PPM (drops alpha)]' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-pgm[output PGM]' \
    '(-bmp -tiff -pam -ppm -pgm -yuv)-yuv[output raw YUV]' \
    '-nofancy[disable fancy YUV420 upscaler]' \
    '-nofilter[disable in-loop filtering]' \
    '(-dither -nodither)-dither[dithering strength 0..100]:strength:' \
    '(-dither -nodither)-nodither[disable all dithering (default)]' \
    '-mt[use multi-threading]' \
    '-crop[crop x_position y_position width height]:x y w h:' \
    '-flip[flip decoded image vertically]' \
    '-resize[resize to width height]:w h:' \
    '-v[verbose (decoding time)]' \
    '-noasm[disable assembly optimizations]' \
    '*:input .webp:_files -g "*.webp"' \
    && ret=0

return ret
