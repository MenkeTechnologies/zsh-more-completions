#compdef nsenter-cli
# _nsenter-cli — util-linux nsenter run program with namespaces of other processes CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_nsenter-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[enter all namespaces of target]' \
        '--all[enter all namespaces of target]' \
        '-t+[pid]:pid:_pids' \
        '--target=+[pid]:pid:_pids' \
        '-m+[mount ns file]:file:_files' \
        '--mount=+[mount ns file]:file:_files' \
        '-u+[uts ns file]:file:_files' \
        '--uts=+[uts ns file]:file:_files' \
        '-i+[ipc ns file]:file:_files' \
        '--ipc=+[ipc ns file]:file:_files' \
        '-n+[net ns file]:file:_files' \
        '--net=+[net ns file]:file:_files' \
        '-p+[pid ns file]:file:_files' \
        '--pid=+[pid ns file]:file:_files' \
        '-C+[cgroup ns file]:file:_files' \
        '--cgroup=+[cgroup ns file]:file:_files' \
        '-U+[user ns file]:file:_files' \
        '--user=+[user ns file]:file:_files' \
        '-T+[time ns file]:file:_files' \
        '--time=+[time ns file]:file:_files' \
        '-S+[uid]:n:' \
        '--setuid=+[uid]:n:' \
        '-G+[gid]:n:' \
        '--setgid=+[gid]:n:' \
        '--preserve-credentials[preserve credentials]' \
        '-r+[root dir]:dir:_files -/' \
        '--root=+[root dir]:dir:_files -/' \
        '-w+[work dir]:dir:_files -/' \
        '--wd=+[work dir]:dir:_files -/' \
        '-e[no exec into shell]' \
        '--no-fork[no fork]' \
        '-F[no fork]' \
        '-Z[adjust selinux context]' \
        '--follow-context[adjust selinux context]' \
        '*:command:_command_names'
}

_nsenter-cli "$@"
