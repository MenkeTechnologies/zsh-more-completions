#compdef diamond diamond-cli
# _diamond — Benjamin Buchfink DIAMOND ultra-fast accelerated BLAST replacement protein and nucleotide sequence aligner (bbuchfink team, C++); custom argparse
# upstream: https://github.com/bbuchfink/diamond

_diamond() {
    local -a sub=(
        'makedb:create reference database'
        'prepdb:prepare database for use'
        'blastp:run protein-vs-protein alignment'
        'blastx:run translated DNA-vs-protein alignment'
        'view:convert binary DAA to other formats'
        'help:show help'
        'version:show version'
        'getseq:retrieve seqs from database'
        'dbinfo:show database information'
        'test:run a quick test'
        'cluster:cluster sequences'
        'deepclust:deep clustering'
        'linclust:linear clustering'
        'realign:realign clusters'
        'recluster:recluster sequences'
        'mergedb:merge databases'
        'random-seqs:generate random sequences'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--threads=+[N threads]:n:' \
        '-p+[N threads]:n:' \
        '--tmpdir=+[tmp dir]:dir:_files -/' \
        '--quiet[quiet]' \
        '--log[create log file]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'diamond subcommand' sub ;;
        args)
            case $words[1] in
                makedb) _arguments \
                    '--in=+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
                    '--db=+[output database]:str:' \
                    '-d+[output database]:str:' \
                    '--taxonmap=+[taxonomy mapping]:file:_files' \
                    '--taxonnodes=+[NCBI nodes.dmp]:file:_files' \
                    '--taxonnames=+[NCBI names.dmp]:file:_files' ;;
                blastp|blastx) _arguments \
                    '--query=+[query fasta]:file:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fastq.gz"' \
                    '-q+[query fasta]:file:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fastq.gz"' \
                    '--db=+[database file]:file:_files -g "*.dmnd"' \
                    '-d+[database file]:file:_files -g "*.dmnd"' \
                    '--out=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--outfmt=+[output format]:f:(0 5 6 100 101 102 103)' \
                    '-f+[output format]:f:(0 5 6 100 101 102 103)' \
                    '--evalue=+[F]:f:' \
                    '-e+[F]:f:' \
                    '--min-score=+[F]:f:' \
                    '--id=+[F]:f:' \
                    '--max-target-seqs=+[N]:n:' \
                    '-k+[N]:n:' \
                    '--max-hsps=+[N]:n:' \
                    '--top=+[F]:f:' \
                    '--ultra-sensitive[ultra sensitive]' \
                    '--more-sensitive[more sensitive]' \
                    '--mid-sensitive[mid sensitive]' \
                    '--sensitive[sensitive]' \
                    '--fast[fast mode]' \
                    '--faster[faster mode]' \
                    '--default-frameshift=+[F]:f:' \
                    '--frameshift=+[F]:f:' \
                    '-F+[F]:f:' \
                    '--block-size=+[size]:f:' \
                    '-b+[size]:f:' \
                    '--index-chunks=+[N]:n:' \
                    '-c+[N]:n:' \
                    '--no-self-hits[no self hits]' \
                    '--unal=+[bool]:b:(0 1)' \
                    '--header[header for tabular]' \
                    '--compress=+[level]:n:' \
                    '--gencode=+[code]:n:' \
                    '--matrix=+[matrix]:m:(BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90 PAM250 PAM70 PAM30)' ;;
                view) _arguments \
                    '--daa=+[input DAA file]:file:_files -g "*.daa"' \
                    '-a+[input DAA file]:file:_files -g "*.daa"' \
                    '--out=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--outfmt=+[output format]:f:(0 5 6)' ;;
                cluster|linclust|deepclust|realign|recluster) _arguments \
                    '--db=+[database]:str:' \
                    '-d+[database]:str:' \
                    '--out=+[output prefix]:str:' \
                    '-o+[output prefix]:str:' \
                    '--approx-id=+[F]:f:' \
                    '-M+[memory]:str:' \
                    '--cluster-steps=+[N]:n:' ;;
            esac
            ;;
    esac
}

_diamond "$@"
