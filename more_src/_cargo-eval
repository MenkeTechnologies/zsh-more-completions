#compdef cargo-eval
# Documentation: https://github.com/reitermarkus/cargo-eval
# Source: cargo-eval Cargo subcommand for quick Rust script evaluation.
# Reference accessed: 2026-06-01
# Invoked as `cargo eval` or `cargo-eval`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-e --expr)'{-e+,--expr=}'[interpret argument as Rust source instead of file path]:expression:_default' \
    '*'{-d+,--dep=}'[add a dependency to generated Cargo.toml]:dep:_default' \
    '*-D+[guess and inject extern crate when names match]:crate:_default' \
    '*-x+[inject extern crate when crate/package names differ]:crate:_default' \
    '(-t --template)'{-t+,--template=}'[custom template for expressions]:template:_default' \
    '--loop[execute closure for each stdin line]' \
    '--count[pass line number as second argument to closure]' \
    '--bench[compile and run benchmarks (nightly)]' \
    '--debug[build debug executable instead of optimized]' \
    '--test[compile and run tests]' \
    '--features=[Cargo features to enable]:features:_default' \
    '--force[force script rebuild]' \
    '--gen-pkg-only[generate Cargo package without compiling/running]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:subcommand:(file-association templates)' \
    '*::positional:->args' \
    && ret=0

case $state in
    args)
        case $line[1] in
            file-association)
                _arguments -s -S \
                    '1:subcommand:(install uninstall)' \
                    '--amend-pathext[execute .crs scripts without extension (Windows)]' \
                    && ret=0
                ;;
            templates)
                _arguments -s -S \
                    '1:subcommand:(list show dump)' \
                    '*:template name:_default' \
                    && ret=0
                ;;
            *)
                _files
                ret=0
                ;;
        esac
        ;;
esac

return ret
