#compdef age-op
# Documentation: https://github.com/stevelr/age-op
# simple CLI encryption with age + 1Password key storage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e -r -d -n)-e[encrypt using identity (private key)]' \
  '(-e -r -d -n)-r[encrypt using recipient (public key)]' \
  '(-e -r -d -n)-d[decrypt file]' \
  '(-e -r -d -n)-n[generate new identity key]' \
  '-a[use ASCII armor (PEM) output]' \
  '-k[path to key in 1Password vault]:key path:_default' \
  '-o[output file (- or unset = stdout)]:output file:_files' \
  '-t[private temp folder for key storage]:tmpdir:_files -/' \
  '*:file:_files' && ret=0

return ret
