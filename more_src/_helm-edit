#compdef helm-edit
# Documentation: https://github.com/mstrzele/helm-edit
# helm edit: edit the values of a release and upgrade it

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[edit all (computed) values]' \
  '(-m --disable-default-intersection)'{-m,--disable-default-intersection}'[keep user values equal to defaults]' \
  '(-e --editor)'{-e,--editor}'=[name of the editor]:editor:' \
  '--revision=[edit values from old revision]:revision:' \
  '--timeout=[time to wait for a Kubernetes operation]:duration:' \
  '--wait[wait until resources are ready before marking success]' \
  '*:release:' && ret=0

return ret
