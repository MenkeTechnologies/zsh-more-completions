#compdef chpst
# Documentation: https://smarden.org/runit/chpst.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-u[set uid/gid from user\[:group\]]:user\[:group\]:_users'
  '-U[set $UID and $GID in environment]:user\[:group\]:_users'
  '-b[set argv\[0\]]:argv0:'
  '-e[load environment from directory]:envdir:_directories'
  '-/[chroot to directory]:root:_directories'
  '-C[change working directory]:dir:_directories'
  '-n[adjust nice level]:nice increment:'
  '-l[lock file (wait if locked)]:lock file:_files'
  '-L[lock file (fail if locked)]:lock file:_files'
  '-m[limit memory (bytes)]:bytes:'
  '-d[limit data segment (bytes)]:bytes:'
  '-o[limit open files]:number:'
  '-p[limit processes per uid]:number:'
  '-f[limit output file size (bytes)]:bytes:'
  '-c[limit core file size (bytes)]:bytes:'
  '-t[limit CPU time (seconds)]:seconds:'
  '-v[verbose]'
  '-V[print version]'
  '-P[run in new process group]'
  '-0[close stdin]'
  '-1[close stdout]'
  '-2[close stderr]'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
