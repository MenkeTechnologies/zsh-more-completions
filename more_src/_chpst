#compdef chpst

local -a arguments

arguments=(
  '-u[set user\[:group\]]:user\[:group\]:_users'
  '-U[set user\[:group\] in environment]:user\[:group\]:_users'
  '-b[set argv\[0\]]:argv0:'
  '-e[set environment from directory]:envdir:_directories'
  '-/[change root directory]:root:_directories'
  '-n[adjust nice level]:nice increment:'
  '-l[lock file (fail if locked)]:lock file:_files'
  '-L[lock file (wait if locked)]:lock file:_files'
  '-m[limit memory (bytes)]:bytes:'
  '-d[limit data segment (bytes)]:bytes:'
  '-o[limit open files]:number:'
  '-p[limit processes]:number:'
  '-f[limit file size (bytes)]:bytes:'
  '-c[limit core size (bytes)]:bytes:'
  '-v[verbose]'
  '-P[run in new session]'
  '-0[close stdin]'
  '-1[close stdout]'
  '-2[close stderr]'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
