# kscreenlocker_greet: KDE screen lock greeter
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--testing[start greeter in testing mode]' \
  '--shell=[shell theme for testing mode]:theme:' \
  '--immediateLock[lock immediately, no grace time]' \
  '--graceTime=[delay before lock UI in milliseconds]:ms:' \
  '--nolock[do not show any lock UI]' \
  '--ksldfd=[file descriptor for connecting to ksld]:fd:' && ret=0
return ret
