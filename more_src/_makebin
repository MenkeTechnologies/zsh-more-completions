#compdef makebin
# Documentation: https://manpages.debian.org/bookworm/sdcc/makebin.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (SDCC makebin manpage
# cross-checked with makebin source darconeous/sdcc).

# makebin: SDCC tool to convert .ihx (Intel hex) to plain binary or
# Game Boy ROM image
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-p[pack mode (truncate to last occupied byte)]' \
  '-s+[ROM size in bytes (default 32768)]:bytes:' \
  '-Z[generate Game Boy format binary]' \
  '-yo+[number of ROM banks (Game Boy)]:n:' \
  '-ya+[number of RAM banks (Game Boy)]:n:' \
  '-yt+[MBC type (Game Boy)]:n:' \
  '-yn+[cartridge name (Game Boy)]:name:' \
  '*:input output:_files' && ret=0
return ret
