#compdef makebin

# makebin: SDCC tool to convert .ihx (Intel hex) to binary or Game Boy ROM
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-p[pad with byte]:hex:' \
  '-s[ROM size]:bytes:' \
  '-Z[generate Game Boy ROM]' \
  '-yn[ROM name]:name:' \
  '-yo[number of ROM banks]:n:' \
  '-yk[license code]:str:' \
  '-yt[cartridge type]:hex:' \
  '-yv[version]:n:' \
  '-ya[RAM banks]:n:' \
  '-yp[address=value]:addr=value:' \
  '-yj[Japanese region]' \
  '*:input output:_files' && ret=0
return ret
