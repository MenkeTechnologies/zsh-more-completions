#compdef kueue-priority-booster
# _kueue-priority-booster — experimental Kueue priority booster controller (kubernetes-sigs/kueue)
# upstream: https://github.com/kubernetes-sigs/kueue/tree/main/cmd/experimental/kueue-priority-booster
# Flags from cmd/experimental/kueue-priority-booster/main.go + controller-runtime zap.Options on tip.

_kueue-priority-booster() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[priority-booster configuration file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--zap-devel=[enable development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kueue-priority-booster "$@"
