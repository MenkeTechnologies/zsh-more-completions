#compdef vinxi

# Zsh completion for vinxi - Full-stack JavaScript SDK

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'dev:Start development server'
      'build:Build for production'
      'start:Start production server'
    )
    _describe -t commands 'vinxi commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      dev)
        _arguments -s -S \
          '--help[show help]' \
          '(-p --port)'{-p,--port}'[port to listen on]:port:' \
          '(-H --host)'{-H,--host}'[host to bind to]:host:' \
          '--force[force re-optimize deps]' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--help[show help]' && ret=0
        ;;
      start)
        _arguments -s -S \
          '--help[show help]' \
          '(-p --port)'{-p,--port}'[port to listen on]:port:' \
          '(-H --host)'{-H,--host}'[host to bind to]:host:' && ret=0
        ;;
    esac
    ;;
esac

return ret
