#compdef bodyclose go-errorlint maintidx nonamedreturns testpackage usestdlibvars
# Documentation: upstream READMEs at github.com/{timakin/bodyclose,polyfloyd/go-errorlint,yagipy/maintidx,firefart/nonamedreturns,maratori/testpackage,sashamelentyev/usestdlibvars}
# Reference accessed: 2026-05-30
# Continuation of Go linter sweep R22 — 6 more single-purpose linters
# wrapping the analysis/passes framework. Most are also runnable via
# `go vet -vettool=$(which TOOL)` and through golangci-lint.

local curcontext="$curcontext" state line ret=1

case $service in

  bodyclose)
    # timakin/bodyclose — HTTP response body closure analyzer.
    _arguments -s -S \
      '-check-consumption[verify response bodies are consumed]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  go-errorlint)
    # polyfloyd/go-errorlint — Go 1.13 error-wrapping pattern linter.
    # NOTE: upstream archived; moved to Codeberg.
    _arguments -s -S \
      '-fix[apply suggested fixes automatically]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  maintidx)
    # yagipy/maintidx — function maintainability index (cyclomatic +
    # Halstead + LOC composite, Microsoft rebased scale).
    _arguments -s -S \
      '-under=[show functions with maintainability below N (default 20)]:N:' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  nonamedreturns)
    # firefart/nonamedreturns — flag named return values.
    _arguments -s -S \
      '-report-error-in-defer[also report named errors used in defer (default false)]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  testpackage)
    # maratori/testpackage — enforce separate _test packages.
    _arguments -s -S \
      '-skip-regexp=[pattern to ignore files (default `(export|internal)_test\.go`)]:pattern:' \
      '-allow-packages=[comma-separated permitted non-_test packages (default main)]:packages:' \
      '-test[analyze test files (default true)]' \
      '-fix[apply suggested fixes automatically]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  usestdlibvars)
    # sashamelentyev/usestdlibvars — suggest stdlib constants for
    # hardcoded values (HTTP/time/crypto/OS/RPC/SQL/TLS).
    _arguments -s -S \
      '-V[show version]' \
      '-h[show help]' \
      '-flags[output analyzer flags in JSON format]' \
      '-json[produce JSON-formatted output]' \
      '-fix[apply suggested fixes automatically]' \
      '-test[include test files (default true)]' \
      '-http-method[detect HTTP method constants (default true)]' \
      '-http-status-code[detect HTTP status code constants (default true)]' \
      '-time-layout[detect time layout constants]' \
      '-time-month[detect time month constants]' \
      '-time-weekday[detect time weekday constants]' \
      '-os-dev-null[detect os.DevNull]' \
      '-crypto-hash[detect crypto hash functions]' \
      '-constant-kind[detect constant kind methods]' \
      '-sql-isolation-level[detect SQL isolation level constants]' \
      '-tls-signature-scheme[detect TLS signature scheme constants]' \
      '-rpc-default-path[detect RPC default path constants]' \
      '-cpuprofile=[write CPU profile to file]:file:_files' \
      '-memprofile=[write memory profile to file]:file:_files' \
      '-trace=[write trace log to file]:file:_files' \
      '-debug=[debug flags subset of fpstv]:flags:' \
      '-c=[context lines (default -1)]:N:' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
