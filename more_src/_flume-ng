#compdef flume-ng

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agent:start a Flume agent'
  'avro-client:send data via Avro RPC'
  'version:show version'
  'help:show usage'
)

_arguments -C \
  '(-c --conf)'{-c,--conf=}'[config directory]:dir:_files -/' \
  '(-C --classpath)'{-C,--classpath=}'[classpath]:cp:' \
  '(-d --dryrun)'{-d,--dryrun}'[dry run]' \
  '--plugins-path=[plugin path]:path:' \
  '*-D[Java property]:prop=value:' \
  '*-X[JVM property]:prop=value:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'flume-ng subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (agent)
        _arguments \
          '(-n --name)'{-n,--name=}'[agent name]:name:' \
          '(-f --conf-file)'{-f,--conf-file=}'[config file]:file:_files -g "*.properties"' \
          '(-z --zkConnString)'{-z,--zkConnString=}'[ZooKeeper connect string]:str:' \
          '(-p --zkBasePath)'{-p,--zkBasePath=}'[ZK base path]:path:' \
          '--no-reload-conf[do not reload config]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (avro-client)
        _arguments \
          '(-P --rpcProps)'{-P,--rpcProps=}'[RPC props file]:file:_files' \
          '(-H --host)'{-H,--host=}'[host]:host:_hosts' \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '--dirname=[directory]:dir:_files -/' \
          '(-F --filename)'{-F,--filename=}'[file]:file:_files' \
          '(-R --headerFile)'{-R,--headerFile=}'[header file]:file:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
