#compdef wimverify
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-verify.1.html
# wimverify — verify the validity and integrity of a WIM file

local ret=1

_arguments -s -S \
  '--nocheck[do not check the WIM integrity information]' \
  '--ref=[reference additional WIMs or split parts]:glob' \
  '*:WIM file:_files' && ret=0

return ret
