#compdef arttime
# Documentation: https://github.com/poetaman/arttime
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-a)-a+[art name]:name:' \
  '(-b)-b+[alternate art name]:name:' \
  '(-t)-t+[message text]:text:' \
  '--random[randomize loaded art]' \
  '-g+[timer goals]:goals:' \
  '--hours=[12 or 24-hour clock]:hours:(12 24)' \
  '(-k --keypoem)'{-k,--keypoem}'+[keystroke poem file]:file:_files' \
  '--ac+[animation color count]:n:' \
  '--tc+[timer color count]:n:' \
  '--theme=[color theme]:theme:(light dark)' \
  '--style+[style number]:n:' \
  '--pa+[primary art palette string]:str:' \
  '--pb+[secondary art palette string]:str:' \
  '--pl+[palette index]:n:' \
  '--nolearn[skip keybindings help on launch]' \
  '--version[show version]' \
  '(-m --man)'{-m,--man}'[open manual]' \
  '(-h --help)'{-h,--help}'[show help]'
