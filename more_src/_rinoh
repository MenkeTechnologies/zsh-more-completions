#compdef rinoh
# Documentation: https://www.mos6581.org/rinohtype/master/rinoh.html
# Render reStructuredText, Markdown, CommonMark or DocBook to PDF with rinohtype

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[show program version number and exit]' \
  '(-f --format)'{-f,--format}'[format of the input file]:format' \
  '*'{-o,--option}'[option passed to the input file reader]:option=value' \
  '(-t --template)'{-t,--template}'[document template or template configuration file]:template' \
  '(-s --stylesheet)'{-s,--stylesheet}'[style sheet used to style document elements]:stylesheet' \
  '(-O --output)'{-O,--output}'[output PDF location or directory]:output:_files' \
  '(-p --paper)'{-p,--paper}'[paper size to render to]:paper' \
  '(-i --install-resources)'{-i,--install-resources}'[install missing resources from PyPI]' \
  '--list-templates[list the installed document templates and exit]' \
  '--list-stylesheets[list the installed style sheets and exit]' \
  '--list-fonts[list installed fonts]::file:_files' \
  '--list-formats[list the supported input formats and exit]' \
  '--list-options[list reader options for a frontend]:frontend' \
  '1:input:_files' && ret=0

return ret
