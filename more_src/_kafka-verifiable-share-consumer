#compdef kafka-verifiable-share-consumer
# Documentation: https://kafka.apache.org/documentation/ (kafka-verifiable-share-consumer.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '--topic[Consumes messages from this topic]:topic:'
    '--group-id[The group id of the share group]:group:'
    '--max-messages[Consume this many messages (-1 to consume until killed)]:count:'
    '--verbose[Log individual consumed records]'
    "--acknowledgement-mode[Acknowledgement mode for the share consumers]:mode:(auto sync async)"
    "--offset-reset-strategy[Share group offset reset strategy]:strategy:(earliest latest)"
    '--command-config[Config properties file]:file:_files'
    '--bootstrap-server[The server(s) to connect to]:host\:port:'
)

_arguments -s -S $arguments
