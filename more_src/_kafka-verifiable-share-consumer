#compdef kafka-verifiable-share-consumer

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to consume from]:topic:'
    '--group-id[Share group ID]:group:'
    '--max-messages[Maximum number of messages to consume (-1 for unlimited)]:count:'
    '--session-timeout[Session timeout in ms]:ms:'
    '--verbose[Print verbose output]'
    '--consumer.config[Consumer config properties file]:file:_files'
)

_arguments -s -S $arguments
