#compdef hiracli
# Documentation: https://github.com/hiracy/hiracli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hiracli: Swiss Army CLI Tool leveraging AWS Bedrock LLMs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    local -a commands=(
      'llm:LLM-related subcommands'
      'git:Git-related subcommands'
      'help:show help for a command'
    )
    _describe -t commands 'hiracli command' commands && ret=0
    ;;
  args)
    case $words[1] in
      llm)
        _arguments \
          '1:subcommand:(list ask flatten-src)' \
          '--llm=[LLM model to use]:model:' \
          '--debug[enable debug output]' \
          '--pattern=[file name pattern]:pattern:' \
          '--extension=[file extension]:ext:' \
          '--path=[base path]:path:_files -/' \
          '--depth-limit=[max depth]:n:' \
          '--max-input-tokens=[max input tokens]:n:' && ret=0
        ;;
      git)
        _arguments \
          '1:subcommand:(diff-comment)' \
          '--llm=[LLM model to use]:model:' \
          '--cached[use cached (staged) diff]' && ret=0
        ;;
    esac
    ;;
esac

return ret
