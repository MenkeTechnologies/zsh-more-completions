#compdef bashunit
# Zsh completion for bashunit (TypenDev bash testing framework)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--filter=[filter tests by name]:pattern:' \
  '--log-junit=[output JUnit XML report to file]:file:_files' \
  '--report-html=[output HTML report to file]:file:_files' \
  '--simple[use simple output format]' \
  '--verbose[use verbose output]' \
  '--debug[enable debug mode]' \
  '--stop-on-failure[stop execution on first failure]' \
  '--no-parallel[disable parallel test execution]' \
  '--parallel[enable parallel test execution]' \
  '--env=[load environment variables from file]:file:_files' \
  '(- *)--version[display version]' \
  '(- *)--help[display help]' \
  '*:test file:_files' && ret=0

return ret
