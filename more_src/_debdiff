#compdef debdiff
# Documentation: https://manpages.debian.org/debdiff
# Source: debian/devscripts scripts/debdiff.pl — compare Debian source/binary packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '*--from=-[first set of debs (followed by deb files)]:debs:_files -g "*.{deb,udeb}"' \
    '*--to=-[second set of debs]:debs:_files -g "*.{deb,udeb}"' \
    '*'{-m+,--move=}'[map prefix FROM TO]:from to:_default' \
    '*--move-regex=-[regex map prefix FROM TO]:from to:_default' \
    '(--nodirs -d --dirs)'{-d,--dirs}'[note directory changes]' \
    '(-d --dirs --nodirs)--nodirs[do not note directory changes (default)]' \
    '(--control)--nocontrol[skip comparing control files]' \
    '(--nocontrol)--control[compare control files]' \
    '--controlfiles=-[control files to compare]:files:_default' \
    '--wp[pass -p to wdiff]' \
    '--wl[pass -l to wdiff]' \
    '--wt[pass -t to wdiff]' \
    '(--no-wdiff-source-control)--wdiff-source-control[compare control files in source packages]' \
    '--no-wdiff-source-control[do not compare source control]' \
    '(--noshow-moved)--show-moved[show moved files]' \
    '--noshow-moved[do not show moved files]' \
    '*--renamed=-[rename map FROM TO]:from to:_default' \
    '(-q --quiet)'{-q,--quiet}'[quiet if no differences]' \
    '*--exclude=-[exclude basename pattern]:pattern:_default' \
    '(-w --ignore-space)'{-w,--ignore-space}'[ignore whitespace]' \
    '--no-check[skip signature and checksum checks]' \
    '(--no-diffstat)--diffstat[include diffstat]' \
    '--no-diffstat[no diffstat (default)]' \
    '(--no-auto-ver-sort)--auto-ver-sort[sort versions automatically]' \
    '--no-auto-ver-sort[do not sort versions (default)]' \
    '(--skip-patches)--apply-patches[apply patches before diffing]' \
    '(--apply-patches)--skip-patches[skip patches]' \
    '--debs-dir=-[directory containing .deb files]:dir:_files -/' \
    '*--unpack-tarballs[unpack contained tarballs]' \
    '*:dsc/changes/deb files:_files -g "*.{dsc,changes,deb,udeb}"' \
    && ret=0

return ret
