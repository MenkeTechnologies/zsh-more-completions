#compdef smem

# Zsh completion for smem - report memory usage

_arguments -s -S \
  '(-H --no-header)'{-H,--no-header}'[disable header line]' \
  '(-c --columns)'{-c+,--columns=}'[columns to show]:columns:' \
  '(-a --autosize)'{-a,--autosize}'[size columns to fit terminal width]' \
  '(-R --realmem)'{-R+,--realmem=}'[amount of physical RAM]:memory:' \
  '(-K --kernel)'{-K,--kernel}'[show kernel memory usage]' \
  '(-m --mappings)'{-m,--mappings}'[show mappings]' \
  '(-p --percent)'{-p,--percent}'[show percentages]' \
  '(-k --abbreviate)'{-k,--abbreviate}'[show unit suffixes]' \
  '(-n --numeric)'{-n,--numeric}'[show numeric user IDs]' \
  '(-s --sort)'{-s+,--sort=}'[sort by column]:column:(pid user command swap uss pss rss vss)' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '(-t --totals)'{-t,--totals}'[show totals]' \
  '(-u --users)'{-u,--users}'[show users]' \
  '(-w --system)'{-w,--system}'[show whole system]' \
  '(-P --processfilter)'{-P+,--processfilter=}'[process filter regex]:regex:' \
  '(-M --mapfilter)'{-M+,--mapfilter=}'[mapping filter regex]:regex:' \
  '(-U --userfilter)'{-U+,--userfilter=}'[user filter regex]:regex:' \
  '--pie=[generate pie chart]:column name:' \
  '--bar=[generate bar chart]:column name:' \
  '-S+[source directory]:directory:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
