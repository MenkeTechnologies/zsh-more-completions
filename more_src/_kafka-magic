#compdef kafka-magic
# _kafka-magic — Kafka Magic kafka-magic CLI command-line frontend wrapping the Kafka Magic GUI tool for managing Apache Kafka clusters topics consumers messages JSON Avro Protobuf schemas connections workspaces filter-and-search testing-suites windows-and-cross-platform-CLI-server-mode SSL-SASL-Kerberos-OAuth (Digital Polygon team Roman Cobzar, .NET); custom argparse
# upstream: https://www.kafkamagic.com/

_kafka-magic() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--bootstrap-servers=+[hosts]:_hosts' \
        '-b+[brokers]:_hosts' \
        '--security-protocol=+[p]:p:(PLAINTEXT SSL SASL_PLAINTEXT SASL_SSL)' \
        '--sasl-mechanism=+[m]:m:(PLAIN SCRAM-SHA-256 SCRAM-SHA-512 GSSAPI OAUTHBEARER)' \
        '--sasl-username=+[user]:str:' \
        '--sasl-password=+[password]:str:' \
        '--ssl-ca-location=+[file]:file:_files -g "*.pem *.crt"' \
        '--ssl-certificate-location=+[file]:file:_files -g "*.pem *.crt"' \
        '--ssl-key-location=+[file]:file:_files -g "*.pem *.key"' \
        '--ssl-key-password=+[password]:str:' \
        '--schema-registry=+[url]:str:' \
        '--workspace=+[file]:file:_files -g "*.kmag *.json"' \
        '-w+[file]:file:_files -g "*.kmag *.json"' \
        '--connection=+[name]:str:' \
        '--topic=+[name]:str:' \
        '-t+[topic]:str:' \
        '--filter=+[expr]:str:' \
        '-f+[filter]:str:' \
        '--limit=+[N]:n:' \
        '-n+[N]:n:' \
        '--offset=+[N]:n:' \
        '--from-beginning[from beginning]' \
        '--format=+[fmt]:f:(JSON AVRO PROTOBUF STRING BINARY)' \
        '--output=+[file]:file:_files' \
        '-o+[file]:file:_files' \
        '--server[run in server mode]' \
        '--port=+[port]:n:' \
        '*:args:'
}

_kafka-magic "$@"
