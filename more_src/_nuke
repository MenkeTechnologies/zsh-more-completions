#compdef nuke

# Zsh completion for nuke - AWS Nuke - remove all resources in an AWS account

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to config file]:config:_files -g "*.{yml,yaml}"' \
  '--profile=[AWS profile to use]:profile' \
  '--access-key-id=[AWS access key ID]:key-id' \
  '--secret-access-key=[AWS secret access key]:secret-key' \
  '--session-token=[AWS session token]:token' \
  '--default-region=[default AWS region]:region:(us-east-1 us-east-2 us-west-1 us-west-2 eu-west-1 eu-west-2 eu-west-3 eu-central-1 eu-north-1 ap-southeast-1 ap-southeast-2 ap-northeast-1 ap-northeast-2 ap-south-1 sa-east-1 ca-central-1)' \
  '--no-dry-run[actually delete resources (no dry run)]' \
  '--force[do not ask for confirmation]' \
  '--force-sleep=[seconds to sleep between delete retries]:seconds' \
  '--quiet[suppress output]' \
  '--no-prompt[do not prompt for confirmation]' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
  '--max-wait-retries=[maximum retries for resource deletion]:retries' \
  && ret=0

return ret
