#compdef niri-msg
# Documentation: https://github.com/YaLTeR/niri/wiki/IPC
# niri-msg: communicate with the running niri Wayland compositor over IPC

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[print the response in JSON]' \
  '1:command:((
    outputs\:"list connected outputs"
    workspaces\:"list workspaces"
    windows\:"list open windows"
    layers\:"list layer-shell surfaces"
    keyboard-layouts\:"list configured keyboard layouts"
    focused-output\:"print the focused output"
    focused-window\:"print the focused window"
    pick-window\:"pick a window interactively"
    pick-color\:"pick a color interactively"
    action\:"perform an action"
    output\:"configure an output"
    event-stream\:"continuously print IPC events"
    version\:"print compositor and CLI version"
    request-error\:"print last request error"
    overview-state\:"print overview state"
    casts\:"list active screencasts"
  ))' \
  '*::arg:_default' && ret=0

return ret
