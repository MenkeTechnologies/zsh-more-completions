#compdef act
# _act-bin — Nektos act run GitHub Actions locally (Casey Lee + community, Go); replay GHA workflows in local Docker
# upstream: https://github.com/nektos/act

_act-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-l --list)'{-l,--list}'[list workflows]' \
        '-W+[workflows path]:dir:_files -/' \
        '--workflows+[workflows path]:dir:_files -/' \
        '-C+[change to dir]:dir:_files -/' \
        '--directory+[change to dir]:dir:_files -/' \
        '-j+[job name]:job:' \
        '--job+[job name]:job:' \
        '-r[reuse containers]' \
        '--reuse[reuse containers]' \
        '-n[dry run]' \
        '--dryrun[dry run]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '-e+[event file]:file:_files' \
        '--eventpath+[event file]:file:_files' \
        '-s+[secret]:KEY=VAL:' \
        '--secret+[secret]:KEY=VAL:' \
        '--secret-file+[secret file]:file:_files' \
        '--var-file+[var file]:file:_files' \
        '--vars-file+[vars file]:file:_files' \
        '--var+[var]:KEY=VAL:' \
        '--input+[input]:KEY=VAL:' \
        '--input-file+[input file]:file:_files' \
        '--env+[env]:KEY=VAL:' \
        '--env-file+[env file]:file:_files' \
        '--use-gitignore+[use gitignore]:bool:(true false)' \
        '-w[watch and rerun]' \
        '--watch[watch and rerun]' \
        '-P+[platform image map]:platform=image:' \
        '--platform+[platform image map]:platform=image:' \
        '--reuse[reuse containers]' \
        '--rm[remove containers on exit]' \
        '--container-architecture+[architecture]:arch:(linux/amd64 linux/arm64 linux/arm/v7)' \
        '--container-cap-add+[add capabilities]:caps:' \
        '--container-cap-drop+[drop capabilities]:caps:' \
        '--container-daemon-socket+[docker socket]:file:_files' \
        '--container-options+[docker options]:str:' \
        '--container-tag+[container tag]:tag:' \
        '--detect-event[detect event from git ref]' \
        '--bind+[bind workdir]' \
        '--use-new-action-cache[new action cache]' \
        '--action-cache-path+[action cache path]:dir:_files -/' \
        '--actor+[actor]:str:' \
        '--artifact-server-addr+[artifact server addr]:addr:' \
        '--artifact-server-path+[artifact server path]:dir:_files -/' \
        '--artifact-server-port+[artifact server port]:port:' \
        '--bug-report[create bug report]' \
        '--cache-server-addr+[cache server addr]:addr:' \
        '--cache-server-path+[cache server path]:dir:_files -/' \
        '--cache-server-port+[cache server port]:port:' \
        '--defaultbranch+[default branch]:str:' \
        '--github-instance+[GitHub instance URL]:url:_urls' \
        '--insecure-secrets[allow insecure secrets]' \
        '--json[json output]' \
        '--log-prefix-job-id[log prefix with job id]' \
        '--logout+[output file]:file:_files' \
        '--matrix+[matrix filter]:KEY:VAL:' \
        '--network+[docker network]:network:' \
        '--no-cache-server[no cache server]' \
        '--no-recurse[no recurse]' \
        '--no-skip-checkout[no skip checkout]' \
        '--privileged[privileged]' \
        '--pull[pull image]' \
        '--rebuild[rebuild image]' \
        '--remote-name+[remote name]:name:' \
        '--replace-ghe-action-token-with-github-com+[replace token]:str:' \
        '--replace-ghe-action-with-github-com+[replace action]:str:' \
        '--userns+[userns]:str:' \
        '*:event:'
}

_act-bin "$@"
