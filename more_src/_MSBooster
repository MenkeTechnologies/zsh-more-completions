#compdef MSBooster
# Documentation: https://github.com/Nesvilab/MSBooster/blob/master/README.md
# MSBooster: add deep-learning features to .pin files for PSM rescoring

local ret=1

_arguments -s -S \
  '--paramsList[file listing one parameter per line]:file:_files' \
  '--DiaNN[path to the DIA-NN executable]:path:_files' \
  '--mzmlDirectory[path(s) to mzML/mgf files]:path:_files' \
  '--pinPepXMLDirectory[path(s) to pin files]:path:_files' \
  '--fragger[path to the fragger.params file]:file:_files' \
  '--outputDirectory[output directory]:dir:_files -/' \
  '--editedPin[base name for edited pin output]:name:' \
  '--renamePin[rename pin files (0/1)]:flag:(0 1)' \
  '--deletePreds[delete prediction files after run]:flag:(0 1)' \
  '--loadingPercent[fraction of data to load]:f:' \
  '--numThreads[number of threads]:n:' \
  '--splitPredInputFile[split prediction input file into N parts]:n:' \
  '--plotExtension[extension for output plots]:ext:' \
  '--features[comma-separated list of features to add]:features:' \
  '--spectraPredFile[load a precomputed spectra prediction file]:file:_files' \
  '--RTPredFile[load a precomputed RT prediction file]:file:_files' \
  '--IMPredFile[load a precomputed IM prediction file]:file:_files' \
  '--spectraModel[spectra prediction model]:model:' \
  '--rtModel[RT prediction model]:model:' \
  '--imModel[IM prediction model]:model:' \
  '--useSpectra[use spectral similarity features (0/1)]:flag:(0 1)' \
  '--useRT[use RT features (0/1)]:flag:(0 1)' \
  '--useIM[use IM features (0/1)]:flag:(0 1)' \
  '--ppmTolerance[fragment match ppm tolerance]:ppm:' \
  '--matchWithDaltons[match fragments in Daltons (0/1)]:flag:(0 1)' \
  '--DaTolerance[fragment match tolerance in Da]:da:' \
  '--useTopFragments[use only top fragments (0/1)]:flag:(0 1)' \
  '--topFragments[number of top fragments to use]:n:' \
  '--useBasePeak[filter by base peak intensity (0/1)]:flag:(0 1)' \
  '--percentBasePeak[base peak intensity percentage cutoff]:pct:' \
  '*:pin file:_files' && ret=0

return ret
