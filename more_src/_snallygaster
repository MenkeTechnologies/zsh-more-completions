#compdef snallygaster
# Documentation: https://github.com/hannob/snallygaster
# tool to scan for secret files on HTTP servers and find file leaks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --tests)'{-t,--tests}'+[comma-separated tests to run]:tests' \
  '--useragent=[user agent to send]:ua' \
  '--nowww[skip scanning www.[host]]' \
  '--nohttp[do not scan http]' \
  '--nohttps[do not scan https]' \
  '(-i --info)'{-i,--info}'[enable all info tests (no security vulnerabilities)]' \
  '(-n --noisy)'{-n,--noisy}'[show noisy messages indicating boring bugs]' \
  '(-p --path)'{-p,--path}'+[base path on server]:path' \
  '(-j --json)'{-j,--json}'[produce JSON output]' \
  '(-d --debug)'{-d,--debug}'[show detailed debugging info]' \
  '*:host:_hosts' && ret=0

return ret
