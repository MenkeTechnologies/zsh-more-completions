#compdef 3dTproject
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTproject.html
# AFNI project out nuisance time series and bandpass for resting-state fMRI

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-input[input dataset]:dataset:_files' \
  '-prefix[output dataset name]:prefix' \
  '-censor[censoring file]:file:_files' \
  '-CENSORTR[censoring time range list]:clist' \
  '-cenmode[treatment of censored timepoints]:mode:(ZERO KILL NTRP)' \
  '-concat[concatenation file with run start indexes]:file:_files' \
  '-noblock[treat auto-catenated dataset as one run]' \
  '*-ort[remove columns from a 1D file]:file:_files' \
  '-polort[remove polynomials up to degree]:degree' \
  '-dsort[remove 3D+time nuisance series per voxel]:dataset:_files' \
  '(-passband -bandpass)'{-passband,-bandpass}'[retain frequencies in range]:fbot' \
  '*-stopband[remove frequencies in range]:fbot' \
  '(-dt -TR)'{-dt,-TR}'[time step for frequency calculations]:tr' \
  '-mask[operate on nonzero voxels in mask]:dataset:_files' \
  '-automask[generate mask automatically]' \
  '-blur[spatial filtering FWHM]:fwhm' \
  '-norm[normalize output to sum-of-squares = 1]' \
  '-quiet[suppress progress messages]' \
  '-verb[save regressor matrix, detailed output]' \
  '*:dataset:_files' && ret=0

return ret
