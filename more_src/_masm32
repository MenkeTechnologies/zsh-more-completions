#compdef masm32

# MASM32: Microsoft Macro Assembler (32-bit Windows SDK)
# Documentation: https://learn.microsoft.com/en-us/cpp/assembler/masm/ml-and-ml64-command-line-reference
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)/?[show help]' \
  '/c[compile only]' \
  '/Fo[output object file]:file:_files' \
  '/Fl[listing file]:file:_files' \
  '/I[include path]:dir:_files -/' \
  '/D[predefine symbol]:symbol:' \
  '/coff[generate COFF]' \
  '/W[warning level]:n:(0 1 2 3)' \
  '/Zd[line numbers]' \
  '/Zf[set FS to current]' \
  '/Zi[symbolic debug info]' \
  '/Sa[max syntax]' \
  '/Cp[case-preserve]' \
  '/Cu[upper case syms]' \
  '/Cx[lower case syms]' \
  '*:source file:_files -g "*.asm"' && ret=0
return ret
