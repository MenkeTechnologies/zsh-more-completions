#compdef cliclick

# macOS UI automation — github.com/BlueM/cliclick README “USAGE”

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'-h'[help]' \
  '-r[restore mouse position when finished]' \
  '-m[mode]:mode:(verbose test)' \
  '-d[print target for p: cmd]:target:(stdout stderr clipboard)' \
  '-e[easing factor]:factor' \
  '-f[commands file]:file:_files' \
  '-w[wait ms after each event]:milliseconds' \
  '-V[show version]' \
  '-o[open version history in browser]' \
  '-n[donation info]' \
  '*:: :_message -e "cliclick action (see -h; e.g. c:x,y)"' && ret=0

return ret
