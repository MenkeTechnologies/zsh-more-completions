#compdef cliclick
# Documentation: https://github.com/BlueM/cliclick
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# macOS UI automation tool.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-r[restore initial mouse location when finished]' \
  '-m[mode]:mode:(verbose test)' \
  '-d[target for p (print) command]:target:(stdout stderr clipboard)' \
  '-e[easing factor for mouse movements]:factor' \
  '-f[read commands from file (- for stdin)]:file:_files' \
  '-w[wait ms after each event (min 20)]:milliseconds' \
  '-V[show version number and release date]' \
  '-o[open version history in browser]' \
  '-n[send a donation]' \
  '-h[show help]' \
  '*:: :_message -e "cliclick action (e.g. c:x,y)"' && ret=0

return ret
