#compdef acedrg
# Documentation: https://www2.mrc-lmb.cam.ac.uk/groups/murshudov/content/acedrg/acedrg.html
# CCP4 acedrg: generate ligand coordinates and restraint dictionaries

local ret=1

_arguments -s -S \
  '-h[show help manual]' \
  '(-v --version)'{-v,--version}'[print version number]' \
  '(-c --mmcif)'{-c+,--mmcif=}'[input mmCIF file]:file:_files' \
  '(-i --smi)'{-i+,--smi=}'[input SMILES string or file]:smiles:' \
  '(-m --mol)'{-m+,--mol=}'[input MDL MOL file]:file:_files' \
  '(-g --mol2)'{-g+,--mol2=}'[input SYBYL MOL2 file]:file:_files' \
  '(-L --linkInstruction)'{-L+,--linkInstruction=}'[covalent link instruction file]:file:_files' \
  '(-o --out)'{-o+,--out=}'[output filename root]:root:' \
  '(-r --res)'{-r+,--res=}'[output 3-letter monomer name]:name:' \
  '-p[use coordinates from input file]' \
  '-K[keep input protonation state]' \
  '-j+[generate n conformers, output lowest energy]:n:' \
  '-k+[generate n conformers, output all]:n:' \
  '-l+[RDKit optimization steps]:n:' \
  '-n[generate atom types output]' \
  '*:file:_files' && ret=0

return ret
