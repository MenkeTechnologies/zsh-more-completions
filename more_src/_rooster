#compdef rooster

# https://github.com/conradkleinespel/rooster — src/lib.rs Command::new subcommands

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _rook_cmds
    _rook_cmds=(
      init add change delete generate regenerate get rename transfer list import export 'set-master-password' 'set-scrypt-params'
    )
    _describe -t commands 'rooster command' _rook_cmds && ret=0
    ;;
esac

return ret
