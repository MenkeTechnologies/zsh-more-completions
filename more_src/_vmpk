#compdef vmpk
# _vmpk — Virtual MIDI Piano Keyboard (pedrolcl/vmpk)
# upstream: https://github.com/pedrolcl/vmpk
# Flags from src/main.cpp (QCommandLineParser).

_vmpk() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --portable)'{-p,--portable}'[portable settings mode]' \
        '(-f --file)'{-f+,--file=}'[portable settings file name]:file:_files'
}

_vmpk "$@"
