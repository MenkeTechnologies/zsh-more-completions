#compdef kopia-cli2

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'benchmark:run benchmarks'
  'blob:low-level blob storage commands'
  'cache:cache management'
  'completion:print shell completion'
  'content:low-level content commands'
  'diff:diff two snapshots'
  'help:show help'
  'index:repo index commands'
  'logs:logs management'
  'maintenance:maintenance tasks'
  'manifest:manifest management'
  'mount:mount snapshots as FUSE'
  'notification:notifications'
  'policy:policy commands'
  'repository:repository commands'
  'restore:restore from snapshot'
  'server:start a Kopia server'
  'session:show sessions'
  'show:print object contents'
  'snapshot:snapshot commands'
  'theme:UI theme commands'
  'whitelist:whitelisted snapshots'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--config-file=[file]:file:_files' \
  '*--auto-maintenance=[auto maintenance]:b:(true false)' \
  '*--cache-directory=[dir]:dir:_files -/' \
  '*--enable-actions[enable actions]' \
  '*--file-log-level=[level]:l:(error warning info debug)' \
  '*--log-dir=[dir]:dir:_files -/' \
  '*--log-dir-max-files=[n]:n:' \
  '*--log-dir-max-age=[duration]:t:' \
  '*--log-level=[level]:l:(error warning info debug)' \
  '*--metrics-listen-addr=[addr]:a:' \
  '*--no-update-check[no update check]' \
  '*--password=[password]:p:' \
  '*--persist-credentials=[persist creds]:b:(true false)' \
  '*--profile-dir=[dir]:dir:_files -/' \
  '*--repo-cmd-prefix=[prefix]:p:' \
  '*--user-cache-directory=[dir]:dir:_files -/' \
  '*-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kopia command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (snapshot)
        _arguments \
          '1:subcommand:(create delete estimate expire fix gc list migrate pin restore verify)' \
          '*: :_files' && ret=0 ;;
      (restore)
        _arguments \
          '(--ignore-errors)--ignore-errors[ignore errors]' \
          '(--ignore-permission-errors)--ignore-permission-errors[ignore perm errors]' \
          '(--no-overwrite-files)--no-overwrite-files[no overwrite]' \
          '(--no-overwrite-directories)--no-overwrite-directories[no overwrite dirs]' \
          '(--no-overwrite-symlinks)--no-overwrite-symlinks[no overwrite symlinks]' \
          '(--write-files-atomically)--write-files-atomically[atomic writes]' \
          '(--mode)--mode=[mode]:m:(auto local-fs zip tar)' \
          '(--shallow)--shallow=[depth]:n:' \
          '(--skip-existing)--skip-existing[skip existing]' \
          '(--skip-owners)--skip-owners[skip owners]' \
          '(--skip-permissions)--skip-permissions[skip perms]' \
          '(--skip-times)--skip-times[skip times]' \
          '(--sparse)--sparse[restore sparse]' \
          '(--write-sparse-files)--write-sparse-files[write sparse]' \
          '(--parallel)--parallel=[n]:n:' \
          '(--ignore-symlink-errors)--ignore-symlink-errors[ignore symlink errors]' \
          '(--restore-dir-entry-at-depth)--restore-dir-entry-at-depth=[n]:n:' \
          '(--min-size-for-placeholder)--min-size-for-placeholder=[bytes]:n:' \
          '*: :_files' && ret=0 ;;
      (repository)
        _arguments \
          '1:subcommand:(connect create disconnect list-blobs list-shards repair set-client set-parameters status sync throttle upgrade validate-provider)' \
          '*: :' && ret=0 ;;
      (policy)
        _arguments \
          '1:subcommand:(delete edit export import list set show)' \
          '*: :' && ret=0 ;;
      (server)
        _arguments \
          '1:subcommand:(acl cancel flush pause refresh resume shutdown start status throttle user)' \
          '*: :' && ret=0 ;;
      (mount)
        _arguments \
          '(--browse)--browse[open browser]' \
          '(--no-traverse-mounts)--no-traverse-mounts[no traverse]' \
          '(--readonly)--readonly[readonly]' \
          '*: :_files -/' && ret=0 ;;
      (maintenance)
        _arguments \
          '1:subcommand:(info run set)' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(clear info set sync)' \
          '*: :' && ret=0 ;;
      (benchmark)
        _arguments \
          '1:subcommand:(compression crypto encryption hashing splitter)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
