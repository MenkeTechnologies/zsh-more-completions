#compdef yunohost
# Documentation: https://man.archlinux.org/search?q=yunohost
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a categories

categories=(
  'user:user management'
  'domain:domain management'
  'app:app management'
  'backup:backup operations'
  'settings:server settings'
  'service:service management'
  'firewall:firewall config'
  'dyndns:dynamic DNS'
  'tools:server tools'
  'hook:hooks'
  'log:operation logs'
  'diagnosis:diagnosis'
  'storage:storage'
)

_arguments -C \
  '--output-as=[format]:fmt:(json plain none)' \
  '--debug[debug]' \
  '--quiet[quiet]' \
  '--version[show version]' \
  '--timeout=[seconds]:n:' \
  '--plain[plain output]' \
  '--json[JSON output]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->category' \
  '*::arg:->args' && ret=0

case $state in
  (category) _describe -t cats 'yunohost category' categories && ret=0 ;;
esac

return ret
