#compdef supabase-cli2 supabase2
# _supabase-cli2 — Supabase supabase-cli2 CLI command-line frontend wrapping the Supabase CLI open-source Firebase alternative tool for developing and deploying Supabase projects locally and in CI written in Go and TypeScript provides local dev environment build deploy database functions migration migration-new migration-up migration-list migration-repair migration-squash storage secrets domains config link init login logout projects organizations status start stop restart serve auth realtime postgrest pgbouncer studio inspect lint cleanup network bans dump-data shell snippets test (Supabase team Paul Copplestone Ant Wilson Andrew Burrows, Go/TypeScript); cobra
# upstream: https://supabase.com/

_supabase-cli2() {
    local -a sub=(
        'bootstrap:bootstrap a project'
        'branches:branch operations'
        'completion:generate shell completion'
        'config:config operations'
        'db:database operations'
        'deploy:deploy operations'
        'domains:domain operations'
        'functions:Edge Functions ops'
        'gen:generate types'
        'help:show help'
        'init:initialize project'
        'inspect:inspect a project'
        'link:link to a project'
        'login:authenticate'
        'logout:revoke session'
        'migration:migration ops'
        'network-bans:network bans ops'
        'network-restrictions:network restrictions ops'
        'orgs:organization operations'
        'postgres-config:Postgres config ops'
        'projects:project operations'
        'restrictions:project restrictions'
        'secrets:secret operations'
        'services:show service versions'
        'snippets:SQL snippet ops'
        'sso:SSO operations'
        'start:start local dev'
        'status:show local status'
        'stop:stop local dev'
        'storage:storage operations'
        'test:run tests'
        'unlink:unlink current project'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--workdir=+[dir]:dir:_files -/' \
        '--experimental[experimental features]' \
        '--no-color[no color]' \
        '-y[yes/skip prompts]' \
        '--yes[yes]' \
        '--token=+[token]:str:' \
        '-t+[token]:str:' \
        '--project-ref=+[ref]:str:' \
        '-p+[project ref]:str:' \
        '--db-url=+[url]:str:' \
        '--password=+[password]:str:' \
        '--linked[linked project]' \
        '--local[local]' \
        '--include-all[include all]' \
        '--data-only[data only]' \
        '--schema=+[schemas]:str:' \
        '*--schema=+[schemas]:str:' \
        '--use-copy[use COPY]' \
        '--use-migra[use migra]' \
        '--use-pg-schema[use pg schema]' \
        '--file=+[file]:file:_files -g "*.sql *.toml"' \
        '-f+[file]:file:_files -g "*.sql *.toml"' \
        '--message=+[text]:str:' \
        '-m+[message]:str:' \
        '--from=+[file]:file:_files' \
        '--to=+[file]:file:_files' \
        '--no-verify-jwt[no verify JWT]' \
        '--import-map=+[file]:file:_files -g "import_map.json *.json"' \
        '--region=+[r]:str:' \
        '--port=+[port]:n:' \
        '--env-file=+[file]:file:_files -g ".env*"' \
        '--config=+[file]:file:_files -g "config.toml *.toml"' \
        '-c+[config]:file:_files -g "config.toml *.toml"' \
        '--exclude=+[services]:str:' \
        '-x+[exclude]:str:' \
        '--no-backup[no backup]' \
        '--no-seed[no seed]' \
        '--ignore-health-check[ignore health check]' \
        '--ignore-security-advisor[ignore advisor]' \
        '--output=+[fmt]:f:(env json yaml toml pretty)' \
        '-o+[output]:f:(env json yaml toml pretty)' \
        '--dry-run[dry run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'supabase subcommand' sub ;;
        args)
            case $words[1] in
                db) _arguments '1:op:(diff push reset start dump lint pull diff:from execute remote)' '*:arg:' ;;
                migration) _arguments '1:op:(new list up down repair squash fetch)' '*:arg:' ;;
                functions) _arguments '1:op:(new serve deploy delete list download)' '*:name:' ;;
                projects|orgs|secrets|domains|storage|snippets|branches|sso|services) _arguments '1:op:(list create delete update get apply remove)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_supabase-cli2 "$@"
