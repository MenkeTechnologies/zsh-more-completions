#compdef dbmate
# Documentation: https://github.com/amacneil/dbmate
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dbmate (database migration tool)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'new:generate a new migration file'
  'up:create database and run pending migrations'
  'create:create the database'
  'drop:drop the database'
  'migrate:migrate the database to the latest version'
  'rollback:rollback the most recent migration'
  'down:alias for rollback'
  'status:show the status of all migrations'
  'dump:write the database schema to disk'
  'load:load schema.sql into database'
  'wait:wait for the database to become available'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --migrations-dir)'{-d,--migrations-dir}'[specify migrations directory]:directory:_directories' \
  '(-e --env)'{-e,--env}'[environment variable for database URL]:env var:(DATABASE_URL)' \
  '--env-file=[alternate env file(s)]:file:_files' \
  '(-s --schema-file)'{-s,--schema-file}'[specify schema file path]:schema file:_files' \
  '(-u --url)'{-u,--url}'[specify the database URL directly]:url:' \
  '--driver=[explicit driver]:driver:' \
  '--migrations-table=[migrations tracking table]:table:' \
  '--no-dump-schema[do not update the schema file on migrate/rollback]' \
  '--strict[fail if migrations apply out of order]' \
  '--wait[wait for the database to become available]' \
  '--wait-timeout=[timeout for --wait]:duration:' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'dbmate command' subcommands && ret=0
    fi
    ;;
esac

return ret
