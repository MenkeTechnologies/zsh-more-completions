#compdef dbmate

# Zsh completion for dbmate (database migration tool)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'create:create the database'
  'drop:drop the database'
  'migrate:migrate the database to the latest version'
  'rollback:rollback the most recent migration'
  'up:create and migrate the database'
  'status:show the status of all migrations'
  'dump:write the database schema to disk'
  'new:generate a new migration file'
  'wait:wait for the database to become available'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --migrations-dir)'{-d,--migrations-dir}'[specify migrations directory]:directory:_directories' \
  '(-e --env)'{-e,--env}'[specify environment variable for database URL]:env var:(DATABASE_URL)' \
  '(-s --schema-file)'{-s,--schema-file}'[specify schema file path]:schema file:_files' \
  '(-u --url)'{-u,--url}'[specify the database URL directly]:url:' \
  '--no-dump-schema[do not update the schema file on migrate/rollback]' \
  '--wait[wait for the database to become available]' \
  '--wait-timeout[timeout in seconds for --wait]:seconds:' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'dbmate command' subcommands && ret=0
    fi
    ;;
esac

return ret
