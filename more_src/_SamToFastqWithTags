#compdef SamToFastqWithTags
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/SamToFastqWithTags.java
# Picard: converts a SAM/BAM/CRAM to FASTQ, extracting tag values into additional FASTQs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM/CRAM file]:file:_files' \
  '*'{-STG,--SEQUENCE_TAG_GROUP}'=[comma separated tags used as read sequence]:s:' \
  '*'{-QTG,--QUALITY_TAG_GROUP}'=[comma separated tags used as read qualities]:s:' \
  '*'{-SEP,--TAG_GROUP_SEPERATOR}'=[sequences to insert between tag groups]:s:' \
  '(-GZOPTG --COMPRESS_OUTPUTS_PER_TAG_GROUP)'{-GZOPTG,--COMPRESS_OUTPUTS_PER_TAG_GROUP}'=[gzip output FASTQ files per tag group]:b:(true false)' \
  '(-F --FASTQ)'{-F,--FASTQ}'=[output FASTQ file]:file:_files' \
  '(-F2 --SECOND_END_FASTQ)'{-F2,--SECOND_END_FASTQ}'=[output FASTQ for second end of pairs]:file:_files' \
  '(-FU --UNPAIRED_FASTQ)'{-FU,--UNPAIRED_FASTQ}'=[output FASTQ for unpaired reads]:file:_files' \
  '(-ODIR --OUTPUT_DIR)'{-ODIR,--OUTPUT_DIR}'=[directory for output FASTQ files]:dir:_files -/' \
  '(-OPRG --OUTPUT_PER_RG)'{-OPRG,--OUTPUT_PER_RG}'=[output a FASTQ per read group]:b:(true false)' \
  '(-GZOPRG --COMPRESS_OUTPUTS_PER_RG)'{-GZOPRG,--COMPRESS_OUTPUTS_PER_RG}'=[gzip output FASTQ files per read group]:b:(true false)' \
  '(-RGT --RG_TAG)'{-RGT,--RG_TAG}'=[read group tag to use for per-RG output]:s:' \
  '(-RC --RE_REVERSE)'{-RC,--RE_REVERSE}'=[re-reverse bases and qualities of reverse-strand reads]:b:(true false)' \
  '(-INTER --INTERLEAVE)'{-INTER,--INTERLEAVE}'=[interleave paired reads into a single FASTQ]:b:(true false)' \
  '(-NON_PF --INCLUDE_NON_PF_READS)'{-NON_PF,--INCLUDE_NON_PF_READS}'=[include reads failing quality filter]:b:(true false)' \
  '(-CLIP_ATTR --CLIPPING_ATTRIBUTE)'{-CLIP_ATTR,--CLIPPING_ATTRIBUTE}'=[tag marking clipping point]:s:' \
  '(-CLIP_ACT --CLIPPING_ACTION)'{-CLIP_ACT,--CLIPPING_ACTION}'=[action to take on clipped bases]:s:' \
  '(-CLIP_MIN --CLIPPING_MIN_LENGTH)'{-CLIP_MIN,--CLIPPING_MIN_LENGTH}'=[min read length after clipping]:n:' \
  '(-R1_TRIM --READ1_TRIM)'{-R1_TRIM,--READ1_TRIM}'=[bases to trim from start of read 1]:n:' \
  '(-R1_MAX_BASES --READ1_MAX_BASES_TO_WRITE)'{-R1_MAX_BASES,--READ1_MAX_BASES_TO_WRITE}'=[max bases to write for read 1]:n:' \
  '(-R2_TRIM --READ2_TRIM)'{-R2_TRIM,--READ2_TRIM}'=[bases to trim from start of read 2]:n:' \
  '(-R2_MAX_BASES --READ2_MAX_BASES_TO_WRITE)'{-R2_MAX_BASES,--READ2_MAX_BASES_TO_WRITE}'=[max bases to write for read 2]:n:' \
  '(-Q --QUALITY)'{-Q,--QUALITY}'=[end-trimming quality threshold]:n:' \
  '--INCLUDE_NON_PRIMARY_ALIGNMENTS=[include non-primary alignments]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
