#compdef sbomgr
# grep-style search across SBOMs by name, CPE, PURL or checksum (interlynk-io)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((packages\:"search SBOM files for package information"))' \
  '(-N --name)'{-N,--name}'[locate packages by name]' \
  '(-C --cpe)'{-C,--cpe}'[find components by CPE value]' \
  '(-P --purl)'{-P,--purl}'[search packages by PURL identifier]' \
  '(-H --checksum)'{-H,--checksum}'[identify packages by checksum]' \
  '(-E --extended-regexp)'{-E,--extended-regexp}'[enable RE2 regular-expression matching]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive search]' \
  '(-l --license)'{-l,--license}'[include package licensing details]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output; exit 0 on match]' \
  '--no-filename[remove file paths from output]' \
  '(-j --jsonl)'{-j,--jsonl}'[format results as JSON Lines]' \
  '(-p --print-errors)'{-p,--print-errors}'[display errors encountered during searches]' \
  '(-O --output-format)'{-O,--output-format}'[customize output tokens]:format:' \
  '(-c --count)'{-c,--count}'[show matching counts instead of detail]' \
  '(-r --recurse)'{-r,--recurse}'[recursively search subdirectories]' \
  '--spdx[search only SPDX format files]' \
  '--cdx[search only CycloneDX format files]' \
  '*:sbom path:_files' && ret=0

return ret
