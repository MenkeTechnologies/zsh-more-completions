#compdef dsnet
# Documentation: https://github.com/naggie/dsnet
# dsnet - manage a WireGuard VPN with a single config file

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--output=[output config file format]:format:(wg-quick vyatta nixos)' \
  '1:command:(add down help init regenerate remove report sync up version)' \
  '*::arg:->args' && ret=0

return ret
