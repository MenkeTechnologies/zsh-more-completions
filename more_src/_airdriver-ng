#compdef airdriver-ng
# _airdriver-ng — aircrack-ng airdriver-ng wireless driver loader CLI for installing patching loading and unloading 802.11 monitor-mode drivers ath9k iwlwifi rtl8812au rtl8814au mt7601u on Linux (aircrack-ng team, Bash); getopt
# upstream: https://github.com/aircrack-ng/aircrack-ng

_airdriver-ng() {
    local -a sub=(
        'install:install driver'
        'remove:remove driver'
        'reinstall:reinstall driver'
        'load:load driver'
        'unload:unload driver'
        'detect:detect chipset'
        'list:list supported drivers'
        'patch:patch kernel driver'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-f[force]' \
        '--force[force]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '-d+[driver dir]:dir:_files -/' \
        '--driver-dir=+[driver dir]:dir:_files -/' \
        '-k+[kernel version]:str:' \
        '--kernel=+[kernel version]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'airdriver-ng subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|reinstall|load|unload|patch) _arguments \
                    '*:driver:(ath9k_htc ath5k ath9k iwlwifi rtl8187 rtl8812au rtl8814au rtl8821au mt7601u mt7610u mt7612u carl9170 b43 b43legacy r8723bs rt2800usb p54usb mwifiex mac80211_hwsim)' ;;
            esac
            ;;
    esac
}

_airdriver-ng "$@"
