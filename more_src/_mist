#compdef mist
# Documentation: https://github.com/ninxsoft/mist-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list all macOS firmwares/installers available to download'
  'download:download a macOS firmware/installer'
  'version:display the version of mist'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'mist command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '--compatible[only list compatible installers]' \
          '--include-betas[include beta releases]' \
          '--latest[only list the latest release]' \
          '--export=[export list path]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
      (download)
        _arguments \
          '--firmware-name=[custom firmware filename]:name' \
          '--application-name=[custom application name]:name' \
          '--image-name=[custom disk image name]:name' \
          '--iso-name=[custom ISO name]:name' \
          '--package-name=[custom package name]:name' \
          '--image-signing-identity=[code signing identity for disk image]:identity' \
          '--package-signing-identity=[code signing identity for package]:identity' \
          '--output-directory=[output directory]:dir:_files -/' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:type and name:' && ret=0 ;;
    esac ;;
esac

return ret
