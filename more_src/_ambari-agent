#compdef ambari-agent
# _ambari-agent — Apache Ambari ambari-agent (per-host management agent registering with ambari-server(8) over HTTPS and running stack-specific scripts; subcommands: start, stop, restart, status, reset; --verbose, --debug, --silent print extra detail during init / restart cycles)
# upstream: https://github.com/apache/ambari
# Subcommands from ambari/ambari-agent/etc/init.d/ambari-agent on tip.

_ambari-agent() {
    _arguments \
        '--help[show help]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '1:command:(start stop restart status reset)' \
        '*::arg:'
}

_ambari-agent "$@"
