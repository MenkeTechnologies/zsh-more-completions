#compdef node_separator
# Documentation: https://arxiv.org/pdf/1311.1714
# KaHIP: compute a 2-way vertex separator of a graph

local ret=1

_arguments -s \
  '--help[print help]' \
  '--imbalance=[desired balance in percent (default 20)]:double' \
  '--seed=[seed for the random number generator]:int' \
  '--preconfiguration=[use a preconfiguration]:variant:(strong eco fast fastsocial ecosocial strongsocial)' \
  '--output_filename=[output filename (default tmpseparator)]:file:_files' \
  '*:graph file:_files' && ret=0

return ret
