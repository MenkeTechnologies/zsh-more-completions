#compdef authorindex
# Documentation: authorindex -h (TeX Live 2026)
# Source: extract author citations from LaTeX .aux + BibTeX into a back-of-the-book index.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help and exit]' \
    '-d[generate additional statistical comments]' \
    '-i[generate .ain file for makeindex input]' \
    '-k[keep auxiliary bibliography style file _autidx_.bst]' \
    '-r[suppress automatic inclusion of \\include-ed .aux files]' \
    '-p[send result to standard output]' \
    '*:aux file:_files -g "*.aux"' \
    && ret=0

return ret
