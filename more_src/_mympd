#compdef mympd
# Documentation: https://man.archlinux.org/man/mympd.1.en
# standalone and lightweight web-based MPD client

local ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[create config and ssl certificates and exit]' \
  '(-d --dump)'{-d,--dump}'[dump default config and exit]' \
  '(-h --help)'{-h,--help}'[print all valid options and exit]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-p --pin)'{-p,--pin}'[set a pin for myMPD settings]:pin' \
  '(-s --syslog)'{-s,--syslog}'[enable syslog logging]' \
  '(-w --workdir)'{-w,--workdir}'[working directory]:dir:_files -/' \
  '(-a --cachedir)'{-a,--cachedir}'[cache directory]:dir:_files -/' && ret=0

return ret
