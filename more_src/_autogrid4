#compdef autogrid4
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/autogrid4.1.html
# autogrid4 - precalculate atomic affinity grid maps for AutoDock.

local ret=1

_arguments -s -S \
  '(-u -h)'{-u,-h}'[usage information]' \
  '-p+[grid parameter file (.gpf)]:file:_files' \
  '-l+[log file (.glg)]:file:_files' \
  '-o[use old PDBQ format, charge q in columns 55-61]' \
  '-d[increased verbosity for debugging]' \
  '*:file:_files' && ret=0

return ret
