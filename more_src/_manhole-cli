#compdef manhole-cli
# _manhole-cli — connect to a running Python manhole (ionelmc/python-manhole)
# upstream: https://github.com/ionelmc/python-manhole
# Flags from src/manhole/cli.py (argparse).

_manhole-cli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-t --timeout)'{-t+,--timeout=}'[connection timeout (seconds)]:seconds:' \
        '(-1 -USR1 -2 -USR2 -s --signal)-1[send SIGUSR1 before connecting]' \
        '(-1 -USR1 -2 -USR2 -s --signal)-USR1[send SIGUSR1 before connecting]' \
        '(-1 -USR1 -2 -USR2 -s --signal)-2[send SIGUSR2 before connecting]' \
        '(-1 -USR1 -2 -USR2 -s --signal)-USR2[send SIGUSR2 before connecting]' \
        '(-1 -USR1 -2 -USR2 -s --signal)'{-s+,--signal=}'[send signal before connecting]:signal:' \
        '1:PID or /tmp/manhole-PID:_pids'
}

_manhole-cli "$@"
