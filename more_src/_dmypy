#compdef dmypy

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--status-file[status file to track daemon]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'start:start daemon'
      'stop:stop daemon'
      'status:show daemon status'
      'check:check files'
      'run:check files (alias for check)'
      'recheck:recheck files'
      'suggest:suggest function signatures'
      'kill:kill daemon'
      'daemon:run daemon in foreground'
      'inspect:inspect internal state'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--log-file[log file for daemon]:file:_files' \
          '--timeout[daemon timeout in seconds]:seconds' \
          '--status-file[status file]:file:_files' \
          '--fswatcher-report-threshold[threshold for filesystem watcher report]:threshold' \
          '*:file:_files' && ret=0
        ;;
      stop|kill)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      check|run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--junit-xml[write junit XML report]:file:_files' \
          '--perf-stats-file[write performance stats]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      recheck)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--junit-xml[write junit XML report]:file:_files' \
          '--perf-stats-file[write performance stats]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      suggest)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      daemon)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--log-file[log file for daemon]:file:_files' \
          '--timeout[daemon timeout in seconds]:seconds' \
          '--status-file[status file]:file:_files' \
          '--fswatcher-report-threshold[threshold for filesystem watcher report]:threshold' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
