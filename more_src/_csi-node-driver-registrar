#compdef csi-node-driver-registrar node-driver-registrar
# _csi-node-driver-registrar — Kubernetes CSI per-node kubelet plugin registrar (kubernetes-csi/node-driver-registrar)
# upstream: https://github.com/kubernetes-csi/node-driver-registrar
# Flags from cmd/csi-node-driver-registrar/main.go on tip.

_csi-node-driver-registrar() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--csi-address=[CSI driver UDS path]:path:_files' \
        '--plugin-registration-path=[kubelet plugin registration dir]:dir:_files -/' \
        '--kubelet-registration-path=[CSI socket path as seen from the kubelet host]:path:_files' \
        '--timeout=[CSI driver RPC timeout]:dur:' \
        '--health-port=[(deprecated) healthz TCP port (0 disables)]:port:' \
        '--http-endpoint=[diagnostics/healthz HTTP host\:port]:host\:port:' \
        '--enable-pprof[expose pprof on --http-endpoint]' \
        '--mode=[(deprecated) special modes]:mode:(kubelet-registration-probe)' \
        '-v[klog verbosity level]:n:'
}

_csi-node-driver-registrar "$@"
