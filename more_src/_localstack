#compdef localstack

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-p --profile)'{-p,--profile}'[configuration profile]:profile' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'config:manage configuration'
      'start:start LocalStack'
      'stop:stop LocalStack'
      'status:show status'
      'restart:restart LocalStack'
      'logs:show logs'
      'wait:wait for LocalStack to be ready'
      'ssh:SSH into LocalStack container'
      'update:update LocalStack'
      'pod:manage cloud pods'
      'extensions:manage extensions'
      'dns:manage DNS server'
      'auth:manage authentication'
      'state:manage state'
      'login:log in to LocalStack'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-d --detached)'{-d,--detached}'[start in background]' \
          '--docker[use Docker mode]' \
          '--host[use host mode]' \
          '--no-banner[disable banner]' \
          '--network[docker network]:network' \
          '--volume[mount volume]:volume' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      status)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(services docker)' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-f --follow)'{-f,--follow}'[follow log output]' && ret=0
        ;;
      wait)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds' && ret=0
        ;;
      pod)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->pod_cmds' && ret=0
        case "$state" in
          pod_cmds)
            local -a pod_commands=(
              'save:save a cloud pod'
              'load:load a cloud pod'
              'delete:delete a cloud pod'
              'list:list cloud pods'
              'inspect:inspect a cloud pod'
              'versions:list pod versions'
            )
            _describe -t commands 'pod command' pod_commands && ret=0
            ;;
        esac
        ;;
      config)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(show validate)' && ret=0
        ;;
      extensions)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(init install list)' && ret=0
        ;;
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout token set-token)' && ret=0
        ;;
    esac
    ;;
esac

return ret
