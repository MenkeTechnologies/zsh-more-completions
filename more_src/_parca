#compdef parca
# Documentation: https://github.com/parca-dev/parca/blob/main/pkg/parca/parca.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Parca - continuous profiling

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config-path=[config file path]:config:_files -g "*.{yaml,yml}"' \
  '--mode=[operating mode]:mode:(all scraper)' \
  '--http-address=[HTTP listen address]:address' \
  '--http-read-timeout=[HTTP read timeout]:duration' \
  '--http-write-timeout=[HTTP write timeout]:duration' \
  '--port=[HTTP port]:port' \
  '--path-prefix=[UI path prefix]:prefix' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:format:(logfmt json)' \
  '--cors-allowed-origins=[CORS allowed origins]:origins' \
  '--storage-active-memory=[active memory for storage]:bytes' \
  '--storage-path=[path for storage]:path:_directories' \
  '--enable-persistence[enable persistent storage]' \
  '--store-address=[remote store address]:address' \
  '--bearer-token=[bearer token for remote store]:token' \
  '--bearer-token-file=[bearer token file]:file:_files' \
  '--insecure[disable TLS for remote store]' \
  '--insecure-skip-verify[skip TLS verification]' && ret=0

return ret
