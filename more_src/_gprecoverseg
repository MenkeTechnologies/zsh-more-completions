#compdef gprecoverseg
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gprecoverseg.html
# Recover a failed Greenplum Database segment instance

local ret=1

_arguments -s -S \
  '(-? -h --help)'{-\?,-h,--help}'[display online help]' \
  '--version[display utility version]' \
  '-a[do not prompt for confirmation]' \
  '-b[max segments per host to operate on in parallel (1-128)]:num' \
  '-B[number of hosts to work on in parallel (1-64)]:num' \
  '-d[coordinator host data directory]:dir:_files -/' \
  '-F[perform full copy of active segment]' \
  '-i[recovery configuration file with failed segment details]:file:_files' \
  '-l[directory for log file output]:dir:_files -/' \
  '-o[output sample recovery configuration file]:file:_files' \
  '-p[new host outside current array for recovery]:host:_hosts' \
  '-q[run in quiet mode]' \
  '-r[rebalance segments to preferred roles after recovery]' \
  '-c[rebalance specific content IDs (with -r)]:content_ids' \
  '-s[show progress sequentially instead of in-place]' \
  '(-v --verbose)'{-v,--verbose}'[set logging output to verbose]' \
  '--differential[perform a differential copy of the active segment]' \
  '--parallel-rsync-degree[number of rsync processes to run in parallel (1-64)]:num' \
  '--hba-hostnames[control IP vs hostname use in pg_hba.conf]:value:(0 1)' \
  '--max-rate[maximum bandwidth rate for full recovery]:rate' \
  '--replay-lag[allowed replay lag in GB when rebalancing]:gb' \
  '--disable-replay-lag[disable replay lag check during rebalancing]' \
  '--no-progress[suppress progress reports]' && ret=0

return ret
