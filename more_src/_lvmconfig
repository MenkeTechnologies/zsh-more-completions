#compdef lvmconfig
# _lvmconfig — LVM2 lvmconfig configuration query CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_lvmconfig() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f+[output file]:file:_files' \
        '--file=+[output file]:file:_files' \
        '--type=+[config type]:t:(current default missing new diff list profilable profilable-command profilable-metadata)' \
        '--mergedconfig[merge config]' \
        '--metadataprofile=+[metadata profile]:str:' \
        '--commandprofile=+[command profile]:str:' \
        '--profile=+[profile]:str:' \
        '--validate[validate]' \
        '--withspaces[show spaces]' \
        '--unconfigured[unconfigured]' \
        '--withcomments[with comments]' \
        '--withfullcomments[with full comments]' \
        '--withlocalmodify[with local modify]' \
        '--withsummary[with summary]' \
        '--withversions[with versions]' \
        '--showdeprecated[show deprecated]' \
        '--showunsupported[show unsupported]' \
        '--ignoreadvanced[ignore advanced]' \
        '--ignoreunsupported[ignore unsupported]' \
        '--ignorelocal[ignore local]' \
        '--atversion=+[at version]:str:' \
        '--sinceversion=+[since version]:str:' \
        '*:config-path:'
}

_lvmconfig "$@"
