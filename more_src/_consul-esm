#compdef consul-esm
# Documentation: https://github.com/hashicorp/consul-esm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-config-file=[path to configuration JSON file]:file:_files -g "*.json"' \
  '-config-dir=[config directory]:dir:_files -/' \
  '-http-addr=[address of local Consul agent]:addr:' \
  '-log-level=[log level]:level:(trace debug info warn err)' \
  '-node=[Consul node name]:node:' \
  '-service=[watch only this service]:service:' \
  '-state-dir=[directory for persisted state]:dir:_files -/' \
  '-enable-ipv6[enable IPv6 health checks]' \
  '-version[print version]'
