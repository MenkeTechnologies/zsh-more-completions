#compdef postqueue

_arguments -s \
  '-c=[config directory]:dir:_files -/' \
  '(-f -i -j -p -s)-f[flush all queues]' \
  '(-f -i -j -p -s)-i=[requeue queue id]:queue_id:' \
  '(-f -i -j -p -s)-j[print queue as JSON]' \
  '(-f -i -j -p -s)-p[print queue in sendmail format]' \
  '(-f -i -j -p -s)-s=[schedule delivery for site]:site:' \
  '-v[verbose]'
