#compdef gost
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '*-L+[listen URL]:url:' \
  '*-F+[forward URL]:url:' \
  '-C+[config file]:file:_files -g "*.json *.yaml *.yml"' \
  '--config+[config file]:file:_files' \
  '-O+[log format]:f:(json text)' \
  '-D[enable debug]' \
  '--debug[enable debug]' \
  '-V[show version]' \
  '--api+[API server addr]:addr:' \
  '--metrics+[metrics addr]:addr:' \
  '--profiling+[profiling addr]:addr:' \
  '*: :' && ret=0

return ret
