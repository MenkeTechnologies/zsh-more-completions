#compdef COMPILE
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/COMPILE.html
# R CMD COMPILE: compile source files for use with SHLIB or LINK

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '*:file:_files' && ret=0

return ret
