#compdef otbcli_SFSTextureExtraction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SFSTextureExtraction.html
# Orfeo ToolBox: compute Structural Feature Set textures on an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to process]:image:_files' \
  '-channel[index of the image channel to analyze]:value:' \
  '-parameters.spethre[max spectral difference between pixels]:value:' \
  '-parameters.spathre[length of calculation line]:value:' \
  '-parameters.nbdir[number of directional angles to evaluate]:value:' \
  '-parameters.alpha[weighting factor for texture computation]:value:' \
  '-parameters.maxcons[max pixels for ratio calculation]:value:' \
  '-out[output image of six texture features]:output:_files' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
