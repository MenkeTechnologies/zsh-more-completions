#compdef i3lock

# Zsh completion for i3lock - improved screen locker

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --nofork)'{-n,--nofork}'[do not fork after starting]' \
  '(-b --beep)'{-b,--beep}'[enable beeping]' \
  '(-u --no-unlock-indicator)'{-u,--no-unlock-indicator}'[disable unlock indicator]' \
  '(-p --pointer)'{-p,--pointer}'[set pointer type]:pointer:(default win)' \
  '(-i --image)'{-i,--image}'[display image as background]:image file:_files -g "*.png"' \
  '(-c --color)'{-c,--color}'[set background color]:color (rrggbb)' \
  '(-t --tiling)'{-t,--tiling}'[tile the image]' \
  '(-e --ignore-empty-password)'{-e,--ignore-empty-password}'[ignore empty password]' \
  '(-f --show-failed-attempts)'{-f,--show-failed-attempts}'[show number of failed attempts]' \
  '--debug[enable debug logging]' \
  '--raw[read raw image]:format (WxH\:fmt)'
