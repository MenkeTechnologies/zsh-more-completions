#compdef backgammon
# Documentation: man backgammon(6)
# Source: openbsd/src games/backgammon/common_source/subs.c — backgammon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n[skip prompts for rules/instructions]' \
    '(-b -r -w)-b[both players red and white]' \
    '(-b -r -w)-r[player is red]' \
    '(-b -r -w)-w[player is white]' \
    '-s+[restore saved game]:file:_files' \
    '-d[disable doubling]' \
    && ret=0

return ret
