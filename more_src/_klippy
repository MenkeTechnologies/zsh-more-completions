#compdef klippy klippy.py

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-l+[log file]:file:_files' \
  '-a+[Unix socket address]:file:_files' \
  '-I+[input pseudo TTY filename]:file:_files' \
  '-i+[input gcode file (batch mode)]:file:_files -g "*.gcode"' \
  '-o+[output serial file]:file:_files' \
  '-d+[data dictionary file (batch mode)]:file:_files' \
  '-v[verbose mode]' \
  '--debugoutput=[debug output prefix]:prefix:' \
  '--import-test[import all modules and exit]' \
  '*:printer_config:_files -g "*.cfg"' && ret=0

return ret
