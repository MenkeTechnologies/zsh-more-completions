#compdef klippy klippy.py
# Documentation: https://github.com/Klipper3d/klipper/blob/master/klippy/klippy.py
# Reference accessed: 2026-05-19
# Verified: upstream klippy.py optparse parser.
# Corrected from prior file: -l is --logfile, -a is --api-server,
# -I is --input-tty, -i is --debuginput, -o is --debugoutput,
# -d is --dictionary. Removed bogus standalone --debugoutput= option
# and invented -h/--help (klippy uses optparse default -h).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --debuginput)'{-i+,--debuginput=}'[read commands from file instead of tty port]:file:_files' \
  '(-I --input-tty)'{-I+,--input-tty=}'[input tty name (default /tmp/printer)]:file:_files' \
  '(-a --api-server)'{-a+,--api-server=}'[api server unix domain socket filename]:file:_files' \
  '(-l --logfile)'{-l+,--logfile=}'[write log to file instead of stderr]:file:_files' \
  '-v[enable debug messages]' \
  '(-o --debugoutput)'{-o+,--debugoutput=}'[write output to file instead of serial port]:file:_files' \
  '(-d --dictionary)'{-d+,--dictionary=}'[file to read for mcu protocol dictionary]:file:_files' \
  '--import-test[perform an import module test]' \
  '*:printer_config:_files -g "*.cfg"' && ret=0

return ret
