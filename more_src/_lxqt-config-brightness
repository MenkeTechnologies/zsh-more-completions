#compdef lxqt-config-brightness
# Documentation: https://github.com/lxqt/lxqt-config/tree/master/lxqt-config-brightness
# Reference accessed: 2026-05-19
# Verified: upstream lxqt-config-brightness/main.cpp QCommandLineOption table.

# lxqt-config-brightness: configure backlight brightness
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-i --increase)'{-i,--increase}'[increase brightness]' \
  '(-d --decrease)'{-d,--decrease}'[decrease brightness]' \
  '(-s --set)'{-s+,--set=}'[set brightness from 1 to 100]:brightness:' \
  '(-r --reset)'{-r,--reset}'[reset gamma to default value]' \
  '--help[show help]' \
  '--version[show version]' \
  '*::lxqt-config-brightness args:_files' && ret=0
return ret
