#compdef cohere-cli cohere
# Documentation: https://www.npmjs.com/package/cohere-cli
# Reference accessed: 2026-05-23
# Verified: npx cohere-cli --help.

# Zsh completion for cohere-cli - Cohere AI chat CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-k --api-key)'{-k+,--api-key=}'[Cohere API key]:key:' \
  '(-m --model)'{-m+,--model=}'[model to use]:model:' \
  '(-t --temperature)'{-t+,--temperature=}'[temperature 0-1]:value:' \
  '(-s --single-message)'{-s,--single-message}'[single message and exit]' \
  '--no-history[do not include chat history]' \
  '--max-tokens[maximum response tokens]:count:' && ret=0

return ret
