#compdef exabgpcli
# Documentation: https://github.com/Exa-Networks/exabgp/wiki/ExaBGP-CLI
# Send commands to a running ExaBGP instance over its named pipe

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--pipename[name of the named pipe used to reach exabgp]:pipe name:' \
  '--no-color[disable colored output]' \
  '*:command:' && ret=0

return ret
