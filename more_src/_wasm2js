#compdef wasm2js

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output)'{-o,--output}'[Output file]:file:_files' \
  '--allow-asserts[Allow assert_ in output]' \
  '--pedantic[Be pedantic about standards compliance]' \
  '--emscripten[Generate Emscripten-compatible output]' \
  '--deterministic[Generate deterministic output]' \
  '--symbols-file[Emit a symbols file]:file:_files' \
  '--all-features[Enable all features]' \
  '--mvp-features[Use only MVP features]' \
  '--enable-sign-ext[Enable sign extension operations]' \
  '--enable-threads[Enable threads]' \
  '--enable-mutable-globals[Enable mutable globals]' \
  '--enable-simd[Enable SIMD]' \
  '--enable-bulk-memory[Enable bulk memory operations]' \
  '--enable-exception-handling[Enable exception handling]' \
  '--enable-tail-call[Enable tail call]' \
  '--enable-reference-types[Enable reference types]' \
  '--enable-multivalue[Enable multivalue]' \
  '--enable-gc[Enable GC]' \
  '--enable-memory64[Enable 64-bit memory]' \
  '--no-validation[Disable validation]' \
  '(- *)--help[Show help]' \
  '1:input file:_files -g "*.(wasm|wat)"' && ret=0

return ret
