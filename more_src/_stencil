#compdef stencil
# Documentation: https://stenciljs.com/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Completion for stencil - Stencil web component compiler CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build the project'
      'test:run tests'
      'generate:generate a new component'
      'g:generate a new component (alias)'
      'version:show version'
      'help:show help'
    )
    _describe -t commands 'stencil command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file path]:config file:_files -g "*.{ts,js}"' \
          '--debug[enable debug output]' \
          '--dev[development mode]' \
          '--docs[generate documentation]' \
          '--es5[generate ES5 builds]' \
          '--log[write logs]' \
          '--no-cache[disable caching]' \
          '--no-open[do not open browser]' \
          '--prerender[prerender the application]' \
          '--prod[production mode]' \
          '--serve[start dev server]' \
          '--stats[write build stats]' \
          '--verbose[verbose output]' \
          '--watch[watch for changes and rebuild]' \
          '--ci[CI mode (set defaults for CI)]' \
          '--max-workers=[max worker threads]:n' \
          '--next[run with the next features]' \
          {-p,--port}'=[dev server port]:port' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--spec[run spec tests]' \
          '--e2e[run end-to-end tests]' \
          '--screenshot[generate screenshots]' \
          '--update-screenshot[update reference screenshots]' \
          '--config=[config file path]:config file:_files -g "*.{ts,js}"' && ret=0
        ;;
      generate|g)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:component tag name' && ret=0
        ;;
    esac
    ;;
esac

return ret
