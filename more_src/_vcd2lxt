#compdef vcd2lxt
# Documentation: https://verilator.org/guide/latest/
# Convert VCD dumpfiles to LXT

local ret=1

_arguments -s -S \
  '-stats[print net statistics in addition to converting]' \
  '-clockpack[apply two-way subtraction algorithm to identify clock-like nets]' \
  '-chgpack[emit data filtered through zlib (gzip)]' \
  '-linear[write LXT in linear format with bzip2 compression]' \
  '-dictpack+[store value changes >= size bits as dictionary index]:size' \
  '*:file:_files -g "*.(vcd|lxt)"' && ret=0

return ret
