#compdef avahi-browse
# _avahi-browse — Lennart Poettering (avahi project) avahi-browse (mDNS/DNS-SD service browser; lists services and optionally resolves them via the Avahi daemon)
# upstream: https://github.com/lathiat/avahi
# Flags from avahi-utils/avahi-browse.c long_options on tip.

_avahi-browse() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-D --browse-domains)'{-D,--browse-domains}'[browse browsing domains instead of services]' \
        '(-d --domain)'{-d+,--domain=}'[domain to browse]:domain:' \
        '(-a --all)'{-a,--all}'[browse all available service types]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-t --terminate)'{-t,--terminate}'[terminate after dumping a more or less complete list]' \
        '(-c --cache)'{-c,--cache}'[terminate after cache is exhausted]' \
        '(-l --ignore-local)'{-l,--ignore-local}'[ignore local services]' \
        '(-r --resolve)'{-r,--resolve}'[resolve services found]' \
        '(-f --no-fail)'{-f,--no-fail}'[do not fail if Avahi daemon is unavailable]' \
        '(-p --parsable)'{-p,--parsable}'[parsable (script-friendly) output]' \
        '(-k --no-db-lookup)'{-k,--no-db-lookup}'[do not look up service-type DB]' \
        '(-b --dump-db)'{-b,--dump-db}'[dump the service type database]' \
        '1:service-type:'
}

_avahi-browse "$@"
