#compdef aimless
# aimless — scaling and merging of integrated intensities (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output reflection MTZ]:file:_files -g "*.mtz"' \
  'XMLOUT[output XML]:file:_files -g "*.xml"' \
  'HKLREF[reference reflection file]:file:_files -g "*.mtz"' \
  'XYZIN[reference coordinates]:file:_files -g "*.(pdb|cif|ent)"' \
  'SCALES[scale factors file]:file:_files' \
  'ROGUES[rogues/outliers file]:file:_files' \
  'HKLOUTUNMERGED[unmerged output MTZ]:file:_files -g "*.mtz"' \
  'SCALEPACK[Scalepack format output]:file:_files' \
  'ANALYSIS[analysis options]:opt:' \
  'ANOMALOUS[anomalous treatment]:opt:' \
  'BFACTOR[B-factor scaling]:opt:' \
  'BINS[resolution bins]:n:' \
  'CELL[unit cell]:cell:' \
  'DUMP[dump scales to file]:opt:' \
  'EXCLUDEBATCH[exclude batches]:batch:' \
  'INTENSITIES[intensity column choice]:opt:' \
  'NAME[project/crystal/dataset name]:name:' \
  'ONLYMERGE[merge only, no scaling]' \
  'OUTPUT[output options]:opt:' \
  'PARTIALS[partial handling]:opt:' \
  'REFINE[refinement options]:opt:' \
  'REJECT[outlier rejection]:opt:' \
  'RESOLUTION[resolution limits]:lim:' \
  'SDCORRECTION[sigma correction]:opt:' \
  'TITLE[output title]:title:' \
  'UNMERGEDOUT[unmerged output filename]:file:_files -g "*.mtz"' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
