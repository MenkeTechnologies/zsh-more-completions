#compdef koreader
# Documentation: https://man.archlinux.org/search?q=koreader
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d[debug mode]' \
  '-v[verbose output]' \
  '-r+[reload events file]:file:_files' \
  '-s+[simulate device]:device:(KindlePaperWhite KindleTouch KoboAura KoboGlo KoboH2O PocketBook reMarkable)' \
  '-h+[set screen height]:n:' \
  '-w+[set screen width]:n:' \
  '*:document:_files -g "*.{epub,pdf,mobi,azw3,fb2,djvu,cbz,cbr,zip,rar,html,md,txt,xps}"' && ret=0

return ret
