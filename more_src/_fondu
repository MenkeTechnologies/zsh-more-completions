#compdef fondu
# fondu — convert between Mac and Unix font formats

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-force[overwrite existing files]' \
  '-inquire[show font information only]' \
  '-latin1[use Latin-1 encoding]' \
  '-show[show what would be done without doing it]' \
  '*:font file:_files' && ret=0

return ret
