#compdef cpancover
# Documentation: cpancover
# Source: pjcj/Devel--Cover bin/cpancover (master) — run coverage analysis across CPAN (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bin_dir=[binary directory]:dir:_files -/' \
    '--build[build coverage (default)]' \
    '--nobuild[skip building]' \
    '--compress_old_versions=[compress N old result versions]:N:_default' \
    '--docker=[docker command]:cmd:_command_names -e' \
    '--dryrun[do not actually run]' \
    '--env=[environment variable]:var:_default' \
    '--force[force rebuild]' \
    '--generate_html[generate HTML report]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-i --info)'{-i,--info}'[show info]' \
    '--latest[only latest module version]' \
    '--local[use local module]' \
    '--local_build[use local build]' \
    '--module_file=[file with module list]:file:_files' \
    '--modules=[modules comma-separated]:list:_default' \
    '--output_file=[output HTML file]:file:_files' \
    '--rebuild[rebuild reports]' \
    '--rebuild_batch=[rebuild batch size]:N:_default' \
    '--report=[report format]:format:(html json text)' \
    '--results_dir=[results directory]:dir:_files -/' \
    '--timeout=[per-module timeout (seconds)]:seconds:_default' \
    '--verbose[verbose output]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--workers=[number of parallel workers]:N:_default' \
    && ret=0

return ret
