#compdef tty-share
# Documentation: https://man.archlinux.org/search?q=tty-share
# Reference accessed: 2026-05-16

# Zsh completion for tty-share terminal sharing

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--public[public session]' \
  '*:: : _message "see tty-share --help"' && ret=0

return ret
