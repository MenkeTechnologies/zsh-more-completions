#compdef tssh

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-l[login name]:username:_users' \
  '-p[port]:port:' \
  '-i[identity file]:key file:_files' \
  '-o[SSH option]:option:' \
  '-J[jump host]:host:_hosts' \
  '-F[config file]:config file:_files' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-A[enable agent forwarding]' \
  '-C[enable compression]' \
  '-N[do not execute remote command]' \
  '-T[disable pseudo-tty allocation]' \
  '-t[force pseudo-tty allocation]' \
  '-v[verbose mode]' \
  '-q[quiet mode]' \
  '-W[request tunnel to host:port]:host\:port:' \
  '-D[dynamic port forwarding]:port:' \
  '-L[local port forwarding]:bind:' \
  '-R[remote port forwarding]:bind:' \
  '-X[enable X11 forwarding]' \
  '1:host:_hosts' \
  '*:command:' && ret=0

return ret
