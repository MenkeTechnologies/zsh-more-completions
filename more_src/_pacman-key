#compdef pacman-key

# Zsh completion for pacman-key - pacman keyring management

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--init[initialize the keyring]' \
  '(-l --list-sigs)'{-l,--list-sigs}'[list keys and signatures]' \
  '--list-keys[list keys]' \
  '--add[add keys from file]:key file:_files' \
  '--recv-keys[receive keys from keyserver]:key IDs' \
  '--delete[delete keys]:key IDs' \
  '--export[export keys]:key IDs' \
  '--finger[list fingerprints]:key IDs' \
  '--updatedb[update trust database]' \
  '--reload[reload the keyring]' \
  '--refresh-keys[refresh keys from keyserver]' \
  '--populate[populate keyring from installed keyrings]:keyrings' \
  '--lsign-key[locally sign a key]:key ID' \
  '--verify[verify a signature]:signature file:_files' \
  '--edit-key[edit a key]:key ID' \
  '--import[import a trustdb]:trustdb file:_files' \
  '--import-trustdb[import a trustdb]:trustdb file:_files' \
  '--gpgdir=[GPG home directory]:directory:_directories' \
  '--keyserver=[keyserver URL]:keyserver' \
  '--config=[pacman config file]:config file:_files'
