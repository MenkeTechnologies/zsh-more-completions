#compdef mythic
# Documentation: https://crates.io/crates/mythic-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: clap-generated `mythic completions zsh` from mythic-cli release.

autoload -U is-at-least

_mythic() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_mythic_commands" \
"*::: :->mythic" \
&& ret=0
    case $state in
    (mythic)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:mythic-command-$line[1]:"
        case $line[1] in
            (build)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'--drafts[Include draft pages]' \
'--clean[Delete output directory before building]' \
'--profile[Print per-stage timing breakdown]' \
'--json[Output build report as JSON (for CI)]' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'-p+[Port to listen on]:PORT:_default' \
'--port=[Port to listen on]:PORT:_default' \
'--drafts[Include draft pages]' \
'--open[Open browser automatically]' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-t+[Starter template\: blank, blog, docs, portfolio]:TEMPLATE:_default' \
'--template=[Starter template\: blank, blog, docs, portfolio]:TEMPLATE:_default' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
':name -- Project name:_default' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'--draft[Create as draft]' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
':content_type -- Content type (e.g., "post", "page", "doc"):_default' \
':title -- Title of the new content:_default' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(migrate)
_arguments "${_arguments_options[@]}" : \
'--from=[Source SSG\: jekyll, hugo, or eleventy]:FROM:_default' \
'--source=[Path to the source project]:SOURCE:_files' \
'--output=[Output path for the migrated Mythic project]:OUTPUT:_files' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'--drafts[Include draft pages]' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to config file]:CONFIG:_files' \
'--config=[Path to config file]:CONFIG:_files' \
'--drafts[Include draft pages]' \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-q[Suppress output (for CI/scripting)]' \
'--quiet[Suppress output (for CI/scripting)]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_mythic__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:mythic-help-command-$line[1]:"
        case $line[1] in
            (build)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(migrate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(watch)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_mythic_commands] )) ||
_mythic_commands() {
    local commands; commands=(
'build:Build the site' \
'serve:Start the development server with live reload' \
'init:Create a new Mythic site' \
'new:Create a new content file with frontmatter scaffold' \
'check:Check the built site for broken links and issues' \
'migrate:Migrate from another static site generator' \
'clean:Delete the output directory' \
'list:List all content pages' \
'watch:Watch for changes and rebuild (without starting a server)' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'mythic commands' commands "$@"
}
