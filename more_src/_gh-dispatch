#compdef gh-dispatch
# Documentation: https://github.com/mdb/gh-dispatch
# Source: mdb/gh-dispatch — gh CLI extension to trigger + watch repository_dispatch/workflow_dispatch events.
# Reference accessed: 2026-06-02
# Also reachable as `gh dispatch`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gd_cmds
_gd_cmds=(
    'repository:trigger a repository_dispatch event and watch the resulting run'
    'workflow:trigger a workflow_dispatch event and watch the resulting run'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gh-dispatch command' _gd_cmds && ret=0
        ;;
    args)
        case $line[1] in
            repository)
                _arguments -s -S \
                    '--repo=[target repository (owner/name)]:repo:_default' \
                    '--workflow=[workflow name to expect]:name:_default' \
                    '--event-type=[dispatch event type]:type:_default' \
                    '--client-payload=[JSON payload to send]:json:_default' \
                    && ret=0
                ;;
            workflow)
                _arguments -s -S \
                    '--repo=[target repository (owner/name)]:repo:_default' \
                    '--workflow=[workflow file]:file:_default' \
                    '--inputs=[JSON workflow inputs]:json:_default' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
