#compdef ociomakeclf
# Documentation: https://opencolorio.readthedocs.io/
# convert a LUT into a CLF or ACES-compliant Look Modification Transform

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--csc=[convert into an ACES-compliant Look Modification Transform]:colorspace:' \
  '--list[print the supported standard ACES color spaces]' \
  '*:file:_files' && ret=0

return ret
