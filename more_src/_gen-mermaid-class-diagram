#compdef gen-mermaid-class-diagram
# _gen-mermaid-class-diagram — emit Mermaid class diagrams from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/mermaidclassdiagramgen.py (click).

_gen-mermaid-class-diagram() {
    local -a args
    args=(
        '(-t --template-file)'{-t+,--template-file=}'[Jinja template for class diagrams]:file:_files'
        '(-d --directory)'{-d+,--directory=}'[output directory for the Markdown files]:dir:_files -/'
        '*'{-c+,--classes=}'[class to emit a diagram for (repeatable; default all)]:class:'
        '--preserve-names[preserve original LinkML names in Mermaid output]'
        '--normalize-names[normalize names to Mermaid conventions (default)]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-mermaid-class-diagram "$@"
