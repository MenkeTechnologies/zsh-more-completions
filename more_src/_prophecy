#compdef prophecy
# Documentation: https://man.archlinux.org/search?q=prophecy
# Reference accessed: 2026-05-16

# EMBOSS prophecy: build a Gribskov or frequency profile from an alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[aligned sequence(s)]:alignment USA:_files' \
  '-type=[profile type]:type:(F G H)' \
  '-name=[profile name]:name:' \
  '-threshold=[threshold reporting cutoff]:val:' \
  '-datafile=[scoring matrix (for type G)]:matrix:_files' \
  '-open=[gap opening penalty]:val:' \
  '-extension=[gap extension penalty]:val:' \
  '-outfile=[profile output file]:file:_files' \
  '*:alignment USA:_files' && ret=0
return ret
