#compdef behat-cli
# _behat-cli — Konstantin Kudryashov Behat PHP BDD framework CLI alias (Behat team, PHP); symfony console
# upstream: https://github.com/Behat/Behat

_behat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--config=+[config file]:file:_files -g "behat.yml*"' \
        '-c+[config file]:file:_files -g "behat.yml*"' \
        '--profile=+[profile]:str:' \
        '-p+[profile]:str:' \
        '--suite=+[suite]:str:' \
        '-s+[suite]:str:' \
        '--name=+[scenario name]:str:' \
        '--tags=+[tag filter]:str:' \
        '--role=+[role filter]:str:' \
        '--story-syntax[show story syntax]' \
        '--definitions=+[definitions]:d:(l i)' \
        '-d+[definitions]:d:(l i)' \
        '--lang=+[lang]:str:' \
        '--append-snippets[append snippets]' \
        '--no-snippets[no snippets]' \
        '--strict[strict mode]' \
        '--rerun[rerun failed]' \
        '--stop-on-failure[stop on failure]' \
        '--init[initialize behat]' \
        '--dry-run[dry run]' \
        '--format=+[formatter]:f:(pretty progress junit html)' \
        '-f+[formatter]:f:(pretty progress junit html)' \
        '--out=+[output path]:file:_files' \
        '-o+[output path]:file:_files' \
        '--colors[force colors]' \
        '--no-colors[no colors]' \
        '--format-settings=+[settings json]:str:' \
        '*:features:_files'
}

_behat-cli "$@"
