#compdef pcli
# Documentation: https://guide.penumbra.zone/pcli/install.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Directory for wallet, view DB, and config]:directory:_directories' \
  '--grpc-url=[Override fullnode gRPC endpoint]:url:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Create or reset a local wallet'
      'query:Inspect public chain state'
      'q:Alias for query'
      'view:Inspect shielded balances and transactions'
      'v:Alias for view'
      'transaction:Build and broadcast transactions'
      'tx:Alias for transaction'
      'threshold:Threshold signing ceremony utilities'
      'migrate:Migrate funds between wallets'
      'validator:Validator maintenance commands'
      'debug:Diagnostics for local installs'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
