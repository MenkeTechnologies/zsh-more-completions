#compdef warpvol
# Documentation: https://bio3d.colorado.edu/imod/doc/man/warpvol.html
# Warp one volume into alignment with another

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -i -InputFile)'{-input,-i,-InputFile}'[Input image file to warp]:file:_files' \
  '(-output -ou -OutputFile)'{-output,-ou,-OutputFile}'[Output file for warped volume]:file:_files' \
  '(-xforms -x -TransformFile)'{-xforms,-x,-TransformFile}'[File with matrix of inverse transforms produced by Findwarp]:file:_files' \
  '(-scale -sc -ScaleTransforms)'{-scale,-sc,-ScaleTransforms}'[Factor by which to scale transforms, to account for the...]:value' \
  '(-tempdir -t -TemporaryDirectory)'{-tempdir,-t,-TemporaryDirectory}'[Directory to use for temporary files. The default is that...]:value' \
  '(-size -si -OutputSizeXYZ)'{-size,-si,-OutputSizeXYZ}'[X, Y, Z dimensions of the output file (Default is Z, Y, X...]:value' \
  '(-same -sa -SameSizeAsInput)'{-same,-sa,-SameSizeAsInput}'[Make default size of output file be same size as input file.]' \
  '(-order -or -InterpolationOrder)'{-order,-or,-InterpolationOrder}'[Order of interpolation to use. Currently only quadratic (2)...]:value' \
  '(-chunk -c -ChunkSizesForHDF)'{-chunk,-c,-ChunkSizesForHDF}'[Size of chunks in X, Y, and Z for output to an HDF file...]:value' \
  '(-memory -m -MemoryLimit)'{-memory,-m,-MemoryLimit}'[Amount of memory to allocate for the major arrays needed by...]:value' \
  '(-verbose -v -VerboseOutput)'{-verbose,-v,-VerboseOutput}'[1 for diagnostic output; 2 for output as each slice is...]:value' \
  '(-patch -pat -PatchOutputFile)'{-patch,-pat,-PatchOutputFile}'[Output text file for vectors representing the displacement...]:file:_files' \
  '(-filled -f -FilledInOutputFile)'{-filled,-f,-FilledInOutputFile}'[Output file for warping transforms after filling in empty...]:file:_files' \
  '(-param -par -ParameterFile)'{-param,-par,-ParameterFile}'[Parameter file]' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
