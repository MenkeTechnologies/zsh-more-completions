#compdef udp-receiver
# Documentation: https://man.archlinux.org/search?q=udp-receiver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--license[show license]' \
  '(-f --file)'{-f,--file}'+[output file]:file:_files' \
  '--nosync[no fsync after write]' \
  '--ttl=[set TTL]:ttl:' \
  '--mcast-rdv-addr=[rendezvous multicast address]:addr:' \
  '--mcast-rdv-port=[rendezvous port]:port:' \
  '--portbase=[port base]:port:' \
  '--interface=[network interface]:iface:_net_interfaces' \
  '--exit-wait=[exit wait ms]:ms:' \
  '--rcvbuf=[receive socket buffer]:bytes:' \
  '--start-timeout=[start timeout sec]:sec:' \
  '--receive-timeout=[receive timeout sec]:sec:' \
  '--log=[log file]:file:_files' \
  '--pipe=[shell pipe through command]:cmd:' \
  '--no-progress[hide progress meter]' \
  '--sender=[sender host]:host:_hosts' \
  '--password=[shared password]:pw:' \
  '--nokbd[disable keyboard control]' \
  '*:file:_files' && ret=0

return ret
