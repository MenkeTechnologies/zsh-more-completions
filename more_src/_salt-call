#compdef salt-call
# _salt-call — SaltStack salt-call (invoke salt execution modules locally on a minion (or with --local in masterless mode); first positional is function name (e.g. state.apply, cmd.run), rest are kwargs)
# upstream: https://github.com/saltstack/salt (salt/cli/call.py)
# Flags from salt cli/call.py on tip.

_salt-call() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-g[show grains]' \
        '-G[refresh grains]' \
        '--local[no master (masterless)]' \
        '--file-root+[file root]:dir:_files -/' \
        '--pillar-root+[pillar root]:dir:_files -/' \
        '--master+[override master IP/hostname]:master:_hosts' \
        '--retcode-passthrough[exit with module retcode]' \
        '--metadata+[saved metadata]:json:' \
        '--skip-grains[skip grain refresh]' \
        '--refresh-grains-cache[refresh grains cache]' \
        '--cache-grains[cache grains]' \
        '-l+[log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-file+[log file]:file:_files' \
        '--output+[output format]:format:(yaml json raw nested key pprint highstate progress txt)' \
        '--no-color[disable colors]' \
        '--state-output+[state output style]:style:(full terse mixed changes)' \
        '1:function:' \
        '*::arg:'
}

_salt-call "$@"
