#compdef twint
# Documentation: https://man.archlinux.org/search?q=twint
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --username)'{-u+,--username=}'[target user]:user:' \
  '(-s --search)'{-s+,--search=}'[search query]:query:' \
  '(-g --geo)'{-g+,--geo=}'[geo lat,long,radius]:loc:' \
  '--near=[near a location]:loc:' \
  '(-l --lang)'{-l+,--lang=}'[language]:lang:' \
  '--year=[before year]:year:' \
  '--since=[date since (YYYY-MM-DD)]:date:' \
  '--until=[date until (YYYY-MM-DD)]:date:' \
  '--email[filter for emails]' \
  '--phone[filter for phone numbers]' \
  '--verified[only verified users]' \
  '--to=[reply target]:user:' \
  '--all=[mentions of user]:user:' \
  '--followers[scrape followers]' \
  '--following[scrape following]' \
  '--favorites[scrape favorites]' \
  '--retweets[include retweets]' \
  '--user-full[fetch full user info]' \
  '--profile-full[full profile crawl]' \
  '--limit=[tweets limit]:n:' \
  '--count[only print count]' \
  '--stats[show stats]' \
  '--db=[SQLite output]:file:_files' \
  '--essid=[Elasticsearch index]:name:' \
  '--csv[CSV output]' \
  '--json[JSON output]' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '--proxy-host=[proxy host]:host:_hosts' \
  '--proxy-port=[proxy port]:port:' \
  '--proxy-type=[proxy type]:type:(http socks4 socks5)' \
  '--tor-control-port=[tor control port]:port:' \
  '--tor-control-password=[tor control password]:password:' \
  '--popular-tweets[only popular tweets]' \
  '--native-retweets[only native retweets]' \
  '--min-likes=[min likes]:n:' \
  '--min-retweets=[min retweets]:n:' \
  '--min-replies=[min replies]:n:' \
  '--media[only tweets with media]' \
  '--images[only tweets with images]' \
  '--videos[only tweets with videos]' \
  '--source=[source filter]:src:' \
  '--hide-output[hide CLI output]' \
  '--resume=[resume from CSV]:file:_files -g "*.csv"' \
  '*::extra:' && ret=0

return ret
