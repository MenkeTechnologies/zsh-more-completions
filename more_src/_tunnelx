#compdef tunnelx
# Documentation: https://github.com/projectdiscovery/tunnelx
# expose a local network as a ProjectDiscovery cloud tunnel

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-auth=[your ProjectDiscovery API key (required)]:api key' \
  '-name=[specify a custom network name (default: hostname)]:name' && ret=0

return ret
