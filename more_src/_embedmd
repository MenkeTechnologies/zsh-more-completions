#compdef embedmd
# Documentation: https://man.archlinux.org/search?q=embedmd
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-w --write)'{-w,--write}'[Write result in place]' \
  '(-strip-embed)'--strip-embed'[Strip embedded code blocks]' \
  '*:markdown files:_files -g "*.md(-.)"'
