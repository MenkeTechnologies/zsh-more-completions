#compdef elixir-ls
# Documentation: https://man.archlinux.org/search?q=elixir-ls
# Reference accessed: 2026-05-16

# Zsh completion for ElixirLS (Elixir Language Server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--stdio[use stdio transport]' && ret=0

return ret
