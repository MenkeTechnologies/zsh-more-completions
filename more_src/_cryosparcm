#compdef cryosparcm
# Documentation: https://guide.cryosparc.com/setup-configuration-and-management/management-and-monitoring-v5.0/cryosparcm-reference-v5.0.md
# cryoSPARC master instance management CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(start stop restart status version maintenancemode resources changeport asset-stats recover update patch worker cluster deps test log filterlog snaplogs errorreport get-workspace-report user job database createuser env call python ipython cli icli downloadtest mongo redis)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $words[1] in
      update) _arguments '--version=[version to install]:version:' '--list[list available versions]' '--check[check for updates]' '--download[download only]' '--install[install]' && ret=0 ;;
      patch) _arguments '--check[check]' '--download[download]' '--install[install]' '--force[force]' && ret=0 ;;
      deps) _arguments '--force[force reinstall]' && ret=0 ;;
      maintenancemode) _arguments '1:mode:(status on off)' && ret=0 ;;
      worker) _arguments '1:action:(connect disconnect update patch)' && ret=0 ;;
      cluster) _arguments '1:action:(connect disconnect dump remove example)' && ret=0 ;;
      test) _arguments '1:suite:(license install workers)' && ret=0 ;;
      user) _arguments '1:action:(list exists create update resetpassword)' && ret=0 ;;
      job) _arguments '1:action:(status queue clear kill log events)' && ret=0 ;;
      database) _arguments '1:action:(check configure fixport backup restore compact export import)' && ret=0 ;;
      createuser) _arguments \
        '--email=[user email]:email:' \
        '--password=[account password]:password:' \
        '--username=[login username]:username:' \
        '--firstname=[given name]:name:' \
        '--lastname=[surname]:name:' && ret=0 ;;
      filterlog) _arguments \
        '(-d --days)'{-d,--days}'=[days]:days:' \
        '(-D --date)'{-D,--date}'=[date]:date:' \
        '(-m --max-lines)'{-m,--max-lines}'=[max lines]:n:' \
        '(-t --tail)'{-t,--tail}'[tail output]' '1:service:' && ret=0 ;;
    esac
    ;;
esac

return ret
