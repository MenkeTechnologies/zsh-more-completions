#compdef mt-fakemetrics
# Documentation: https://docs.victoriametrics.com/
# Generate fake metrics for metrictank load testing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --add-tags)'{-t,--add-tags}'[add built-in tags to generated metrics]' \
  '--carbon-addr=[carbon TCP address]:addr' \
  '--config=[config file path]:_files' \
  '--custom-tags=[comma-separated tag list]:tags' \
  '--filter=[comma-separated filters to apply]:filters' \
  '--gnet-addr=[gnet address]:addr' \
  '--gnet-key=[gnet API key]:key' \
  '--kafka-comp=[compression]:comp:(none gzip snappy)' \
  '--kafka-mdm-addr=[kafka TCP address for MetricData-Msgp]:addr' \
  '--kafka-mdm-topic=[kafka topic]:topic' \
  '--kafka-mdm-v2[enable MetricPoint optimization]' \
  '--listen=[HTTP listener address for pprof]:addr' \
  '--log-level=[log level 0=TRACE to 6=FATAL]:level' \
  '--num-unique-custom-tags=[make custom tags unique]:n' \
  '--num-unique-tags=[add unique number to tags]:n' \
  '--partition-scheme=[partitioning method]:scheme' \
  '--statsd-addr=[statsd TCP address]:addr' \
  '--statsd-type=[statsd type]:type:(standard datadog)' \
  '--stdout[emit metrics to stdout]' && ret=0

return ret
