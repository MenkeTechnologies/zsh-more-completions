#compdef force-mosaic
# Documentation: https://force-eo.readthedocs.io/en/latest/components/auxilliary/mosaic.html
# FORCE: mosaicking of image chips into VRT mosaics

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v)-v[show version]' \
  '(-i)-i[show program purpose]' \
  '(-j)-j[number of parallel processes]:jobs:' \
  '(-m)-m[mosaic output directory (relative to tiles)]:dir:_files -/' \
  '1:datacube dir:_files -/' && ret=0

return ret
