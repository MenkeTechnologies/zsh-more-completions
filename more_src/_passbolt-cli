#compdef passbolt-cli
# _passbolt-cli — Passbolt open-source password manager CLI alias (passbolt team, Node); commander
# upstream: https://github.com/passbolt/passbolt_cli

_passbolt-cli() {
    local -a sub=(
        'register:register a new account'
        'login:login to passbolt'
        'logout:logout'
        'profile:show profile'
        'resource:list:list resources'
        'resource:get:get resource'
        'resource:create:create resource'
        'resource:update:update resource'
        'resource:delete:delete resource'
        'resource:share:share resource'
        'resource:unshare:unshare resource'
        'resource:search:search resources'
        'resource:export:export resources'
        'resource:import:import resources'
        'folder:list:list folders'
        'folder:create:create folder'
        'folder:delete:delete folder'
        'folder:rename:rename folder'
        'tag:list:list tags'
        'tag:add:add tag'
        'tag:remove:remove tag'
        'group:list:list groups'
        'group:create:create group'
        'group:delete:delete group'
        'group:add-user:add user'
        'group:remove-user:remove user'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:get:get user'
        'user:update:update user'
        'comment:add:add comment'
        'comment:delete:delete comment'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.{json,yml,yaml}"' \
        '-c+[config file]:file:_files -g "*.{json,yml,yaml}"' \
        '--server=+[server URL]:url:_urls' \
        '--user=+[username]:user:_users' \
        '--password=+[passphrase]:str:' \
        '--key=+[gpg private key]:file:_files' \
        '--insecure[skip TLS verify]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'passbolt subcommand' sub ;;
        args)
            case $words[1] in
                resource:get|resource:update|resource:delete|resource:share|resource:unshare) _arguments '1:resource id:' ;;
                resource:create) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--username=+[username]:user:_users' \
                    '-u+[username]:user:_users' \
                    '--uri=+[URI]:url:_urls' \
                    '-i+[URI]:url:_urls' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--folder-parent-id=+[folder id]:str:' \
                    '--tags=+[tags csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_passbolt-cli "$@"
