#compdef gocheck
# _gocheck — gocheck rich Go testing framework wrapper (Gustavo Niemeyer); v1 fixture-based test harness with custom flags
# upstream: https://gopkg.in/check.v1

_gocheck() {
    _arguments \
        '-check.b[run benchmarks]' \
        '-check.bmem[show memory usage]' \
        '-check.btime+[bench time]:duration:' \
        '-check.f+[focus regex]:regex:' \
        '-check.v[verbose]' \
        '-check.vv[very verbose]' \
        '-check.work[use work directory]' \
        '-check.list[list tests]' \
        '-check.stream[stream output]' \
        '-check.seed+[seed]:n:' \
        '-check.skip+[skip regex]:regex:' \
        '*:packages:'
}

_gocheck "$@"
