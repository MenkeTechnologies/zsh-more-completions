#compdef s6-tlsclient
# Documentation: https://skarnet.org/software/s6-networking/s6-tlsclient.html
# Reference accessed: 2026-05-30
# s6-tlsclient — TLS-wrapped TCP client runner. Combines s6-tcpclient + s6-tlsc.

local curcontext="$curcontext" state line ret=1

# Inherits s6-tcpclient's full option set, plus TLS-specific:
_arguments -s -S \
  '(-q -Q -v)-q[quiet]' \
  '(-q -Q -v)-Q[normal verbosity (default)]' \
  '(-q -Q -v)-v[verbose]' \
  '(-4 -6)-4[IPv4 only]' \
  '(-4 -6)-6[IPv6 only]' \
  '(-d -D)-d[disable TCP_NODELAY (default)]' \
  '(-d -D)-D[enable TCP_NODELAY]' \
  '(-h -H)-h[check /etc/hosts before DNS]' \
  '(-h -H)-H[skip DNS lookups]' \
  '(-n -N)-n[qualify host during resolution]' \
  '(-n -N)-N[do not qualify host (default)]' \
  '(-r -R)-r[obtain TCPREMOTEINFO via IDENT]' \
  '(-r -R)-R[disable IDENT (default)]' \
  '-t+[global timeout (seconds)]:sec:' \
  '-T+[connection timeouts x+y]:x+y:' \
  '-i+[local bind IP]:ip:' \
  '-p+[local bind port]:port:' \
  '-l+[TCPLOCALHOST value]:name:' \
  '(-Z -z)-Z[keep s6-tlsc-io-specific env variables]' \
  '(-Z -z)-z[remove s6-tlsc-io-specific env variables]' \
  '(-S -s)-S[use close_notify to signal end of TLS connection]' \
  '(-S -s)-s[use EOF to signal end of TLS connection]' \
  '(-J -j)-J[exit nonzero on peer close_notify failure]' \
  '(-J -j)-j[ignore peer close_notify failure]' \
  '(-Y -y)-Y[do not send client certificate]' \
  '(-Y -y)-y[send client certificate]' \
  '-k+[SNI server name (Server Name Indication)]:servername:' \
  '-K+[TLS handshake timeout]:ms:' \
  '1:host:_hosts' \
  '2:port:' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
