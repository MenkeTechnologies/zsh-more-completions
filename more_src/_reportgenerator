#compdef reportgenerator
# Documentation: https://github.com/danielpalme/ReportGenerator
# reportgenerator - convert coverage reports into human-readable reports

local ret=1

_arguments -s -S \
  '-reports=[coverage reports to parse (semicolon separated)]:reports:_files' \
  '-targetdir=[directory where the report is saved]:dir:_files -/' \
  '-reporttypes=[output formats and scope (semicolon separated)]:types:' \
  '-sourcedirs=[directories containing source code (semicolon separated)]:dirs:_files -/' \
  '-historydir=[directory for storing persistent coverage information]:dir:_files -/' \
  '-plugins=[plugin files for custom reports or history storage]:plugins:_files' \
  '-assemblyfilters=[assemblies to include or exclude]:filters:' \
  '-classfilters=[classes to include or exclude]:filters:' \
  '-filefilters=[files to include or exclude]:filters:' \
  '-riskhotspotassemblyfilters=[assemblies for risk hotspot analysis]:filters:' \
  '-riskhotspotclassfilters=[classes for risk hotspot analysis]:filters:' \
  '-verbosity=[verbosity level of log messages]:level:(Verbose Info Warning Error Off)' \
  '-title=[custom report title]:title:' \
  '-tag=[tag or build version identifier]:tag:' \
  '-license=[license key for the PRO version]:license:' \
  '-settings:[additional settings as key-value pairs]:setting:' \
  '*::arg:_default' && ret=0

return ret
