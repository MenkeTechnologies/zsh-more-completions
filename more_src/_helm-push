#compdef helm-push
# helm-push: push Helm charts to ChartMuseum or OCI registries
# https://github.com/chartmuseum/helm-push

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --app-version)'{-a+,--app-version=}'[override app version]:version' \
  '--ca-file=[verify certificates with this CA bundle]:file:_files' \
  '--cert-file=[identify HTTPS client using this cert]:file:_files' \
  '--context-path=[ChartMuseum context path]:path' \
  '--debug[enable verbose output]' \
  '-d[enable verbose output]' \
  '(-f --force)'{-f,--force}'[force upload even if chart version exists]' \
  '--home=[helm home directory]:directory:_directories' \
  '--insecure[connect over HTTP instead of HTTPS]' \
  '--key-file=[identify HTTPS client using this key]:file:_files' \
  '-p+[override chart version]:version' \
  '--version=[override chart version]:version' \
  '-u+[override HTTP basic auth username]:username' \
  '--username=[override HTTP basic auth username]:username' \
  '-P+[override HTTP basic auth password]:password' \
  '--password=[override HTTP basic auth password]:password' \
  '-t+[override access token]:token' \
  '--access-token=[override access token]:token' \
  '--auth-header=[alternative HTTP auth header]:header' \
  '1:chart:_files' \
  '2:repository name'
