#compdef imapsync

# Zsh completion for imapsync - IMAP mailbox synchronization

_arguments -s -S \
  '--host1=[source IMAP server]:host:_hosts' \
  '--port1=[source port]:port:' \
  '--user1=[source username]:user:' \
  '--password1=[source password]:password:' \
  '--passfile1=[source password file]:file:_files' \
  '--authuser1=[source authentication user]:user:' \
  '--ssl1[use SSL for source]' \
  '--tls1[use TLS for source]' \
  '--host2=[destination IMAP server]:host:_hosts' \
  '--port2=[destination port]:port:' \
  '--user2=[destination username]:user:' \
  '--password2=[destination password]:password:' \
  '--passfile2=[destination password file]:file:_files' \
  '--authuser2=[destination authentication user]:user:' \
  '--ssl2[use SSL for destination]' \
  '--tls2[use TLS for destination]' \
  '--folder=[sync only this folder]:folder:' \
  '--exclude=[exclude folders matching regex]:regex:' \
  '--include=[include folders matching regex]:regex:' \
  '--subfolder2=[sync to subfolder]:subfolder:' \
  '--prefix1=[prefix for source folders]:prefix:' \
  '--prefix2=[prefix for destination folders]:prefix:' \
  '--sep1=[source folder separator]:separator:' \
  '--sep2=[destination folder separator]:separator:' \
  '--delete[delete on destination what is not on source]' \
  '--delete2[delete messages on destination not on source]' \
  '--delete2folders[delete folders on destination not on source]' \
  '--expunge[expunge deleted messages on source]' \
  '--expunge1[expunge deleted messages on source]' \
  '--expunge2[expunge deleted messages on destination]' \
  '--dry[dry run]' \
  '--maxage=[sync only messages newer than N days]:days:' \
  '--minage=[sync only messages older than N days]:days:' \
  '--maxsize=[skip messages larger than N bytes]:bytes:' \
  '--minsize=[skip messages smaller than N bytes]:bytes:' \
  '--maxlinelength=[max line length]:length:' \
  '--useuid[use UID for matching]' \
  '--nofoldersizes[do not compute folder sizes]' \
  '--justfolders[only create folders, do not sync messages]' \
  '--justfoldersizes[only display folder sizes]' \
  '--justconnect[just connect and disconnect]' \
  '--justlogin[just login and logout]' \
  '--logfile=[log file]:file:_files' \
  '--logdir=[log directory]:directory:_files -/' \
  '--debug[enable debug output]' \
  '--debugimap[enable IMAP debug]' \
  '--version[show version]' \
  '--help[show help]'
