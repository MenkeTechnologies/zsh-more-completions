#compdef netdatacli
# Documentation: https://learn.netdata.cloud/docs/netdata-agent/agent-cli
# Netdata Agent command line control interface

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'help:display usage information and exit'
      'reload-health:reload the health configuration'
      'reload-labels:reload host labels from netdata.conf'
      'reopen-logs:close and reopen log files'
      'shutdown-agent:gracefully shut down the Netdata Agent'
      'fatal-agent:log current state and forcefully halt the Agent'
      'reload-claiming-state:reload the Agent claiming state from disk'
      'ping:verify whether the Agent is ready (outputs pong)'
      'aclk-state:return the current state of ACLK and Cloud connection'
      'dumpconfig:display the current netdata.conf configuration'
      'mark-stale-nodes-ephemeral:mark disconnected nodes as ephemeral'
      'remove-stale-node:remove disconnected nodes from availability'
      'version:display the Netdata Agent version'
    )
    _describe -t commands 'netdatacli command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      aclk-state)
        _values 'format' 'json[return state in JSON]' && ret=0
        ;;
    esac
    ;;
esac

return ret
