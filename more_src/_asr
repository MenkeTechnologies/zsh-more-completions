#compdef asr
# Documentation: https://www.unix.com/man-page/osx/8/asr/
# Source: Apple macOS — Apple Software Restore (disk-image / volume cloner + multicast server).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'restore:restore a disk image or volume to another volume'
            'restoreexact:restore and resize target partition to match source size'
            'server:multicast source over the network'
            'imagescan:checksum data in the image and store in the image'
            'help:print usage'
            'version:print version'
        )
        _describe -t subcmds 'asr command' subcmds && ret=0
        ;;
    args)
        _arguments \
            '--source=[source disk image / volume / network location]:src:_files' \
            '--target=[destination volume / device]:target:_files' \
            '--file=[local file/dir for multicast restore output]:path:_files' \
            '--erase[erase target (required)]' \
            '--config=[server config plist]:plist:_files' \
            '--format=[destination filesystem]:fmt:(HFS+ HFSX APFS)' \
            '--noprompt[skip erasure confirmation prompt]' \
            '--timeout=[multicast client wait timeout]:seconds:' \
            '--puppetstrings[machine-parseable progress output]' \
            '--noverify[skip post-restore verification]' \
            '--allowfragmentedcatalog[allow restore from fragmented source catalog]' \
            '--corestorageconvert[convert target to CoreStorage LVG]' \
            '--buffers=[buffer count]:n:' \
            '--buffersize=[buffer size]:size:' \
            '--csumbuffers=[checksum buffer count]:n:' \
            '--csumbuffersize=[checksum buffer size]:size:' \
            '--verbose[verbose progress + errors]' \
            '--debug[diagnostic messages]' \
            '--nostream[bypass multicast reorder checks for disk images]' \
            '--interface=[network interface for multicasting]:iface:_net_interfaces' \
            '*:file:_files' \
            && ret=0
        ;;
esac

return ret
