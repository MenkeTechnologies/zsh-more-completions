#compdef topcat
# Documentation: https://www.star.bris.ac.uk/mbt/topcat/sun253/topcatArgs.html
# Reference accessed: 2026-05-27
# Verified: upstream TOPCAT User Guide SUN/253 section 10.1 (Command-line Arguments)

local curcontext="$curcontext" state line ret=1

local -a _topcat_formats
_topcat_formats=(
  fits
  fits-plus
  fits-basic
  votable
  ascii
  csv
  tst
  ipac
  wdc
  cdf
  ecsv
  feather
  parquet
  gbin
  mrt
)

_arguments -C \
  '(- *)'{-h,-help}'[print usage message and exit]' \
  '(- *)-version[print version information and exit]' \
  '*'{-v,-verbose}'[increase logging verbosity (repeatable)]' \
  '-debug[add source location info to log messages]' \
  '-demo[start with demonstration tables loaded]' \
  '-running[load tables into existing TOPCAT instance if available]' \
  '-memory[store all table data in memory]' \
  '-disk[store all table data in temporary disk files]' \
  '-samp[force SAMP protocol for tool interoperability]' \
  '-plastic[use PLASTIC instead of SAMP]' \
  '-hub[run internal SAMP/PLASTIC hub if none exists]' \
  '-nohub[do not run an internal hub]' \
  '-exthub[run external SAMP/PLASTIC hub in separate window]' \
  '-noserv[disable all SAMP/PLASTIC services]' \
  '-nocheckvers[do not check for latest version on startup]' \
  '-memgui[display memory usage window]' \
  '-bench[print task execution time]' \
  '-stilts[run STILTS command-line tool instead of TOPCAT]' \
  '-jsamp[run JSAMP command-line tool instead of TOPCAT]' \
  '-tree[start with tree-load window open]' \
  '-file[treat following arguments as filenames]' \
  '*-f+[set file format for following table arguments]:format:('"${_topcat_formats[*]}"')' \
  '*:table:_files' && ret=0

return ret
