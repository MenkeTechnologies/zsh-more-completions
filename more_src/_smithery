#compdef smithery
# Documentation: https://github.com/smithery-ai/cli
# Reference accessed: 2026-05-17
# Verified: smithery-ai/cli upstream README.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated mcp/tool/skill/auth/namespace subcommand tree (real
# upstream subcommands are install/run/inspect/list/login/dev/build).

# smithery: Smithery MCP server registry CLI
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'install:install an MCP server package'
  'run:run an MCP server'
  'inspect:inspect an MCP server'
  'list:list (clients)'
  'login:authenticate'
  'dev:start dev mode'
  'build:build for distribution'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'smithery command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          ':package:' \
          '--client=[MCP client]:client:' \
          '--config=[JSON config]:json:' && ret=0
        ;;
      (run)
        _arguments \
          ':package:' \
          '--config=[JSON config]:json:' && ret=0
        ;;
      (inspect)
        _arguments ':package:' && ret=0
        ;;
      (list)
        _arguments '1:resource:(clients)' && ret=0
        ;;
    esac
    ;;
esac
return ret
