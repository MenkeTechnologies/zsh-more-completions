#compdef smithery

_smithery() {
    local line state
    local -a commands
    commands=(
        'mcp:Manage MCP servers and connections'
        'tool:List, find, and execute tools'
        'skill:Manage agent skills'
        'auth:Authentication and session management'
        'namespace:Switch between environments'
    )

    _arguments -C \
        '--help[Show help]' \
        '--json[Output results in JSON format]' \
        '--verbose[Show detailed logs]' \
        '--table[Force output into a table format]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'smithery command' commands
            ;;
        args)
            case $line[1] in
                mcp)
                    _arguments '1:subcommand:(search add list remove publish)' '2: :->mcp_args'
                    ;;
                tool)
                    _arguments '1:subcommand:(list find get call)' '2: :->tool_args'
                    ;;
                skill)
                    _arguments '1:subcommand:(search add)' '2: :->skill_args'
                    ;;
                auth)
                    _arguments '1:subcommand:(login whoami token)'
                    ;;
                namespace)
                    _arguments '1:subcommand:(use)' '2:namespace name:'
                    ;;
            esac
            ;;
    esac
}

_smithery "$@"
