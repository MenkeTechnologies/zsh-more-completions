#compdef hook-injector
# _hook-injector — containerd NRI sample plugin: injects OCI runtime hooks from /etc/containers/oci/hooks.d into containers
# upstream: https://github.com/containerd/nri
# Flags from plugins/hook-injector/hook-injector.go on tip.

_hook-injector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket-path=[path of the NRI socket file]:socket:_files' \
        '--verbose[enable verbose logging]' \
        '--disableWatch[do not watch hook directories for new hooks]'
}

_hook-injector "$@"
