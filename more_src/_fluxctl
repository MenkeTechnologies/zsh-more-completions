#compdef fluxctl

# Zsh completion for fluxctl - Flux v1 CLI for managing Flux deployments

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'list-workloads:List workloads currently running in the cluster'
  'list-images:Show deployed and available images'
  'release:Release a new version of a workload'
  'automate:Turn on automatic deployment for a workload'
  'deautomate:Turn off automatic deployment for a workload'
  'lock:Lock a workload to prevent deployment'
  'unlock:Unlock a workload to allow deployment'
  'policy:Manage policies for a workload'
  'sync:Synchronize the cluster with the git repository'
  'save:Save workload definitions to local files'
  'identity:Display the cluster identity public key'
  'version:Print version information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--url=[base URL of the Flux API]:url' \
  '(-t --token)'{-t,--token}'[Weave Cloud authentication token]:token' \
  '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
  '--context=[kubectl context to use]:context' \
  '--timeout=[timeout for API requests]:duration' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'fluxctl command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      list-workloads)
        _arguments \
          '(-a --all-namespaces)'{-a,--all-namespaces}'[list across all namespaces]' \
          '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' && ret=0
        ;;
      list-images)
        _arguments \
          '(-w --workload)'{-w,--workload}'[show images for this workload]:workload' \
          '(-n --namespace)'{-n,--namespace}'[namespace]:namespace' \
          '(-l --limit)'{-l,--limit}'[number of images to show]:limit' && ret=0
        ;;
      release)
        _arguments \
          '(-w --workload)'{-w,--workload}'[release this workload]:workload' \
          '--all[release all workloads]' \
          '--update-image=[update a specific image]:image' \
          '--update-all-images[update all images to latest]' \
          '--force[disregard locks and policies]' \
          '--dry-run[do not release]' && ret=0
        ;;
      automate|deautomate|lock|unlock)
        _arguments \
          '(-w --workload)'{-w,--workload}'[workload to manage]:workload' && ret=0
        ;;
      policy)
        _arguments \
          '(-w --workload)'{-w,--workload}'[workload to manage]:workload' \
          '--tag-all=[set tag filter for all containers]:filter' \
          '--tag=[set tag filter for specific container]:container=filter' && ret=0
        ;;
    esac
    ;;
esac

return ret
