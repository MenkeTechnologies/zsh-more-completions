#compdef dgen dgen-sdl
# Documentation: https://man.archlinux.org/search?q=dgen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-r+[load rc file]:file:_files' \
  '-n+[non-interactive]:n:' \
  '-p+[CPU emulator]:p:(musa cyclone star debug)' \
  '-R+[region code]:r:(U J E B X)' \
  '-N[NTSC mode]' \
  '-P[PAL mode]' \
  '-d+[debug level]:n:' \
  '-D+[debug graphics]:n:' \
  '-s+[load state]:n:' \
  '-c+[load checksum]:file:_files' \
  '-C+[no debug]:b:(0 1)' \
  '-m+[main loop ms]:n:' \
  '-S+[snd freq Hz]:n:' \
  '-X+[X scale]:n:' \
  '-Y+[Y scale]:n:' \
  '*: :_files -g "*.bin *.gen *.smd *.md *.zip *.gz"' && ret=0

return ret
