#compdef cuyo
# Documentation: https://manpages.debian.org/bookworm/cuyo/cuyo.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm cuyo(6) manpage. NOTE: --version here
# selects level versions (comma-separated), NOT print-and-exit.
# Removed from prior file: bogus man.archlinux.org search URL.

# cuyo: pixel-puzzle game similar to Tetris
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h -\?)-h[show help]' \
  '(-h -\?)-\?[show help]' \
  '-d[debug mode]' \
  '-f[fullscreen]' \
  '-g[window size WxH]:size:' \
  '--version=[activate level versions]:versions:' \
  '*:level file:_files -g "*.ld(-.)"' && ret=0
return ret
