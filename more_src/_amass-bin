#compdef amass
# _amass-bin — OWASP Amass attack surface mapping (Jeff Foley, Go); subdomain enumeration + network mapping for authorized recon
# upstream: https://github.com/owasp-amass/amass

_amass-bin() {
    local -a sub=(
        'intel:gather OSINT intelligence'
        'enum:enumerate DNS subdomains'
        'viz:visualize Amass graph'
        'track:track changes in graph'
        'db:query the Amass database'
        'subdomains:list subdomains'
        'assoc:list associations'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amass subcommand' sub ;;
        args)
            case $words[1] in
                enum) _arguments \
                    '-active[active enumeration]' \
                    '-passive[passive only]' \
                    '-brute[brute force]' \
                    '-d+[domain]:domain:' \
                    '-df+[domains file]:file:_files' \
                    '-config+[config file]:file:_files' \
                    '-r+[resolvers file]:file:_files' \
                    '-w+[wordlist file]:file:_files' \
                    '-rf+[resolvers file]:file:_files' \
                    '-trf+[trusted resolvers file]:file:_files' \
                    '-bl+[blacklist file]:file:_files' \
                    '-aw+[alt wordlist]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '-dir+[graph dir]:dir:_files -/' \
                    '-json+[json output]:file:_files' \
                    '-log+[log file]:file:_files' \
                    '-min-for-recursive+[min names for recursive]:n:' \
                    '-max-dns-queries+[max DNS queries/sec]:n:' \
                    '-rdns+[reverse DNS dir]:dir:_files -/' \
                    '-src[show data sources]' \
                    '-silent[silent]' \
                    '-timeout+[run timeout min]:n:' ;;
                intel) _arguments \
                    '-active[active intel]' \
                    '-config+[config file]:file:_files' \
                    '-d+[domain]:domain:' \
                    '-df+[domains file]:file:_files' \
                    '-org+[organization]:org:' \
                    '-asn+[ASN]:asn:' \
                    '-cidr+[CIDR]:cidr:' \
                    '-o+[output file]:file:_files' \
                    '-whois[lookup WHOIS]' ;;
                db) _arguments \
                    '-d+[domain]:domain:' \
                    '-config+[config file]:file:_files' \
                    '-dir+[graph dir]:dir:_files -/' \
                    '-list[list events]' \
                    '-names[show names]' \
                    '-show[show events]' \
                    '-summary[show summary]' \
                    '-json+[json output]:file:_files' ;;
            esac
            ;;
    esac
}

_amass-bin "$@"
