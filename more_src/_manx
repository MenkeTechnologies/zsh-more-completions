#compdef manx

_manx() {
    local line state
    local -a commands
    commands=(
        'init:Run the interactive setup wizard'
        'search:Search official documentation'
        'doc:Read specific documentation (e.g., numpy@2 "broadcasting")'
        'snippet:Get code examples'
        'index:Index local notes or crawl a website'
        'update:Update the tool and its local models'
        'help:Print help message'
    )

    _arguments -C \
        '--pick[Use interactive TUI picker]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'manx command' commands
            ;;
        args)
            case $line[1] in
                doc)
                    _arguments \
                        '1:library@version:' \
                        '2:topic:'
                    ;;
                snippet)
                    _arguments \
                        '1:library:' \
                        '2:topic:'
                    ;;
                index)
                    _arguments \
                        '1:path or URL:_files'
                    ;;
                search)
                    _arguments \
                        '*:query:'
                    ;;
            esac
            ;;
    esac
}

_manx "$@"
