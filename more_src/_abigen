#compdef abigen

_arguments -s \
  '--abi=[ABI JSON path]:file:_files -g "*.json"' \
  '--bin=[bytecode path]:file:_files' \
  '--type=[binding struct name]:name:' \
  '--combined-json=[combined-json file]:file:_files' \
  '--exc=[types to exclude]:list:' \
  '--pkg=[Go package name]:name:' \
  '--out=[output file]:file:_files' \
  '--alias=[func/event renames]:list:' \
  '--v2[generate v2 bindings]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
