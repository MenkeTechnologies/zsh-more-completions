#compdef canu
# Documentation: https://canu.readthedocs.io/en/latest/quick-start.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Canu: long-read assembler for Nanopore/PacBio
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-citation[show citations]' \
  '-p[prefix for output files]:prefix:' \
  '-d[output directory]:dir:_files -/' \
  '-correct[only run correction stage]' \
  '-trim[run trimming stage only]' \
  '-assemble[run assembly stage only]' \
  '-trim-assemble[run trim+assemble (skip correction)]' \
  '-haplotype[haplotype-resolved assembly]' \
  '-pacbio[PacBio CLR reads]:file:_files' \
  '-pacbio-hifi[PacBio HiFi reads]:file:_files' \
  '-nanopore[Nanopore reads]:file:_files' \
  '-nanopore-corrected[pre-corrected Nanopore reads]:file:_files' \
  '-pacbio-corrected[pre-corrected PacBio reads]:file:_files' \
  '-pacbio-raw[raw PacBio reads]:file:_files' \
  '-nanopore-raw[raw Nanopore reads]:file:_files' \
  'genomeSize=[expected genome size (e.g. 4.6m, 3g)]:size:' \
  'rawErrorRate=[expected error rate of raw reads]:rate:' \
  'correctedErrorRate=[expected error rate after correction]:rate:' \
  'minReadLength=[discard reads shorter than this]:n:' \
  'minOverlapLength=[minimum overlap length]:n:' \
  'corOutCoverage=[output coverage of corrected reads]:n:' \
  'corMinCoverage=[minimum coverage required to correct a base]:n:' \
  'useGrid=[use a grid scheduler]:bool:(true false)' \
  'gridOptions=[options to pass to grid scheduler]:opts:' \
  'gridEngineMemoryPerJob=[memory per job]:val:' \
  'gridEngineThreadsPerJob=[threads per job]:n:' \
  '*:assembly options:_files' && ret=0
return ret
