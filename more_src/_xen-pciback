#compdef xen-pciback
# Documentation: https://man.archlinux.org/search?q=xen-pciback
# Reference accessed: 2026-05-16

# xen-pciback: Xen helper to back PCI devices to driver domains
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::xen-pciback args:_files' && ret=0
return ret
