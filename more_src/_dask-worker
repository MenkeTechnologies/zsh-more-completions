#compdef dask-worker
# Documentation: https://docs.dask.org/en/stable/deploying-cli.html
# dask-worker - launch a Dask distributed worker process

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--tls-ca-file=[CA cert(s) file for TLS in PEM format]:file:_files' \
  '--tls-cert=[certificate file for TLS in PEM format]:file:_files' \
  '--tls-key=[private key file for TLS in PEM format]:file:_files' \
  '--worker-port=[serving computation port, defaults to random]:port' \
  '--nanny-port=[serving nanny port, defaults to random]:port' \
  '--dashboard-address=[address on which to listen for diagnostics dashboard]:address' \
  '--dashboard[launch the dashboard]' \
  '--no-dashboard[do not launch the dashboard]' \
  '--listen-address=[the address to which the worker binds]:address' \
  '--contact-address=[the address the worker advertises to the scheduler]:address' \
  '--host=[serving host, ip address visible to the scheduler and workers]:host' \
  '--interface=[network interface like eth0 or ib0]:interface' \
  '--protocol=[protocol like tcp, tls, or ucx]:protocol:(tcp tls ucx)' \
  '--nthreads=[number of threads per process]:threads' \
  '--nworkers=[number of worker processes to launch]:n' \
  '--name=[a unique name for this worker]:name' \
  '--memory-limit=[bytes of memory per process the worker can use]:limit' \
  '--nanny[start workers in nanny process for management]' \
  '--no-nanny[do not start workers in nanny process]' \
  '--pid-file=[file to write the process PID]:file:_files' \
  '--local-directory=[directory to place worker files]:dir:_files -/' \
  '--resources=[resources for task constraints like GPU=2 MEM=10e9]:resources' \
  '--scheduler-file=[filename to JSON encoded scheduler information]:file:_files' \
  '--death-timeout=[seconds to wait for a scheduler before closing]:seconds' \
  '--dashboard-prefix=[prefix for the dashboard]:prefix' \
  '--lifetime=[shut down the worker after this duration]:duration' \
  '--lifetime-stagger=[random amount by which to stagger lifetime values]:stagger' \
  '--lifetime-restart[restart the worker after the lifetime lapses]' \
  '--no-lifetime-restart[do not restart the worker after lifetime lapses]' \
  '--worker-class=[worker class used to instantiate workers from]:class' \
  '--preload=[module that should be loaded by each worker process]:module' \
  '--preload-nanny=[module that should be loaded by each nanny]:module' \
  '--scheduler-sni=[scheduler SNI if different from scheduler hostname]:sni' \
  '*:scheduler address:' && ret=0

return ret
