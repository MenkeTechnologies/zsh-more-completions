#compdef pinecone
# Documentation: https://man.archlinux.org/search?q=pinecone
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate'
  'logout:log out'
  'whoami:show current user'
  'organization:organization commands'
  'project:project commands'
  'index:index commands'
  'collection:collection commands'
  'api-key:API key commands'
  'config:CLI config'
  'completion:generate completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--api-key=[API key]:k:' \
  '*--json[JSON output]' \
  '*--profile=[profile]:p:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pinecone command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (index)
        _arguments \
          '1:subcommand:(create create-serverless create-pod delete describe list configure)' \
          '*: :' && ret=0 ;;
      (collection)
        _arguments \
          '1:subcommand:(create delete describe list)' \
          '*: :' && ret=0 ;;
      (project)
        _arguments \
          '1:subcommand:(create delete describe list update)' \
          '*: :' && ret=0 ;;
      (organization)
        _arguments \
          '1:subcommand:(list describe set)' \
          '*: :' && ret=0 ;;
      (api-key)
        _arguments \
          '1:subcommand:(create delete list rotate)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(get set unset list)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
