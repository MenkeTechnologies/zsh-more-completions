#compdef phenix.real_space_refine
# Documentation: https://phenix-online.org/documentation/reference/real_space_refine.html
# phenix.real_space_refine - refine a model against a real-space map (supplementary)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'resolution=[map resolution (required for CCP4 maps)]:val:' \
  'nproc=[number of processors]:n:' \
  'macro_cycles=[number of refinement iterations]:n:' \
  'weight=[manual data-to-restraints weighting]:val:' \
  'run=[refinement methods]:method:(minimization_global rigid_body local_grid_search morphing simulated_annealing adp occupancy)' \
  'target_bonds_rmsd=[desired bond deviation from ideal]:val:' \
  'target_angles_rmsd=[desired angle deviation from ideal]:val:' \
  'rotamer_restraints=[enable/disable rotamer fitting]:bool:(True False)' \
  'ramachandran_restraints=[enable/disable Ramachandran restraints]:bool:(True False)' \
  'c_beta_restraints=[enable/disable C-beta deviation restraints]:bool:(True False)' \
  'ncs_constraints=[enable/disable NCS constraints]:bool:(True False)' \
  'refine_ncs_operators=[refine NCS operators during refinement]:bool:(True False)' \
  'secondary_structure.enabled=[activate secondary structure restraints]:bool:(True False)' \
  'label=[Fourier map coefficients to use]:labels:' \
  'reference_coordinate_restraints.enabled=[restrain to starting coordinates]:bool:(True False)' \
  'reference_coordinate_restraints.selection=[atom selection for coordinate restraints]:sel:' \
  'reference_coordinate_restraints.sigma=[weighting for coordinate restraints]:val:' \
  '*:file:_files' && ret=0

return ret
