#compdef checktrans

# EMBOSS checktrans: check protein translation for internal stop codons / ORFs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-orfml=[minimum ORF length]:length:' \
  '-addlast[mark last residue as stop if it is M (start)]' \
  '-outseq=[ORF sequence output file]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '-outfeat=[features output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
