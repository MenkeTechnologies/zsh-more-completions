#compdef control.sh control-utility

_arguments -s \
  '(- *)--help[show help]' \
  '--host=[host]:host:_hosts' \
  '--port=[port]:port:' \
  '--user=[username]:user:_users' \
  '--password=[password]:password:' \
  '--ping-interval=[ping interval]:ms:' \
  '--ping-timeout=[ping timeout]:ms:' \
  '--ssl-protocol=[SSL protocol]:proto:' \
  '--ssl-cipher-suites=[SSL cipher suites]:list:' \
  '--ssl-key-algorithm=[SSL key algorithm]:alg:' \
  '--keystore-type=[keystore type]:type:(JKS PKCS12)' \
  '--keystore=[keystore]:file:_files' \
  '--keystore-password=[keystore password]:password:' \
  '--truststore-type=[truststore type]:type:(JKS PKCS12)' \
  '--truststore=[truststore]:file:_files' \
  '--truststore-password=[truststore password]:password:' \
  '--ssl-factory=[SSL factory class]:class:' \
  '--verbose[verbose output]' \
  '--yes[skip confirmation]' \
  '--auto-confirmation[skip confirmation]' \
  '--enable-experimental[enable experimental commands]' \
  '--activate[activate the cluster (deprecated)]' \
  '--deactivate[deactivate the cluster (deprecated)]' \
  '--state[show cluster state]' \
  '--set-state=[set cluster state]:state:(ACTIVE INACTIVE ACTIVE_READ_ONLY)' \
  '--baseline[baseline operations]' \
  '--tx[transaction operations]' \
  '--cache[cache operations]' \
  '--metric[metric operations]' \
  '--system-view[query system views]' \
  '--tracing-configuration[configure tracing]' \
  '--change-tag[change cluster tag]' \
  '--consistency[consistency check operations]' \
  '--snapshot[snapshot operations]' \
  '--persistence[persistence operations]' \
  '--defragmentation[defragmentation operations]' \
  '--performance-statistics[performance statistics operations]' \
  '--property[node property operations]' \
  '--shutdown-policy[shutdown policy operations]' \
  '--warm-up[warm-up operations]' \
  '--kill[kill operations]' \
  '--diagnostic[diagnostic operations]' \
  '*:arg:'
