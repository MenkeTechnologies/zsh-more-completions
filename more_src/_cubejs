#compdef cubejs
# Documentation: https://cube.dev/docs/reference/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cubejs-cli npm package ships the `cubejs` (and `cubejs-cli`) binary.
# Subcommands: create, generate, validate, token, deploy.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:scaffold a new Cube app'
  'generate:generate data models from database tables'
  'validate:validate project models'
  'token:generate a JWT Cube API token'
  'deploy:deploy a Cube app to Cube Cloud'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cubejs command' commands && ret=0
    ;;
  args)
    case $words[1] in
      create)
        _arguments -s \
          '(-d --db-type)'{-d,--db-type}'[database type]:type:(postgres mysql athena bigquery snowflake mssql redshift mongobi clickhouse druid elasticsearch hive oracle prestodb questdb sqlite firebolt ksql materialize crate)' \
          '(-t --template)'{-t,--template}'[framework template]:template:(docker express serverless serverless-aws)' \
          '*:project name:' && ret=0
        ;;
      token)
        _arguments -s \
          '(-e --expiry)'{-e,--expiry}'[token duration]:duration:' \
          '(-s --secret)'{-s,--secret}'[Cube app secret]:secret:' \
          '*'{-p,--payload}'[payload key=value]:payload:' && ret=0
        ;;
      deploy)
        _arguments -s \
          '--token=[Cube Cloud auth token]:token:' \
          '--directory=[project directory]:dir:_files -/' \
          '--upload-env=[upload env vars from file]:file:_files' \
          '--replace-env=[replace env vars from file]:file:_files' && ret=0
        ;;
      generate)
        _arguments -s \
          '(-t --tables)'{-t,--tables}'[comma-delimited tables]:tables:' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
