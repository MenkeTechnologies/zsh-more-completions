#compdef grails-forge-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create-app:create a new Grails application'
  'create-plugin:create a new Grails plugin'
  'create-profile:create a new Grails profile'
  'feature-info:show feature info'
  'list-features:list available features'
  'list-profiles:list available profiles'
  'profile-info:show profile info'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose output]' \
  '*--features=[features to apply]:feature:' \
  '--lang=[language]:lang:(java groovy kotlin)' \
  '--build=[build tool]:tool:(gradle gradle_kotlin maven)' \
  '--test=[test framework]:framework:(junit spock)' \
  '--javaVersion=[Java version]:version:(11 17 21)' \
  '--inplace[use current directory]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'grails-forge-cli subcommand' subcommands && ret=0
    ;;
esac

return ret
