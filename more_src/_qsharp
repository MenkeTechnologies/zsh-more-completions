#compdef qsc qsharp qsharp-cli
# _qsharp — Microsoft Q# programming language compiler and runtime for the Azure Quantum Development Kit (microsoft team, Rust); clap-derive
# upstream: https://github.com/microsoft/qsharp

_qsharp() {
    local -a sub=(
        'new:create a new Q# project'
        'build:build a Q# project'
        'run:run a Q# program'
        'check:check a Q# program for errors'
        'fmt:format Q# code'
        'doc:generate Q# documentation'
        'init:initialize a Q# project'
        'add:add a Q# dependency'
        'remove:remove a Q# dependency'
        'update:update dependencies'
        'install:install a Q# package'
        'submit:submit job to Azure Quantum'
        'qir:emit QIR'
        'estimate:run resource estimation'
        'simulate:simulate a Q# program'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--target=+[target profile]:t:(adaptive_ri adaptive_rif unrestricted base)' \
        '--language-features=+[features csv]:str:' \
        '--package-type=+[type]:t:(exe lib)' \
        '--manifest-path=+[manifest path]:file:_files -g "qsharp.json *.json"' \
        '--manifest=+[manifest path]:file:_files -g "qsharp.json *.json"' \
        '--package-name=+[name]:str:' \
        '--workspace=+[workspace dir]:dir:_files -/' \
        '--target-arch=+[arch]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qsharp subcommand' sub ;;
        args)
            case $words[1] in
                new|init) _arguments \
                    '--template=+[template]:t:(default lib exe)' \
                    '*:name:_files -/' ;;
                run|simulate|estimate|qir) _arguments \
                    '--shots=+[N]:n:' \
                    '--entry=+[entry expression]:str:' \
                    '--seed=+[seed]:n:' \
                    '--logical-depth-factor=+[F]:f:' \
                    '*:program:_files -g "*.qs *.qsproj qsharp.json"' ;;
                check|fmt|build) _arguments '*:source:_files -g "*.qs qsharp.json"' ;;
                submit) _arguments \
                    '--workspace-id=+[Azure workspace]:str:' \
                    '--resource-group=+[resource group]:str:' \
                    '--subscription-id=+[subscription]:str:' \
                    '--target-id=+[Azure target id]:str:' \
                    '*:program:_files -g "*.qs qsharp.json"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_qsharp "$@"
