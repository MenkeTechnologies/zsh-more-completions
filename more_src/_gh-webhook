#compdef gh-webhook
# Documentation: https://docs.github.com/en/webhooks/testing-and-troubleshooting-webhooks/using-the-github-cli-to-forward-webhooks-for-testing
# gh-webhook - GitHub CLI extension to forward webhooks for local testing

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(forward)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      forward)
        _arguments -s -S \
          '(-E --events)'{-E,--events}'=[names of event types to forward, "*" for all]:events:' \
          '(-R --repo)'{-R,--repo}'=[name of the repo where the webhook is installed]:repo:' \
          '(-U --url)'{-U,--url}'=[address of the local server to receive events]:url:' \
          '--org=[listen for organization webhooks instead of repository]:org:' \
          '(-H --github-host)'{-H,--github-host}'=[GitHub host name]:host:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
