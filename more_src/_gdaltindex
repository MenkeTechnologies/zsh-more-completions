#compdef gdaltindex
# Documentation: https://gdal.org/programs/gdaltindex.html
# Reference accessed: 2026-05-16
# Verified: upstream GDAL docs for gdaltindex.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# gdaltindex: build a tile index for a set of raster datasets
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-general[show general help]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '-overwrite[overwrite existing index]' \
  '-recursive[recurse into subdirectories]' \
  '-filename_filter[filename glob filter]:pattern:' \
  '-min_pixel_size[minimum pixel size]:size:' \
  '-max_pixel_size[maximum pixel size]:size:' \
  '-of[output format]:format:' \
  '-tileindex[tile index field name]:name:' \
  '-write_absolute_path[store absolute paths]' \
  '-skip_different_projection[skip rasters with different SRS]' \
  '-t_srs[target SRS]:srs:' \
  '-src_srs_name[source SRS field name]:name:' \
  '-src_srs_format[source SRS format]:format:(AUTO WKT EPSG PROJ)' \
  '-lyr_name[output layer name]:name:' \
  '*-lco[layer creation option]:option:' \
  '-gti_filename[GTI sidecar filename]:file:_files' \
  '-tr[target resolution xres yres]:res:' \
  '-te[target extent xmin ymin xmax ymax]:extent:' \
  '-ot[output data type]:type:' \
  '-bandcount[number of bands]:n:' \
  '-nodata[nodata value]:value:' \
  '-colorinterp[color interpretation]:interp:' \
  '-mask[mask band specifier]:spec:' \
  '*-mo[metadata key=value]:metadata:' \
  '-fetch_md[fetch metadata]:md:' \
  '1:output index:_files' \
  '*:raster:_files' && ret=0
return ret
