#compdef emmax
# Documentation: https://genome.sph.umich.edu/wiki/EMMAX
# EMMAX mixed-model GWAS association test accounting for sample structure

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose mode]' \
  '-d[precision of values]:digits' \
  '-t[tped/tfam file prefix]:prefix:_files' \
  '-p[phenotype file]:file:_files' \
  '-c[covariate file]:file:_files' \
  '-k[kinship matrix file]:file:_files' \
  '-o[output file prefix]:prefix:_files' \
  '*:tped prefix:_files' && ret=0

return ret
