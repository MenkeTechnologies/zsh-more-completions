#compdef rslib
# Documentation: https://lib.rsbuild.rs
# Source: https://github.com/web-infra-dev/rslib/blob/main/packages/core/src/cli/commands.ts
# Reference accessed: 2026-06-01
# Rsbuild-based library development tool (ESM/CJS/UMD/MF/IIFE outputs).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _rsl_cmds
_rsl_cmds=(
    'build:build the library for production (default)'
    'inspect:inspect the Rsbuild/Rspack configs of the project'
    'mf-dev:start Rsbuild dev server in Module Federation format'
)

local _rsl_common=(
    '(-c --config)'{-c+,--config=}'[config file path]:file:_files'
    '--config-loader=[config loader]:loader:(auto jiti native)'
    '(-r --root)'{-r+,--root=}'[project root]:dir:_files -/'
    '--env-mode=[env mode for .env.<mode>]:mode:_default'
    '--env-dir=[directory for .env files]:dir:_files -/'
    '--log-level=[log level]:level:(info warn error silent)'
    '*--lib=[library id (repeatable)]:lib:_default'
    '--no-env[disable loading .env files]'
)

_arguments -C \
    $_rsl_common \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'rslib command' _rsl_cmds && ret=0
        ;;
    args)
        case $line[1] in
            build|"")
                _arguments -s -S $_rsl_common \
                    '(-w --watch)'{-w,--watch}'[watch and rebuild on changes]' \
                    '*--entry=[entry file or pattern (repeatable)]:entry:_files' \
                    '--dist-path=[output directory]:dir:_files -/' \
                    '--bundle[enable bundle mode]' \
                    '--no-bundle[disable bundle mode]' \
                    '--format=[output format]:format:(esm cjs umd mf iife)' \
                    '--syntax=[build syntax target]:syntax:_default' \
                    '--target=[runtime target]:target:(web node)' \
                    '--dts[emit declaration files]' \
                    '--no-dts[skip declaration files]' \
                    '*--externals=[external package (repeatable)]:pkg:_default' \
                    '--minify[minify output]' \
                    '--no-minify[disable minify]' \
                    '--clean[clean output dir before build]' \
                    '--no-clean[skip clean]' \
                    '--auto-extension[enable automatic extension redirect]' \
                    '--no-auto-extension[disable automatic extension redirect]' \
                    '--auto-external[automatic dep externalization]' \
                    '--no-auto-external[disable auto externalization]' \
                    '--tsconfig=[tsconfig path relative to root]:tsconfig:_files -g "tsconfig*.json"' \
                    && ret=0
                ;;
            inspect)
                _arguments -s -S $_rsl_common \
                    '--output=[inspect output path (default .rsbuild)]:dir:_files -/' \
                    '--verbose[show full function definitions]' \
                    && ret=0
                ;;
            mf-dev)
                _arguments -s -S $_rsl_common && ret=0
                ;;
        esac
        ;;
esac

return ret
