'-h[Print help]' \
'--help[Print help]' \
':system_config -- System configuration file to compare against:_files' \
&& ret=0
;;
(steamos)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':system_config -- System configuration file to compare against:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_uplare__subcmd__diff__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

