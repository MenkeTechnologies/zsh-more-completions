#compdef skabus-rpcc
# _skabus-rpcc — skabus skabus-rpcc (client-side rpcc bridge: maintains a session with a remote skabus-rpcd, hosts local interfaces, dispatches incoming requests to per-interface programs)
# upstream: https://github.com/skarnet/skabus
# Flags from src/rpc/skabus-rpcc.c on tip.

_skabus-rpcc() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-1[print local socket info on fd 1]' \
        '-c+[max simultaneous local connections]:n:' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '-C+[per-message dispatcher (prog:sep:flags)]:spec:' \
        '*-y+[register interface (ifname:ifprog:sep:flags)]:spec:' \
        '1:rpcd-path:_files' \
        '2:client-name:'
}

_skabus-rpcc "$@"
