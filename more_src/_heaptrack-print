#compdef heaptrack-print

# heaptrack-print: analyze a heaptrack.* file (memory profiling)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-p[print peak alloc backtrace]' \
  '--print-peaks[print peak alloc backtrace]' \
  '-a[print allocations backtrace]' \
  '--print-allocations[print allocations backtrace]' \
  '-l[print leak backtraces]' \
  '--print-leaks[print leak backtraces]' \
  '-T[print temporary allocations]' \
  '--print-temporary[print temporary allocations]' \
  '-A[print allocators]' \
  '--print-allocators[print allocators]' \
  '-S[print histogram]' \
  '--print-histogram=[print histogram]:file:_files' \
  '-c[skip C++ demangling]' \
  '--no-cpp-symbols[skip C++ demangling]' \
  '-i[suppress file]:file:_files' \
  '--suppressions=[suppress file]:file:_files' \
  '-d[disable embedded suppressions]' \
  '--disable-embedded-suppressions[disable embedded suppressions]' \
  '-m[merge backtraces]' \
  '--merge-backtraces[merge backtraces]' \
  '-f[print file table]' \
  '--print-files[print file table]' \
  '-w[print flamegraph data]:file:_files' \
  '--print-flamegraph=[print flamegraph data]:file:_files' \
  '-M[print massif output]:file:_files' \
  '--print-massif=[print massif output]:file:_files' \
  '-z[print to filename]:file:_files' \
  '--print-output=[print to filename]:file:_files' \
  '*:heaptrack file:_files -g "*.{gz,zst}"' && ret=0
return ret
