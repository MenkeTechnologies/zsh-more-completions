#compdef gpgconnect gpg-connect-agent
# _gpgconnect — GnuPG gpg-connect-agent communicate with gpg-agent assuan CLI (Werner Koch / GnuPG team, C); custom argparse
# upstream: https://github.com/gpg/gnupg

_gpgconnect() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-verbose[no verbose]' \
        '--no-history[no history]' \
        '--homedir=+[GnuPG home dir]:dir:_files -/' \
        '--agent-program=+[agent program]:file:_files' \
        '--dirmngr-program=+[dirmngr program]:file:_files' \
        '--keyboxd-program=+[keyboxd program]:file:_files' \
        '--dirmngr[connect to dirmngr]' \
        '--keyboxd[connect to keyboxd]' \
        '--uiserver[connect to ui server]' \
        '-S+[server type]:s:(agent dirmngr keyboxd uiserver)' \
        '--server=+[server type]:s:(agent dirmngr keyboxd uiserver)' \
        '--debug-name=+[debug name]:str:' \
        '--debug-flags=+[debug flags]:str:' \
        '--exec[execute commands directly]' \
        '-E[execute commands directly]' \
        '--no-ext-connect[no ext connect]' \
        '--no-autostart[no autostart]' \
        '--tcp-socket=+[TCP socket address]:str:' \
        '-c[hex command]' \
        '--raw-socket=+[raw socket]:file:_files' \
        '-r[reset]' \
        '--run=+[run commands from file]:file:_files' \
        '-R+[run commands from file]:file:_files' \
        '--subst[substitute env vars]' \
        '-s[subscribe]' \
        '*:assuan-command:'
}

_gpgconnect "$@"
