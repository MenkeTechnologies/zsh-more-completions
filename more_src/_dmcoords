#compdef dmcoords
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmcoords.html
# Convert between Chandra coordinate systems

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input dataset/block specification]:infile:_files' \
  'asolfile=[input aspect solution file]:asolfile:_files' \
  'option=[conversion option]:option:(cel sky det chip logical msc)' \
  'chip_id=[chip ID number]:chip_id:' \
  'chipx=[chip X pixel coordinate]:chipx:' \
  'chipy=[chip Y pixel coordinate]:chipy:' \
  'tdetx=[tiled detector X pixel]:tdetx:' \
  'tdety=[tiled detector Y pixel]:tdety:' \
  'detx=[focal plane X pixel]:detx:' \
  'dety=[focal plane Y pixel]:dety:' \
  'x=[sky plane X pixel]:x:' \
  'y=[sky plane Y pixel]:y:' \
  'logicalx=[X coordinate in binned image]:logicalx:' \
  'logicaly=[Y coordinate in binned image]:logicaly:' \
  'ra=[right ascension]:ra:' \
  'dec=[declination]:dec:' \
  'theta=[off-axis angle in arcminutes]:theta:' \
  'phi=[azimuthal angle in degrees]:phi:' \
  'order=[grating order]:order:' \
  'energy=[energy in keV]:energy:' \
  'wavelength=[wavelength in Angstroms]:wavelength:' \
  'celfmt=[RA/Dec format]:celfmt:(deg hms)' \
  'detector=[detector type]:detector:(ACIS HRC-I HRC-S)' \
  'grating=[grating name]:grating:(NONE HETG LETG)' \
  'geompar=[Pixlib geometry parameter file]:geompar:_files' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
