#compdef lastdb
# Documentation: https://gitlab.com/mcfrith/last/-/raw/main/doc/lastdb.rst
# Prepare sequences for fast alignment search with lastal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show all options and their default settings, and exit]' \
  '-p[interpret the sequences as proteins]' \
  '-c[soft-mask lowercase letters]' \
  '-u+[specify a seeding scheme]:name:' \
  '-P+[run this many threads in parallel]:threads:' \
  '-q[interpret sequences as proteins with a 21-letter alphabet]' \
  '-S+[specify which strand of the input DNA sequences should be prepared]:strand:' \
  '-R+[specify lowercase usage, by two digits]:digits:' \
  '-U+[maximum length of the repeating unit for tandem repeats]:length:' \
  '-w+[allow initial matches only at every STEP-th position]:step:' \
  '-W+[allow initial matches only at minimum positions in any window]:size:' \
  '-Q+[specify how to read the sequences]:name:' \
  '-s+[limit memory usage by splitting output into volumes]:bytes:' \
  '-m+[specify a spaced seed pattern]:pattern:' \
  '-d+[specify DNA seed patterns]:pattern:' \
  '-a+[specify your own alphabet]:symbols:' \
  '-i+[makes lastdb faster, limiting lastal options]:matches:' \
  '-b+[specify the maximum length for buckets, a lookup table]:length:' \
  '-B+[use the maximum possible bucket length]:fold:' \
  '-C+[specify the type of child table to make]:number:' \
  '-x[just count sequences and letters]' \
  '-D[read pre-existing lastdb files, and print all the sequences in them]' \
  '--bits=[use this many bits per base for DNA sequences]:n:' \
  '--circular[the sequences given to lastdb are circular]' \
  '-v[be verbose: write messages about what lastdb is doing]' \
  '(-V --version)'{-V,--version}'[show version information, and exit]' \
  '*:output name and fasta files:_files' && ret=0

return ret
