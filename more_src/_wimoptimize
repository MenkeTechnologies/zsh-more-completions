#compdef wimoptimize
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-optimize.1.html
# wimoptimize — optimize a WIM archive by rebuilding and recompressing

local ret=1

_arguments -s -S \
  '--check[verify integrity and include integrity info]' \
  '--nocheck[exclude extra integrity info from the optimized WIM]' \
  '--include-integrity[add integrity info without prior verification]' \
  '--recompress[recompress all data during optimization]' \
  '--compress=[recompress using specified type and optional level]:type:(none XPRESS LZX LZMS)' \
  '--chunk-size=[set WIM compression chunk size]:size' \
  '--solid[create a solid archive]' \
  '--solid-compress=[set compression type for solid resources]:type:(none XPRESS LZX LZMS)' \
  '--solid-chunk-size=[set chunk size for solid resources]:size' \
  '--threads=[number of compression threads]:threads' \
  '--pipable[rebuild WIM for sequential application from a pipe]' \
  '--not-pipable[rebuild WIM in non-pipable format]' \
  '--unsafe-compact[perform in-place compaction without a temp file]' \
  '*:WIM file:_files' && ret=0

return ret
