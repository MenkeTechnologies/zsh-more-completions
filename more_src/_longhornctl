#compdef longhornctl
# Documentation: https://github.com/longhorn/cli/blob/master/docs/longhornctl.md
# Longhorn CLI for preflighting, operating and troubleshooting Longhorn

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--image=[container image for longhornctl-local]:image' \
  '--image-pull-secret=[registry credentials for image retrieval]:secret' \
  '--image-registry=[registry to override images across components]:registry' \
  '--kubeconfig=[path to Kubernetes configuration file]:kubeconfig:_files' \
  '(-l --log-level)'{-l,--log-level=}'[logging verbosity]:level:(trace debug info warn error fatal panic)' \
  '--namespace=[Kubernetes namespace for DaemonSet pods]:namespace' \
  '--node-selector=[node label matching criteria for DaemonSet scheduling]:selector' \
  '--tolerations=[pod tolerations for node affinity]:tolerations' \
  '1:command:(check checksum doc export get global-options install trim version)' \
  '*::arg:_default' && ret=0

return ret
