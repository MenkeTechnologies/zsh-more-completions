#compdef blkid
# _blkid-bin — util-linux block device identifier; print FS UUID/LABEL/TYPE for partitions and image files
# upstream: https://github.com/util-linux/util-linux

_blkid-bin() {
    _arguments \
        '(-c --cache-file)'{-c,--cache-file}'+[cache file]:file:_files' \
        '(-d --no-encoding)'{-d,--no-encoding}'[no encoding for safe chars]' \
        '(-g --garbage-collect)'{-g,--garbage-collect}'[remove stale entries from cache]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-i --info)'{-i,--info}'[I/O Limits info]' \
        '(-k --list-filesystems)'{-k,--list-filesystems}'[list known FS]' \
        '(-l --list-one)'{-l,--list-one}'[look up first match for tags]' \
        '(-L --label)'{-L,--label}'+[find device by label]:label:' \
        '(-n --match-types)'{-n,--match-types}'+[match types]:types:' \
        '(-o --output)'{-o,--output}'+[output format]:format:(full value device export udev)' \
        '(-O --offset)'{-O,--offset}'+[offset]:n:' \
        '(-p --probe)'{-p,--probe}'[low-level probing mode]' \
        '(-s --match-tag)'{-s,--match-tag}'+[show only these tags]:tag:' \
        '(-S --size)'{-S,--size}'+[override size]:n:' \
        '(-t --match-token)'{-t,--match-token}'+[token search]:NAME=value:' \
        '(-u --usages)'{-u,--usages}'+[usage filter]:usage:(filesystem raid crypto other)' \
        '(-U --uuid)'{-U,--uuid}'+[find by UUID]:uuid:' \
        '(-w --no-part-details)'{-w,--no-part-details}'[skip part details]' \
        '*:device:_files'
}

_blkid-bin "$@"
