#compdef nnUNetv2_predict
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# nnU-Net v2 inference on a folder of images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input folder]:input folder:_files -/' \
  '-o[output folder]:output folder:_files -/' \
  '-d[dataset name or id]:dataset:' \
  '-c[configuration]:configuration:(2d 3d_fullres 3d_lowres 3d_cascade_fullres)' \
  '-f[folds]:folds:' \
  '-tr[trainer]:trainer:' \
  '-p[plans identifier]:plans:' \
  '-chk[checkpoint name]:checkpoint:' \
  '--save_probabilities[export predicted probability maps]' \
  '-device[compute device]:device:(cpu cuda mps)' \
  '*:arg:_files' && ret=0

return ret
