#compdef paperjam
# Documentation: https://mj.ucw.cz/sw/paperjam/paperjam.1.html
# paperjam - transform PDF files (impose, scale, rotate, n-up, crop marks)

local ret=1

_arguments -s -S \
  '(-b --bbox)'{-b,--bbox}'[recalculate image box to enclose drawn contents]' \
  '(-d --debug)'{-d,--debug}'[show debugging messages]' \
  '--no-auto[do not perform automatic transforms]' \
  '--help[show help on options and commands]' \
  '1:input PDF:_files -g "*.pdf"' \
  '2:command:' \
  '3:output PDF:_files -g "*.pdf"' && ret=0

return ret
