#compdef velero-helper
# _velero-helper — Velero pause-mode helper sidecar (vmware-tanzu/velero)
# upstream: https://github.com/vmware-tanzu/velero
# Subcommands from cmd/velero-helper/velero-helper.go on tip.

_velero-helper() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:mode:(pause)'
}

_velero-helper "$@"
