#compdef pSX
# Documentation: (none - pSX is closed-source freeware, discontinued; no
# public source repo)
# Reference accessed: 2026-05-16
# Verified: no upstream source available (pSX is freeware, last release 2009).
# Tool kept per "do not delete files" directive with conservative stub.

# pSX: closed-source PlayStation 1 emulator (discontinued 2009)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:PSX disc image:_files -g "*.(iso|cue|bin|img|mdf|pbp|chd|ecm)"' && ret=0
return ret
