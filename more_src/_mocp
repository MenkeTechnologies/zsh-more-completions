#compdef mocp

# Zsh completion for mocp - music on console player

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-S --server)'{-S,--server}'[run only the server]' \
  '(-F --foreground)'{-F,--foreground}'[run the server in foreground (for debugging)]' \
  '(-R --sound-driver)'{-R,--sound-driver}'[use specified sound driver]:driver:(jack alsa oss sndio)' \
  '(-m --music-dir)'{-m,--music-dir}'[start in specified directory]:directory:_files -/' \
  '(-a --append)'{-a,--append}'[append files/directories/playlists to the playlist]' \
  '(-q --enqueue)'{-q,--enqueue}'[add files to the queue]' \
  '(-c --clear)'{-c,--clear}'[clear the playlist and exit]' \
  '(-p --play)'{-p,--play}'[start playing from the first item on the playlist]' \
  '(-l --playit)'{-l,--playit}'[play files without adding them to the playlist]' \
  '(-s --stop)'{-s,--stop}'[stop playing]' \
  '(-f --next)'{-f,--next}'[play next file]' \
  '(-r --previous)'{-r,--previous}'[play previous file]' \
  '(-x --exit)'{-x,--exit}'[shutdown the server]' \
  '(-P --pause)'{-P,--pause}'[pause]' \
  '(-U --unpause)'{-U,--unpause}'[unpause]' \
  '(-G --toggle-pause)'{-G,--toggle-pause}'[toggle between play and pause]' \
  '(-k --seek)'{-k,--seek}'[seek by N seconds]:seconds' \
  '(-j --jump)'{-j,--jump}'[jump to some position in the current track]:position (Ns/%/Nm)' \
  '(-v --volume)'{-v,--volume}'[adjust volume]:volume (+/-N)' \
  '(-y --sync)'{-y,--sync}'[synchronize playlist with the server]' \
  '(-n --nosync)'{-n,--nosync}'[do not synchronize playlist with the server]' \
  '(-T --theme)'{-T,--theme}'[use specified theme file]:theme:_files' \
  '(-C --config)'{-C,--config}'[use specified config file]:config:_files' \
  '(-O --set-option)'{-O,--set-option}'[set option NAME=VALUE]:option' \
  '(-M --moc-dir)'{-M,--moc-dir}'[use specified MOC directory]:directory:_files -/' \
  '(-D --debug)'{-D,--debug}'[turn on logging to a file]' \
  '(-A --ascii)'{-A,--ascii}'[use ASCII characters to draw lines]' \
  '(-i --info)'{-i,--info}'[print information about the file currently playing]' \
  '(-Q --format)'{-Q,--format}'[print formatted information]:format string' \
  '(-e --recursively)'{-e,--recursively}'[alias for -a]' \
  '--on=[turn on a control]:control:(shuffle autonext repeat)' \
  '--off=[turn off a control]:control:(shuffle autonext repeat)' \
  '--toggle=[toggle a control]:control:(shuffle autonext repeat)' \
  '(-t --toggle)'{-t,--toggle}'[toggle a control]:control:(shuffle autonext repeat)' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:file or directory:_files' && ret=0

return ret
