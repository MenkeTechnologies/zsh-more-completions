#compdef tcoffee
# Documentation: https://man.archlinux.org/search?q=tcoffee
# Reference accessed: 2026-05-16

# T-Coffee (alternative invocation name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-other_pg[show other programs]' \
  '-version[show version]' \
  '-in[input sequence file(s)]:file:_files' \
  '-seq[sequence input]:file:_files' \
  '-method[methods used]:methods:' \
  '-mode[mode]:mode:(regular expresso 3dcoffee psicoffee rcoffee mcoffee saracoffee accurate)' \
  '-evaluate[evaluate existing alignment]' \
  '-output[output format(s)]:fmt:' \
  '-outfile[output file]:file:_files' \
  '-tree[guide tree]:val:' \
  '-newtree[output guide tree]:file:_files' \
  '-usetree[use a tree]:file:_files' \
  '-n_core[number of cores]:n:' \
  '-thread[threads]:n:' \
  '-quiet[reduce output]' \
  '-runname[output base name]:name:' \
  '*::t-coffee options:_files' && ret=0
return ret
