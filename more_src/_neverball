#compdef neverball
# Documentation: https://manpages.debian.org/bookworm/neverball/neverball.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm neverball(6) manpage OPTIONS list.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated short -d/-r/-l forms (neverball uses long-only options).

# neverball: tilt-the-floor 3D ball-rolling puzzle
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--data[data directory]:dir:_files -/' \
  '--replay[play replay file]:file:_files -g "*.nbr(-.)"' \
  '--info[load level for info]' \
  '*:level:_files -g "*.sol(-.)"' && ret=0
return ret
