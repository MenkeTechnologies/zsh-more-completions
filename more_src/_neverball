#compdef neverball
# Documentation: https://man.archlinux.org/search?q=neverball
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --datadir)'{-d,--datadir}'+[data dir]:dir:_files -/' \
  '(-r --replay)'{-r,--replay}'+[replay file]:file:_files -g "*.nbr"' \
  '(-l --level)'{-l,--level}'+[level set]:set:' && ret=0

return ret
