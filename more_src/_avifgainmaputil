#compdef avifgainmaputil

local -a subcmds

subcmds=(
    'help:Show help'
    'extract:Extract gain map from AVIF'
    'combine:Combine SDR and gain map into AVIF'
    'convert:Convert between gain map formats'
    'tonemap:Apply gain map tonemapping'
    'info:Show gain map info'
)

_arguments -s -S \
    '--help[Show help message]' \
    '-h[Show help message]' \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'avifgainmaputil subcommand' subcmds
        ;;
    options)
        case $words[1] in
            extract)
                _arguments \
                    '-q[Quality]:quality' \
                    '--qcolor=[Quality for color]:quality' \
                    '--qalpha=[Quality for alpha]:quality' \
                    '--speed=[Encoding speed]:speed' \
                    '*:AVIF file:_files -g "*.avif"'
                ;;
            combine)
                _arguments \
                    '-q[Quality]:quality' \
                    '--qcolor=[Quality for color]:quality' \
                    '--qalpha=[Quality for alpha]:quality' \
                    '--speed=[Encoding speed]:speed' \
                    '--downscaling=[Downscaling factor]:factor' \
                    '*:files:_files'
                ;;
            convert|tonemap)
                _arguments \
                    '-q[Quality]:quality' \
                    '--qcolor=[Quality for color]:quality' \
                    '--speed=[Encoding speed]:speed' \
                    '--headroom=[HDR headroom]:headroom' \
                    '*:files:_files'
                ;;
            info)
                _arguments '*:AVIF file:_files -g "*.avif"'
                ;;
        esac
        ;;
esac
