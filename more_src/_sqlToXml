#compdef sqlToXml
# UCSC kent: dump out all or part of a relational database to XML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-topTag=[name for the top level XML tag]:name:' \
  '-query=[dump records matching SQL select in this file]:file:_files' \
  '-tab=[number of spaces between tabs in xml]:n:' \
  '-maxList=[limit any lists in output to this size]:n:' \
  ':database:' \
  ':dump spec:_files' \
  ':output xml:_files' && ret=0

return ret
