#compdef hanami

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'new:generate a new Hanami project'
      'server:start the application server'
      'console:start the interactive console'
      'generate:generate project components'
      'db:manage the database'
      'routes:print registered routes'
      'middleware:print middleware stack'
      'version:show Hanami version'
      'install:install Hanami'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments \
          '--template=[template engine]:engine:(erb haml slim)' \
          '--database=[database]:database:(sqlite postgres mysql)' \
          '--test=[test framework]:framework:(rspec minitest)' \
          '--head[use Hanami HEAD]' \
          '1:project name:' && ret=0
        ;;
      (server)
        _arguments \
          '(-p --port)'{-p,--port}'=[port number]:port:' \
          '(-o --host)'{-o,--host}'=[host]:host:' \
          '--server=[Rack-compatible server]:server:(puma webrick thin falcon)' \
          '--no-code-reloading[disable code reloading]' && ret=0
        ;;
      (generate)
        _arguments \
          '1:type:(action slice)' \
          '2:name:' && ret=0
        ;;
      (db)
        _arguments \
          '1:action:(create drop migrate seed prepare version structure)' && ret=0
        ;;
    esac
    ;;
esac

return ret
