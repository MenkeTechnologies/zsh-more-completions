#compdef hanami
# Documentation: https://github.com/hanami/cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Subcommands enumerated from lib/hanami/cli/commands/{app,gem} in upstream.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'new:generate a new Hanami project'
      'version:show Hanami version'
      'assets:asset management commands'
      'console:start the interactive console'
      'db:manage the database'
      'dev:start the development server'
      'generate:generate project components'
      'install:install Hanami'
      'middleware:print middleware stack'
      'routes:print registered routes'
      'run:application runner'
      'server:start the application server'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (new)
        _arguments \
          '--head[use Hanami HEAD]' \
          '1:project name:' && ret=0
        ;;
      (server)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port number]:port:' \
          '(-o --host)'{-o+,--host=}'[host]:host:' && ret=0
        ;;
      (generate)
        _arguments \
          '1:type:(action slice migration relation operation repo struct view)' \
          '2:name:' && ret=0
        ;;
      (db)
        _arguments \
          '1:action:(create drop migrate seed prepare version structure rollback)' && ret=0
        ;;
      (assets)
        _arguments \
          '1:action:(compile watch)' && ret=0
        ;;
    esac
    ;;
esac

return ret
