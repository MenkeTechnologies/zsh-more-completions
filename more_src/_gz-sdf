#compdef gz-sdf
# Documentation: https://gazebosim.org/docs
# SDFormat file check/convert/print tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message]' \
  '--force-version=[use a specific library version]:version' \
  '--versions[show the available versions]' \
  '(-k --check)'{-k,--check}'=[check if an SDFormat file is valid]:file:_files' \
  '(-d --describe)'{-d,--describe}'=[print the aggregated SDFormat spec description]:version' \
  '(-p --print)'{-p,--print}'=[print converted file]:file:_files' \
  '(-g --graph)'{-g,--graph}'=[print PoseRelativeTo or FrameAttachedTo graph]:type' \
  '--inertial-stats=[print moment of inertia, center of mass and total mass]:file:_files' \
  '(-i --preserve-includes)'{-i,--preserve-includes}'[preserve included tags when printing]' \
  '--degrees[print pose rotation angles in degrees]' \
  '--expand-auto-inertials[print auto-computed inertial values for simple shapes]' \
  '--snap-to-degrees=[snap pose rotation angles to interval in degrees]:interval' \
  '--snap-tolerance=[tolerance at which snapping occurs]:tolerance' \
  '--precision=[output stream precision for floating point numbers]:precision' && ret=0

return ret
