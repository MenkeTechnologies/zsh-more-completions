#compdef jvisualvm
# Documentation: https://visualvm.github.io/docs/command-line-options.html
# VisualVM all-in-one Java troubleshooting tool launcher

local ret=1

_arguments -s \
  '--help[show available options]' \
  '--jdkhome[set the JDK installation to run VisualVM]:jdk dir:_files -/' \
  '--userdir[directory to store user settings and installed plugins]:userdir:_files -/' \
  '--cachedir[directory to store user cache (must differ from userdir)]:cachedir:_files -/' \
  '--cp\:p[prepend custom classpath to VisualVM classpath]:classpath:_files' \
  '--cp\:a[append custom classpath to VisualVM classpath]:classpath:_files' \
  '--laf[Swing look and feel used to render the GUI]:laf' \
  '--fontsize[base font size used in the GUI]:size' \
  '--openfile[open the provided file or snapshot in the GUI]:file:_files' \
  '--openid[open a process with the provided id]:id' \
  '--openpid[open a process with the provided pid]:pid' \
  '--openjmx[open a process specified by the provided JMX connection]:jmx connection' \
  '--threaddump[take thread dump of the provided process]:pid' \
  '--heapdump[take heap dump of the provided process]:pid' \
  '--start-cpu-sampler[start a CPU sampling session]:pid' \
  '--start-memory-sampler[start a memory sampling session]:pid' \
  '--snapshot-sampler[capture sampling data snapshot]:pid' \
  '--stop-sampler[terminate active sampler session]:pid' \
  '--start-jfr[start flight recording of the provided process]:pid' \
  '--dump-jfr[dump the flight recorder data collected so far]:pid' \
  '--stop-jfr[stop the flight recording of the provided process]:pid' \
  '--source-roots[directories to search for source files]:roots:_files -/' \
  '--source-viewer[command to launch an external sources viewer]:command' \
  '--source-config[configure sources via properties file]:file:_files' \
  '--window-to-front[bring VisualVM window to foreground]' \
  '*:-J jvm option:_default' && ret=0

return ret
