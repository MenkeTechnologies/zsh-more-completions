#compdef compute-sanitizer cuda-compute-sanitizer
# _cuda-compute-sanitizer — NVIDIA cuda-compute-sanitizer functional correctness checker memcheck initcheck racecheck synccheck (NVIDIA team, C++); custom argparse
# upstream: https://docs.nvidia.com/cuda/compute-sanitizer/

_cuda-compute-sanitizer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--tool=+[tool]:t:(memcheck initcheck racecheck synccheck)' \
        '--show-backtrace=+[mode]:m:(no yes host device)' \
        '--print-level=+[level]:l:(info warn error fatal)' \
        '--log-file=+[log file]:file:_files' \
        '--save=+[file]:file:_files' \
        '--xml[output XML]' \
        '--target-processes=+[scope]:s:(application-only all)' \
        '--launch-skip=+[N]:n:' \
        '--launch-count=+[N]:n:' \
        '--track-stream-ordered-races=+[bool]:b:(yes no)' \
        '--track-memcheck-races=+[bool]:b:(yes no)' \
        '--check-cache-control=+[bool]:b:(yes no)' \
        '--check-device-heap=+[bool]:b:(yes no)' \
        '--check-bulk-loads=+[bool]:b:(yes no)' \
        '--check-bulk-store=+[bool]:b:(yes no)' \
        '--check-coherency=+[bool]:b:(yes no)' \
        '--leak-check=+[mode]:m:(no full)' \
        '--demangle=+[mode]:m:(no simple full)' \
        '--padding=+[bytes]:n:' \
        '--prefix=+[string]:str:' \
        '--language=+[lang]:l:(c c++)' \
        '--force-blocking-launches=+[bool]:b:(yes no)' \
        '--track-unused-memory=+[bool]:b:(yes no)' \
        '--suppressions=+[file]:file:_files' \
        '--generate-suppressions=+[file]:file:_files' \
        '--exclude=+[pattern]:str:' \
        '--filter=+[pattern]:str:' \
        '--require-cuda-init=+[bool]:b:(yes no)' \
        '--injection-path=+[path]:dir:_files -/' \
        '*:cuda binary:_files'
}

_cuda-compute-sanitizer "$@"
