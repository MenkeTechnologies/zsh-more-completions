#compdef gh-hook
# Documentation: https://github.com/lucasmelin/gh-hook
# gh-hook - GitHub CLI extension to manage repository webhooks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(create list delete)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '--file=[pass webhook data via a JSON file]:file:_files' \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      list|delete)
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'=[target repository]:repo:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
