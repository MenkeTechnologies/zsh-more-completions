#compdef gnatmake
# Documentation: https://man.archlinux.org/search?q=gnatmake
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[also recompile read-only sources]' \
  '-aL+[archived library dir]:dir:_files -/' \
  '-aO+[object dir]:dir:_files -/' \
  '-aI+[source dir]:dir:_files -/' \
  '-aP+[project path]:dir:_files -/' \
  '-b[bind only]' \
  '-B[build only]' \
  '-c[compile only]' \
  '-C[cache sources]' \
  '-D+[object dir]:dir:_files -/' \
  '-eL[follow symlinks]' \
  '-eS[show output on stdout]' \
  '-f[force recompile all]' \
  '-h[help]' \
  '-i[install]' \
  '-I+[search dir]:dir:_files -/' \
  '-j+[parallel jobs]:n:' \
  '-k[keep going on error]' \
  '-l[bind only - generate b__]' \
  '-m[minimum recompilation]' \
  '-M[print sources]' \
  '-n[do nothing]' \
  '-nostdinc[no stdinc]' \
  '-nostdlib[no stdlib]' \
  '-o+[output]:file:_files' \
  '-p[create missing dirs]' \
  '-P+[project file]:file:_files -g "*.gpr"' \
  '-q[quiet]' \
  '-R[do not relink]' \
  '-s[recompile if compile switches changed]' \
  '-u[unique compilation]' \
  '-U[recursive build]' \
  '-v[verbose]' \
  '-vP+[project verbosity]:level:(0 1 2)' \
  '-w[suppress all warnings]' \
  '-x[disable required source check]' \
  '-X+[scenario var]:var=val:' \
  '-z[no main]' \
  '-bargs[binder args]:args:' \
  '-cargs[compiler args]:args:' \
  '-largs[linker args]:args:' \
  '-margs[main args]:args:' \
  '*:source:_files -g "*.{ada,adb,ads}"' && ret=0

return ret
