#compdef ferium

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-file=[config file path]:config file:_files' \
  '--github-token=[GitHub API token]:token' \
  '--curseforge-api-key=[CurseForge API key]:key' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a mod to the profile'
      'complete:generate shell completion'
      'list:list mods in current profile'
      'modpack:manage modpacks'
      'profile:manage profiles'
      'remove:remove a mod from the profile'
      'scan:scan mods directory for installed mods'
      'upgrade:download and install mod updates'
    )
    _describe -t commands 'ferium command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:mod identifier' && ret=0
        ;;
      profile)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(create delete info list switch configure)' && ret=0
        ;;
      modpack)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add delete list switch upgrade)' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:mod name' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      complete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
