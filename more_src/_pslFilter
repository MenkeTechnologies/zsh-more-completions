#compdef pslFilter
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: filter out psl file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-dir[input files are directories rather than single files]' \
  '-reward=[bonus to score for match]:n:' \
  '-cost=[penalty to score for mismatch]:n:' \
  '-gapOpenCost=[penalty for gap opening]:n:' \
  '-gapSizeLogMod=[penalty for gap sizes]:n:' \
  '-minScore=[minimum score to pass filter]:n:' \
  '-minMatch=[min match including repeats to pass]:n:' \
  '-minUniqueMatch=[min non-repeats to pass]:n:' \
  '-maxBadPpt=[maximum divergence in parts per thousand]:n:' \
  '-minAli=[minimum ratio query in alignment in ppt]:n:' \
  '-minAliT=[like minAli for target]:n:' \
  '-noHead[don'\''t output psl header]' \
  ':in psl:_files' \
  ':out psl:_files' && ret=0

return ret
