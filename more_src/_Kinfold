#compdef Kinfold
# Kinfold — simulate kinetic folding of RNA secondary structures (ViennaRNA)

local ret=1

_arguments -s -S \
  '--help[display help information]' \
  '--version[display version information]' \
  '--noShift[disable shift moves]' \
  '--noLP[forbid structures with isolated base-pairs]' \
  '--num=[number of trajectories to compute]:num' \
  '--time=[maximum folding trajectory length]:tmax' \
  '--grow=[chain growth event frequency during transcription]:rate' \
  '--glen=[initial chain length for transcription simulation]:len' \
  '--fpt[toggle first passage time vs open-ended simulations]' \
  '--start[read start conformation from stdin]' \
  '--stop[read stop structures from stdin]' \
  '--met[use Metropolis rule instead of Kawasaki rule]' \
  '--seed=[random number seed (three numbers separated by =)]:seed' \
  '(-v --verbose)'{-v,--verbose}'[print additional information]' \
  '(-q --silent)'{-q,--silent}'[suppress trajectory output]' \
  '--lmin[print only local minima]' \
  '--cut=[print trajectory portions below specified energy]:energy' \
  '--log=[set log file name]:file:_files' \
  '--dangles=[select dangling end model]:mode:(0 1 2)' \
  '(-T --Temp)'{-T,--Temp}'=[set simulation temperature]:temp' \
  '(-P --Par)'{-P,--Par}'=[read energy parameters from file]:file:_files' \
  '--logML[toggle logarithmic multiloop energies]' && ret=0

return ret
