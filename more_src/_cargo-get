#compdef cargo-get
# query package information from Cargo.toml in a script-friendly way

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--entry[search the given directory for Cargo.toml]:path:_files -/' \
  '--terminator[line terminator]:terminator' \
  '--delimiter[delimiter for multiple values]:delimiter' \
  '--pretty[pretty output format]' \
  '--full[full output format]' \
  '1:property:(package.name package.edition package.rust_version package.version package.build package.workspace package.authors package.links package.description package.homepage package.readme package.keywords package.categories package.exclude package.include package.license package.license_file package.repository package.default_run package.publish package.resolver package.metadata workspace.members workspace.default_members)' && ret=0

return ret
