#compdef patroni_exporter
# Documentation: https://github.com/gopaytech/patroni_exporter
# Prometheus exporter that scrapes Patroni stats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--patroni.host=[Patroni host or IP address]:host' \
  '--patroni.port=[Patroni port]:port' \
  '--log.level=[only log messages with the given severity or above]:level:(debug info warn error)' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[show application version]' \
  '*:arg:_default' && ret=0

return ret
