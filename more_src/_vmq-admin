#compdef vmq-admin vernemq-admin
# Documentation: https://docs.vernemq.com/llms-full.txt
# Reference accessed: 2026-05-21
# Verified: upstream VerneMQ docs (llms-full.txt) at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cluster:manage cluster membership'
  'session:retrieve session info'
  'listener:manage listener interfaces'
  'plugin:manage plugins'
  'metrics:show broker metrics'
  'retain:show retained messages'
  'api-key:manage API keys'
  'trace:trace MQTT client activity'
  'bridge:show bridge endpoint status'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vmq-admin command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cluster) _values 'subcommand' 'show' 'join' 'leave' && ret=0 ;;
      (session)
        _arguments \
          '--node=[node]:node:' \
          '--is_online=[online]:bool:(true false)' \
          '--client_id=[client id]:id:' \
          '--mountpoint=[mountpoint]:mp:' \
          '--limit=[max rows]:n:' \
          '*: :->sess' && ret=0
        case $state in
          (sess) _values 'subcommand' 'show' 'reauthorize' 'disconnect' && ret=0 ;;
        esac ;;
      (listener) _values 'subcommand' 'show' 'start' 'stop' 'restart' 'delete' && ret=0 ;;
      (plugin) _values 'subcommand' 'enable' 'disable' 'show' && ret=0 ;;
      (metrics) _values 'subcommand' 'show' && ret=0 ;;
      (retain) _values 'subcommand' 'show' && ret=0 ;;
      (trace) _values 'subcommand' 'client' && ret=0 ;;
      (api-key) _values 'subcommand' 'create' 'add' 'delete' 'show' && ret=0 ;;
      (bridge) _values 'subcommand' 'show' && ret=0 ;;
    esac ;;
esac

return ret
