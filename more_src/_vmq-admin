#compdef vmq-admin vernemq-admin
# Documentation: https://man.archlinux.org/search?q=vmq-admin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'node:manage this node'
  'cluster:manage cluster membership'
  'session:retrieve session info'
  'listener:manage listener interfaces'
  'plugin:manage plugins'
  'metrics:show metrics'
  'retain:show retained messages'
  'webhooks:webhooks status'
  'tls:TLS PSK info'
  'trace:trace VerneMQ events'
  'mgmt:management API'
  'api-key:manage API keys'
  'crl:CRL management'
  'cluster-peer:peer ops'
  'health:health check'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vmq-admin command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cluster) _values 'subcommand' 'show' 'status' 'join' 'leave' 'upgrade' && ret=0 ;;
      (session)
        _arguments \
          '--node=[node]:node:' \
          '--is_online=[online]:bool:(true false)' \
          '--client_id=[client id]:id:' \
          '--mountpoint=[mountpoint]:mp:' \
          '--limit=[max rows]:n:' \
          '*: :->sess' && ret=0
        case $state in
          (sess) _values 'subcommand' 'show' 'reauthorize' 'disconnect' && ret=0 ;;
        esac ;;
      (listener) _values 'subcommand' 'show' 'start' 'stop' 'restart' 'delete' && ret=0 ;;
      (plugin) _values 'subcommand' 'enable' 'disable' 'show' && ret=0 ;;
      (metrics) _values 'subcommand' 'show' 'reset' && ret=0 ;;
      (retain) _values 'subcommand' 'show' && ret=0 ;;
      (webhooks) _values 'subcommand' 'show' 'cache' && ret=0 ;;
      (trace)
        _arguments \
          '--mountpoint=[mountpoint]:mp:' \
          '--rate-max=[max msgs in interval]:n:' \
          '--rate-interval=[interval ms]:ms:' \
          '--trunc-payload=[payload truncation bytes]:n:' \
          '*: :' && ret=0 ;;
      (api-key) _values 'subcommand' 'create' 'add' 'delete' 'show' && ret=0 ;;
      (node) _values 'subcommand' 'show' 'stop' 'start' 'restart' && ret=0 ;;
    esac ;;
esac

return ret
