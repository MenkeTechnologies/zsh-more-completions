#compdef swift-driver
# Documentation: https://github.com/apple/swift-driver
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: swift-driver is the Swift compiler driver; CLI surface is the entire swift/swiftc option set.
# Delegate to the existing _swift completion if present; otherwise just complete Swift source files.

local curcontext="$curcontext" state line ret=1

(( $+functions[_swift] )) || autoload -Uz _swift 2>/dev/null
if (( $+functions[_swift] )); then
  _swift "$@"
  return
fi

_arguments \
  '*:Swift source file:_files -g "*.swift"' && ret=0

return ret
