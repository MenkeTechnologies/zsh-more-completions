#compdef swift-driver
# Documentation: https://man.archlinux.org/search?q=swift-driver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_swift] )) || autoload -Uz _swift 2>/dev/null
if (( $+functions[_swift] )); then
  _swift "$@"
  return
fi

_arguments \
  '*:Swift source file:_files -g "*.swift"' && ret=0

return ret
