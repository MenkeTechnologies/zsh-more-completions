#compdef zvm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install a Zig version'
  'i:alias for install'
  'use:switch to an installed Zig version'
  'list:list installed Zig versions'
  'ls:alias for list'
  'run:run a Zig command without changing default'
  'uninstall:remove an installed Zig version'
  'rm:alias for uninstall'
  'upgrade:upgrade zvm itself'
  'vmu:configure version map source'
  'mirrorlist:set custom mirror distribution server'
  'clean:remove build artifacts'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--color[enable ANSI color]' \
  '--colour[enable ANSI color]' \
  '--nocolor[disable ANSI color]' \
  '--nocolour[disable ANSI color]' \
  '--yescolor[force ANSI color]' \
  '--yescolour[force ANSI color]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zvm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|i)
        _arguments \
          '(-f --force)'{-f,--force}'[force reinstall]' \
          '--zls[install ZLS alongside]' \
          '--full[use ZLS build compatible with Zig version]' \
          '--target-os=[override OS]:os:(linux macos windows freebsd netbsd dragonfly haiku)' \
          '--target-arch=[override architecture]:arch:(x86_64 aarch64 i386 arm riscv64)' \
          '--nomirror[skip community mirror downloads]' \
          '*::version:' && ret=0 ;;
      (use|run|uninstall|rm)
        _arguments '*::version:' && ret=0 ;;
      (list|ls)
        _arguments \
          '(-a --all)'{-a,--all}'[list remote available versions]' \
          '--vmu[show configured version map sources]' && ret=0 ;;
      (vmu)
        _arguments '*::sub:(zig zls default mach)' && ret=0 ;;
      (mirrorlist)
        _arguments '*::url_or_default:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish pwsh)' && ret=0 ;;
    esac ;;
esac

return ret
