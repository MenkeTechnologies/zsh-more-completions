#compdef zvm
# Documentation: https://github.com/tristanisham/zvm
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (main.go flag definitions).
# Removed from prior file: fabricated --colour, --nocolor, --nocolour,
# --yescolor, --yescolour aliases (upstream defines only --color as a
# StringFlag accepting on/yes/y/enabled/true/off/no/n/disabled/false).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:download and install a version of Zig'
  'i:alias for install'
  'use:switch between versions of Zig'
  'list:list installed Zig versions'
  'ls:alias for list'
  'run:run a command with the given Zig version'
  'uninstall:remove an installed version of Zig'
  'rm:alias for uninstall'
  'upgrade:self-upgrade ZVM'
  'clean:remove build artifacts'
  'vmu:configure version map source'
  'mirrorlist:set custom mirror distribution server'
  'completion:generate a shell completion script'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--color=[enable or disable colored output]:value:(on yes y enabled true off no n disabled false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zvm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|i)
        _arguments \
          '(-f --force)'{-f,--force}'[force installation]' \
          '--zls[install ZLS]' \
          '--full[use full ZLS compatibility mode]' \
          '--nomirror[download Zig from ziglang.org instead of a community mirror]' \
          '--target-os=[override target operating system]:os:(linux macos windows freebsd netbsd dragonfly haiku)' \
          '--target-arch=[override target architecture]:arch:(x86_64 aarch64 arm riscv64)' \
          '*::version:' && ret=0 ;;
      (use)
        _arguments \
          '--sync[sync current Zig with repository]' \
          '*::version:' && ret=0 ;;
      (run|uninstall|rm)
        _arguments '*::version:' && ret=0 ;;
      (list|ls)
        _arguments \
          '(-a --all)'{-a,--all}'[list remote Zig versions available for download]' \
          '--vmu[list set version maps]' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish pwsh)' && ret=0 ;;
    esac ;;
esac

return ret
