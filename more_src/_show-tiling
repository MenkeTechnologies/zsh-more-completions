#compdef show-tiling
# Documentation: https://manpages.debian.org/testing/mummer/show-tiling.1.en.html
# MUMmer utility to construct a tiling path from a delta file

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-a[print tab-delimited alignment region coordinates to stdout]' \
  '-c[assume reference sequences are circular]' \
  '-g+[maximum gap between clustered alignments]:gap' \
  '-i+[minimum percent identity to tile]:identity' \
  '-l+[minimum length contig to report]:length' \
  '-p+[output pseudo molecule of query contigs to file]:file:_files' \
  '-R[randomly place repetitive contigs]' \
  '-t+[output TIGR style contig list to file]:file:_files' \
  '-u+[output unusable contig coordinates to file]:file:_files' \
  '-v+[minimum contig coverage to tile]:coverage' \
  '-V+[minimum contig coverage difference]:diff' \
  '-x[print XML contig linking information to stdout]' \
  ':delta file:_files -g "*.delta"' && ret=0

return ret
