#compdef verible-verilog-lint verible-verilog-diff verible-verilog-project verible-verilog-obfuscate verible-verilog-ls
# Documentation: source-direct extraction from upstream
# chipsalliance/verible — per-tool ABSL_FLAG declarations under
#   verible/verilog/tools/{lint,diff,project,obfuscator,ls}/*.cc
# Each ABSL_FLAG(type, name, default, doc) was parsed for type +
# name + default. Per-binary enums decoded source-direct from
# the corresponding `EnumNameMap<X> kXEnumStringMap({...})`
# tables (AutofixMode for verilog-lint, DiffMode for verilog-diff).
# project-tool subcommands decoded source-direct from its
# `static const std::pair<std::string_view, SubcommandEntry>
# kCommands[]` table.
# Reference accessed: 2026-05-30 via gh api.
# chipsalliance verible R163 — 5-stem multi-binary harvest of
# the verible Verilog/SystemVerilog tooling siblings shipped
# alongside the already-covered verible-verilog-format +
# verible-verilog-syntax binaries.  Sister tools to the heavily
# covered FPGA / EDA family (yosys + 4 yosys-* siblings, nextpnr-
# ice40 / -ecp5 / -nexus / -gowin / -machxo2 / -himbaechel, the
# icestorm utility set icepack/icebram/icetime/iceprog, openocd,
# sigrok-cli, verilator).

case $service in

  verible-verilog-lint)
    _arguments -s -S \
      '--check_syntax=[check for lexical/syntax errors (default true)]:bool:(true false)' \
      '--parse_fatal=[exit nonzero on syntax errors (default true)]:bool:(true false)' \
      '--lint_fatal=[exit nonzero on lint violations (default true)]:bool:(true false)' \
      '--help_rules=[print description of one rule or all then exit]:rule:' \
      '--generate_markdown[print all rules formatted as Markdown then exit]' \
      '--print_rules_file[print current rule set in .rules.verible_lint format then exit]' \
      '--show_diagnostic_context[print an extra source-position-marker line per diagnostic]' \
      '--autofix=[autofix mode]:mode:(no patch-interactive patch inplace-interactive inplace generate-waiver)' \
      '--autofix_output_file=[patch/waiver output file]:file:_files' \
      '*:SystemVerilog source file:_files -g "*.(v|sv|svh|vh)"'
    ;;

  verible-verilog-diff)
    _arguments -s -S \
      '--mode=[diff equivalence mode]:mode:(format obfuscate)' \
      ':file1:_files -g "*.(v|sv|svh|vh)"' \
      ':file2:_files -g "*.(v|sv|svh|vh)"'
    ;;

  verible-verilog-project)
    _arguments -C \
      '--file_list_path=[file list source]:file:_files' \
      '--file_list_root=[file-list root directory (default .)]:dir:_files -/' \
      '--include_dir_paths=[comma-separated include search dirs]:dirs:' \
      '1: :->cmd' \
      '*:: :->args'
    case $state in
      cmd)
        local -a subcmds=(
          'symbol-table-defs:print unified symbol-table representation without resolution'
          'symbol-table-refs:print symbol-table references after attempted resolution'
          'file-deps:print inter-file dependencies graph'
        )
        _describe -t commands 'project-tool subcommand' subcmds
        ;;
      args)
        _files -g "*.(v|sv|svh|vh)"
        ;;
    esac
    ;;

  verible-verilog-obfuscate)
    _arguments -s -S \
      '--load_map=[pre-load existing translation dictionary (saved by --save_map)]:file:_files' \
      '--save_map=[save translation dictionary for reuse with --load_map]:file:_files' \
      '--decode[apply translation map in reverse to de-obfuscate (needs --load_map)]' \
      '--preserve_interface[preserve module name, port names, parameter names]' \
      '--preserve_builtin_functions[preserve built-in function names (sin/ceil/...)]'
    ;;

  verible-verilog-ls)
    _arguments -s -S \
      '--push_diagnostic_notifications=[push diagnostics as LSP notifications (default true)]:bool:(true false)'
    ;;

esac
