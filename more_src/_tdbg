#compdef tdbg
# _tdbg — Temporal server debugging CLI (temporalio/temporal)
# upstream: https://github.com/temporalio/temporal
# Subcommands from tools/tdbg/tdbg_commands.go (urfave/cli/v2).

_tdbg() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--address=[host:port of Temporal frontend service]:address:' \
        '(-n --namespace)'{-n+,--namespace=}'[Temporal workflow namespace]:namespace:' \
        '(-ct --context_timeout)'{-ct+,--context_timeout=}'[RPC context timeout (seconds)]:s:' \
        '(-y --yes)'{-y,--yes}'[automatically confirm all prompts]' \
        '--tls-cert-path=[x509 certificate]:file:_files' \
        '--tls-key-path=[private key]:file:_files' \
        '--tls-ca-path=[server CA certificate]:file:_files' \
        '--tls-disable-host-verification[disable TLS host verification]' \
        '--tls-server-name=[target server name]:host:' \
        '--color=[when to use color]:mode:(auto always never)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                execution:'manage workflow executions'
                shard:'manage shards'
                history-host:'inspect history service hosts'
                taskqueue:'manage task queues'
                membership:'inspect cluster membership'
                dlq:'manage dead letter queues'
                schedule:'manage scheduled workflows'
                decode:'decode raw payloads'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                execution)
                    _arguments '1:subcommand:(import show describe refresh-tasks rebuild replicate delete)' ;;
                shard)
                    _arguments '1:subcommand:(describe list-tasks close-shard remove-task)' ;;
                history-host)
                    _arguments '1:subcommand:(describe get-shardid list-tasks)' ;;
                taskqueue)
                    _arguments '1:subcommand:(list-tasks describe-task-queue-partition force-unload-task-queue-partition get-user-data)' ;;
                membership)
                    _arguments '1:subcommand:(list-gossip list-db)' ;;
                dlq)
                    _arguments '1:subcommand:(read purge merge job list)' ;;
                decode)
                    _arguments '1:subcommand:(proto base64)' ;;
            esac
            ;;
    esac
}

_tdbg "$@"
