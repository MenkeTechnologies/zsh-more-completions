#compdef ttypo
# Documentation: https://github.com/drewja/ttypo
# Reference accessed: 2026-05-21
# Verified: generated by ttypo completions zsh (v0.1.21 via cargo binstall)

autoload -U is-at-least

_ttypo() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-w+[Specify word count]:N:_default' \
'--words=[Specify word count]:N:_default' \
'-c+[Use config file]:PATH:_files' \
'--config=[Use config file]:PATH:_files' \
'--language-file=[Specify test language in file]:PATH:_files' \
'-l+[Specify test language]:LANG:_default' \
'--language=[Specify test language]:LANG:_default' \
'-d[]' \
'--debug[]' \
'--list-languages[List installed languages]' \
'--no-backtrack[Disable backtracking to completed words]' \
'--sudden-death[Enable sudden death mode to restart on first error]' \
'--no-backspace[Disable backspace]' \
'--ascii[Display all but skip non-ASCII characters during typing]' \
'--restart[Ignore saved progress for the input file and start from the beginning]' \
'--no-save[Do not persist per-document progress for this invocation]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::contents -- Read test contents from the specified file, or "-" for stdin:_files' \
":: :_ttypo_commands" \
"*::: :->ttypo" \
&& ret=0
    case $state in
    (ttypo)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ttypo-command-$line[2]:"
        case $line[2] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_ttypo__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:ttypo-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_ttypo_commands] )) ||
_ttypo_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'ttypo commands' commands "$@"
}
(( $+functions[_ttypo__subcmd__completions_commands] )) ||
_ttypo__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'ttypo completions commands' commands "$@"
}
(( $+functions[_ttypo__subcmd__help_commands] )) ||
_ttypo__subcmd__help_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'ttypo help commands' commands "$@"
}
(( $+functions[_ttypo__subcmd__help__subcmd__completions_commands] )) ||
_ttypo__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'ttypo help completions commands' commands "$@"
}
(( $+functions[_ttypo__subcmd__help__subcmd__help_commands] )) ||
_ttypo__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'ttypo help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_ttypo" ]; then
    _ttypo "$@"
else
    compdef _ttypo ttypo
fi
