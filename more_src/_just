#compdef just
# Documentation: https://man.archlinux.org/man/just.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for just (command runner).
# Corrected from prior file: -c is --command (not standalone); --command
# takes value; --dotenv-path is -E; --global-justfile is -g; --list/-l;
# --unsorted/-u (was wrongly two separate entries); added real flags
# --man, --groups, --explain, --timestamp, --timestamp-format,
# --variables, --tempdir, --one, --allow-missing.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--check[Run --fmt in check mode]' \
  '--chooser=[Override binary invoked by --choose]:chooser program' \
  '--choose[Select one or more recipes to run using a chooser]' \
  '--clear-shell-args[Clear shell arguments]' \
  '--color=[Print colorful output]:color:(auto always never)' \
  '(-c --command)'{-c,--command}'=[Run an arbitrary command with the working directory and dotenv]:command' \
  '--command-color=[Echo recipe lines in specified color]:color:(black blue cyan green purple red yellow)' \
  '--completions=[Print shell completion script]:shell:(zsh bash fish powershell elvish nushell)' \
  '--dotenv-filename=[Search for additional dotenv file]:filename:_files' \
  '(-E --dotenv-path)'{-E,--dotenv-path}'=[Load additional dotenv file at path]:path:_files' \
  '(-n --dry-run)'{-n,--dry-run}'[Print what just would do without doing it]' \
  '--dump[Print justfile]' \
  '--dump-format=[Dump justfile in given format]:format:(just json)' \
  '(-e --edit)'{-e,--edit}'[Edit justfile with editor given by $VISUAL or $EDITOR]' \
  '--evaluate[Evaluate and print all variables]' \
  '(-f --justfile)'{-f,--justfile}'=[Use specified justfile]:justfile:_files' \
  '--fmt[Format and overwrite justfile]' \
  '(-g --global-justfile)'{-g,--global-justfile}'[Use global justfile]' \
  '--groups[List recipe groups]' \
  '--highlight[Highlight echoed recipe lines in bold]' \
  '--init[Initialize new justfile in project root]' \
  '(-l --list)'{-l,--list}'[List available recipes and their arguments]' \
  '--list-heading=[Print heading before list]:heading' \
  '--list-prefix=[Print prefix before each item in list]:prefix' \
  '--list-submodules[List recipes in submodules]' \
  '--man[Print man page]' \
  '--no-aliases[Do not print aliases in list]' \
  '--no-deps[Do not run recipe dependencies]' \
  '--no-dotenv[Do not load .env file]' \
  '--no-highlight[Do not highlight echoed recipe lines]' \
  '--one[Forbid multiple recipes from being invoked on the command line]' \
  '(-q --quiet)'{-q,--quiet}'[Suppress all output]' \
  '--allow-missing[Ignore missing recipe and module errors]' \
  '--set=[Override variable with value]:assignment' \
  '--shell=[Invoke specified shell to run recipes]:shell' \
  '--shell-arg=[Invoke shell with specified argument to run recipes]:arg' \
  '--shell-command[Invoke --command with the shell used to run recipe lines]' \
  '(-s --show)'{-s,--show}'=[Show information about specified recipe]:recipe' \
  '--summary[List names of available recipes]' \
  '--explain[Print recipe doc comment before running it]' \
  '--timestamp[Print recipe command timestamps]' \
  '--timestamp-format=[Timestamp format string]:format' \
  '--tempdir=[Create temporary directories in given directory]:dir:_directories' \
  '--unsorted[Return list and summary entries in source order]' \
  '-u[Return list and summary entries in source order]' \
  '--unstable[Enable unstable features]' \
  '--variables[List names of variables]' \
  '(-v --verbose)'{-v,--verbose}'[Use verbose output]' \
  '(-V --version)'{-V,--version}'[Print version information]' \
  '(-d --working-directory)'{-d,--working-directory}'=[Use specified working directory]:dir:_directories' \
  '--yes[Automatically confirm all recipes]' \
  '(- *)'{-h,--help}'[Print help information]' \
  '*:: :->recipes' && ret=0

case $state in
  recipes)
    local -a recipes
    recipes=( ${(f)"$(just --summary --unsorted 2>/dev/null)"} )
    if [[ -n "$recipes" ]]; then
      _describe -t recipes 'recipe' recipes && ret=0
    fi
    ;;
esac

return ret
