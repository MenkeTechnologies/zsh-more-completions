#compdef hg

# Zsh completion for Mercurial (hg) version control

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add files to the next commit'
  'addremove:add all new files, delete all missing files'
  'annotate:show changeset information by line'
  'archive:create an unversioned archive'
  'backout:reverse effect of an earlier changeset'
  'bisect:subdivision search of changesets'
  'bookmarks:create a new bookmark or list existing bookmarks'
  'branch:set or show the current branch name'
  'branches:list repository named branches'
  'bundle:create a bundle file'
  'cat:output the current or given revision of files'
  'clone:make a copy of an existing repository'
  'commit:commit the specified files or all outstanding changes'
  'config:show combined config settings'
  'copy:mark files as copied for the next commit'
  'diff:diff repository or files'
  'export:dump the header and diffs for one or more changesets'
  'files:list tracked files'
  'forget:forget the specified files on the next commit'
  'graft:copy changes from other branches'
  'grep:search revision history for a pattern'
  'heads:show branch heads'
  'help:show help for a given topic'
  'identify:identify the working directory or specified revision'
  'import:import an ordered set of patches'
  'incoming:show new changesets found in source'
  'init:create a new repository'
  'log:show revision history'
  'manifest:output the current or given revision manifest'
  'merge:merge another revision into working directory'
  'outgoing:show changesets not found in destination'
  'parents:show the parents of the working directory'
  'paths:show aliases for remote repositories'
  'phase:set or show the current phase name'
  'pull:pull changes from the specified source'
  'push:push changes to the specified destination'
  'recover:roll back an interrupted transaction'
  'remove:remove the specified files on the next commit'
  'rename:rename files'
  'resolve:redo merges or set/view the merge status'
  'revert:restore files to their checkout state'
  'rollback:roll back the last transaction (dangerous)'
  'root:print the root of the current working directory'
  'serve:start stand-alone webserver'
  'shelve:save and set aside changes from the working directory'
  'status:show changed files in the working directory'
  'summary:summarize working directory state'
  'tag:add one or more tags for the current or given revision'
  'tags:list repository tags'
  'tip:show the tip revision'
  'unbundle:apply one or more bundle files'
  'unshelve:restore a shelved change to the working directory'
  'update:update working directory'
  'verify:verify the integrity of the repository'
  'version:output version and copyright information'
)

_arguments -s -S \
  '(-R --repository)'{-R+,--repository=}'[repository root directory]:directory:_files -/' \
  '--cwd=[change working directory]:directory:_files -/' \
  '(-y --noninteractive)'{-y,--noninteractive}'[do not prompt]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[enable additional output]' \
  '--color=[when to colorize]:when:(true false yes no always auto never debug)' \
  '--config=[set/override config option]:option=value:' \
  '--debug[enable debugging output]' \
  '--debugger[start debugger]' \
  '--encoding=[set character encoding]:encoding:' \
  '--encodingmode=[set character encoding mode]:mode:' \
  '--traceback[always print a traceback on exception]' \
  '--time[time how long the command takes]' \
  '--profile[print command execution profile]' \
  '--version[output version information and exit]' \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '--hidden[consider hidden changesets]' \
  '--pager=[when to paginate]:when:(true false yes no always auto never)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'hg command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      clone)
        _arguments \
          '(-U --noupdate)'{-U,--noupdate}'[do not update the new working directory]' \
          '--uncompressed[use uncompressed transfer]' \
          '(-r --rev)'{-r+,--rev=}'[revision to clone]:revision:' \
          '(-b --branch)'{-b+,--branch=}'[branch to clone]:branch:' \
          '1:source:' \
          '2:destination:_files -/'
        ;;
      commit)
        _arguments \
          '(-m --message)'{-m+,--message=}'[commit message]:message:' \
          '(-l --logfile)'{-l+,--logfile=}'[read commit message from file]:file:_files' \
          '(-A --addremove)'{-A,--addremove}'[mark new/missing files as added/removed]' \
          '(-u --user)'{-u+,--user=}'[record user]:user:' \
          '(-d --date)'{-d+,--date=}'[record date]:date:' \
          '*:files:_files'
        ;;
      log)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow file history]' \
          '(-l --limit)'{-l+,--limit=}'[limit output]:count:' \
          '(-p --patch)'{-p,--patch}'[show patch]' \
          '--stat[show diffstat]' \
          '(-G --graph)'{-G,--graph}'[show graph]' \
          '--template=[output format template]:template:' \
          '*:files:_files'
        ;;
      pull|push)
        _arguments \
          '(-r --rev)'{-r+,--rev=}'[revision]:revision:' \
          '(-b --branch)'{-b+,--branch=}'[branch]:branch:' \
          '(-f --force)'{-f,--force}'[force]' \
          '1:repository:'
        ;;
      status)
        _arguments \
          '(-A --all)'{-A,--all}'[show all files]' \
          '(-m --modified)'{-m,--modified}'[show only modified files]' \
          '(-a --added)'{-a,--added}'[show only added files]' \
          '(-r --removed)'{-r,--removed}'[show only removed files]' \
          '(-d --deleted)'{-d,--deleted}'[show only deleted files]' \
          '(-c --clean)'{-c,--clean}'[show only clean files]' \
          '(-u --unknown)'{-u,--unknown}'[show only unknown files]' \
          '(-i --ignored)'{-i,--ignored}'[show only ignored files]' \
          '*:files:_files'
        ;;
    esac
    ;;
esac

return ret
