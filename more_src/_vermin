#compdef vermin
# Documentation: https://github.com/netromdk/vermin
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-t+,--target=}'[required Python version]:ver' \
  '--versions[display version range information]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(default parsable github)' \
  '*-v[increase verbosity (stackable: -v, -vv, -vvv, -vvvv)]' \
  '--verbose[increase verbosity]' \
  '--quiet[suppress explanatory output]' \
  '--processes=[parallel worker count]:n' \
  '(-i --ignore-incomp)'{-i,--ignore-incomp}'[ignore incompatible-version findings]' \
  '--no-parse-comments[disable parsing of # novm/# novermin comments]' \
  '--lint[show only target version violations]' \
  '--violations[show only target version violations]' \
  '--hidden[also analyze hidden files]' \
  '--no-tips[disable tip suggestions]' \
  '--eval-annotations[evaluate generic/literal annotations at runtime]' \
  '--no-eval-annotations[skip annotation evaluation]' \
  '--feature=[enable experimental feature]:feature' \
  '--exclude=[exclude modules/members/kwargs from analysis]:item' \
  '--backport=[backported module to consider]:module' \
  '--config-file=[path to vermin config]:file:_files' \
  '*:paths:_files -/' && ret=0

return ret
