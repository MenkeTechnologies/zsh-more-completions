#compdef vermin
# Documentation: https://man.archlinux.org/search?q=vermin
# Reference accessed: 2026-05-16

# Zsh completion for vermin Python version detector (netromdk/vermin)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--quiet[suppress explanatory output]' \
  '--no-quiet[default verbose output]' \
  '-v[count verbosity; repeatable up to -vvvv]' \
  '*--target=[required Python version]:ver' \
  '--no-target[no --target requirement]' \
  '--processes=[parallel worker count]:n' \
  '--ignore[ignore incompatible-version hints]' \
  '--no-parse-comments[strip comments before parsing]' \
  '--lint[only print actionable issues]' \
  '--violations[only show rule violations]' \
  '--no-vars[disable user rule variables]' \
  '--no-strftime[skip strftime directive scan]' \
  '--no-argument-parser[skip argparse defaults scan]' \
  '--no-import-stats[omit import frequency table]' \
  '--config-file[path to vermin config]:file:_files' \
  '*:paths:_files -/' && ret=0

return ret
