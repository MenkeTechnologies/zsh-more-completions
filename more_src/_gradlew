#compdef gradlew
# _gradlew — Gradle wrapper script (Gradle Inc, Shell + Java); invoke project-pinned Gradle version
# upstream: https://github.com/gradle/gradle

_gradlew() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-b+[build file]:file:_files -g "*.gradle*"' \
        '--build-file+[build file]:file:_files -g "*.gradle*"' \
        '-c+[settings file]:file:_files' \
        '--settings-file+[settings file]:file:_files' \
        '-D+[system property]:KEY=VAL:' \
        '-P+[project property]:KEY=VAL:' \
        '-i[info logging]' \
        '--info[info logging]' \
        '-q[quiet logging]' \
        '--quiet[quiet logging]' \
        '-d[debug logging]' \
        '--debug[debug logging]' \
        '-s[stack trace]' \
        '--stacktrace[stack trace]' \
        '-S[full stack trace]' \
        '--full-stacktrace[full stack trace]' \
        '--scan[generate build scan]' \
        '--no-scan[disable build scan]' \
        '--profile[profile report]' \
        '-x+[exclude task]:task:' \
        '--exclude-task+[exclude task]:task:' \
        '--continue[continue on failure]' \
        '--continuous[continuous build]' \
        '-t[continuous build]' \
        '--no-daemon[no daemon]' \
        '--offline[offline]' \
        '--refresh-dependencies[refresh deps]' \
        '--rerun-tasks[rerun tasks]' \
        '--parallel[parallel]' \
        '--no-parallel[no parallel]' \
        '--max-workers+[max workers]:n:' \
        '*:task:'
}

_gradlew "$@"
