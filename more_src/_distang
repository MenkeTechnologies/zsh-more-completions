#compdef distang
# CCP4: calculate distances, angles, and torsions within a structure

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate-pairs file]:output:_files' \
  'DISTOUT[output distance information file]:output:_files' \
  'KHCONN[output PROTIN-style distance dictionary]:output:_files' \
  'PDBCONN[output PDB CONECT lines]:output:_files' \
  '*:keyword:(DISTANCE ANGLE TORSION OUTPUT RADII FROM TO SYMMETRY GRID END)' && ret=0

return ret
