#compdef logswan
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/logswan.1.html
# logswan - fast Web log analyzer using probabilistic data structures

local ret=1

_arguments -s -S \
  '-h[display usage]' \
  '-v[display version]' \
  '-g[enable GeoIP lookups]' \
  '-d+[path to a GeoIP database]:db:_files' \
  '*:logfile:_files' && ret=0

return ret
