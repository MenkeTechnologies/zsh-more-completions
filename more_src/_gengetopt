#compdef gengetopt
# Documentation: https://man.archlinux.org/search?q=gengetopt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input)'{-i+,--input=}'[input file]:file:_files -g "*.ggo"' \
  '(-f --func-name)'{-f+,--func-name=}'[parser function name]:name:' \
  '(-a --arg-struct-name)'{-a+,--arg-struct-name=}'[args struct name]:name:' \
  '(-F --file-name)'{-F+,--file-name=}'[output file base]:name:' \
  '(-G --gen)'{-G,--gen}'[generate getopt_long]' \
  '(-c --c-extension)'{-c+,--c-extension=}'[C extension]:ext:' \
  '(-H --header-extension)'{-H+,--header-extension=}'[header extension]:ext:' \
  '(-l --long-help)'{-l,--long-help}'[long help]' \
  '(-S --no-handle-help)'{-S,--no-handle-help}'[no help handling]' \
  '(-B --no-handle-version)'{-B,--no-handle-version}'[no version handling]' \
  '(-N --no-handle-error)'{-N,--no-handle-error}'[no error handling]' \
  '(-u --unamed-opts)'{-u+,--unamed-opts=}'[unnamed options name]:name:' \
  '(-C --conf-parser)'{-C,--conf-parser}'[generate conf parser]' \
  '(-s --string-parser)'{-s,--string-parser}'[generate string parser]' \
  '(--include-getopt)--include-getopt[include getopt]' \
  '(--show-required)--show-required[show required]' \
  '(-n --no-help)'{-n,--no-help}'[no help generation]' \
  '(-V --no-version)'{-V,--no-version}'[no version generation]' \
  '--set-package=[package name]:pkg:' \
  '--set-version=[version]:ver:' \
  '(-D --output-dir)'{-D+,--output-dir=}'[output dir]:dir:_files -/' \
  '*: :_files -g "*.ggo"' && ret=0

return ret
