#compdef qmleasing
# Documentation: https://github.com/qt/qtdeclarative/tree/dev/tools/qmleasing
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-h,--help}'[show help]' \
  '*:QML file:_files -g "*.qml"' && ret=0

return ret
