#compdef foamNew
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamNew — dispatch to foamNewSource / foamNewTemplate for boilerplate generation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'source:create a class source file (delegates to foamNewSource)'
            'template:create a class template source file (delegates to foamNewTemplate)'
        )
        _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
    args)
        local -a types=(C H I IO)
        case $line[1] in
            source|template)
                _arguments \
                    '1:type:('"$types"')' \
                    '2:class:' \
                    '*:template args:'
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac

return ret
