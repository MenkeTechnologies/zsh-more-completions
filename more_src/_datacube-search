#compdef datacube-search
# Documentation: https://opendatacube.readthedocs.io/en/stable/installation/cli.html
# Open Data Cube search tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--log-file=[log file location]:file:_files' \
  '(-E --env)'{-E,--env}'=[ODC environment to use]:env' \
  '(-C --config --config-file)'{-C,--config,--config-file}'=[configuration file path]:config:_files' \
  '(-R --raw-config --config-text)'{-R,--raw-config,--config-text}'=[configuration as a string]:config' \
  '--log-queries[print database queries]' \
  '-f[output format]:format:(csv pretty)' \
  '1:command:(datasets product-counts)' \
  '*::arg:_default' && ret=0

return ret
