#compdef pmm-admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add service'
  'annotate:annotate node/service'
  'config:configure pmm-agent'
  'help:show help'
  'inventory:inventory operations'
  'list:list services'
  'register:register node'
  'remove:remove service'
  'repair:repair service'
  'status:show agent status'
  'summary:create summary archive'
  'unregister:unregister node'
  'version:show version'
  'completion:generate completions'
)

_arguments -C \
  '--server-url=[server URL]:url:' \
  '--server-insecure-tls[skip TLS verify]' \
  '--debug[debug]' \
  '--trace[trace]' \
  '--pmm-agent-listen-port=[port]:port:' \
  '--json[JSON output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'pmm-admin subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (status) _arguments '--wait=[duration]:duration:' && ret=0 ;;
      (summary)
        _arguments \
          '--filename=[archive name]:name:' \
          '--skip-server[skip server logs]' \
          '--pprof[include profiling]' && ret=0 ;;
      (list) _arguments '--node-id=[node id]:id:' && ret=0 ;;
      (config)
        _arguments \
          '--node-model=[model]:model:' \
          '--region=[region]:region:' \
          '--az=[AZ]:az:' \
          '--agent-password=[password]:pw:' \
          '--force[force]' \
          '--disable-collectors=[list]:list:' \
          '--custom-labels=[labels]:labels:' \
          '--paths-base=[path]:path:_files -/' \
          '--log-level=[level]:level:(debug info warn error fatal)' \
          '--log-lines-count=[lines]:n:' \
          '--metrics-mode=[mode]:mode:(auto push pull)' \
          '*:address:' && ret=0 ;;
      (annotate)
        _arguments \
          '--tags=[tags]:list:' \
          '--node[annotate node]' \
          '--node-name=[name]:name:' \
          '--service[annotate services]' \
          '--service-name=[name]:name:' \
          '*:text:' && ret=0 ;;
      (register)
        _arguments \
          '--machine-id=[id]:id:' \
          '--distro=[distro]:distro:' \
          '--container-id=[id]:id:' \
          '--container-name=[name]:name:' \
          '--node-model=[model]:model:' \
          '--region=[region]:region:' \
          '--az=[AZ]:az:' \
          '--custom-labels=[labels]:labels:' \
          '--agent-password=[password]:pw:' \
          '--force[force]' \
          '--disable-collectors=[list]:list:' \
          '--metrics-mode=[mode]:mode:(auto push pull)' \
          '*:address or type:' && ret=0 ;;
      (unregister)
        _arguments \
          '--force[force]' \
          '--node-name=[name]:name:' && ret=0 ;;
      (remove)
        _arguments \
          '--service-id=[id]:id:' \
          '1:service-type:(mysql mongodb postgresql proxysql haproxy external valkey)' \
          '2:service-name:' && ret=0 ;;
      (add)
        _arguments \
          '1:type:(external external-serverless haproxy mongodb mysql postgresql proxysql valkey)' \
          '*:arg:' && ret=0 ;;
    esac
    ;;
esac

return ret
