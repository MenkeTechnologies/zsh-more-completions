#compdef syz-db
# _syz-db — manipulate syzkaller corpus databases (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Subcommands from tools/syz-db/syz-db.go (flag).

_syz-db() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '-version=[database version]:n:' \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                pack:'pack a directory of programs into a corpus database'
                unpack:'unpack a corpus database into a directory'
                merge:'merge multiple corpus databases'
                bench:'run deserialization benchmark and print stats'
                print:'print corpus database contents'
                rm:'remove a syscall from db'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                pack) _arguments '1:dir:_files -/' '2:corpus.db:_files' ;;
                unpack) _arguments '1:corpus.db:_files' '2:dir:_files -/' ;;
                merge) _arguments '1:dst corpus.db:_files' '*:src corpus.db or prog:_files' ;;
                bench|print) _arguments '1:corpus.db:_files' ;;
                rm) _arguments '1:corpus.db:_files' '2:syscall name:' ;;
            esac
            ;;
    esac
}

_syz-db "$@"
