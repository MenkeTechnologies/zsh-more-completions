#compdef kk
# Documentation: https://github.com/kubesphere/kubekey/blob/3.x/docs/commands/kk.md
# KubeKey: install Kubernetes and cloud-native add-ons (all-in-one, multi-node, HA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable verbose output]' \
  '(-f --filename)'{-f,--filename}'=[path to configuration file]:file:_files' \
  '(-a --artifact)'{-a,--artifact}'=[path to a KubeKey artifact]:file:_files' \
  '--certificates-dir=[directory for storing required certificates]:dir:_files -/' \
  '--container-manager=[container runtime]:runtime:(docker crio containerd isula)' \
  '--download-cmd=[custom command for downloading binaries]:cmd' \
  '--ignore-err[continue despite errors, removing problematic hosts]' \
  '--in-cluster[execute from within the cluster environment]' \
  '--skip-pull-images[bypass pre-pulling container images]' \
  '--skip-push-images[bypass pre-pushing container images]' \
  '--with-kubernetes=[override config Kubernetes version]:version' \
  '--with-kubesphere=[deploy specified KubeSphere version]:version' \
  '--with-local-storage[install local PV provisioner]' \
  '--with-packages[install OS packages via artifact]' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
  '1:command:(add artifact certs completion create delete init plugin upgrade version)' \
  '*::arg:->args' && ret=0

return ret
