#compdef netChainSubset
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: create chain file with subset of chains that appear in the net

local ret=1

_arguments -s -S \
  '-gapOut=[output gap sizes to file]:file:_files' \
  '-type=[restrict output to particular type in net file]:type' \
  '-splitOnInsert[split chain when get an insertion of another chain]' \
  '-wholeChains[write entire chains referenced by net, do not split]' \
  '-skipMissing[skip chains that are not found instead of erroring]' \
  '1:input net:_files -g "*.net"' \
  '2:input chain:_files -g "*.chain"' \
  '3:output chain:_files -g "*.chain"' && ret=0

return ret
