#compdef sfeikods
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/llisiw/Meikods.c
# Madagascar: Fast marching eikonal solver with source perturbation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vel=[input is velocity (y) or slowness (n)]:flag:(y n)' \
  'order=[accuracy order]:order:' \
  'sweep=[use sweeping (y/n)]:flag:(y n)' \
  'br1=[box size 1]:b:' \
  'br2=[box size 2]:b:' \
  'br3=[box size 3]:b:' \
  'plane1=[plane-wave source in dim 1 (y/n)]:flag:(y n)' \
  'plane2=[plane-wave source in dim 2 (y/n)]:flag:(y n)' \
  'plane3=[plane-wave source in dim 3 (y/n)]:flag:(y n)' \
  'b1=[constant-velocity box samples in dim 1]:n:' \
  'b2=[constant-velocity box samples in dim 2]:n:' \
  'b3=[constant-velocity box samples in dim 3]:n:' \
  'shotfile=[shot location file]:file:_files' \
  'zshot=[shot z coordinate]:z:' \
  'yshot=[shot y coordinate]:y:' \
  'xshot=[shot x coordinate]:x:' \
  'tdl1=[traveltime derivative output 1]:file:_files' \
  'tds1=[slowness derivative output 1]:file:_files' \
  'tdl2=[traveltime derivative output 2]:file:_files' \
  'tds2=[slowness derivative output 2]:file:_files' \
  'l=[perturbation order]:n:' \
  '*:RSF file:_files' && ret=0

return ret
