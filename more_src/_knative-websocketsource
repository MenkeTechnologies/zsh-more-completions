#compdef knative-websocketsource
# _knative-websocketsource — Knative Eventing reference WebSocket CloudEvent source
# upstream: https://github.com/knative/eventing
# Flags from cmd/websocketsource/main.go on tip.

_knative-websocketsource() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--sink=[destination URL to send events to]:url:_urls' \
        '--source=[WebSocket URL to receive messages from]:url:_urls' \
        '--eventType=[CloudEvents type attribute]:type:' \
        '--eventSource=[CloudEvents source attribute]:uri:'
}

_knative-websocketsource "$@"
