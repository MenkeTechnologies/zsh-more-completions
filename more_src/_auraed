_auraed() {
    case "$service" in
        auraescript)
            _arguments \
                '(- *)'{-h,--help}'[show help]' \
                '*:TypeScript/JavaScript module:_files -g "*.(ts|tsx|js|mjs|mts)"' && return
            ;;
    esac

    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--server-crt=[signed server certificate (default /etc/aurae/pki/_signed.server.crt)]:cert:_files -g "*.crt"' \
        '--server-key=[secret server key (default /etc/aurae/pki/server.key)]:key:_files -g "*.key *.pem"' \
        '--ca-crt=[CA certificate (default /etc/aurae/pki/ca.crt)]:cert:_files -g "*.crt"' \
        '(-s --socket)'{-s,--socket}'=[aurae socket (file or addr; default ${runtime_dir}/aurae.sock or [::1]:8080)]:addr:' \
        '(-r --runtime-dir)'{-r,--runtime-dir}'=[runtime path (default /var/run/aurae)]:dir:_files -/' \
        '(-l --library-dir)'{-l,--library-dir}'=[library path (default /var/lib/aurae)]:dir:_files -/' \
        '(-v --verbose --ritz)'{-v,--verbose,--ritz}'[verbose logging]' \
        '--nested[run as nested auraed instance inside an Aurae cell]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ad_cmds=(
                'spawn:spawn child auraed instance'
            )
            _describe -t commands 'auraed command' _ad_cmds && ret=0
            ;;
        args)
            case $words[1] in
                spawn)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output directory (default .)]:dir:_files -/' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_auraed "$@"
