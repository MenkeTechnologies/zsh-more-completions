#compdef zfs-program
# _zfs-program — OpenZFS zfs program (run a Lua-based channel program in the SPA kernel context for atomic, multi-dataset operations; -n no-effect (dry run), -j JSON output, -t timeout ms, -m memory cap bytes; positional pool, program file, optional args)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c (zfs_do_channel_program) on tip.

_zfs-program() {
    _arguments \
        '-n[no-effect (read-only)]' \
        '-j[JSON output]' \
        '-t+[timeout ms]:ms:' \
        '-m+[memory cap bytes]:bytes:' \
        '1:pool:' \
        '2:program file:_files -g "*.lua"' \
        '*:program args:'
}

_zfs-program "$@"
