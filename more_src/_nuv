#compdef nuv
# Documentation: https://man.archlinux.org/search?q=nuv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

local -a tasks=(
  '-login:log into Nuvolaris'
  '-logout:log out'
  '-update:update embedded tools and tasks'
  '-config:edit Nuvolaris configuration'
  '-task:embedded Task tool'
  '-wsk:embedded wsk CLI (OpenWhisk)'
  '-basename:embedded basename'
  '-cat:embedded cat'
  '-curl:embedded curl'
  '-dirname:embedded dirname'
  '-envsubst:embedded envsubst'
  '-jq:embedded jq'
  '-realpath:embedded realpath'
  '-sed:embedded sed'
  '-yq:embedded yq'
  '-version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-version[show version]' \
  '*::task_or_invocation:->tasks' && ret=0

case $state in
  (tasks) _describe -t tasks 'nuv task' tasks && ret=0 ;;
esac

return ret
