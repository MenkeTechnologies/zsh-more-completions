#compdef log2graph
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/log2graph.cpp
# Convert a plain text log file into an OctoMap binary scan graph

local ret=1

_arguments -s -S \
  ':input log:_files -g "*.log"' \
  ':output graph:_files -g "*.graph"' && ret=0

return ret
