#compdef cargo-valgrind
# Documentation: https://crates.io/crates/cargo-valgrind
# run cargo subcommands under valgrind to detect memory errors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:cargo subcommand:(run test bench)' \
  '*::cargo args:_default' && ret=0

return ret
