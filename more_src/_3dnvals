#compdef 3dnvals
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dnvals.html
# AFNI report number of sub-bricks in a 3D dataset

local ret=1

_arguments -s -S \
  '-all[output all four dimensions Nx Ny Nz Nvals]' \
  '-verbose[show header filename before results]' \
  '*:dataset:_files' && ret=0

return ret
