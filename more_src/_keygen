#compdef keygen
# Documentation: https://keygen.sh/docs/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (keygen-sh/keygen-cli).
# Corrected from prior file: only `upload` accepts --platform/--arch/
# --signing-key and only `new` accepts --channel/--version; publish/
# tag/untag/yank/del accept only --release. Added real --no-color
# global flag.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'genkey:generate an Ed25519 public/private key pair'
  'new:create a new release object (DRAFT)'
  'upload:upload an artifact to a release'
  'publish:set a release to PUBLISHED'
  'tag:tag an existing release'
  'untag:untag an existing release'
  'yank:yank an existing release'
  'del:delete an existing release'
  'upgrade:check for and install CLI upgrades'
)

_arguments -C \
  '--account=[account UUID]:uuid:' \
  '--product=[product UUID]:uuid:' \
  '--token=[API token]:token:' \
  '--no-color[disable colored output]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'keygen subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new)
        _arguments \
          '--channel=[release channel]:channel:' \
          '--version=[release version]:version:' && ret=0
        ;;
      (upload)
        _arguments \
          '--release=[target release version]:release:' \
          '--platform=[target platform]:platform:' \
          '--arch=[target architecture]:arch:' \
          '--signing-key=[path to Ed25519 signing key]:file:_files' \
          '*:artifact:_files' && ret=0
        ;;
      (publish|tag|untag|yank|del)
        _arguments \
          '--release=[release identifier]:release:' && ret=0
        ;;
      (upgrade)
        _arguments \
          '--no-auto-upgrade[disable automatic upgrade checks]' && ret=0
        ;;
    esac
    ;;
esac

return ret
