#compdef keygen
# Documentation: https://man.archlinux.org/search?q=keygen
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'genkey:generate Ed25519 key pair'
  'new:create new release object'
  'upload:upload artifact to release'
  'publish:set release to PUBLISHED'
  'tag:set release tag'
  'untag:remove release tag'
  'yank:set release to YANKED'
  'del:delete release'
  'upgrade:check for CLI updates'
)

_arguments -C \
  '--account=[account UUID]:uuid:' \
  '--product=[product UUID]:uuid:' \
  '--token=[API token]:token:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-auto-upgrade[disable auto upgrade]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'keygen subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (new|upload|publish|tag|untag|yank|del)
        _arguments \
          '--release=[release name]:release:' \
          '--channel=[channel]:channel:' \
          '--version=[version]:version:' \
          '--platform=[platform]:platform:' \
          '--arch=[architecture]:arch:' \
          '--signing-key=[signing key]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
