#compdef chsh-cli chfn-cli
# _chsh-cli — util-linux chsh/chfn change shell or finger info CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_chsh-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-l[list available shells]' \
        '--list-shells[list available shells]' \
        '-s+[shell]:str:' \
        '--shell=+[shell]:str:' \
        '-f+[full name]:str:' \
        '--full-name=+[full name]:str:' \
        '-o+[office room]:str:' \
        '--office=+[office room]:str:' \
        '-p+[office phone]:str:' \
        '--office-phone=+[office phone]:str:' \
        '-r+[home phone]:str:' \
        '--home-phone=+[home phone]:str:' \
        '*:user:_users'
}

_chsh-cli "$@"
