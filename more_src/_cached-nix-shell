#compdef cached-nix-shell
# Documentation: https://github.com/xzfc/cached-nix-shell
# instant caching wrapper around nix-shell

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --packages)'{-p,--packages}'[install the specified packages]:packages:' \
  '(-i)-i[interpreter to use for the script]:interpreter:' \
  '--run=[run a command in the environment]:command:' \
  '--command=[run a command in the environment]:command:' \
  '--wrap[wrap a program that calls nix-shell internally]' \
  '--pure[clear most of the environment before building]' \
  '*:file:_files' && ret=0

return ret
