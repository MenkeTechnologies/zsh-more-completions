#compdef remap
# Documentation: https://man.archlinux.org/search?q=remap
# Reference accessed: 2026-05-16

# EMBOSS remap: display restriction enzyme cleavage sites and translation
# overlay on a DNA sequence in a publication-ready map.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show command-line help]' \
  '-auto[turn off prompts]' \
  '-stdout[write report to stdout]' \
  '-filter[stdin/stdout filter]' \
  '-options[prompt for ACD qualifiers]' \
  '-debug[debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[fatal errors]' \
  '-die[dying messages]' \
  '-version[print version]' \
  '-sequence=[DNA sequence(s) to map]:sequence USA:_files' \
  '-enzymes=[enzymes (comma-list, "all" for full REBASE, "@file" for list)]:enzymes:' \
  '-sitelen=[minimum recognition-site length to consider]:length:(4 5 6 7 8 9 10)' \
  '-mincuts=[only show enzymes with at least N cuts]:min cuts:' \
  '-maxcuts=[only show enzymes with at most N cuts]:max cuts:' \
  '-single[force enzymes to appear at only one site]' \
  '-blunt[include enzymes that cut blunt-ended]' \
  '-sticky[include enzymes that cut sticky-ended]' \
  '-ambiguity[treat ambiguity codes as exact matches]' \
  '-plasmid[treat sequence as circular]' \
  '-methylation[exclude enzymes blocked by methylation patterns]' \
  '-commercial[only include commercially available enzymes]' \
  '-table=[genetic code (NCBI translation table)]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-frames=[reading frames to translate]:frames:(1 2 3 -1 -2 -3 F R 6)' \
  '-cutlist[print enzyme cut-position list]' \
  '-flatreformat[print map flat (no overlap arrows)]' \
  '-limit[only show one of each pair of isoschizomers]' \
  '-translation[include protein translation in output]' \
  '-orfminsize=[minimum ORF length to report]:length:' \
  '-uppercase=[uppercase regions (start..end[,start..end])]:regions:' \
  '-highlight=[highlight regions of sequence]:regions:' \
  '-threeletter[use three-letter amino acid codes]' \
  '-number[number residues in output]' \
  '-width=[display columns per line]:cols:' \
  '-length=[output line length]:cols:' \
  '-margin=[output margin width]:cols:' \
  '-name[include sequence name in output]' \
  '-description[include sequence description]' \
  '-offset=[number from offset value]:offset:' \
  '-html[output HTML formatted map]' \
  '-outfile=[output file (default remap.out)]:file:_files' \
  '*:DNA sequence:_files' && ret=0

return ret
