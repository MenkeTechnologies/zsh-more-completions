#compdef kicost

# KiCost: KiCad cost-of-materials estimator (BOM pricing)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input=}'[KiCad BOM XML file(s)]:file:_files -g "*.xml"' \
  '(-o --output)'{-o,--output=}'[output spreadsheet file]:file:_files -g "*.xlsx"' \
  '(-f --field)'{-f,--field=}'[BOM fields to include]:fields:' \
  '(-eda --eda)'{-eda,--eda=}'[EDA tool source]:eda:(kicad altium csv generic_csv proteus)' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite output without prompting]' \
  '(-n --num_processes)'{-n,--num_processes=}'[number of parallel processes]:n:' \
  '--include[distributors to include]:list:(digikey mouser farnell newark rs tme arrow)' \
  '--exclude[distributors to exclude]:list:' \
  '(-s --serial)'{-s,--serial}'[query distributors serially]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '--collapse_refs[collapse same-part references]' \
  '--no_collapse[do not collapse references]' \
  '--variant[variant name]:variant:' \
  '--currency[currency code]:cur:(USD EUR GBP CNY JPY)' \
  '--debug[debug level]:n:' \
  '--api_key[API key for distributor]:key:' \
  '*:KiCad XML or netlist file:_files' && ret=0
return ret
