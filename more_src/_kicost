#compdef kicost
# Documentation: https://github.com/hildogjr/KiCost/blob/master/kicost/__main__.py
# Reference accessed: 2026-05-19
# Verified: upstream source (argparse) at the URL above.

# KiCost: KiCad cost-of-materials estimator (BOM pricing)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)'{-v,--version}'[show program version]' \
  '(- *)--info[show program and library information and version]' \
  '(-i --input)'{-i,--input}'[one or more schematic BOM XML files]:*:file:_files' \
  '(-o --output)'{-o,--output}'[generated cost spreadsheet]:file:_files' \
  '(-f --fields)'{-f,--fields}'[additional part fields to include]:fields:' \
  '--translate_fields[specify or remove field translation]:fields:' \
  '--variant[schematic variant name filter (regex)]:variant:' \
  '(-w --overwrite)'{-w,--overwrite}'[allow overwriting an existing spreadsheet]' \
  '(-q --quiet)'{-q,--quiet}'[enable quiet mode with no warnings]' \
  '--ignore_fields[part fields to ignore when reading the BoM]:fields:' \
  '--group_fields[part fields to merge when grouping parts]:fields:' \
  '--split_extra_fields[part fields for the multipart split process]:fields:' \
  '--debug[print debugging info (larger LEVEL means more info)]:level:' \
  '--eda[EDA tool the BOM originated from]:eda:(kicad altium csv generic_csv)' \
  '(- *)--show_dist_list[show list of distributors, then exit]' \
  '(- *)--show_eda_list[show list of EDA tools, then exit]' \
  '--no_collapse[do not collapse part references in the spreadsheet]' \
  '--show_cat_url[show catalogue links in the spreadsheet]' \
  '(-e --exclude)'{-e,--exclude}'[exclude the given distributor(s)]:distributors:' \
  '--include[include only the given distributor(s)]:distributors:' \
  '--no_price[create a spreadsheet without scraping distributor data]' \
  '--currency[priority currency (ISO4217, e.g. USD EUR)]:currency:' \
  '(-n --board_qty)'{-n,--board_qty}'[number of boards to fabricate]:qty:' \
  '--max_column_width[maximum column width (0 disables adjust)]:width:' \
  '--gui[start the GUI passing the --input file]:file:_files' \
  '--force_en_us[workaround for broken wxWidgets locale on Windows]' \
  '(- *)--setup[run KiCost integration configuration script]' \
  '(- *)--unsetup[undo the KiCost integration]' \
  '--disable_api[disable the listed APIs]:apis:' \
  '--enable_api[enable the listed APIs]:apis:' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '--cache_ttl[force the Time To Live for the APIs caches]:ttl:' \
  '--cache_path[force the base path for the APIs caches]:dir:_files -/' \
  '*:KiCad BOM XML file:_files -g "*.xml"' && ret=0
return ret
