#compdef tink-agent
# _tink-agent — Tinkerbell next-gen worker agent (tinkerbell/tink)
# upstream: https://github.com/tinkerbell/tink
# Flags from internal/cli/agent.go on tip.

_tink-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--agent-id=[unique agent instance ID]:id:' \
        '--tink-server-addr=[Tink server gRPC host\:port]:host\:port:' \
        '-v[klog verbosity level]:n:'
}

_tink-agent "$@"
