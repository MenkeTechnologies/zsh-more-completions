#compdef conan

# Zsh completion for conan (C/C++ package manager v2)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build a package from source'
      'cache:manage Conan cache'
      'config:manage Conan configuration'
      'create:create a package'
      'download:download packages from remote'
      'editable:manage editable packages'
      'export:export a recipe to the cache'
      'export-pkg:export pre-built binaries'
      'graph:dependency graph operations'
      'inspect:inspect a conanfile'
      'install:install dependencies'
      'list:list packages'
      'lock:manage lockfiles'
      'new:create a new conanfile template'
      'pkglist:package list operations'
      'profile:manage profiles'
      'remote:manage remotes'
      'remove:remove packages'
      'search:search packages in remotes'
      'source:run source method of a recipe'
      'test:test a package'
      'upload:upload packages to remote'
      'version:show version'
    )
    _describe -t commands 'conan command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments \
          '(-of --output-folder)'{-of,--output-folder}'[output folder]:folder:_files -/' \
          '(-g --generator)'{-g,--generator}'[generators to use]:generator:(CMakeDeps CMakeToolchain MSBuildDeps MSBuildToolchain MesonToolchain BazelDeps BazelToolchain PkgConfigDeps VirtualBuildEnv VirtualRunEnv AutotoolsDeps AutotoolsToolchain)' \
          '--deployer[deployer to use]:deployer' \
          '-r[remote]:remote' \
          '-nr[do not resolve remotes]' \
          '-u[update packages]' \
          '--build[build policy]:policy:(never missing outdated cascade)' \
          '(-pr --profile)'{-pr,--profile}'[profile]:profile' \
          '(-s --settings)'{-s,--settings}'[settings]:setting' \
          '(-o --options)'{-o,--options}'[options]:option' \
          '(-c --conf)'{-c,--conf}'[configuration]:config' \
          '--lockfile[lockfile]:file:_files -g "*.lock"' \
          '1:path or reference:_files' && ret=0
        ;;
      (create)
        _arguments \
          '--build[build policy]:policy:(never missing outdated cascade)' \
          '(-pr --profile)'{-pr,--profile}'[profile]:profile' \
          '(-s --settings)'{-s,--settings}'[settings]:setting' \
          '(-o --options)'{-o,--options}'[options]:option' \
          '(-c --conf)'{-c,--conf}'[configuration]:config' \
          '-r[remote]:remote' \
          '-u[update packages]' \
          '--name[package name]:name' \
          '--version[package version]:version' \
          '--user[package user]:user' \
          '--channel[package channel]:channel' \
          '1:path:_files -/' && ret=0
        ;;
      (profile)
        _arguments \
          '1:subcommand:(detect list path show)' \
          '2:profile' && ret=0
        ;;
      (remote)
        _arguments \
          '1:subcommand:(add disable enable list login logout remove rename set-user update)' && ret=0
        ;;
      (new)
        _arguments \
          '-d[define a template variable]:variable=value' \
          '-f[force overwrite]' \
          '1:template:(basic_layout cmake_lib cmake_exe meson_lib meson_exe msbuild_lib msbuild_exe bazel_lib bazel_exe autotools_lib autotools_exe)' && ret=0
        ;;
      (search)
        _arguments \
          '-r[remote]:remote' \
          '1:pattern' && ret=0
        ;;
      (list)
        _arguments \
          '-r[remote]:remote' \
          '-c[cache only]' \
          '--graph[use graph info]:file:_files' \
          '-p[package list pattern]:pattern' \
          '1:pattern' && ret=0
        ;;
      (upload)
        _arguments \
          '-r[remote]:remote' \
          '-c[only upload from cache]' \
          '--only-recipe[only upload recipe]' \
          '1:pattern' && ret=0
        ;;
    esac
    ;;
esac

return ret
