#compdef tf-a-tools fiptool
# Documentation: https://man.archlinux.org/search?q=tf-a-tools
# Reference accessed: 2026-05-16

# Trusted Firmware-A fiptool: create/update FIP (Firmware Image Package)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a new FIP'
  'update:update a FIP image'
  'unpack:unpack a FIP image'
  'remove:remove image from FIP'
  'info:show FIP info'
  'help:show help'
  'version:show version'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--force[force overwrite]' \
  '--align=[FIP align]:n:' \
  '--plat-toc-flags=[platform TOC flags]:hex:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'fiptool command' commands && ret=0 ;;
esac
return ret
