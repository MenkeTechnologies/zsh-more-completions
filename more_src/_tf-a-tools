#compdef tf-a-tools fiptool
# Documentation: https://trustedfirmware-a.readthedocs.io/en/latest/getting_started/tools-build.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Trusted Firmware-A fiptool: create/update FIP (Firmware Image Package)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a new FIP'
  'update:update an existing FIP'
  'unpack:unpack images from FIP'
  'remove:remove images from FIP'
  'info:list images contained in FIP'
  'help:show help for command'
  'version:show fiptool version'
)
_arguments -C \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'fiptool command' commands && ret=0 ;;
esac
return ret
