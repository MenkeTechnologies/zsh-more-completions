#compdef tracee-bench tracee-operator
# Documentation: source-direct extraction from upstream
# aquasecurity/tracee cmd/tracee-bench/main.go urfave/cli `app :=
# cli.App{Name: "tracee-bench", Usage: ..., Flags: []cli.Flag{...}}`
# + cmd/tracee-operator/main.go Go stdlib `flag.StringVar/BoolVar(...)`
# declarations in `parseConfig()`.
# Reference accessed: 2026-05-30 via gh api.
# Aqua tracee R152c — 2-stem multi-binary harvest of the 2 tracee
# auxiliary binaries not previously covered (`tracee` and
# `traceectl` from the same upstream cmd/ tree are already in
# the corpus). Note: the legacy `tracee-rules` and `tracee-ebpf`
# binaries from older tracee versions have been consolidated
# into the single `tracee` binary in current upstream - confirmed
# by 404 on `cmd/tracee-rules/` and `cmd/tracee-ebpf/` lookups.

case $service in

  tracee-bench)
    # Prometheus-based performance probe for tracee. Scrapes a
    # configured Prometheus instance for tracee_events_total and
    # tracee_lostevents_total rates and computes a benchmark
    # summary. Uses urfave/cli v2 not cobra.
    _arguments -s -S \
      '--prometheus=[Prometheus instance URL (default http://localhost:9090)]:url:_urls' \
      '--period=[scrape period in seconds]:sec:' \
      '--output=[output format]:format:(pretty json)'
    ;;

  tracee-operator)
    # Kubernetes operator for the Tracee DaemonSet using
    # sigs.k8s.io/controller-runtime. Manages the tracee.aquasec.
    # com/v1beta1 Policy CRD. Uses Go stdlib flag package + zap
    # logging options (zap.Options.BindFlags adds the standard
    # `--zap-*` flags below the listed ones).
    _arguments -s -S \
      '--metrics-bind-address=[address the metrics endpoint binds to (default :8080)]:addr:' \
      '--health-probe-bind-address=[address the health-probe endpoint binds to (default :8081)]:addr:' \
      '--tracee-namespace=[namespace where Tracee is installed (default tracee-system)]:ns:' \
      '--tracee-name=[name of the Tracee DaemonSet (default tracee)]:name:' \
      '--configmap-name=[name of the Tracee ConfigMap (default tracee-config)]:name:' \
      '--leader-elect[enable leader election (ensures only one active controller manager)]' \
      '--zap-devel[development-mode zap logger (verbose; stack traces on warnings)]' \
      '--zap-encoder=[zap log encoder]:encoder:(json console)' \
      '--zap-log-level=[zap log level]:level:(debug info error)' \
      '--zap-stacktrace-level=[zap stacktrace level]:level:(info error panic)'
    ;;

esac
