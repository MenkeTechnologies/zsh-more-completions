#compdef iina iina-cli
# Documentation: https://github.com/iina/iina/blob/develop/iina-cli/main.swift
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-w --separate-windows)'{-w,--separate-windows}'[open each file in its own window]' \
  '--stdin[read input from standard input]' \
  '--no-stdin[disable stdin input]' \
  '--keep-running[keep CLI running until IINA exits]' \
  '--music-mode[activate music mode after opening]' \
  '--pip[enable Picture-in-Picture after opening]' \
  '*--mpv-*=[pass mpv option (e.g. --mpv-volume=20)]:value:' \
  '*::file_or_url:_files' && ret=0

return ret
