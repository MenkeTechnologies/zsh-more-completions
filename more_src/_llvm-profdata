#compdef llvm-profdata
# _llvm-profdata — LLVM profile data tool (LLVM project, C++); manipulate PGO profile data
# upstream: https://github.com/llvm/llvm-project

_llvm-profdata() {
    local -a sub=(
        'show:print profile contents'
        'merge:merge profile files'
        'overlap:show overlap between profiles'
        'order:order functions'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llvm-profdata subcommand' sub ;;
        args)
            case $words[1] in
                show) _arguments \
                    '-all-functions[show all functions]' \
                    '-counts[show counts]' \
                    '-detailed-summary[detailed summary]' \
                    '-detailed-summary-cutoffs+[cutoffs]:n:' \
                    '-function=+[function name]:str:' \
                    '-ic-targets[ic targets]' \
                    '-instr[instrumented profile]' \
                    '-list-below-cutoff=+[cutoff]:n:' \
                    '-memop-sizes[show memop sizes]' \
                    '-o+[output file]:file:_files' \
                    '-output+[output file]:file:_files' \
                    '-text[text format]' \
                    '-topn=+[top N]:n:' \
                    '-value-cutoff=+[value cutoff]:n:' \
                    '-online-merge[online merge]' \
                    '-sample[sample profile]' \
                    '-show-prof-sym-list+[file]:file:_files' \
                    '*:profile file:_files -g "*.profdata"' ;;
                merge) _arguments \
                    '-correlate=+[correlate]:val:(binary debug-info)' \
                    '-debug-info=+[debug info]:file:_files' \
                    '-failure-mode=+[failure mode]:mode:(all any warn)' \
                    '-instr[instrumented profile]' \
                    '-num-threads=+[threads]:n:' \
                    '-j+[threads]:n:' \
                    '-output+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '-output-format=+[output format]:fmt:(binary text)' \
                    '-supplement-instr-with-sample+[sample file]:file:_files' \
                    '-sample[sample profile]' \
                    '-sparse[sparse merge]' \
                    '-input-files=+[input file list]:file:_files' \
                    '-weight=+[weight]:n:' \
                    '*:profile file:_files -g "*.profdata"' ;;
            esac
            ;;
    esac
}

_llvm-profdata "$@"
