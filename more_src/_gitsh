#compdef gitsh
# gitsh — interactive shell for git (thoughtbot)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--git=[path to git binary]:path:_files' \
  '--no-greeting[suppress the greeting message]' \
  && ret=0

return ret
