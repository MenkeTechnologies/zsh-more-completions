#compdef gevpick
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gEvPick.cxx
# gevpick - GENIE utility to cherry-pick events of a given topology

local ret=1

_arguments -s -S \
  '-i[input file(s); wildcards accepted]:files:_files' \
  '-t[type of events to cherry-pick]:topology:(all numu_cc_1pip numu_cc_1pi0 numu_cc_1pim numu_nc_1pip numu_nc_1pi0 numu_nc_1pim numu_cc_hyperon numubar_cc_hyperon cc_hyperon cc_qe numu_cc_qe cc_mec numu_cc_mec cc_qe_mec numu_cc_qe_mec not_cc_qe_mec not_numu_cc_qe_mec cc_not_qe_mec numu_not_cc_qe_mec)' \
  '-o[output filename (default gntp.<topology>.ghep.root)]:outfile:_files' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--event-record-print-level[level of information shown when printing the event record]:level:' \
  '*: :_files' && ret=0

return ret
