#compdef yaps
# Documentation: https://manpages.debian.org/testing/abcmidi/yaps.1.en.html
# translate abc music notation files to PostScript

local ret=1

_arguments -s -S \
  '-d[debug: display internal data structures]' \
  '-e+[draw only tunes with the given reference numbers]:list' \
  '-E[generate Encapsulated PostScript output]' \
  '-M+[set margin sizes in points (XXXxYYY)]:margins' \
  '-N[add page numbering]' \
  '-k+[add bar numbering, optional interval]:interval' \
  '-o+[output PostScript file name]:output file:_files -g "*.ps"' \
  '-P+[paper size (0=A4, 1=US Letter, or XXXxYYY)]:paper' \
  '-s+[scaling factor (default 0.7)]:scale' \
  '-V[print voices separately for multi-voice tunes]' \
  '-ver[print version number and exit]' \
  '-x[print tune number from X: field]' \
  '-OCC[accept the old chord convention]' \
  '*:abc file:_files -g "*.abc"' && ret=0

return ret
