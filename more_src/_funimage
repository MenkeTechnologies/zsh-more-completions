#compdef funimage
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funimage.1
# Create a FITS image from Funtools data files or event lists

local ret=1

_arguments -s -S \
  '-a[append output as image extension to existing FITS file]' \
  '-l[treat input as a list file (x col, y col, value)]' \
  '-p+[1D image projection along axis]:axis:(x y)' \
  '*:file:_files' && ret=0

return ret
