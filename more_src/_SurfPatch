#compdef SurfPatch
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfPatch.html
# AFNI/SUMA create surface patches from specified nodes

local ret=1

_arguments -s -S \
  '-spec[spec file containing input surfaces]:spec:_files' \
  '-surf_A[first input surface]:surface:' \
  '-input[node file inode ilabel defining patch]:nodefile:_files' \
  '-prefix[output prefix for the created patch]:outpref:' \
  '-hits[minimum nodes required per triangle (1-3)]:min_hits:' \
  '-masklabel[only use nodes labeled with this mask value]:msk:' \
  '(-vol -vol_only)-vol[calculate volume between two surfaces]' \
  '(-vol -vol_only)-vol_only[calculate volume without writing patch files]' \
  '-out_type[output format]:type:(FreeSurfer SureFit 1D Ply)' \
  '-patch2surf[convert patch to full surface with patch nodes]' \
  '-node_depth[compute depth relative to principal direction]:node_depth:' \
  '(-check_bowtie -fix_bowtie -ok_bowtie)-check_bowtie[check for bowtie artifacts]' \
  '(-check_bowtie -fix_bowtie -ok_bowtie)-fix_bowtie[remove bowtie artifacts]' \
  '(-check_bowtie -fix_bowtie -ok_bowtie)-ok_bowtie[skip bowtie checking]' \
  '(-adjust_contour -do-not-adjust_contour)-adjust_contour[shrink contours at non-selected nodes]' \
  '(-adjust_contour -do-not-adjust_contour)-do-not-adjust_contour[skip contour adjustment (default)]' \
  '-stiched_surface[write stitched surface used for volume]:surf:' \
  '-coord_gain[multiply coordinates for easier viewing]:gain:' \
  '-flip_orientation[reverse triangle orientation]' \
  '-verb[set verbosity level]:verb:' \
  '*:surface:_files' && ret=0

return ret
