#compdef impacket-dcomexec
# Documentation: https://github.com/fortra/impacket/blob/master/examples/dcomexec.py
# Executes a semi-interactive shell using the ShellBrowserWindow DCOM object

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-share=[share where the output will be grabbed from (default ADMIN$)]:share' \
  '-nooutput[do not print the output (no SMB connection created)]' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-codec=[sets encoding used (codec) from the target'\''s output (default utf-8)]:codec' \
  '-object=[DCOM object used to execute the shell command (default ShellWindows)]:object' \
  '-com-version=[DCOM version, format MAJOR_VERSION:MINOR_VERSION e.g. 5.7]:version' \
  '-shell-type=[choose a command processor for the semi-interactive shell]:type' \
  '-silentcommand[does not execute cmd.exe to run given command]' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '-dc-ip=[IP address of the domain controller]:ip' \
  '-A=[smbclient/mount.cifs-style authentication file]:file:_files' \
  '-keytab=[read keys for SPN from keytab file]:file:_files' \
  '1:target (\[\[domain/\]username\[:password\]@\]<host>):' \
  '2:command:' && ret=0

return ret
