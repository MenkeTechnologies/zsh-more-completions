#compdef sn1per sniper
# _sn1per — XeroSecurity sn1per CLI automated reconnaissance scanner orchestrating nmap nikto dirb amass theHarvester sublist3r metasploit-aux modules wordpress-scan joomscan testssl recon-ng masscan workspace-bound vulnerability assessment producing HTML PDF JSON pen-test report for offensive security workflow (XeroSecurity team, shell/Python); custom argparse
# upstream: https://github.com/1N3/Sn1per

_sn1per() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[target]:str:' \
        '--target=+[target]:str:' \
        '-w+[workspace]:str:' \
        '--workspace=+[name]:str:' \
        '-m+[mode]:m:(normal stealth nuke discover web webonly mass massvulnscan masswebscan stealthlist passive vulnscan webvulnscan webvulnscanmedium webvulnscanhigh)' \
        '--mode=+[m]:m:(normal stealth nuke discover web webonly mass massvulnscan masswebscan stealthlist passive vulnscan webvulnscan webvulnscanmedium webvulnscanhigh)' \
        '-t+[target file]:file:_files' \
        '--target-file=+[file]:file:_files' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-f+[report format]:f:(html pdf json text csv)' \
        '--format=+[format]:f:(html pdf json text csv)' \
        '--osint[passive OSINT only]' \
        '--noportscan[skip port scan]' \
        '--nobrute[skip brute force]' \
        '--report[generate report]' \
        '--update[update sn1per]' \
        '--api[API server mode]' \
        '--list-workspaces[list workspaces]' \
        '--delete-workspace=+[name]:str:' \
        '--get-workspace=+[name]:str:' \
        '--reimport-workspace=+[name]:str:' \
        '*:target:'
}

_sn1per "$@"
