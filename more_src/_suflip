#compdef suflip
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/suflip.c
# SUFLIP - flip a data set in various ways

local ret=1

_arguments -s -S \
  'flip=[rotational sense of flip]:f:' \
  'tmpdir=[directory path for temp files]:dir:_files -/' \
  'verbose=[=1 echoes flip info]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
