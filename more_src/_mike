#compdef mike

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'deploy:deploy documentation for a version'
      'delete:delete a version of documentation'
      'alias:create an alias for a version'
      'retitle:change the title of a version'
      'list:list deployed versions'
      'set-default:set the default version'
      'serve:serve documentation locally'
      'generate-completion:generate shell completion'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (deploy)
        _arguments \
          '(-t --title)'{-t,--title}'=[title for the version]:title:' \
          '(-S --set-default)'{-S,--set-default}'[set as default version]' \
          '(-u --update-aliases)'{-u,--update-aliases}'[update existing aliases]' \
          '(-A --alias)'{-A,--alias}'=[alias for this version]:alias:' \
          '(-F --config-file)'{-F,--config-file}'=[mkdocs.yml file]:file:_files' \
          '(-b --branch)'{-b,--branch}'=[branch to deploy to]:branch:' \
          '(-r --remote)'{-r,--remote}'=[remote to push to]:remote:' \
          '(-p --push)'{-p,--push}'[push after deploy]' \
          '--prefix=[subdirectory prefix]:prefix:' \
          '--rebase[rebase before pushing]' \
          '--ignore[ignore build errors]' \
          '1:version:' && ret=0
        ;;
      (delete)
        _arguments \
          '--all[delete all versions]' \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' \
          '(-p --push)'{-p,--push}'[push after delete]' \
          '(-r --remote)'{-r,--remote}'=[remote]:remote:' \
          '*:version:' && ret=0
        ;;
      (alias)
        _arguments \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' \
          '(-p --push)'{-p,--push}'[push after alias]' \
          '(-r --remote)'{-r,--remote}'=[remote]:remote:' \
          '1:version:' \
          '*:alias:' && ret=0
        ;;
      (retitle)
        _arguments \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' \
          '(-p --push)'{-p,--push}'[push after retitle]' \
          '(-r --remote)'{-r,--remote}'=[remote]:remote:' \
          '1:version:' \
          '2:title:' && ret=0
        ;;
      (set-default)
        _arguments \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' \
          '(-p --push)'{-p,--push}'[push after set-default]' \
          '(-r --remote)'{-r,--remote}'=[remote]:remote:' \
          '1:version:' && ret=0
        ;;
      (list)
        _arguments \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' \
          '(-r --remote)'{-r,--remote}'=[remote]:remote:' \
          '(-j --json)'{-j,--json}'[JSON output]' && ret=0
        ;;
      (serve)
        _arguments \
          '(-a --dev-addr)'{-a,--dev-addr}'=[address to serve on]:address:' \
          '(-b --branch)'{-b,--branch}'=[branch]:branch:' && ret=0
        ;;
    esac
    ;;
esac

return ret
