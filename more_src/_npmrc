#compdef npmrc
# Documentation: https://github.com/deoxxa/npmrc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --create)'{-c+,--create=}'[create new profile]:name:' \
  '(-r --registry)'{-r+,--registry=}'[switch to mirror registry]:mirror:(au eu cn default)' \
  '(-l --list)'{-l,--list}'[list profiles]' \
  '(-d --delete)'{-d+,--delete=}'[delete profile]:name:' \
  '(-s --status)'{-s,--status}'[show current profile]' \
  '*:profile name:' && ret=0

return ret
