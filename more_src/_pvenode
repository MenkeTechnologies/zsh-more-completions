#compdef pvenode
# _pvenode — Proxmox Server Solutions pvenode Proxmox VE node configuration CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pvenode() {
    local -a sub=(
        'acme:ACME subcommands'
        'cert:certificate subcommands'
        'config:node config subcommands'
        'task:task subcommands'
        'wakeonlan:wake-on-LAN a node'
        'startall:start all guests'
        'stopall:stop all guests'
        'migrateall:migrate all guests'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pvenode subcommand' sub ;;
        args)
            case $words[1] in
                acme) _arguments '1:acme cmd:(account cert plugin order register list update)' ;;
                cert) _arguments '1:cert cmd:(info set delete list)' ;;
                config) _arguments '1:config cmd:(get set)' ;;
                task) _arguments '1:task cmd:(list log status)' ;;
                wakeonlan) _arguments '1:node:' ;;
                startall|stopall) _arguments \
                    '--force[force action]' \
                    '--vms=+[vmids csv]:str:' ;;
                migrateall) _arguments \
                    '--maxworkers=+[N]:n:' \
                    '--target=+[target node]:str:' \
                    '--vms=+[vmids csv]:str:' \
                    '--with-local-disks[migrate local disks]' \
                    '1:node:' ;;
            esac
            ;;
    esac
}

_pvenode "$@"
