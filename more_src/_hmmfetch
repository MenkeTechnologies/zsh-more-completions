#compdef hmmfetch
# Documentation: https://github.com/EddyRivasLab/hmmer/blob/master/src/hmmfetch.c
# Reference accessed: 2026-05-27
# Verified: upstream src/hmmfetch.c ESL_OPTIONS table (HMMER 3.x)

# HMMER hmmfetch: retrieve profile HMM(s) from a file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help on version and usage]' \
  '-f[second command-line arg is a file of names to retrieve]' \
  '-o[output HMM to file instead of stdout]:file:_files' \
  '-O[output HMM to file named after the key]' \
  '--index[index the HMM file, creating a .ssi index file]' \
  '*:HMM file and key:_files' && ret=0
return ret
