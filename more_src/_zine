#compdef zine

local curcontext="$curcontext" state line ret=1

_zine_commands() {
  local -a commands=(
    'new:create a new zine project or theme'
    'build:build the zine site'
    'serve:serve the zine site locally'
    'markdown:render markdown'
  )
  _describe -t commands 'zine command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_zine_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --path)'{-p,--path}'[path for the new project]:path:_directories' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-s --source)'{-s,--source}'[source directory]:source:_directories' \
          '(-d --dest)'{-d,--dest}'[destination directory]:dest:_directories' \
          '(-p --path)'{-p,--path}'[project path]:path:_directories' \
          && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-p --path)'{-p,--path}'[project path]:path:_directories' \
          '--port[port to serve on]:port:' \
          '(-o --open)'{-o,--open}'[open browser automatically]' \
          '(-s --source)'{-s,--source}'[source directory]:source:_directories' \
          '(-d --dest)'{-d,--dest}'[destination directory]:dest:_directories' \
          && ret=0
        ;;
      markdown)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
