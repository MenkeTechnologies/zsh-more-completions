#compdef rtabmap-export
# Documentation: https://github.com/introlab/rtabmap/blob/master/tools/Export/main.cpp
# Export point clouds, meshes, poses and grids from an RTAB-Map database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cloud[export assembled point cloud]' \
  '--mesh[export assembled mesh]' \
  '--poses[export optimized robot frame poses]' \
  '--poses_camera[export optimized camera frame poses]' \
  '--poses_scan[export optimized scan frame poses]' \
  '--poses_landmark[export optimized landmark poses]' \
  '--poses_gt[export ground truth robot frame poses]' \
  '--poses_gps[export GPS poses in local coordinates]' \
  '--gps[export GPS values in world coordinates]' \
  '--images[export images with timestamp as filename]' \
  '--images_id[export images with node ID as filename]' \
  '--map[export 2D occupancy grid]' \
  '--octomap[export 3D OctoMap]' \
  '--output=[set output filename]:name' \
  '--output_dir=[set output directory]:dir:_files -/' \
  '--ascii[export PLY in ASCII format]' \
  '--las[export cloud in LAS instead of PLY]' \
  '--decimation=[depth image decimation before cloud creation]:n' \
  '--min_range=[minimum cloud range in m]:m' \
  '--max_range=[maximum cloud range in m]:m' \
  '--voxel=[voxel size for point clouds in m]:m' \
  '--scan[use laser scan for point cloud]' \
  '--noise_radius=[noise filtering search radius]:r' \
  '--noise_k=[minimum neighbors for noise filtering]:k' \
  '--random_samples=[random filter output samples]:n' \
  '--color_radius=[radius for polygon colorization]:r' \
  '--ground_normals_up[flip ground normals if close to -z axis]' \
  '--filter_ceiling=[filter points above custom height]:h' \
  '--filter_floor=[filter points below custom height]:h' \
  '--texture[texture the mesh]' \
  '--texture_size=[texture resolution]:n' \
  '--texture_count=[maximum textures generated]:n' \
  '--texture_range=[maximum camera range for texturing]:m' \
  '--texture_angle=[maximum camera angle for texturing]:deg' \
  '--texture_depth_error=[maximum depth error for texturing]:e' \
  '--texture_color_policy=[vertex coloring method]:policy:(0 1 2)' \
  '--no_blending[disable blending during texturing]' \
  '--no_clean[disable cleaning colorless polygons]' \
  '--min_cluster=[filter polygon clusters smaller than threshold]:n' \
  '--poisson_depth=[Poisson depth for mesh reconstruction]:n' \
  '--poisson_size=[target polygon size in m]:m' \
  '--max_polygons=[maximum polygons when meshing]:n' \
  '--multiband[enable multiband texturing]' \
  '--multiband_downscale=[downscaling factor]:n' \
  '--multiband_contrib=[contributions per frequency band]:n' \
  '--multiband_unwrap=[unwrap method]:m:(0 1 2)' \
  '--multiband_fillholes[fill texture holes]' \
  '--multiband_padding=[texture edge padding]:n' \
  '--cam_projection[project camera onto cloud]' \
  '--cam_projection_keep_all[keep uncolored points]' \
  '--cam_projection_decimation=[image decimation before projection]:n' \
  '--cam_projection_mask=[mask file for projection]:file:_files' \
  '--opt=[optimization approach]:opt:(0 1 2 3)' \
  '--ba[global bundle adjustment]' \
  '--gain=[gain compensation value]:n' \
  '--gain_gray[apply compensation to grayscale only]' \
  '--low_gain=[low brightness gain]:n' \
  '--high_gain=[high brightness gain]:n' \
  '--poses_format=[output pose format]:fmt' \
  '--xmin=[X-axis min range filter]:m' \
  '--xmax=[X-axis max range filter]:m' \
  '--ymin=[Y-axis min range filter]:m' \
  '--ymax=[Y-axis max range filter]:m' \
  '--zmin=[Z-axis min range filter]:m' \
  '--zmax=[Z-axis max range filter]:m' \
  '--density_radius=[pose filtering radius]:r' \
  '--density_angle=[pose filtering angle threshold]:deg' \
  '--save_in_db[save results back to database]' \
  '*:database:_files -g "*.db"' && ret=0

return ret
