#compdef yarn-application yarn-app
# _yarn-application — Apache Hadoop YARN application client (administrative subcommand of yarn: -list, -kill <appId>, -status <appId>, -appStates, -appTypes, -movetoqueue, -changeQueue, -upgradeAttribute, -fail, -appAttempt, -components, -decommission, -nodes, -queue, -version)
# upstream: https://github.com/apache/hadoop
# Flags from Apache Hadoop hadoop-yarn ApplicationCLI on tip.

_yarn-application() {
    _arguments \
        '--help[show help]' \
        '-list[list applications]' \
        '-kill+[application id]:appId:' \
        '-status+[application id]:appId:' \
        '-appStates+[states csv]:states:(ALL ACCEPTED FINISHED FAILED KILLED RUNNING SUBMITTED NEW NEW_SAVING)' \
        '-appTypes+[types csv]:types:' \
        '-appTags+[tags csv]:tags:' \
        '-movetoqueue+[appId]:appId:' \
        '-queue+[queue]:queue:' \
        '-changeQueue+[appId queue]:spec:' \
        '-upgradeAttribute+[attr]:attr:' \
        '-fail+[appId]:appId:' \
        '-appAttempt+[appAttemptId]:attempt:' \
        '-components+[appId]:appId:' \
        '-decommission+[appId comp container]:spec:' \
        '-nodes[show nodes]' \
        '-version[show version]' \
        '*:argument:'
}

_yarn-application "$@"
