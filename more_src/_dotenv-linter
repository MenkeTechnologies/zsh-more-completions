#compdef dotenv-linter

# Zsh completion for dotenv-linter (.env file linter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'check:check .env files (default)'
      'fix:fix .env files'
      'compare:compare .env files'
      'list:list available checks'
    )
    _describe -t commands 'dotenv-linter command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (check|fix)
        _arguments \
          '(-e --exclude)'{-e,--exclude}'[exclude file]:file:_files' \
          '(-s --skip)'{-s,--skip}'[skip check]:check:(DuplicatedKey EndingBlankLine ExtraBlankLine IncorrectDelimiter KeyWithoutValue LeadingCharacter LowercaseKey QuoteCharacter SpaceCharacter SubstitutionKey TrailingWhitespace UnorderedKey)' \
          '--no-backup[do not create backup files]' \
          '(-r --recursive)'{-r,--recursive}'[recursively search directories]' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '--not-check-updates[disable update check]' \
          '(-v --version)'{-v,--version}'[show version]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files -g ".env*"' && ret=0
        ;;
      (compare)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file:_files -g ".env*"' && ret=0
        ;;
    esac
    ;;
esac

return ret
