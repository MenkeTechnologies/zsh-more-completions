#compdef umount.cifs
# Documentation: https://man.archlinux.org/search?q=umount.cifs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-v[verbose]' \
  '-l[lazy unmount - detach now, cleanup later]' \
  '-f[force unmount (even if busy)]' \
  '-n[do not update /etc/mtab]' \
  '-i[do not run /sbin/umount.<type>]' \
  '-r[remount read-only on failure]' \
  '*:mountpoint:_directories' && ret=0

return ret
