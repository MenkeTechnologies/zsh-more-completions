#compdef encrypted-kubeconfig kubectl-encrypted_kubeconfig
# Documentation: https://github.com/n4-de/kubectl-encrypted-kubeconfig
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# kubectl-encrypted-kubeconfig: client-go credentials plugin to work with encrypted KUBECONFIG.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:subcommand:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'auth:perform authentication against a cluster (used as client-go exec plugin)'
      'convert:encrypt a pre-existing KUBECONFIG file'
    )
    _describe -t commands 'encrypted-kubeconfig subcommand' cmds && ret=0
    ;;
  args)
    case ${words[1]} in
      convert)
        _arguments -s -S \
          '--kubeconfig=[KUBECONFIG to convert]:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
