#compdef pfstmo_reinhard02
# Documentation: http://pfstools.sourceforge.net/man1/pfstmo_reinhard02.1.html
# pfstools: Reinhard 2002 photographic tone reproduction operator

local ret=1

_arguments -s -S \
  '--scales[use scales for local adaptation (local version)]' \
  '--key=[key value for the image (default 0.18, range 0..1)]:val' \
  '--phi=[phi value (default 1.0, range >=0.0)]:val' \
  '--range=[range size (default 8, range >1)]:val' \
  '--lower=[lower scale size (default 1, range >=1)]:val' \
  '--upper=[upper scale size (default 43, range >=1)]:val' \
  '(-t --temporal-coherent)'{-t,--temporal-coherent}'[time-coherent tone mapping for video]' \
  '--verbose[print additional information]' \
  '--help[print list of command line options]' && ret=0

return ret
