#compdef d8
# Documentation: https://developer.android.com/tools/d8
# Source: Android SDK — Java bytecode → DEX compiler (successor to dx).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--debug --release)--debug[include debug info (symbol tables)]' \
    '(--debug --release)--release[no debug info (still keeps stack-trace data)]' \
    '--output=[output DEX path (default cwd)]:path:_files' \
    '--lib=[android.jar of the target SDK]:android.jar:_files -g "*.jar"' \
    '*--classpath=[classpath resources]:path:_files' \
    '--min-api=[minimum API level for the output DEX]:api:' \
    '--intermediate[not the complete set of bytecode (incremental)]' \
    '(--file-per-class --file-per-class-file)--file-per-class[one DEX per class]' \
    '(--file-per-class --file-per-class-file)--file-per-class-file[one DEX per .class input file]' \
    '--no-desugaring[disable Java 8 desugaring]' \
    '--main-dex-list=[file with classes for the main DEX]:file:_files' \
    '--main-dex-rules=[ProGuard keep rules for main DEX]:file:_files' \
    '--main-dex-list-output=[output resulting main DEX list]:file:_files' \
    '--pg-map=[mapping file for distribution]:file:_files' \
    '--desugared-lib=[desugared-library JSON configuration]:file:_files' \
    '(--force-enable-assertions --force-ea --force-disable-assertions --force-da --force-passthrough-assertions --force-pa --force-assertions-handler --force-ah)'{--force-enable-assertions,--force-ea}'[force-enable javac asserts]:scope:' \
    '(--force-enable-assertions --force-ea --force-disable-assertions --force-da --force-passthrough-assertions --force-pa --force-assertions-handler --force-ah)'{--force-disable-assertions,--force-da}'[force-disable javac asserts]:scope:' \
    '(--force-enable-assertions --force-ea --force-disable-assertions --force-da --force-passthrough-assertions --force-pa --force-assertions-handler --force-ah)'{--force-passthrough-assertions,--force-pa}'[leave javac asserts unchanged]:scope:' \
    '(--force-enable-assertions --force-ea --force-disable-assertions --force-da --force-passthrough-assertions --force-pa --force-assertions-handler --force-ah)'{--force-assertions-handler,--force-ah}'[invoke handler method on assertion error]:handler:scope:' \
    '--thread-count=[number of compilation threads]:n:' \
    '--map-diagnostics=[remap diagnostic level]:from-to:' \
    '(- *)--version[print d8 version]' \
    '(- *)--help[show help]' \
    '*:input .jar / .class:_files' \
    && ret=0

return ret
