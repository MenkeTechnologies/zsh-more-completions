#compdef ergodox ergodox-flasher teensy-loader-cli
# _ergodox — ErgoDox keyboard layout flashing utilities (Erez Zukerman / OLKB / ZSA, C); custom argparse for teensy-loader-cli
# upstream: https://github.com/PaulStoffregen/teensy_loader_cli

_ergodox() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-mmcu=+[microcontroller]:mcu:(atmega32u4 at90usb162 at90usb646 at90usb1286 atmega32u2 atmega32u4-amd atmega32u2-amd)' \
        '--mcu=+[microcontroller]:mcu:(atmega32u4 at90usb162 at90usb646 at90usb1286 atmega32u2 atmega32u4-amd atmega32u2-amd)' \
        '-w[wait for device]' \
        '--wait[wait for device]' \
        '-r[reboot device]' \
        '--reboot[reboot device]' \
        '-s[wait for device with soft-reboot]' \
        '--soft[wait for device with soft-reboot]' \
        '-n[no reboot after programming]' \
        '--no-reboot[no reboot after programming]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '*:file:_files -g "*.hex *.bin"'
}

_ergodox "$@"
