#compdef radiff2
# Documentation: https://manpages.debian.org/unstable/radare2/radiff2.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '*-A[run aaa after loading]' \
  '-C[graphdiff code]' \
  '-d[delta diffing]' \
  '-D[disasm output]' \
  '-j[JSON output]' \
  '-n[count changes]' \
  '-O[opcode bytes only]' \
  '-p[physical addressing]' \
  '-q[quiet]' \
  '-r[r2 commands output]' \
  '-s[Myers edit distance]' \
  '-ss[Levenshtein distance]' \
  '-T[threaded analysis]' \
  '-u[unified output]' \
  '-U[system diff unified]' \
  '-v[show version]' \
  '-V[verbose]' \
  '-x[two-column hex diff]' \
  '-X[xpatch format]' \
  '-a=[arch]:arch:(x86 arm mips ppc)' \
  '-b=[bits]:bits:(16 32 64)' \
  '-B=[base address]:addr:' \
  '-c=[r2 command]:cmd:' \
  '*-e=[eval k=v]:setting:' \
  '-f=[output format]:fmt:' \
  '-g=[graph diff]:sym:' \
  '-i=[bin info]:type:(imports exports symbols sections)' \
  '-l=[length]:len:' \
  '-m=[graph mode]:mode:(a d t s j J k i)' \
  '-o=[initial offset]:offset:' \
  '-S=[sort code diff]:field:(name namelen addr size type dist)' \
  '-t=[threshold pct]:n:' \
  '1:file1:_files' \
  '2:file2:_files'
