#compdef pmview
# Documentation: https://man.archlinux.org/man/pmview.1.en
# 3D visualization of Performance Co-Pilot metrics

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '-a+[specify archives to obtain metrics from]:archive:_files' \
  '-C[parse config and exit before displaying window]' \
  '-c+[load configuration from configfile]:configfile:_files' \
  '-h+[fetch metrics from pmcd on host]:host:_hosts' \
  '-n+[load an alternative local PMNS from file]:pmnsfile:_files' \
  '-p+[connect to time controls on this port]:port' \
  '-R+[pmlogger config to use when recording]:logconfig:_files' \
  '-r+[append config onto generated pmlogger config]:addconfig:_files' \
  '-t+[update interval to fetch metrics]:interval' \
  '-x+[pmlaunch specification version]:version' \
  '-z[change reporting timezone to metrics source]' \
  '-Z+[change default timezone]:timezone' \
  '-S+[sample retrieval window start time]:starttime' \
  '-T+[sample retrieval window end time]:endtime' \
  '-O+[initial origin within time window]:origin' \
  '-A+[natural alignment of sample times]:align' \
  '-D+[enable additional diagnostics output]:debug' \
  '-geometry+[X11 geometry specification]:geometry' \
  '-display+[X11 display specification]:display' \
  '-name+[window name]:name' \
  '-title+[window title]:title' && ret=0

return ret
