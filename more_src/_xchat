#compdef xchat XChat
# Documentation: https://man.archlinux.org/search?q=xchat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --no-auto)'{-a,--no-auto}'[do not autoconnect]' \
  '(-c --command)'{-c,--command}'+[execute command]:cmd:' \
  '(-d --cfgdir)'{-d,--cfgdir}'+[config dir]:dir:_files -/' \
  '(-e --existing)'{-e,--existing}'[use existing instance]' \
  '(-n --no-plugins)'{-n,--no-plugins}'[do not load plugins]' \
  '(-p --no-panel)'{-p,--no-panel}'[no system tray]' \
  '(-r --no-auto)'{-r,--no-auto}'[no autoconnect]' \
  '(-u --url)'{-u,--url}'+[connect URL]:url:' \
  '--display=+[X display]:disp:' && ret=0

return ret
