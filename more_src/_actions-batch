#compdef actions-batch

# actions-batch — GitHub Actions batch runner; see `actions-batch --help`

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--private=[repo is private]:bool:(true false)' \
  '--owner=[owner or org name]:name:' \
  '--token-file=[path with GitHub token]:file:_files' \
  '--runs-on=[runner label]:label:' \
  '--org=[target is org]:bool:(true false)' \
  '--file=[workflow script]:file:_files' \
  '*:args:_default' && ret=0

return ret
