#compdef dartvm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--enable-asserts[enable assert statements]' \
  '*--define=[define environment variable]:key=value:' \
  '*-D+[define environment variable]:key=value:' \
  '*--package=[package mapping]:package:' \
  '--packages=[packages config file]:file:_files' \
  '--snapshot=[output snapshot file]:file:_files' \
  '--snapshot-kind=[snapshot kind]:kind:(kernel app-jit app-aot)' \
  '--observe[start observatory]' \
  '--enable-vm-service=-[VM service port]:port:' \
  '--no-pause-isolates-on-exit[do not pause on exit]' \
  '--no-pause-isolates-on-unhandled-exceptions[do not pause on unhandled exceptions]' \
  '*:Dart script file:_files -g "*.dart"' && ret=0

return ret
