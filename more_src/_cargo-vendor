#compdef cargo-vendor
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-vendor.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Built-in `cargo vendor` subcommand: mirror project's source dependencies into a directory.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-s+,--sync=}'[additional Cargo.toml to sync]:file:_files -g "*.toml"' \
  '--manifest-path=[Cargo.toml]:file:_files -g "*.toml"' \
  '--no-delete[do not delete the vendor directory contents]' \
  '--respect-source-config[respect [source] in .cargo/config.toml]' \
  '--versioned-dirs[use versioned directory names]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '*'{-v,--verbose}'[verbose output (may be specified twice)]' \
  '--color=[coloring]:when:(auto always never)' \
  '*--config=[override Cargo config value]:key=value or path:' \
  '--frozen[require Cargo.lock and cache up to date]' \
  '--locked[require Cargo.lock up to date]' \
  '--offline[run without network access]' \
  '1:path:_directories'
