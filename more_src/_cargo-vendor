#compdef cargo-vendor

# Zsh completion for cargo-vendor (Rust dependency vendoring)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-s+[additional Cargo.toml to sync]:file:_files' \
  '--sync=[additional Cargo.toml to sync]:file:_files' \
  '--manifest-path=[path to Cargo.toml]:file:_files' \
  '--no-delete[do not delete older crates in vendor directory]' \
  '--respect-source-config[respect .cargo/config.toml source replacements]' \
  '--versioned-dirs[use versioned directories]' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock is up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '1:path:_directories'
