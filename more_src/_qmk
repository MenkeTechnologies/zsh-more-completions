#compdef qmk
# Documentation: https://docs.qmk.fm/cli_commands + lib/python/qmk/cli/ subcommand registry
# Reference accessed: 2026-05-29
# QMK Firmware CLI for mechanical keyboard firmware.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'compile:compile firmware from any directory'
  'flash:compile and flash to a bootloader'
  'new-keyboard:create a new keyboard from templates'
  'new-keymap:generate a keymap from existing defaults'
  'list-keyboards:display all available keyboards'
  'list-keymaps:show keymaps for a keyboard'
  'info:display keyboard and keymap details'
  'find:search keyboards using filter expressions'
  'lint:identify errors and anti-patterns'
  'json2c:convert Configurator export to C keymap'
  'c2json:convert C keymap to JSON format'
  'via2json:transform VIA backup to QMK format'
  'kle2json:convert keyboard-layout-editor JSON to QMK info.json'
  'format-json:format JSON files readably'
  'format-c:format C source code'
  'format-python:format Python source code'
  'format-text:check formatting of text files'
  'import-keyboard:import data-driven keyboard'
  'import-keymap:import data-driven keymap'
  'import-kbfirmware:create keyboard from KBfirmware export'
  'config:manage QMK behavior settings'
  'console:connect to keyboard debugging console'
  'doctor:examine environment for issues'
  'env:print QMK environment info'
  'migrate:convert legacy code to info.json format'
  'clean:remove build artifacts'
  'cd:open shell in firmware directory'
  'docs:start a webserver serving QMK documentation'
  'generate-api:generate version of QMK API'
  'generate-compilation-database:generate compile_commands.json'
  'generate-config-h:generate keyboard config.h'
  'generate-rules-mk:generate keyboard rules.mk'
  'generate-info-json:generate keyboard info.json'
  'generate-keyboard-h:generate keyboard.h header'
  'generate-keyboard-c:generate keyboard.c source'
  'generate-keymap-h:generate keymap.h header'
  'generate-keymap-c:generate keymap.c source'
  'generate-dfu-header:generate DFU bootloader header'
  'generate-develop-pr-list:generate develop PR list'
  'generate-version-h:generate version.h'
  'license-check:check source files for missing license headers'
  'mass-compile:compile firmware for many boards'
  'painter-make-font:generate QMK Painter font'
  'painter-make-image:generate QMK Painter image'
  'painter-convert-graphics:convert image to QMK Painter format'
  'pytest:run pytest on QMK Python code'
  'test-c:run QMK C unit tests'
  'hello:say hello (test command)'
  'userspace-add:add a build target to userspace'
  'userspace-remove:remove a build target from userspace'
  'userspace-list:display current userspace targets'
  'userspace-compile:build all userspace targets'
  'userspace-doctor:check userspace configuration'
  'ci:CI helpers for the QMK project'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose mode]' \
  '--no-color[disable colored output]' \
  '--color[force colored output]' \
  '--datetime-fmt=[strftime format for datetime in log messages]:fmt:' \
  '--log-file=[log to file]:file:_files' \
  '--log-fmt=[log format string]:fmt:' \
  '--log-file-fmt=[log file format string]:fmt:' \
  '--log-file-level=[log file verbosity]:level:(critical error warning info debug notset)' \
  '--log-level=[console log verbosity]:level:(critical error warning info debug notset)' \
  '--config-file=[path to QMK config file]:file:_files -g "*.ini"' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'qmk subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      compile|flash)
        _arguments \
          '(-c --clean)'{-c,--clean}'[clean before compile]' \
          '(-j --parallel)'{-j,--parallel=}'[parallel make jobs]:n:' \
          '(-e --env)'{-e,--env=}'[set environment variable for make]:var=value:' \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard to build firmware for]:keyboard:' \
          '(-km --keymap)'{-km,--keymap=}'[keymap to build firmware for]:keymap:' \
          '(-bl --bootloader)'{-bl,--bootloader=}'[bootloader target]:bootloader:' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-c --clean)--no-clean[do not clean before compile]' \
          '--target=[CMake-style build target]:target:' \
          '*:keymap.json:_files -g "*.json"' && ret=0
        ;;
      new-keyboard)
        _arguments \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard name]:name:' \
          '(-l --layout)'{-l,--layout=}'[layout template]:layout:' \
          '(-t --type)'{-t,--type=}'[MCU type]:mcu:' \
          '(-u --username)'{-u,--username=}'[username for maintainer field]:user:' \
          '(-n --realname)'{-n,--realname=}'[real name for maintainer field]:name:' && ret=0
        ;;
      new-keymap)
        _arguments \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard to add a keymap for]:keyboard:' \
          '(-km --keymap)'{-km,--keymap=}'[name for the new keymap]:keymap:' && ret=0
        ;;
      find)
        _arguments \
          '*'{-f,--filter=}'[filter expression]:filter:' \
          '*--print=[field to print]:field:' && ret=0
        ;;
      info)
        _arguments \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard to display info for]:keyboard:' \
          '(-km --keymap)'{-km,--keymap=}'[keymap to display info for]:keymap:' \
          '(-l --layouts)'{-l,--layouts}'[render the layouts]' \
          '(-m --matrix)'{-m,--matrix}'[render the matrix]' \
          '(-f --format)'{-f,--format=}'[output format]:format:(friendly text json)' \
          '--ascii[only use ASCII characters]' && ret=0
        ;;
      lint)
        _arguments \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard to lint]:keyboard:' \
          '(-km --keymap)'{-km,--keymap=}'[keymap to lint]:keymap:' \
          '--strict[treat warnings as errors]' && ret=0
        ;;
      config)
        _arguments \
          '(-ro --read-only)'{-ro,--read-only}'[read-only mode (do not write to disk)]' \
          '*:key[=value]:' && ret=0
        ;;
      console)
        _arguments \
          '(-b --bootloaders-only)'{-b,--bootloaders-only}'[show only bootloader devices]' \
          '(-d --device)'{-d,--device=}'[device to connect to]:device:' \
          '(-l --list)'{-l,--list}'[list available devices]' \
          '(-n --numeric)'{-n,--numeric}'[show numeric values for keys]' \
          '(-t --timestamp)'{-t,--timestamp}'[print timestamp]' \
          '(-w --wait)'{-w,--wait=}'[interval to wait between reconnections]:seconds:' && ret=0
        ;;
      doctor)
        _arguments \
          '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
          '(-n --no)'{-n,--no}'[answer no to all prompts]' && ret=0
        ;;
      mass-compile)
        _arguments \
          '(-c --clean)'{-c,--clean}'[clean before compile]' \
          '(-t --no-temp)'{-t,--no-temp}'[do not use temp folder]' \
          '(-e --env)'{-e,--env=}'[environment variables for make]:var=value:' \
          '(-j --parallel)'{-j,--parallel=}'[max parallel make jobs]:n:' \
          '(-bl --bootloader)'{-bl,--bootloader=}'[target bootloader]:bootloader:' \
          '*'{-f,--filter=}'[filter for keyboards]:filter:' && ret=0
        ;;
      docs)
        _arguments \
          '(-b --browser)'{-b,--browser}'[open in browser]' \
          '(-p --port)'{-p,--port=}'[port for the webserver]:port:' && ret=0
        ;;
      userspace-add)
        _arguments \
          '(-kb --keyboard)'{-kb,--keyboard=}'[keyboard for target]:keyboard:' \
          '(-km --keymap)'{-km,--keymap=}'[keymap for target]:keymap:' \
          '(-e --env)'{-e,--env=}'[environment variables]:var=value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
