#compdef git-interactive-rebase-tool
# Documentation: https://man.archlinux.org/search?q=git-interactive-rebase-tool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--license[show license]' \
  '*:rebase todo file:_files' && ret=0

return ret
