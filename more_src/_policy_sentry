#compdef policy_sentry
# Documentation: https://policy-sentry.readthedocs.io/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: maintainer-shipped (Click-based dynamic completion via
# _POLICY_SENTRY_COMPLETE=zsh_complete).

_policy_sentry_completion() {
    local -a completions
    local -a completions_with_descriptions
    local -a response
    (( ! $+commands[policy_sentry] )) && return 1

    response=("${(@f)$(env COMP_WORDS="${words[*]}" COMP_CWORD=$((CURRENT-1)) _POLICY_SENTRY_COMPLETE=zsh_complete policy_sentry)}")

    for type key descr in ${response}; do
        if [[ "$type" == "plain" ]]; then
            if [[ "$descr" == "_" ]]; then
                completions+=("$key")
            else
                completions_with_descriptions+=("$key":"$descr")
            fi
        elif [[ "$type" == "dir" ]]; then
            _path_files -/
        elif [[ "$type" == "file" ]]; then
            _path_files -f
        fi
    done

    if [ -n "$completions_with_descriptions" ]; then
        _describe -V unsorted completions_with_descriptions -U
    fi

    if [ -n "$completions" ]; then
        compadd -U -V unsorted -a completions
    fi
}

if [[ $zsh_eval_context[-1] == loadautofunc ]]; then
    # autoload from fpath, call function directly
    _policy_sentry_completion "$@"
else
    # eval/source/. command, register function for later
    compdef _policy_sentry_completion policy_sentry
fi

