#compdef xournalpp xournal++

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --create-pdf)'{-p+,--create-pdf=}'[export to PDF]:file:_files' \
  '(-i --create-img)'{-i+,--create-img=}'[export to image (png/svg)]:file:_files' \
  '(-n --no-pdf-compression)'{-n,--no-pdf-compression}'[disable PDF compression]' \
  '(-q --pdf-quality)'{-q+,--pdf-quality=}'[PDF rendering quality]:quality:(low medium high)' \
  '(-d --create-dir)'{-d,--create-dir}'[create dir if needed]' \
  '--page=[export page range]:range:' \
  '*:xopp_file:_files -g "*.{xopp,xoj,pdf}"' && ret=0

return ret
