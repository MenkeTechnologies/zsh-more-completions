#compdef pwru

# Zsh completion for pwru - eBPF-based packet tracing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--filter-ifname=[filter by interface name]:interface' \
  '--filter-mark=[filter by fwmark]:mark' \
  '--filter-netns=[filter by network namespace]:netns' \
  '--filter-func=[filter kernel functions]:function' \
  '--filter-proto=[filter by protocol]:protocol:(tcp udp icmp)' \
  '--filter-src=[filter by source]:ip' \
  '--filter-dst=[filter by destination]:ip' \
  '--filter-sport=[filter by source port]:port' \
  '--filter-dport=[filter by destination port]:port' \
  '--output-tuple[output 5-tuple info]' \
  '--output-stack[output kernel stack trace]' \
  '--output-skb[output skb data]' \
  '--output-caller[output caller information]' \
  '--output-ts=[output timestamp]:mode:(none relative absolute boot)' \
  '--output-meta[output skb metadata]' \
  '--output-limit-lines=[max output lines]:lines' \
  '--output-file=[write output to file]:file:_files' \
  '--output-json[output in JSON format]' \
  '--backend=[tracing backend]:backend:(kprobe kprobe-multi tc)' \
  '--kernel-btf=[path to kernel BTF]:file:_files' \
  '--per-cpu-buffer=[per-CPU buffer size]:size' \
  '--timestamp=[timestamp display]:mode:(none relative absolute boot)' \
  '*:pcap filter expression' && ret=0

return ret
