#compdef mafCoverage
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: analyse coverage by maf files chromosome by chromosome and genome-wide

local ret=1

_arguments -s -S \
  '-restrict=[restrict to parts in restrict.bed]:file:_files -g "*.bed"' \
  '-count=[number of matching species to count coverage (default 3)]:n' \
  '1:database:' \
  '2:maf file:_files -g "*.maf"' && ret=0

return ret
