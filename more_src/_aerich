#compdef aerich
# _aerich — Tortoise-ORM database migration tool (tortoise/aerich)
# upstream: https://github.com/tortoise/aerich

_aerich() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.py"' \
        '(-a --app)'{-a,--app}'=[Tortoise-ORM app name]:app:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_aerich_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-t --tortoise-orm)'{-t,--tortoise-orm}'=[Tortoise-ORM config path]:path:' \
                        '--location=[migration directory]:dir:_files -/' \
                        '--help[show help]' && ret=0 ;;
                init-db)
                    _arguments \
                        '(-s --safe)'{-s,--safe}'[only run if tables do not exist]' \
                        '--help[show help]' && ret=0 ;;
                migrate)
                    _arguments \
                        '--name=[migration name]:name:' \
                        '--help[show help]' && ret=0 ;;
                upgrade|downgrade)
                    _arguments \
                        '--help[show help]' \
                        '1:version:' && ret=0 ;;
                heads|history|inspectdb) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_aerich_commands] )) ||
_aerich_commands() {
    local -a commands
    commands=(
        'init:initialize aerich config and create migration location'
        'init-db:generate schema and create first migration'
        'migrate:generate migration changes'
        'upgrade:upgrade to latest version'
        'downgrade:downgrade to specified version'
        'heads:show current available heads'
        'history:list all migrations'
        'inspectdb:inspect database and generate models'
    )
    _describe -t commands 'aerich command' commands
}

_aerich "$@"
