#compdef shellharden
# _shellharden-bin — shellharden Bash hardener (Andreas Nordal, Rust); rewrites scripts to add quotes around variables
# upstream: https://github.com/anordal/shellharden

_shellharden-bin() {
    _arguments \
        '(--help)--help[show help]' \
        '(--version)--version[show version]' \
        '(--check)--check[check only, exit nonzero on changes]' \
        '(--replace)--replace[rewrite files in place]' \
        '(--suggest)--suggest[show suggested rewrites]' \
        '(--transform)--transform[print rewritten output]' \
        '*:script:_files -g "*.(sh|bash)"'
}

_shellharden-bin "$@"
