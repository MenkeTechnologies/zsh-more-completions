#compdef orc-contents
# Documentation: https://orc.apache.org/docs/cpp-tools.html
# orc-contents - display ORC file contents as JSON

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --columns)'{-c,--columns}'=[comma separated list of top-level column fields]:columns' \
  '(-t --columnTypeIds)'{-t,--columnTypeIds}'=[comma separated list of column type ids]:ids' \
  '(-n --columnNames)'{-n,--columnNames}'=[comma separated list of column names]:names' \
  '(-b --batch)'{-b,--batch}'=[batch size for reading]:size' \
  '*:ORC file:_files' && ret=0

return ret
