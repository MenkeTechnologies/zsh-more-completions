#compdef binny chronicle grant
# Documentation: upstream READMEs at github.com/anchore/{binny,chronicle,grant}
# Reference accessed: 2026-05-30
# Anchore sister-CLI harvest R28 — three smaller tools in the same
# Go/clio-based family as the previously-covered _grype-cli/_syft-cli/
# _cocogitto/_clio/_quill suite.

local curcontext="$curcontext" state line ret=1

case $service in

  binny)
    # anchore/binny — manage a directory of binaries via .binny.yaml
    # without a traditional package manager. Acquisition methods:
    # github-release, go-install, go-build, hosted-shell.
    local -a _subcmds
    _subcmds=(
      'install:deploy all configured tools'
      'check:verify installation status'
      'update:refresh pinned versions within constraints'
      'list:display all tools and their status'
      'add:add a new managed binary to the config'
      'remove:remove a binary from the config'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'binny subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  chronicle)
    # anchore/chronicle — GitHub-aware changelog generator.
    # Output format enum: md, md-pretty, json, version.
    _arguments -s -S \
      '(-o --output)-o+[output format/file (e.g. md=CHANGELOG.md)]:format:(md md-pretty json version)' \
      '(-o --output)--output=[output format/file]:format:(md md-pretty json version)' \
      '(-s --since-tag)-s+[starting git tag (default: last release)]:tag:' \
      '(-s --since-tag)--since-tag=[starting git tag (default: last release)]:tag:' \
      '(-u --until-tag)-u+[ending git tag (default: HEAD)]:tag:' \
      '(-u --until-tag)--until-tag=[ending git tag (default: HEAD)]:tag:' \
      '(-n --speculate-next-version)-n[guess next release version]' \
      '(-n --speculate-next-version)--speculate-next-version[guess next release version]' \
      '-q[suppress logging output]' \
      '1:repository path:_directories' \
      && ret=0
    ;;

  grant)
    # anchore/grant — license scanner for container images / SBOMs /
    # filesystems. Two subcommands: list (enumerate) + check (policy).
    local -a _subcmds
    _subcmds=(
      'list:enumerate licenses in container image/SBOM/directory'
      'check:validate licenses against policy'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'grant subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          list|check)
            _arguments \
              '*:target (container image, sbom:FILE, dir:PATH, or filesystem path):' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
