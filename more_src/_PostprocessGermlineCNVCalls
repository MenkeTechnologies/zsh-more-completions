#compdef PostprocessGermlineCNVCalls
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/PostprocessGermlineCNVCalls.java
# Postprocesses the output of GermlineCNVCaller and generates VCFs and denoised copy ratios

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--calls-shard-path=[List of paths to GermlineCNVCaller call directories.]:value:_files' \
  '--model-shard-path=[List of paths to GermlineCNVCaller model directories.]:value:_files' \
  '--contig-ploidy-calls=[Path to contig-ploidy calls directory (output of DetermineGermlineContigPloidy).]:value:' \
  '--sample-index=[Sample index in the call-set (must be contained in all shards).]:value:' \
  '--autosomal-ref-copy-number=[Reference copy-number on autosomal intervals.]:value:' \
  '--allosomal-contig=[Contigs to treat as allosomal (i.e. choose their reference copy-number allele according to]:value:' \
  '--input-intervals-vcf=[Input VCF with combined intervals for all samples]:value:_files' \
  '--clustered-breakpoints=[VCF with clustered breakpoints and copy number calls for all samples, can be generated...]:value:' \
  '--output-genotyped-intervals=[Output intervals VCF file.]:value:_files' \
  '--output-genotyped-segments=[Output segments VCF file.]:value:_files' \
  '--output-denoised-copy-ratios=[Output denoised copy ratio file.]:value:_files' \
  '--het-deletion-qs-threshold[Filter out heterozygous deletions with quality lower than this.]' \
  '--hom-deletion-qs-threshold[Filter out homozygous deletions with quality lower than this.]' \
  '--duplication-qs-threshold[Filter out duplications with quality lower than this.]' \
  '--site-frequency-threshold[Filter out variants with site frequency higher than this.]' \
  '*:argument:_files' && ret=0

return ret
