#compdef cruft

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new project from a Cookiecutter template'
  'check:check if the project is up to date with the template'
  'diff:show diff between the project and the latest template'
  'update:update the project to the latest template'
  'link:link an existing project to a Cookiecutter template'
  'help:show help for a command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      create)
        _arguments \
          '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_files -/' \
          '--config-file=[Cookiecutter config file]:config file:_files' \
          '--default-config[use default Cookiecutter config]' \
          '--extra-context=[extra context as JSON]:JSON' \
          '--no-input[do not prompt for parameters]' \
          '--checkout=[branch, tag, or commit to checkout]:ref' \
          '--directory=[directory within template repo]:directory' \
          '(-y --skip-apply-ask)'{-y,--skip-apply-ask}'[skip asking to apply changes]' \
          '--allow-untracked-files[allow untracked files]' \
          '1:template URL or path' && ret=0
        ;;
      check|diff)
        _arguments \
          '--checkout=[branch, tag, or commit]:ref' \
          '--project-dir=[path to the project]:directory:_files -/' \
          '--exit-code[exit with non-zero on diff]' && ret=0
        ;;
      update)
        _arguments \
          '--checkout=[branch, tag, or commit]:ref' \
          '--project-dir=[path to the project]:directory:_files -/' \
          '(-y --skip-apply-ask)'{-y,--skip-apply-ask}'[skip asking to apply changes]' \
          '--skip-update[only check, do not update]' \
          '--allow-untracked-files[allow untracked files]' && ret=0
        ;;
      link)
        _arguments \
          '--checkout=[branch, tag, or commit]:ref' \
          '--project-dir=[path to the project]:directory:_files -/' \
          '--no-input[do not prompt for parameters]' \
          '--directory=[directory within template repo]:directory' \
          '1:template URL or path' && ret=0
        ;;
    esac
    ;;
esac

return ret
