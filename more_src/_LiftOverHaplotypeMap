#compdef LiftOverHaplotypeMap
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#LiftOverHaplotypeMap
# Picard: lift over a haplotype database to another reference using a chain file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[haplotype database to be lifted over]:file:_files' \
  {-O=,--OUTPUT=}'[where to write the lifted-over haplotype database]:file:_files' \
  {-SD=,--SEQUENCE_DICTIONARY=}'[sequence dictionary to write into the output database]:file:_files' \
  '--CHAIN=[chain file that guides LiftOver (UCSC format)]:chain:_files -g "*.chain"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:argument:_files' && ret=0

return ret
