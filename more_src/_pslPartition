#compdef pslPartition
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: split PSL files into non-overlapping sets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-outLevels=[number of output subdirectory levels]:n:' \
  '-partSize=[combine non-overlapping partitions up to this many PSLs]:n:' \
  '-dropContained[drop PSLs completely contained in another block]' \
  '-parallel=[number of cores for parallel sorting]:n:' \
  ':psl file:_files' \
  ':out dir:_files -/' && ret=0

return ret
