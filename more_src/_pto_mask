#compdef pto_mask
# Documentation: https://man.archlinux.org/man/pto_mask.1.en
# pto_mask: add or modify masks in a Hugin .pto project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto file]:file:_files -g "*.pto"' \
  '--mask=[read mask from file and assign to image: filename@imgNr]:mask:' \
  '--rotate=[rotate mask CLOCKWISE|90|COUNTERCLOCKWISE|-90]:rotation:(CLOCKWISE 90 COUNTERCLOCKWISE -90)' \
  '--process=[mask resize handling CLIP|SCALE|PROP_SCALE]:process:(CLIP SCALE PROP_SCALE)' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
