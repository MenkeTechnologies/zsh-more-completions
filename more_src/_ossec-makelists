#compdef ossec-makelists
# Documentation: https://www.ossec.net/docs/docs/programs/ossec-makelists.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# OSSEC tool to rebuild cdb_list databases declared in ossec.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[debug (repeatable)]' \
  '-F[force rebuild of all configured databases]' \
  '-t[test config]' \
  '-u[user]:user:_users' \
  '-g[group]:group:_groups' \
  '*::ossec-makelists args:_files' && ret=0
return ret
