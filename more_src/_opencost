#compdef opencost
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--window=[time window]:window:(1d 7d 30d today yesterday week month lastweek lastmonth)' \
  '--aggregate=[aggregation level]:aggregate:(namespace deployment controller service label pod container node cluster)' \
  '--filter-namespaces=[filter by namespaces]:namespaces:' \
  '--filter-labels=[filter by labels]:labels:' \
  '--filter-clusters=[filter by clusters]:clusters:' \
  '--show-all[show all cost data]' \
  '--show-cpu[show CPU cost]' \
  '--show-memory[show memory cost]' \
  '--show-gpu[show GPU cost]' \
  '--show-pv[show persistent volume cost]' \
  '--show-network[show network cost]' \
  '--show-efficiency[show efficiency metrics]' && ret=0
return ret
