#compdef gravprisms
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/potential — compute gravity/geoid/VGG over vertical prisms

local ret=1

_arguments -s \
  '-C+[create prisms from feature/layer grids]:opts:_default' \
  '-D+[fixed density contrast or density grid]:density:_default' \
  '-E+[uniform x/y prism dimensions]:dims:_default' \
  '-F+[field component f|n|v]:field:(f n v)' \
  '-G+[output grid or table file]:file:_files' \
  '-H+[variable radial density vs depth]:opts:_default' \
  '-L+[base surface grid or constant z]:base:_default' \
  '-M+[distance unit h|v in km]:unit:_default' \
  '-N+[track file with observation points]:file:_files' \
  '-S+[seamount heights grid]:file:_files' \
  '-T+[top surface grid or constant z]:top:_default' \
  '-Z+[observation level constant or grid]:level:_default' \
  '-I+[grid spacing dx/dy]:spacing:_default' \
  '-R+[region west/east/south/north]:region:_default' \
  '*-V[verbose (stackable)]' \
  '*:input table:_files' \
  && ret=0

return ret
