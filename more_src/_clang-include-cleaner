#compdef clang-include-cleaner
# Documentation: https://clangd.llvm.org/design/include-cleaner
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-p+[build path (compile_commands.json directory)]:dir:_files -/' \
  '--edit[apply edits to analyzed source files]' \
  '--insert[allow header insertions]' \
  '--print=[print results]:format:(changes)' \
  '--html=[output filename for HTML report]:file:_files' \
  '--ignore-headers=[regex of headers to ignore]:regex' \
  '*--extra-arg=[extra argument for clang]:arg' \
  '*--extra-arg-before=[extra argument before others]:arg' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|m|mm|h|hpp|hxx)"' && ret=0

return ret
