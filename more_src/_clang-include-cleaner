#compdef clang-include-cleaner

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-p+[path to compile_commands.json or build directory]:dir:_files -/' \
  '--edit[apply suggested edits in-place]' \
  '--remove[remove unused includes only]' \
  '--insert[insert missing includes only]' \
  '--print=[print results]:format:(changes html plain)' \
  '--ignore-headers=-[regex of headers to ignore]:regex:' \
  '--only-headers=-[regex of headers to consider]:regex:' \
  '--disable-pragma-keep[ignore IWYU pragma keep]' \
  '--no-disable-pragma-keep[respect IWYU pragma keep]' \
  '*--extra-arg=[extra argument for clang]:arg:' \
  '*--extra-arg-before=[extra argument before others]:arg:' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|m|mm|h|hpp|hxx)"' && ret=0

return ret
