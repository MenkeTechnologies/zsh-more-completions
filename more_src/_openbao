#compdef openbao
# Documentation: https://man.archlinux.org/search?q=openbao
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'agent:run the OpenBao agent'
  'audit:manage audit devices'
  'auth:authenticate to OpenBao'
  'debug:debugging utilities'
  'delete:remove data at OpenBao paths'
  'kv:manage key/value secrets'
  'lease:manage secret leases'
  'list:list data at OpenBao paths'
  'login:authenticate and obtain a token'
  'monitor:stream server logs'
  'namespace:manage namespaces'
  'operator:perform operator tasks (init, seal, raft, etc.)'
  'patch:update specific fields at a path'
  'path-help:show API documentation for a path'
  'pki:manage PKI secrets engine'
  'plugin:manage plugins'
  'policy:manage access policies'
  'print:print formatted output'
  'proxy:run the OpenBao proxy'
  'read:HTTP GET on a path'
  'secrets:manage secrets engines'
  'server:start the OpenBao server'
  'ssh:manage SSH secrets'
  'status:show server status'
  'token:manage tokens'
  'transit:manage transit encryption'
  'unwrap:unwrap a wrapped response'
  'version:show OpenBao version'
  'version-history:show version history'
  'write:HTTP PUT/POST on a path'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-address=[OpenBao server URL]:url:' \
  '-ca-cert=[CA cert file]:file:_files' \
  '-ca-path=[CA cert dir]:dir:_files -/' \
  '-client-cert=[client cert]:file:_files' \
  '-client-key=[client key]:file:_files' \
  '-format=[output format]:format:(table json yaml raw)' \
  '-namespace=[namespace]:namespace:' \
  '-tls-skip-verify[skip TLS verification]' \
  '-tls-server-name=[TLS server name]:name:' \
  '-non-interactive[do not prompt for input]' \
  '-mfa=[MFA payload]:payload:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openbao command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (kv)
        local -a kv_subs=(
          'put:write data to a KV path'
          'patch:patch data at a KV path'
          'get:read data at a KV path'
          'list:list keys at a KV path'
          'delete:delete a key'
          'destroy:destroy a version'
          'undelete:undelete a version'
          'metadata:manage version metadata'
          'enable-versioning:upgrade KV v1 to v2'
          'rollback:rollback to a previous version'
        )
        _describe -t kvcmds 'kv subcommand' kv_subs && ret=0
        _arguments \
          '-mount=[KV mount point]:mount:' \
          '-cas=[check-and-set version]:n:' \
          '-version=[version to read]:n:' \
          '-field=[print just one field]:field:' && ret=0 ;;
      (auth)
        _arguments '*::sub:(enable disable list tune help move)' && ret=0 ;;
      (secrets)
        _arguments '*::sub:(enable disable list tune move)' && ret=0 ;;
      (operator)
        _arguments '*::sub:(init seal unseal step-down rotate raft generate-root rekey diagnose key-status migrate members usage)' && ret=0 ;;
      (token)
        _arguments '*::sub:(create lookup renew revoke capabilities)' && ret=0 ;;
      (policy)
        _arguments '*::sub:(list read write delete fmt)' && ret=0 ;;
      (lease)
        _arguments '*::sub:(lookup renew revoke list)' && ret=0 ;;
      (namespace)
        _arguments '*::sub:(create delete list lookup patch)' && ret=0 ;;
      (debug)
        _arguments \
          '-target=[debug target]:target:(config host metrics pprof replication-status server-status)' \
          '-output=[output bundle]:file:_files' \
          '-duration=[debug duration]:duration:' && ret=0 ;;
      (server)
        _arguments \
          '-config=[config file or dir]:path:_files' \
          '-dev[development mode]' \
          '-dev-listen-address=[dev listen address]:address:' \
          '-dev-root-token-id=[dev root token]:token:' \
          '-log-level=[log level]:level:(trace debug info warn error)' && ret=0 ;;
      (read|write|delete|patch|list)
        _arguments \
          '-format=[output format]:format:(table json yaml raw)' \
          '-field=[print just one field]:field:' \
          '*::path:' && ret=0 ;;
    esac ;;
esac

return ret
