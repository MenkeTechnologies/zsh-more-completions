#compdef kubectl-clusterpedia

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '--chunk-size=[list chunk size]:size:' \
  '--cluster=[cluster name]:cluster:' \
  '-n[namespace]:namespace:' \
  '-o[output format]:format:(wide yaml json jsonpath name)' \
  '1:resource: _default' \
  '*:name or selector: _default'
