#compdef mri_aparc2aseg-extra
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_aparc2aseg
# FreeSurfer: map cortical parcellation labels into the aseg volume

local ret=1

_arguments -s -S \
  '(- *)--version[display version information and exit]' \
  '--s[recon-ed subject in the SUBJECTS_DIR]:subject' \
  '--o[output segmentation volume]:output:_files' \
  '--a2005[use the aparc.a2005 parcellation]' \
  '--ribbon[use hemi.ribbon.mgz as cortex mask]' \
  '--annot[use specified label file instead of aparc]:name' \
  '*:argument:_files' && ret=0

return ret
