#compdef ociochecklut
# load a LUT and evaluate RGB(A) values through it

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[verbose output]' \
  '-t[send a predefined set of test RGB values through the LUT]' \
  '--gpu[evaluate using the GPU renderer rather than the CPU renderer]' \
  '1:lut file:_files' \
  '*:RGB(A) value:' && ret=0

return ret
