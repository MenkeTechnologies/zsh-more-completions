#compdef ifrename
# _ifrename — wireless-tools ifrename (rename network interfaces in early-boot scripts based on stable selectors from /etc/iftab: MAC address, driver, BUSPATH, BUSINFO; -c specifies the iftab config)
# upstream: https://hewlettpackard.github.io/wireless-tools/ (jt@hpl.hp.com)
# Flags from wireless-tools ifrename.c on tip.

_ifrename() {
    _arguments \
        '-c+[config file (default /etc/iftab)]:file:_files' \
        '-p[print rules]' \
        '-d[debug]' \
        '-D[verbose debug]' \
        '-V[show version]' \
        '-t+[lookup type]:type:(mac driver businfo arp ifname interrupt baseaddress firmware)' \
        '-i+[interface]:interface:_net_interfaces' \
        '-n+[new name]:name:'
}

_ifrename "$@"
