#compdef pyres_scheduler
# Documentation: https://github.com/binarydud/pyres/blob/master/pyres/scripts.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

typeset -A opt_args
local context state line

_arguments -s -S \
  "(- *)"{-h,--help}"[show help]" \
  "--host=[Redis host (default localhost)]:host:" \
  "--port=[Redis port (default 6379)]:port:" \
  "--password=[Redis password]:password:" \
  "(-l --log-level)"{-l+,--log-level=}"[log level]:level:(debug info warning error critical)" \
  "-f+[logfile path]:file:_files" \
  "-p+[pidfile path]:file:_files" \
  "*::args:" && return 0
