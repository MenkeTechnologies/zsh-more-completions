#compdef ecppack
# Documentation: https://man.archlinux.org/search?q=ecppack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--input=[input ASCII config file]:file:_files -g "*.config"' \
  '--bit=[output bitstream]:file:_files -g "*.bit"' \
  '--svf=[output SVF file]:file:_files -g "*.svf"' \
  '--svf-rowsize=[SVF row size]:rowsize:' \
  '--idcode=[force IDCODE]:idcode:' \
  '--freq=[SPI flash frequency MHz]:mhz:(2.4 4.8 9.7 19.4 38.8 62)' \
  '--compress[compress bitstream]' \
  '--bootaddr=[set boot address]:addr:' \
  '--background[load in background after boot]' \
  '--input-spi-bitstream=[input SPI bitstream]:file:_files' \
  '--input-spi-multiboot-pad-bytes=[multi-boot pad bytes]:n:' \
  '--spimode=[SPI mode]:mode:(fast normal dual quad)' \
  '--secspi=[secondary SPI config]:cfg:' \
  '--secsmode=[secondary SPI mode]:mode:(fast normal dual quad)' \
  '*:file:_files' && ret=0

return ret
