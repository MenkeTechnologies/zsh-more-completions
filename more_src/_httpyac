#compdef httpyac

# Zsh completion for httpyac - HTTP client CLI based on .http/.rest files

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'send:execute http/rest file (default)'
  'oauth2:manage oauth2 tokens'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '(-a --all)'{-a,--all}'[execute all http requests in a http file]' \
  '(-b --bail)'{-b,--bail}'[stops on first test error]' \
  '--filter[filter requests by type]:filter:(only-failed)' \
  '(-n --name)'{-n,--name}'[execute with matching name]:name:' \
  '--line[line of the http request in the file]:line:' \
  '(-t --timeout)'{-t,--timeout}'[maximum time allowed for connection (ms)]:timeout:' \
  '--insecure[allow insecure server connections when using ssl]' \
  '(-e --env)'{-e,--env}'[environment]:env:' \
  '--env-file[environment file]:file:_files' \
  '--repeat[repeat count for requests]:count:' \
  '--repeat-mode[repeat mode]:mode:(sequential parallel)' \
  '-o+[output format]:format:(short body headers response exchange none)' \
  '--output[output format]:format:(short body headers response exchange none)' \
  '--output-failed[output format of failed requests]:format:(short body headers response exchange none)' \
  '--raw[prevent formatting of response body]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output (log level: trace)]' \
  '--quiet[suppress any logs]' \
  '--json[use json output]' \
  '--silent[suppress any logs]' \
  '--var[set variable]:name=value:' \
  '--no-color[disable colored output]' \
  '*:files:_files -g "*.(http|rest)"' && ret=0

case $state in
  (command)
    _describe -t commands 'httpyac command' commands && ret=0
    ;;
esac

return ret
