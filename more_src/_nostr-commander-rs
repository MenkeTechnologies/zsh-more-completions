#compdef nostr-commander-rs
# Documentation: https://github.com/8go/nostr-commander-rs
# Source: 8go/nostr-commander-rs — single-binary clap-driven Nostr client.
# Reference accessed: 2026-06-01
# Crate is `nostr-commander`; binary is `nostr-commander-rs`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--create-user[create a new Nostr user (keypair)]' \
    '--delete-user[delete the local user]' \
    '--user-name=[set user name]:name:_default' \
    '--display-name=[set display name]:name:_default' \
    '*--publish=[publish a note to subscribed relays]:note:_default' \
    '*--dm=[send an encrypted direct message]:msg:_default' \
    '*--add-relay=[configure a relay URL]:url:_default' \
    '*--subscribe-author=[follow author npub]:npub:_default' \
    '*--subscribe-channel=[join a public channel]:channel:_default' \
    '--listen[monitor incoming events and messages]' \
    '--show-contacts[display the contact list]' \
    '--add-contact=[add a contact npub]:npub:_default' \
    '--nsec=[private key for fire-and-forget publish]:nsec:_default' \
    '*-v[verbose (repeatable)]' \
    '--readme[download the README from the repo]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--manual[long-form manual]' \
    '(- *)--version[show version]' \
    && ret=0

return ret
