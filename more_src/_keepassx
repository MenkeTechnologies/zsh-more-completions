#compdef keepassx
# _keepassx — KeePassX cross-platform password manager (KeePassX team, C++); custom argparse
# upstream: https://github.com/keepassx/keepassx

_keepassx() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--language=+[language]:str:' \
        '--cfg=+[config file]:file:_files' \
        '--lock[lock on start]' \
        '-L[lock on start]' \
        '--min[minimized]' \
        '-m[minimized]' \
        '--keyfile=+[key file]:file:_files' \
        '-k+[key file]:file:_files' \
        '*:database:_files -g "*.kdb *.kdbx"'
}

_keepassx "$@"
