#compdef kafka-console-share-consumer
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/consumer/ConsoleShareConsumerOptions.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--topic[Topic to consume from]:topic:'
    '--group[Share group ID]:group:'
    '--consumer-property[User-defined consumer properties as key=value pairs]:property:'
    '--consumer-config[Consumer config properties file]:file:_files'
    '--command-property[Admin client properties as key=value pairs]:property:'
    '--command-config[Admin client config properties file]:file:_files'
    '--formatter[Message formatter class]:class:'
    '--formatter-config[Formatter config properties file]:file:_files'
    '--formatter-property[Properties for the message formatter]:property:'
    '--property[Properties for the message formatter]:property:'
    '--max-messages[Maximum number of messages to consume]:count:'
    '--timeout-ms[Exit if no message available for specified time]:ms:'
    '--reject[Reject the message instead of acknowledging it]'
    '--reject-message-on-error[Reject the message if there is an error]'
    '--release[Release the message instead of acknowledging it]'
    '--key-deserializer[Key deserializer class]:class:'
    '--value-deserializer[Value deserializer class]:class:'
    '--enable-systest-events[Enable system test lifecycle events logging]'
)

_arguments -s -S $arguments
