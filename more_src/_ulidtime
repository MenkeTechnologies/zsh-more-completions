#compdef ulidtime
# _ulidtime — decode ULID timestamps (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/ulidtime/main.go on tip.

_ulidtime() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-seconds[show timestamp as Unix seconds]' \
        '-millis[show timestamp as Unix milliseconds]' \
        '-entropy[show ULID random part as hex]' \
        '-header[print header row]' \
        '*:ulid:'
}

_ulidtime "$@"
