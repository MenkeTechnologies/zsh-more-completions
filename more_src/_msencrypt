#compdef msencrypt
# Documentation: https://mapserver.org/utilities/msencrypt.html
# Create an encryption key or encrypt connection-string portions for MapServer mapfiles

local ret=1

_arguments -s \
  '-keygen[create a new encryption key in the given file]:key_filename:_files' \
  '-key[use the given key file to encrypt a string]:key_filename:_files' \
  '*:string to encrypt:' && ret=0

return ret
