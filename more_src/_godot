#compdef godot

# Zsh completion for godot - Godot game engine CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-e[start the editor]' \
  '--editor[start the editor]' \
  '-p[start the project manager]' \
  '--project-manager[start the project manager]' \
  '-q[quit after first iteration]' \
  '--quit[quit after first iteration]' \
  '--quit-after=[quit after given number of frames]:frames' \
  '--path=[set project path]:dir:_directories' \
  '-u[upwards search for project.godot]:path:_directories' \
  '--upwards[upwards search for project.godot]' \
  '--main-pack=[load pack file]:file:_files -g "*.pck"' \
  '--render-thread=[render thread mode]:mode:(unsafe safe separate)' \
  '--remote-fs=[remote filesystem]:host\:port' \
  '--remote-fs-password=[password for remote filesystem]:password' \
  '--audio-driver=[audio driver]:driver:(PulseAudio ALSA CoreAudio WASAPI Dummy)' \
  '--display-driver=[display driver]:driver:(x11 wayland windows macos headless)' \
  '--rendering-method=[rendering method]:method:(forward_plus mobile gl_compatibility)' \
  '--rendering-driver=[rendering driver]:driver:(vulkan opengl3 dummy)' \
  '--gpu-index=[GPU device index]:index' \
  '--text-driver=[text rendering driver]:driver:(default)' \
  '-f[fullscreen mode]' \
  '--fullscreen[fullscreen mode]' \
  '-m[maximized window]' \
  '--maximized[maximized window]' \
  '-w[windowed mode]' \
  '--windowed[windowed mode]' \
  '-t[always on top]' \
  '--always-on-top[always on top]' \
  '--resolution=[set window resolution]:WxH' \
  '--position=[set window position]:X,Y' \
  '--screen=[set window screen]:screen' \
  '--single-window[use single window mode]' \
  '--xr-mode=[XR mode]:mode:(default off on)' \
  '-s[run script]:script:_files -g "*.gd"' \
  '--script=[run script]:script:_files -g "*.gd"' \
  '--check-only[only check for errors without running]' \
  '--export-release=[export project in release mode]:preset name' \
  '--export-debug=[export project in debug mode]:preset name' \
  '--export-pack=[export project as PCK/ZIP]:preset name' \
  '--convert-3to4=[convert project from Godot 3 to 4]:max-file-kb' \
  '--validate-conversion-3to4=[validate conversion]:max-file-kb' \
  '--doctool=[dump engine API reference]:path:_directories' \
  '--no-docbase[disallow dumping base types]' \
  '--build-solutions[build C#/GDExtension solutions]' \
  '--dump-gdextension-interface[generate GDExtension header file]' \
  '--dump-extension-api[generate extension API JSON]' \
  '--benchmark[enable benchmarking]' \
  '--benchmark-file=[save benchmark results]:file:_files' \
  '-v[verbose stdout mode]' \
  '--verbose[verbose stdout mode]' \
  '--headless[enable headless mode]' \
  '--breakpoints=[set breakpoints]:breakpoints' \
  '--profiling[enable profiling in script debugger]' \
  '--debug-collisions[show collision shapes]' \
  '--debug-paths[show path lines]' \
  '--debug-navigation[show navigation mesh]' \
  '--debug-stringnames[print StringName allocations]' \
  '--frame-delay=[simulate CPU load]:milliseconds' \
  '--time-scale=[set time scale]:scale' \
  '--disable-render-loop[disable render loop]' \
  '--disable-crash-handler[disable crash handler]' \
  '--fixed-fps=[force fixed FPS]:fps' \
  '--print-fps[print FPS to stdout]' \
  '*:file:_files -g "*.{tscn,scn,godot,gd,tres,res}"' && ret=0

return ret
