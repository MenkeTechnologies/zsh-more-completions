#compdef fasm2frames
# Documentation: https://github.com/SymbiFlow/prjxray/blob/master/utils/fasm2frames.py
# Project X-Ray: convert FASM to 7-series frame deltas

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--db_root=[database root directory]:dir:_files -/' \
  '--part=[FPGA part name]:part' \
  '--sparse[do not zero fill all frames]' \
  '--roi=[ROI design.json file defining tiles within ROI]:file:_files' \
  '--emit_pudc_b_pullup[emit IBUF and PULLUP on PUDC_B pin if unused]' \
  '--debug[print debug dump]' \
  '1:input fasm file:_files' \
  '2:output frm file:_files' && ret=0

return ret
