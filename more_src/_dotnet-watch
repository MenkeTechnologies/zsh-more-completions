#compdef dotnet-watch

_arguments -s \
  '(- *)'{-?,-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--artifacts-path=[artifacts directory]:dir:_files -/' \
  '--disable-build-servers[disable build servers]' \
  '--list[list watched files]' \
  '--no-hot-reload[disable hot reload]' \
  '--no-self-contained[disable self-contained]' \
  '--non-interactive[non-interactive mode]' \
  '--project=[project path]:file:_files -g "*.csproj"' \
  '(--sc --self-contained)'{--sc,--self-contained}'[self-contained]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:(run build test)' \
  '*::arg:->args'
