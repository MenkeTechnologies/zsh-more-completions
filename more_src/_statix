#compdef statix

# Zsh completion for statix - linter and suggestion tool for Nix

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'check:lint Nix files for antipatterns'
  'fix:apply suggestions to Nix files'
  'single:lint a single expression'
  'explain:explain a lint warning'
  'dump:dump the AST of a Nix file'
  'help:print help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --format)'{-o,--format}'[output format]:format:(errfmt json stderr)' \
  '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      check|fix)
        _arguments \
          '(-i --ignore)'{-i,--ignore}'[ignore warnings]:warning codes:' \
          '--unreachable[check for unreachable code]' \
          '*:file:_files -g "*.nix"' && ret=0
        ;;
      single)
        _arguments ':expression:' && ret=0
        ;;
      explain)
        _arguments ':warning code:' && ret=0
        ;;
      dump)
        _arguments '*:file:_files -g "*.nix"' && ret=0
        ;;
    esac
    ;;
esac

return ret
