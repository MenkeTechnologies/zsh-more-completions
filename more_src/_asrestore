#compdef asrestore
# Documentation: https://aerospike.com/docs/tools/restore/asrestore_use
# Aerospike restore utility — restores a backup into an Aerospike database

local ret=1

_arguments -s -S \
  '(-h --host)'{-h,--host}'+[host(s) to connect to]:host:_hosts' \
  '(-p --port)'{-p,--port}'+[port to connect to]:port:' \
  '(-U --user)'{-U,--user}'+[user to authenticate as]:user:' \
  '(-P --password)'{-P,--password}'+[password to authenticate with]:password:' \
  '(-A --auth)'{-A,--auth}'+[authentication mode]:mode:(INTERNAL EXTERNAL EXTERNAL_INSECURE PKI)' \
  '(-S --services-alternate)'{-S,--services-alternate}'[use alternate-access-address]' \
  '(-d --directory)'{-d,--directory}'+[directory to read backup files from]:dir:_files -/' \
  '--directory-list=[comma-separated list of directories]:dirs:' \
  '--parent-directory=[parent of the directory-list paths]:dir:_files -/' \
  '(-i --input-file)'{-i,--input-file}'+[backup file to read]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'+[source/destination namespace mapping]:namespace:' \
  '(-s --set-list)'{-s,--set-list}'+[comma-separated list of sets to restore]:sets:' \
  '(-B --bin-list)'{-B,--bin-list}'+[comma-separated list of bins to restore]:bins:' \
  '(-R --no-records)'{-R,--no-records}'[do not restore records]' \
  '(-I --no-indexes)'{-I,--no-indexes}'[do not restore secondary indexes]' \
  '(-F --no-udfs)'{-F,--no-udfs}'[do not restore UDF modules]' \
  '(-L --indexes-last)'{-L,--indexes-last}'[restore secondary indexes after records]' \
  '(-K --ignore-record-error)'{-K,--ignore-record-error}'[ignore permanent record-specific errors]' \
  '(-u --unique)'{-u,--unique}'[skip records that already exist]' \
  '(-g --no-generation)'{-g,--no-generation}'[ignore record generation count]' \
  '(-r --replace)'{-r,--replace}'[replace existing records entirely]' \
  '(-l --extra-ttl)'{-l,--extra-ttl}'+[add seconds to expiring records TTL]:seconds:' \
  '(-t --parallel)'{-t,--parallel}'+[number of restore threads]:threads:' \
  '(-N --nice)'{-N,--nice}'+[bandwidth and TPS limits]:limit:' \
  '(-T --timeout)'{-T,--timeout}'+[socket timeout in ms]:ms:' \
  '--socket-timeout=[socket timeout in ms]:ms:' \
  '--total-timeout=[total transaction timeout in ms]:ms:' \
  '--max-retries=[max retries per transaction]:n:' \
  '--retry-scale-factor=[retry backoff scale factor]:n:' \
  '--batch-size=[records per batch write]:n:' \
  '--max-async-batches=[max in-flight async batches]:n:' \
  '--disable-batch-writes[disable batch writes]' \
  '--event-loops=[number of c-client event loops]:n:' \
  '(-y --encrypt)'{-y,--encrypt}'+[encryption algorithm]:alg:(none aes128 aes256)' \
  '(-z --compress)'{-z,--compress}'+[compression algorithm]:alg:(none zstd)' \
  '(-w --wait)'{-w,--wait}'[wait for restored indexes to be built]' \
  '(-m --machine)'{-m,--machine}'+[machine-readable status file]:file:_files' \
  '--validate[validate backup file without restoring]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--tls-enable[enable TLS]' \
  '--tls-name=[TLS server name]:name:' \
  '--tls-cafile=[TLS CA file]:file:_files' \
  '--tls-capath=[TLS CA path]:dir:_files -/' \
  '--tls-keyfile=[TLS key file]:file:_files' \
  '--tls-keyfile-password=[TLS key file password]:password:' \
  '--tls-certfile=[TLS cert chain file]:file:_files' \
  '--config-file=[path to config file]:file:_files' \
  '--instance=[config file instance name]:name:' \
  '--no-config-file[do not read any config file]' \
  '--only-config-file=[read only this config file]:file:_files' && ret=0

return ret
