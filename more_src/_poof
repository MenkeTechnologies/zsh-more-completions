#compdef poof
# Documentation: https://man.archlinux.org/search?q=poof
# Reference accessed: 2026-05-16
# Source: cargo binstall poof@0.6.1
# Probed via: completions --shell zsh
# Repository: https://github.com/pirafrank/poof

autoload -U is-at-least

_poof() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_poof_commands" \
"*::: :->poof" \
&& ret=0
    case $state in
    (poof)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:poof-command-$line[1]:"
        case $line[1] in
            (download)
_arguments "${_arguments_options[@]}" : \
'-t+[Optional release tag (defaults to '\''latest'\'')]:TAG:_default' \
'--tag=[Optional release tag (defaults to '\''latest'\'')]:TAG:_default' \
'-h[Print help]' \
'--help[Print help]' \
':repo -- GitHub user and repository in the format USERNAME/REPO e.g. pirafrank/rust_exif_renamer:_default' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'-t+[Optional release tag (defaults to '\''latest'\'')]:TAG:_default' \
'--tag=[Optional release tag (defaults to '\''latest'\'')]:TAG:_default' \
'-h[Print help]' \
'--help[Print help]' \
':repo -- GitHub user and repository in the format USERNAME/REPO e.g. pirafrank/rust_exif_renamer:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::repo -- GitHub user and repository in the format USERNAME/REPO e.g. pirafrank/rust_exif_renamer:_default' \
&& ret=0
;;
(which)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':binary_name -- Name of the binary to look up:_default' \
&& ret=0
;;
(what)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':repo -- GitHub user and repository in the format USERNAME/REPO e.g. pirafrank/rust_exif_renamer:_default' \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':repo -- GitHub user and repository in the format USERNAME/REPO e.g. pirafrank/rust_exif_renamer:_default' \
'::version -- Version to set as default. If not specified, uses the latest version:_default' \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
'()--all[Update all installed binaries]' \
'-h[Print help]' \
'--help[Print help]' \
'::repo -- Github slug in the format USERNAME/REPO:_default' \
&& ret=0
;;
(unlink)
_arguments "${_arguments_options[@]}" : \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
':binary_name -- Name of the binary to unlink from the bin directory:_default' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'-v+[Version to uninstall]:VERSION:_default' \
'--version=[Version to uninstall]:VERSION:_default' \
'--all[Uninstall all versions of the slug]' \
'-y[Skip confirmation prompt]' \
'--yes[Skip confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
':repo -- GitHub user and repository in the format USERNAME/REPO:_default' \
&& ret=0
;;
(enable)
_arguments "${_arguments_options[@]}" : \
'-s+[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'--shell=[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-s+[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'--shell=[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-s+[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'--shell=[Shell type to generate completions for, integrate via init command, and more. Possible values\: bash, elvish, fish, nushell (or nu), powershell (or pwsh), xonsh, zsh]:SHELL:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_poof__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:poof-help-command-$line[1]:"
        case $line[1] in
            (download)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(which)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(what)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unlink)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(enable)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_poof_commands] )) ||
_poof_commands() {
    local commands; commands=(
'download:Only perform download for the platform in current directory. Do not install' \
'install:Download binary for the platform and install it' \
'list:List all installed binaries and their versions' \
'which:Show which repository provides a binary' \
'what:List all binaries provided by the latest version of a repository' \
'use:Set an installed version of a slug as the default one' \
'update:Update installed binaries of a slug or all installed binaries to their latest versions' \
'unlink:Remove binary from PATH. Use '\''poof use'\'' to re-add it' \
'uninstall:Uninstall a version or all versions of a repository' \
'enable:Persistently add poof'\''s bin directory to your shell PATH' \
'check:Check if poof'\''s bin directory is in the PATH' \
'completions:Generate shell completions to stdout' \
'init:Generate shell-specific init script to add poof bin directory to PATH' \
'clean:Empty the cache directory' \
'info:Show install and environment information' \
'version:Show version information' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'poof commands' commands "$@"
}
