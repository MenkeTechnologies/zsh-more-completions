#compdef toxiproxy-cli

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --host)'{-h,--host}'=[toxiproxy host]:host:' \
  '--help[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'list:list all proxies'
      'inspect:inspect a proxy'
      'create:create a new proxy'
      'delete:delete a proxy'
      'toggle:toggle a proxy'
      'toxic:manage toxics on a proxy'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (create)
        _arguments \
          '(-l --listen)'{-l,--listen}'=[listen address]:address:' \
          '(-u --upstream)'{-u,--upstream}'=[upstream address]:address:' \
          '1:proxy name:' && ret=0
        ;;
      (inspect|delete|toggle)
        _arguments '1:proxy name:' && ret=0
        ;;
      (toxic)
        _arguments \
          '1:action:(add remove list)' \
          '(-n --toxicName)'{-n,--toxicName}'=[toxic name]:name:' \
          '(-t --type)'{-t,--type}'=[toxic type]:type:(latency bandwidth slow_close timeout slicer limit_data)' \
          '(-s --stream)'{-s,--stream}'=[stream direction]:direction:(upstream downstream)' \
          '(-a --attribute)'{-a,--attribute}'=[toxic attribute]:key=value:' \
          '(-x --toxicity)'{-x,--toxicity}'=[toxicity level 0.0-1.0]:toxicity:' \
          '2:proxy name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
