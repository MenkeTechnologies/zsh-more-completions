#compdef swift-dispersion-report
# Documentation: https://man.archlinux.org/search?q=swift-dispersion-report
# Reference accessed: 2026-05-16

# swift-dispersion-report: check dispersion of object/container replicas
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-j[print JSON output]' \
  '--dump-json[print JSON output]' \
  '--object-only[only check objects]' \
  '--container-only[only check containers]' \
  '*:dispersion config:_files -g "*.conf"' && ret=0
return ret
