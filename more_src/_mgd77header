#compdef mgd77header
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/mgd77 — create, read or change MGD77 header records

local ret=1

_arguments -s \
  '-H+[set header field values from appended file]:file:_files' \
  '-M+[display metadata f|r|t (+param)]:mode:_default' \
  '*-V[verbose (stackable)]' \
  '*:cruise id:_files' \
  && ret=0

return ret
