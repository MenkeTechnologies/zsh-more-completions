#compdef sstrip
# Documentation: https://github.com/BR903/ELFkickers/blob/master/sstrip/sstrip.c
# super-strip: remove all non-loadable bytes from an ELF executable

local ret=1

_arguments -s \
  '(-H --help)'{-H,--help}'[display help and exit]' \
  '(-V --version)'{-V,--version}'[show version and license information]' \
  '(-z --zeroes --zeros)'{-z,--zeroes,--zeros}'[also discard trailing zero bytes]' \
  '*:ELF file:_files' && ret=0

return ret
