#compdef otbcli_Superimpose
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Superimpose.html
# Orfeo ToolBox: reproject an image into the geometry of a reference image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-inr[input reference image]:image:_files' \
  '-inm[image to reproject into the reference geometry]:image:_files' \
  '-out[output reprojected image]:output:_files' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '-lms[spacing of the deformation field]:value:' \
  '-fv[fill value for areas outside reprojected image]:value:' \
  '-mode[superimposition mode]:mode:(default phr)' \
  '-interpolator[interpolation method]:interp:(bco nn linear)' \
  '-interpolator.bco.radius[radius for bicubic interpolation filter]:radius:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
