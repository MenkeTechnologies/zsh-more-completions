#compdef easytag
# _easytag — EasyTAG GTK ID3/Vorbis/APE/FLAC/Speex/MP4 tag editor (C); batch-tag music collections
# upstream: https://gitlab.gnome.org/Archive/easytag

_easytag() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--display+[X display]:display:' \
        '--app-id+[GApplication id]:id:' \
        '*:music dir:_files -/'
}

_easytag "$@"
