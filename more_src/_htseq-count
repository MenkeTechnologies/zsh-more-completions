#compdef htseq-count
# Documentation: upstream HTSeq documentation at
# htseq.readthedocs.io/en/master/htseqcount.html
# Reference accessed: 2026-05-30 via WebFetch.
# htseq-count R98 — Python HTSeq's RNA-seq read counter. Assigns
# sequencing reads in a SAM/BAM file to genomic features defined in
# a GTF/GFF annotation file. Sister tool to featureCounts (Subread
# package) which is covered separately.

local -a _formats _orders _samfmt _stranded _modes _nonunique
local -a _sec_modes
_formats=( sam bam )
_orders=( name pos )
_samfmt=( sam bam )
_stranded=( yes no reverse )
_modes=( union intersection-strict intersection-nonempty )
_nonunique=( none all fraction random )
_sec_modes=( score ignore )

_arguments -s -S \
  '(-f --format)'{-f,--format}'=[input data format]:format:($_formats)' \
  '(-r --order)'{-r,--order}'=[paired-end sort order]:order:($_orders)' \
  '--max-reads-in-buffer=[max reads buffered for pos-sorted data (default 30M)]:N:' \
  '(-s --stranded)'{-s,--stranded}'=[strand specificity (default yes)]:mode:($_stranded)' \
  '(-a --a)'{-a,--a}'=[minimum MAPQ quality (default 10)]:N:' \
  '(-t --type)'{-t,--type}'=[GTF feature type to process (default exon)]:type:' \
  '(-i --idattr)'{-i,--idattr}'=[GTF attribute for feature ID (default gene_id)]:attr:' \
  '*--additional-attr=[additional attributes to display (repeatable)]:attr:' \
  '--add-chromosome-info[include chromosome information in output]' \
  "--feature-query=[restrict to features matching expression (e.g. 'gene_name == \"ACTB\"')]:expr:" \
  '(-m --mode)'{-m,--mode}'=[overlap handling mode]:mode:($_modes)' \
  '--nonunique=[multiple assignment handling]:mode:($_nonunique)' \
  '--secondary-alignments=[secondary alignment handling]:mode:($_sec_modes)' \
  '--supplementary-alignments=[supplementary/chimeric alignment handling]:mode:($_sec_modes)' \
  '(-n --nprocesses)'{-n,--nprocesses}'=[parallel processes (default 1)]:N:' \
  '(-o --samout)'{-o,--samout}'=[output SAM with feature assignments]:file:_files' \
  '(-p --samout-format)'{-p,--samout-format}'=[SAM output format]:format:($_samfmt)' \
  '(-c --counts_output)'{-c,--counts_output}'=[counts output file (tsv/csv/mtx/h5ad/loom)]:file:_files' \
  '--counts-output-sparse[store counts as sparse matrix (mtx/h5ad/loom)]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress reports]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:SAM/BAM alignment file:_files -g "*.(sam|bam)"' \
  '2:GTF/GFF annotation file:_files -g "*.(gtf|gff|gff3)"'
