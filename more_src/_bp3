#compdef bp3
# Documentation: https://www.ccp4.ac.uk/html/bp3.html
# CCP4 BP3 - multivariate likelihood substructure refinement and phasing

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ file with diffraction data]:file:_files' \
  'HKLOUT[output MTZ file with phased data]:file:_files' \
  '*:keyword:(XTAL SITE ATOM DNAME MODL CELL COLUMN FORM RESO BINS REFINE PHASE CYCLE REFALL NORM XYZ OCCU BISO UANO NOREF ISOE ANOE SDLU KSCALE BSCALE THRESHOLD ACENTRIC CENTRIC NODES TITLE VERBOSE OUTPUT WOLFE ALLIN)' && ret=0

return ret
