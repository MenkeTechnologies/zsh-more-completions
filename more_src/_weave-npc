#compdef weave-npc
# Documentation: https://man.archlinux.org/search?q=weave-npc
# Reference accessed: 2026-05-16

# weave-npc: Weave Net Kubernetes Network Policy controller
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--no-masq-local[do not masquerade traffic between local pods]' \
  '--config-file=[config file]:file:_files' \
  '*::weave-npc args:_files' && ret=0
return ret
