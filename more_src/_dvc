#compdef dvc

# Zsh completion for DVC (Data Version Control)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cd=[change to directory before executing]:directory:_directories' \
  '-q[be quiet]' \
  '--quiet[be quiet]' \
  '-v[be verbose]' \
  '--verbose[be verbose]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize DVC in the current directory'
      'add:track data files or directories with DVC'
      'remove:remove DVC-tracked files or directories'
      'push:upload tracked files to remote storage'
      'pull:download tracked files from remote storage'
      'fetch:download files from remote storage to cache'
      'checkout:checkout data files from cache'
      'repro:reproduce a pipeline'
      'run:generate a stage file'
      'params:manage parameters'
      'metrics:manage metrics'
      'plots:manage plots'
      'diff:show changes in data'
      'status:show changed stages and files'
      'gc:garbage collect unused cache files'
      'config:manage configuration'
      'remote:manage remote storage'
      'cache:manage cache settings'
      'install:install DVC git hooks'
      'unprotect:unprotect tracked files'
      'move:rename or move a DVC-tracked file'
      'import:download file or directory from DVC repo'
      'import-url:download file from URL and track'
      'get:download file from DVC repo'
      'get-url:download file from URL'
      'dag:visualize DVC pipeline DAG'
      'freeze:freeze stages'
      'unfreeze:unfreeze stages'
      'destroy:remove DVC files and internals'
      'doctor:show DVC system information'
      'completion:generate shell completion'
      'version:show version'
      'exp:manage experiments'
      'studio:interact with DVC Studio'
    )
    _describe -t commands 'dvc command' commands && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--no-commit[do not save to cache]' \
          '--glob[allow glob patterns]' \
          '-o+[specify output filename]:output:_files' \
          '--file=[specify .dvc file name]:dvc file:_files -g "*.dvc"' \
          '*:file:_files' && ret=0
        ;;
      push|pull|fetch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-r+[remote storage to use]:remote' \
          '--remote=[remote storage to use]:remote' \
          '-a[push all branches]' \
          '--all-branches[push all branches]' \
          '-T[push all tags]' \
          '--all-tags[push all tags]' \
          '-j+[number of jobs]:jobs' \
          '--jobs=[number of jobs]:jobs' \
          '*:target:_files -g "*.dvc"' && ret=0
        ;;
      repro)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-f[force reproduction]' \
          '--force[force reproduction]' \
          '-s[single stage]' \
          '--single-item[single stage]' \
          '-p[reproduce pipeline]' \
          '--pipeline[reproduce pipeline]' \
          '--downstream[reproduce downstream pipeline]' \
          '*:target:_files -g "*.dvc"' && ret=0
        ;;
      remote)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add default list modify remove rename)' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--global[use global config]' \
          '--system[use system config]' \
          '--local[use local config]' \
          '-u[unset config value]' \
          '--unset[unset config value]' \
          '-l[list all config values]' \
          '--list[list all config values]' && ret=0
        ;;
      gc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-w[keep only files used in workspace]' \
          '--workspace[keep only files used in workspace]' \
          '-a[keep files for all branches]' \
          '--all-branches[keep files for all branches]' \
          '-T[keep files for all tags]' \
          '--all-tags[keep files for all tags]' \
          '--all-commits[keep files for all commits]' \
          '--all-experiments[keep files for all experiments]' \
          '-f[force garbage collection]' \
          '--force[force garbage collection]' \
          '-j+[number of jobs]:jobs' \
          '--jobs=[number of jobs]:jobs' && ret=0
        ;;
      exp)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(show diff run apply branch list gc push pull remove)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
