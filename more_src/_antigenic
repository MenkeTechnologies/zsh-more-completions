#compdef antigenic
# antigenic - Find antigenic sites in proteins

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input protein sequence(s)]:file:_files' \
  '-minlen[minimum length of antigenic region]:length:' \
  '-outfile[output report file name]:file:_files' \
  '-sbegin1[start position for analysis]:pos:' \
  '-send1[end position for analysis]:pos:' \
  '-sreverse1[reverse sequence (DNA only)]' \
  '-sask1[prompt for begin/end/reverse]' \
  '-sformat1[input sequence format]:format:' \
  '-sdbname1[database name for retrieval]:db:' \
  '-rformat2[report output format]:format:' \
  '-rscoreshow2[display scores in report]' \
  '-rmaxall2[maximum total hits to report]:n:' \
  '-rmaxseq2[maximum hits per sequence]:n:' \
  '-auto[turn off prompts]' \
  '-stdout[write to standard output]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
