#compdef maildirproc
# Documentation: https://mailprocessing.github.io/mailprocessing/reference.html
# maildirproc - filter and process mail in local Maildirs via an rc file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-r --rcfile)'{-r,--rcfile=}'[use rc FILE]:file:_files' \
  '(-l --logfile)'{-l,--logfile=}'[log to FILE]:file:_files' \
  '--log-level=[set numeric log level]:level' \
  '(-m --maildir)'{-m,--maildir=}'[add maildir DIRECTORY to process]:dir:_files -/' \
  '(-b --maildir-base)'{-b,--maildir-base=}'[set maildir base DIRECTORY]:dir:_files -/' \
  '(-p --folder-prefix)'{-p,--folder-prefix=}'[set folder name PREFIX]:prefix' \
  '(-s --folder-separator)'{-s,--folder-separator=}'[set folder name SEParator]:sep' \
  '--auto-reload-rcfile[reload rc file when it changes]' \
  '--dry-run[do not perform actions, only log]' \
  '--once[process maildirs once then exit]' \
  '--test[test rc file then exit]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:file:_files' && ret=0

return ret
