#compdef opus_demo
# Documentation: https://github.com/xiph/opus/blob/master/src/opus_demo.c
# demonstration encoder/decoder for the Opus audio codec

local ret=1

_arguments -s -S \
  '-e[only run the encoder (output the bit-stream)]' \
  '-d[only run the decoder (read the bit-stream as input)]' \
  '-cbr[enable constant bitrate]' \
  '-cvbr[enable constrained variable bitrate]' \
  '-bandwidth[audio bandwidth]:bandwidth:(NB MB WB SWB FB)' \
  '-framesize[frame size in ms]:framesize:(2.5 5 10 20 40 60 80 100 120)' \
  '-max_payload[maximum payload size in bytes]:bytes' \
  '-complexity[encoder complexity, 0 (lowest) to 10 (highest)]:complexity' \
  '-dec_complexity[decoder complexity, 0 to 10]:complexity' \
  '-inbandfec[enable SILK inband FEC]' \
  '-forcemono[force mono encoding, even for stereo input]' \
  '-dtx[enable SILK DTX]' \
  '-delayed-decision[use look-ahead for speech/music detection]' \
  '-loss[optimize for packet loss percentage (0-100)]:percent' \
  '-sim_loss[simulate bursty packet loss]:percent' \
  '-lossfile[read loss patterns from file]:file:_files' \
  '-dred[add Deep REDundancy frames]:frames' \
  '-16[use 16-bit PCM]' \
  '-24[use 24-bit PCM]' \
  '-f32[use 32-bit float PCM]' \
  '*:file:_files' && ret=0

return ret
