#compdef compstyle
# Documentation: https://man.archlinux.org/search?q=compstyle
# Reference accessed: 2026-05-16
# Source: https://github.com/mattmc3/ez-compinit/blob/5c9b6da88a463573e26e6846ff164026640ef2f6/functions/_compstyle
# Repository: mattmc3/ez-compinit (functions/_compstyle)

if [[ "$#populate_completion_styles" -eq 0 ]]; then
  compstyleinit 2>/dev/null
  [[ $#completion_styles -gt 0 ]] || populate_completion_styles 2>/dev/null
fi

_arguments -s \
  '-l[list completion styles]:*:' \
  "-h[help]::completion style:($completion_styles):*:" \
  ":completion style:($completion_styles)"

