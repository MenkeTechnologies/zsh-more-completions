#compdef resty

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-e+[execute string]:Lua code' \
  '-I+[add search directory for Lua libraries]:directory:_directories' \
  '--errlog-level=[set error log level]:level:(stderr emerg alert crit error warn notice info debug)' \
  '--http-conf=[extra http configuration block]:config' \
  '--http-include=[include config file in http block]:file:_files' \
  '--main-conf=[extra main configuration block]:config' \
  '--main-include=[include config file in main block]:file:_files' \
  '--ns=[specify DNS nameserver]:nameserver' \
  '--resolve-ipv6[enable IPv6 resolution]' \
  '--shdict=[define shared dict]:name size' \
  '--nginx=[specify nginx path]:path:_files' \
  '-j+[turn on or off the LuaJIT JIT compiler]:mode:(on off dump)' \
  '--gdb[enable GDB debugging mode]' \
  '--gdb-opts=[GDB debugger command-line options]:options' \
  '--rr[enable rr recording mode]' \
  '--stap[enable SystemTap tracing mode]' \
  '--stap-opts=[SystemTap command-line options]:options' \
  '--user-runner=[specify a custom runner command]:runner' \
  '--valgrind[enable Valgrind mode]' \
  '--valgrind-opts=[Valgrind command-line options]:options' \
  '*:Lua file:_files -g "*.lua"' && ret=0

return ret
