#compdef cproc
# Minimal C11 compiler using QBE backend

_arguments -s -S \
  '-c[compile only, do not link]' \
  '-D-[define macro]:macro:' \
  '-E[preprocess only]' \
  '-g[include debug information]' \
  '-I[add include path]:dir:_files -/' \
  '-L[add library path]:dir:_files -/' \
  '-l[link library]:library:' \
  '-o[output file]:file:_files' \
  '-O-[optimization level]:level:(0 1 2 3 s)' \
  '-S[output assembly]' \
  '-U[undefine macro]:macro:' \
  '-W-[warning option]:warning:' \
  '-std=[language standard]:standard:(c11 c99)' \
  '-pedantic[strict standards compliance]' \
  '*:source file:_files -g "*.c"' \
  && return 0
