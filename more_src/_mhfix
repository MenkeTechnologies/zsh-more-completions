#compdef mhfix
# Documentation: https://man.archlinux.org/search?q=mhfix
# Reference accessed: 2026-05-16

# mhfix: fix MH mail folder header lines
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[list folders to fix]' \
  '-v[verbose]' \
  '*:folder:_files -/' && ret=0
return ret
