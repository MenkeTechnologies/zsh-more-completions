#compdef mhfix
# Documentation: https://manpages.debian.org/jessie/nmh/mhfixmsg.1mh.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mhfix: fix MH mail folder header lines
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-l[list folders to fix]' \
  '-v[verbose]' \
  '*:folder:_files -/' && ret=0
return ret
