#compdef kanidmd
# _kanidmd — William Brown Kanidm identity management server daemon (kanidm team, Rust); clap-derive
# upstream: https://github.com/kanidm/kanidm

_kanidmd() {
    local -a sub=(
        'server:start kanidm server'
        'configtest:validate config'
        'cert-generate:generate self-signed cert'
        'database:database subcommands'
        'recover-account:reset password'
        'show-replication-certificate:show repl cert'
        'renew-replication-certificate:renew repl cert'
        'refresh-replication-consumer:refresh consumer'
        'domain:domain subcommands'
        'healthcheck:health check'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--debug[debug logging]' \
        '-d[debug logging]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kanidmd subcommand' sub ;;
        args)
            case $words[1] in
                database) _arguments '1:db cmd:(backup restore verify reindex vacuum)' ;;
                domain) _arguments '1:domain cmd:(rename change show-replication-certificate)' ;;
                recover-account) _arguments \
                    '--name=+[account]:user:_users' \
                    '*:account:_users' ;;
                healthcheck) _arguments \
                    '--no-verify-tls[skip TLS verify]' \
                    '--check-origin[check origin]' ;;
            esac
            ;;
    esac
}

_kanidmd "$@"
