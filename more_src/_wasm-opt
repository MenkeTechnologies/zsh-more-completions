#compdef wasm-opt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '-O[execute default optimization passes]' \
  '-O0[no optimization]' \
  '-O1[light optimization]' \
  '-O2[moderate optimization]' \
  '-O3[heavy optimization]' \
  '-O4[aggressive optimization]' \
  '-Os[optimize for code size]' \
  '-Oz[aggressively optimize for code size]' \
  '--optimize-level=[set the optimization level]:level:(0 1 2 3 4)' \
  '--shrink-level=[set the shrink level]:level:(0 1 2)' \
  '-g[preserve debug info]' \
  '--debuginfo[preserve debug info]' \
  '-S[emit text format output]' \
  '--emit-text[emit text format output]' \
  '--converge[run passes until binary does not change]' \
  '--enable-threads[enable threads feature]' \
  '--enable-mutable-globals[enable mutable globals feature]' \
  '--enable-nontrapping-float-to-int[enable nontrapping float-to-int]' \
  '--enable-simd[enable SIMD feature]' \
  '--enable-bulk-memory[enable bulk memory feature]' \
  '--enable-sign-ext[enable sign extension feature]' \
  '--enable-exception-handling[enable exception handling]' \
  '--enable-tail-call[enable tail call feature]' \
  '--enable-reference-types[enable reference types]' \
  '--enable-multivalue[enable multivalue feature]' \
  '--enable-gc[enable GC feature]' \
  '--enable-memory64[enable memory64 feature]' \
  '--enable-all[enable all features]' \
  '--mvp-features[use only MVP features]' \
  '--all-features[enable all features]' \
  '--detect-features[use features from the input module]' \
  '--quiet[suppress warnings]' \
  '--no-validation[skip validation]' \
  '--print[print the wasm module]' \
  '--print-minified[print the wasm module minified]' \
  '--print-features[print the used features]' \
  '--metrics[report metrics]' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
