#compdef wasm-opt
# Documentation: https://github.com/WebAssembly/binaryen (src/tools/optimization-options.h, tool-options.h)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '-O[execute default optimization passes (equivalent to -Os)]' \
  '-O0[execute no optimization passes]' \
  '-O1[execute -O1 optimization passes (quick&useful opts)]' \
  '-O2[execute -O2 optimization passes (most opts, generally gets most perf)]' \
  '-O3[execute -O3 optimization passes (spends potentially a lot of time optimizing)]' \
  '-O4[execute -O4 optimization passes (also flatten the IR)]' \
  '-Os[execute default optimization passes, focusing on code size]' \
  '-Oz[execute default optimization passes, super-focusing on code size]' \
  '(--optimize-level -ol)'{--optimize-level=,-ol+}'[how much to focus on optimizing code]:level:(0 1 2 3 4)' \
  '(--shrink-level -s)'{--shrink-level=,-s+}'[how much to focus on shrinking code size]:level:(0 1 2)' \
  '(--debuginfo -g)'{--debuginfo,-g}'[emit names section in wasm binary (or full debuginfo in wast)]' \
  '(-S --emit-text)'{-S,--emit-text}'[emit text instead of binary for the output file]' \
  '(-c --converge)'{-c,--converge}'[run passes to convergence, continuing while binary size decreases]' \
  '--mvp-features[disable all features besides MVP]' \
  '--all-features[enable all features]' \
  '--detect-features[use features from the input module]' \
  '--quiet[emit less verbose output and hide trivial warnings]' \
  '--no-validation[do not validate the wasm output]' \
  '--pass-arg=[pass an argument to the pass]:arg' \
  '--closed-world[assume the module is in a closed world]' \
  '--preserve-type-order[preserve the original type order]' \
  '--generate-stack-ir[generate StackIR during writing]' \
  '--optimize-stack-ir[optimize StackIR]' \
  '--print-stack-ir[print StackIR]' \
  '--enable-threads[enable threads feature]' \
  '--disable-threads[disable threads feature]' \
  '--enable-mutable-globals[enable mutable globals feature]' \
  '--disable-mutable-globals[disable mutable globals feature]' \
  '--enable-nontrapping-float-to-int[enable nontrapping float-to-int feature]' \
  '--disable-nontrapping-float-to-int[disable nontrapping float-to-int feature]' \
  '--enable-simd[enable SIMD feature]' \
  '--disable-simd[disable SIMD feature]' \
  '--enable-bulk-memory[enable bulk memory feature]' \
  '--disable-bulk-memory[disable bulk memory feature]' \
  '--enable-sign-ext[enable sign extension feature]' \
  '--disable-sign-ext[disable sign extension feature]' \
  '--enable-exception-handling[enable exception handling feature]' \
  '--disable-exception-handling[disable exception handling feature]' \
  '--enable-tail-call[enable tail call feature]' \
  '--disable-tail-call[disable tail call feature]' \
  '--enable-reference-types[enable reference types feature]' \
  '--disable-reference-types[disable reference types feature]' \
  '--enable-multivalue[enable multivalue feature]' \
  '--disable-multivalue[disable multivalue feature]' \
  '--enable-gc[enable GC feature]' \
  '--disable-gc[disable GC feature]' \
  '--enable-memory64[enable memory64 feature]' \
  '--disable-memory64[disable memory64 feature]' \
  '--enable-relaxed-simd[enable relaxed SIMD feature]' \
  '--disable-relaxed-simd[disable relaxed SIMD feature]' \
  '--enable-extended-const[enable extended const feature]' \
  '--disable-extended-const[disable extended const feature]' \
  '--enable-strings[enable strings feature]' \
  '--disable-strings[disable strings feature]' \
  '--enable-multimemory[enable multimemory feature]' \
  '--disable-multimemory[disable multimemory feature]' \
  '--enable-typed-function-references[enable typed function references feature]' \
  '--disable-typed-function-references[disable typed function references feature]' \
  '(-ism --input-source-map)'{-ism+,--input-source-map=}'[consume source map from the specified file]:file:_files' \
  '(-osm --output-source-map)'{-osm+,--output-source-map=}'[emit source map to the specified file]:file:_files' \
  '(-osu --output-source-map-url)'{-osu+,--output-source-map-url=}'[emit source map URL]:url' \
  '--emit-exnref[after running passes, translate to new EH instructions]' \
  '(-esw --emit-spec-wrapper)'{-esw,--emit-spec-wrapper}'[emit a wasm spec interpreter wrapper file]' \
  '--emit-wasm2c-wrapper=[emit a wasm2c wrapper file to the given path]:file:_files' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
