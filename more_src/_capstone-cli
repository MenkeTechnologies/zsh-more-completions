#compdef capstone-cli cstool
# _capstone-cli — Nguyen Anh Quynh Capstone capstone-cli cstool CLI disassembly framework command-line frontend around the Capstone library disassembling hex-encoded byte streams from stdin or args producing per-instruction mnemonic operand-decoded output supporting x86 x86_64 ARM ARM64 MIPS PowerPC SPARC SystemZ XCore M68K M680X TMS320C64x BPF EBPF RISC-V WebAssembly TriCore (Nguyen Anh Quynh team, C); getopt
# upstream: https://www.capstone-engine.org/

_capstone-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[detail mode]' \
        '-r[real instructions only]' \
        '-s[show syntax variants]' \
        '-S+[syntax]:s:(att intel masm noregname)' \
        '-u[unsigned hex]' \
        '*:arch+hex:_files'
}

_capstone-cli "$@"
