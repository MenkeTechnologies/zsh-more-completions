#compdef debugpy
# Documentation: https://github.com/microsoft/debugpy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for debugpy (Python debugger for DAP)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--listen=[listen for DAP connections]:host\:port:' \
  '--connect=[connect to DAP client]:host\:port:' \
  '--wait-for-client[wait for client to connect before running]' \
  '--configure-qt=[configure Qt signal handling]:mode:(none auto)' \
  '--configure-subProcess=[configure subprocess debugging]:mode:(true false)' \
  '--adapter-access-token=[access token for adapter]:token:' \
  '--log-to=[directory for log files]:directory:_files -/' \
  '--log-to-stderr[log to stderr]' \
  '(-m --module)'{-m,--module}'[run library module as a script]:module:' \
  '(-c --code)'{-c,--code}'[program passed as string]:code:' \
  '--pid=[attach to process by PID]:pid:_pids' \
  '*:script:_files -g "*.py"' && ret=0

return ret
