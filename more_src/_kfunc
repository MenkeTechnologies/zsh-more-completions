#compdef kfunc kfunc-cli
# _kfunc — Linux Kernel kfunc CLI helper for managing BPF kfuncs kernel functions exposed to BPF programs listing-discovering kfunc-set registering filter-by-name signature trampoline-attach detach BPF kfunc ID listing-attaching trampolines on running tracing BPF subsystem program-helper for live kernel probes (Linux Kernel team, C); getopt
# upstream: https://docs.kernel.org/bpf/kfuncs.html

_kfunc() {
    local -a sub=(
        'list:list available kfuncs'
        'show:show details for a kfunc'
        'attach:attach to a kfunc'
        'detach:detach from a kfunc'
        'filter:filter kfuncs by name pattern'
        'set:show kfunc sets'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--filter=+[regex]:str:' \
        '--name=+[name]:str:' \
        '--subsystem=+[name]:str:' \
        '--module=+[name]:str:' \
        '-o+[output]:f:(json yaml table text plain)' \
        '--output=+[format]:f:(json yaml table text plain)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kfunc subcommand' sub ;;
        args)
            case $words[1] in
                show|attach|detach) _arguments '*:kfunc name:' ;;
            esac
            ;;
    esac
}

_kfunc "$@"
