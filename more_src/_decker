#compdef decker

# Zsh completion for decker multimedia presentation compiler

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-q[quiet]' \
  '(-d -c -b)'{-d,-c,-b}'[output format shortcut]' \
  '*:decker document:_files -g "*.dk"' && ret=0

return ret
