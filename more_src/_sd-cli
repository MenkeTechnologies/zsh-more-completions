#compdef sd
# Documentation: https://raw.githubusercontent.com/chmln/sd/master/sd-cli/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream clap Options struct in sd-cli/src/cli.rs.
# Removed from prior file: --fixed-strings flag entry separate from -s
# (real sd treats --fixed-strings / -F / --string-mode / -s as same boolean).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --flags)'{-f+,--flags=}'[regex flags]:flags:' \
  '(-n --max-replacements)'{-n+,--max-replacements=}'[max replacements]:limit:' \
  '(-p --preview)'{-p,--preview}'[preview only]' \
  '(-F --fixed-strings -s --string-mode)'{-F,--fixed-strings,-s,--string-mode}'[treat as literal string]' \
  '(-A --across)'{-A,--across}'[match across line boundaries]' \
  '1:find pattern:' \
  '2:replace string:' \
  '*: :_files' && ret=0

return ret
