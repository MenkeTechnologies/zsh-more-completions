#compdef sd

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --flags)'{-f+,--flags=}'[regex flags]:flags:(c i m s w e)' \
  '(-n --max-replacements)'{-n+,--max-replacements=}'[max replacements]:n:' \
  '(-p --preview)'{-p,--preview}'[preview only]' \
  '(-s --string-mode)'{-s,--string-mode}'[treat as literal string]' \
  '(--fixed-strings)--fixed-strings[treat as literal]' \
  '1:find pattern:' \
  '2:replace string:' \
  '*: :_files' && ret=0

return ret
