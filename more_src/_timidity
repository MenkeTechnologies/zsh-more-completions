#compdef timidity timidity++
# _timidity — Masanao Izumo TiMidity++ MIDI to WAVE renderer/player with GUS/EAS SoundFont support and ALSA/OSS/PulseAudio/JACK/CoreAudio outputs (tim61 team, C); getopt
# upstream: https://timidity.sourceforge.net/

_timidity() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-A+[amplification %]:n:' \
        '-B+[buffer size,N]:str:' \
        '-C+[ratio]:n:' \
        '-D+[mode]:m:(0 1 2 3 4)' \
        '-EFreverb=+[level]:n:' \
        '-EFchorus=+[level]:n:' \
        '-EFns=+[N]:n:' \
        '-EFresamp=+[mode]:m:(none linear cspline lagrange newton gauss)' \
        '-F+[antialias]' \
        '-i+[interface]:i:(d v T R E P A)' \
        '-k+[time msec]:n:' \
        '-K+[transpose]:n:' \
        '-L+[path]:dir:_files -/' \
        '-N+[noise]:n:' \
        '-O+[output mode]:o:(s 1 3 d w r b R a M l F j N p e o)' \
        '-o+[output file]:file:_files -g "*.wav *.aiff *.au *.snd *.flac *.ogg *.mp3"' \
        '-P+[patch file]:file:_files -g "*.pat *.cfg *.sf2 *.dls"' \
        '-q+[quiet]' \
        '-Q+[quality]:n:' \
        '-r[reverse]' \
        '-R+[delay ms]:n:' \
        '-s+[sample rate]:n:(8000 11025 16000 22050 32000 44100 48000 88200 96000)' \
        '-S+[cache size]:n:' \
        '-t+[output charset]:e:(utf-8 iso-8859-1 sjis euc)' \
        '-T+[tempo]:n:' \
        '-U[unload patches]' \
        '-W+[wrd format]:w:(n d t f)' \
        '-x+[command]:str:' \
        '-Z+[freq.cfg]:file:_files' \
        '-c+[config]:file:_files -g "*.cfg"' \
        '-Y+[reverb]:n:' \
        '*:MIDI/audio file:_files -g "*.mid *.midi *.kar *.mod *.s3m *.it *.xm *.rcp *.mfi *.wrd *.smaf *.mmf"'
}

_timidity "$@"
