#compdef elf2uf2-rs

# JoNil/elf2uf2-rs — Clap CLI (convert|deploy) + global --verbose LogLevel.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=( 'convert:write UF2 file from ELF' 'deploy:flash ELF to UF2 bootloader' )

_arguments -s -S -C \
  '(-v --verbose)'{-v,--verbose}"=[log level]:level:(off error warn info debug trace)" \
  '1: :->cmd' \
  '*::args: _normal' && ret=0

case $state in
  cmd)
    _describe -t commands 'elf2uf2-rs' subcmds && ret=0
    ;;
esac

return ret
