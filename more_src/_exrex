#compdef exrex

# Zsh completion for exrex - generate strings matching a regex

_arguments -s -S \
  '(-c --count)'{-c,--count}'[print number of matching strings]' \
  '(-m --max-number)'{-m+,--max-number=}'[max number of strings to generate]:count:' \
  '(-l --limit)'{-l+,--limit=}'[max range limit for repetitions]:limit:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[output delimiter]:delimiter:' \
  '(-r --random)'{-r,--random}'[generate random string]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:regex pattern:'
