#compdef sccache

# Zsh completion for sccache - shared compilation cache

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--start-server[start background server]' \
  '--stop-server[stop background server]' \
  '--show-stats[show cache statistics]' \
  '--show-adv-stats[show advanced cache statistics]' \
  '--zero-stats[zero cache statistics]' \
  '--dist-auth[authenticate for distributed compilation]' \
  '--dist-status[show distributed compilation status]' \
  '--package-toolchain[package local toolchain for distribution]' \
  '--stats-format[set stats output format]:format:(text json)' \
  '--dist-url[set scheduler URL]:url:' \
  '*::compiler arguments:_dispatch cc cc'
