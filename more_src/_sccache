#compdef sccache
# Documentation: https://github.com/mozilla/sccache
# Reference accessed: 2026-05-21
# Verified: upstream README documents --start-server, --stop-server,
# --show-stats, --stats-format, --dist-auth, --dist-status,
# --package-toolchain, --dist-url. --show-adv-stats, --zero-stats are
# also documented in current sccache.

local curcontext="$curcontext" ret=1

_arguments \
  '(- *)--help[show help message]' \
  '(- *)--version[show version]' \
  '--start-server[start background server]' \
  '--stop-server[stop background server]' \
  '--show-stats[show cache statistics]' \
  '--show-adv-stats[show advanced cache statistics]' \
  '--zero-stats[zero cache statistics]' \
  '--dist-auth[authenticate for distributed compilation]' \
  '--dist-status[show distributed compilation status]' \
  '--package-toolchain[package local toolchain for distribution]:exe:_files' \
  '--stats-format=[stats output format]:format:(text json)' \
  '--dist-url=[scheduler URL]:url:' \
  '*::compiler arguments:_dispatch cc cc' && ret=0

return ret
