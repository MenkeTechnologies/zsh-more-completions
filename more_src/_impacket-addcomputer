#compdef impacket-addcomputer

# Impacket addcomputer.py: add new computer account via LDAP/SAMR
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-method[creation method]:method:(SAMR LDAPS)' \
  '-port[connection port]:port:' \
  '-domain-netbios[domain NetBIOS]:netbios:' \
  '-computer-name[new computer name]:name:' \
  '-computer-pass[new computer password]:pwd:' \
  '-delete[delete the computer account instead]' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos]' \
  '-aesKey[AES key]:key:' \
  '*:domain/user[:password]:' && ret=0
return ret
