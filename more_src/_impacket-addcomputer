#compdef impacket-addcomputer
# Documentation: https://github.com/fortra/impacket/blob/master/examples/addcomputer.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-addcomputer: create / modify / delete a domain computer object.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-domain-netbios[domain NetBIOS name]:netbios:' \
  '-computer-name[new computer name (random if omitted)]:name:' \
  '-computer-pass[password for the computer account]:pass:' \
  '-no-add[set password on existing account without adding]' \
  '-delete[remove an existing computer account]' \
  '-method[method to use]:method:(SAMR LDAPS)' \
  '-port[destination port]:port:(139 445 636)' \
  '-baseDN[LDAP base DN]:dn:' \
  '-computer-group[group DN for the new account]:dn:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-host[domain controller hostname]:host:_hosts' \
  '-dc-ip[domain controller IP]:ip:' \
  '*::positional:_files' && ret=0
return ret
