#compdef packagekitd
# Documentation: https://github.com/PackageKit/PackageKit/blob/main/src/pk-main.c
# Reference accessed: 2026-05-16
# Verified: src/pk-main.c GOptionEntry array.

# packagekitd: PackageKit daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version and exit]' \
  '--backend=[packaging backend to use]:backend:(dummy alpm aptcc dnf zypp slackpkg ports portage urpmi)' \
  '--disable-timer[disable the idle timer]' \
  '--timed-exit[exit after a small delay]' \
  '--immediate-exit[exit after the engine has loaded]' \
  '--keep-environment[do not clear environment on startup]' && ret=0
return ret
