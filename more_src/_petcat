#compdef petcat
# Documentation: https://github.com/VICE-Team/svn-mirror/blob/main/vice/src/tools/petcat/petcat.c
# Reference accessed: 2026-05-16
# Verified: vice/src/tools/petcat/petcat.c argv loop (lines 1100-1198) + usage()
# (lines 1401-1488) + basic_list[] (lines 545-590) for the version selectors.
# Removed from prior file: --help (real is -help/-?), -1/-2/-a/-b/-4/-5/-7/-10/-71
# (real version flags are -<verselect> where verselect comes from basic_list[];
# real values include "1p", "2", "40", "4e", "3", "70", "10", "71", "65", plus
# many extension variants), -w as plain flag (real is -w<version>), -text mode
# (real - kept), -c (real - kept), -l (real - kept), -o (real - kept), -q
# (NOT in source; real verbose flag is -v), -skip (real - kept), -utf8
# (NOT in source).

# petcat: VICE C64 BASIC tokenizer/detokenizer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-\?[show help]' \
  '(- *)-version[show version]' \
  '-v[verbose output]' \
  '-c[interpret control codes (default if textmode)]' \
  '-nc[suppress control codes]' \
  '-ic[interpret control codes case-insensitive]' \
  '-qc[convert non-alphanumerics in quotes to controls]' \
  '-d[output raw codes in decimal]' \
  '-h[write header (default if stdout)]' \
  '-nh[no header (default if file output)]' \
  '-skip[skip N bytes of input]:n:' \
  '-text[force text mode]' \
  '-C-[checksum type]:type:' \
  '-l[load address (hex, no prefix)]:addr:' \
  '-o[output file]:file:_files' \
  '-f[force overwrite output]' \
  '-1p[BASIC v1.0 (PET)]' \
  '-2[BASIC v2.0 (C64/VIC20/PET)]' \
  '-40[BASIC v4.0 (PET/CBM2)]' \
  '-4e[BASIC v2.0 with v4.0 ext (C64)]' \
  '-3[BASIC v3.5 (C16/+4)]' \
  '-70[BASIC v7.0 (C128)]' \
  '-71[BASIC v7.1 ext (C128)]' \
  '-10[BASIC v10.0 (C65/C64DX)]' \
  '-65[BASIC v65.0 (Mega65)]' \
  '-simon[Simons BASIC (C64)]' \
  '-superexp[Super Expander (VIC20)]' \
  '-turtle[Turtle Basic (VIC20)]' \
  '-speech[Speech Basic v2.7 (C64)]' \
  '-a[@Basic (C64)]' \
  '-f[Final Cartridge III (C64)]' \
  '-ultra[Ultrabasic-64 (C64)]' \
  '-graph[Graphics Basic (C64)]' \
  '-bws[WS Basic (C64)]' \
  '-mighty[Mighty Basic (VIC20)]' \
  '-pegasus[Pegasus Basic v4.0 (C64)]' \
  '-xbasic[Xbasic (C64)]' \
  '-drago[Drago Basic v2.2 (C64)]' \
  '-reu[REU-Basic (C64)]' \
  '-lightning[Basic Lightning (C64)]' \
  '-magic[Magic Basic (C64)]' \
  '-easy[Easy Basic (VIC20)]' \
  '-blarg[Blarg (C64)]' \
  '-4v[Basic v4.0 ext (VIC20)]' \
  '-5[Basic v5.0 ext (VIC20)]' \
  '-bwsf[WS Basic final (C64)]' \
  '-game[Game Basic (C64)]' \
  '-bsx[Basex (C64)]' \
  '-superbas[Super Basic (C64)]' \
  '-exp64[Expanded Basic (C64)]' \
  '-sxc[Super Expander Chip (C64)]' \
  '-bwarsaw[Warsaw Basic (C64)]' \
  '-exp20[Expanded Basic (VIC20)]' \
  '-supergra[Supergrafik 64 (C64)]' \
  '-bk[Kipper Basic (C64)]' \
  '-bob[Basic on Bails (C64)]' \
  '-eve[Eve Basic (C64)]' \
  '-tt64[The Tool 64 (C64)]' \
  '-handy[Handy Basic v1.0 (VIC20)]' \
  '*:file:_files -g "*.(prg|bas|txt|p00)"' && ret=0
return ret
