#compdef petcat
# Documentation: https://vice-emu.sourceforge.io/vice_15.html#SEC306
# Reference accessed: 2026-05-16

# petcat: VICE C64 BASIC tokenizer/detokenizer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-1[BASIC 1.0]' \
  '-2[BASIC 2.0]' \
  '-a[BASIC 3.5 (Plus/4)]' \
  '-b[BASIC 4.0]' \
  '-4[BASIC 4.0]' \
  '-5[BASIC 5.0]' \
  '-7[BASIC 7.0]' \
  '-10[BASIC 10.0]' \
  '-71[BASIC 7.1]' \
  '-w[detokenize (write text)]' \
  '-text[text mode]' \
  '-c[control codes lower/uppercase]' \
  '-l[list line numbers]:n:' \
  '-o[output file]:file:_files' \
  '-q[quiet]' \
  '-skip[skip first N bytes]:n:' \
  '-utf8[use UTF-8]' \
  '*:file:_files -g "*.(prg|bas|txt|p00)"' && ret=0
return ret
