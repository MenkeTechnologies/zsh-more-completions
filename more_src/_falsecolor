#compdef falsecolor
# Documentation: https://floyd.lbl.gov/radiance/man_html/falsecolor.1.html
# Radiance false color image generator

local ret=1

_arguments -s \
  '-i[input picture file]:input:_files' \
  '-p[overlay contours on another Radiance picture]:picture:_files' \
  '-cb[produce contour bands instead of lines]' \
  '-cl[create contour lines]' \
  '-cp[create a posterization (banded colours) effect]' \
  '-e[print extrema on brightest and darkest pixels]' \
  '-s[set luminance scale]:scale' \
  '-d[maximum decimal places for legend entries]:digits' \
  '-l[legend label]:label' \
  '-n[number of contours and legend entries]:ndivs' \
  '-lw[legend width in pixels]:lwidth' \
  '-lh[legend height in pixels]:lheight' \
  '-log[use logarithmic mapping over given decades]:decades' \
  '-m[multiplier for value conversion]:mult' \
  '-pal[select color palette]:palette:(spec tbo hot eco pm3d def)' \
  '-r[custom red channel expression]:redv' \
  '-g[custom green channel expression]:grnv' \
  '-b[custom blue channel expression]:bluv' \
  '-palettes[display all available color palettes as HDR image]' && ret=0

return ret
