#compdef fnirtfileutils
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fnirt/utils.html
# FSL: convert and manipulate fnirt coefficient/field files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --in)'{-i,--in=}'[filename of input coefficients/field]:input:_files' \
  '(-r --ref)'{-r,--ref=}'[filename of target image for the warps]:ref:_files' \
  '(-o --out)'{-o,--out=}'[filename of output file]:output:_files' \
  '(-f --outformat)'{-f,--outformat=}'[output format]:format:(field spline)' \
  '(-w --warpres)'{-w,--warpres=}'[warp resolution xres,yres,zres]:warpres:' \
  '(-k --knotspace)'{-k,--knotspace=}'[knot-spacing xksp,yksp,zksp]:knotspace:' \
  '(-j --jac)'{-j,--jac=}'[filename of output Jacobian determinants]:jac:_files' \
  '(-a --withaff)'{-a,--withaff}'[include affine transform as displacements in output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:image:_files' && ret=0

return ret
