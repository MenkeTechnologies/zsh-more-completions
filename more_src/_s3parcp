#compdef s3parcp
# Documentation: https://github.com/chanzuckerberg/s3parcp
# s3parcp - parallel chunked S3 copy tool, faster than s3cp

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message]' \
  '(-p --part-size)'{-p,--part-size=}'[part size in bytes of parts to be downloaded]:bytes' \
  '(-c --concurrency)'{-c,--concurrency=}'[download concurrency]:concurrency' \
  '(-b --buffer-size)'{-b,--buffer-size=}'[size of download buffer in bytes]:bytes' \
  '--checksum[compare checksum if downloading or place checksum in metadata if uploading]' \
  '(-r --recursive)'{-r,--recursive}'[copy directories or folders recursively]' \
  '--version[print the current version]' \
  '--s3_url=[a custom s3 API url]:url' \
  '--max-retries=[max per chunk retries]:retries' \
  '--disable-ssl[disable SSL]' \
  '--disable-cached-credentials[disable caching AWS credentials]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '*:file:_files' && ret=0

return ret
