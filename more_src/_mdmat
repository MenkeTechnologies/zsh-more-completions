#compdef mdmat gmx-mdmat
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-mdmat.html
# gmx mdmat: calculate residue contact maps

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-mean[X PixMap distance matrix]:file:_files' \
  '-frames[X PixMap frame-by-frame matrices]:file:_files' \
  '-no[contact count file]:file:_files' \
  '-b[initial frame time in ps]:time:' \
  '-e[final frame time in ps]:time:' \
  '-dt[frame selection interval in ps]:time:' \
  '-xvg[plot format selection]:format:(xmgrace xmgr none)' \
  '-t[distance truncation threshold]:real:' \
  '-nlevels[discretization levels for distance matrix]:int:' && ret=0

return ret
