#compdef statuscake-cli statuscake
# _statuscake-cli — StatusCake statuscake-cli CLI command-line frontend wrapping the StatusCake uptime monitoring SSL monitoring page speed test domain monitoring server monitoring platform REST API providing uptime ssl pagespeed domain server contact-group maintenance-window status-page user heartbeat HTTP-HTTPS-Push-DNS-TCP-SMTP-SSH-PING worldwide-probes detailed-reports (StatusCake team, Go); cobra
# upstream: https://www.statuscake.com/

_statuscake-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'uptime:uptime test operations'
        'ssl:SSL test operations'
        'pagespeed:pagespeed test operations'
        'domain:domain test operations'
        'server:server test operations'
        'heartbeat:heartbeat operations'
        'contact-group:contact group operations'
        'maintenance-window:maintenance window operations'
        'status-page:status page operations'
        'user:user operations'
        'subscription:subscription operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '--name=+[name]:str:' \
        '--website-url=+[url]:str:' \
        '--check-rate=+[sec]:n:' \
        '--test-type=+[t]:t:(HTTP HTTPS TCP DNS SMTP SSH PING PUSH)' \
        '--paused=+[v]:v:(true false)' \
        '--contact-groups=+[ids]:str:' \
        '--confirmation=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--port=+[port]:n:' \
        '--trigger-rate=+[N]:n:' \
        '--follow-redirects=+[v]:v:(true false)' \
        '--use-jar=+[v]:v:(true false)' \
        '--enable-ssl-alert=+[v]:v:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'statuscake subcommand' sub ;;
        args)
            case $words[1] in
                uptime|ssl|pagespeed|domain|server|heartbeat|contact-group|maintenance-window|status-page|user|subscription) _arguments '1:op:(list get create update delete pause resume)' '*:id:' ;;
            esac
            ;;
    esac
}

_statuscake-cli "$@"
