#compdef splint

# Zsh completion for Splint (C static analyzer)

_splint() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-I+[add include directory]:include dir:_files -/' \
    '-D+[define preprocessor symbol]:name=value:' \
    '-U+[undefine preprocessor symbol]:name:' \
    '-f+[load options file]:options file:_files' \
    '-nof[do not load default options files]' \
    '-systemdirs[system directories]:directories:_files -/' \
    '-tmpdir[set temporary directory]:directory:_files -/' \
    '-weak[set weak checking mode]' \
    '-standard[set standard checking mode]' \
    '-checks[set checks mode]' \
    '-strict[set strict checking mode]' \
    '+strict[maximum strict checking]' \
    '-booltype+[set boolean type name]:type name:' \
    '-boolfalse+[set boolean false name]:name:' \
    '-booltrue+[set boolean true name]:name:' \
    '-null[enable null checking]' \
    '+null[disable null checking]' \
    '-nullret[check for null return values]' \
    '-nullstate[check null state transitions]' \
    '-nullderef[check null dereferences]' \
    '-mustfreeonly[only report must-free errors]' \
    '-memchecks[enable memory checking]' \
    '-bounds[enable bounds checking]' \
    '-boundsread[check for array bounds on reads]' \
    '-boundswrite[check for array bounds on writes]' \
    '-likelyboundsread[check likely bounds on reads]' \
    '-likelyboundswrite[check likely bounds on writes]' \
    '-fcnuse[check function return values are used]' \
    '-retval[check return values]' \
    '-retvalint[check return values of int functions]' \
    '-retvalother[check return values of other functions]' \
    '-unrecog[report unrecognized identifiers]' \
    '-type[enable type checking]' \
    '-exportlocal[export local variables]' \
    '-declundef[check declared but undefined]' \
    '-specundef[check specified but undefined]' \
    '-shadow[check for variable shadowing]' \
    '-imptype[enable implicit type casts]' \
    '-predboolint[boolean predicates for int types]' \
    '-predboolothers[boolean predicates for other types]' \
    '-predboolptr[boolean predicates for pointer types]' \
    '-switchswitchseg[switch segment fall through]' \
    '-unreachable[check for unreachable code]' \
    '-infloops[check for infinite loops]' \
    '-supcounts[suppress message count]' \
    '-showsummary[show summary of errors]' \
    '-showscan[show file being scanned]' \
    '-showalluses[show all uses of variables]' \
    '-stats[show statistics]' \
    '-timedist[show time distribution]' \
    '-quiet[suppress non-error messages]' \
    '-whichlib[show library being used]' \
    '-help[display help]' \
    '*:source files:_files -g "*.{c,h}"' \
    && ret=0

  return ret
}

_splint "$@"
