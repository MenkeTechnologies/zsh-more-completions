#compdef unmakemap
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss68.html
# SMURF: produce simulated time series data from a SCUBA-2 map.

local ret=1

_arguments -s -S \
  'IN=[input 2D sky image]:ndf:_files' \
  'OUT=[output time series NDFs]:ndf:_files' \
  'REF=[template time series data cubes]:ndf:_files' \
  'QIN=[input 2D sky Q values image]:ndf:_files' \
  'UIN=[input 2D sky U values image]:ndf:_files' \
  'COM=[time series NDFs supplying common-mode]:ndf:_files' \
  'GAI=[2D NDFs specifying bolometer gain]:ndf:_files' \
  'ALIGNSYS=[align template positions in current frame]:flag:(TRUE FALSE)' \
  'AMP2=[amplitude of 2 Hz signal]:amp:' \
  'AMP4=[amplitude of 4 Hz signal]:amp:' \
  'AMP16=[amplitude of 16 Hz signal]:amp:' \
  'ANGROT=[angle to POL2 analyser in degrees]:ang:' \
  'COMVAL=[common mode signal value in pW]:val:' \
  'HARMONIC=[harmonic for Q and U values]:n:' \
  'INSTQ=[instrumental normalised Q per bolometer]:val:' \
  'INSTU=[instrumental normalised U per bolometer]:val:' \
  'INTERP=[resampling method]:method:(Nearest Linear Sinc SincSinc SincCos SincGauss Somb SombCos BlockAve)' \
  'IPFORM=[instrumental polarisation model type]:type:' \
  'JKDATA=[HDS file for Johnstone/Kennedy model]:file:_files' \
  'PARAMS=[interpolation scheme parameters]:params:' \
  'PAOFF=[angle analyser to half-wave plate]:ang:' \
  'PASIGN=[rotation sense of half-wave plate]:flag:(TRUE FALSE)' \
  'PHASE2=[phase offset for 2 Hz signal]:deg:' \
  'PHASE4=[phase offset for 4 Hz signal]:deg:' \
  'PHASE16=[phase offset for 16 Hz signal]:deg:' \
  'PLDATA=[polynomial coefficients for PL model]:coeffs:' \
  'POINTING=[text file with pointing corrections]:file:_files' \
  'PERROR=[std deviation of pointing errors]:val:' \
  'SIGMA=[Gaussian noise standard deviation]:val:' \
  'USEAXIS=[axes from current frame]:axes:' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
