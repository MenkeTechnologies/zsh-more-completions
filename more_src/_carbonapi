#compdef carbonapi
# Documentation: https://github.com/bookingcom/carbonapi
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-config=[config file]:file:_files -g "*.(yaml|yml)"' \
  '-check-config[check config and exit]' \
  '-exact-config[require all config params present]' \
  '-envprefix=[env var prefix]:prefix:' \
  '(- *)-version[show version]'
