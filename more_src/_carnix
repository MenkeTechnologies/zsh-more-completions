#compdef carnix
# Documentation: https://man.archlinux.org/search?q=carnix
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'generate-nix:Emit Nix expressions for Cargo.lock workspace'
      'build:Shell alias for nix-build results'
      'print-src-url:Resolve crate source URL'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
