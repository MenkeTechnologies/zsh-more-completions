#compdef hclq
# Documentation: https://man.archlinux.org/search?q=hclq
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Help for hclq]' \
  '(-i --in)'{-i,--in}'=[Read input file]:file:_files' \
  '(-o --out)'{-o,--out}'=[Write output file]:file:_files' \
  '--version[Print version]' \
  '1:command:(get set)' \
  '*::query or value: _default'
