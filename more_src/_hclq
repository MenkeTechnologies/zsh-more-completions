#compdef hclq
# Documentation: https://github.com/mattolenik/hclq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for hclq]' \
  '(-i --in)'{-i,--in}'=[read input file]:file:_files' \
  '(-o --out)'{-o,--out}'=[write output file]:file:_files' \
  '--raw[output raw strings without quotes]' \
  '--version[print version]' \
  '1:command:(get set help)' \
  '*::query or value: _default'
