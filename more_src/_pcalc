#compdef pcalc
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-b[binary output]' \
  '-o[octal output]' \
  '-d[decimal output]' \
  '-x[hex output]' \
  '-a[show all bases]' \
  '-n[no base prefix]' \
  '-u[unsigned output]' \
  '-8[8-bit width]' \
  '-16[16-bit width]' \
  '-32[32-bit width]' \
  '-64[64-bit width]' \
  '*:expression:' && ret=0
return ret
