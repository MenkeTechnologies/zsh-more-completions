#compdef phenix.geometry_minimization
# Documentation: https://phenix-online.org/documentation/reference/geometry_minimization.html
# Phenix: minimize geometry restraints (regularize) of an atomic model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'file_name=[input PDB model file]:file:_files -g "*.(pdb|cif)"' \
  'output_file_name_prefix=[prefix for output files]:prefix:' \
  'selection=[atom selection: selected atoms move]:selection:' \
  'write_geo_file=[generate geometry output file]:bool:(True False)' \
  'silent=[suppress console output]:bool:(True False)' \
  'directory=[working directory path]:dir:_files -/' \
  'restraints=[custom restraints file]:file:_files -g "*.cif"' \
  'fix_rotamer_outliers=[remove rotamer deviations]:bool:(True False)' \
  'secondary_structure.enabled=[secondary structure restraints]:bool:(True False)' \
  'ramachandran_plot_restraints.enabled=[Ramachandran restraints]:bool:(True False)' \
  'minimization.max_iterations=[maximum optimization steps]:n:' \
  'minimization.macro_cycles=[number of refinement passes]:n:' \
  'minimization.riding_h=[use riding model for hydrogens]:bool:(True False)' \
  '*:model file:_files -g "*.(pdb|cif)"' && ret=0

return ret
