#compdef seqerakit
# Documentation: https://github.com/seqeralabs/seqera-kit
# Declarative automation of Seqera Platform resources via YAML and the tw CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[list available commands and options]' \
  '(-v --version)'{-v,--version}'[show the seqerakit version]' \
  '--info[show installation and configuration info]' \
  '--dryrun[print the tw commands that would be executed]' \
  '(-j --json)'{-j,--json}'[output the results as JSON to stdout]' \
  '--delete[recursively delete resources in the YAML file]' \
  '--cli=[pass tw-specific CLI options]:options' \
  '--targets=[resource types to create]:targets' \
  '--target=[target specific resources by name within a type]:target' \
  '--env-file=[provide environment variables from a file]:file:_files' \
  '*:YAML file:_files -g "*.(yml|yaml)"' && ret=0

return ret
