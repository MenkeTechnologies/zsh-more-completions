#compdef vttablet
# _vttablet — Vitess per-shard MySQL agent (vitessio/vitess)
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vttablet/cli/cli.go + go/vt/servenv/servenv.go on tip.

_vttablet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--tablet-path=[tablet alias (e.g. cell-100)]:alias:' \
        '--tablet-config=[tablet YAML config file]:file:_files' \
        '--table-acl-config=[table ACL config file]:file:_files' \
        '--enforce-tableacl-config[fail to start without a valid table ACL config]' \
        '--table-acl-config-reload-interval=[table ACL config reload interval]:dur:' \
        '--port=[HTTP server port]:port:' \
        '--bind-address=[server bind address]:ip:' \
        '--grpc-port=[gRPC server port]:port:' \
        '--grpc-bind-address=[gRPC server bind address]:ip:' \
        '--pid-file=[pid file path]:file:_files' \
        '--lameduck-period=[graceful shutdown lameduck period]:dur:' \
        '--service-map=[enabled gRPC services (comma-sep)]:list:' \
        '--topo-implementation=[topo backend]:impl:(etcd2 zk2 consul)' \
        '--topo-global-server-address=[topo global server endpoint]:addr:' \
        '--topo-global-root=[topo global root path]:path:' \
        '--backup-storage-implementation=[backup storage backend]:impl:(file s3 gcs azblob ceph)' \
        '--file-backup-storage-root=[file backup storage root]:dir:_files -/' \
        '--logtostderr[log to stderr instead of files]' \
        '--alsologtostderr[also log to stderr]' \
        '--log_dir=[klog log directory]:dir:_files -/' \
        '--stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)' \
        '-v[klog verbosity level]:n:' \
        '--vmodule=[per-module verbosity (pattern=N,...)]:spec:'
}

_vttablet "$@"
