#compdef milvus
# Documentation: https://man.archlinux.org/search?q=milvus
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'connect:connect to Milvus server'
      'create:create resources'
      'delete:delete resources'
      'describe:describe resource details'
      'exit:exit the CLI'
      'help:show help'
      'list:list resources'
      'load:load a collection'
      'query:query data'
      'release:release a collection'
      'search:search vectors'
      'show:show information'
      'version:show version'
      'import:import data'
    )
    _describe -t commands 'milvus command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      connect)
        _arguments -s -S \
          '--host[server host]:host:_hosts' \
          '--port[server port]:port:' \
          '--alias[connection alias]:alias:' \
          '--secure[use TLS connection]' && ret=0
        ;;
      create)
        _arguments \
          '1:resource type:->create_type' \
          '*::create args:' && ret=0
        if [[ $state == create_type ]]; then
          local -a create_types=(
            'collection:create a collection'
            'partition:create a partition'
            'index:create an index'
            'user:create a user'
            'role:create a role'
            'alias:create an alias'
          )
          _describe -t types 'resource type' create_types && ret=0
        fi
        ;;
      delete)
        _arguments \
          '1:resource type:((collection partition index user role alias))' \
          '*:name:' && ret=0
        ;;
      describe)
        _arguments \
          '1:resource type:((collection partition index))' \
          '*:name:' && ret=0
        ;;
      list)
        _arguments \
          '1:resource type:((collections partitions indexes users roles))' && ret=0
        ;;
      load|release)
        _arguments '*:collection name:' && ret=0
        ;;
      query|search)
        _arguments '*:collection name:' && ret=0
        ;;
      import)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
