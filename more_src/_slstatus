#compdef slstatus
# _slstatus — suckless slstatus status monitor (C); writes status info to X root window or stdout
# upstream: https://tools.suckless.org/slstatus

_slstatus() {
    _arguments \
        '-1[run once and exit]' \
        '-s[write to stdout instead of root]' \
        '-v[show version]'
}

_slstatus "$@"
