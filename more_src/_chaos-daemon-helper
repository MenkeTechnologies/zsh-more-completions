#compdef chaos-daemon-helper cdh
# _chaos-daemon-helper — helper to run logic inside other namespaces/cgroups (chaos-mesh/chaos-mesh)
# upstream: https://github.com/chaos-mesh/chaos-mesh
# Subcommands from cmd/chaos-daemon-helper/main.go (cobra).

_chaos-daemon-helper() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:command:(normalize-volume-name)'
}

_chaos-daemon-helper "$@"
