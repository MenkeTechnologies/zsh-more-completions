#compdef clusternet-hub
# _clusternet-hub — Clusternet parent-cluster hub (clusternet/clusternet)
# upstream: https://github.com/clusternet/clusternet
# Flags from pkg/hub/options/options.go (pflag).

_clusternet-hub() {
    _arguments \
        '--peer-port=[port for HTTPS peer communication]:port:' \
        '--peer-token=[peer authentication token]:token:' \
        '--enable-tunnel-logging[enable tunnel logging]' \
        '--reserved-namespace=[default namespace for Manifests]:ns:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[Kubernetes API server address]:url:_urls'
}

_clusternet-hub "$@"
