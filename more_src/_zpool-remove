#compdef zpool-remove
# _zpool-remove — OpenZFS zpool remove (remove a top-level vdev (mirror/special/cache/log/spare) from a pool by relocating data off it; -n dry-run, -p partial only, -s stop in-progress removal, -w wait until done; positional pool followed by devices to remove)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_remove) on tip.

_zpool-remove() {
    _arguments \
        '-n[dry run]' \
        '-p[partial]' \
        '-s[stop in-progress removal]' \
        '-w[wait until done]' \
        '1:pool:' \
        '*:device:'
}

_zpool-remove "$@"
