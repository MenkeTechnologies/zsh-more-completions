#compdef genion gmx-genion
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-genion.html
# Randomly replace solvent molecules with monoatomic ions

local ret=1

_arguments -s -S \
  '-s+[run input file]:tpr file:_files -g "*.tpr"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-p+[topology file]:topology file:_files -g "*.top"' \
  '-o+[output structure file]:structure file:_files -g "*.(gro|g96|pdb)"' \
  '-np+[number of positive ions to add]:number:' \
  '-pname+[positive ion species name]:name:' \
  '-pq+[charge of positive ions]:charge:' \
  '-nn+[number of negative ions to add]:number:' \
  '-nname+[negative ion species name]:name:' \
  '-nq+[charge of negative ions]:charge:' \
  '-rmin+[minimum distance between ions and solute]:value:' \
  '-seed+[random seed (0 auto)]:seed:' \
  '-conc+[target salt concentration mol/liter]:value:' \
  '-neutral[add ions to achieve charge neutrality]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
