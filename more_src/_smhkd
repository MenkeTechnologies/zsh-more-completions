_smhkd_command() {
    local -a _smhkd_cmds
    _smhkd_cmds=(
        'list:List available MIDI controllers'
        'run:Listen to MIDI events and run commands'
    )

    if ((CURRENT == 1)); then
        _describe -t commands 'smhkd commands' _smhkd_cmds
    fi
}

_arguments \
    {-h,--help}'[Show help text]' \
    '--version[Show version]' \
    '*::smhkd commands:_smhkd_command'
