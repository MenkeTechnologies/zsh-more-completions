#compdef pluginkit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-m[match plugins]' \
  '-A[also include disabled plugins]' \
  '-D[show plugin discovery info]' \
  '-v[verbose]' \
  '-p+[protocol]:protocol:' \
  '-i+[identifier]:identifier:' \
  '-a[add plugin]' \
  '-r[remove plugin]' \
  '-e+[change user election]:election:(use enable disable)' \
  '*:plugin path / key[=value]:_files -/' && ret=0

return ret
