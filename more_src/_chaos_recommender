#compdef chaos_recommender.py chaos-recommender
# _chaos_recommender — Krkn chaos scenario recommender (krkn-chaos/krkn)
# upstream: https://github.com/krkn-chaos/krkn
# Flags from utils/chaos_recommender/chaos_recommender.py (argparse).

_chaos_recommender.py() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config-file)'{-c+,--config-file=}'[config file path]:file:_files -g "*.yaml"' \
        '(-o --options)'{-o,--options}'[evaluate command-line options]' \
        '(-n --namespaces)'{-n+,--namespaces=}'[namespaces (space-separated)]:namespaces:' \
        '(-p --prometheus-endpoint)'{-p+,--prometheus-endpoint=}'[Prometheus endpoint]:url:_urls' \
        '(-k --kubeconfig)'{-k+,--kubeconfig=}'[kubeconfig path]:file:_files' \
        '(-t --token)'{-t+,--token=}'[bearer token]:token:' \
        '(-s --scrape-duration)'{-s+,--scrape-duration=}'[Prometheus scrape duration (e.g. 10m)]:duration:' \
        '(-L --log-level)'{-L+,--log-level=}'[log level]:level:(DEBUG INFO WARNING ERROR)' \
        '(-J --json-output-file)'{-J+,--json-output-file=}'[JSON output file]:file:_files' \
        '(-M --MEM)'{-M+,--MEM=}'[memory scenarios]:scenarios:' \
        '(-C --CPU)'{-C+,--CPU=}'[CPU scenarios]:scenarios:' \
        '(-N --NETWORK)'{-N+,--NETWORK=}'[network scenarios]:scenarios:' \
        '(-G --GENERIC)'{-G+,--GENERIC=}'[generic scenarios]:scenarios:' \
        '--threshold=[threshold]:value:' \
        '--cpu-threshold=[CPU threshold]:value:' \
        '--mem-threshold=[memory threshold]:value:'
}

_chaos_recommender.py "$@"
