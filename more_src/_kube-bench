#compdef kube-bench

# Zsh completion for kube-bench - Kubernetes CIS benchmark tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_kube_bench_run_options=(
  '--targets=[comma-separated list of targets to check]:targets:_values -s , targets master node etcd policies controlplane managedservices'
  '--benchmark=[CIS benchmark version]:version:'
  '--version=[Kubernetes version]:version:'
  '--check=[comma-separated list of checks to run]:checks:'
  '--group=[comma-separated list of groups to run]:groups:'
  '--skip=[comma-separated list of checks to skip]:checks:'
  '(-D --config-dir)'{-D,--config-dir}'=[configuration directory]:config directory:_directories'
  '--json[output results as JSON]'
  '--junit[output results as JUnit XML]'
  '--asff[output results as AWS Security Finding Format]'
  '--noremediations[do not print remediations]'
  '--noresults[do not print results]'
  '--nosummary[do not print summary]'
  '--nototals[do not print totals]'
  '--include-test-output[include test command output in results]'
  '--outputfile=[write output to file]:output file:_files'
  '--no-exit-code[do not set exit code to non-zero on failure]'
  '(-v --verbosity)'{-v,--verbosity}'=[log verbosity level]:level:'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'run:Run CIS benchmark checks'
      'master:Run Kubernetes master node checks'
      'node:Run Kubernetes worker node checks'
      'version:Display version information'
      'help:Help about any command'
    )
    _describe -t commands 'kube-bench commands' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      run|master|node)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' \
          ${_kube_bench_run_options[@]} && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
