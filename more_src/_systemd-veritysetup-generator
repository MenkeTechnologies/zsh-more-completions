#compdef systemd-veritysetup-generator
# _systemd-veritysetup-generator (systemd unit generator that synthesises systemd-veritysetup@.service instances from /etc/veritytab; generators are invoked by systemd with three positional dirs (normal_dir, early_dir, late_dir) and not by users directly)
# upstream: https://github.com/systemd/systemd (src/veritysetup)
# Argument shape from systemd src/veritysetup/veritysetup-generator.c on tip.

_systemd-veritysetup-generator() {
    _arguments \
        '1:normal dir:_files -/' \
        '2:early dir:_files -/' \
        '3:late dir:_files -/'
}

_systemd-veritysetup-generator "$@"
