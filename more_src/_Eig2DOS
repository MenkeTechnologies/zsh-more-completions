#compdef Eig2DOS
# Documentation: https://docs.siesta-project.org/projects/siesta/en/latest/tutorials/basic/analysis-tools/index.html
# SIESTA estimate density of states from a .EIG file

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-f[shift energies so Fermi level is at 0 eV]' \
  '-s[Gaussian broadening per state in eV (default 0.2)]:broadening:' \
  '-n[number of energy points (default 200)]:npoints:' \
  '-e[minimum energy of the window (Emin)]:emin:' \
  '-E[maximum energy of the window (Emax)]:emax:' \
  '-m[minimum energy of the window]:emin:' \
  '-M[maximum energy of the window]:emax:' \
  '-k[k-point weights file (.KP)]:kp file:_files' \
  '*:EIG file:_files' && ret=0

return ret
