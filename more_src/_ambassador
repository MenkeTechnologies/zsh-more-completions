#compdef ambassador
# _ambassador — Ambassador Labs Edge Stack / Emissary install/control binary (Ambassador Labs, Go); spf13/cobra
# upstream: https://github.com/emissary-ingress/emissary

_ambassador() {
    local -a sub=(
        'install:install Ambassador Edge Stack'
        'uninstall:uninstall Ambassador'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
        'edge-stack:edge-stack commands'
        'auth:authentication helpers'
        'license:license commands'
        'login:login to Ambassador Cloud'
        'logout:logout'
        'connect:connect to Ambassador Cloud'
        'tunnel:tunnel traffic'
        'sync:sync config to cloud'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ambassador subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--quick-start[quick start]' \
                    '--license=+[license key]:str:' \
                    '--namespace=+[namespace]:str:' \
                    '--version=+[version]:str:' \
                    '--registry=+[image registry]:str:' \
                    '--values=+[values yaml]:file:_files' \
                    '--no-license-prompt[no license prompt]' ;;
                edge-stack) _arguments \
                    '1:cmd:(dashboard activate)' \
                    '*:arg:' ;;
                license) _arguments \
                    '1:cmd:(activate show update)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ambassador "$@"
