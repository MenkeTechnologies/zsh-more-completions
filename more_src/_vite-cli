#compdef vite
# _vite-cli — Vite next-gen frontend tooling CLI (Evan You, Vue team); ESM dev server + Rollup production build
# upstream: https://github.com/vitejs/vite

_vite-cli() {
    local -a sub=(
        'dev:start dev server (default)'
        'serve:alias for dev'
        'build:build for production'
        'optimize:pre-bundle deps'
        'preview:preview production build'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files -g "vite.config*"' \
        '(-d --debug)'{-d,--debug}'+[debug log]:filter:' \
        '(-l --logLevel)'{-l,--logLevel}'+[log level]:level:(silent error warn info)' \
        '(-f --filter)'{-f,--filter}'+[filter debug logs]:filter:' \
        '(-m --mode)'{-m,--mode}'+[mode]:mode:(development production test)' \
        '--clearScreen[clear screen]' \
        '--force[force re-bundle]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vite subcommand' sub ;;
        args)
            case $words[1] in
                dev|serve|preview) _arguments \
                    '--host+[host]:host:_hosts' \
                    '--port+[port]:port:' \
                    '--strictPort[exit if port busy]' \
                    '--https[serve over HTTPS]' \
                    '--open[open browser]' \
                    '--cors[enable CORS]' ;;
                build) _arguments \
                    '--target+[browser target]:target:' \
                    '--outDir+[output dir]:dir:_files -/' \
                    '--assetsDir+[assets dir]:dir:_files -/' \
                    '--assetsInlineLimit+[inline limit (bytes)]:n:' \
                    '--ssr+[SSR entry]:file:_files' \
                    '--sourcemap[generate sourcemap]' \
                    '--minify+[minifier]:minifier:(terser esbuild false)' \
                    '--manifest[emit manifest]' \
                    '--ssrManifest[emit SSR manifest]' \
                    '--emptyOutDir[empty output dir]' \
                    '(-w --watch)'{-w,--watch}'[watch + rebuild]' ;;
                optimize) _arguments '--force[force re-optimize]' ;;
            esac
            ;;
    esac
}

_vite-cli "$@"
