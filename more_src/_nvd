#compdef nvd

# Zsh completion for nvd (Nix/NixOS package version diff tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'diff:compare two Nix profiles or closures'
    )
    _describe -t commands 'nvd command' commands && ret=0
    ;;
  (args)
    _arguments \
      '1:old closure:_files' \
      '2:new closure:_files' && ret=0
    ;;
esac

return ret
