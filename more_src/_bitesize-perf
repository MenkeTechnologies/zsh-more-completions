#compdef bitesize-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/bitesize.8
# show disk I/O size as a histogram (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-b+[histogram buckets in Kbytes]:buckets' \
  '*:seconds:' && ret=0

return ret
