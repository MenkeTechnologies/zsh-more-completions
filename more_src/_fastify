#compdef fastify

# Zsh completion for Fastify CLI

_fastify() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'start:start a Fastify application'
    'eject:generate a Fastify project scaffolding'
    'generate:generate a new Fastify project'
    'print-routes:print all registered routes'
    'print-plugins:print all registered plugins'
    'version:display Fastify version'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'fastify command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        start)
          _arguments -s -S \
            '(-p --port)'{-p,--port}'[port to listen on]:port:' \
            '(-a --address)'{-a,--address}'[address to listen on]:address:_hosts' \
            '(-s --socket)'{-s,--socket}'[socket path]:socket path:_files' \
            '(-l --log-level)'{-l,--log-level}'[log level]:level:(fatal error warn info debug trace silent)' \
            '(-L --log-file)'{-L,--log-file}'[log file]:log file:_files' \
            '(-P --pretty-logs)'{-P,--pretty-logs}'[pretty print logs]' \
            '(-o --options)'{-o,--options}'[use custom options]' \
            '(-w --watch)'{-w,--watch}'[watch for changes]' \
            '--ignore-watch=[patterns to ignore in watch mode]:pattern:' \
            '--verbose-watch[verbose watch mode]' \
            '(-d --debug)'{-d,--debug}'[start in debug mode]' \
            '--debug-host=[debug host]:host:' \
            '--debug-port=[debug port]:port:' \
            '(-T --plugin-timeout)'{-T,--plugin-timeout}'[plugin timeout in ms]:ms:' \
            '--body-limit=[max request body size]:bytes:' \
            '--require=[require module]:module:' \
            '--import=[import module]:module:' \
            '1:app file:_files -g "*.{js,mjs,cjs,ts}"' \
            && ret=0
          ;;
        generate)
          _arguments -s -S \
            '--lang=[project language]:language:(js ts)' \
            '--esm[use ESM]' \
            '--standardlint[add standard lint]' \
            '1:directory:_files -/' \
            && ret=0
          ;;
        print-routes)
          _arguments -s -S \
            '--common-prefix[group by common prefix]' \
            '--include-hooks[include hooks]' \
            '--include-meta=[include meta keys]:keys:' \
            '1:app file:_files -g "*.{js,mjs,cjs,ts}"' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_fastify "$@"
