#compdef kafka-metadata-shell
# Documentation: https://kafka.apache.org/documentation/ (kafka-metadata-shell.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    {--snapshot,-s}'[The metadata snapshot file to read]:file:_files'
    '*:command:'
)

_arguments -s -S $arguments
