#compdef obspy-mseed-recordanalyzer
# ObsPy: analyze and print MiniSEED record headers

local ret=1

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version]' \
  '-n+[show info about N-th record (default 0)]:record number' \
  '(-a --all)'{-a,--all}'[show info for all records]' \
  '(-f --fast)'{-f,--fast}'[jump to specified record assuming equal record sizes]' \
  '1:filename:_files' && ret=0

return ret
