#compdef jpegtran
# Documentation: https://manpages.debian.org/jpegtran.1
# Source: libjpeg / mozjpeg — lossless JPEG transcoder / transformer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-optimize[optimize entropy-encoding parameters]' \
    '-progressive[create progressive JPEG]' \
    '-restart[restart marker every N MCU rows (Nb for blocks)]:N:' \
    '-arithmetic[use arithmetic coding]' \
    '-scans[scan script file]:file:_files' \
    '-flip[mirror image]:axis:(horizontal vertical)' \
    '-rotate[rotate clockwise]:degrees:(90 180 270)' \
    '-transpose[transpose across UL-LR axis]' \
    '-transverse[transverse transpose across UR-LL axis]' \
    '-trim[drop non-transformable edge blocks]' \
    '-perfect[fail if transformation cannot be perfect]' \
    '-crop[crop to WxH+X+Y rectangle]:geometry:' \
    '-wipe[gray out WxH+X+Y rectangle]:geometry:' \
    '-drop[drop another image at +X+Y from file]:+X+Y file:' \
    '-grayscale[force grayscale output]' \
    '-copy[marker copy policy]:policy:(none comments icc all)' \
    '-icc[embed ICC profile from file]:file:_files' \
    '-maxmemory[memory limit (KB)]:n:' \
    '-maxscans[abort if input > N scans]:n:' \
    '-outfile[output file]:file:_files' \
    '-report[report transformation progress]' \
    '-strict[treat warnings as fatal]' \
    '-verbose[debug printout]' \
    '-debug[debug printout (alias)]' \
    '(- *)-version[print version]' \
    '*:input .jpg:_files -g "*.(jpg|jpeg|jpe|jif|jfif|jfi)"' \
    && ret=0

return ret
