#compdef arm-none-eabi-nm
# _arm-none-eabi-nm — Arm Limited arm-none-eabi-nm CLI for the bare-metal ARM cross-nm symbol-table dumper listing symbols in ELF object archive printing demangled type defined undefined size value sorting (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-nm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-A[print file name]' \
        '--print-file-name[print file name]' \
        '-a[show all symbols]' \
        '--debug-syms[show all symbols]' \
        '-B[BSD format]' \
        '--format=+[fmt]:f:(bsd sysv posix just-symbols)' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '--demangle=+[style]:s:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '-D[dynamic symbols]' \
        '--dynamic[dynamic symbols]' \
        '-f+[format]:f:(bsd sysv posix just-symbols)' \
        '-g[external only]' \
        '--extern-only[external only]' \
        '-l[line numbers]' \
        '--line-numbers[line numbers]' \
        '-n[numeric sort]' \
        '--numeric-sort[numeric sort]' \
        '-o[print file name]' \
        '-p[no sort]' \
        '--no-sort[no sort]' \
        '-P[portable output]' \
        '--portability[portable output]' \
        '-r[reverse sort]' \
        '--reverse-sort[reverse sort]' \
        '-S[print size]' \
        '--print-size[print size]' \
        '-s[print archive index]' \
        '--print-armap[print archive index]' \
        '-t+[radix]:r:(d o x)' \
        '--radix=+[radix]:r:(d o x)' \
        '-u[only undefined]' \
        '--undefined-only[only undefined]' \
        '-X+[bit size]:n:(32 64)' \
        '*:object archive ELF:_files -g "*.o *.elf *.axf *.so *.a *.ko"'
}

_arm-none-eabi-nm "$@"
