#compdef balbes
# Documentation: https://www2.mrc-lmb.cam.ac.uk/groups/murshudov/content/balbes/documentation_fs/manual_115.html
# CCP4 BALBES - automated molecular replacement pipeline

local ret=1

_arguments -s -S \
  '-f[input crystallographic data file (MTZ/CIF)]:file:_files' \
  '-s[input protein sequence file (FASTA)]:file:_files' \
  '-o[root directory for BALBES job output]:dir:_files -/' \
  '-m[input model file (PDB), disables homology search]:file:_files' \
  '-l[user database for homologous model search]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
