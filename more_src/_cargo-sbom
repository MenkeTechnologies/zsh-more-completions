#compdef cargo-sbom
# Documentation: https://github.com/psastras/sbom-rs
# Source: https://github.com/psastras/sbom-rs/blob/master/cargo-sbom/src/main.rs
# Reference accessed: 2026-06-01
# Cargo subcommand; invoke as `cargo sbom` or `cargo-sbom`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--cargo-package=[specific workspace package to generate SBOM for]:pkg:_default' \
    '--output-format=[SBOM output format]:format:(spdx_json_2_3 cyclone_dx_json_1_4 cyclone_dx_json_1_5 cyclone_dx_json_1_6)' \
    '--project-directory=[directory to the Cargo project (default .)]:dir:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
