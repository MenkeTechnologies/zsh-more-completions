#compdef antechamber-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools antechamber: file conversion, charge and atom type assignment

local ret=1

_arguments -s -S \
  '-help[print instructions]' \
  '-i[input file name]:file:_files' \
  '-fi[input file format]:format:(ac mol2 pdb mpdb prepi prepc gzmat gcrt mopint mopcrt gout mopout alc csd mdl hin rst22 jzmat gesp charmm)' \
  '-o[output file name]:file:_files' \
  '-fo[output file format]:format:(ac mol2 pdb mpdb prepi prepc gzmat gcrt mopint mopcrt mopout gamess alc csd mdl hin rst22 jzmat gesp charmm)' \
  '-c[charge method]:method:(resp bcc cm1 cm2 esp mul rc wc gas)' \
  '-cf[charge file name]:file:_files' \
  '-nc[net molecular charge (int)]:charge:' \
  '-a[additional file name]:file:_files' \
  '-fa[additional file format]:format:(ac mol2 pdb mpdb prepi prepc)' \
  '-ao[additional file operation]:op:(crd crg radius name type bond)' \
  '-m[multiplicity (2S+1)]:mult:' \
  '-rn[residue name]:name:' \
  '-rf[residue topology file name]:file:_files' \
  '-ch[check file name for gaussian]:name:' \
  '-ek[mopac or sqm keyword in quotes]:keyword:' \
  '-gk[gaussian job keyword in quotes]:keyword:' \
  '-gopt[gaussian optimization keyword in quotes]:keyword:' \
  '-gsp[gaussian single point keyword in quotes]:keyword:' \
  '-gm[gaussian memory keyword in quotes]:keyword:' \
  '-gn[gaussian nproc keyword in quotes]:keyword:' \
  '-gdsk[gaussian maxdisk keyword in quotes]:keyword:' \
  '-gv[generate gesp file]:flag:(0 1)' \
  '-ge[gaussian esp file]:file:_files' \
  '-tor[torsional angle list in quotes]:list:' \
  '-df[am1-bcc precharge flag]:flag:(0 2)' \
  '-at[atom type]:type:(gaff gaff2 amber bcc abcg2 sybyl)' \
  '-du[fix duplicate atom names]:yn:(y n)' \
  '-bk[component/block Id for ccif]:id:' \
  '-an[adjust atom names]:yn:(y n)' \
  '-j[atom and bond type prediction index]:index:(0 1 2 3 4 5)' \
  '-s[status information]:level:(0 1 2)' \
  '-eq[equalizing atomic charge]:level:(0 1 2)' \
  '-pf[remove intermediate files]:yn:(y n)' \
  '-pl[maximum path length]:length:' \
  '-seq[atomic sequence order changable]:yn:(y n)' \
  '-dr[acdoctor mode]:yn:(y n)' \
  '*:file:_files' && ret=0

return ret
