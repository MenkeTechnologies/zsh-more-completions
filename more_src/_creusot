#compdef cargo-creusot creusot
# _creusot — Creusot: deductive verifier for Rust via Why3 (creusot-rs/creusot)
# upstream: https://github.com/creusot-rs/creusot
# Subcommands from cargo-creusot/src/main.rs.

_creusot() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-p --package)'{-p+,--package=}'[package to verify (repeatable)]:package:' \
        '--no-check-version[skip the creusot-contracts version check]' \
        '--only=[run only one stage]:stage:(coma prove)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_creusot_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new|init)
                    _arguments \
                        '1:path:_files -/' && ret=0 ;;
                why3|why3-conf)
                    _arguments \
                        '*:why3-find argument:' && ret=0 ;;
                config)
                    _arguments \
                        '--update[update ~/.cargo/config.toml instead of just checking]' \
                        '--creusot-path=[path to local creusot-std]:path:_files -/' && ret=0 ;;
                clean|doc|version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_creusot_commands] )) ||
_creusot_commands() {
    local -a commands
    commands=(
        'new:create a new Creusot project at the given path'
        'init:initialize Creusot in the current directory'
        'clean:remove generated proof artifacts'
        'doc:build documentation (rustdoc with Creusot enabled)'
        'why3:invoke why3find on the proof tree'
        'why3-conf:write or check the why3 configuration'
        'config:install or check ~/.cargo/config.toml for creusot-std patch'
        'version:print the Creusot version'
    )
    _describe -t commands 'cargo creusot command' commands
}

_creusot "$@"
