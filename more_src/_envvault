(( $+functions[_envvault_commands] )) ||
_envvault_commands() {
    local commands; commands=(
'init:Initialize a new vault (auto-imports .env)' \
'set:Set a secret (add or update)' \
'get:Get a secret'\''s value' \
'list:List all secrets' \
'delete:Delete a secret' \
'run:Run a command with secrets injected' \
'rotate-key:Change the vault'\''s master password' \
'export:Export secrets to a file or stdout' \
'import:Import secrets from a file' \
'auth:Manage authentication methods (keyring, keyfile)' \
'env:Manage environments (list, clone, delete)' \
'diff:Compare secrets between two environments' \
'edit:Open secrets in an editor (decrypts to temp file, re-encrypts on save)' \
'version:Show version and check for updates' \
'update:Update envvault to the latest version' \
'completions:Generate shell completion scripts' \
'scan:Scan files for leaked secrets (API keys, tokens, passwords)' \
'search:Search secrets by name pattern (supports * and ? wildcards)' \
'audit:View, export, or purge the audit log' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'envvault commands' commands "$@"
}
(( $+functions[_envvault__audit_commands] )) ||
_envvault__audit_commands() {
    local commands; commands=(
'export:Export audit log to JSON or CSV' \
'purge:Delete old audit entries' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'envvault audit commands' commands "$@"
}
(( $+functions[_envvault__audit__export_commands] )) ||
_envvault__audit__export_commands() {
    local commands; commands=()
    _describe -t commands 'envvault audit export commands' commands "$@"
}
(( $+functions[_envvault__audit__help_commands] )) ||
_envvault__audit__help_commands() {
