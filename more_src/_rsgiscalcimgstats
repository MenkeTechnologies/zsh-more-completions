#compdef rsgiscalcimgstats
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgiscalcimgstats RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --image)'{-i,--image}'[The image on which stats and pyramids are to calculated.]:value:_files' \
  '(-t --thematic)'{-t,--thematic}'[The image is thermatic, calc stats and pyramids accordingly.]' \
  '(-p --nopyramids)'{-p,--nopyramids}'[Do not calculate image pyramids.]' \
  '(-n --nodata)'{-n,--nodata}'[No data value for the input image for when calculating stats]:value:_files' \
  '(-c --noclrtab)'{-c,--noclrtab}'[Do not add a colour table (only for thematic images)]' \
  '*:file:_files' && ret=0

return ret
