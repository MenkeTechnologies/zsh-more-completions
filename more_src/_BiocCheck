#compdef BiocCheck BiocCheckGitClone
# _BiocCheck — Bioconductor BiocCheck R command line and Rscript wrapper for additional Bioconductor package checks (Bioconductor team, R/Shell); custom argparse
# upstream: https://github.com/Bioconductor/BiocCheck

_BiocCheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--no-check-vignettes[no check vignettes]' \
        '--no-check-version-num[no check version number]' \
        '--no-check-rd[no check Rd]' \
        '--no-check-rd-data[no check Rd data]' \
        '--no-check-namespace[no check namespace]' \
        '--no-check-deprecated[no check deprecated]' \
        '--no-check-system-files[no check system files]' \
        '--no-check-news[no check NEWS]' \
        '--no-check-formatting[no check formatting]' \
        '--no-check-coding-practices[no check coding practices]' \
        '--no-check-function-len[no check function length]' \
        '--no-check-indentation[no check indentation]' \
        '--no-check-line-length[no check line length]' \
        '--no-check-license[no check license]' \
        '--no-check-bioc-views[no check biocViews]' \
        '--no-check-bbs[no check bbs]' \
        '--no-check-internet-resources[no check internet]' \
        '--no-check-cran-dependencies[no check cran dependencies]' \
        '--no-check-bioconductor-dependencies[no check bioc dependencies]' \
        '--build-output-file=+[file]:file:_files' \
        '--new-package[treat as new package]' \
        '--no-format-info[no format info]' \
        '--no-output-summary[no output summary]' \
        '-d+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '*:package source:_files -g "*.tar.gz"'
}

_BiocCheck "$@"
