#compdef ucspilogd
# _ucspilogd — s6 daemontools-extras ucspilogd (UCSPI-aware logger filter; read syslog-ish input and prepend select UCSPI environment variables ($TCPREMOTEIP, $TCPLOCALPORT, ...) to each line for downstream s6-log/multilog)
# upstream: https://github.com/skarnet/s6
# Flags from src/daemontools-extras/ucspilogd.c on tip.

_ucspilogd() {
    _arguments \
        '-D+[default value for missing UCSPI vars]:default:' \
        '*:var:'
}

_ucspilogd "$@"
