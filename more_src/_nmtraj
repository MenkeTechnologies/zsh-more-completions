#compdef nmtraj gmx-nmtraj
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-nmtraj.html
# gmx nmtraj: generate a virtual oscillating trajectory from an eigenvector

local ret=1

_arguments -s \
  '-s[structure+mass(db) file]:file:_files' \
  '-v[full precision trajectory]:file:_files' \
  '-o[trajectory output]:file:_files' \
  '-eignr[string of eigenvectors to use]:string:' \
  '-phases[string of phases]:string:' \
  '-temp[temperature in Kelvin]:real:' \
  '-amplitude[amplitude for modes with eigenvalue<=0]:real:' \
  '-nframes[number of frames to generate]:int:' && ret=0

return ret
