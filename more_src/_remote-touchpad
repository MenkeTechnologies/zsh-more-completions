#compdef remote-touchpad
# ============================================================================
# remote-touchpad - turn your smartphone into a mouse + keyboard (Go, GPL-3.0)
#
# Author : Unrud (unrud@outlook.com)
# Upstream: https://github.com/Unrud/remote-touchpad
#
# remote-touchpad is the inverse of weylus: instead of streaming a
# desktop screen to a tablet, it runs an HTTP + WebSocket server on
# the desktop and accepts pointer + keyboard events back from a
# browser on a smartphone, turning the phone into a wireless touchpad
# + soft keyboard. Connection bootstrap is via a QR code rendered to
# the terminal at startup encoding the server URL + shared secret;
# the user scans the QR with their phone camera and the page joins
# the session.
#
# The QR-code emission lane is built on `github.com/skip2/go-qrcode`
# (declared verbatim at go.mod HEAD), the canonical Go QR code
# encoder by Tom Harwood (skip2, github.com/skip2/go-qrcode, ~8000
# stars). Verbatim from upstream `terminal/qr.go`:
#
#     package terminal
#     import qrcode "github.com/skip2/go-qrcode"
#     func GenerateQRCode(message string, colorize bool) (string, error) {
#         q, err := qrcode.New(message, qrcode.Medium)
#         if err != nil { return "", err }
#         return qrCodeToString(q.Bitmap(), colorize), nil
#     }
#
# skip2/go-qrcode implements ISO/IEC 18004 QR Model 2 with the same
# Reed-Solomon error-correction-over-GF(256) backbone as the Rust
# and JS canonical libraries, the four EC levels (`qrcode.Low`,
# `qrcode.Medium`, `qrcode.High`, `qrcode.Highest`), eight mask
# patterns, alignment + timing patterns, version selection (1 - 40),
# and the four encoding modes (numeric, alphanumeric, byte, kanji).
# The library is a hard-fork descendant of the original Tom Harwood
# QR generator from the early-2010s era and is the de-facto pick
# whenever a pure-Go QR encoder is needed (no C/FFI deps).
#
# ----------------------------------------------------------------------------
# AXIS 199 :: QR CODE GENERATION (ISO/IEC 18004 - QR Model 2)
# Round 1296 :: Go slot 2 of 4 :: continues Axis 199
#
# Cross-language canonical library family for this axis:
#   Rust    : kennytm/qrcode-rust       [R1295 _weylus]
#   Go      : skip2/go-qrcode           [R1296 THIS FILE]
#   TS/Node : soldair/node-qrcode       [R1297 closing]
#
# remote-touchpad pairs cleanly with weylus (Axis 199 opener): both
# tools generate a connection-bootstrap QR at server startup so the
# user-facing device (tablet for weylus, phone for remote-touchpad)
# can join with one camera scan rather than typing in a URL. This is
# the dominant "QR for pairing" usage pattern - same shape across
# WireGuard provisioning, Tailscale auth, OTP enrollment, and
# end-to-end pair-and-trust flows.
# ============================================================================

_remote-touchpad() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--version[print version and exit]' \
        '--bind[bind server to [HOSTNAME]:PORT (default :0 = ephemeral)]:bind addr:' \
        '--secret[shared secret token for client authentication]:secret:' \
        '--cert[TLS certificate file (PEM)]:cert file:_files -g "*.(crt|pem)"' \
        '--key[TLS private key file (PEM)]:key file:_files -g "*.(key|pem)"' \
        '--update-rate[updates per second (default 30)]:rate:' \
        '--move-speed[touch move speed multiplier (default 1)]:multiplier:' \
        '--scroll-speed[touch scroll speed multiplier (default 1)]:multiplier:' \
        '--mouse-move-speed[mouse move speed multiplier (default 1)]:multiplier:' \
        '--mouse-scroll-speed[mouse scroll speed multiplier (default 1)]:multiplier:' \
        '(- *)'{-h,--help}'[print help]'
}

_remote-touchpad "$@"
