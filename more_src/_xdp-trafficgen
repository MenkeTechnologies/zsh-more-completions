#compdef xdp-trafficgen
# _xdp-trafficgen — XDP-based packet generator (xdp-project/xdp-tools)
# upstream: https://github.com/xdp-project/xdp-tools
# Subcommands + per-command flags from xdp-trafficgen/xdp-trafficgen.8.

_xdp-trafficgen() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_xdp-trafficgen_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                udp|tcp)
                    _arguments \
                        '(-m --dst-mac)'{-m+,--dst-mac=}'[destination MAC address]:mac:' \
                        '(-M --src-mac)'{-M+,--src-mac=}'[source MAC address]:mac:' \
                        '(-a --dst-addr)'{-a+,--dst-addr=}'[destination IP address]:addr:' \
                        '(-A --src-addr)'{-A+,--src-addr=}'[source IP address]:addr:' \
                        '(-p --dst-port)'{-p+,--dst-port=}'[destination port]:port:' \
                        '(-P --src-port)'{-P+,--src-port=}'[source port]:port:' \
                        '(-d --dyn-ports)'{-d+,--dyn-ports=}'[number of dynamic ports to rotate]:n:' \
                        '(-n --num-packets)'{-n+,--num-packets=}'[total packets to send]:n:' \
                        '(-s --pkt-size)'{-s+,--pkt-size=}'[packet size in bytes]:bytes:' \
                        '(-t --threads)'{-t+,--threads=}'[number of generator threads]:n:' \
                        '(-I --interval)'{-I+,--interval=}'[stats interval in seconds]:seconds:' \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '--version[show version]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                xsk-udp)
                    _arguments \
                        '(-m --dst-mac)'{-m+,--dst-mac=}'[destination MAC address]:mac:' \
                        '(-M --src-mac)'{-M+,--src-mac=}'[source MAC address]:mac:' \
                        '(-y --timestamp)'{-y,--timestamp}'[include a timestamp in each packet]' \
                        '(-V --vlan-tag)'{-V,--vlan-tag}'[add a VLAN tag]' \
                        '(-J --vlan-id)'{-J+,--vlan-id=}'[VLAN id]:id:' \
                        '(-K --vlan-pri)'{-K+,--vlan-pri=}'[VLAN priority]:pri:' \
                        '(-P --fill-pattern)'{-P+,--fill-pattern=}'[payload fill pattern]:pattern:' \
                        '(-T --tx-cycle-time)'{-T+,--tx-cycle-time=}'[transmit cycle time in us]:us:' \
                        '(-q --queue)'{-q+,--queue=}'[AF_XDP queue id]:queue:' \
                        '(-i --interval)'{-i+,--interval=}'[stats interval in seconds]:seconds:' \
                        '(-O --retries)'{-O+,--retries=}'[number of sendto retries]:n:' \
                        '(-f --frame-size)'{-f+,--frame-size=}'[UMEM frame size in bytes]:bytes:' \
                        '(-s --pkt-size)'{-s+,--pkt-size=}'[packet size in bytes]:bytes:' \
                        '(-d --duration)'{-d+,--duration=}'[duration in seconds]:seconds:' \
                        '(-c --pkt-count)'{-c+,--pkt-count=}'[total packets to send]:n:' \
                        '(-b --batch-size)'{-b+,--batch-size=}'[packets per batch]:n:' \
                        '(-I --irq-string)'{-I+,--irq-string=}'[IRQ name pattern]:pattern:' \
                        '(-p --poll)'{-p,--poll}'[use poll() rather than sendto wakeups]' \
                        '(-m --no-need-wakeup)'{-m,--no-need-wakeup}'[disable XDP_USE_NEED_WAKEUP]' \
                        '(-u --unaligned)'{-u,--unaligned}'[use unaligned chunks]' \
                        '(-M --shared-umem)'{-M,--shared-umem}'[share UMEM across queues]' \
                        '(-x --extra-stats)'{-x,--extra-stats}'[print extra per-thread stats]' \
                        '(-Q --quiet)'{-Q,--quiet}'[suppress non-error output]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
                probe)
                    _arguments \
                        '*'{-v,--verbose}'[increase verbosity]' \
                        '--version[show version]' \
                        '1:ifname:_net_interfaces' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xdp-trafficgen_commands] )) ||
_xdp-trafficgen_commands() {
    local -a commands
    commands=(
        'udp:generate UDP traffic'
        'tcp:generate TCP traffic'
        'xsk-udp:generate UDP traffic using AF_XDP sockets'
        'probe:probe kernel support for XDP traffic generation'
    )
    _describe -t commands 'xdp-trafficgen command' commands
}

_xdp-trafficgen "$@"
