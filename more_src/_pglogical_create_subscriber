#compdef pglogical_create_subscriber
# Documentation: https://man.archlinux.org/search?q=pglogical_create_subscriber
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--dropslot-if-exists)--dropslot-if-exists[drop slot if it exists]' \
  '(--subscriber-name)--subscriber-name=+[subscriber name]:name:' \
  '(--provider-dsn)--provider-dsn=+[provider DSN]:dsn:' \
  '(--subscriber-dsn)--subscriber-dsn=+[subscriber DSN]:dsn:' \
  '(--pgdata)--pgdata=+[data directory]:dir:_files -/' \
  '(--replication-sets)--replication-sets=+[replication sets]:sets:' \
  '(--databases)--databases=+[databases]:dbs:' \
  '(--apply-delay)--apply-delay=+[apply delay]:delay:' \
  '(--recovery-conf)--recovery-conf=+[recovery conf]:file:_files' \
  '(--postgresql-conf)--postgresql-conf=+[postgresql conf]:file:_files' \
  '(--hba-conf)--hba-conf=+[hba conf]:file:_files' \
  '(--stop)--stop[stop subscriber after import]' \
  '(--clone)--clone[clone from provider via pg_basebackup]' \
  '(--restore-point)--restore-point=+[restore point name]:name:' \
  '(--use-existing-data)--use-existing-data[skip data copy]' \
  '(--text-output)--text-output[output in text format]' \
  '(--verbose)--verbose[verbose]' && ret=0

return ret
