#compdef namada
# Documentation: https://man.archlinux.org/search?q=namada
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--base-dir=[Namada base directory]:directory:_directories' \
  '--chain-id=[Chain identifier]:id:' \
  '--mode=[Light or full client mode]:mode:(full-seed full desktop tablet-light tablet)' \
  '--ledger[Use a hardware wallet]' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'client:Interact with the Namada ledger'
      'utils:Auxiliary utilities'
      'ledger:Ledger-related helpers'
      'tendermint-node:Run embedded tendermint'
      'node:Run validator / full node'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
