#compdef lfe

# Zsh completion for lfe - Lisp Flavoured Erlang

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e[evaluate expression]:expression: ' \
  '-f[evaluate file]:file:_files' \
  '-pa[prepend path to code path]:directory:_directories' \
  '-pz[append path to code path]:directory:_directories' \
  '-noshell[start without interactive shell]' \
  '-s[start a module]:module: ' \
  '1:command:(eval run repl)' \
  '*:args: ' && ret=0

return ret
