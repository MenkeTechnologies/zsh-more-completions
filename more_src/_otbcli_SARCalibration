#compdef otbcli_SARCalibration
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SARCalibration.html
# Orfeo ToolBox: perform radiometric calibration of a SAR image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input complex image]:image:_files' \
  '-out[output calibrated backscatter image]:output:_files' \
  '-removenoise[remove the noise of the input product]:bool:(true false)' \
  '-lut[lookup table values selection]:lut:(sigma beta gamma DN)' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
