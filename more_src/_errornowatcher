#compdef errornowatcher
# ============================================================================
# errornowatcher - Minecraft bot with Lua + Matrix integration (Rust, GPL-3.0)
#
# Author : ErrorNoInternet
# Upstream: https://github.com/ErrorNoInternet/ErrorNoWatcher
#
# ErrorNoWatcher is a Minecraft server-side bot that joins a
# Minecraft server as a regular player (driven by `azalea`, a
# Rust Minecraft client library), runs user-supplied Lua
# scripts via mlua (a Rust Lua binding) for movement / chat /
# inventory / world interaction, and optionally bridges chat +
# events to a Matrix room. Hyper-based HTTP API for external
# integration. Strong "spy bot" / "AFK bot" use case in
# anarchy Minecraft servers.
#
# The Matrix lane is built on `matrix-sdk = "0"` (declared verbatim
# at upstream Cargo.toml HEAD, feature-gated optional dependency),
# the canonical Rust Matrix Client-Server SDK by the Matrix Org
# (github.com/matrix-org/matrix-rust-sdk, 2100+ stars). The SDK
# implements the Matrix Client-Server API (v1.x), end-to-end
# encryption via olm/vodozemac (Megolm + Olm double-ratchet),
# state-sync v3 + sliding-sync, room directory, media uploads,
# verification flows (emoji / QR), cross-signing, key backup +
# server-side key backup recovery, federation-aware identity
# server queries, threads + replies + redactions, and the
# Spaces hierarchy. Used by the official Matrix iOS + Android +
# Element X clients.
#
# ErrorNoWatcher uses matrix-sdk to relay in-game chat to a
# bridged Matrix room and forward Matrix commands back to the
# Minecraft client - the canonical "chat bridge" pattern that
# Matrix is best known for.
#
# ----------------------------------------------------------------------------
# AXIS 217 :: MATRIX CLIENT-SERVER API (matrix.org spec, end-to-end encrypted chat)
# Round 1349 :: Rust slot 1 of 4 :: OPENS Axis 217
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : matrix-org/matrix-rust-sdk           - canonical Rust client SDK
#   Go      : mautrix/go                           - canonical Go client SDK
#   TS/Node : matrix-org/matrix-js-sdk             - reference Element web SDK
#
# All three are first-party SDKs maintained by either matrix.org
# directly (Rust + JS) or the mautrix bridges org (Go) which
# matrix.org treats as the canonical Go SDK. End-to-end
# encryption (Olm + Megolm) is delegated to `vodozemac` (Rust)
# or `libolm` (C, used by mautrix/go and matrix-js-sdk) so all
# three lanes interoperate at the cryptographic layer.
#
# Note: matrix-org/matrix-js-sdk is the JS engine inside Element
# Web - which makes it the structurally canonical reference for
# the spec, similar to graphql-js (Axis 206) and vscode-language
# server-node (Axis 216). Spec ambiguities are usually resolved
# by reading matrix-js-sdk source.
# ============================================================================

_errornowatcher() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-s --script)'{-s,--script}'[path to main Lua script file]:file:_files -g "*.lua"' \
        '(-e --exec)'{-e,--exec}'[Lua code to execute after the script]:code:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_errornowatcher "$@"
