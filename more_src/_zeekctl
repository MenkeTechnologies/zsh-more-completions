#compdef zeekctl
# Documentation: https://github.com/zeek/zeekctl
# Reference accessed: 2026-05-16
# Verified: upstream zeek/zeekctl README. zeekctl is an interactive
# subcommand shell; the only top-level flag is invoking a single
# subcommand from the CLI.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# zeekctl: interactive control shell for Zeek cluster
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'start:start Zeek nodes'
  'stop:stop Zeek nodes'
  'restart:restart Zeek nodes'
  'status:show node status'
  'deploy:check + install + restart'
  'check:syntax-check scripts'
  'install:install configs to nodes'
  'cleanup:remove old logs and tempfiles'
  'diag:run diagnostics on crashed nodes'
  'top:show top-like view per node'
  'capstats:capture statistics from interfaces'
  'netstats:show packet capture statistics'
  'peerstatus:show inter-node communication status'
  'print:print Zeek variable values'
  'cron:run periodic maintenance tasks'
  'df:show disk usage per node'
  'scripts:list loaded scripts'
  'process:trace process events for a node'
  'exec:run shell command on nodes'
  'config:show running configuration'
  'nodes:list configured nodes'
  'help:show help'
  'exit:exit shell'
  'quit:exit shell'
)
_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'zeekctl command' commands && ret=0 ;;
esac
return ret
