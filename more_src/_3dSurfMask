#compdef 3dSurfMask
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSurfMask.html
# AFNI mark voxel positions relative to a surface

local ret=1

_arguments -s -S \
  '-i_TYPE[input surface (mandatory)]:surface:_files' \
  '-prefix[prefix for output dataset (mandatory)]:prefix:' \
  '-grid_parent[grid for output volume (mandatory)]:dataset:_files' \
  '-fill_method[fill method]:meth:(SLOW FAST)' \
  '-sv[surface volume for coordinate alignment]:dataset:_files' \
  '-mask_only[binary output (1 inside, 0 outside)]' \
  '-flip_orientation[flip triangle winding]' \
  '-no_dist[compute mask only, skip distance]' \
  '-onestate[all surfaces appear simultaneously]' \
  '-anatomical[label all input surfaces as anatomical]' \
  '-spec[surface specification file]:spec:_files' \
  '-surf_A[surface name from SPEC file]:surface:' \
  '-tn[surface type and name]:type:' \
  '-tsn[surface type, state, and name]:type:' \
  '*:surface:_files' && ret=0

return ret
