#compdef 3dPeriodogram
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dPeriodogram.html
# Compute the periodogram (power spectrum estimate) of each voxel time series

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-taper[fraction of data for Hamming window taper]:frac:' \
  '-nfft[FFT length in points]:L:' \
  '*:dataset:_files' && ret=0

return ret
