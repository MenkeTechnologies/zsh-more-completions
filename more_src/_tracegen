#compdef tracegen
# ---------------------------------------------------------------------------
# tracegen — Jaeger's canonical OpenTelemetry trace load generator (Go)
#
# upstream: https://github.com/jaegertracing/jaeger
#           (this binary lives at cmd/tracegen/ in the Jaeger repo, 22,852★)
# project: CNCF Jaeger — distributed tracing platform (CNCF graduated)
# license: Apache-2.0
#
# Source-direct completion: every flag below is verbatim from
# internal/tracegen/config.go `Config.Flags()` registration plus the
# `--adaptive-sampling` flag registered directly in cmd/tracegen/main.go
# on the jaegertracing/jaeger tip.
#
# Direct deps from main.go imports:
#   go.opentelemetry.io/otel                         ← canonical Go OTel API
#                                                      (this axis)
#   go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracegrpc
#   go.opentelemetry.io/otel/exporters/otlp/otlptrace/otlptracehttp
#   go.opentelemetry.io/otel/exporters/stdout/stdouttrace
#   go.opentelemetry.io/otel/sdk/trace
#   go.opentelemetry.io/contrib/samplers/jaegerremote (remote adaptive sampling)
#   go.uber.org/zap                                  (structured logging)
#
# tracegen synthesizes traces with configurable workers/services/spans/
# attributes counts and emits them via OTLP/HTTP, OTLP/gRPC, or stdout —
# making it the de-facto OTel-API load harness for OpenTelemetry Collector,
# Jaeger, Tempo, and any OTLP-compatible backend.
#
# === AXIS 161 CONTINUES — distributed-tracing observability ecosystem ===
# Axis position: Go=216 continues Axis 161 (slot 2/0/0).  Canonical Go
# observability implementation is the OpenTelemetry Go SIG's
# `go.opentelemetry.io/otel` module family — CNCF-blessed SDK shipping
# the API, the SDK, and the OTLP/gRPC + OTLP/HTTP exporters.  Used in
# production by Jaeger itself, Grafana Tempo, Honeycomb refinery,
# the OpenTelemetry Collector, and basically every modern Go web service
# that does distributed tracing.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=216   _avail-light-client  ← previous round (axis 161 OPENS at 1/0/0)
#   Go=216     ← THIS FILE          (axis 161 continues, slot 2/0/0)
#   TS-Node=216 ← next round        (axis 161 CLOSES at triple-216, slot 1/1/1)
# ---------------------------------------------------------------------------

_tracegen() {
    _arguments -s -S \
        '-workers=[number of workers (goroutines) to run (default 1)]:n:' \
        '-traces=[traces per worker (ignored if -duration provided, default 1)]:n:' \
        '-spans=[child spans per trace (default 1)]:n:' \
        '-attrs=[attributes per child span (default 11)]:n:' \
        '-attr-keys=[distinct attribute keys (default 97)]:n:' \
        '-attr-values=[distinct values per attribute (default 1000)]:n:' \
        '-debug[set DEBUG flag on the spans to force sampling]' \
        '-firehose[set FIREHOSE flag on the spans to skip indexing]' \
        '-pause=[sleep before finishing each span (default 1µs; 0s → fake 123µs)]:duration:' \
        '-duration=[overall test duration (overrides -traces)]:duration:' \
        '-service=[service name prefix (default tracegen)]:service:' \
        '-services=[unique suffixes to add to service name (e.g. tracegen-01)]:n:' \
        '-trace-exporter=[trace exporter (default otlp-http)]:exporter:(otlp otlp-http otlp-grpc stdout)' \
        '-adaptive-sampling=[HTTP endpoint to retrieve sampling strategies (e.g. http://localhost:14268/api/sampling)]:url:' \
        '-h[show usage]'
}

_tracegen "$@"
