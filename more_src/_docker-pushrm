#compdef docker-pushrm
# Documentation: https://github.com/christian-korneck/docker-pushrm
# push a README to Docker Hub, Harbor v2 or Quay container registry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--provider=[registry type]:provider:(harbor2 quay)' \
  '--file=[path to README file]:file:_files' \
  '(-s --short)'{-s,--short}'=[set repo short description (Docker Hub only)]:text:' \
  '--debug[enable debug output]' \
  '*:repository:' && ret=0

return ret
