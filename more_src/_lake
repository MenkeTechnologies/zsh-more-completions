#compdef lake
# Documentation: https://lean-lang.org/doc/reference/latest/Build-Tools-and-Distribution/Lake/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lake - Lean 4 build system and package manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new Lean package'
  'init:initialize a Lean package in the current directory'
  'build:build targets'
  'check-build:check that default targets are configured'
  'query:build targets and report results'
  'clean:remove build outputs'
  'update:update dependencies'
  'upload:upload build artifacts to a GitHub release'
  'pack:archive build directory'
  'unpack:extract build archive'
  'exe:build and run an executable target'
  'exec:build and run an executable target (alias of exe)'
  'env:execute command in the Lake environment'
  'lean:run Lean with the package configuration'
  'test:run the package test driver'
  'lint:run the package lint driver'
  'check-test:verify test driver is configured'
  'check-lint:verify lint driver is configured'
  'script:manage and run workspace scripts'
  'scripts:shorthand for lake script list'
  'run:execute a script (alias of lake script run)'
  'serve:start a language server for the package'
  'translate-config:translate lakefile format'
  'shake:check for unused imports'
  'cache:manage build cache'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --dir)'{-d+,--dir=}'[use the package in the given directory]:directory:_files -/' \
  '(-f --file)'{-f+,--file=}'[use the given lakefile]:file:_files' \
  '-K+[set a configuration option]:key=value:' \
  '--packages=[package overrides file]:file:_files' \
  '--old[rebuild only modified modules]' \
  '(-q --quiet)'{-q,--quiet}'[hide informational logs]' \
  '(-v --verbose)'{-v,--verbose}'[show trace logs and targets]' \
  '--no-build[exit if targets are not up-to-date]' \
  '--no-cache[do not use build cache]' \
  '--try-cache[try downloading build cache]' \
  '--update[update dependencies before building]' \
  '(-R --reconfigure)'{-R,--reconfigure}'[re-elaborate config file]' \
  '(-H --rehash)'{-H,--rehash}'[recompute file hashes]' \
  '--keep-toolchain[skip automatic toolchain updates]' \
  '--wfail[treat warnings as errors]' \
  '--iofail[fail on any I/O logs]' \
  '--log-level=[set minimum log level]:level:' \
  '--fail-level=[set failure threshold]:level:' \
  '--ansi[enable ANSI codes]' \
  '--no-ansi[disable ANSI codes]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'lake command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (new)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package name' \
          '2:template:(std exe lib math)' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package name' \
          '2:template:(std exe lib math)' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:target' && ret=0
        ;;
      (exe|exec)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:executable target' \
          '*:arguments' && ret=0
        ;;
      (update)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:package' && ret=0
        ;;
      (env)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:command:_command_names' && ret=0
        ;;
      (lean)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:lean arguments' && ret=0
        ;;
      (script)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(list run doc)' && ret=0
        ;;
      (cache)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:cache sub:(get put add clean services stage unstage)' && ret=0
        ;;
      (clean|test|lint|serve|upload|scripts|check-test|check-lint|check-build|translate-config|shake|query|pack|unpack)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
