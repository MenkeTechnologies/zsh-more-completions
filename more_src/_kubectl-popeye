#compdef kubectl-popeye
# Documentation: https://github.com/derailed/popeye
# A Kubernetes cluster resource sanitizer (kubectl popeye)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n,--namespace}'=[restrict scan to a namespace]:namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[run popeye in all namespaces]' \
  '(-f --file)'{-f,--file}'=[spinach yaml config to tune linters]:file:_files' \
  '--context=[use a kubeconfig context]:context' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '(-o --out)'{-o,--out}'=[output format]:format:(standard yaml html json junit prometheus score jurassic)' \
  '--save[save the popeye report to a file]' \
  '--output-file=[specify output filename for the report]:file:_files' \
  '--logs=[set logging output destination]:dest' \
  '--min-score=[set a minimum cluster score percentage]:score' \
  '(-s --sections)'{-s,--sections}'=[specify which linters to run]:sections' \
  '--lint=[set a minimum lint severity level]:level:(ok info warn error)' \
  '--force-exit-zero[force exit with a zero error code]' \
  '--s3-bucket=[push the generated report to an AWS S3 bucket]:bucket' \
  '--s3-region=[set the AWS region for S3 uploads]:region' \
  '--s3-endpoint=[set a Minio server endpoint URI]:endpoint' \
  '--push-gtwy-url=[set a Prometheus pushgateway URL]:url' \
  '--as=[username to impersonate for the operation]:user' \
  '--as-group=[group to impersonate for the operation]:group' \
  '--token=[bearer token for authentication to the API server]:token' \
  '--insecure-skip-tls-verify[skip checking the server certificate for validity]' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--request-timeout=[length of time to wait before giving up on a request]:duration' \
  '-v[set the verbosity level for debug logs]:level' \
  '1:command:(version help)' && ret=0

return ret
