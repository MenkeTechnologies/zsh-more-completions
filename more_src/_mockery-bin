#compdef mockery
# _mockery-bin — mockery Go mock generator (Vektra et al, Go); produces testify-style mocks for interfaces
# upstream: https://github.com/vektra/mockery

_mockery-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--name+[interface name regex]:regex:' \
        '--all[generate for all interfaces in current dir]' \
        '--print[print to stdout]' \
        '--output+[output dir]:dir:_files -/' \
        '--outpkg+[output package name]:name:' \
        '--filename+[output filename]:str:' \
        '--structname+[mock struct name]:name:' \
        '--case+[file case]:case:(snake camel underscore lower upper)' \
        '--note+[note for generated file]:str:' \
        '--cpuprofile+[CPU profile]:file:_files' \
        '--dir+[input dir]:dir:_files -/' \
        '--keeptree[keep package tree]' \
        '--tags+[build tags]:tags:' \
        '--recursive[recurse subpackages]' \
        '--inpackage[generate in same package]' \
        '--inpackage-suffix[generate _test.go suffix]' \
        '--testonly[generate only in _test.go]' \
        '--exported[export private interfaces]' \
        '--with-expecter[generate expecter]' \
        '--unroll-variadic+[unroll variadics]:bool:(true false)' \
        '--issue-845-fix[apply issue 845 fix]' \
        '--quiet[suppress logs]' \
        '--config+[config file]:file:_files' \
        '*:interface:'
}

_mockery-bin "$@"
