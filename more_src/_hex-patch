#compdef hex-patch
# Documentation: https://github.com/Etto48/HexPatch
# hex-patch - binary patcher and editor with terminal user interface

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --ssh)'{-s,--ssh}'[connection string in the format <user>@<host>[:<port>]]:ssh' \
  '(-w --password)'{-w,--password}'[password to use for SSH connection]:password' \
  '(-c --config)'{-c,--config}'[configuration file to use]:file:_files' \
  '(-p --plugins)'{-p,--plugins}'[plugin directory to use]:dir:_files -/' \
  '*:path:_files' && ret=0

return ret
