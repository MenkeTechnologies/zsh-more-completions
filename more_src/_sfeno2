local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'order=[interpolation order]:order:' \
  'is_inverse=[make velocity to slowness (y/n)]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
