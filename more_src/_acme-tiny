#compdef acme-tiny

# Zsh completion for acme-tiny - tiny ACME client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--account-key=[path to account private key]:key file:_files' \
  '--csr=[path to certificate signing request]:CSR file:_files' \
  '--acme-dir=[path to ACME challenge directory]:directory:_directories' \
  '--ca=[certificate authority URL]:URL' \
  '--contact=[contact information for account]:contact' \
  '--quiet[suppress output except errors]' \
  '--disable-check[disable self-check of challenge]' \
  '--directory-url=[ACME directory URL]:URL' \
  '--check-port=[port to use for challenge check]:port' && ret=0

return ret
