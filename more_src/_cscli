#compdef cscli

# completions for CrowdSec CLI (cscli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[configuration file]:file:_files' \
  '--debug[set logging to debug]' \
  '--info[set logging to info]' \
  '--warning[set logging to warning]' \
  '--error[set logging to error]' \
  '--trace[set logging to trace]' \
  '-o+[output format]:format:(human json raw)' \
  '--output=[output format]:format:(human json raw)' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'alerts:manage alerts'
      'bouncers:manage bouncers'
      'capi:manage interaction with Central API'
      'collections:manage collections'
      'completion:generate shell completion script'
      'config:manage configuration'
      'console:manage console'
      'dashboard:manage dashboard'
      'decisions:manage decisions'
      'explain:explain log processing'
      'hub:manage hub'
      'hubtest:run hub tests'
      'lapi:manage Local API'
      'machines:manage machines'
      'metrics:show metrics'
      'notifications:manage notifications'
      'parsers:manage parsers'
      'postoverflows:manage postoverflows'
      'scenarios:manage scenarios'
      'simulation:manage simulation'
      'support:generate support bundle'
      'version:show version'
    )
    _describe -t commands 'cscli command' commands && ret=0
    ;;
esac

return ret
