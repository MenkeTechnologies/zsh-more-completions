#compdef certspotter
# Documentation: https://github.com/SSLMate/certspotter/blob/master/man/certspotter.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--logs-dir=[watch log directory]:directory:_directories' \
  '--smtp-from=[from address for alerts]:addr' \
  '--smtp-to=[recipient for alerts]:addr' \
  '--smtp-url=[SMTP submission URL]:url' \
  '--watchlist=[watchlist file]:file:_files' \
  '1:command:(watch download)' \
  '*:args: _default'
