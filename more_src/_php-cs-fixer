#compdef php-cs-fixer

# Zsh completion for php-cs-fixer (PHP Coding Standards Fixer)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'check:check code style without modifying files'
      'describe:describe a rule or ruleset'
      'fix:fix code style'
      'list:list available fixers'
      'list-files:list files that would be processed'
      'self-update:update php-cs-fixer'
    )
    _describe -t commands 'php-cs-fixer command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (fix|check)
        _arguments \
          '--config[path to config file]:config:_files -g "*.php"' \
          '--rules[rules to apply]:rules' \
          '--using-cache[enable cache]:cache:(yes no)' \
          '--cache-file[path to cache file]:cache file:_files' \
          '--dry-run[show diff without changing files]' \
          '--diff[show diff of changes]' \
          '--format[output format]:format:(checkstyle gitlab json junit txt xml)' \
          '--path-mode[path mode]:mode:(override intersection)' \
          '--allow-risky[allow risky rules]:allow:(yes no)' \
          '--stop-on-violation[stop on first violation]' \
          '--show-progress[show progress]:progress:(none dots bar)' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '*:path:_files' && ret=0
        ;;
      (describe)
        _arguments \
          '1:rule or set' && ret=0
        ;;
    esac
    ;;
esac

return ret
