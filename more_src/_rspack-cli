#compdef rspack-cli
# _rspack-cli — Rspack bundler CLI (web-infra-dev/rspack)
# upstream: https://github.com/web-infra-dev/rspack
# Subcommands & flags from packages/rspack-cli/src/cli.ts + utils/options.ts (cac).

_rspack-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(js|cjs|mjs|ts|cts|mts)"' \
        '*--config-name=[configuration name(s)]:name:' \
        '--config-loader=[config loader]:loader:(auto jiti native)' \
        '*--env=[env passed to config function]:KEY=VAL:' \
        '--node-env=[set process.env.NODE_ENV]:env:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'build:build the project (alias: bundle, b)'
                'serve:run dev server (alias: server, s)'
                'preview:preview the production build (alias: preview, p)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                build|serve)
                    _arguments \
                        '(-d --devtool)'{-d+,--devtool=}'[source-map style or false]:devtool:(eval cheap-source-map cheap-module-source-map source-map inline-source-map hidden-source-map false true)' \
                        '*--entry=[entry file]:file:_files' \
                        '(-m --mode)'{-m+,--mode=}'[build mode]:mode:(development production none)' \
                        '(-o --output-path)'{-o+,--output-path=}'[output dir]:dir:_files -/' \
                        '(-w --watch)'{-w,--watch}'[watch for changes]'
                    ;;
            esac
            ;;
    esac
}

_rspack-cli "$@"
