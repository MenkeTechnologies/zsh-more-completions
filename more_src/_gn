#compdef gn

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze which targets are affected by a list of files'
  'args:display or configure arguments for a build directory'
  'check:check header dependencies'
  'clean:clean the output directory'
  'desc:show lots of information about a target or config'
  'format:reformat .gn files'
  'gen:generate ninja files'
  'help:show help about a command or topic'
  'ls:list matching targets'
  'meta:list target metadata'
  'outputs:list target outputs'
  'path:find paths between two targets'
  'refs:find things referencing a target or file'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--root=[set source root]:directory:_directories' \
  '--dotfile=[set .gn file location]:file:_files' \
  '--markdown[output in markdown format]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '--color=[control terminal colors]:mode:(auto on off)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'gn command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      gen)
        _arguments -s -S \
          '--args=[build arguments]:args' \
          '--ide=[generate IDE project]:ide:(eclipse vs vs2013 vs2015 vs2017 vs2019 vs2022 xcode json qtcreator)' \
          '--filters=[list of label patterns]:filters' \
          '--no-deps[do not generate ninja deps]' \
          '--check[run header check]' \
          '--fail-on-unused-args[fail on unused build arguments]' \
          '--export-compile-commands=[generate compile_commands.json for targets]:targets' \
          '--export-rust-project[generate rust-project.json]' \
          '--ninja-executable=[path to ninja]:ninja:_files' \
          '--ninja-args=[extra arguments for ninja]:args' \
          '--json-ide-script=[path to IDE script]:script:_files' \
          '--json-ide-script-args=[arguments for IDE script]:args' \
          '1:build directory:_directories' && ret=0
        ;;
      ls)
        _arguments -s -S \
          '--all-toolchains[match all toolchains]' \
          '--as=[output format]:format:(buildfile label output)' \
          '--type=[target type]:type:(action action_foreach bundle_data copy create_bundle executable group loadable_module shared_library source_set static_library generated_file rust_library)' \
          '--testonly=[filter testonly]:value:(true false)' \
          '1:build directory:_directories' \
          '2:label pattern:' && ret=0
        ;;
      desc)
        _arguments -s -S \
          '--all[show all information]' \
          '--blame[show blame]' \
          '--tree[show dependency tree]' \
          '--format=[output format]:format:(json)' \
          '1:build directory:_directories' \
          '2:target label:' && ret=0
        ;;
      format)
        _arguments -s -S \
          '--dry-run[do not write formatted file]' \
          '--dump-tree[dump parse tree]' \
          '--stdin[read from stdin]' \
          '*:gn file:_files -g "*.(gn|gni)"' && ret=0
        ;;
      refs)
        _arguments -s -S \
          '--all[show all references]' \
          '--all-toolchains[search all toolchains]' \
          '--as=[output format]:format:(buildfile label output)' \
          '--type=[filter by type]:type' \
          '--tree[show reference tree]' \
          '1:build directory:_directories' \
          '2:label or file:' && ret=0
        ;;
      check)
        _arguments -s -S \
          '--force[force check all targets]' \
          '1:build directory:_directories' \
          '2:label pattern:' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '1:build directory:_directories' && ret=0
        ;;
      args)
        _arguments -s -S \
          '--list=[list build args]:filter' \
          '--short[short format]' \
          '--args=[initial args]:args' \
          '1:build directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
