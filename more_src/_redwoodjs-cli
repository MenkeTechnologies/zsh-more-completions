#compdef redwoodjs-cli
# _redwoodjs-cli — Tom Preston-Werner Redwood opinionated full-stack JS framework CLI alias (redwoodjs team, TypeScript); yargs
# upstream: https://github.com/redwoodjs/redwood

_redwoodjs-cli() {
    local -a sub=(
        'dev:start development server'
        'build:build for production'
        'serve:serve production build'
        'test:run tests'
        'check:check codebase'
        'deploy:deploy app'
        'data-migrate:run data migrations'
        'destroy:destroy file from generator'
        'exec:execute a script'
        'generate:generate scaffold'
        'info:show info'
        'lint:lint code'
        'prerender:prerender pages'
        'prisma:run prisma command'
        'record:create/update record'
        'setup:configure features'
        'storybook:run storybook'
        'storybook-build:build storybook'
        'studio:run redwood studio'
        'type-check:run type check'
        'update:update redwood version'
        'upgrade:upgrade redwood version'
        'utility:misc utilities'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--load-env-files=+[files]:str:' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redwood subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '1:side:(api web both)' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--port-detection[detect port]' \
                    '--watchNodeModules[watch node_modules]' \
                    '--apiDebugPort=+[port]:port:' \
                    '--fwd=+[args]:str:' \
                    '--generate[generate types]' \
                    '--apollo-debug[apollo debug]' ;;
                build) _arguments \
                    '1:side:(api web both)' \
                    '--stats[stats]' \
                    '--verbose[verbose]' \
                    '-v[verbose]' \
                    '--performance[performance]' \
                    '--prerender[prerender]' \
                    '--prisma[run prisma]' \
                    '--esbuild[use esbuild]' ;;
                generate|destroy) _arguments \
                    '1:type:(cell component dataMigration directive function layout model page sdl secret-key service scaffold script types util realtime job)' \
                    '*:args:' \
                    '--force[force]' \
                    '-f[force]' \
                    '--typescript[typescript]' \
                    '--javascript[javascript]' ;;
                deploy) _arguments \
                    '1:provider:(baremetal flightcontrol netlify render serverless vercel)' \
                    '*:args:' ;;
                setup) _arguments \
                    '1:topic:(auth cache custom-web-index db-auth deploy generator graphql jobs mailer monitoring package realtime tsconfig ui webpack)' \
                    '*:args:' ;;
                test) _arguments \
                    '*:side:(api web)' \
                    '--watch[watch]' \
                    '--collect-coverage[coverage]' \
                    '--clear-cache[clear cache]' \
                    '--db-push[db push]' ;;
            esac
            ;;
    esac
}

_redwoodjs-cli "$@"
