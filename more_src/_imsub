#compdef imsub
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imsub.html
# MIRIAD: extract a subportion of an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'out=[output image]:out:_files' \
  'region=[region to extract]:region:' \
  'incr=[sampling step per axis]:incr:' \
  '*:image:_files' && ret=0

return ret
