#compdef jless
# Documentation: https://man.archlinux.org/search?q=jless
# Reference accessed: 2026-05-16

# Zsh completion for jless - A command-line JSON viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--mode=[initial viewing mode]:mode:(line data)' \
  '--scrolloff=[number of lines to maintain as padding]:lines:' \
  '--json[force interpretation of input as JSON]' \
  '--yaml[force interpretation of input as YAML]' \
  '*:file:_files -g "*.{json,yaml,yml}"' && ret=0

return ret
