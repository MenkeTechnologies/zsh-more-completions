#compdef lncli

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--rpcserver=[host\:port of LND]:rpc server:' \
  '--lnddir=[path to lnd home directory]:directory:_directories' \
  '--tlscertpath=[path to TLS certificate]:cert file:_files' \
  '--chain=[target chain]:chain:(bitcoin litecoin)' \
  '--network=[target network]:network:(mainnet testnet simnet regtest)' \
  '--no-macaroons[disable macaroon authentication]' \
  '--macaroonpath=[path to macaroon file]:macaroon file:_files' \
  '--macaroontimeout=[macaroon timeout in seconds]:seconds:' \
  '--macaroonip=[macaroon IP address restriction]:ip:' \
  '--profile=[connection profile]:profile:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:initialize a wallet'
      'unlock:unlock an encrypted wallet'
      'changepassword:change wallet password'
      'newaddress:generate a new address'
      'sendmany:send funds to multiple addresses'
      'sendcoins:send bitcoin on-chain'
      'listunspent:list UTXOs'
      'estimatefee:estimate fee rate'
      'walletbalance:compute wallet balance'
      'channelbalance:compute channel balance'
      'getinfo:return basic information about the node'
      'getrecoveryinfo:display recovery information'
      'pendingchannels:display pending channels'
      'listchannels:list open channels'
      'closedchannels:list closed channels'
      'getnetworkinfo:return network information'
      'feereport:display channel fee schedule and earnings'
      'updatechanpolicy:update channel fee schedule'
      'exportchanbackup:export channel backup'
      'verifychanbackup:verify channel backup'
      'restorechanbackup:restore channels from backup'
      'openchannel:open a channel'
      'batchopenchannel:open multiple channels'
      'closechannel:close a channel'
      'closeallchannels:close all open channels'
      'abandonchannel:abandon a channel'
      'sendpayment:send a payment'
      'payinvoice:pay a Lightning invoice'
      'sendtoroute:send a payment over a specified route'
      'addinvoice:add a new invoice'
      'lookupinvoice:lookup an invoice'
      'listinvoices:list invoices'
      'decodepayreq:decode a payment request'
      'listpayments:list payments'
      'queryroutes:query routes to a destination'
      'fwdinghistory:query forwarding history'
      'querymc:query mission control state'
      'queryprob:estimate routing success probability'
      'resetmc:reset mission control state'
      'importmc:import mission control state'
      'buildroute:build a route from a list of hops'
      'connect:connect to a remote peer'
      'disconnect:disconnect from a peer'
      'listpeers:list all active peers'
      'describegraph:describe the network graph'
      'getnodemetrics:get node metrics'
      'getchaninfo:get channel information'
      'getnodeinfo:get node information'
      'signmessage:sign a message'
      'verifymessage:verify a signed message'
      'stop:stop the lnd daemon'
      'profile:manage connection profiles'
      'bakemacaroon:bake a new macaroon'
      'listmacaroonids:list root key IDs'
      'deletemacaroonid:delete a macaroon ID'
      'listpermissions:list available permissions'
      'state:get the current state of the wallet'
    )
    _describe -t commands 'lncli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      openchannel)
        _arguments -s -S \
          '--node_key=[node pub key]:pubkey:' \
          '--local_amt=[local amount in satoshis]:satoshis:' \
          '--push_amt=[push amount in satoshis]:satoshis:' \
          '--sat_per_vbyte=[fee rate in sat/vbyte]:sat/vbyte:' \
          '--private[make channel private]' \
          '--min_htlc_msat=[minimum HTLC in msat]:msat:' \
          '--close_address=[address for cooperative close]:address:' \
          '--funding_shim[use a funding shim]' && ret=0
        ;;
      closechannel)
        _arguments -s -S \
          '--funding_txid=[channel funding txid]:txid:' \
          '--output_index=[channel output index]:index:' \
          '--force[force close the channel]' \
          '--sat_per_vbyte=[fee rate in sat/vbyte]:sat/vbyte:' \
          '--delivery_addr=[delivery address]:address:' && ret=0
        ;;
      sendpayment|payinvoice)
        _arguments -s -S \
          '--pay_req=[payment request]:payment request:' \
          '--amt=[payment amount in satoshis]:satoshis:' \
          '--fee_limit=[fee limit in satoshis]:satoshis:' \
          '--fee_limit_percent=[fee limit as percentage]:percent:' \
          '--outgoing_chan_id=[outgoing channel ID]:channel ID:' \
          '--force[skip payment request confirmation]' \
          '--timeout=[payment timeout]:seconds:' && ret=0
        ;;
      addinvoice)
        _arguments -s -S \
          '--memo=[invoice memo]:memo:' \
          '--amt=[amount in satoshis]:satoshis:' \
          '--amt_msat=[amount in millisatoshis]:millisatoshis:' \
          '--expiry=[invoice expiry in seconds]:seconds:' \
          '--fallback_addr=[fallback on-chain address]:address:' \
          '--private[include routing hints for private channels]' && ret=0
        ;;
      connect)
        _arguments -s -S \
          '--perm[make connection permanent]' \
          '--timeout=[connection timeout]:seconds:' \
          '1:peer (pubkey@host\:port):' && ret=0
        ;;
      newaddress)
        _arguments -s -S \
          '1:address type:(p2wkh np2wkh p2tr)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
