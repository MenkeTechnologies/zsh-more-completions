#compdef znc-buildmod
# Documentation: https://wiki.znc.in/Compiling_modules
# Reference accessed: 2026-05-21
# Verified: znc-buildmod is a simple wrapper that compiles a single .cpp source.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '*:module source:_files -g "*.cpp"' && ret=0

return ret
