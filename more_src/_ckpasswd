#compdef ckpasswd
# Documentation: https://man.cx/ckpasswd
# Reference accessed: 2026-05-16
# Verified: ckpasswd(8) manpage (INN nnrpd-auth helper).

# ckpasswd: nnrpd authentication helper (INN)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[password database]:database:_files' \
  '-f[password file]:filename:_files' \
  '-g[look up system group; return user@group]' \
  '-p[use given password (testing)]:password:' \
  '-s[check against getspnam(3) shadow]' \
  '-u[authenticate as username]:user:_users' && ret=0
return ret
