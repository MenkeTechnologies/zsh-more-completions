autoload -U is-at-least

_cnc() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::items -- The items to be discarded:_files' \
&& ret=0
}

(( $+functions[_cnc_commands] )) ||
_cnc_commands() {
    local commands; commands=()
    _describe -t commands 'cnc commands' commands "$@"
}

if [ "$funcstack[1]" = "_cnc" ]; then
    _cnc "$@"
else
    compdef _cnc cnc
fi
