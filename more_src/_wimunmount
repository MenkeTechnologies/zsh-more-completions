#compdef wimunmount
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/wimlib-imagex-unmount.1.html
# wimunmount — unmount a WIM image that was mounted via FUSE

local ret=1

_arguments -s -S \
  '--commit[update the WIM file with the changes that were made]' \
  '--force[with --commit, force commit even if descriptors remain open]' \
  '--check[include extra integrity info when committing changes]' \
  '--rebuild[rebuild the entire WIM rather than appending new data]' \
  '--new-image[save modifications as a new image, preserving the original]' \
  '*:mount directory:_files -/' && ret=0

return ret
