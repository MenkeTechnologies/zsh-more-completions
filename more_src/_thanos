#compdef thanos

_thanos_cmds() {
    local -a commands=(
        'sidecar:connect to Prometheus and expose StoreAPI'
        'store:serve metrics from object storage'
        'query:query node exposing PromQL'
        'query-frontend:query frontend for caching and splitting'
        'rule:ruler evaluating recording and alerting rules'
        'compact:compact and downsample object store blocks'
        'tools:various tools for debugging and maintenance'
        'receive:accept remote write and expose StoreAPI'
    )
    _describe -t commands 'thanos command' commands
}

_thanos() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:format:(logfmt json)' \
        '--tracing.config=[tracing config YAML]:config' \
        '--tracing.config-file=[tracing config file]:file:_files' \
        '1:command:_thanos_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                sidecar)
                    _arguments \
                        '--prometheus.url=[Prometheus URL]:url' \
                        '--prometheus.ready_timeout=[readiness timeout]:duration' \
                        '--tsdb.path=[TSDB data directory]:dir:_directories' \
                        '--grpc-address=[gRPC listen address]:address' \
                        '--grpc-server-tls-cert=[gRPC TLS cert]:file:_files' \
                        '--grpc-server-tls-key=[gRPC TLS key]:file:_files' \
                        '--http-address=[HTTP listen address]:address' \
                        '--objstore.config=[object store config YAML]:config' \
                        '--objstore.config-file=[object store config file]:file:_files' \
                        '--reloader.config-file=[config file to watch]:file:_files' \
                        '--reloader.config-envsubst-file=[envsubst config output]:file:_files' \
                        '--reloader.rule-dir=[rule directory to watch]:dir:_directories' \
                        '--min-time=[minimum time for data]:time' \
                        '--shipper.upload-compacted[upload compacted blocks]'
                    ;;
                store)
                    _arguments \
                        '--data-dir=[local data directory]:dir:_directories' \
                        '--grpc-address=[gRPC listen address]:address' \
                        '--http-address=[HTTP listen address]:address' \
                        '--objstore.config=[object store config YAML]:config' \
                        '--objstore.config-file=[object store config file]:file:_files' \
                        '--index-cache-size=[index cache size]:size' \
                        '--chunk-pool-size=[chunk pool size]:size' \
                        '--store.grpc.series-max-concurrency=[max series concurrency]:number' \
                        '--sync-block-duration=[block sync interval]:duration' \
                        '--min-time=[minimum time for data]:time' \
                        '--max-time=[maximum time for data]:time' \
                        '--selector.relabel-config=[selector relabel config]:config' \
                        '--selector.relabel-config-file=[selector relabel config file]:file:_files'
                    ;;
                query)
                    _arguments \
                        '--grpc-address=[gRPC listen address]:address' \
                        '--http-address=[HTTP listen address]:address' \
                        '--query.replica-label=[replica label]:label' \
                        '--query.auto-downsampling[enable auto downsampling]' \
                        '--query.partial-response[enable partial response]' \
                        '--query.max-concurrent=[max concurrent queries]:number' \
                        '--query.timeout=[query timeout]:duration' \
                        '--store=[store API addresses]:address' \
                        '--store.sd-files=[store SD files]:file:_files' \
                        '--store.sd-interval=[store SD interval]:duration' \
                        '--store-strict=[strict store addresses]:address' \
                        '--web.external-prefix=[external URL prefix]:prefix' \
                        '--web.route-prefix=[route prefix]:prefix'
                    ;;
                query-frontend)
                    _arguments \
                        '--http-address=[HTTP listen address]:address' \
                        '--query-frontend.downstream-url=[downstream Thanos Query URL]:url' \
                        '--query-frontend.compress-responses[compress responses]' \
                        '--query-range.split-interval=[split interval]:duration' \
                        '--query-range.max-retries-per-request=[max retries]:number' \
                        '--query-range.max-query-length=[max query length]:duration' \
                        '--query-range.max-query-parallelism=[max parallelism]:number' \
                        '--query-range.response-cache-max-freshness=[cache max freshness]:duration' \
                        '--query-range.response-cache-config=[response cache config]:config' \
                        '--query-range.response-cache-config-file=[response cache config file]:file:_files'
                    ;;
                compact)
                    _arguments \
                        '--data-dir=[data directory]:dir:_directories' \
                        '--http-address=[HTTP listen address]:address' \
                        '--objstore.config=[object store config YAML]:config' \
                        '--objstore.config-file=[object store config file]:file:_files' \
                        '--consistency-delay=[consistency delay]:duration' \
                        '--retention.resolution-raw=[raw retention]:duration' \
                        '--retention.resolution-5m=[5m resolution retention]:duration' \
                        '--retention.resolution-1h=[1h resolution retention]:duration' \
                        '--compact.concurrency=[compaction concurrency]:number' \
                        '--downsample.concurrency=[downsampling concurrency]:number' \
                        '--wait[wait after one compaction run]' \
                        '--wait-interval=[wait interval]:duration' \
                        '--delete-delay=[deletion delay]:duration' \
                        '--deduplication.replica-label=[dedup replica label]:label'
                    ;;
                receive)
                    _arguments \
                        '--grpc-address=[gRPC listen address]:address' \
                        '--http-address=[HTTP listen address]:address' \
                        '--remote-write.address=[remote write listen address]:address' \
                        '--tsdb.path=[TSDB data directory]:dir:_directories' \
                        '--tsdb.retention=[TSDB retention]:duration' \
                        '--receive.hashrings=[hashrings config]:config' \
                        '--receive.hashrings-file=[hashrings config file]:file:_files' \
                        '--receive.local-endpoint=[local endpoint]:endpoint' \
                        '--receive.tenant-header=[tenant header name]:name' \
                        '--receive.default-tenant-id=[default tenant ID]:id' \
                        '--receive.replication-factor=[replication factor]:number' \
                        '--objstore.config=[object store config YAML]:config' \
                        '--objstore.config-file=[object store config file]:file:_files' \
                        '*:label'
                    ;;
                rule)
                    _arguments \
                        '--grpc-address=[gRPC listen address]:address' \
                        '--http-address=[HTTP listen address]:address' \
                        '--data-dir=[data directory]:dir:_directories' \
                        '--rule-file=[rule files glob]:glob' \
                        '--eval-interval=[rule evaluation interval]:duration' \
                        '--query=[query API endpoint]:url' \
                        '--query.sd-files=[query SD files]:file:_files' \
                        '--alertmanagers.url=[Alertmanager URLs]:url' \
                        '--alert.label-drop=[alert labels to drop]:label' \
                        '--resend-delay=[alert resend delay]:duration' \
                        '--objstore.config=[object store config]:config' \
                        '--objstore.config-file=[object store config file]:file:_files'
                    ;;
                tools)
                    _arguments \
                        '1:subcommand:(bucket rules)'
                    ;;
            esac
            ;;
    esac
}

_thanos "$@"
