#compdef opensnoop-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/opensnoop.8
# trace open() syscalls with file details (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-n+[filter by process name on open]:name' \
  '-p+[filter by process ID on open]:pid:_pids' \
  '-L+[filter by thread ID on open]:tid' \
  '-t[include time in seconds]' \
  '-x[only show failed open attempts]' \
  '*:filename:' && ret=0

return ret
