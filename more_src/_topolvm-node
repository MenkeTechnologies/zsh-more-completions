#compdef topolvm-node
# Documentation: https://github.com/topolvm/topolvm/blob/main/docs/topolvm-node.md
# topolvm-node — TopoLVM CSI node service daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--csi-socket=[UNIX domain socket of topolvm-node]:socket:_files' \
  '--lvmd-socket=[UNIX domain socket of LVMd service]:socket:_files' \
  '--metrics-bind-address=[bind address for the metrics endpoint]:address' \
  '--secure-metrics-server[secure the metrics server]' \
  '--nodename=[node resource name]:name' && ret=0

return ret
