#compdef api-extractor
# _api-extractor — analyze and document TypeScript packages (microsoft/rushstack)
# upstream: https://github.com/microsoft/rushstack/tree/main/apps/api-extractor
# Flags from apps/api-extractor/src/cli/.

_api-extractor() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-d --debug)'{-d,--debug}'[show full call stack on error]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:create an api-extractor.json config file'
                'run:invoke API Extractor on a project'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[config file (default api-extractor.json)]:file:_files -g "api-extractor*.json"' \
                        '(-l --local)'{-l,--local}'[local mode (allow updating api report)]' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        '--diagnostics[show diagnostic output]' \
                        '--typescript-compiler-folder=[TypeScript compiler folder]:dir:_files -/' \
                        '--print-api-report-diff[print API report diff]'
                    ;;
            esac
            ;;
    esac
}

_api-extractor "$@"
