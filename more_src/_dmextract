#compdef dmextract
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmextract.html
# Extract a histogram (e.g. radial profile or light curve) from a table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input virtual file or stack]:infile:_files' \
  'outfile=[output histogram file]:outfile:_files' \
  'bkg=[background file or value]:bkg:_files' \
  'error=[error method on counts]:error:(gaussian gehrels variance)' \
  'bkgerror=[error method for background]:bkgerror:(gaussian gehrels variance)' \
  'bkgnorm=[background normalization factor]:bkgnorm:' \
  'exp=[exposure correction file]:exp:_files' \
  'bkgexp=[background exposure correction file]:bkgexp:_files' \
  'sys_err=[fixed fractional systematic error]:sys_err:' \
  'opt=[output file type format]:opt:(pha1 pha2 generic generic2 ltc1 ltc2)' \
  'defaults=[mission database file]:defaults:_files' \
  'wmap=[filtering/binning for WMAP]:wmap:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
