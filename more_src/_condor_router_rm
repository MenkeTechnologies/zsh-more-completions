#compdef condor_router_rm
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_router_rm.html
# remove jobs being managed by the HTCondor job router

local ret=1

_arguments -s -S \
  '-constraint[remove jobs matching the constraint]:expression' \
  '-held[remove only jobs in the hold state]' \
  '-idle[remove only idle jobs]' \
  '-route[remove only jobs on the specified route]:name' \
  '*:job:_default' && ret=0

return ret
