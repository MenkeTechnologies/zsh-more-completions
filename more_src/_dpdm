#compdef dpdm
# _dpdm — JavaScript/TypeScript dependency analyzer (acrazing/dpdm)
# upstream: https://github.com/acrazing/dpdm
# Flags from src/bin/dpdm.ts (yargs .option).

_dpdm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--context=[context directory for shortening paths]:dir:_files -/' \
        '--cwd=[working directory]:dir:_files -/' \
        '(--ext --extensions)'{--ext,--extensions}'=[comma-separated extensions to resolve]:list:' \
        '--js=[comma-separated extensions for JS-like files]:list:' \
        '--include=[included filenames regexp]:regex:' \
        '--exclude=[excluded filenames regexp]:regex:' \
        '--output=[output file path]:file:_files' \
        '--tree=[print dependency tree]:bool:(true false)' \
        '--circular=[print circular dependencies]:bool:(true false)' \
        '--warning=[print warnings]:bool:(true false)' \
        '--tsconfig=[tsconfig path]:file:_files -g "*.json"' \
        '--transform=[apply TypeScript transforms]:bool:(true false)' \
        '--exit-code=[exit code per circular/warning]:spec:' \
        '--progress=[show progress]:bool:(true false)' \
        '--detect-unused-files-from=[detect unused files from pattern]:glob:' \
        '--skip-dynamic-imports=[skip dynamic imports]:mode:(none circular tree)' \
        '*--skip-imports=[skip ISSUER:DEPENDENCY imports]:spec:' \
        '--group-by-package=[group dependencies by package]:bool:(true false)' \
        '*:file or glob:_files'
}

_dpdm "$@"
