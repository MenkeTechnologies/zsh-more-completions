#compdef eliasdb
# ============================================================================
# eliasdb - lightweight graph-based database
#            with EQL query language + REST API
#            + interactive console
#            (Go, MPL-2.0)
#
# Author : Matthias Ladkau (krotik)
# Upstream: https://github.com/krotik/eliasdb
#
# EliasDB is a self-contained graph database
# written in pure Go (no third-party
# libraries apart from Go's standard library
# + gorilla/websocket for the live UI +
# krotik's own utility libraries). Stores
# data as nodes (key-value objects)
# connected via edges, with full-text
# indexing + an SQL-like query language
# called EQL.
#
# Architectural features:
#   - **Embedded or standalone** (use as a
#     Go library inside an application or
#     run as a standalone HTTPS server)
#   - **HTTPS REST API** (server mode exposes
#     a REST API + static file server)
#   - **WebSocket terminal** (live query
#     terminal accessed via the bundled web
#     UI; gorilla/websocket-backed)
#   - **EQL query language** (SQL-like syntax
#     for graph traversal queries)
#   - **Full-text indexing** (all stored data
#     auto-indexed for phrase search)
#   - **Partitioned storage** (logical
#     separation of unrelated graphs in the
#     same database file)
#   - **Cascading deletions** (delete a node
#     and all its children automatically)
#   - **Transactional kv-store backend**
#     (custom fast key-value store with
#     transaction + rollback support)
#   - **In-memory mode** (purely memory-
#     backed mode for caching + testing)
#   - **Rule-based consistency** (programmable
#     consistency rules trigger on graph
#     state changes)
#
# Use cases:
#   - Lightweight graph DB for IoT + edge
#     compute (small footprint; embeddable)
#   - Knowledge graphs for small + medium
#     teams (Neo4j alternative without the
#     JVM)
#   - Asset relationship tracking (CMDB +
#     dependency graphs)
#   - Social network prototypes (friend-of-
#     friend traversals via EQL)
#   - Document graph (markdown + wiki link
#     traversal)
#   - Local development databases for graph-
#     based apps before scaling to Neo4j
#     or DGraph
#
# Usage:
#   eliasdb <subcommand> [flags]
#
# Top-level subcommands:
#   server                         - start the
#                                     EliasDB
#                                     HTTPS
#                                     server
#                                     (long-
#                                     running)
#   console                        - connect to
#                                     an
#                                     EliasDB
#                                     server's
#                                     interactive
#                                     console
#
# `server` flags (Go stdlib flag):
#   -import <zipfile>              - import a
#                                     database
#                                     from a
#                                     zip
#                                     file
#                                     before
#                                     starting
#                                     the
#                                     server
#   -export <zipfile>              - export
#                                     the
#                                     current
#                                     database
#                                     to a zip
#                                     file +
#                                     exit
#   -help                          - show
#                                     server
#                                     flags +
#                                     exit
#
# Server configuration (via `eliasdb.config.
# json` in working directory):
#   {
#     "EnableReadOnly": false,
#     "HTTPSCertificate": "cert.pem",
#     "HTTPSKey": "key.pem",
#     "LocationConfig": "...",
#     "LocationData": "db",
#     "LocationHTTPS": "ssl",
#     "LocationWebFolder": "web",
#     "LockFile": "eliasdb.lck",
#     "MemoryOnlyStorage": false,
#     "EnableECALScripts": true,
#     "EnableWebFolder": true,
#     "EnableWebTerminal": true,
#     "EnableAccessControl": false,
#     "ResultCacheMaxSize": 1000,
#     "ClusterConfig": "...",
#     "ClusterPort": "9030",
#     "ClusterStateInfoFile": "cluster-state.json"
#   }
#
# `console` flags (Go stdlib flag):
#   -host <addr>                   - host of
#                                     the
#                                     EliasDB
#                                     server
#                                     (default
#                                     localhost
#                                     - from
#                                     config)
#   -port <port>                   - port of
#                                     the
#                                     EliasDB
#                                     server
#                                     (default
#                                     9090 -
#                                     from
#                                     config)
#   -file <path>                   - read
#                                     commands
#                                     from
#                                     file +
#                                     exit
#                                     (batch
#                                     mode)
#   -exec <cmd>                    - execute a
#                                     single
#                                     line +
#                                     exit
#   -help                          - show
#                                     console
#                                     flags +
#                                     exit
#
# EQL query language overview (from EliasDB
# console or REST API):
#   - Get nodes:
#       get Person where name = "alice"
#   - Traverse edges (friend-of-friend):
#       get Person where name = "alice"
#         traverse Person::knows::Person
#   - Filtered traversals:
#       get Person traverse :::Company
#         where employee_count > 1000
#   - Aggregations:
#       lookup Person where age > 30
#   - Show with specific columns:
#       get Person show name, age, email
#         where name beginswith "A"
#
# Example invocations:
#   # Start the EliasDB server (config from
#   # ./eliasdb.config.json or defaults)
#   eliasdb server
#
#   # Import a database from a zip file then
#   # start
#   eliasdb server -import dump.zip
#
#   # Export current database + exit
#   eliasdb server -export backup.zip
#
#   # Connect to an EliasDB server console
#   eliasdb console -host localhost -port 9090
#
#   # Execute a single EQL query then exit
#   eliasdb console \
#     -exec 'get Person where name = "alice"'
#
#   # Run a batch of EQL commands from a file
#   eliasdb console -file queries.eql
#
# Console commands (interactive after
# `eliasdb console`):
#   help                           - show
#                                     console
#                                     help
#   ver                            - show
#                                     server
#                                     version
#   login <user>                   - login
#                                     to a
#                                     user
#                                     account
#                                     (when
#                                     access
#                                     control
#                                     is
#                                     enabled)
#   logout                         - logout
#                                     current
#                                     user
#   whoami                         - show
#                                     current
#                                     user
#   info                           - show
#                                     database
#                                     statistics
#   part                           - show /
#                                     switch
#                                     partition
#   part <name>                    - switch to
#                                     partition
#                                     <name>
#   partitions                     - list all
#                                     partitions
#   nodes                          - list
#                                     all node
#                                     kinds in
#                                     current
#                                     partition
#   export                         - export
#                                     current
#                                     partition
#   exit                           - exit the
#                                     console
#
# The gorilla/websocket lane is built on
# `github.com/gorilla/websocket v1.4.1`
# (declared verbatim at upstream go.mod HEAD
# as a direct dep, imported by `api/v1/term.
# go` for the live WebSocket-based query
# terminal accessed via the bundled web UI
# at https://localhost:9090/web/), the
# canonical Go WebSocket library by the
# Gorilla web toolkit maintainers -
# github.com/gorilla/websocket.
#
# gorilla/websocket is the de-facto canonical
# Go WebSocket library:
#   - **RFC 6455 compliant** (the IETF
#     WebSocket spec; gorilla/websocket
#     passes the Autobahn fuzzing test
#     suite)
#   - **Standalone library** (no dependency
#     on the rest of the Gorilla web toolkit;
#     can be used with any Go HTTP server)
#   - **Server + client APIs** (both
#     directions of WebSocket connections)
#   - **Compression** (permessage-deflate,
#     RFC 7692)
#   - **Subprotocol negotiation** (Sec-
#     WebSocket-Protocol header handling)
#   - **Streaming I/O** (Reader/Writer +
#     Read/Write message helpers)
#   - **TLS support** (any net/http TLS
#     setup works)
#   - 23,000+ stars on github.com/gorilla/
#     websocket (one of the highest-star
#     Go libraries)
#   - ~50,000+ reverse-deps on pkg.go.dev
#     (the most-imported Go WebSocket
#     library)
#
# gorilla/websocket's distinguishing position
# vs Go WebSocket alternatives:
#   - gorilla/websocket (Gorilla team):
#     canonical (despite the 2022 temporary
#     archival; community-revived and
#     actively maintained again since 2024);
#     THIS AXIS
#   - coder/websocket (formerly nhooyr/
#     websocket by Anmol Sethi; adopted by
#     coder Inc): modern alternative;
#     simpler API; idiomatic context.Context
#     usage; growing adoption
#   - gobwas/ws: low-level high-performance
#     WebSocket; manual framing for max
#     throughput; less ergonomic
#   - olahol/melody: minimalist abstraction
#     over gorilla/websocket for chat-style
#     broadcasts
#
# Gorilla web toolkit was a comprehensive Go
# web framework (gorilla/mux + gorilla/
# sessions + gorilla/websocket + gorilla/
# securecookie + gorilla/handlers). The
# project briefly entered archive status in
# December 2022 due to maintainer burnout,
# but the community successfully revived all
# the core libraries in early 2024 with new
# maintainers (including the websocket
# library which now sees regular updates
# again).
#
# The Gorilla web toolkit's historical role
# in Go is *foundational web infrastructure*
# - gorilla/mux was the canonical router
# before chi + httprouter + the Go 1.22
# stdlib router; gorilla/websocket remains
# the canonical WebSocket library through
# the revival.
#
# Multi-axis canonical-Go author/org cohort
# extension (now spanning 21 distinct
# individuals/orgs after R1542):
#   - + Gorilla web toolkit maintainers
#     (gorilla/websocket + gorilla/mux +
#     gorilla/sessions + gorilla/handlers;
#     THIS AXIS; canonical Go WebSocket +
#     RFC 6455 + the most-imported Go
#     WebSocket library)
#
# The Gorilla maintainers join the canonical-
# Go cohort at the *foundational web
# infrastructure* level - similar position
# to:
#   - hashicorp/* (Vault + Consul + Terraform
#     SDK libraries)
#   - kubernetes/k8s.io/* (Kubernetes
#     client-go + apimachinery)
#   - prometheus/* (Prometheus client +
#     exposition libraries)
# The community-maintained web-toolkit
# pattern is well-represented in the Go
# canonical landscape.
#
# eliasdb uses gorilla/websocket for:
#   - The web terminal UI's WebSocket
#     endpoint (`/db/term/v1/ws`) that
#     forwards user-typed EQL queries to
#     the server and streams results back
#     for the in-browser console
#   - Live query result streaming (results
#     are streamed as they're computed
#     rather than buffered)
#   - Console session state (per-WebSocket
#     session state for partition selection
#     + login + query history)
#
# This is the canonical use case for
# gorilla/websocket in production Go
# services: persistent control + query
# channel between a web UI and a
# long-running server process, distinct
# from request-response HTTP traffic.
#
# ----------------------------------------------------------------------------
# AXIS 281 :: WebSocket libraries
#              (RFC 6455 WebSocket protocol
#              implementations;
#              full-duplex single-TCP-connection
#              messaging + permessage-deflate
#              + subprotocol negotiation +
#              binary + text frames)
# Round 1542 :: Go slot 2 of 4 :: continues Axis 281
#
# Cross-language canonical library family for
# this axis:
#   Rust    : snapview/tungstenite-rs    [R1541 _camilladsp]
#             (Daniel Abramov + snapview team;
#              canonical Rust WebSocket;
#              sync + tokio-tungstenite async
#              + async-tungstenite variants)
#   Go      : gorilla/websocket           [R1542 THIS FILE]
#             (Gorilla web toolkit
#              maintainers; canonical Go
#              WebSocket; community-revived
#              after 2022 archival; THE most-
#              imported Go WebSocket library)
#   TS/Node : websockets/ws              [R1543 closing]
#             (Einar Otto Stangvik + Luigi
#              Pinca; canonical Node
#              WebSocket; ~140M weekly npm
#              downloads)
#
# Use-case spectrum across the lanes (so far):
#   - camilladsp (Rust, tungstenite): real-
#     time audio DSP engine control API
#     (live config reload + gain control +
#     mute toggling)
#   - eliasdb (Go, gorilla/websocket):
#     graph database live query terminal
#     (web UI console accessing EQL query
#     engine via persistent WebSocket)
#
# Both use cases share the *long-running
# server with persistent control channel*
# pattern - the WebSocket replaces what
# would otherwise be many short-lived HTTP
# requests with a single persistent
# connection carrying interactive control
# traffic.
# ============================================================================

_eliasdb() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '1: :_eliasdb_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                server)
                    _arguments \
                        '-import=[import database from zip file]:file:_files -g "*.zip"' \
                        '-export=[export database to zip file]:file:_files -g "*.zip"' \
                        '-help[show server flags]'
                    ;;
                console)
                    _arguments \
                        '-host=[EliasDB server host]:host:_hosts' \
                        '-port=[EliasDB server port]:port:' \
                        '-file=[read EQL commands from file + exit]:file:_files' \
                        '-exec=[execute single EQL command + exit]:command:' \
                        '-help[show console flags]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_eliasdb_cmds() {
    local -a cmds
    cmds=(
        'server:start the EliasDB HTTPS server'
        'console:connect to an EliasDB server interactive console'
    )
    _describe -t commands 'eliasdb command' cmds
}

_eliasdb "$@"
