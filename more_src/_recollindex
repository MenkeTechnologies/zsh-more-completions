#compdef recollindex
# Recoll indexing tool

local ret=1

_arguments -s -S \
  '-c[specify configuration directory]:directory:_files -/' \
  '-z[reset index before starting]' \
  '-Z[reset user index]' \
  '-k[kill running indexer]' \
  '-l[list indexed files]' \
  '-s[show indexer status]' \
  '-m[monitor mode]' \
  '-D[do not run as daemon]' \
  '-e[erase documents for missing files]' \
  '-i[index specific files]:file:_files' \
  '-r[recursive]' \
  '-n[no beagle compat]' \
  '-x[do not index]' \
  '-h[show help]' \
  '*:paths:_files -/' && ret=0

return ret
