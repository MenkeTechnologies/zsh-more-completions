#compdef pangeo-forge-runner
# Documentation: https://pangeo-forge-runner.readthedocs.io/en/latest/reference/commands.html
# Run pangeo-forge recipes on Apache Beam

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(bake expand-meta)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      bake)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repo=[URL of feedstock repository]:url' \
          '--ref=[git/mercurial reference]:ref' \
          '--feedstock-subdir=[subdirectory containing meta.yaml]:subdir:_files -/' \
          '--recipe-id=[run only this recipe id]:id' \
          '--job-name=[custom job name]:name' \
          '--prune[limit execution to 2 time steps for testing]' \
          '--container-image=[container image for job workers]:image' \
          '--bakery-class=[bakery implementation class]:class' \
          '--json-logs[enable JSON formatted logging]' \
          '--config-file=[load config from file]:file:_files' \
          '--show-config[dump configuration to stdout]' \
          '--show-config-json[dump configuration as JSON]' && ret=0
        ;;
      expand-meta)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--repo=[URL of feedstock repository]:url' \
          '--ref=[git/mercurial reference]:ref' \
          '--feedstock-subdir=[subdirectory containing meta.yaml]:subdir:_files -/' \
          '--json-logs[enable JSON formatted logging]' \
          '--config-file=[load config from file]:file:_files' \
          '--show-config[dump configuration to stdout]' \
          '--show-config-json[dump configuration as JSON]' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
