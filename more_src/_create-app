#compdef create-app
# Documentation: https://www.npmjs.com/package/@shopify/create-app
# Reference accessed: 2026-05-24
# Verified: npm view @shopify/create-app bin; npx create-app init --help output.

# Zsh completion for create-app - Shopify app scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' init && ret=0
    ;;
  args)
    _arguments -C       '(-n --name)'{-n,--name}'[app name]:name:'       '(-p --path)'{-p,--path}'[target path]:directory:_directories'       '(-d --package-manager)'{-d,--package-manager}'[package manager]:manager:(npm yarn pnpm bun)'       '--template=[app template]:template:'       '--flavor=[template flavor]:flavor:'       '--organization-id=[Shopify organization id]:id:'       '--client-id=[Shopify app client id]:id:'       '(-h --help)'{-h,--help}'[show help]'       '(-V --version)'{-V,--version}'[show version]' && ret=0
    ;;
esac

return ret
