#compdef checkstyle

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c=[configuration file]:file:_files -g "*.xml"' \
  '-p=[properties file]:file:_files -g "*.properties"' \
  '*-D-[set property name=value]:property:' \
  '-o=[output file]:file:_files' \
  '-f=[output format]:format:(plain xml sarif)' \
  '(-w --tabWidth)'{-w,--tabWidth=}'[tab width]:n:' \
  '*'{-e,--exclude=}'[exclude path]:path:_files' \
  '*'{-x,--exclude-regexp=}'[exclude regex]:regex:' \
  '(-t --tree)'{-t,--tree}'[print AST tree]' \
  '(-T --treeWithComments)'{-T,--treeWithComments}'[print AST tree with comments]' \
  '(-J --treeWithJavadoc)'{-J,--treeWithJavadoc}'[print AST tree with Javadoc]' \
  '(-j --javadocTree)'{-j,--javadocTree}'[print Javadoc tree]' \
  '(-b --branch-matching-xpath)'{-b,--branch-matching-xpath=}'[branch matching xpath]:query:' \
  '(-g --generate-xpath-suppression)'{-g,--generate-xpath-suppression}'[generate xpath suppressions]' \
  '(-G --generate-checks-and-files-suppression)'{-G,--generate-checks-and-files-suppression}'[generate checks/files suppressions]' \
  '-s=[suppress at line:column]:position:' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-E --executeIgnoredModules)'{-E,--executeIgnoredModules}'[execute ignored modules]' \
  '*:file:_files -g "*.java"'
