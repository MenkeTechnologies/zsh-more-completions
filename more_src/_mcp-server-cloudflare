#compdef mcp-server-cloudflare
# Documentation: https://github.com/cloudflare/mcp-server-cloudflare
# Reference accessed: 2026-05-23
# Verified: @cloudflare/mcp-server-cloudflare CLI (init and run commands).

# Zsh completion for mcp-server-cloudflare - Cloudflare MCP server installer and runner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mcp-server-cloudflare command' \
      'init[connect Cloudflare API and install MCP server]' \
      'run[run Cloudflare MCP server]' && ret=0
    ;;
esac

return ret
