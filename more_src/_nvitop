#compdef nvitop
# Documentation: https://github.com/XuehaiPan/nvitop
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nvitop - interactive NVIDIA GPU process viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show version number and exit]' \
  '(-m --monitor)'{-m,--monitor}'[run as a resource monitor]:mode:(auto full compact)' \
  '(-1 --once)'{-1,--once}'[report query data only once]' \
  '--interval=[update interval (seconds)]:seconds:' \
  '(-U --no-unicode --ascii)'{-U,--no-unicode,--ascii}'[use ASCII characters only]' \
  '--readonly[disable process-mutating features]' \
  '--colorful[use gradient colors for spectrum-like bar charts]' \
  '--force-color[force colorize even when stdout is not a TTY]' \
  '--light[tweak visuals for light theme terminals]' \
  '--gpu-util-thresh=[GPU utilization thresholds (default: 10 75)]:th1 th2:' \
  '--mem-util-thresh=[GPU memory percent thresholds (default: 10 80)]:th1 th2:' \
  '(-o --only)'{-o,--only}'[show specified devices only]:indices:' \
  '(-ov --only-visible)'{-ov,--only-visible}'[show only CUDA_VISIBLE_DEVICES]' \
  '(-c --compute)'{-c,--compute}'[show only compute context processes (C or C+G)]' \
  '(-C --only-compute)'{-C,--only-compute}'[show only compute context processes (C only)]' \
  '(-g --graphics)'{-g,--graphics}'[show only graphics context processes (G or C+G)]' \
  '(-G --only-graphics)'{-G,--only-graphics}'[show only graphics context (G only)]' \
  '(-u --user)'{-u,--user}'[show processes of specified users]:user:_users' \
  '(-p --pid)'{-p,--pid}'[show processes with specified PIDs]:pids:' && ret=0

return ret
