#compdef nvitop

# Zsh completion for nvitop - interactive NVIDIA GPU process viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-m --monitor)'{-m,--monitor}'[run as a resource monitor]' \
  '(-o --only)'{-o,--only}'[only show GPU processes]:mode:(auto compute graphics)' \
  '(-1 --once)'{-1,--once}'[print once and exit (non-interactive)]' \
  '--ascii[use ASCII characters for bar graphs]' \
  '--colorful[force colorful output]' \
  '--light[enable light mode for terminal with light background]' \
  '--gpu-util-thresh=[set GPU utilization thresholds for coloring]:low,high' \
  '--mem-util-thresh=[set GPU memory utilization thresholds for coloring]:low,high' \
  '(-U --user)'{-U,--user}'[only show processes of specified user]:user:_users' \
  '(-p --pid)'{-p,--pid}'[only show specified PIDs]:pid' \
  '(-f --force-color)'{-f,--force-color}'[force colorful output]' \
  '--version[show version information]' \
  '(-h --help)'{-h,--help}'[show help message]' && ret=0

return ret
