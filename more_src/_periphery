#compdef periphery

# Zsh completion for periphery - Periphery Swift dead code detection

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'scan:Scan for unused code'
      'clear-cache:Clear the build cache'
      'version:Display the current version'
    )
    _describe -t commands 'periphery commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      scan)
        _arguments -s -S \
          '--config=[path to configuration file]:config file:_files -g "*.yml"' \
          '--workspace=[path to workspace (.xcworkspace)]:workspace file:_files -g "*.xcworkspace"' \
          '--project=[path to project (.xcodeproj)]:project file:_files -g "*.xcodeproj"' \
          '*--schemes=[schemes to build]:scheme:' \
          '*--targets=[targets to analyze]:target:' \
          '*--index-exclude=[exclude files from indexing matching pattern]:pattern:' \
          '*--report-exclude=[exclude results matching pattern]:pattern:' \
          '--retain-public[retain all public declarations]' \
          '*--retain-assign-only-property-types=[property types to retain]:type:' \
          '--retain-objc-accessible[retain declarations accessible by ObjC]' \
          '--retain-objc-annotated[retain ObjC annotated declarations]' \
          '--retain-unused-protocol-func-params[retain unused protocol function parameters]' \
          '*--external-encodable-protocols=[external protocols that conform to Encodable]:protocol:' \
          '--disable-redundant-public-analysis[disable redundant public accessibility analysis]' \
          '--clean-build[perform a clean build]' \
          '--skip-build[skip the build phase]' \
          '--index-store-path=[path to index store]:path:_files -/' \
          '*--retain-files=[retain files matching pattern]:pattern:' \
          '--format=[output format]:format:(xcode json csv codeclimate github-actions)' \
          '--strict[exit with non-zero status on warnings]' \
          '--quiet[suppress non-error output]' \
          '--verbose[enable verbose output]' \
          '--baseline=[path to baseline file]:baseline file:_files' \
          '--write-baseline=[write baseline to file]:baseline file:_files' && ret=0
        ;;
      clear-cache)
        ;;
      version)
        ;;
    esac
    ;;
esac

return ret
