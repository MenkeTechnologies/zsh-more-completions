#compdef periphery
# Documentation: https://github.com/peripheryapp/periphery
# Reference accessed: 2026-05-20
# Verified: upstream Sources/Frontend/Commands/ScanCommand.swift.

# Zsh completion for periphery - Periphery Swift dead code detection

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'scan:Scan for unused code'
      'clear-cache:Clear the build cache'
      'check-update:Check for updates'
      'version:Display the current version'
    )
    _describe -t commands 'periphery commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      scan)
        _arguments -s -S \
          '--setup[enable guided setup]' \
          '--project-root=[path to project root directory]:dir:_directories' \
          '--config=[path to configuration file]:config file:_files -g "*.yml"' \
          '--project=[path to .xcodeproj or .xcworkspace]:project:_files' \
          '*--schemes=[schemes to build]:scheme:' \
          '--format=[output format]:format:(xcode csv json checkstyle codeclimate github-actions github-markdown gitlab-codequality)' \
          '--exclude-tests[exclude test targets from indexing]' \
          '*--exclude-targets=[targets to exclude from indexing]:target:' \
          '*--index-exclude=[source file globs to exclude from indexing]:pattern:' \
          '*--report-exclude=[source file globs to exclude from results]:pattern:' \
          '*--report-include=[source file globs to include in results]:pattern:' \
          '*--retain-files=[source file globs whose containing declarations are retained]:pattern:' \
          '*--index-store-path=[path(s) to index store, implies --skip-build]:path:_files -/' \
          '--retain-public[retain all public declarations]' \
          '*--no-retain-spi=[public SPI names to check even with --retain-public]:spi:' \
          '--disable-redundant-public-analysis[disable redundant public accessibility analysis]' \
          '--disable-unused-import-analysis[disable unused import analysis]' \
          '--superfluous-ignore-comments[report superfluous ignore comments]' \
          '--no-superfluous-ignore-comments[suppress superfluous ignore comment reports]' \
          '*--retain-unused-imported-modules=[names of unused imported modules to retain]:module:' \
          '--retain-assign-only-properties[retain assign-only properties]' \
          '*--retain-assign-only-property-types=[assign-only property types to retain]:type:' \
          '*--external-encodable-protocols=[external Encodable-inheriting protocols]:protocol:' \
          '*--external-codable-protocols=[external Codable-inheriting protocols]:protocol:' \
          '*--external-test-case-classes=[external XCTestCase subclasses]:class:' \
          '--retain-objc-accessible[retain ObjC-accessible declarations]' \
          '--retain-objc-annotated[retain @objc-annotated declarations]' \
          '--retain-unused-protocol-func-params[retain unused protocol function parameters]' \
          '--retain-swift-ui-previews[retain SwiftUI previews]' \
          '--retain-codable-properties[retain Codable type properties]' \
          '--retain-encodable-properties[retain Encodable-only properties]' \
          '--retain-equatable-properties[retain Equatable/Hashable properties]' \
          '--retain-hashable-properties[retain Hashable properties]' \
          '--clean-build[clean existing build artifacts before building]' \
          '--skip-build[skip the build phase]' \
          '--skip-schemes-validation[skip schemes validation]' \
          '--relative-results[output result paths relative to cwd]' \
          '--strict[exit non-zero if any unused code found]' \
          '--disable-update-check[disable update check]' \
          '--verbose[enable verbose logging]' \
          '--quiet[only output results]' \
          '--color=[colored output mode]:mode:(auto always never)' \
          '--no-color[disable colored output]' \
          '--json-package-manifest-path=[JSON package manifest path]:file:_files' \
          '--baseline=[baseline file path used to filter results]:file:_files' \
          '--write-baseline=[baseline file path to write]:file:_files' \
          '--write-results=[file path for formatted results]:file:_files' \
          '--generic-project-config=[non-Apple build system project config]:file:_files' \
          '--bazel[enable Bazel project mode]' \
          '--bazel-filter=[Bazel top-level targets query filter]:filter:' \
          '--bazel-query=[Bazel top-level targets query expression]:query:' \
          '--bazel-index-store=[global Bazel index store path]:path:_files -/' \
          '--bazel-check-visibility[enable Bazel visibility checking]' \
          '*::build args:_default' && ret=0
        ;;
      clear-cache|check-update|version)
        ;;
    esac
    ;;
esac

return ret
