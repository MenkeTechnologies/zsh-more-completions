#compdef flow

# Zsh completion for Flow (Facebook Flow type checker for JavaScript)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a .flowconfig'
  'check:do a full check and print errors'
  'status:show current errors (start server if needed)'
  'start:start the Flow server'
  'stop:stop the Flow server'
  'ast:print the AST'
  'autocomplete:queries autocomplete information'
  'batch-coverage:show aggregate coverage information'
  'check-contents:check contents from stdin'
  'coverage:show coverage information for a file'
  'cycle:show dependency cycles'
  'find-module:resolve a module name to a file'
  'find-refs:find references to a definition'
  'force-recheck:force recheck of changed files'
  'get-def:get definition location'
  'graph:output dependency graph'
  'ls:list files tracked by Flow'
  'server:run the Flow server in foreground'
  'suggest:suggest types for a file'
  'type-at-pos:show type at a given position'
  'version:print version information'
)

_arguments -s -S \
  '1:command:->command' \
  '--all[check all files, not just those with @flow]' \
  '--color[use colors in output]:when:(auto always never)' \
  '--from[specify caller]:caller' \
  '--json[output results in JSON format]' \
  '--max-workers[maximum number of workers]:count' \
  '--no-auto-start[do not auto-start the server]' \
  '--quiet[suppress output]' \
  '--root[specify project root]:directory:_files -/' \
  '--retries[number of retries on connection failure]:count' \
  '--strip-root[strip root directory from paths]' \
  '--temp-dir[specify temp directory]:directory:_files -/' \
  '--timeout[timeout in seconds]:seconds' \
  '--version[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flow command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (check|status)
        _arguments \
          '--all[check all files]' \
          '--json[output JSON]' \
          '--show-all-errors[show all errors]' \
          '--show-all-branches[show all branches in error messages]' \
          '--max-workers[max workers]:count' \
          '*:file:_files -g "*.(js|jsx|ts|tsx|mjs)(N)"' && ret=0
        ;;
      (coverage|type-at-pos|get-def|find-refs|suggest|autocomplete)
        _arguments \
          '--json[output JSON]' \
          '--strip-root[strip root directory]' \
          '1:file:_files -g "*.(js|jsx|ts|tsx|mjs)(N)"' \
          '2:line' \
          '3:column' && ret=0
        ;;
      (find-module)
        _arguments '1:module name' && ret=0
        ;;
      (init)
        _arguments '--options[include all options in generated config]' && ret=0
        ;;
      (ls)
        _arguments \
          '--all[include ignored files]' \
          '--json[output JSON]' \
          '*:root:_files -/' && ret=0
        ;;
      (force-recheck)
        _arguments '*:file:_files' && ret=0
        ;;
      (start|stop|server)
        _arguments \
          '--all[check all files]' \
          '--max-workers[max workers]:count' \
          '--lazy-mode[start in lazy mode]:mode:(fs ide watchman none)' && ret=0
        ;;
    esac
    ;;
esac

return ret
