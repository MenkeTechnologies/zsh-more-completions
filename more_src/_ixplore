#compdef ixplore
# Documentation: https://doc.powerdns.com/authoritative/manpages/ixplore.1.html
# Work with IXFR incremental zone transfers in diff or track modes

local ret=1

_arguments -C \
  '1:command:(diff track)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      diff)
        _arguments \
          '1:zone:' \
          '2:before:_files' \
          '3:after:_files' && ret=0
        ;;
      track)
        _arguments \
          '1:ip-address:_hosts' \
          '2:port:_ports' \
          '3:zone:' \
          '4:directory:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
