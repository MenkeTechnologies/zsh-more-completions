#compdef customfetch
# Documentation: https://github.com/Toni500github/customfetch
# customfetch - a system information tool focused on customizability and performance

local ret=1

_arguments -s -S \
  '-h[show all CLI arguments]' \
  '-w[show comprehensive guide on tags, colors, and syntax]' \
  '-l[list all available modules including from plugins]' \
  '--gen-config=[regenerate the default config file]:path:_files' \
  '-C[use a custom config file]:path:_files' \
  '-n[disable logo display]' \
  '-N[disable all colors]' \
  '-d[use a specific distro logo]:distro:' \
  '-s[path to custom ASCII art or image]:path:_files' \
  '(-i --image-backend)'{-i,--image-backend}'[specify image backend]:backend:' \
  '-m[display specific modules only]:module:' \
  '--loop-ms=[update display every given interval in milliseconds]:milliseconds:' && ret=0

return ret
