#compdef bam bluesky-account-migrator
# ============================================================================
# _bam — zsh completion for rekmarks/bluesky-account-migrator (`bam`)
#         — the Bluesky account migration CLI (@atproto/api)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/rekmarks/bluesky-account-migrator
#   Author     : Erik Marks (rekmarks)
#   License    : MIT
#   Language   : TypeScript
#   Package    : bluesky-account-migrator  (npm)
#   Binaries   : bam, bluesky-account-migrator
#                (package.json bin: bam → dist/main.mjs;  the npm
#                 package name is also a binary via npm's default
#                 npm-prefix-handling)
#   Last push  : 2026-02-01
#
# WHAT IT IS
#   bluesky-account-migrator (`bam`) is "a simple CLI for migrating
#   Bluesky accounts from one PDS to another" — a long-form Bluesky
#   account migration utility that walks the full AT Protocol
#   `com.atproto.server.*` migration handshake.  The CLI runs in one
#   of two modes:  an **interactive** mode that prompts via inquirer
#   for the source/destination handle, app password, invite code,
#   and any 2FA/email-confirmation tokens;  or a **pipe** mode that
#   reads a JSON envelope of all required credentials from stdin
#   (for use in scripted/CI migrations).  Under the hood every
#   step is performed by an `AtpAgent` from `@atproto/api`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli.ts yargs builder +
#                       src/commands/migrate/index.ts CommandModule)
#   bam [migrate | m] [OPTIONS]
#   bluesky-account-migrator [migrate | m] [OPTIONS]
#
#   `bam` and `bluesky-account-migrator` are equivalent wrappers
#   around the same yargs entry point.  The default command (`$0`)
#   is `migrate` itself — so a bare invocation runs the migration.
#
#   Global flags:
#     -h, --help                Show help
#     -v, --version             Show version
#         --debug               Show error stack traces  [boolean,
#                                                         default false]
#
#   Command:
#     migrate (alias: m, default `$0`)
#         Perform an account migration.  Mode group (choose one):
#       -i, --interactive       Run in interactive mode (inquirer
#                               prompts).  Conflicts with --pipe.
#                               Defaults to true when neither
#                               --interactive nor --pipe is supplied.
#       -p, --pipe              Run in pipe mode (read a JSON
#                               credentials envelope from stdin).
#                               Conflicts with --interactive.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `@atproto/api ^0.14.19` declared in
#   package.json — the canonical TypeScript AT Protocol client
#   maintained by Bluesky PBC (bluesky-social/atproto, npm package
#   `@atproto/api`).  @atproto/api is the typed, lexicon-generated
#   TypeScript binding to every public AT Protocol Lexicon
#   (`com.atproto.*` / `app.bsky.*` namespaces), the canonical
#   counterpart of `atrium-rs/atrium`'s Rust bindings (R881 _bsky-cli)
#   and `bluesky-social/indigo`'s Go bindings (R882 _atr).  bam's
#   `src/migration/` uses an `AtpAgent` instance to run the
#   migration handshake:  source `com.atproto.server.getServiceAuth`
#   → destination `com.atproto.server.createAccount` → source
#   `com.atproto.server.deactivateAccount` → destination
#   `com.atproto.identity.updateHandle` → destination
#   `com.atproto.repo.importRepo` + `uploadBlob` per blob.  Verified
#   via:
#     gh api repos/rekmarks/bluesky-account-migrator/contents/package.json
#       → "@atproto/api": "^0.14.19"
#     gh api repos/rekmarks/bluesky-account-migrator/contents/src/main.ts
#       → cli(process.argv, commands)
#   This entry is the TS-Node=128 leader bump that CLOSES Axis 73
#   (AT Protocol / Bluesky SDK) at 1/1/1 three-language symmetry —
#   pairing Rust=atrium-rs/bsky-sdk + atrium-api (R881 _bsky-cli),
#   Go=bluesky-social/indigo (R882 _atr), and TS-Node=@atproto/api
#   ^0.14.19 (this entry).  Triple-128 landmark on commit.
#
#   No completion for `bam` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `_bam-loader` in this corpus targets an unrelated
#   tool;  `bam` is the bluesky-account-migrator binary.
# ============================================================================

_bam() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--debug[show error stack traces]' \
        '1: :_bam_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                migrate|m)
                    _arguments \
                        '(-i --interactive -p --pipe)'{-i,--interactive}'[run in interactive mode (default; conflicts with --pipe)]' \
                        '(-i --interactive -p --pipe)'{-p,--pipe}'[run in pipe mode (stdin JSON credentials; conflicts with --interactive)]' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bam_commands] )) ||
_bam_commands() {
    local -a commands
    commands=(
        'migrate:perform an account migration (default command)'
        'm:perform an account migration (alias for migrate)'
    )
    _describe -t commands 'bam command' commands
}

_bam "$@"
