#compdef amp-code
# Documentation: https://ampcode.com
# Reference accessed: 2026-05-23
# Verified: npx @sourcegraph/amp --help.

# Zsh completion for amp-code - Sourcegraph Amp coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'amp command' \
      'version[print version and exit]' \
      'logout[remove stored API key]' \
      'login[log in to Amp]' \
      'threads[manage threads]' \
      't[alias for threads]' \
      'thread[alias for threads]' \
      'tools[tool management]' \
      'tool[alias for tools]' \
      'review[run code review]' \
      'skill[manage skills]' \
      'skills[alias for skill]' \
      'permissions[manage permissions]' \
      'permission[alias for permissions]' \
      'mcp[manage MCP servers]' && ret=0
    ;;
  args)
    case $line[1] in
      threads|t|thread)
        _arguments -C \
          '1:subcommand:->thread_cmds' \
          '*:: :->thread_args' && ret=0
        case $state in
          thread_cmds)
            _values 'amp threads command' \
              'new[create thread]' 'n[alias for new]' \
              'continue[continue thread]' 'c[alias for continue]' \
              'list[list threads]' 'l[alias for list]' 'ls[alias for list]' \
              'usage[show thread usage]' \
              'visibility[show or set visibility]' 'v[alias for visibility]' \
              'search[search threads]' 'find[alias for search]' \
              'label[add labels]' \
              'share[share thread]' 's[alias for share]' \
              'report[report thread to support]' \
              'rename[rename thread]' 'r[alias for rename]' \
              'archive[archive thread]' \
              'delete[delete thread]' \
              'handoff[create handoff thread]' 'h[alias for handoff]' \
              'markdown[render as markdown]' 'md[alias for markdown]' \
              'export[export thread as JSON]' && ret=0
            ;;
        esac
        ;;
      tools|tool)
        _arguments \
          '1:subcommand:(list ls show make use)' && ret=0
        ;;
      skill|skills)
        _arguments \
          '1:subcommand:(add list ls remove rm info)' && ret=0
        ;;
      permissions|permission)
        _arguments \
          '1:subcommand:(list ls test edit add)' && ret=0
        ;;
      mcp)
        _arguments \
          '1:subcommand:(add list remove)' && ret=0
        ;;
    esac
    ;;
esac

return ret
