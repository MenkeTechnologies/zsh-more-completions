#compdef calico-node
# Documentation: https://github.com/projectcalico/calico
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# calico-node: Calico per-node agent
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'startup:run startup tasks'
  'allocate-tunnel-addrs:allocate tunnel addresses'
  'monitor-token:monitor token'
  'shutdown:run shutdown tasks'
  'felix:run Felix dataplane'
  'bird:run BIRD BGP daemon'
  'confd:run confd template engine'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--ipv4[run IPv4]' \
  '--ipv6[run IPv6]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'calico-node command' commands && ret=0 ;;
esac
return ret
