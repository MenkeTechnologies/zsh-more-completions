#compdef imframe
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imframe.html
# MIRIAD imframe - enlarge an image by padding with zeros

local ret=1

_arguments -s -S \
  'in=[input image (no default)]:in:_files' \
  'region=[region of the input data]:region' \
  'box=[coordinate ranges xmin,xmax,ymin,ymax in relative pixels]:box' \
  'out=[output image (no default)]:out:_files' \
  'frame=[output dataset dimensions as coordinate ranges]:frame' \
  'goal=[new axis ordering (e.g. zxy), - to reverse]:goal' \
  '*:image:_files' && ret=0

return ret
