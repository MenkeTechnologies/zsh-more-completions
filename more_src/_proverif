#compdef proverif proverif_test pvanaltrace
# Documentation: https://bblanche.gitlabpages.inria.fr/proverif/manual.pdf
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-in+[input language]:lang:(pi pitype horn hornxml horntype)' \
  '-test[test mode]' \
  '-color[colored output]' \
  '-html+[output HTML to dir]:dir:_files -/' \
  '-graph+[output traces to dir]:dir:_files -/' \
  '-allow-private-comm-on-public-free-names[allow private comm]' \
  '-no-saturation[disable saturation]' \
  '-precise[precise mode]' \
  '-noprecise[no precise mode]' \
  '-check-no-channel-renaming[no chan rename]' \
  '-tex+[LaTeX output]:file:_files' \
  '-lib+[library file]:file:_files -g "*.pv *.pvl"' \
  '-set+[set option]:opt:' \
  '-DontIgnoreErrors[do not ignore errors]' \
  '-only-fact+[only fact]:fact:' \
  '-allowDiffPatterns[allow diff patterns]' \
  '-not-injective[no injective]' \
  '-noequations[no equations]' \
  '-out+[output type]:t:(equiv events pred)' \
  '*: :_files -g "*.pv *.pvl *.horn"' && ret=0

return ret
