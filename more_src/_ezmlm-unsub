#compdef ezmlm-unsub
# Documentation: https://man.archlinux.org/search?q=ezmlm-unsub
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-n[digest list]' \
  '-N[normal list]' \
  '-m[suppress mail notification]' \
  '-M[send notification]' \
  '1:dir:_files -/' \
  '*:address:' && ret=0

return ret
