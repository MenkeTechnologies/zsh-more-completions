#compdef wire
# Documentation: https://github.com/google/wire
# Reference accessed: 2026-05-21
# Verified: upstream source at https://raw.githubusercontent.com/google/wire/main/cmd/wire/main.go

# Zsh completion for Wire - Go dependency injection code generator

local curcontext="$curcontext" state line ret=1

local -a wire_commands
wire_commands=(
  'check:check that all injectors can be satisfied'
  'diff:show diff between existing and generated code'
  'gen:generate injector code'
  'show:show information about injectors'
  'commands:list all command names'
  'help:describe subcommands and their syntax'
  'flags:describe all known top-level flags'
)

_arguments -C \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'wire command' wire_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      gen)
        _arguments \
          '-header_file=[path to header file for generated code]:file:_files' \
          '-output_file_prefix=[prefix for output files]:prefix:' \
          '-tags=[build tags to set]:tags:' \
          '*:package patterns:_files -/' && ret=0
        ;;
      diff)
        _arguments \
          '-header_file=[path to header file for generated code]:file:_files' \
          '-tags=[build tags to set]:tags:' \
          '*:package patterns:_files -/' && ret=0
        ;;
      check)
        _arguments \
          '-tags=[build tags to set]:tags:' \
          '*:package patterns:_files -/' && ret=0
        ;;
      show)
        _arguments \
          '-tags=[build tags to set]:tags:' \
          '*:package patterns:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
