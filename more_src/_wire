#compdef wire

# Zsh completion for Wire - Go dependency injection code generator

local curcontext="$curcontext" state line ret=1

local -a wire_commands
wire_commands=(
  'check:check that all injectors can be satisfied'
  'diff:show diff between existing and generated code'
  'gen:generate injector code'
  'show:show information about injectors'
  'version:print version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--header-file=[path to header file for generated code]:file:_files -g "*.go"' \
  '--output-file-prefix=[prefix for output files]:prefix:' \
  '--tags=[build tags to set]:build tags:' \
  '1:command:_describe -t commands command wire_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      gen|diff|check)
        _arguments -s -S \
          '--header-file=[path to header file for generated code]:file:_files -g "*.go"' \
          '--output-file-prefix=[prefix for output files]:prefix:' \
          '--tags=[build tags to set]:build tags:' \
          '*:package patterns:_files -/' && ret=0
        ;;
      show)
        _arguments -s -S \
          '*:package patterns:_files -/' && ret=0
        ;;
      version)
        ;;
    esac
    ;;
esac

return ret
