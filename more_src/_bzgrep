#compdef bzgrep bzegrep bzfgrep
# _bzgrep — bzip2 bzgrep family (decompress .bz2/.gz/.Z inputs and pipe to grep/egrep/fgrep — bzip2-shipped shell wrapper at bzip2/bzgrep)
# upstream: https://gitlab.com/bzip2/bzip2
# Flags forwarded directly to grep(1); see bzip2/bzgrep on tip.

_bzgrep() {
    _arguments \
        '-E[extended regex]' \
        '-F[fixed strings]' \
        '-G[basic regex]' \
        '-i[case-insensitive]' \
        '-n[print line numbers]' \
        '-l[print only filenames with match]' \
        '-c[count matches]' \
        '-q[quiet]' \
        '-v[invert match]' \
        '-w[whole word]' \
        '-x[whole line]' \
        '-h[suppress filename prefix]' \
        '-H[force filename prefix]' \
        '-e+[pattern]:pattern:' \
        '-f+[pattern file]:file:_files' \
        '-A+[trailing context]:n:' \
        '-B+[leading context]:n:' \
        '-C+[context]:n:' \
        '1:pattern:' \
        '*:file:_files'
}

_bzgrep "$@"
