#compdef rad

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'init:initialize a new radicle repository'
      'clone:clone a radicle repository'
      'id:manage your radicle identity'
      'self:show your identity'
      'inspect:inspect a radicle object'
      'ls:list repositories'
      'sync:sync with the network'
      'fetch:fetch updates from seeds'
      'push:push changes to the network'
      'pull:pull changes from the network'
      'fork:fork a repository'
      'patch:manage patches'
      'issue:manage issues'
      'review:manage reviews'
      'assign:assign to issues or patches'
      'label:manage labels'
      'node:manage your radicle node'
      'seed:manage seed policies'
      'follow:follow a peer'
      'unfollow:unfollow a peer'
      'track:track a repository'
      'untrack:untrack a repository'
      'remote:manage remotes'
      'cob:manage collaborative objects'
      'path:show radicle paths'
      'web:open the web interface'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init)
        _arguments \
          '--name=[project name]:name:' \
          '--description=[project description]:description:' \
          '--default-branch=[default branch]:branch:' \
          '--scope=[visibility scope]:scope:(private public)' \
          '--set-upstream[set as upstream]' && ret=0
        ;;
      (clone)
        _arguments \
          '--scope=[visibility scope]:scope:(private public)' \
          '1:repository ID:' && ret=0
        ;;
      (patch)
        _arguments \
          '1:action:(list show create update comment merge delete checkout ready review archive)' && ret=0
        ;;
      (issue)
        _arguments \
          '1:action:(list show create comment close reopen delete label assign)' && ret=0
        ;;
      (node)
        _arguments \
          '1:action:(start stop status config routing events)' && ret=0
        ;;
      (sync)
        _arguments \
          '--fetch[only fetch]' \
          '--announce[only announce]' \
          '--timeout=[timeout in seconds]:seconds:' && ret=0
        ;;
    esac
    ;;
esac

return ret
