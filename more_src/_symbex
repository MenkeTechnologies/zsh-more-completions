#compdef symbex
# Documentation: https://github.com/simonw/symbex
# Find symbols in Python code and print the code for them

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--version[show version]' \
  '*'{-f,--file}'+[search within specified files]:file:_files' \
  '*'{-d,--directory}'+[search within directories]:directory:_files -/' \
  '--stdlib[search the Python standard library]' \
  '*'{-x,--exclude}'+[exclude directories]:directory:_files -/' \
  '*'{-m,--module}'+[search within importable modules]:module:' \
  '*--sys-path+[calculate imports relative to paths]:path:_files -/' \
  '(-s --signatures)'{-s,--signatures}'[show just signatures]' \
  '(-n --no-file)'{-n,--no-file}'[omit file location comments]' \
  '(-i --imports)'{-i,--imports}'[include import statements]' \
  '(--docs --docstrings)'{--docs,--docstrings}'[show signatures with docstrings]' \
  '--count[show count of matching symbols]' \
  '--silent[suppress parse error warnings]' \
  '--function[match functions]' \
  '--async[match async functions]' \
  '--unasync[match non-async functions]' \
  '--class[match classes]' \
  '--documented[match symbols with docstrings]' \
  '--undocumented[match symbols without docstrings]' \
  '--public[match public symbols]' \
  '--private[match private symbols]' \
  '--dunder[match __*__ dunder methods]' \
  '--typed[match functions with type annotations]' \
  '--untyped[match functions without annotations]' \
  '--partially-typed[match partially typed functions]' \
  '--fully-typed[match fully typed functions]' \
  '--no-init[exclude __init__ methods]' \
  '--replace[replace matched symbol with stdin]' \
  '--rexec+[replace by piping to a command]:command:' \
  '--check[exit non-zero if matches found]' \
  '--csv[output as CSV]' \
  '--tsv[output as TSV]' \
  '--json[output as JSON array]' \
  '--nl[output as newline-delimited JSON]' \
  '--id-prefix+[prefix for symbol identifiers]:prefix:' \
  '*:symbol:' && ret=0

return ret
