#compdef adbsync adb-sync
# Documentation: https://github.com/google/adb-sync
# Reference accessed: 2026-05-16
# Verified: upstream google/adb-sync (archived March 2025). Real binary
# name is `adb-sync` with hyphen; aliased here.
# Removed from prior file: fabricated -V/--version (uses --help only)
# and bogus man.archlinux.org search URL.

# adbsync (adb-sync): sync files to/from Android via adb
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '(-e --adb)'{-e+,--adb=}'[adb binary and arguments]:cmd:' \
  '--device[direct to only connected USB device]' \
  '--emulator[direct to only running emulator]' \
  '(-s --serial)'{-s+,--serial=}'[direct to device/emulator with serial]:serial:' \
  '(-H --host)'{-H+,--host=}'[adb server host (default localhost)]:host:_hosts' \
  '(-P --port)'{-P+,--port=}'[adb server port (default 5037)]:port:' \
  '(-R --reverse)'{-R,--reverse}'[reverse sync (pull not push)]' \
  '(-2 --two-way)'{-2,--two-way}'[two-way sync (compare mtime)]' \
  '(-t --times)'{-t,--times}'[preserve modification times]' \
  '(-d --delete)'{-d,--delete}'[delete files from dst not on src]' \
  '(-f --force)'{-f,--force}'[allow deleting files when replacing]' \
  '(-n --no-clobber)'{-n,--no-clobber}'[do not overwrite existing files]' \
  '(-L --copy-links)'{-L,--copy-links}'[transform symlinks into referent]' \
  '--dry-run[show what would be done without doing it]' \
  '*:src/dst:_files' && ret=0
return ret
