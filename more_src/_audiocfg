#compdef audiocfg
# Documentation: man audiocfg(1)
# Source: netbsd/src usr.bin/audiocfg — audio device configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:command:(list default set test)' \
    '2::device index:_default' \
    '*::arg:_default' \
    && ret=0

return ret
