#compdef rnacofold
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAcofold.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAcofold: predict structure for two co-folded RNAs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-p --partfunc)'{-p,--partfunc=-}'[compute partition function]::n:' \
  '(-a --all_pf)'{-a,--all_pf=-}'[compute all partition functions]::n:' \
  '(-c --concentrations)'{-c,--concentrations}'[compute concentrations]' \
  '(-f --concfile)'{-f,--concfile=}'[concentration file]:file:_files' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '--bppmThreshold=[bpp threshold for plots]:thresh:' \
  '(-g --gquad)'{-g,--gquad}'[G-quadruplex formation]' \
  '(-S --pfScale)'{-S,--pfScale=}'[pf scaling factor]:factor:' \
  '--MEA=[maximum expected accuracy structure]:gamma:' \
  '--centroid[output centroid structure]' \
  '--auto-id[auto-generate sequence IDs]' \
  '--noPS[suppress PostScript output]' \
  '*:RNA sequences (separated by &):_files' && ret=0
return ret
