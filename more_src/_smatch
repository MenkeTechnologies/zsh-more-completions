#compdef smatch
# C source code static analysis checker

local ret=1

_arguments -s -S \
  '-p[specify project]:project:' \
  '-D[define preprocessor symbol]:symbol:' \
  '-I[specify include path]:directory:_files -/' \
  '-W[specify warning level]:level:' \
  '--debug[enable debug mode]' \
  '--no-data[do not use smatch_data]' \
  '--two-passes[run two passes]' \
  '--file-output[output to file]' \
  '--succeed[always exit with 0]' \
  '--info[output informational messages]' \
  '--spammy[output extra warnings]' \
  '--full-path[use full file paths]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:source files:_files -g "*.(c|h)"' && ret=0

return ret
