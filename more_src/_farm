#compdef farm

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a common_flags=(
  {-c,--config}'=[config file]:config file:_files'
  '--root=[project root directory]:directory:_directories'
  '--mode=[build mode]:mode:(development production)'
  '--base=[public base path]:path'
  '--clearScreen[clear screen before logging]'
  '--no-clearScreen[do not clear screen before logging]'
  '--lazy-compilation[enable lazy compilation]'
  '--no-lazy-compilation[disable lazy compilation]'
  '--minify[enable minification]'
  '--no-minify[disable minification]'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  $common_flags \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:Start dev server'
      'dev:Start dev server'
      'build:Build for production'
      'preview:Preview production build'
      'watch:Watch and rebuild on changes'
      'clean:Clean build artifacts'
      'plugin:Plugin management'
    )
    _describe -t commands 'farm command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start|dev|preview)
        _arguments -s -S \
          $common_flags \
          '--port=[server port]:port' \
          '--host=[server host]:host' \
          '--open[open browser on start]' \
          '--https[enable HTTPS]' \
          '--strictPort[exit if port is in use]' \
          '--hmr[enable hot module replacement]' \
          '--no-hmr[disable hot module replacement]' && ret=0
        ;;
      build)
        _arguments -s -S \
          $common_flags \
          {-o,--outDir}'=[output directory]:directory:_directories' \
          '--sourcemap[generate source maps]' \
          '--target=[build target]:target' \
          {-w,--watch}'[watch mode]' && ret=0
        ;;
      watch)
        _arguments -s -S $common_flags && ret=0
        ;;
      clean)
        _arguments -s -S $common_flags && ret=0
        ;;
      plugin)
        local -a plugin_cmds=(
          'create:Create a new plugin'
        )
        _describe -t commands 'plugin subcommand' plugin_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
