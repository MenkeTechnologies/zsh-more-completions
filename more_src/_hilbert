#compdef hilbert
# Documentation: https://4ti2.github.io/hilbert.html
# 4ti2: compute the Hilbert basis of cones and lattices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '--version[display version information]' \
  '(-p --precision)'{-p,--precision=}'[integer precision: 32, 64, gmp]:precision:(32 64 gmp)' \
  '(-m --maxnorm)'{-m,--maxnorm}'[write max-norm vectors to PROJECT.maxnorm]' \
  '(-b --backup)'{-b,--backup=}'[frequently backup status to PROJECT.backup]:freq:' \
  '(-r --resume)'{-r,--resume}'[resume from backup file PROJECT.backup]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-u --update)'{-u,--update=}'[updated output on console]:level:(1 2)' \
  '(-v --verbose)'{-v,--verbose=}'[verbose output]:level:(1 2 3)' \
  '(-n --log)'{-n,--log=}'[logging level to PROJECT.log]:level:(0 1 2 3)' \
  '*:project:_files' && ret=0

return ret
