#compdef rusty-tags
# Documentation: https://github.com/dan-t/rusty-tags
# Create ctags/etags for a cargo project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-s --start-dir)'{-s,--start-dir}'+[start directory for Cargo.toml search]:dir:_files -/' \
  '(-O --output)'{-O,--output}'+[name of output tags file]:filename:_files' \
  '(-o --omit-deps)'{-o,--omit-deps}'[do not generate tags for dependencies]' \
  '(-f --force-recreate)'{-f,--force-recreate}'[force recreation of dependency and std tags]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output about all operations]' \
  '(-q --quiet)'{-q,--quiet}'[output nothing but errors]' \
  '(-n --num-threads)'{-n,--num-threads}'+[threads used for tags creation]:num:' \
  '1:tags kind:(vi emacs)' && ret=0

return ret
