#compdef cutter cut-diff
# Documentation: https://manpages.org/cutter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# clear-code/cutter — Cutter unit testing framework for C/C++

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show common options]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--mode=[run mode]:mode:(test analyze)' \
  '(-m --multi-thread)'{-m,--multi-thread}'[run tests in separate threads]' \
  '--max-threads=[max concurrent threads]:n:' \
  '(-t --test-case)'{-t,--test-case}'=[filter by test case name (regex with /)]:name:' \
  '(-n --name)'{-n,--name}'=[filter by test name (regex with /)]:name:' \
  '(-u --ui)'{-u,--ui}'=[user interface]:ui:(console gtk)' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(s n v)' \
  '(-c --color)'{-c,--color}'=[colored output]:mode:(yes no auto)' \
  '--pdf-report=[export PDF report]:file:_files' \
  '--xml-report=[export XML report]:file:_files' \
  '--log-level=[log verbosity]:level:' \
  '--stream=[stream backend]:backend:(xml)' \
  '--stream-directory=[stream output directory]:dir:_files -/' \
  '(-s --source-directory)'{-s,--source-directory}'=[prepend to file paths]:dir:_files -/' \
  '--disable-signal-handling[disable signal handling]' \
  '--fatal-failures[stop on test failures]' \
  '--stop-before-test[set breakpoint before each test]' \
  '*:test directory:_files -/' && ret=0

return ret
