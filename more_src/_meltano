#compdef meltano

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--log-level=[log level]:level:(debug info warning error critical)' \
  '--log-config=[log config file]:file:_files' \
  '--environment=[Meltano environment]:environment:' \
  '--no-environment[do not use any environment]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'add:add a plugin to your project'
      'config:manage plugin configuration'
      'discover:list available plugins'
      'elt:run an ELT pipeline'
      'environment:manage environments'
      'hub:interact with Meltano Hub'
      'init:create a new Meltano project'
      'install:install project dependencies'
      'invoke:invoke a plugin'
      'job:manage jobs'
      'lock:manage lock files'
      'remove:remove a plugin from your project'
      'run:run a set of commands'
      'schedule:manage pipeline schedules'
      'select:manage extractor select patterns'
      'state:manage Singer state'
      'test:run tests for a plugin'
      'upgrade:upgrade Meltano'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (add)
        _arguments \
          '--custom[add a custom plugin]' \
          '--inherit-from=[inherit from existing plugin]:plugin:' \
          '--variant=[plugin variant]:variant:' \
          '1:plugin type:(extractors loaders transformers orchestrators transformers utilities files mappers)' \
          '2:plugin name:' && ret=0
        ;;
      (config)
        _arguments \
          '--format=[output format]:format:(json env dotenv)' \
          '1:plugin name:' \
          '2:action:(list set unset reset test)' && ret=0
        ;;
      (elt)
        _arguments \
          '--transform=[transform to run]:transform:(run skip only)' \
          '--catalog=[catalog file]:file:_files' \
          '--state-id=[state ID]:id:' \
          '--dump=[dump format]:format:(catalog state extractor-config loader-config)' \
          '--full-refresh[perform full refresh]' \
          '--force[force run]' \
          '1:extractor:' \
          '2:loader:' && ret=0
        ;;
      (init)
        _arguments \
          '--no-usage-stats[disable anonymous usage stats]' \
          '1:project name:' && ret=0
        ;;
      (install)
        _arguments \
          '--clean[clean install]' \
          '--parallelism=[number of parallel installs]:number:' \
          '1:plugin type:(extractors loaders transformers orchestrators transformers utilities files mappers)' && ret=0
        ;;
      (invoke)
        _arguments \
          '--dump=[dump format]:format:(config catalog state)' \
          '1:plugin name:' && ret=0
        ;;
      (run)
        _arguments \
          '--dry-run[show what would be run]' \
          '--full-refresh[perform full refresh]' \
          '--force[force run]' \
          '--no-state-update[do not update state]' \
          '*:command or plugin:' && ret=0
        ;;
      (schedule)
        _arguments \
          '1:action:(add list remove set)' && ret=0
        ;;
      (select)
        _arguments \
          '--list[list current selections]' \
          '--all[select all]' \
          '--exclude[add exclusion]' \
          '1:extractor:' \
          '*:entity or attribute:' && ret=0
        ;;
    esac
    ;;
esac

return ret
