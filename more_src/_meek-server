#compdef meek-server

# meek-server: Tor pluggable transport server for meek
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-port=[listen port]:port:' \
  '-cert=[TLS cert]:file:_files' \
  '-key=[TLS key]:file:_files' \
  '-acme-hostnames=[ACME hostnames]:hosts:' \
  '-acme-email=[ACME email]:email:' \
  '-log=[log file]:file:_files' \
  '-state=[state directory]:dir:_files -/' \
  '*::meek-server args:_files' && ret=0
return ret
