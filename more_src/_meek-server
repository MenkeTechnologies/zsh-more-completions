#compdef meek-server

# meek-server: Tor meek pluggable transport server side
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-port[listen port]:port:' \
  '-cert[TLS cert file]:file:_files' \
  '-key[TLS key file]:file:_files' \
  '-log[log file]:file:_files' \
  '-disable-tls[disable TLS termination]' \
  '*::meek-server args:_files' && ret=0
return ret
