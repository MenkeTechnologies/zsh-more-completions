#compdef bedSort
# _bedSort — UCSC Kent Lab bedSort sort a BED file first by chromosome name then by chromStart position (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/util.html

_bedSort() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '*:input output:_files -g "*.bed *.bedgraph *.bdg *.bgr *.gff *.gff3 *.gtf *.vcf"'
}

_bedSort "$@"
