#compdef slic3r
# Documentation: https://man.archlinux.org/search?q=slic3r
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)--help[show help]' \
  '(-g --export-gcode --gcode)'{-g,--export-gcode,--gcode}'[slice and export G-code]' \
  '--export-stl[export STL]' \
  '--export-amf[export AMF]' \
  '--export-3mf[export 3MF]' \
  '--export-obj[export OBJ]' \
  '--export-pov[export POV-Ray]' \
  '--export-svg[export SVG slices]' \
  '(--sla --export-sla-svg)'{--sla,--export-sla-svg}'[export SLA slices]' \
  '--info[print model info]' \
  '--save=[save config]:file:_files -g "*.ini"' \
  '(-m --merge)'{-m,--merge}'[merge models]' \
  '--dont-arrange[merge at original coords]' \
  '--center=[center point]:x,y:' \
  '--align-xy=[align point]:x,y:' \
  '--scale=[scale factor]:factor:' \
  '--scale-to-fit=[scale to fit]:x,y,z:' \
  '--rotate=[rotate angle]:angle:' \
  '--rotate-x=[rotate around X]:angle:' \
  '--rotate-y=[rotate around Y]:angle:' \
  '--duplicate=[duplicate count]:n:' \
  '--duplicate-grid=[grid layout]:x,y:' \
  '--duplicate-distance=[distance mm]:mm:' \
  '--cut=[cut at Z]:z:' \
  '--cut-x=[cut at X]:x:' \
  '--cut-y=[cut at Y]:y:' \
  '--cut-grid=[cut grid]:x,y:' \
  '--split[split unconnected parts]' \
  '--repair[repair non-manifold]' \
  '(-o --output)'{-o,--output=}'[output filename]:file:_files' \
  '--output-filename-format=[filename format]:fmt:' \
  '*--load=[config file]:file:_files -g "*.ini"' \
  '--ignore-nonexistent-config[ignore missing config]' \
  '--help-options[full options reference]' \
  '--autosave=[autosave file]:file:_files' \
  '--datadir=[data directory]:dir:_files -/' \
  '--layer-height=[layer height]:mm:' \
  '--perimeters=[perimeters]:n:' \
  '--nozzle-diameter=[nozzle diameter]:mm:' \
  '--filament-diameter=[filament diameter]:mm:' \
  '--temperature=[temperature]:c:' \
  '--first-layer-temperature=[first layer temp]:c:' \
  '--fill-pattern=[fill pattern]:pattern:' \
  '*:model:_files -g "*.(stl|obj|amf|3mf)"'
