#compdef hudi-cli hudi-cli.sh

local curcontext="$curcontext" state line ret=1
local -a top_commands

# Hudi CLI is interactive shell-based, but commands can also be executed via -c
# We document the major shell commands available within the CLI
top_commands=(
  'connect:connect to a Hudi table via base path'
  'create:initialize a new Hudi table'
  'desc:show table properties'
  'help:show help'
  'exit:exit shell'
  'quit:exit shell'
  'commits:commit operations'
  'commit:single-commit operations'
  'compaction:compaction operations'
  'compactions:list/manage compactions'
  'cleans:cleanup operation timeline'
  'clean:single-clean operations'
  'savepoint:savepoint operations'
  'savepoints:list savepoints'
  'show:show various views (fsview, archived, rollbacks, env, logfile)'
  'stats:statistics commands (filesizes, wa)'
  'metadata:metadata table operations'
  'bootstrap:bootstrap operations'
  'repair:repair operations'
  'export:export instants and timeline'
  'fetch:fetch table schema'
  'set:set spark launcher variables'
  'sync:cross-table sync'
  'table:table-level configuration'
  'upgrade:upgrade table version'
  'downgrade:downgrade table version'
  'kerberos:kerberos kinit authentication'
  'temp_query:temporary view SQL query'
  'temp_delete:delete temporary view'
)

_arguments -C \
  '(- *)--help[show help]' \
  '*-c+[execute command and exit]:command:' \
  '*--cmdfile=[run commands from file]:file:_files' \
  '*--target-bin=[target binary]:bin:' \
  '*--logging.level=[log level]:level:' \
  '1: :->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t top_commands 'hudi-cli command' top_commands && ret=0
    ;;
  (args)
    case $line[1] in
      (connect)
        _arguments \
          '--path=[table base path]:path:' \
          '--layoutVersion=[timeline layout version]:n:' \
          '--initialCheckIntervalMs=[initial check interval]:ms:' \
          '--maxWaitIntervalMs=[max wait interval]:ms:' \
          '--maxCheckIntervalMs=[max check interval]:ms:' \
          '--eventually-consistent[eventual consistency]' \
          '--credentials-fetch[fetch credentials]' && ret=0
        ;;
      (commits)
        _values 'commits action' \
          'show' 'refresh' 'sync' 'showarchived' 'compare' && ret=0
        ;;
      (commit)
        _values 'commit action' \
          'showpartitions' 'showfiles' 'show_write_stats' 'rollback' && ret=0
        ;;
      (compaction)
        _values 'compaction action' \
          'schedule' 'run' 'scheduleAndExecute' 'show' 'showarchived' \
          'validate' 'unschedule' 'unscheduleFileId' 'repair' && ret=0
        ;;
      (cleans)
        _values 'cleans action' 'show' 'refresh' 'run' && ret=0
        ;;
      (clean)
        _values 'clean action' 'showpartitions' && ret=0
        ;;
      (savepoint)
        _values 'savepoint action' 'create' 'rollback' && ret=0
        ;;
      (savepoints)
        _values 'savepoints action' 'show' 'refresh' && ret=0
        ;;
      (show)
        _values 'show target' \
          'fsview' 'archived' 'env' 'envs' 'rollback' 'rollbacks' 'logfile' && ret=0
        ;;
      (stats)
        _values 'stats target' 'filesizes' 'wa' && ret=0
        ;;
      (metadata)
        _values 'metadata action' \
          'create' 'delete' 'refresh' 'list-partitions' 'list-files' \
          'validate-files' 'stats' && ret=0
        ;;
      (bootstrap)
        _values 'bootstrap action' \
          'run' 'index' && ret=0
        ;;
      (repair)
        _values 'repair action' \
          'deduplicate' 'migrate-partition-meta' 'addpartitionmeta' \
          'corrupted' 'overwrite-hoodie-props' && ret=0
        ;;
      (table)
        _values 'table action' \
          'update-configs' 'delete-configs' 'recover-configs' \
          'change-table-type' && ret=0
        ;;
      (kerberos)
        _values 'kerberos action' 'kinit' && ret=0
        ;;
    esac
    ;;
esac

return ret
