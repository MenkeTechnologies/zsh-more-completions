#compdef gprof2dot

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-n --node-thres)'{-n,--node-thres}'+[node threshold percent]:pct:' \
  '(-e --edge-thres)'{-e,--edge-thres}'+[edge threshold percent]:pct:' \
  '(-f --format)'{-f,--format}'+[input format]:format:(prof callgrind perf oprofile hprof pstats axe sysprof xperf dtrace sleepy)' \
  '(-c --colormap)'{-c,--colormap}'+[colormap]:colormap:(color pink gray bw print)' \
  '(-s --strip)'{-s,--strip}'[strip function param info]' \
  '(-w --wrap)'{-w,--wrap}'[wrap function names]' \
  '(-z --root)'{-z,--root}'+[root function]:func:' \
  '(-l --leaf)'{-l,--leaf}'+[leaf function]:func:' \
  '--node-label=[node label fields]:fields:' \
  '--list-functions=[list matching functions]:pattern:' \
  '--depth=[max depth]:n:' \
  '--skew=[skew]:val:' \
  '--total=[totals method]:method:' \
  '--colour-nodes-by-selftime[colour nodes by self time]' \
  '*:file:_files' && ret=0

return ret
