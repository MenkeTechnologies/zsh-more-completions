#compdef atheme-services
# _atheme-services — Atheme IRC services daemon (atheme/atheme)
# upstream: https://github.com/atheme/atheme
# Flags from libathemecore/atheme.c (mowgli_getopt_long "c:bdhrl:np:D:v").

_atheme-services() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-v[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-b[create database and exit]' \
        '-d[force debug logging]' \
        '-r[read-only mode]' \
        '-l+[log file path]:file:_files' \
        '-n[stay in foreground (live mode)]' \
        '-p+[PID file path]:file:_files' \
        '-D+[data directory]:dir:_files -/'
}

_atheme-services "$@"
