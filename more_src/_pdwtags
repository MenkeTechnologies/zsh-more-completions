#compdef pdwtags
# _pdwtags — pahole-dwarves pdwtags (Arnaldo Carvalho de Melo); pretty-print every DWARF tag in a binary
# upstream: https://github.com/acmel/dwarves

_pdwtags() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-l --line)'{-l,--line}'[print decl file:line]' \
        '*:file:_files'
}

_pdwtags "$@"
