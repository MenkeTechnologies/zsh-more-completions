#compdef cargo-espmonitor
# _cargo-espmonitor — cargo subcommand wrapping espmonitor (esp-rs/espmonitor)
# upstream: https://github.com/esp-rs/espmonitor
# Flags from cargo-espmonitor/src/main.rs (clap derive CargoAppArgs).

_cargo-espmonitor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-r --reset --no-reset)'{-r,--reset}'[reset chip on start (default)]' \
        '(-r --reset --no-reset)--no-reset[do not reset chip on start]' \
        '(-s --speed)'{-s+,--speed=}'[serial baud rate (default 115200)]:baud:' \
        '--flash[flash image before monitoring (requires cargo-espflash)]' \
        '--flash-speed=[baud rate when flashing]:baud:' \
        '--features=[features to build with when flashing]:features:' \
        '(-c --chip)'{-c+,--chip=}'[target ESP chip]:chip:(esp32 esp32s2 esp8266 esp32c3)' \
        '--framework=[target framework]:framework:(baremetal esp-idf)' \
        '--release[use the release build]' \
        '--example=[run a specific example]:name:' \
        '--bin=[run a specific bin]:name:' \
        '--package=[run from this package]:pkg:' \
        '--target=[target triple]:triple:' \
        '*:serial device:_files -g "/dev/tty*"'
}

_cargo-espmonitor "$@"
