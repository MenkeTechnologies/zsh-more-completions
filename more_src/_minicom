#compdef minicom

# Zsh completion for minicom - serial communication program

_arguments -s -S \
  '-b[set baud rate]:baud rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
  '-D[specify device]:device:_files -W /dev -g "tty*"' \
  '-o[skip initialization]' \
  '-s[enter setup mode]' \
  '-c[enable or disable color]:color:(on off)' \
  '-S[run script at startup]:script file:_files' \
  '-d[dial entry from dialing directory]:entry:' \
  '-p[use pseudo terminal]:pseudo terminal:_files -W /dev -g "pts/*"' \
  '-C[open capture file]:capture file:_files' \
  '-T[disable terminal capabilities]' \
  '-l[turn off langstrips]' \
  '-L[turn on langstrips]' \
  '-w[enable line wrap]' \
  '-H[hang up on exit]' \
  '-z[use terminal statusline]' \
  '-8[enable 8bit characters]' \
  '-a[attribute usage]:attribute usage:(on off)' \
  '-t[terminal type]:terminal type:(vt102 vt100 ansi)' \
  '-R[character set]:character set:' \
  '-7[force 7bit mode]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '::configuration:_files'
