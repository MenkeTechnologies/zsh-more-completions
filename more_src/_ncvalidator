#compdef ncvalidator
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/ncvalidator.1.html
# PnetCDF tool to validate a classic netCDF file against CDF file formats

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-t[turn on tracing mode, printing validation progress]' \
  '-x[repair null-byte padding in the file header (in place)]' \
  '-q[quiet mode, print nothing (check exit status)]' \
  '*:netcdf file:_files' && ret=0

return ret
