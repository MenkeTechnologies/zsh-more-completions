#compdef principal gmx-principal
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-principal.html
# gmx principal: calculate principal axes of inertia for a group of atoms

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass(db) file]:file:_files' \
  '-n[index file]:file:_files' \
  '-a1[xvgr/xmgr file for first principal axis]:file:_files' \
  '-a2[xvgr/xmgr file for second principal axis]:file:_files' \
  '-a3[xvgr/xmgr file for third principal axis]:file:_files' \
  '-om[xvgr/xmgr file for moment of inertia]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt = first time]:time:' \
  '-tu[unit for time values]:unit:(fs ps ns us ms s)' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-foo[dummy option to avoid empty array]' && ret=0

return ret
