#compdef libvirt-guests
# Documentation: https://man.archlinux.org/search?q=libvirt-guests
# Reference accessed: 2026-05-16

# libvirt-guests: suspend/resume all libvirt guests at host shutdown/boot
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:action:(start stop restart status gueststatus shutdown suspend resume)' && ret=0
return ret
