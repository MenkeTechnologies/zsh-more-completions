#compdef libvirt-guests

# libvirt-guests: init-style helper to suspend/resume libvirt VMs on shutdown
local curcontext="$curcontext" ret=1
_arguments -C \
  '1: :(start stop status restart force-reload condrestart try-restart shutdown gueststatus)' \
  '*::libvirt-guests args:_files' && ret=0
return ret
