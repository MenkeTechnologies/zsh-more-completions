#compdef maildev
# _maildev — local SMTP server + Web UI for development (maildev/maildev)
# upstream: https://github.com/maildev/maildev
# Flags from lib/options.js (commander).

_maildev() {
    local -a args
    args=(
        '(-s --smtp)'{-s+,--smtp=}'[SMTP port to catch emails (default 1025)]:port:'
        '(-w --web)'{-w+,--web=}'[port for the web GUI (default 1080)]:port:'
        '--mail-directory=[directory for persisting emails]:dir:_files -/'
        '--https[switch from http to https for the web GUI]'
        '--https-key=[ssl private key for the web GUI]:file:_files'
        '--https-cert=[ssl certificate for the web GUI]:file:_files'
        '--ip=[address to bind the SMTP service to (default ::)]:ip:'
        '--outgoing-host=[SMTP host for outgoing emails]:host:'
        '--outgoing-port=[SMTP port for outgoing emails]:port:'
        '--outgoing-user=[SMTP user for outgoing emails]:user:'
        '--outgoing-pass=[SMTP password for outgoing emails]:pass:'
        '--outgoing-secure[use SMTP SSL for outgoing emails]'
        '--auto-relay=[enable auto-relay (optional fallback recipient)]:email:'
        '--auto-relay-rules=[YAML / JSON auto-relay filter rules]:file:_files'
        '--incoming-user=[SMTP user required for incoming emails]:user:'
        '--incoming-pass=[SMTP password required for incoming emails]:pass:'
        '--incoming-secure[require STARTTLS / TLS on the SMTP listener]'
        '--incoming-cert=[ssl certificate for the SMTP listener]:file:_files'
        '--incoming-key=[ssl key for the SMTP listener]:file:_files'
        '--web-ip=[address to bind the web GUI to (defaults to --ip)]:ip:'
        '--web-user=[HTTP basic-auth user for the web GUI]:user:'
        '--web-pass=[HTTP basic-auth password for the web GUI]:pass:'
        '--base-pathname=[base URL path for the web GUI]:path:'
        '--disable-web[disable the web GUI (SMTP only)]'
        '--hide-extensions=[comma-separated SMTP extensions to NOT advertise]:exts:'
        '(-v --verbose)'{-v,--verbose}'[verbose log output]'
        '--silent[silence all log output]'
        '--log-mail-contents[log a JSON dump of every incoming email]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_maildev "$@"
