#compdef gmx-wham
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-wham.html
# gmx wham: weighted histogram analysis after umbrella sampling

local ret=1

_arguments -s \
  '-ix[generic data file for pullx filenames]:file:_files' \
  '-if[generic data file for pullf filenames]:file:_files' \
  '-it[generic data file for tpr filenames]:file:_files' \
  '-is[generic data file for coordinate selection]:file:_files' \
  '-iiact[generic data file for input autocorrelation times]:file:_files' \
  '-tab[generic data file for tabulated umbrella potential]:file:_files' \
  '-o[PMF profile output file]:file:_files' \
  '-hist[histogram output file]:file:_files' \
  '-oiact[integrated autocorrelation time output]:file:_files' \
  '-bsres[bootstrap results file]:file:_files' \
  '-bsprof[all bootstrap profiles file]:file:_files' \
  '-xvg[plot format]:format:(xmgrace xmgr none)' \
  '-min[minimum reaction coordinate value]:real:' \
  '-max[maximum reaction coordinate value]:real:' \
  '-auto[auto-determine boundaries]' \
  '-bins[number of histogram bins]:int:' \
  '-temp[temperature in Kelvin]:real:' \
  '-tol[convergence tolerance]:real:' \
  '-v[verbose output mode]' \
  '-b[starting time for analysis]:real:' \
  '-e[ending time for analysis]:real:' \
  '-dt[data sampling interval]:real:' \
  '-histonly[output histograms only]' \
  '-boundsonly[determine limits and exit]' \
  '-log[output logarithmic profile]' \
  '-unit[energy units]:unit:(kJ kCal kT)' \
  '-zprof0[set zero-point position]:real:' \
  '-cycl[enable periodic profile]' \
  '-sym[symmetrize around zero]' \
  '-ac[calculate autocorrelation weighting]' \
  '-acsig[ACT smoothing parameter]:real:' \
  '-ac-trestart[ACF restart interval]:real:' \
  '-nBootstrap[number of bootstrap samples]:int:' \
  '-bs-method[bootstrap strategy]:method:(b-hist hist traj traj-gauss)' \
  '-bs-tau[assumed autocorrelation time]:real:' \
  '-bs-seed[random seed for bootstrapping]:int:' \
  '-histbs-block[histogram block size for mixing]:int:' \
  '-vbs[verbose bootstrap output]' && ret=0

return ret
