#compdef perlrs pe

# Zsh completion for perlrs / pe — a Perl interpreter written in Rust

_perlrs_debug_flags() {
  _values -s '' 'debug flag' \
    'p[tokenizing and parsing]' \
    's[stack snapshots]' \
    'l[label stack processing]' \
    't[trace execution]' \
    'o[method and overloading resolution]' \
    'c[string/numeric conversions]' \
    'P[print profiling info]' \
    'm[memory and SV allocation]' \
    'f[format processing]' \
    'r[regular expression parsing and execution]' \
    'x[syntax tree dump]' \
    'u[tainting checks]' \
    'H[hash dump]' \
    'X[scratchpad allocation]' \
    'D[cleaning up]' \
    'S[op slab allocation]' \
    'T[tokenizing]' \
    'R[include reference counts of dumped variables]' \
    'J[show s/// junctions]' \
    'v[verbose: use abs path when printing file names]'
}

_perlrs() {
  local -a args
  args=(
    # Execution
    '*-e+[one line of program (several allowed)]:code:'
    '*-E+[like -e but enables all optional features]:code:'
    '-c[check syntax only (runs BEGIN and CHECK blocks)]'
    '-d+[run program under debugger]::module:'
    '-D+[set debugging flags]:flags:_perlrs_debug_flags'
    '-u[dump core after parsing program]'

    # Input processing
    '-n[assume "while (<>) \{ ... \}" loop around program]'
    '-p[assume loop like -n but print line also like sed]'
    '-a[autosplit mode with -n or -p (splits $_ into @F)]'
    '-F+[split() pattern for -a switch]:pattern:'
    '-l+[enable line ending processing]::octnum:'
    '-0+[specify record separator]::octal:'
    '-g[read all input in one go (slurp mode, alias for -0777)]'
    '-i+[edit <> files in place (backup if extension supplied)]::extension:'

    # Modules and paths
    '*-M+[use module before executing program]:module:_perl_modules'
    '*-m+[use module() before executing program (no import)]:module:_perl_modules'
    '*-I+[specify @INC directory]:directory:_directories'
    '-f[do not do $sitelib/sitecustomize.pl at startup]'
    '-S[look for programfile using PATH]'
    '-x+[ignore text before \#!perl line]::directory:_directories'

    # Unicode and safety
    '-C+[enable listed Unicode features]::number/list:'
    '-t[enable tainting warnings]'
    '-T[enable tainting checks]'
    '-U[allow unsafe operations]'
    '-s[enable switch parsing after programfile]'

    # Warnings
    '-w[enable many useful warnings]'
    '-W[enable all warnings]'
    '-X[disable all warnings]'

    # Info
    '-v[print version patchlevel and license]'
    '-V+[print configuration summary]::config variable:(version api_version archname osname threads useithreads usethreads use64bitint use64bitall cc optimize prefix installprefix perlpath)'
    '(- *)'{-h,--help}'[print help]'

    # perlrs extensions
    '-j+[number of threads for parallel operations]:threads:'
    '--threads=[number of threads for parallel operations]:threads:'

    # Positional
    '1:script file:_files -g "*.pl *.pm *.t *.cgi *.psgi"'
    '*:script arguments:_files'
  )

  _arguments -s -S $args
}

_perlrs "$@"
