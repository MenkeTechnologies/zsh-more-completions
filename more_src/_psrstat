#compdef psrstat
# Documentation: http://psrchive.sourceforge.net/manuals/psrstat/
# PSRCHIVE: query attributes and statistics of archives.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '*-c+[quantities to query, separated by commas]:quantities:' \
  '-l+[index ranges for looping over profiles]:ranges:' \
  '*:archive:_files' && ret=0

return ret
