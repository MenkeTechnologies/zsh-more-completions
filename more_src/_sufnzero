#compdef sufnzero
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/picking/sufnzero.c
# get time of first non-zero sample by trace

local ret=1

_arguments -s -S \
  'mode=[output time of first/last/both non-zero sample]:mode:(first last both)' \
  'min=[threshold value for considering as zero]:min' \
  'key=[header keyword(s) to print]:key' \
  '*:file:_files' && ret=0


return ret
