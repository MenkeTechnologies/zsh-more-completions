#compdef arm-none-eabi-gcc arm-none-eabi-g++ arm-none-eabi-c++
# _arm-none-eabi-gcc — Arm Limited arm-none-eabi-gcc CLI for the bare-metal ARM Cortex-M/A cross-compiler GCC supporting C C++ assembly newlib nano specs FPU hardware-float thumb instruction-set CPU profile linker scripts (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-gcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c[compile only]' \
        '-S[assembly only]' \
        '-E[preprocess only]' \
        '-o+[output file]:file:_files' \
        '-I+[include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-D+[define]:str:' \
        '-U+[undefine]:str:' \
        '-O+[opt level]:O:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-W+[warning]:str:' \
        '-pedantic[pedantic]' \
        '-mcpu=+[cpu]:c:(arm7tdmi arm9 arm10 arm926ej-s cortex-m0 cortex-m0plus cortex-m1 cortex-m3 cortex-m4 cortex-m7 cortex-m23 cortex-m33 cortex-m35p cortex-m55 cortex-m85 cortex-r4 cortex-r5 cortex-r7 cortex-r8 cortex-r52 cortex-a5 cortex-a7 cortex-a8 cortex-a9 cortex-a15 cortex-a17 cortex-a32 cortex-a35 cortex-a53 cortex-a57 cortex-a72 cortex-a73 cortex-a75 cortex-a76)' \
        '-march=+[arch]:a:(armv4 armv4t armv5te armv5tej armv6 armv6-m armv6s-m armv6t2 armv6kz armv7 armv7-m armv7e-m armv7-r armv7-a armv7ve armv7-em armv8-m.base armv8-m.main armv8.1-m.main armv8-r armv8-a armv8.1-a armv8.2-a armv9-a)' \
        '-mtune=+[tune]:str:' \
        '-mthumb[generate Thumb]' \
        '-marm[generate ARM]' \
        '-mfloat-abi=+[abi]:a:(soft softfp hard)' \
        '-mfpu=+[fpu]:f:(none vfp vfpv3 vfpv3-d16 vfpv3-fp16 vfpv4 vfpv4-d16 fpv4-sp-d16 fpv5-sp-d16 fpv5-d16 neon neon-vfpv3 neon-vfpv4 fp-armv8 neon-fp-armv8 crypto-neon-fp-armv8)' \
        '-mlong-calls[long calls]' \
        '-msoft-float[soft float]' \
        '-mhard-float[hard float]' \
        '-mbig-endian[big endian]' \
        '-mlittle-endian[little endian]' \
        '-specs=+[spec file]:file:_files -g "*.specs"' \
        '-nostdlib[no standard libraries]' \
        '-nodefaultlibs[no default libraries]' \
        '-nostartfiles[no start files]' \
        '-T+[linker script]:file:_files -g "*.ld"' \
        '-Wl,+[linker option]:str:' \
        '-static[static link]' \
        '-fno-builtin[no builtin]' \
        '-fno-common[no common]' \
        '-fno-exceptions[no exceptions]' \
        '-fno-rtti[no RTTI]' \
        '-ffreestanding[freestanding]' \
        '-ffunction-sections[function sections]' \
        '-fdata-sections[data sections]' \
        '-fstack-usage[stack usage]' \
        '-flto[link-time optimization]' \
        '*:source file:_files -g "*.c *.cc *.cpp *.cxx *.s *.S *.o *.a"'
}

_arm-none-eabi-gcc "$@"
