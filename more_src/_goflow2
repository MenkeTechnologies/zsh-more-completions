#compdef goflow2
# Documentation: https://github.com/netsampler/goflow2
# High-performance NetFlow/IPFIX/sFlow collector forwarding flows to file or Kafka

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-listen=[listen sockets in URI form e.g. sflow://:6343,netflow://:2055]:listen' \
  '-format=[output format]:format:(json bin)' \
  '-transport=[output transport]:transport:(file kafka)' \
  '-transport.file=[path to output file]:file:_files' \
  '-transport.file.sep=[separator for file output records]:sep' \
  '-transport.kafka.brokers=[Kafka broker addresses]:brokers' \
  '-transport.kafka.topic=[Kafka topic name]:topic' \
  '-transport.kafka.compression=[Kafka producer compression type]:compression:(none gzip snappy lz4 zstd)' \
  '-mapping=[path to YAML mapping file for template fields]:file:_files -g "*.(yaml|yml)"' && ret=0

return ret
