#compdef s6-rc
# Documentation: https://skarnet.org/software/s6-rc/s6-rc.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[specify live directory]:live directory:_files -/' \
  '-b[blocking lock]' \
  '-u[up transition (start services)]' \
  '-d[down transition (stop services)]' \
  '-p[prune dead services]' \
  '-D[dry run]' \
  '-v+[set verbosity level]:verbosity:(0 1 2 3)' \
  '-t+[set timeout in milliseconds]:timeout' \
  '-a[apply to all services]' \
  '1:command:(change list listall help)' \
  '*:service name' && ret=0

return ret
