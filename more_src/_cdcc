#compdef cdcc
# Documentation: https://www.dcc-servers.net/dcc/dcc-tree/cdcc.html
# DCC control program: query and configure the DCC client

local ret=1

_arguments -s -S \
  '-V[display version]' \
  '-B[send error messages to both stderr and stdout]' \
  '-d[enable debugging output]' \
  '-q[quiet initial complaints about the map file]' \
  '-h[DCC home directory]:dir:_files -/' \
  '-c[file of DCC IDs and passwords]:file:_files' \
  '*:operation:' && ret=0

return ret
