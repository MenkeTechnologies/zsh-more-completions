#compdef strelaysrv

_arguments -s \
  '-listen=[listen address]:addr:' \
  '-keys=[key dir]:dir:_files -/' \
  '-network-timeout=[network timeout]:duration:' \
  '-ping-interval=[ping interval]:duration:' \
  '-message-timeout=[message timeout]:duration:' \
  '-per-session-rate=[per-session bytes/s]:n:' \
  '-global-rate=[global bytes/s]:n:' \
  '-debug[debug]' \
  '-status-srv=[status server addr]:addr:' \
  '-token=[shared token]:token:' \
  '-pools=[announce to pool URL(s)]:pools:' \
  '-provided-by=[provided-by string]:str:' \
  '-ext-address=[external address]:addr:' \
  '-protocol=[protocol]:proto:(tcp tcp4 tcp6)' \
  '-nat[enable NAT-PMP/UPnP]' \
  '-nat-lease=[NAT lease minutes]:n:' \
  '-nat-renewal=[NAT renewal minutes]:n:' \
  '-nat-timeout=[NAT discovery timeout s]:n:' \
  '-pprof[enable pprof endpoint]' \
  '-network-buffer=[network buffer bytes]:n:' \
  '(- *)-version[show version]'
