#compdef zellij
# _zellij-bin — Zellij Rust terminal workspace / multiplexer (Aram Drevekenin); tmux/screen-style with WebAssembly plugin system
# upstream: https://github.com/zellij-org/zellij

_zellij-bin() {
    local -a sub=(
        'options:run with specific options'
        'setup:setup zellij and print info'
        'list-sessions:list active sessions'
        'ls:alias for list-sessions'
        'attach:attach to a session'
        'a:alias for attach'
        'kill-session:kill a session'
        'kill-all-sessions:kill all sessions'
        'delete-session:delete a session'
        'delete-all-sessions:delete all sessions'
        'action:perform an action'
        'run:run a single command in a new pane'
        'edit:open editor in a new pane'
        'e:alias for edit'
        'plugin:run a plugin'
        'convert-config:convert old config to new format'
        'convert-layout:convert old layout to new format'
        'convert-theme:convert old theme to new format'
        'pipe:pipe to a plugin'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-s --session)'{-s,--session}'+[session name]:name:' \
        '(-l --layout)'{-l,--layout}'+[layout file or builtin]:layout:' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files -g "*.kdl"' \
        '--config-dir+[config dir]:dir:_files -/' \
        '--data-dir+[data dir]:dir:_files -/' \
        '--server+[server socket]:file:_files' \
        '--debug[debug log]' \
        '--max-panes+[max panes]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zellij subcommand' sub ;;
        args)
            case $words[1] in
                attach|a|kill-session|delete-session) _arguments \
                    '(-c --create)'{-c,--create}'[create if missing]' \
                    '1:session:' ;;
                action) _arguments \
                    '1:action:(write write-chars switch-to-mode resize move-focus move-focus-or-tab move-pane dump-screen edit-scrollback scroll-up scroll-down scroll-to-bottom page-scroll-up page-scroll-down half-page-scroll-up half-page-scroll-down toggle-focus-fullscreen toggle-pane-frames toggle-active-sync-tabs new-pane edit-stdout-out switch-tab-up switch-tab-down go-to-tab go-to-tab-name go-to-tab-name-or-create rename-tab undo-rename-tab close-tab undo-rename-pane new-tab close-pane move-pane-backwards detach launch-or-focus-plugin launch-plugin start-or-reload-plugin clear next-swap-layout previous-swap-layout query-tab-names move-tab move-tab-backwards)' \
                    '*:args:' ;;
                run) _arguments \
                    '(-d --direction)'{-d,--direction}'+[direction]:dir:(down right)' \
                    '(-c --close-on-exit)'{-c,--close-on-exit}'[close pane on exit]' \
                    '(-s --start-suspended)'{-s,--start-suspended}'[suspended at start]' \
                    '(-f --floating)'{-f,--floating}'[floating pane]' \
                    '(-i --in-place)'{-i,--in-place}'[in place]' \
                    '--width+[width]:str:' \
                    '--height+[height]:str:' \
                    '--x+[x]:str:' \
                    '--y+[y]:str:' \
                    '--cwd+[cwd]:dir:_files -/' \
                    '*::command:_command_names -e' ;;
                edit|e) _arguments \
                    '(-d --direction)'{-d,--direction}'+[direction]:dir:(down right)' \
                    '(-l --line-number)'{-l,--line-number}'+[line number]:n:' \
                    '(-f --floating)'{-f,--floating}'[floating]' \
                    '(-i --in-place)'{-i,--in-place}'[in place]' \
                    '--width+[width]:str:' \
                    '--height+[height]:str:' \
                    '--x+[x]:str:' \
                    '--y+[y]:str:' \
                    '--cwd+[cwd]:dir:_files -/' \
                    '*:file:_files' ;;
                setup) _arguments \
                    '(-d --dump-config)'{-d,--dump-config}'[dump default config]' \
                    '--clean[clean current setup]' \
                    '--check[check setup]' \
                    '--dump-layout+[dump layout]:layout:' \
                    '--dump-swap-layout+[dump swap layout]:layout:' \
                    '--generate-completion+[shell]:shell:(bash zsh fish powershell elvish)' \
                    '--generate-auto-start+[shell]:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_zellij-bin "$@"
