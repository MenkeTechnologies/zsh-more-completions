#compdef polars
# Documentation: https://man.archlinux.org/search?q=polars
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[execute a command string and exit]:sql:' \
  '-o[output mode]:mode:(csv json parquet arrow table markdown md)' \
  '*:query:'
