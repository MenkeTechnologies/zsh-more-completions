#compdef podofoimpose
# Documentation: https://github.com/podofo/podofo/blob/master/tools/podofoimpose/podofoimpose.cpp
# podofoimpose - impose pages of a PDF according to an imposition plan

local ret=1

_arguments -s -S \
  '1:input PDF or file list:_files' \
  '2:output PDF file:_files -g "*.pdf"' \
  '3:imposition plan file:_files' \
  '4:interpreter:(native lua)' && ret=0

return ret
