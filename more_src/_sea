#compdef sea seahorn
# _sea — SeaHorn: LLVM-based software model checker for C/C++
# upstream: https://github.com/seahorn/seahorn
# Subcommands from py/sea/commands.py and py/sea/__main__.py.

_sea() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_sea_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                clang)
                    _arguments \
                        '-S[emit LLVM assembly (.ll) instead of bitcode]' \
                        '-m+[target machine bit-width]:bits:(32 64)' \
                        '-g[emit debug info]' \
                        '-I+[add include directory]:dir:_files -/' \
                        '-o+[output file]:file:_files' \
                        '*:source file:_files -g "*.(c|cc|cpp|cxx|ll|bc)"' && ret=0 ;;
                pp)
                    _arguments \
                        '--inline[inline all functions]' \
                        '--inline-only=[inline only the named functions]:names:' \
                        '--inline-allocators[inline allocators]' \
                        '--inline-constructors[inline C++ constructors]' \
                        '--promote-assumptions[promote assume() calls]' \
                        '--abstract-memory[abstract memory operations]' \
                        '--entry=[entry-point function if main is absent]:fn:' \
                        '--lower-invoke[lower invoke instructions to call+unwind]' \
                        '--devirt-functions[devirtualize indirect calls]' \
                        '--devirt-functions-with-cha[devirtualize using CHA]' \
                        '--lower-assert[lower assert() to assume(!cond)]' \
                        '--strip-extern[stub external functions]' \
                        '--slice-functions=[slice to the given functions]:names:' \
                        '--internalize[create dummy defs for missing functions]' \
                        '*:bitcode file:_files -g "*.(bc|ll)"' && ret=0 ;;
                ms)
                    _arguments \
                        '--no-ms[skip mixed-semantics pass]' \
                        '--no-reduce-main[do not reduce main]' \
                        '--symbolize-constant-loop-bounds[symbolize constant loop bounds]' \
                        '*:bitcode file:_files -g "*.(bc|ll)"' && ret=0 ;;
                opt)
                    _arguments \
                        '-O+[optimization level]:level:(0 1 2 3)' \
                        '--enable-indvar[enable indvar simplification]' \
                        '--enable-loop-idiom[enable loop-idiom recognition]' \
                        '--enable-nondet-init[enable nondet initialization]' \
                        '--llvm-inline-threshold=[inline threshold]:n:' \
                        '--llvm-unroll-threshold=[unroll threshold]:n:' \
                        '--enable-vectorize[enable vectorization]' \
                        '*:bitcode file:_files -g "*.(bc|ll)"' && ret=0 ;;
                horn|pf|bpf|smt|fe|clp|fe-crab|crabpp|term|fi|inc|fe-inspect|inspect-bitcode|cut-loops|smc|wmem|ndc-inst|rmtf|fat-bnd-check|add-branch-sentinel|unroll|linkrt)
                    _arguments \
                        '--cex=[counterexample output file]:file:_files' \
                        '--solve[run the solver]' \
                        '--log=[per-pass log filter]:filter:' \
                        '--sea-dsa-log=[sea-dsa log filter]:filter:' \
                        '*:input file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sea_commands] )) ||
_sea_commands() {
    local -a commands
    commands=(
        'clang:compile C/C++ source to LLVM bitcode'
        'linkrt:link the sea-rt runtime library'
        'pp:run SeaHorn pre-processing transformations'
        'ms:mixed-semantics transformation'
        'opt:run LLVM optimizations'
        'crabpp:run Crab abstract interpretation in Seapp'
        'ndc-inst:nondeterministic-choice instrumentation'
        'smc:simple memory checks instrumentation'
        'rmtf:remove redundant target-features from attributes'
        'wmem:wrap external memory access with SeaRt calls'
        'cut-loops:loop-cutting transformation'
        'fat-bnd-check:add fat-bounds-check instrumentation'
        'add-branch-sentinel:add branch-sentinel instrumentation'
        'unroll:unroll loops'
        'horn:run the SeaHorn back-end model checker'
        'pf:run the full SeaHorn verification pipeline'
        'bpf:run the bounded SeaHorn verification pipeline'
        'smt:emit SMT-LIB Horn clauses'
        'fe:run the front-end (clang+pp+ms+opt)'
        'clp:emit CLP Horn clauses'
        'fe-crab:run the front-end with Crab analysis'
        'term:run the SeaHorn termination checker'
        'fi:run the SeaHorn function-info pass'
        'inc:run the SeaHorn incremental checker'
        'fe-inspect:inspect the front-end bitcode'
        'inspect-bitcode:inspect a bitcode file'
    )
    _describe -t commands 'sea command' commands
}

_sea "$@"
