#compdef foreman-installer

# foreman-installer: Puppet-based installer for Foreman / Satellite
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-S --scenario)'{-S,--scenario=}'[deployment scenario]:scenario:(foreman katello luna proxy)' \
  '(-i --interactive)'{-i,--interactive}'[interactive parameter prompts]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-l --verbose-log-level)'{-l,--verbose-log-level=}'[log level]:level:(NOTICE INFO DEBUG)' \
  '(-c --color-of-logging)'{-c,--color-of-logging=}'[colorise log]:color:(yes no auto)' \
  '(-d --dont-save-answers)'{-d,--dont-save-answers}'[do not save answers file]' \
  '(-n --noop)'{-n,--noop}'[dry-run (no real changes)]' \
  '(-p --profile)'{-p,--profile}'[performance-profile the run]' \
  '--ignore-undocumented[do not fail on undocumented params]' \
  '--reset[reset all parameters to defaults]' \
  '--enable-foreman[enable foreman module]' \
  '--disable-foreman[disable foreman module]' \
  '--list-scenarios[list available scenarios]' \
  '--upgrade-puppet[upgrade Puppet during install]' \
  '*::installer params (-puppet-NAME=VALUE):_files' && ret=0
return ret
