#compdef rsgisfilehash
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisfilehash RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input file for which the hash will be created for.]:value:_files' \
  '(-b --blocksize)'{-b,--blocksize}'[Block size used to calculate the file hash, default is 4096 bytes]:value:_files' \
  '(-o --outhash)'{-o,--outhash}'[The hash to calculate; default\: SHA256]:value:(SHA1 SHA224 SHA256 SHA384 SHA512 MD5 Blake2B Blake2S SHA3_224 SHA3_256 SHA3_384 SHA3_512)' \
  '*:file:_files' && ret=0

return ret
