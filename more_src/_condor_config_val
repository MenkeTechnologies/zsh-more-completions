#compdef condor_config_val
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_config_val.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_config_val: query or set HTCondor configuration values.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-config[show config files]' \
  '-address[address]:sinful:' \
  '-pool[pool]:pool:' \
  '-name[daemon]:name:' \
  '-master[query master subsystem]' \
  '-startd[query startd subsystem]' \
  '-schedd[query schedd subsystem]' \
  '-collector[query collector subsystem]' \
  '-negotiator[query negotiator subsystem]' \
  '-subsystem[subsystem]:sub:' \
  '-local-name[local-name override]:name:' \
  '-set[persistent set: name=value]:name=value:' \
  '-unset[persistent unset]:name:' \
  '-rset[runtime set persistent: name=value]:name=value:' \
  '-runset[runtime unset]:name:' \
  '-evaluate[evaluate expression]:expr:' \
  '-summary[show summary]' \
  '-dump[dump config]' \
  '-default[show default value]' \
  '-expand[expand value]' \
  '-raw[raw values]' \
  '-verbose[verbose]' \
  '-used[show used config knobs]' \
  '-unused[show unused config knobs]' \
  '-writeconfig[write config]:file:_files' \
  '-macro[print macros]' \
  '-mixedcase[mixed case output]' \
  '*:macro name:' && ret=0
return ret
