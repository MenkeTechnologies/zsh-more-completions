#compdef condor_config_val
# Documentation: https://man.archlinux.org/search?q=condor_config_val
# Reference accessed: 2026-05-16

# condor_config_val: query or set Condor configuration values
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-config[show config files]' \
  '-pool[pool]:pool:' \
  '-name[daemon]:name:' \
  '-addr[address]:sinful:' \
  '-master[master subsystem]' \
  '-startd[startd subsystem]' \
  '-schedd[schedd subsystem]' \
  '-collector[collector subsystem]' \
  '-negotiator[negotiator subsystem]' \
  '-subsystem[subsystem]:sub:' \
  '-local-name[local-name]:name:' \
  '-rset[runtime set persistent]:name=value:' \
  '-set[persistent set]:name=value:' \
  '-unset[persistent unset]:name:' \
  '-runset[runtime set]:name=value:' \
  '-runtime-set[runtime set]:name=value:' \
  '-evaluate[evaluate expr]:expr:' \
  '-summary[show summary]' \
  '-dump[dump config]' \
  '-expand[expand value]' \
  '-raw[raw values]' \
  '-verbose[verbose]' \
  '*:macro name:' && ret=0
return ret
