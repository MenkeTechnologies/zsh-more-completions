#compdef arm-linux-objdump arm-linux-gnueabi-objdump arm-linux-gnueabihf-objdump
# _arm-linux-objdump — GNU binutils arm-linux-objdump CLI cross-arch ELF object dumper disassembling ARM Thumb-2 instructions printing section headers symbol tables relocations source-mixed listings dwarf .eh_frame .debug_info dump for ARM Linux binaries kernel modules with Thumb-A/M variant detection (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_arm-linux-objdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[archive headers]' \
        '--archive-headers[archive headers]' \
        '-f[file headers]' \
        '--file-headers[file headers]' \
        '-p[private headers]' \
        '--private-headers[private headers]' \
        '-h[section headers]' \
        '--section-headers[section headers]' \
        '--headers[section headers]' \
        '-x[all headers]' \
        '--all-headers[all headers]' \
        '-d[disassemble]' \
        '--disassemble[disassemble]' \
        '-D[disassemble all]' \
        '--disassemble-all[disassemble all]' \
        '-S[source-mixed]' \
        '--source[source-mixed]' \
        '-l[line numbers]' \
        '--line-numbers[line numbers]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '-r[relocations]' \
        '--reloc[relocations]' \
        '-R[dynamic relocations]' \
        '--dynamic-reloc[dynamic relocations]' \
        '-s[section contents]' \
        '--full-contents[section contents]' \
        '-t[symbol table]' \
        '--syms[symbol table]' \
        '-T[dynamic symbol table]' \
        '--dynamic-syms[dynamic symbol table]' \
        '-g[debugging info]' \
        '--debugging[debugging info]' \
        '-W[dwarf]' \
        '--dwarf[dwarf]' \
        '--dwarf=+[type]:t:(info abbrev decodedline rawline loc Ranges pubnames frames frames-interp str loc decode-loc trace_info trace_abbrev trace_aranges gdb_index addr cu_index links follow-links =a =A =c =f =F =g =i =k =K =l =L =m =N =o =O =p =r =R =s =t =T =w)' \
        '-j+[section]:str:' \
        '--section=+[section]:str:' \
        '-b+[bfd]:str:' \
        '--target=+[bfd]:str:' \
        '-m+[arch]:a:(arm thumb)' \
        '--architecture=+[arch]:a:(arm thumb)' \
        '-M+[disassembler options]:str:' \
        '--disassembler-options=+[opts]:str:' \
        '--prefix=+[path]:dir:_files -/' \
        '--prefix-strip=+[N]:n:' \
        '--start-address=+[addr]:str:' \
        '--stop-address=+[addr]:str:' \
        '*:file:_files'
}

_arm-linux-objdump "$@"
