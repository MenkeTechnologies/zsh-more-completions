#compdef hist2workspace
# Documentation: https://linux.die.net/man/1/hist2workspace
# create a RooFit/RooStats workspace from histograms (HistFactory)

local ret=1

_arguments -s -S \
  '-standard_form[default model interpolating between RooHistFuncs]' \
  '-number_counting_form[original model using a Poisson per histogram bin]' \
  '*:input xml:_files -g "*.xml"' && ret=0

return ret
