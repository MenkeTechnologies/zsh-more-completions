#compdef tsui
# Documentation: https://man.archlinux.org/search?q=tsui
# Reference accessed: 2026-05-16

# Zsh completion for tsui — Tailscale TUI (neuralinkcorp/tsui; no CLI flags)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' && ret=0

return ret
