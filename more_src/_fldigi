#compdef fldigi
# Documentation: https://man.archlinux.org/search?q=fldigi
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config-dir=+[config directory]:dir:_files -/' \
  '--rig-xml=+[rig xml file]:file:_files -g "*.xml"' \
  '--arq-server-address=+[ARQ host]:host:_hosts' \
  '--arq-server-port=+[ARQ port]:port:' \
  '--flrig-xmlrpc-address=+[flrig address]:addr:' \
  '--flrig-xmlrpc-port=+[flrig port]:port:' \
  '--xmlrpc-server-address=+[xmlrpc address]:addr:' \
  '--xmlrpc-server-port=+[xmlrpc port]:port:' \
  '--xmlrpc-allow=+[allow regex]:regex:' \
  '--xmlrpc-deny=+[deny regex]:regex:' \
  '--xmlrpc-list[list xmlrpc methods]' \
  '--noise[generate test noise]' \
  '--enable-io-port[enable IO port]' \
  '--disable-io-port[disable IO port]' \
  '--debug-level=+[debug level]:lvl:(0 1 2 3 4 5)' \
  '--exit-after=+[exit after sec]:sec:' \
  '--profile=+[user profile dir]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
