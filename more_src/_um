#compdef um
# Documentation: https://man.archlinux.org/search?q=um
# Reference accessed: 2026-05-16

# sinclairtarget/um — personal man-page helper

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'um command' compadd -- init list read edit rm config
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
