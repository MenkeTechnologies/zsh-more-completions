#compdef tea
# Documentation: https://gitea.com/gitea/tea (README)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tea (Gitea CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'issues:list, create and update issues'
  'issue:list, create and update issues'
  'i:list, create and update issues'
  'pulls:manage and checkout pull requests'
  'pull:manage and checkout pull requests'
  'pr:manage and checkout pull requests'
  'labels:manage issue labels'
  'label:manage issue labels'
  'milestones:list and create milestones'
  'milestone:list and create milestones'
  'ms:list and create milestones'
  'releases:manage releases'
  'release:manage releases'
  'r:manage releases'
  'times:operate on tracked times'
  'time:operate on tracked times'
  't:operate on tracked times'
  'organizations:list, create, delete organizations'
  'organization:list, create, delete organizations'
  'org:list, create, delete organizations'
  'repos:show repository details'
  'repo:show repository details'
  'branches:consult branches'
  'branch:consult branches'
  'b:consult branches'
  'actions:manage repository actions (secrets, variables)'
  'comment:add a comment to an issue / pr'
  'c:add a comment to an issue / pr'
  'webhooks:manage repository webhooks'
  'webhook:manage repository webhooks'
  'open:open something in web browser'
  'o:open something in web browser'
  'notifications:show notifications'
  'notification:show notifications'
  'n:show notifications'
  'clone:clone a repository locally'
  'C:clone a repository locally'
  'whoami:show current logged-in user'
  'admin:operations requiring admin access'
  'a:operations requiring admin access'
  'logins:log in to a Gitea server'
  'login:log in to a Gitea server'
  'logout:log out from a Gitea server'
  'help:show help'
  'h:show help'
)

_arguments -s -S \
  '--debug[enable debug mode]' \
  '--vvv[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tea command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (issues|issue|i)
        local -a issue_cmds=(
          'list:list issues'
          'create:create an issue'
          'close:close an issue'
          'reopen:reopen an issue'
        )
        _describe -t issue_cmds 'issue subcommand' issue_cmds && ret=0
        ;;
      (pulls|pull|pr)
        local -a pr_cmds=(
          'list:list pull requests'
          'checkout:checkout a PR'
          'clean:clean PR branch'
          'close:close a PR'
          'create:create a PR'
          'merge:merge a PR'
          'reopen:reopen a PR'
          'review:review a PR'
        )
        _describe -t pr_cmds 'PR subcommand' pr_cmds && ret=0
        ;;
      (repos|repo)
        local -a repo_cmds=(
          'list:list repos'
          'search:search repos'
          'create:create a repo'
          'fork:fork a repo'
        )
        _describe -t repo_cmds 'repo subcommand' repo_cmds && ret=0
        ;;
      (releases|release|r)
        local -a rel_cmds=(
          'list:list releases'
          'create:create a release'
          'delete:delete a release'
          'edit:edit a release'
          'assets:manage release assets'
        )
        _describe -t rel_cmds 'release subcommand' rel_cmds && ret=0
        ;;
      (milestones|milestone|ms)
        local -a ms_cmds=(
          'list:list milestones'
          'create:create a milestone'
          'close:close a milestone'
          'reopen:reopen a milestone'
          'delete:delete a milestone'
          'issues:list issues for milestone'
        )
        _describe -t ms_cmds 'milestone subcommand' ms_cmds && ret=0
        ;;
      (labels|label)
        local -a label_cmds=(
          'list:list labels'
          'create:create a label'
          'update:update a label'
          'delete:delete a label'
        )
        _describe -t label_cmds 'label subcommand' label_cmds && ret=0
        ;;
      (logins|login)
        local -a login_cmds=(
          'add:add a login'
          'list:list logins'
          'default:show default login'
          'delete:delete a login'
          'edit:edit a login'
          'setdefault:set default login'
        )
        _describe -t login_cmds 'login subcommand' login_cmds && ret=0
        ;;
      (notifications|notification|n)
        local -a notif_cmds=(
          'list:list notifications'
          'mark-read:mark as read'
          'mark-unread:mark as unread'
        )
        _describe -t notif_cmds 'notifications subcommand' notif_cmds && ret=0
        ;;
      (admin|a)
        _values 'admin subcommand' 'users' && ret=0
        ;;
      (actions)
        local -a action_cmds=(
          'secrets:manage repository action secrets'
          'variables:manage repository action variables'
        )
        _describe -t action_cmds 'actions subcommand' action_cmds && ret=0
        ;;
      (webhooks|webhook)
        local -a wh_cmds=(
          'list:list webhooks'
          'create:create a webhook'
          'delete:delete a webhook'
        )
        _describe -t wh_cmds 'webhooks subcommand' wh_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
