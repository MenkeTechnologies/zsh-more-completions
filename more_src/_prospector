#compdef prospector

# Zsh completion for prospector - Python source code analyzer

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '(-A --autodetect)'{-A,--autodetect}'[auto-detect libraries used]'
  '(-u --uses)'{-u,--uses}'[specify libraries explicitly]:library:(django celery flask)'
  '(-0 --zero-exit)'{-0,--zero-exit}'[always exit with code 0]'
  '(-s --strictness)'{-s,--strictness}'[set strictness level]:level:(verylow low medium high veryhigh)'
  '(-S --summary-only)'{-S,--summary-only}'[only show summary]'
  '(-M --messages-only)'{-M,--messages-only}'[only show messages]'
  '(-E --external-config)'{-E,--external-config}'[use tool external config]:strategy:(none merge only)'
  '--absolute-paths[output absolute paths]'
  '(-t --tool)'{-t,--tool}'[enable a specific tool]:tool:(pylint pyflakes mccabe pep8 pep257 pycodestyle pydocstyle dodgy mypy vulture bandit pyroma frosted profile-validator)'
  '--with-tool[enable an additional tool]:tool:(pylint pyflakes mccabe pep8 pep257 pycodestyle pydocstyle dodgy mypy vulture bandit pyroma frosted profile-validator)'
  '--without-tool[disable a tool]:tool:(pylint pyflakes mccabe pep8 pep257 pycodestyle pydocstyle dodgy mypy vulture bandit pyroma frosted profile-validator)'
  '(-p --profile)'{-p,--profile}'[profile to use]:profile:_files -g "*.(yaml|yml)"'
  '(-P --profile-path)'{-P,--profile-path}'[path to search for profiles]:path:_files -/'
  '--no-external-config[disable external tool config]'
  '(-I --ignore-patterns)'{-I,--ignore-patterns}'[regex to ignore paths]:pattern:'
  '(-i --ignore-paths)'{-i,--ignore-paths}'[path prefixes to ignore]:path:_files -/'
  '(-D --doc-warnings)'{-D,--doc-warnings}'[include documentation warnings]'
  '(-T --test-warnings)'{-T,--test-warnings}'[include test warnings]'
  '(-8 --no-style-warnings)'{-8,--no-style-warnings}'[disable style warnings]'
  '(-F --full-pep8)'{-F,--full-pep8}'[include full pep8 style warnings]'
  '(-m --member-warnings)'{-m,--member-warnings}'[include member warnings]'
  '(-U --no-autodetect)'{-U,--no-autodetect}'[do not autodetect frameworks]'
  '(-W --die-on-tool-error)'{-W,--die-on-tool-error}'[exit with error if a tool fails]'
  '(-X --include-tool-stdout)'{-X,--include-tool-stdout}'[include stdout of failing tools]'
  '(-o --output-format)'{-o,--output-format}'[output format]:format:(text json xunit yaml emacs grouped pylint vscode)'
  '--max-line-length[maximum line length]:length:'
  '--legacy-tool-names[use legacy tool names]'
  '--show-profile[show resolved profile]'
  '--path[path to run prospector on]:path:_files -/'
  '--workers[number of workers]:n:'
  '(-v --version)'{-v,--version}'[show version]'
  '*:path:_files'
)

_arguments -s -S $arguments
