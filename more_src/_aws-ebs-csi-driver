#compdef aws-ebs-csi-driver
# _aws-ebs-csi-driver — AWS EBS CSI driver (controller/node/all modes)
# upstream: https://github.com/kubernetes-sigs/aws-ebs-csi-driver
# Flags from cmd/main.go + pkg/driver/options.go on tip; first positional arg selects mode.

_aws-ebs-csi-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1::mode:(controller node all metadata-labeler)' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--http-endpoint=[TCP address for the metrics HTTP server]:addr:' \
        '--metrics-cert-file=[TLS cert for the metrics server]:file:_files' \
        '--metrics-key-file=[TLS key for the metrics server]:file:_files' \
        '--enable-otel-tracing[enable OpenTelemetry tracing]' \
        '--metadata-sources=[csv of metadata sources (imds k8s)]:csv:' \
        '--user-agent-extra=[extra string appended to user agent]:s:' \
        '--aws-sdk-debug-log[enable aws sdk debug logging]' \
        '--k8s-tag-cluster-id=[Kubernetes cluster id tag for EBS volumes]:id:' \
        '--warn-on-invalid-tag[warn on invalid tags instead of failing]' \
        '--batching[enable batching of EC2 API calls]' \
        '--modify-volume-request-handler-timeout=[coalesce window for ModifyVolume calls]:duration:' \
        '--deprecated-metrics[enable deprecated metrics]' \
        '--enable-node-local-volumes[enable pre-attached EBS node-local volumes]' \
        '--volume-attach-limit=[max volume attachments per node]:n:' \
        '--reserved-volume-attachments=[volume attachments reserved for system]:n:' \
        '--windows-host-process[run inside a Windows privileged container (alpha)]' \
        '--legacy-xfs[format XFS without modern features (DEPRECATED)]' \
        '--csi-mount-point-prefix=[mountpoint prefix for CSI-managed volumes]:dir:_files -/' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '--logging-format=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[DEPRECATED log to stderr]:bool:(true false)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_aws-ebs-csi-driver "$@"
