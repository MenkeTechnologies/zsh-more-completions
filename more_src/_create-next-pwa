#compdef create-next-pwa
# Documentation: https://www.npmjs.com/package/create-next-pwa
# Reference accessed: 2026-05-24
# Verified: npm view create-next-pwa bin; npx create-next-pwa --help output.

# Zsh completion for create-next-pwa - Next.js Progressive Web App scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-ts --typescript)'{-ts,--typescript}'[use TypeScript instead of JavaScript]'   '(-t --tailwind)'{-t,--tailwind}'[integrate Tailwind CSS]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' name && ret=0
    ;;
  args)
  case $line[1] in
    name)
      _arguments -C ':PWA project name:' && ret=0
      ;;
  esac
    ;;
esac

return ret
