#compdef openai

# OpenAI CLI completion

_openai_subcommands() {
  local -a subcmds=(
    'api:Interact with the OpenAI API'
    'tools:Utility tools'
    'migrate:Migrate from older API versions'
  )
  _describe -t commands 'openai subcommand' subcmds
}

_openai_api_subcommands() {
  local -a subcmds=(
    'chat_completions.create:Create a chat completion'
    'completions.create:Create a completion'
    'images.generate:Generate images'
    'embeddings.create:Create embeddings'
    'files.create:Upload a file'
    'files.list:List files'
    'files.delete:Delete a file'
    'fine_tuning.jobs.create:Create a fine-tuning job'
    'fine_tuning.jobs.list:List fine-tuning jobs'
    'models.list:List available models'
    'models.delete:Delete a model'
    'audio.transcriptions.create:Transcribe audio'
    'audio.translations.create:Translate audio'
  )
  _describe -t commands 'api subcommand' subcmds
}

_openai_tools_subcommands() {
  local -a subcmds=(
    'fine_tunes.prepare_data:Prepare data for fine-tuning'
  )
  _describe -t commands 'tools subcommand' subcmds
}

_openai() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--api-key=[OpenAI API key]:api key' \
    '--organization=[OpenAI organization ID]:organization' \
    '1:subcommand:_openai_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        api)
          _arguments -C \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:_openai_api_subcommands' \
            '*::arg:->api_args'
          case $state in
            api_args)
              case ${line[1]} in
                chat_completions.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to use]:model' \
                    '-g+[system/user/assistant message]:message' \
                    '-t+[sampling temperature]:temperature' \
                    '-M+[max tokens]:max tokens' \
                    '-n+[number of completions]:count' \
                    '--stop=[stop sequence]:stop' \
                    '--stream[stream output]'
                  ;;
                completions.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to use]:model' \
                    '-p+[prompt]:prompt' \
                    '-t+[sampling temperature]:temperature' \
                    '-M+[max tokens]:max tokens' \
                    '-n+[number of completions]:count' \
                    '--stop=[stop sequence]:stop' \
                    '--stream[stream output]'
                  ;;
                images.generate)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-p+[prompt]:prompt' \
                    '-n+[number of images]:count' \
                    '--size=[image size]:size:(256x256 512x512 1024x1024)' \
                    '--response-format=[response format]:format:(url b64_json)'
                  ;;
                embeddings.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to use]:model' \
                    '-i+[input text]:input'
                  ;;
                files.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-f+[file to upload]:file:_files' \
                    '-p+[purpose]:purpose:(fine-tune assistants)'
                  ;;
                files.list)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]'
                  ;;
                files.delete)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-i+[file ID]:file id'
                  ;;
                fine_tuning.jobs.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to fine-tune]:model' \
                    '-t+[training file ID]:training file' \
                    '--validation-file=[validation file ID]:validation file' \
                    '--suffix=[model suffix]:suffix' \
                    '--n-epochs=[number of epochs]:epochs'
                  ;;
                fine_tuning.jobs.list)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--limit=[number of results]:limit'
                  ;;
                models.list)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]'
                  ;;
                models.delete)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-i+[model ID]:model id'
                  ;;
                audio.transcriptions.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to use]:model' \
                    '-f+[audio file]:file:_files' \
                    '--language=[language]:language' \
                    '--response-format=[response format]:format:(json text srt verbose_json vtt)'
                  ;;
                audio.translations.create)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-m+[model to use]:model' \
                    '-f+[audio file]:file:_files' \
                    '--response-format=[response format]:format:(json text srt verbose_json vtt)'
                  ;;
              esac
              ;;
          esac
          ;;
        tools)
          _arguments -C \
            '(- *)'{-h,--help}'[show help]' \
            '1:subcommand:_openai_tools_subcommands' \
            '*::arg:->tools_args'
          case $state in
            tools_args)
              case ${line[1]} in
                fine_tunes.prepare_data)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '-f+[input file]:file:_files' \
                    '-q[auto-accept suggestions]'
                  ;;
              esac
              ;;
          esac
          ;;
        migrate)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_openai "$@"
