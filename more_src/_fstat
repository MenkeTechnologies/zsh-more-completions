#compdef fstat
# _fstat — OpenBSD fstat (identify open files; -p filters by pid, -u by user, -f restricts to files on the same filesystem as named path args, -o numeric inode/dev for sort, -s adds socket details, -n numeric output, -v verbose)
# upstream: https://github.com/openbsd/src (usr.bin/fstat)
# Flags from usr.bin/fstat/fstat.1 on tip.

_fstat() {
    _arguments \
        '-f[same filesystem as args]' \
        '-n[numeric output]' \
        '-o[include socket-state and inode/dev]' \
        '-s[show extended socket info]' \
        '-v[verbose]' \
        '-M+[core file]:file:_files' \
        '-N+[kernel symbol file]:file:_files' \
        '-p+[pid filter]:pid:_pids' \
        '-u+[user filter]:user:_users' \
        '*:file:_files'
}

_fstat "$@"
