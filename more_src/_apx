#compdef apx

# Zsh completion for apx - Vanilla OS package manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'autoremove:Remove packages that are no longer needed'
  'clean:Clean the apx package manager cache'
  'enter:Enter the managed container shell'
  'export:Export an application or binary from the container'
  'help:Help about any command'
  'init:Initialize the managed container'
  'install:Install packages inside the container'
  'list:List installed packages'
  'log:Show logs'
  'purge:Purge packages from the container'
  'remove:Remove packages from the container'
  'run:Run a command inside the container'
  'search:Search for packages'
  'show:Show details about a package'
  'unexport:Unexport an application or binary'
  'update:Update the list of available packages'
  'upgrade:Upgrade installed packages'
  'version:Show version information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[show more output]' \
  '(-n --name)'{-n,--name}'[container name]:name' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'apx command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-y --assume-yes)'{-y,--assume-yes}'[proceed without confirmation]' \
          '(-f --fix-broken)'{-f,--fix-broken}'[fix broken dependencies]' \
          '--no-export[do not export application entry]' \
          '--sideload=[install a local package]:file:_files' \
          '*:package:' && ret=0
        ;;
      remove|purge)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-y --assume-yes)'{-y,--assume-yes}'[proceed without confirmation]' \
          '*:package:' && ret=0
        ;;
      export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--app-name=[application name to export]:name' \
          '--bin=[binary name to export]:name' && ret=0
        ;;
      unexport)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--app-name=[application name to unexport]:name' \
          '--bin=[binary name to unexport]:name' && ret=0
        ;;
      run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:command:' && ret=0
        ;;
      search|show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:package:' && ret=0
        ;;
    esac
    ;;
esac

return ret
