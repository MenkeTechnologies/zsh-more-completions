#compdef jd

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-set[treat arrays as sets]' \
  '-mset[treat arrays as multisets]' \
  '-color[enable color output]' \
  '-yaml[read YAML input]' \
  '-p[output patch format]' \
  '-f[output format]:format:(jd patch merge)' \
  '-t[translate format]:format:(jd patch merge)' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0
return ret
