#compdef vcfToBed
# UCSC kent: convert VCF to BED9+ with optional extra fields

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-fixChromNames[prepend chr to chromosome names]' \
  '-fields=[comma-separated list of tags to include]:fields:' \
  '-fieldsIsFile[the -fields argument is a file with one tag per line]' \
  ':in vcf:_files -g "*.(vcf|vcf.gz)"' \
  ':out prefix:_files' && ret=0

return ret
