#compdef azurite azurite-blob azurite-queue azurite-table

_arguments -s \
  '--blobHost=[blob listen address]:addr:' \
  '--blobPort=[blob listen port]:port:' \
  '--blobKeepAliveTimeout=[blob keep-alive timeout]:secs:' \
  '--queueHost=[queue listen address]:addr:' \
  '--queuePort=[queue listen port]:port:' \
  '--queueKeepAliveTimeout=[queue keep-alive timeout]:secs:' \
  '--tableHost=[table listen address]:addr:' \
  '--tablePort=[table listen port]:port:' \
  '--tableKeepAliveTimeout=[table keep-alive timeout]:secs:' \
  '(-l --location)'{-l,--location=}'[workspace directory]:dir:_files -/' \
  '(-s --silent)'{-s,--silent}'[disable access log output]' \
  '(-d --debug)'{-d,--debug=}'[debug log file]:file:_files' \
  '(-L --loose)'{-L,--loose}'[ignore unsupported headers]' \
  '--inMemoryPersistence[memory-only persistence]' \
  '--extentMemoryLimit=[in-memory extent size MB]:mb:' \
  '--cert=[PEM/PFX certificate]:file:_files' \
  '--key=[PEM key]:file:_files' \
  '--pwd=[PFX cert password]:pw:' \
  '--oauth=[enable OAuth]:mode:(basic)' \
  '--skipApiVersionCheck[skip API version validation]' \
  '--disableProductStyleUrl[parse account from URI path]' \
  '--disableTelemetry[disable telemetry]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
