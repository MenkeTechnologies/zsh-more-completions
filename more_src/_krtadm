#compdef krtadm
# Documentation: https://github.com/freakmaxi/kertish-dos/blob/master/admin-tool/flags.go
# Reference accessed: 2026-05-19
# Verified: upstream admin-tool/flags.go (Go flag.FlagSet). krtadm is the
# kertish-dos admin tool (formerly kertish-admin).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print usage documentation]' \
  '(-v -version)'{-v,-version}'[print release version]' \
  '-target=[manager end point to work with]:address:' \
  '-t=[manager end point to work with]:address:' \
  '-manager-address=[(deprecated) manager end point]:address:' \
  '-create-cluster=[create data nodes cluster (binding addresses)]:addrs:' \
  '-delete-cluster=[delete cluster (cluster id)]:id:' \
  '-move-cluster=[move cluster data (sourceId,targetId)]:ids:' \
  '-balance-clusters=[balance data weight between clusters]:ids:' \
  '-get-cluster=[get and print cluster information]:id:' \
  '-get-clusters[get and print all clusters information]' \
  '-add-node=[add nodes to an existing cluster]:spec:' \
  '-remove-node=[remove the node from its cluster]:node:' \
  '-repair-consistency=[repair chunk distribution consistency]:model:(full structure structure+integrity integrity integrity+checksum checksum checksum+rebuild)' \
  '-create-snapshot=[create snapshot on a cluster (cluster id)]:id:' \
  '-delete-snapshot=[delete a snapshot (clusterId with index)]:spec:' \
  '-restore-snapshot=[restore a snapshot (clusterId with index)]:spec:' \
  '-change-state=[change the state of the cluster(s)]:ids:' \
  '-online[change cluster state to ONLINE]' \
  '-readonly[change cluster state to READONLY]' \
  '-offline[change cluster state to OFFLINE]' \
  '-sync-cluster=[synchronise selected cluster and its nodes]:id:' \
  '-sync-clusters[synchronise all clusters and their nodes]' \
  '-clusters-report[get clusters health report]' && ret=0

return ret
