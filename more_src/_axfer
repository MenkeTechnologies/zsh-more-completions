#compdef axfer
# Documentation: https://manpages.debian.org/axfer.1
# Source: alsa-utils — modern split of aplay/arecord (transfer/list/version/help subcommands + capture/playback direction).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-l --list-devices -L --list-pcms)-l[compat: list-devices subcommand]' \
    '(-l --list-devices -L --list-pcms)--list-devices[compat: list-devices subcommand]' \
    '(-l --list-devices -L --list-pcms)-L[compat: list-pcms subcommand]' \
    '(-l --list-devices -L --list-pcms)--list-pcms[compat: list-pcms subcommand]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'transfer:transmit audio data (delegates to axfer-transfer)'
            'list:dump lists of available sound devices and nodes'
            'version:print version'
            'help:print help on subcommands'
        )
        _describe -t subcmds 'axfer command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            transfer)
                local -a dirs=(
                    'capture:capture transmission'
                    'playback:playback transmission'
                )
                _describe -t dirs 'direction' dirs && ret=0
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac

return ret
