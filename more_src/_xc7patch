#compdef xc7patch
# Documentation: https://github.com/SymbiFlow/prjxray/blob/master/tools/xc7patch.cc
# Project X-Ray: patch frame deltas into a 7-series bitstream

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--part_name=[target part name]:part' \
  '--part_file=[definition file for target 7-series part]:file:_files' \
  '--bitstream_file=[initial bitstream to which deltas are applied]:file:_files' \
  '--frm_file=[file with list of frame deltas to apply]:file:_files' \
  '--output_file=[write patched bitstream to file]:file:_files' \
  '--architecture=[architecture specification]:arch:(Series7)' && ret=0

return ret
