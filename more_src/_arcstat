#compdef arcstat
# Documentation: https://man.archlinux.org/search?q=arcstat
# Reference accessed: 2026-05-16

# arcstat: query ARC job status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-d[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '--debug=[debug level]:level:(FATAL ERROR WARNING INFO VERBOSE DEBUG)' \
  '-a[query all jobs]' \
  '--all[query all jobs]' \
  '-l[long format]' \
  '--long[long format]' \
  '-s[filter by state]:state:(Accepted Preparing Submitting Hold Queuing Running Finishing Finished Killed Failed Other)' \
  '--status=[filter by state]:state:' \
  '-c[cluster URL]:url:' \
  '--cluster=[cluster URL]:url:' \
  '-r[reject cluster]:url:' \
  '--rejectmanagement=[reject cluster]:url:' \
  '-i[index server]:url:' \
  '--index=[index server]:url:' \
  '-C[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-j[joblist file]:file:_files' \
  '--joblist=[joblist file]:file:_files' \
  '-S[server tag]:tag:' \
  '--server[only server names]' \
  '-u[unknown jobs]' \
  '--show-unknown[unknown jobs]' \
  '*:jobid:' && ret=0
return ret
