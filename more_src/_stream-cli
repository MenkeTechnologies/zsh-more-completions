#compdef stream-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'chat:Chat product commands'
  'config:manage CLI configuration (apps)'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--app=[active application name]:app:' \
  '--config=[config file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'stream-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (chat)
        local -a chat_subs=(
          'create-channel:create a channel'
          'get-channel:fetch a channel'
          'list-channels:list channels'
          'delete-channel:delete a channel'
          'truncate-channel:truncate a channel'
          'update-channel:update a channel'
          'hide-channel:hide a channel for a user'
          'show-channel:show a hidden channel'
          'send-message:send a message'
          'send-event:send an event'
          'flag-message:flag a message'
          'unflag-message:unflag a message'
          'mute-user:mute a user'
          'unmute-user:unmute a user'
          'ban-user:ban a user'
          'unban-user:unban a user'
          'shadow-ban-user:shadow-ban a user'
          'remove-shadow-ban:remove a shadow ban'
          'upsert-user:upsert a user'
          'list-users:list users'
          'delete-user:delete a user'
          'export-channels:export channels to JSON'
          'export-user:export a user'
          'reactivate-user:reactivate a user'
          'deactivate-user:deactivate a user'
          'create-token:create a token for a user'
        )
        _describe -t cccmds 'chat subcommand' chat_subs && ret=0
        _arguments \
          '--type=[channel type]:type:' \
          '--id=[channel id]:id:' \
          '--user=[user id]:user:' \
          '--user-id=[user id]:user:' \
          '--target-user-id=[target user id]:user:' \
          '--muted-by-id=[user id who is muting]:user:' \
          '--channel-type=[channel type]:type:' \
          '--channel-id=[channel id]:id:' \
          '--text=[message text]:text:' \
          '--message-id=[message id]:id:' \
          '--limit=[result limit]:n:' \
          '--expiration=[mute expiration in minutes]:minutes:' \
          '--output-format=[output format]:format:(json tree)' \
          '*--attachment=[attachment file]:file:_files' && ret=0 ;;
      (config)
        _arguments '*::sub:(new list update remove default)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
