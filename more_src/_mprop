#compdef mprop
# Documentation: https://docs.siesta-project.org/projects/siesta/en/latest/tutorials/basic/analysis-tools/index.html
# SIESTA process projected density of states from .mpr orbital selection files

local ret=1

_arguments -s -S \
  '-h[print help]' \
  '-n[number of energy points]:npoints:' \
  '-m[minimum energy]:emin:' \
  '-M[maximum energy]:emax:' \
  '-s[smearing/broadening in eV]:smearing:' \
  '*:prop base name:_files' && ret=0

return ret
