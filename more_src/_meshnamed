#compdef meshnamed
# Documentation: https://github.com/zhoreeq/meshname
# meshnamed - universal naming system DNS server for IPv6 mesh networks

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-listenaddr=[address to listen on]:addr:' \
  '-networks=[TLD=subnet list separated by comma]:list:' \
  '-nomeship[disable .meship resolver]' \
  '-getname=[convert an IPv6 address to a name]:address:' \
  '-getip=[convert a name to an IPv6 address]:name:' \
  '-debug[enable debug logging]' && ret=0

return ret
