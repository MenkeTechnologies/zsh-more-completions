#compdef bindgen
# Documentation: https://rust-lang.github.io/rust-bindgen/command-line-usage.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# rust-lang/rust-bindgen — bindgen/options/cli.rs (clap) subset
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-o --output)'{-o,--output}'[output path]:file:_files' \
  '--verbose[verbose libclang logging]' \
  '--generate[regenerate when clang headers move]' \
  '--rust-target[Rust/LLVM target version]' \
  '--rust-edition[2015|2018|2021|2024]' \
  '--rustfmt-configuration-file[absolute rustfmt TOML]:file:_files' \
  '--no-rustfmt-bindings[skip rustfmt on output]' \
  '*:C/C++/objc header:_files'
