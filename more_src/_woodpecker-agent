#compdef woodpecker-agent
# Documentation: https://man.archlinux.org/search?q=woodpecker-agent
# Reference accessed: 2026-05-16

# woodpecker-agent: Woodpecker CI agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--server=[Woodpecker server gRPC URL]:url:' \
  '--grpc-secure[use TLS for gRPC]' \
  '--grpc-skip-insecure[skip verifying gRPC server cert]' \
  '--agent-config=[agent config file]:file:_files' \
  '--filter=[event filter]:filter:' \
  '--hostname=[hostname]:host:_hosts' \
  '--backend-engine=[backend]:engine:(docker kubernetes local ssh)' \
  '--max-workflows=[max workflows]:n:' \
  '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
  '--log-format=[log format]:fmt:(text json color)' \
  '--healthcheck[enable healthcheck endpoint]' \
  '--healthcheck-addr=[healthcheck addr]:addr:' \
  '--metrics[enable metrics endpoint]' \
  '--metrics-addr=[metrics addr]:addr:' \
  '*::woodpecker-agent args:_files' && ret=0
return ret
