#compdef pyftmerge
# Documentation: https://man.archlinux.org/search?q=pyftmerge
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output file]:file:_files -g "*.(otf|ttf)"' \
  '-v[verbose]' \
  '*:font file:_files -g "*.(otf|ttf)"' && ret=0

return ret
