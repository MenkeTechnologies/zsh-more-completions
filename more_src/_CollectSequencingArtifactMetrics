#compdef CollectSequencingArtifactMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectSequencingArtifactMetrics
# Picard: collect metrics on sequencing artifacts (pre-adapter and bait-bias)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[base name for output metrics files]:basename:' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--INTERVALS=[optional interval list to restrict analysis to]:interval_list:_files -g "*.interval_list"' \
  '--DB_SNP=[dbSNP VCF used to exclude regions near known polymorphisms]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  '--MINIMUM_QUALITY_SCORE=[minimum base quality for inclusion]:int:' \
  '--MINIMUM_MAPPING_QUALITY=[minimum mapping quality for inclusion]:int:' \
  '--MINIMUM_INSERT_SIZE=[minimum insert size for read inclusion]:int:' \
  '--MAXIMUM_INSERT_SIZE=[maximum insert size for read inclusion]:int:' \
  '--INCLUDE_UNPAIRED=[include unpaired reads in analysis]:bool:(true false)' \
  '--INCLUDE_DUPLICATES=[include duplicate reads]:bool:(true false)' \
  '--INCLUDE_NON_PF_READS=[include non-PF reads]:bool:(true false)' \
  '--TANDEM_READS=[true if mate pairs face the same direction]:bool:(true false)' \
  '--USE_OQ=[use original quality scores when available]:bool:(true false)' \
  '--CONTEXT_SIZE=[number of context bases on each side]:int:' \
  '*--CONTEXTS_TO_PRINT=[specific contexts to print in detail metrics]:context:' \
  '--FILE_EXTENSION=[file extension appended to metric file names]:ext:' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
