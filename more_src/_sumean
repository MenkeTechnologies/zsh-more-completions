#compdef sumean
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/attributes_parameter_estimation/sumean.c
# SUMEAN - get the mean values of data traces

local ret=1

_arguments -s -S \
  'outpar=[output parameter file]:f:_files' \
  'power=[power for the mean computation]:p:' \
  'verbose=[=1 for verbose output]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
