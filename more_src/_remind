#compdef remind

# Zsh completion for remind (calendar/reminder program)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[Do not trigger timed reminders immediately]' \
  '-b+[Time format for calendar mode]:format:(0 1 2)' \
  '-c+[Produce a calendar for n months]:months' \
  '-d[Debug: trace expression evaluation]' \
  '-e[Divert messages from stderr to stdout]' \
  '-f[Do not fork when entering daemon mode]' \
  '-g[Sort reminders by trigger date/time]' \
  '-h[Hush mode - be quiet]' \
  '-i[Run in non-daemon interactive mode]' \
  '-j+[Set proximity for calendar mode]:days' \
  '-k+[Run command for timed reminders]:command' \
  '-l[Do not add line breaks to long reminders]' \
  '-m[Start calendar with Monday instead of Sunday]' \
  '-n[Print next reminder date]' \
  '-o[Ignore ONCE directives]' \
  '-p+[Produce output for rem2ps or front-ends]:format' \
  '-q[Do not show queued timed reminders on startup]' \
  '-r[Disable RUN directives]' \
  '-s+[Produce simple calendar output]:format' \
  '-t+[Set trigger time for delayed reminders]:time' \
  '-u[Flush output after each line]' \
  '-v[More verbose output]' \
  '-w+[Calendar column width]:width' \
  '-x+[Set maximum number of iterations for SATISFY]:max' \
  '-y[Run in Purge mode]' \
  '-z+[Daemon mode with wake interval in minutes]:minutes' \
  '*:reminder file:_files' && ret=0

return ret
