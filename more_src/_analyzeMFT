#compdef analyzeMFT analyzemft analyzeMFT.py
# Documentation: https://github.com/rowingdude/analyzeMFT/blob/master/USAGE.md
# analyzeMFT - NTFS Master File Table parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'=[read MFT from file]:file:_files' \
  '(-o --output)'{-o,--output}'=[write CSV results to file]:file:_files' \
  '(-b --bodyfile)'{-b,--bodyfile}'=[write MAC info to bodyfile]:file:_files' \
  '(-c --csvtimefile)'{-c,--csvtimefile}'=[write CSV timeline file]:file:_files' \
  '(-a --anomaly)'{-a,--anomaly}'[enable anomaly detection]' \
  '(-l --localtz)'{-l,--localtz}'[report times in local timezone]' \
  '(-d --debug)'{-d,--debug}'[enable debugging output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--bodystd[use STD_INFO timestamps for bodyfile]' \
  '--bodyfull[use full path plus filename]' \
  '--threads=[number of parsing threads]:count' && ret=0

return ret
