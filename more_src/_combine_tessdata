#compdef combine_tessdata
# Documentation: https://man.archlinux.org/search?q=combine_tessdata
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e[extract tessdata components]' \
  '-o[overwrite tessdata components]' \
  '-u[unpack all tessdata components]' \
  '-c[compact a traineddata file]' \
  '-d[show debug info]' \
  '-l[list network information]' \
  '*:file:_files -g "*.(traineddata|unicharset)"' && ret=0

return ret
