#compdef combine_tessdata
# Documentation: https://github.com/tesseract-ocr/tesseract/blob/main/src/training/combine_tessdata.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-e[extract named components from traineddata]' \
  '-o[overwrite individual components in traineddata]' \
  '-u[unpack all components to output path prefix]' \
  '-c[compact LSTM component to int]' \
  '-d[list the directory of components]' \
  '-l[list network information from traineddata]' \
  '-dl[list directory of components and network info]' \
  '-ld[list directory of components and network info]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.(traineddata|unicharset)"' && ret=0

return ret
