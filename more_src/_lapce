#compdef lapce

# Zsh completion for Lapce editor

_lapce() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-n[do not load previous state]' \
    '--new[do not load previous state]' \
    '-w[wait until the files have been closed]' \
    '--wait[wait until the files have been closed]' \
    '-d[compare two files with each other]' \
    '--diff[compare two files with each other]' \
    '-g[go to specific line and column]:line\:column:' \
    '--goto=[go to specific line and column]:line\:column:' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-V --version)'{-V,--version}'[display version]' \
    '--verbose[verbose logging]' \
    '*:file:_files' \
    && ret=0

  return ret
}

_lapce "$@"
