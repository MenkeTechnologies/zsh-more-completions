#compdef valhalla_ways_to_edges
# Documentation: https://github.com/valhalla/valhalla
# Generate a list of edges for each auto-drivable OSM way.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to JSON config file]:file:_files -g "*.json(-.)"' \
  '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' && ret=0

return ret
