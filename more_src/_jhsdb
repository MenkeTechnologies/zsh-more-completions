#compdef jhsdb

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'clhsdb:command-line HotSpot debugger'
    'hsdb:graphical HotSpot debugger'
    'jstack:print Java stack traces'
    'jmap:print heap info or dump'
    'jinfo:print JVM flags and properties'
    'jsnap:print performance counters'
    'debugd:attach to process and act as debug server'
)

_arguments -s -S \
    '--help[show help]' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'jhsdb subcommand' subcommands
        ;;
    args)
        case $words[1] in
            jstack)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--connect=[debug server]:server' \
                    '--mixed[print both Java and native frames]' \
                    '--locks[print lock info]'
                ;;
            jmap)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--connect=[debug server]:server' \
                    '--heap[print heap summary]' \
                    '--histo[print class histogram]' \
                    '--clstats[print class loader stats]' \
                    '--finalizerinfo[print finalizer queue info]' \
                    '--binaryheap[dump heap in binary format]' \
                    '--dumpfile=[heap dump file]:file:_files'
                ;;
            jinfo)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--connect=[debug server]:server' \
                    '--flags[print VM flags]' \
                    '--sysprops[print system properties]'
                ;;
            jsnap)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--connect=[debug server]:server' \
                    '--all[print all performance counters]'
                ;;
            debugd)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--serverid=[unique server ID]:server ID'
                ;;
            clhsdb|hsdb)
                _arguments \
                    '--pid=[process ID]:PID' \
                    '--exe=[executable]:executable:_files' \
                    '--core=[core file]:core file:_files' \
                    '--connect=[debug server]:server'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
