#compdef condor_fetchlog
# Documentation: https://man.archlinux.org/search?q=condor_fetchlog
# Reference accessed: 2026-05-16

# condor_fetchlog: fetch a Condor daemon log over the network
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-pool[pool/collector]:pool:' \
  '-debug[debug]' \
  '*:host subsystem:' && ret=0
return ret
