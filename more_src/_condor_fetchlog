#compdef condor_fetchlog
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_fetchlog.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_fetchlog: fetch a HTCondor daemon log over the network.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[central manager host[:port]]:pool:' \
  '-master[send to condor_master daemon (default)]' \
  '-startd[send to condor_startd daemon]' \
  '-schedd[send to condor_schedd daemon]' \
  '-collector[send to condor_collector daemon]' \
  '-negotiator[send to condor_negotiator daemon]' \
  '-kbdd[send to condor_kbdd daemon]' \
  '*:host subsystem:' && ret=0
return ret
