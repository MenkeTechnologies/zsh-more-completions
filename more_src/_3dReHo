#compdef 3dReHo
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dReHo.html
# AFNI: regional homogeneity (Kendall W) of voxel neighborhoods

local ret=1

_arguments -s -S \
  '-prefix[output file name prefix]:prefix:' \
  '-inset[input time series file]:dataset:_files' \
  '-nneigh[neighborhood size 7/19/27 (default 27)]:n:(7 19 27)' \
  '-chi_sq[output Friedman chi-square sub-brick]' \
  '-mask[whole brain mask]:mask:_files' \
  '-in_rois[ROI labels for per-region ReHo]:rois:_files' \
  '-neigh_RAD[spherical neighborhood radius]:R:' \
  '-neigh_X[ellipsoidal semi-radius X]:A:' \
  '-neigh_Y[ellipsoidal semi-radius Y]:B:' \
  '-neigh_Z[ellipsoidal semi-radius Z]:C:' \
  '-box_RAD[cubic box neighborhood size]:BR:' \
  '-box_X[box extent along X]:BA:' \
  '-box_Y[box extent along Y]:BB:' \
  '-box_Z[box extent along Z]:BC:' \
  '*:dataset:_files' && ret=0

return ret
