#compdef qrkey
# Documentation: https://github.com/Techwolf12/qrkey
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'generate:generate QR codes from a file'
      'recover:recover a file from QR codes'
    )
    _describe -t commands 'qrkey command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (generate)
        _arguments -s -S \
          '--in=[input file]:file:_files' \
          '--out=[output PDF file]:file:_files' && ret=0
        ;;
      (recover)
        _arguments -s -S \
          '--in=[input text file with QR codes]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
