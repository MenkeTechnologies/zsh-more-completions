#compdef stmux
# Documentation: https://github.com/rse/stmux
# Source: rse/stmux — Node.js Blessed-based terminal multiplexer for build scripts.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-w --wait)'{-w+,--wait=}'[wait after last command finishes]:condition:(error always)' \
    '(-a --activator)'{-a+,--activator=}'[prefix key (default a)]:key:_default' \
    '(-t --title)'{-t+,--title=}'[terminal window title]:title:_default' \
    '(-c --cursor)'{-c+,--cursor=}'[cursor style]:type:(block underline line)' \
    '(-n --number)'{-n,--number}'[display terminal numbers in titles]' \
    '(-e --error)'{-e+,--error=}'[monitor for error pattern]:regexp:_default' \
    '(-m --method)'{-m+,--method=}'[notification methods]:methods:_default' \
    '(-M --mouse)'{-M,--mouse}'[enable mouse event handling]' \
    '(-f --file)'{-f+,--file=}'[read specification from configuration file]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*:specification args:_default' \
    && ret=0

return ret
