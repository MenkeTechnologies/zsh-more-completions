#compdef aubioquiet

# aubioquiet: detect quiet/silence regions
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-i[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '--input=[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '-r[sample rate]:rate:' \
  '--samplerate=[sample rate]:rate:' \
  '-B[buffer size]:n:' \
  '--bufsize=[buffer size]:n:' \
  '-H[hop size]:n:' \
  '--hopsize=[hop size]:n:' \
  -s[silence threshold dB]:db: -t[duration of silence]:sec: \
  '*::aubioquiet args:_files' && ret=0
return ret
