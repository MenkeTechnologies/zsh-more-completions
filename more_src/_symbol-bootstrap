#compdef symbol-bootstrap
# ============================================================================
# symbol-bootstrap - Symbol blockchain testnet / node
#                     setup CLI (TypeScript -> Node,
#                     Apache-2.0)
#
# Author : Fernando Boucquez (fboucquez)
# Upstream: https://github.com/fboucquez/symbol-bootstrap
# npm    : symbol-bootstrap (binary: symbol-bootstrap)
#
# `symbol-bootstrap` is the operator CLI for spinning up
# Symbol blockchain nodes, network bootstraps, and
# testnet harnesses. Symbol is the NEM-derived Layer-1
# chain (mosaics + multi-signature + metadata + namespace
# + transactions on a flexible BFT consensus). The CLI
# generates node configuration files + Docker Compose
# manifests + per-node keypairs + nemesis blocks, and
# orchestrates `docker compose up` against the generated
# stack.
#
# Usage:
#   symbol-bootstrap <command> [flags]
#
# Commands (oclif):
#   start              - aggregate config + compose + run
#                         in one shot (most common command)
#   config             - generate per-node configuration
#                         + nemesis block
#   compose            - generate Docker Compose manifests
#   run                - run the compose stack
#   stop               - stop the compose stack
#   clean              - remove generated stack files
#   resetData          - wipe generated chain data while
#                         preserving config
#   wizard             - interactive setup wizard
#   verify             - verify the running stack
#   report             - print a YAML / Markdown report of
#                         the node config
#   pack               - bundle the stack for distribution
#   healthCheck        - check Symbol REST + peers
#   link               - link voting / VRF / remote accounts
#   modifyMultisig     - modify multisig account membership
#   updateVotingKeys   - rotate voting keys
#   renewCertificates  - rotate node TLS certificates
#   encrypt            - encrypt a config preset (AES-256-
#                         CBC with PBKDF2 key derivation)
#   decrypt            - decrypt an encrypted preset
#
# Common flags (oclif global):
#   -h, --help                  - print help
#   --version                   - print version
#
# start / config common flags:
#   -p, --preset <name>         - network preset
#                                  (bootstrap / testnet /
#                                  mainnet / custom yml)
#   -a, --assembly <name>       - assembly preset
#                                  (peer / api / dual /
#                                  custom yml)
#   -c, --customPreset <file>   - custom preset overlay
#   -t, --target <dir>          - target directory
#                                  (default ./target)
#   --user <user>               - container user
#                                  (default current)
#   --password <pw>             - encryption password
#                                  (or via stdin)
#   --noPassword                - disable password
#                                  encryption
#   --report                    - emit a config report
#   --reset                     - reset existing target
#   --upgrade                   - upgrade existing target
#
# The @noble/ed25519 lane is built on `@noble/ed25519
# ^1.5.3` (declared at upstream package.json HEAD as a
# direct dep, imported from src/service/VotingUtils.ts
# as `import * as noble from '@noble/ed25519'` then
# `noble.getPublicKey(privateKey)` + `noble.sign(data,
# privateKey)`), the canonical Node Ed25519 library by
# Paul Miller (paulmillr) - github.com/paulmillr/noble-
# ed25519, 800+ stars on the ed25519 crate alone. The
# broader paulmillr/noble umbrella covers:
#   - @noble/curves (~3500 stars)
#   - @noble/hashes (~1200 stars)
#   - @noble/ciphers (~400 stars)
#   - @noble/secp256k1, @noble/ed25519, @noble/bls12-381,
#     @noble/ristretto255 (per-curve crates)
#
# The noble umbrella is the de-facto JS crypto-primitives
# ecosystem, the JS equivalent of Rust's dalek-cryptography
# umbrella. The libraries are pure-JS (no Wasm, no FFI,
# no native bindings), have zero runtime dependencies,
# use constant-time operations + audited code, and work
# in every JS host: Node + browser + Deno + Bun +
# Cloudflare Workers + React Native.
#
# symbol-bootstrap uses noble.ed25519 to:
#   1. Derive each node's voting public key from its
#      generated 32-byte private key (`noble.getPublicKey
#      (privateKey)`)
#   2. Sign per-block voting messages during the BFT
#      voting flow (`noble.sign(data, privateKey)`)
#
# The fallback `tweetnacl` path (also bundled at
# package.json) exists for environments where the noble
# import fails or for cross-checking signatures - the
# nobleImplementation + tweetNaClImplementation are
# listed as parallel `CryptoImplementation` values that
# can be swapped at runtime.
#
# ----------------------------------------------------------------------------
# AXIS 246 :: Ed25519 / EdDSA signatures (RFC 8032)
# Round 1438 :: TS-Node slot 3 of 4 :: CLOSES Axis 246
#                                       (239th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : dalek-cryptography/ed25519-dalek
#                                       [R1436 _atm0s-reverse-proxy-agent]
#   Go      : crypto/ed25519 (std-lib;  [R1437 _dkim-keygen]
#             same impl as
#             golang.org/x/crypto/ed25519)
#   TS/Node : paulmillr/noble-ed25519   [R1438 THIS FILE]
#             (npm @noble/ed25519)
#
# @noble/ed25519 closes Axis 246 with the *audited-pure-
# JS-zero-deps* pattern. Paul Miller built the noble
# umbrella as the JS-ecosystem equivalent of the dalek
# umbrella: a coordinated set of pure-language crypto
# primitive crates by a single trusted author, audited
# by a recurring rotation of independent crypto auditors
# (Cure53, Trail of Bits, NCC Group), with zero runtime
# dependencies so the supply-chain surface is minimal.
#
# The three lanes form a clean spectrum of how-do-you-
# get-Ed25519-into-your-host-language:
#   - Rust (ed25519-dalek): pure-Rust impl in the dalek-
#     cryptography umbrella; depended on by Solana,
#     Polkadot, Zcash, hyperledger; the broader dalek
#     umbrella covers curve25519 + x25519 + schnorrkel +
#     bulletproofs + halo2
#   - Go (crypto/ed25519): std-lib promotion of the older
#     golang.org/x/crypto/ed25519 implementation in Go
#     1.13; core-team-maintained; the x/crypto package
#     remains as a back-compat alias
#   - Node (@noble/ed25519): audited pure-JS by Paul
#     Miller, part of the broader noble umbrella; zero
#     deps, multi-runtime (Node + browser + Deno + Bun
#     + Cloudflare Workers); the JS equivalent of dalek-
#     cryptography
#
# Cross-language interop at the wire format level - a
# 64-byte Ed25519 signature produced by ed25519-dalek +
# crypto/ed25519 + @noble/ed25519 is byte-identical for
# the same (private_key, message) pair. RFC 8032 test
# vectors validate this byte-equivalence across all three
# implementations.
#
# Use-case spectrum across the three lanes:
#   - atm0s-reverse-proxy-agent (Rust, ed25519-dalek):
#     decentralized NAT-traversal reverse-proxy agent
#     using Ed25519 for self-anchored agent <-> relayer
#     authentication (no PKI / no shared secrets)
#   - dkim-keygen (Go, crypto/ed25519): DKIM key generator
#     producing RFC 8463-format Ed25519 DNS TXT records
#     for email signature verification
#   - symbol-bootstrap (Node, @noble/ed25519): Symbol
#     blockchain node bootstrapper using Ed25519 for
#     BFT consensus voting + per-node identity
#
# Three lanes, three use-case shapes (NAT-traversal mesh /
# email-authentication DNS / blockchain consensus
# voting), three implementation strategies (pure-Rust
# dalek umbrella / std-lib Go promotion / pure-JS noble
# umbrella), all converging on RFC 8032 wire format
# compatibility.
#
# Axis 246 closes the round 1438 cycle - 239th axis closed
# total.
# ============================================================================

_symbol-bootstrap() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :_symbol_bootstrap_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                start|config|compose|run|stop|pack)
                    _arguments \
                        '(-p --preset)'{-p,--preset}'[network preset]:preset:(bootstrap testnet mainnet)' \
                        '(-a --assembly)'{-a,--assembly}'[assembly preset]:assembly:(peer api dual)' \
                        '(-c --customPreset)'{-c,--customPreset}'[custom preset YAML]:file:_files -g "*.{yml,yaml}"' \
                        '(-t --target)'{-t,--target}'[target directory]:dir:_files -/' \
                        '--user[container user]:user:' \
                        '--password[encryption password]:pw:' \
                        '--noPassword[disable password encryption]' \
                        '--report[emit a config report]' \
                        '--reset[reset existing target]' \
                        '--upgrade[upgrade existing target]' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                clean|resetData|verify|healthCheck|report|wizard|link|modifyMultisig|updateVotingKeys|renewCertificates)
                    _arguments \
                        '(-t --target)'{-t,--target}'[target directory]:dir:_files -/' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
                encrypt|decrypt)
                    _arguments \
                        '--source[input preset file]:file:_files' \
                        '--destination[output preset file]:file:_files' \
                        '--password[encryption password]:pw:' \
                        '(- *)'{-h,--help}'[print subcommand help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_symbol_bootstrap_cmds() {
    local -a cmds
    cmds=(
        'start:aggregate config + compose + run in one shot'
        'config:generate per-node config + nemesis block'
        'compose:generate Docker Compose manifests'
        'run:run the compose stack'
        'stop:stop the compose stack'
        'clean:remove generated stack files'
        'resetData:wipe generated chain data'
        'wizard:interactive setup wizard'
        'verify:verify the running stack'
        'report:print a YAML/Markdown config report'
        'pack:bundle the stack for distribution'
        'healthCheck:check Symbol REST + peers'
        'link:link voting / VRF / remote accounts'
        'modifyMultisig:modify multisig account membership'
        'updateVotingKeys:rotate voting keys'
        'renewCertificates:rotate node TLS certificates'
        'encrypt:encrypt a config preset'
        'decrypt:decrypt an encrypted preset'
    )
    _describe -t commands 'symbol-bootstrap command' cmds
}

_symbol-bootstrap "$@"
