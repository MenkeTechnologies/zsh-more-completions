#compdef hostess

# Zsh completion for hostess - /etc/hosts manager

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'add:add or replace a hosts entry'
      'aff:add hosts entry and immediately enable it'
      'apply:apply hosts file from JSON'
      'del:delete a hosts entry'
      'dump:dump hosts file as JSON'
      'fix:reformat hosts file'
      'fmt:alias for fix'
      'has:check if a hostname exists'
      'ls:list hosts entries'
      'off:disable a hostname'
      'on:enable a hostname'
      'rm:alias for del'
    )
    _describe -t commands 'hostess commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      add|aff)
        _arguments -s -S \
          '1:hostname:' \
          '2:ip address:' && ret=0
        ;;
      del|rm|off|on|has)
        _arguments -s -S \
          '1:hostname:' && ret=0
        ;;
      apply)
        _arguments -s -S \
          '1:JSON file:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
