#compdef patat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-w[watch file for changes]' \
  '--watch[watch file for changes]' \
  '-f[force ANSI terminal]' \
  '--force[force ANSI terminal]' \
  '-d+[initial slide number]:slide number:' \
  '--dump[dump presentation as text]' \
  '-s+[slide separator]:separator:' \
  '--syntax-definition=[custom syntax definition]:file:_files' \
  '--syntax-theme=[syntax highlight theme]:theme:' \
  '--images=[image rendering method]:method:(auto iterm2 kitty w3m)' \
  '--eval-command=[command for eval blocks]:command:_command_names' \
  '1:presentation file:_files -g "*.(md|markdown|txt)"' && ret=0

return ret
