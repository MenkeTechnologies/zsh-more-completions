#compdef patat
# Documentation: https://github.com/jaspervdj/patat
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[display version info and exit]' \
  '(-w --watch)'{-w,--watch}'[watch file for changes]' \
  '(-f --force)'{-f,--force}'[force ANSI terminal]' \
  '(-d --dump)'{-d,--dump}'[just dump all slides and exit]' \
  '1:presentation file:_files -g "*.(md|markdown|txt)"' && ret=0

return ret
