  _arguments -C \
    '--ttl[lock TTL in seconds]:seconds:' \
    '--owner[owner agent ID]:agent ID:_pd_complete_agents' \
    '(-j --json)'{-j,--json}'[JSON output]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
