#compdef sfdip
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/pwd/Mdip.c
# Madagascar: 3-D dip estimation by plane wave destruction

local ret=1

_arguments -s \
  'both=[if y compute both left and right predictions]:both:(y n)' \
  'n4=[what to compute in 3-D: 0 in-line 1 cross-line 2 both]:n4:(0 1 2)' \
  'niter=[number of iterations]:niter' \
  'liter=[number of linear iterations]:liter' \
  'rect1=[dip smoothness on 1st axis]:rect1' \
  'rect2=[dip smoothness on 2nd axis]:rect2' \
  'rect3=[dip smoothness on 3rd axis]:rect3' \
  'p0=[initial in-line dip]:p0' \
  'q0=[initial cross-line dip]:q0' \
  'order=[accuracy order]:order' \
  'nj1=[in-line antialiasing]:nj1' \
  'nj2=[cross-line antialiasing]:nj2' \
  'drift=[if shift filter]:drift:(y n)' \
  'verb=[verbosity flag]:verb:(y n)' \
  'pmin=[minimum inline dip]:pmin' \
  'pmax=[maximum inline dip]:pmax' \
  'qmin=[minimum cross-line dip]:qmin' \
  'qmax=[maximum cross-line dip]:qmax' \
  'eps=[regularization]:eps' \
  'mask=[mask file for dip estimation]:mask file:_files' \
  'idip=[initial in-line dip file]:idip file:_files' \
  'xdip=[initial cross-line dip file]:xdip file:_files' \
  '*:RSF file:_files' && ret=0

return ret
