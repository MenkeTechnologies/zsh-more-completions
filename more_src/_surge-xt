#compdef surge-xt Surge-XT surge-xt-cli
# Documentation: https://man.archlinux.org/search?q=surge-xt
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:patch:_files -g "*.fxp"' && ret=0

return ret
