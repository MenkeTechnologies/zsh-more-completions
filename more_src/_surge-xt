#compdef surge-xt-cli surge-xt Surge-XT
# Documentation: https://github.com/surge-synthesizer/surge/blob/main/src/surge-xt/cli/cli-main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream source surge-xt/cli/cli-main.cpp at the URL above.
# Note: the surge-xt GUI standalone has no CLI flags; this completion
# covers the surge-xt-cli headless binary's options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-l,--list-devices}'[list available audio/MIDI devices and exit]' \
  '--audio-interface=[audio output device index (e.g. 0.2)]:index:' \
  '--audio-ports=[output ports, zero-indexed pair (e.g. 0,1)]:ports:' \
  '--audio-input-interface=[audio input device index]:index:' \
  '--audio-input-ports=[input ports]:ports:' \
  '--all-midi-inputs[connect all available MIDI inputs]' \
  '--midi-input=[connect a single MIDI input by index]:index:' \
  '--osc-in-port=[OSC input port]:port:' \
  '--osc-out-port=[OSC output port]:port:' \
  '--osc-out-ipaddr=[OSC output IP address (default 127.0.0.1)]:ip:' \
  '--sample-rate=[audio sample rate in Hz]:hz:' \
  '--buffer-size=[audio buffer size in samples]:samples:' \
  '--init-patch=[load a patch file at startup]:file:_files -g "*.fxp"' \
  '--no-stdin[disable keyboard input polling]' \
  '--mpe-enable[enable MPE mode]' \
  '--mpe-pitch-bend-range=[MPE pitch bend range in semitones]:semitones:' \
  '*:patch:_files -g "*.fxp"' && ret=0

return ret
