#compdef scil_tractogram_filter_by_roi
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_filter_by_roi.html
# Filter streamlines by ROIs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--drawn_roi[hand-drawn ROI from binary file]:roi:_files -g "*.nii *.nii.gz"' \
  '*--atlas_roi[atlas label selection]:atlas:_files -g "*.nii *.nii.gz"' \
  '*--bdo[bounding box file from MI-Brain]:bdo:_files' \
  '*--x_plane[plane slice number in voxel space]:x' \
  '*--y_plane[plane slice number in voxel space]:y' \
  '*--z_plane[plane slice number in voxel space]:z' \
  '--filtering_list=[text file with one filtering rule per line]:file:_files' \
  '*--overwrite_distance[replace distance values for mode/criteria]:value' \
  '--no_empty[prevent output file creation if no streamlines remain]' \
  '--display_counts[show streamline counts before/after filtering]' \
  '--save_rejected=[output rejected streamlines to file]:file:_files' \
  '--save_masks_atlas_roi=[save atlas ROI masks with prefix]:prefix' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '--indent=[JSON pretty-print indentation]:indent' \
  '--sort_keys[sort JSON output keys]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[force overwrite output files]' \
  '1:in_tractogram:_files' \
  '2:out_tractogram:_files' && ret=0

return ret
