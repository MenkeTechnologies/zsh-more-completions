#compdef flare
# Documentation: https://flarerpg.org/index.php/manual
# Reference accessed: 2026-05-16

# Flare: free single-player 2D action RPG
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--data-path=[data path]:dir:_files -/' \
  '--mods=[mod list]:list:' \
  '--mod-paths=[mod paths]:list:' \
  '--no-audio[disable audio]' \
  '--load-script=[load script]:file:_files' \
  '--load-slot=[load save slot]:n:' \
  '--debug[debug mode]' \
  '--render-device=[renderer]:renderer:(software hardware sdl_renderer)' \
  '*::flare args:_files' && ret=0
return ret
