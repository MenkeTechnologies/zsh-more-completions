#compdef astscript
# astscript — GNU Astronomy Utilities script runner

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cite[show citation info]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '--command[run inline script]:script:' \
  '--installdir[installation directory]:dir:_directories' \
  '--list[list available scripts]' \
  '--dryrun[print commands without running]' \
  '*:script or input file:_files'
