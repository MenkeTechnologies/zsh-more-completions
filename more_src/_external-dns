#compdef external-dns
# Documentation: https://man.archlinux.org/search?q=external-dns
# Reference accessed: 2026-05-16

# external-dns: sync exposed Kubernetes Services and Ingresses with DNS providers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--source=[source type]:source:(service ingress node fake connector istio-gateway istio-virtualservice cloudfoundry contour-httpproxy crd empty f5-virtualserver gateway-grpcroute gateway-httproute gateway-tcproute gateway-tlsroute gateway-udproute gloo-proxy kong-tcpingress openshift-route skipper-routegroup traefik-proxy ambassador-host)' \
  '--provider=[DNS provider]:provider:(aws aws-sd azure azure-private-dns google cloudflare digitalocean rfc2136 designate akamai dnsimple infoblox dyn ns1 oci rcodezero gandi godaddy hetzner inmemory linode nfsd ovh pdns plural rdns rfc2136 scaleway transip ultradns)' \
  '--domain-filter=[domain filter]:domains:' \
  '--exclude-domains=[exclude domains]:domains:' \
  '--registry=[registry type]:registry:(txt aws-sd noop)' \
  '--txt-owner-id=[TXT owner id]:id:' \
  '--txt-prefix=[TXT prefix]:prefix:' \
  '--txt-suffix=[TXT suffix]:suffix:' \
  '--policy=[policy]:policy:(sync upsert-only create-only)' \
  '--namespace=[k8s namespace]:ns:' \
  '--annotation-filter=[annotation filter]:filter:' \
  '--label-filter=[label filter]:filter:' \
  '--fqdn-template=[FQDN template]:template:' \
  '--ignore-hostname-annotation[ignore hostname annotation]' \
  '--ignore-ingress-tls-spec[ignore ingress TLS spec]' \
  '--interval=[reconcile interval]:duration:' \
  '--once[run once and exit]' \
  '--dry-run[dry run]' \
  '--log-level=[log level]:level:(debug info warn error fatal panic)' \
  '--log-format=[log format]:fmt:(text json)' \
  '--metrics-address=[metrics address]:addr:' \
  '--server=[k8s API server]:url:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--request-timeout=[request timeout]:duration:' \
  '--aws-zone-type=[AWS zone type]:type:(public private)' \
  '--aws-zone-tags=[AWS zone tags]:tags:' \
  '--aws-zones-cache-duration=[AWS zone cache duration]:duration:' \
  '--aws-batch-change-size=[AWS batch change size]:n:' \
  '--aws-batch-change-interval=[AWS batch change interval]:duration:' \
  '--aws-evaluate-target-health=[evaluate target health]:bool:(true false)' \
  '--cloudflare-proxied[cloudflare proxied]' \
  '--cloudflare-dns-records-per-page=[records per page]:n:' \
  '*::external-dns args:_files' && ret=0
return ret
