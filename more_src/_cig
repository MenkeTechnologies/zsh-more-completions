#compdef cig
# Documentation: https://man.archlinux.org/search?q=cig
# Reference accessed: 2026-05-16

# stevenjack/cig (git commit frequency); Homebrew: Formula/c/cig.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '(--cp)--cp=[config path]:path:_files -g "*.yml"' \
  '(--days)--days=[number of days]:days:' \
  '*:: :_default' && ret=0
return ret
