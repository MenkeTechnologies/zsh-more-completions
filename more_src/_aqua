#compdef aqua

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize aqua config'
  'install:install tools (alias i)'
  'i:install tools'
  'update-aqua:update aqua itself'
  'update-checksum:update checksums (upc)'
  'upc:update checksums'
  'update:update tools'
  'generate:generate config (g)'
  'g:generate config'
  'genr:generate registry'
  'which:show tool location'
  'info:show aqua info'
  'remove:remove tool'
  'vacuum:remove unused tools'
  'token:manage GitHub token'
  'cp:copy a tool'
  'policy:manage policy (init)'
  'exec:exec tool with given config'
  'list:list configured tools'
  'root:show aqua root dir'
  'completion:generate shell completion'
  'help:show help'
  'version:print version'
)

_arguments -C \
  '--log-level=[log level]:level:(debug info warn error)' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.(yaml|yml)"' \
  '--disable-cosign[disable cosign verification]' \
  '--disable-slsa[disable SLSA verification]' \
  '--disable-github-artifact-attestation[disable GAA]' \
  '--disable-github-immutable-release[disable GIR]' \
  '--trace=[trace file]:file:_files' \
  '--cpu-profile=[CPU profile file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'aqua subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (install|i)
        _arguments \
          '(-l --only-link)'{-l,--only-link}'[only link]' \
          '--test[test mode]' \
          '(-a --all)'{-a,--all}'[install all]' \
          '*'{-t,--tags}'=[tag]:tag:' \
          '*--exclude-tags=[exclude tag]:tag:' && ret=0
        ;;
      (generate|g)
        _arguments \
          '-f=[input file]:file:_files' \
          '-i[interactive]' \
          '--pin[pin version]' \
          '-g[also write registry]' \
          '(-d --detail)'{-d,--detail}'[generate with detail]' \
          '-o=[output file]:file:_files' \
          '(-s --select-version)'{-s,--select-version}'[select version interactively]' \
          '--limit=[result limit]:n:' \
          '--insert[insert into existing config]' && ret=0
        ;;
    esac
    ;;
esac

return ret
