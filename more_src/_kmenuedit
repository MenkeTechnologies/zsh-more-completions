#compdef kmenuedit
# _kmenuedit — KDE kmenuedit (Plasma start-menu editor; --menu opens to a specific menu file, --systemmenu edits the system menu (root), --noinit skips first-run wizard; reads/writes XML in $XDG_CONFIG_HOME/menus/)
# upstream: https://invent.kde.org/plasma/kmenuedit
# Flags from kmenuedit src/main.cpp on tip.

_kmenuedit() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--menu+[menu file]:file:_files -g "*.menu"' \
        '--systemmenu[edit system menu]' \
        '--noinit[no init dialogs]'
}

_kmenuedit "$@"
