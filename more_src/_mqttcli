#compdef mqttcli

# Zsh completion for mqttcli - MQTT client written in Go

local curcontext="$curcontext" state line ret=1

_mqttcli_commands() {
  local -a commands=(
    'pub:publish a message'
    'sub:subscribe to a topic'
    'help:show help'
  )
  _describe -t commands 'mqttcli command' commands
}

_arguments -C \
  '--help[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-d[debug mode]' \
  '1: :_mqttcli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      pub)
        _arguments \
          '-c[config file path]:file:_files' \
          '--host[broker host]:host' \
          '-p[broker port]:port' \
          '(-q --qos)'{-q,--qos}'[qos level]:qos:(0 1 2)' \
          '(-r --retain)'{-r,--retain}'[retain message]' \
          '(-t --topic)'{-t,--topic}'[MQTT topic]:topic' \
          '(-m --message)'{-m,--message}'[message body]:message' \
          '(-f --file)'{-f,--file}'[read message body from file]:file:_files' \
          '(-n --null-message)'{-n,--null-message}'[send null message]' \
          '(-s --stdin-line)'{-s,--stdin-line}'[read messages from stdin lines]' \
          '(-S --stdin-file)'{-S,--stdin-file}'[read one message body from stdin]' \
          '--insecure[skip TLS verification]' \
          '--tls-ca-file[CA cert file]:file:_files' \
          '--tls-cert-file[client cert file]:file:_files' \
          '--tls-key-file[client key file]:file:_files' \
          '--user[MQTT username]:username' \
          '--pw[MQTT password]:password' \
          '--client-id[MQTT client id]:client-id' \
          '--will-topic[will topic]:topic' \
          '--will-payload[will payload]:payload' \
          '--will-qos[will qos]:qos:(0 1 2)' \
          '--will-retain[will retain]' && ret=0
        ;;
      sub)
        _arguments \
          '-c[config file path]:file:_files' \
          '--host[broker host]:host' \
          '-p[broker port]:port' \
          '(-q --qos)'{-q,--qos}'[qos level]:qos:(0 1 2)' \
          '(-t --topic)'{-t,--topic}'[MQTT topic]:topic' \
          '--user[MQTT username]:username' \
          '--pw[MQTT password]:password' \
          '--client-id[MQTT client id]:client-id' \
          '--insecure[skip TLS verification]' \
          '--tls-ca-file[CA cert file]:file:_files' \
          '--tls-cert-file[client cert file]:file:_files' \
          '--tls-key-file[client key file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
