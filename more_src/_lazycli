#compdef lazycli
# Documentation: https://github.com/jesseduffield/lazycli/blob/master/src/args.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Flag set taken from the clap definition in src/args.rs. There is no
# --config/--print-config in the binary — config lives in $XDG_CONFIG_HOME
# and is edited interactively with `$` inside the TUI.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --ignore)'{-i,--ignore}'=[ignore first N lines of output]:n:' \
  '(-r --refresh)'{-r,--refresh}'=[refresh frequency in seconds]:seconds:' \
  '*: :_command_names' && ret=0

return ret
