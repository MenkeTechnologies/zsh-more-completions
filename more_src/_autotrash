#compdef autotrash
# _autotrash — autotrash (Python helper that purges items from the XDG Trash directory older than a threshold or once the trash exceeds a quota; -d N days delete after, --min-free MB keep this much free, --max-free, --trash-dir override, -i interactive)
# upstream: https://github.com/bneijt/autotrash
# Flags from autotrash autotrash/_cli.py on tip.

_autotrash() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[delete after N days]:days:' \
        '--days+[delete after N days]:days:' \
        '--min-free+[MB free target]:mb:' \
        '--max-free+[MB free cap]:mb:' \
        '--trash-dir+[trash dir]:dir:_files -/' \
        '-T+[trash dir]:dir:_files -/' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--check[show planned deletions only]' \
        '--dry-run[show planned deletions only]' \
        '--delete+[delete first N MB]:mb:' \
        '--stat[print stats]' \
        '--user+[user]:user:_users' \
        '--info[show config and exit]'
}

_autotrash "$@"
