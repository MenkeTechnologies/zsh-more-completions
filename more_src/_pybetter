#compdef pybetter
# Documentation: https://github.com/lensvol/pybetter
# pybetter - tool for fixing trivial Python code problems

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--noop[do not make any changes to the source files]' \
  '--diff[show diff-like output of the changes made]' \
  '--select=[apply only improvements with the provided codes]:codes:' \
  '--exclude=[exclude improvements with the provided codes]:codes:' \
  '--exit-code=[exit with provided code if fixes were applied]:code:' \
  '*:path:_files' && ret=0

return ret
