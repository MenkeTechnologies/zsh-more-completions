#compdef soft
# Documentation: https://github.com/charmbracelet/soft-serve
# Reference accessed: 2026-05-17
# Verified: charmbracelet/soft-serve upstream — self-hostable Git
# server with TUI accessible over SSH. Subcommands: serve, hook,
# migrate-config, man, help. Configuration primarily via env vars
# (SOFT_SERVE_DATA_PATH, SOFT_SERVE_INITIAL_ADMIN_KEYS, etc.) and
# config.yaml. Few CLI flags directly.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for soft-serve - self-hostable Git server with TUI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'serve:start the server'
      'hook:run Git hooks'
      'migrate:run database migrations'
      'admin:admin management commands'
      'man:generate man pages'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config[config file path]:file:_files' \
          '--data-path[data directory path]:dir:_directories' \
          '--initial-admin-keys[initial admin SSH keys]:keys:' \
          && ret=0
        ;;
      (admin)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(user repo settings)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
