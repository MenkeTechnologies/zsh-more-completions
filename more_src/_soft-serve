#compdef soft
# Documentation: https://github.com/charmbracelet/soft-serve
# Reference accessed: 2026-05-21
# Verified: charmbracelet/soft-serve upstream README. Soft Serve is a
# self-hostable Git server with TUI accessible over SSH. The `soft`
# binary primarily ships `serve` (start server), `browse` (local repo
# browser), `hook` (Git hooks), and `man` subcommands; admin operations
# (user, repo, pubkey, settings, token, info) are issued over SSH to a
# running instance, not via local subcommands. Removed from prior file:
# fabricated `migrate` subcommand and bogus inline admin flags.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'serve:start the Soft Serve server'
      'browse:browse local repositories'
      'hook:run Git hooks'
      'man:generate man pages'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      (browse)
        _arguments \
          '1:directory:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
