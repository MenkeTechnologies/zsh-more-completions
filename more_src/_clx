#compdef clx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config+[path to config file]:config:_files' \
  '--comment-width+[width of comment section]:width:' \
  '--indent-size+[indent size for nested comments]:size:' \
  '--highlight-headlines[highlight headlines in articles]' \
  '--no-less-verify[do not verify less is available]' && ret=0

return ret
