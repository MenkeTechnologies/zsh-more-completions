#compdef dwicat
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwicat.html
# Source: MRtrix3/mrtrix3 bin/dwicat — concatenate DWI series with intensity matching (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[binary mask for intensity matching]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '*:inputs (DWI series) + output:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
