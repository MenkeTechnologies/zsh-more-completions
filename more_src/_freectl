#compdef freectl
# Documentation: https://github.com/Igglybuff/freectl
# Source: Igglybuff/freectl cmd/ — Go CLI for finding cool stuff (spf13/cobra).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _freectl_cmds
_freectl_cmds=(
    'add:add a source'
    'delete:delete a source'
    'list:list sources'
    'process:process sources'
    'search:search across sources'
    'serve:start the web interface'
    'stats:show statistics'
    'update:update sources'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'freectl command' _freectl_cmds && ret=0
        ;;
esac

return ret
