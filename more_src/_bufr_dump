#compdef bufr_dump
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_dump
# Source: ecmwf/eccodes tools/bufr_dump.cc — dump BUFR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-j+[JSON mode]:mode:(s f a)' \
    '-D+[decoding dump style]:style:(filter fortran python C)' \
    '-E+[encoding dump style]:style:(filter fortran python C)' \
    '-d[print all data values]' \
    '-O[octet mode (WMO documentation style)]' \
    '-H[print octet content in hex]' \
    '-a[dump aliases]' \
    '-w+[where clause filter]:filter:_default' \
    '(- *)-V[show version]' \
    '-7[do not fail on wrong message length]' \
    '*:bufr file:_files' \
    && ret=0

return ret
