#compdef create_ap

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c)-c+[channel number]:n:' \
  '(-w)-w+[WPA mode]:mode:(1 2 1+2)' \
  '(-n)-n[no internet sharing]' \
  '(-m)-m+[mode]:mode:(nat bridge none)' \
  '--hidden[hidden network]' \
  '--mac=[MAC address]:mac:' \
  '--mac-filter[enable MAC filtering]' \
  '--mac-filter-accept=[accept MACs file]:file:_files' \
  '--isolate-clients[disable comms between clients]' \
  '--ieee80211n[enable 802.11n HT]' \
  '--ieee80211ac[enable 802.11ac VHT]' \
  '--ieee80211ax[enable 802.11ax HE]' \
  '--ht_capab=[HT capabilities]:caps:' \
  '--vht_capab=[VHT capabilities]:caps:' \
  '--country=[two-letter country code]:cc:' \
  '--freq-band=[frequency band]:band:(2.4 5)' \
  '--driver=[wifi driver]:drv:(nl80211 wired none)' \
  '--no-virt[do not create virtual interface]' \
  '--no-haveged[do not run haveged]' \
  '--no-dns[disable DNS]' \
  '--no-dnsmasq[do not run dnsmasq]' \
  '--fix-unmanaged[fix NetworkManager]' \
  '--list-running[list running create_ap processes]' \
  '--list-clients=[list clients of process]:pid:' \
  '--stop=[stop process]:pid:' \
  '--mkconfig=[store configs to file]:file:_files' \
  '--config=[load configs from file]:file:_files' \
  '--daemon[run in background]' \
  '--pidfile=[pidfile]:file:_files' \
  '--logfile=[log file]:file:_files' \
  '-d[do not free pidfile on exit]' \
  '*:: :' && ret=0

return ret
