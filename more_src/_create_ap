#compdef create_ap
# Documentation: https://github.com/oblique/create_ap
# Reference accessed: 2026-05-17
# Verified: upstream create_ap script usage at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c+[channel number]:n:' \
  '-w+[WPA version]:mode:(1 2 1+2)' \
  '-n[no internet sharing]' \
  '-m+[sharing method]:mode:(nat bridge none)' \
  '-g+[IPv4 gateway]:ip:' \
  '--hidden[hidden network]' \
  '--mac=[MAC address]:mac:' \
  '--mac-filter[enable MAC filtering]' \
  '--mac-filter-accept=[accept MACs file]:file:_files' \
  '--isolate-clients[disable client-to-client communication]' \
  '--ieee80211n[enable 802.11n (HT)]' \
  '--ieee80211ac[enable 802.11ac (VHT)]' \
  '--ht_capab=[HT capabilities]:caps:' \
  '--vht_capab=[VHT capabilities]:caps:' \
  '--country=[two-letter country code]:cc:' \
  '--freq-band=[frequency band]:band:(2.4 5)' \
  '--driver=[wifi driver]:drv:' \
  '--no-virt[skip virtual interface creation]' \
  '--psk[use 64-digit pre-shared-key]' \
  '--no-haveged[disable automatic haveged startup]' \
  '--no-dns[disable dnsmasq DNS]' \
  '--no-dnsmasq[disable dnsmasq completely]' \
  '-d[DNS considers /etc/hosts]' \
  '-e+[additional hosts file for DNS]:file:_files' \
  '--dhcp-dns=[DNS returned by DHCP]:ips:' \
  '--redirect-to-localhost[redirect web requests to localhost]' \
  '--fix-unmanaged[fix NetworkManager unmanaged status]' \
  '--list-running[list running create_ap processes]' \
  '--list-clients=[list clients of process]:id:' \
  '--stop=[stop running instance by PID or interface]:id:' \
  '--mkconfig=[store configs to file]:file:_files' \
  '--config=[load configs from file]:file:_files' \
  '--daemon[run in background]' \
  '--pidfile=[pidfile]:file:_files' \
  '--logfile=[log file]:file:_files' \
  '--hostapd-debug=[enable hostapd debug]:level:(1 2)' \
  '*:: :' && ret=0

return ret
