#compdef imodsendevent
# Documentation: https://bio3d.colorado.edu/imod/doc/man/imodsendevent.html
# imodsendevent - sends a clipboard message with a command to 3dmod

local ret=1

_arguments -s -S \
  '(-t)-t[timeout in seconds to wait for a reply from 3dmod]:seconds' \
  '(-D)-D[debug mode; log what is sent]' \
  '(-view)-view[send to 3dmodv instead of 3dmod]' \
  '*:window id action argument:' && ret=0

return ret
