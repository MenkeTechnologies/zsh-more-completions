#compdef db.tables
# GRASS GIS: list all tables for a given database

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  '-p[print tables and exit]' \
  '-s[system tables instead of user tables]' \
  'driver=[database driver]:driver:(dbf odbc ogr pg sqlite)' \
  'database=[database name]:database' && ret=0

return ret
