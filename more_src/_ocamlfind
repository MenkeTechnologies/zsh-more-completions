#compdef ocamlfind
# Documentation: http://projects.camlcity.org/projects/findlib.html
# Reference accessed: 2026-05-19
# Verified: `ocamlfind` and each subcommand `-help` on local
# install (findlib via opam). Top-level subcommands harvested
# from `ocamlfind help`: query, ocamlc, ocamlcp, ocamlmklib,
# ocamlmktop, ocamlopt, ocamloptp, ocamldep, ocamlbrowser,
# ocamldoc, install, remove, printppx, printconf, lint, list.
# Corrected from prior file: 'pkg' subcommand removed (not real,
# was 'pkg/cmd' usage hint); 'printconf' values updated to real
# (conf, path, destdir, metadir, metapath, stdlib, ldconf);
# install flag '-dont-add-directory-to-ldconf' renamed to real
# '-dont-add-directory-directive'; query flags expanded with -d,
# -r, -pp, -prefix, -suffix, -separator, -qe, -qo,
# -help-format; install adds -add, -patch-version, -patch-rmpkg,
# -patch-archives.

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'query:query package properties'
    'ocamlc:invoke ocamlc with package options'
    'ocamlcp:invoke ocamlcp with package options'
    'ocamlopt:invoke ocamlopt with package options'
    'ocamloptp:invoke ocamloptp with package options'
    'ocamldep:invoke ocamldep with package options'
    'ocamldoc:invoke ocamldoc with package options'
    'ocamlmktop:invoke ocamlmktop with package options'
    'ocamlmklib:invoke ocamlmklib with package options'
    'ocamlbrowser:invoke ocamlbrowser with package options'
    'install:install a package'
    'remove:remove a package'
    'printppx:print ppx invocation'
    'printconf:print configuration'
    'lint:lint a META file'
    'list:list installed packages'
)

_arguments -s -S \
    '-toolchain[select toolchain]:toolchain:' \
    '1:subcommand:->subcmd' \
    '*::arguments:->args'

case $state in
    subcmd)
        _describe -t subcommands 'ocamlfind subcommand' subcommands
        ;;
    args)
        case $words[1] in
            query)
                _arguments \
                    '-predicates[comma-separated predicates]:predicates:' \
                    '-format[output format]:format:' \
                    '-separator[separator string]:separator:' \
                    '-prefix[string printed before first answer]:prefix:' \
                    '-suffix[string printed after last answer]:suffix:' \
                    '(-recursive -r)'{-recursive,-r}'[include direct and indirect ancestors/descendants]' \
                    '(-descendants -d)'{-descendants,-d}'[query descendants]' \
                    '-pp[get preprocessor pkgs]' \
                    '(-long-format -l)'{-long-format,-l}'[long output format]' \
                    '-i-format[print -I options]' \
                    '-l-format[print -ccopt -L options]' \
                    '-a-format[print archive names]' \
                    '-o-format[print link options]' \
                    '-p-format[print package names]' \
                    '-help-format[list supported -format formats]' \
                    '-qe[do not print errors]' \
                    '-qo[do not print regular output]' \
                    '*:package name:'
                ;;
            list)
                _arguments \
                    '-describe[output package descriptions]'
                ;;
            ocamlc|ocamlcp|ocamlopt|ocamloptp|ocamldep|ocamldoc|ocamlmktop|ocamlmklib)
                _arguments \
                    '*-package[refer to package when compiling]:package:' \
                    '-linkpkg[link packages in]' \
                    '*-predicates[add predicate]:predicate:' \
                    '*-dontlink[do not link this package]:package:' \
                    '-syntax[use preprocessor predicate]:predicate:' \
                    '*-ppopt[preprocessor option]:option:' \
                    '*-ppxopt[ppx package and options]:pkg\,opts:' \
                    '*-dllpath-pkg[add -dllpath for this package]:package:' \
                    '-dllpath-all[add -dllpath for all linked packages]' \
                    '-ignore-error[ignore META error directive]' \
                    '*-passopt[pass option directly]:option:' \
                    '-passrest[pass all remaining options directly]' \
                    '-only-show[show constructed command without exec]' \
                    '*:source file:_files -g "*.{ml,mli,cmo,cma,cmx,cmxa,o,a}"'
                ;;
            install)
                _arguments \
                    '-destdir[destination directory]:directory:_directories' \
                    '-metadir[META file install directory]:directory:_directories' \
                    '-ldconf[ld.conf file]:file:_files' \
                    '-dont-add-directory-directive[never append directory= to META]' \
                    '-add[add files to existing package]' \
                    '-dll[following files are DLLs]' \
                    '-nodll[following files are not DLLs]' \
                    '-optional[following files are optional]' \
                    '-patch-version[patch package version]:version:' \
                    '-patch-rmpkg[remove subpackage]:name:' \
                    '-patch-archives[remove non-existing archives]' \
                    '1:package name:' \
                    '*:files:_files'
                ;;
            remove)
                _arguments \
                    '-destdir[destination directory]:directory:_directories' \
                    '-metadir[META file directory]:directory:_directories' \
                    '-ldconf[ld.conf file]:file:_files' \
                    '1:package name:'
                ;;
            printconf)
                _arguments \
                    '1:variable:(conf path destdir metadir metapath stdlib ldconf)'
                ;;
            printppx)
                _arguments \
                    '*-predicates[predicates]:predicate:' \
                    '*:package:'
                ;;
            lint)
                _arguments '*:META file:_files'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac
