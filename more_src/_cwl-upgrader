#compdef cwl-upgrader
# Documentation: https://github.com/common-workflow-language/cwl-upgrader
# cwl-upgrader - upgrade CWL documents from draft-3/v1.0/v1.1 to a newer version

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--dir=[directory to write upgraded files into]:dir:_files -/' \
  '*:CWL document:_files' && ret=0

return ret
