#compdef ucsm-cli

# Cisco UCS Manager CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--host=[UCSM host]:host:' \
  '--user=[username]:user:' \
  '--password=[password]:pwd:' \
  '--secure[use HTTPS]' \
  '*::ucsm-cli args:_files' && ret=0
return ret
