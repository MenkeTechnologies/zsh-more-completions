#compdef ucsm-cli

# ucsm-cli: Cisco UCS Manager command line interface
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-H[UCSM hostname]:host:_hosts' \
  '-u[username]:user:_users' \
  '-p[password]:password:' \
  '-S[run a script file]:file:_files' \
  '-c[run a single command]:cmd:' \
  '-v[verbose]' \
  '*::ucsm-cli args:_files' && ret=0
return ret
