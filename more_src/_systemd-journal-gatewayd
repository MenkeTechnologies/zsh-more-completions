#compdef systemd-journal-gatewayd
# Documentation: https://man.archlinux.org/search?q=systemd-journal-gatewayd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cert=+[certificate file]:file:_files' \
  '--key=+[key file]:file:_files' \
  '--trust=+[CA cert]:file:_files' \
  '-D+[journal directory]:dir:_files -/' \
  '--directory=+[journal directory]:dir:_files -/' \
  '--system[show messages from system services]' \
  '--user[show messages from user services]' \
  '-m[merge user/system]' \
  '--merge[merge user/system journals]' \
  '--file=+[journal file]:file:_files' \
  '--namespace=+[journal namespace]:ns:' && ret=0

return ret
