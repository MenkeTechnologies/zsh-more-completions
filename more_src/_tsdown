#compdef tsdown

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--entry=[entry file(s)]:entry files:_files' \
  '--format=[output format]:format:(esm cjs iife)' \
  '--out-dir=[output directory]:directory:_directories' \
  '--dts[generate declaration files]' \
  '--clean[clean output directory before build]' \
  '--minify[enable minification]' \
  '--sourcemap[generate source maps]' \
  '--target=[ES target]:target:(es2015 es2016 es2017 es2018 es2019 es2020 es2021 es2022 es2023 esnext)' \
  '--platform=[target platform]:platform:(node browser neutral)' \
  '--external=[external dependencies]:packages' \
  '--no-external=[force bundle dependencies]:packages' \
  '--global-name=[name for IIFE global]:name' \
  '--env=[define environment variables]:variables' \
  '--treeshake[enable tree shaking]' \
  '--splitting[enable code splitting]' \
  '--shims[add Node.js shims]' \
  '--config=[path to config file]:file:_files' \
  '--no-config[disable config file loading]' \
  '--watch[watch mode]' \
  '-w[watch mode]' \
  '*:entry files:_files' && ret=0

return ret
