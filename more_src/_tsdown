#compdef tsdown
# Documentation: https://github.com/rolldown/tsdown/blob/main/src/cli.ts
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[use a custom config file]:file:_files' \
  '--config-loader=[config loader to use]:loader:(auto native tsx unrun)' \
  '--no-config[disable config file]' \
  '(-f --format)'{-f+,--format=}'[bundle format]:format:(esm cjs iife umd)' \
  '--clean[clean output directory]' \
  '--no-clean[disable clean output directory]' \
  '*--deps.never-bundle=[mark dependencies as external]:module:' \
  '--minify[minify output]' \
  '--devtools[enable devtools integration]' \
  '--debug=[show debug logs]:feature:' \
  '--target=[bundle target (e.g. es2015, esnext)]:target:' \
  '(-l --logLevel)'{-l+,--logLevel=}'[set log level]:level:(info warn error silent)' \
  '--fail-on-warn[fail on warnings]' \
  '--no-write[disable writing files to disk]' \
  '(-d --out-dir)'{-d+,--out-dir=}'[output directory]:directory:_directories' \
  '--treeshake[tree-shake bundle]' \
  '--sourcemap[generate source map]' \
  '--shims[enable cjs and esm shims]' \
  '--platform=[target platform]:platform:(node browser neutral)' \
  '--dts[generate dts files]' \
  '--publint[enable publint]' \
  '--attw[enable Are the types wrong integration]' \
  '--unused[enable unused dependencies check]' \
  '(-w --watch)'{-w-,--watch=-}'[watch mode]::path:_files' \
  '--ignore-watch=[ignore custom paths in watch mode]:path:_files' \
  '--from-vite=[reuse config from Vite or Vitest]::vitest:' \
  '--report[size report]' \
  '*--env.=[define compile-time env variables]:value:' \
  '--env-file=[load environment variables from a file]:file:_files' \
  '--env-prefix=[prefix for env variables to inject into the bundle]:prefix:' \
  '--on-success=[command to run on success]:command:' \
  '--copy=[copy files to output dir]:dir:_directories' \
  '--public-dir=[alias for --copy (deprecated)]:dir:_directories' \
  '--tsconfig=[set tsconfig path]:file:_files -g "tsconfig*.json"' \
  '--unbundle[unbundle mode]' \
  '--root=[root directory of input files]:dir:_directories' \
  '--exe[bundle as executable]' \
  '(-W --workspace)'{-W-,--workspace=-}'[enable workspace mode]::dir:_directories' \
  '(-F --filter)'{-F+,--filter=}'[filter configs]:pattern:' \
  '--exports[generate export-related metadata for package.json]' \
  '1: :->cmd' \
  '*:entry files:_files' && ret=0

case $state in
  (cmd)
    local -a subcommands=(
      'create:[deprecated] create a tsdown project; use `npx create-tsdown` instead'
      'migrate:[deprecated] migrate from tsup to tsdown; use `npx tsdown-migrate` instead'
    )
    _alternative \
      'subcommands:tsdown subcommand:_describe -t cmds "subcommand" subcommands' \
      'files:entry file:_files' && ret=0
    ;;
esac

return ret
