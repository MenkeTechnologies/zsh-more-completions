#compdef gotadmin
# Documentation: https://gameoftrees.org/gotadmin.1.html
# Game of Trees repository administration utility

local ret=1
local curcontext="$curcontext" state line

_arguments -C -s \
  '(-h)-h[display usage information]' \
  '(-V --version)'{-V,--version}'[display program version and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'gotadmin command' \
      'init[create a new repository]' \
      'info[display repository information]' \
      'pack[generate a new pack file]' \
      'indexpack[create a pack index for a pack file]' \
      'listpack[list the contents of a pack file]' \
      'cleanup[repack and purge unreferenced objects]' \
      'dump[dump repository to a bundle file]' \
      'load[load a bundle file into a repository]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s \
          '-A[set hashing algorithm sha1 or sha256]:algorithm:(sha1 sha256)' \
          '-b[set HEAD reference branch]:branch:' \
          '*:repository:_files -/' && ret=0
        ;;
      info)
        _arguments -s \
          '-r[specify repository path]:repository:_files -/' && ret=0
        ;;
      pack)
        _arguments -s \
          '-a[add objects even if already packed]' \
          '-D[force ref-delta representation]' \
          '-q[suppress progress reporting]' \
          '-r[specify repository path]:repository:_files -/' \
          '*-x[exclude objects reachable from reference]:reference:' && ret=0
        ;;
      listpack)
        _arguments -s \
          '-h[show human-readable object sizes]' \
          '-s[display pack file statistics]' \
          '*:packfile:_files' && ret=0
        ;;
      cleanup)
        _arguments -s \
          '-a[delete all redundant objects]' \
          '-n[dry-run, do not remove any files]' \
          '-p[remove orphaned pack index files]' \
          '-q[suppress progress reporting]' \
          '-r[specify repository path]:repository:_files -/' && ret=0
        ;;
      dump)
        _arguments -s \
          '-q[suppress progress reporting]' \
          '-r[specify repository path]:repository:_files -/' \
          '*-x[exclude objects reachable from reference]:reference:' \
          '*:bundle:_files' && ret=0
        ;;
      load)
        _arguments -s \
          '-l[list available bundle references]' \
          '-n[verify bundle without installing]' \
          '-q[suppress progress reporting]' \
          '-r[specify repository path]:repository:_files -/' \
          '*:bundle:_files' && ret=0
        ;;
      indexpack)
        _arguments -s '*:packfile:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
