#compdef stgenfiles
# _stgenfiles — generate random Syncthing test files (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stgenfiles/main.go (stdlib flag).

_stgenfiles() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-dir=[directory to generate into]:dir:_files -/'
        '-files=[number of files to create]:n:'
        '-maxexp=[max file size exponent (size = 2^maxexp)]:n:'
        '-src=[source of file data]:file:_files'
    )
    _arguments -s $args
}

_stgenfiles "$@"
