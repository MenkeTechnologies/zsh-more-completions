#compdef hatch-build
# _hatch-build — Hatch Python build backend (pypa/hatch)
# upstream: https://github.com/pypa/hatch

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --target)'{-t,--target}'=[build target]:target:(wheel sdist)' \
  '--clean[clean before building]' \
  '--hooks-only[only run build hooks]' \
  '--no-hooks[skip build hooks]' \
  '--ext[build extension modules only]' \
  '*:location:_files -/'
