#compdef bootloader-grub2
# Documentation: https://man.archlinux.org/search?q=bootloader-grub2
# Reference accessed: 2026-05-16

# bootloader-grub2: distro wrapper to update GRUB2 config
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--update[regenerate grub.cfg]' \
  '--install[install GRUB to device]:device:_files -g "/dev/*"' \
  '--force[force operation]' \
  '*::bootloader-grub2 args:_files' && ret=0
return ret
