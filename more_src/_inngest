#compdef inngest

# Zsh completion for Inngest CLI

_inngest() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'dev:start the Inngest dev server'
    'init:initialize an Inngest project'
    'deploy:deploy functions to Inngest'
    'run:run a function locally'
    'login:log in to Inngest'
    'logout:log out of Inngest'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'inngest command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        dev)
          _arguments -s -S \
            '--port=[port to listen on]:port:' \
            '--host=[host to listen on]:host:_hosts' \
            '-u+[URL of your app to forward events to]:URL:' \
            '--sdk-url=[URL of your app]:URL:' \
            '--no-discovery[disable auto-discovery]' \
            '--no-poll[disable polling]' \
            '--poll-interval=[polling interval]:interval:' \
            '--retry-interval=[retry interval]:interval:' \
            '-v[verbose output]' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        deploy)
          _arguments -s -S \
            '1:app URL:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_inngest "$@"
