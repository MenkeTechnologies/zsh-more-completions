#compdef nft
# Documentation: https://man.archlinux.org/man/nft.8.en
# Reference accessed: 2026-05-30
# nft — nftables CLI (the modern replacement for iptables/ip6tables/arptables/ebtables).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)-V[show extended version + compile config]' \
  '(-f --file)'{-f,--file=}'[read commands from file ("-" for stdin)]:file:_files' \
  '(-i --interactive)'{-i,--interactive}'[start interactive readline shell]' \
  '*'{-D,--define=}'[define variable (name=value; repeatable)]:def:' \
  '*'{-I,--includepath=}'[add directory to include search path (repeatable)]:dir:_directories' \
  '(-c --check)'{-c,--check}'[validate commands without applying changes]' \
  '(-o --optimize)'{-o,--optimize}'[optimize ruleset]' \
  '(-a --handle)'{-a,--handle}'[display object handles]' \
  '(-s --stateless)'{-s,--stateless}'[omit stateful rule information]' \
  '(-t --terse)'{-t,--terse}'[omit set contents]' \
  '(-S --service)'{-S,--service}'[translate ports to service names]' \
  '(-N --reversedns)'{-N,--reversedns}'[reverse DNS lookup for IP addresses]' \
  '(-u --guid)'{-u,--guid}'[translate UID/GID to names]' \
  '(-n --numeric)'{-n,--numeric}'[fully numerical output]' \
  '(-y --numeric-priority)'{-y,--numeric-priority}'[show chain priorities numerically]' \
  '(-p --numeric-protocol)'{-p,--numeric-protocol}'[show protocols numerically]' \
  '(-T --numeric-time)'{-T,--numeric-time}'[display time values numerically]' \
  '(-e --echo)'{-e,--echo}'[echo notifications for add/insert/replace operations]' \
  '(-j --json)'{-j,--json}'[format output as JSON]' \
  '(-d --debug)'{-d,--debug=}'[debug level]:level:(scanner parser eval netlink mnl proto-ctx segtree all)' \
  '*:nft command:' \
  && ret=0

return ret
