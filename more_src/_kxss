#compdef kxss
# _kxss — Tom Hudson kxss CLI for identifying reflected URL parameters that allow special characters likely indicating cross-site-scripting vectors before payload crafting (tomnomnom team, Go); flag
# upstream: https://github.com/tomnomnom/hacks

_kxss() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[N concurrent threads]:n:' \
        '--concurrent=+[N concurrent threads]:n:' \
        '-r[follow redirects]' \
        '--follow-redirects[follow redirects]' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-H+[header]:str:' \
        '--header=+[header]:str:' \
        '--special-chars=+[characters]:str:' \
        '--silent[silent]' \
        '*:URL or file:_files'
}

_kxss "$@"
