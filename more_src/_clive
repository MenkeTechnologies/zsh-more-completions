#compdef clive
# Documentation: https://man.archlinux.org/search?q=clive
# Reference accessed: 2026-05-16

# koki-develop/clive (cobra); Homebrew: Formula/c/clive.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'clive command' compadd -- run exec start version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
