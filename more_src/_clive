#compdef clive
# Documentation: https://github.com/koki-develop/clive
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# koki-develop/clive: terminal demo automation tool (cobra).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a configuration file'
  'start:launch browser and begin automated terminal operations'
  'validate:check configuration file for errors'
  'completion:generate shell autocompletion scripts'
  'help:help about any command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'clive command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (init|start|validate)
        _arguments \
          '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.yml *.yaml"' && ret=0
        ;;
      (completion)
        _values 'shell' bash fish powershell zsh && ret=0
        ;;
    esac
    ;;
esac

return ret
