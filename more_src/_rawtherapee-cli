#compdef rawtherapee-cli rawtherapee

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-c[convert files in batch]' \
  '-o+[output file or folder]:path:_files' \
  '-O+[output file/folder and copy pp3]:path:_files' \
  '-Y[overwrite output files]' \
  '*-p+[processing profile (.pp3)]:file:_files -g "*.pp3"' \
  '-d[use default profile]' \
  '-s[use sidecar pp3 file]' \
  '-S[use sidecar pp3 if present]' \
  '-j[output JPEG quality 1-100]:q:' \
  '-js+[JPEG subsampling]:s:(1 2 3)' \
  '-b+[bit depth]:bits:(8 16 16f 32)' \
  '-bs[output big-endian]' \
  '-f[fast export mode]' \
  '-q[quick start mode]' \
  '-a[process all supported types in folder]' \
  '-Y[overwrite existing]' \
  '-n[output PNG]' \
  '-t[output TIFF uncompressed]' \
  '-tz[output TIFF deflate compression]' \
  '-w[wait for input on stdin (server)]' \
  '-W[set GUI working profile]:profile:' \
  '*:input:_files' && ret=0

return ret
