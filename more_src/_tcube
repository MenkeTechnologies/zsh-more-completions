#compdef tcube
# Documentation: https://www.star.bris.ac.uk/~mbt/stilts/sun256/tcube-usage.html
# STILTS: calculate an N-dimensional histogram of table columns

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'cols=[expressions defining numeric columns]:cols:' \
  'ifmt=[input table format]:fmt:' \
  'istream=[read input as a stream]:bool:(true false)' \
  'icmd=[input filter commands]:cmds:' \
  'bounds=[coordinate ranges per dimension]:bounds:' \
  'binsizes=[bin extent per dimension]:size:' \
  'nbins=[number of pixels per dimension]:num:' \
  'combine=[bin aggregation method]:combine:(sum sum-per-unit count count-per-unit mean median Q1 Q3 min max stdev stdev_pop hit)' \
  'out=[output file location]:out:_files' \
  'otype=[output numeric type]:otype:(byte short int long float double)' \
  'scale=[weighting expression for bin contributions]:expr:' \
  '*:in:_files' && ret=0

return ret
