#compdef svgcleaner

# Zsh completion for svgcleaner - SVG optimizer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--indent[output indentation]:indent:(none tabs 1 2 3 4)' \
  '--allow-bigger-file[allow output larger than input]' \
  '--copy-on-error[copy input to output on error]' \
  '--quiet[suppress output]' \
  '--multipass[run multiple optimization passes]' \
  '--no-defaults[disable default optimizations]' \
  '--remove-comments[remove XML comments]' \
  '--remove-declarations[remove XML declarations]' \
  '--remove-nonsvg-elements[remove non-SVG elements]' \
  '--remove-unused-defs[remove unused defs]' \
  '--convert-shapes[convert shapes to paths]' \
  '--remove-title[remove title element]' \
  '--remove-desc[remove desc element]' \
  '--remove-metadata[remove metadata element]' \
  '--remove-nonsvg-attributes[remove non-SVG attributes]' \
  '--remove-unreferenced-ids[remove unreferenced IDs]' \
  '--trim-ids[trim IDs]' \
  '--remove-text-attributes[remove text attributes for non-text]' \
  '--remove-unused-coordinates[remove unused coordinates]' \
  '--remove-default-attributes[remove default attributes]' \
  '--remove-xmlns-xlink-attribute[remove xmlns:xlink when unused]' \
  '--remove-needless-attributes[remove needless attributes]' \
  '--join-style-attributes[join style into attributes]:mode:(none some all)' \
  '--paths-to-relative[convert paths to relative]' \
  '--remove-unused-segments[remove unused path segments]' \
  '--trim-paths[trim path data]' \
  '--coordinates-precision[set precision for coordinates]:precision:' \
  '--properties-precision[set precision for properties]:precision:' \
  '--paths-coordinates-precision[set precision for path coords]:precision:' \
  '--transforms-precision[set precision for transforms]:precision:' \
  '1:input SVG:_files -g "*.svg(-.)"' \
  '2:output SVG:_files -g "*.svg(-.)"' && return 0
