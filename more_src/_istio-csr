#compdef istio-csr cert-manager-istio-csr
# _istio-csr — cert-manager Istio CSR controller (signs SVIDs via cert-manager)
# upstream: https://github.com/cert-manager/istio-csr
# Flags from cmd/app/options/options.go on tip.

_istio-csr() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --log-level)'{-v,--log-level=}'[log verbosity (0-5)]:n:' \
        '--log-format=[log format]:fmt:(text json)' \
        '--readiness-probe-port=[ready probe port]:port:' \
        '--readiness-probe-path=[ready probe path]:path:' \
        '--metrics-port=[metrics bind port]:port:' \
        '--trust-domain=[SPIFFE trust domain]:domain:' \
        '--root-ca-file=[PEM file of upstream root CA]:file:_files' \
        '--serving-address=[gRPC serving address]:host\:port:' \
        '(-d --serving-certificate-duration)'{-d,--serving-certificate-duration=}'[serving cert duration]:dur:' \
        '*--serving-certificate-dns-names=[csv of serving cert DNS SANs]:csv:' \
        '--serving-certificate-key-size=[serving cert key size]:n:' \
        '--serving-signature-algorithm=[serving cert signature algorithm]:alg:(RSA ECDSA)' \
        '(-p --preserve-certificate-requests)'{-p,--preserve-certificate-requests}'[keep CertificateRequest objects after signing]' \
        '(-n --certificate-namespace)'{-n,--certificate-namespace=}'[namespace where CertificateRequests are created]:ns:' \
        '--issuer-enabled=[enable the default issuer]:bool:(true false)' \
        '--issuer-name=[default cert-manager Issuer name]:name:' \
        '--issuer-kind=[default Issuer kind]:kind:(Issuer ClusterIssuer)' \
        '--issuer-group=[default Issuer API group]:group:' \
        '--runtime-issuance-config-map-name=[ConfigMap holding runtime issuance config]:name:' \
        '--runtime-issuance-config-map-namespace=[runtime issuance ConfigMap namespace]:ns:' \
        '*--certificate-request-additional-annotations=[k=v annotations added to CR]:k=v:' \
        '--max-client-certificate-duration=[max requested cert duration]:dur:' \
        '--enable-client-cert-authenticator=[enable client cert authenticator]:bool:(true false)' \
        '*--ca-trusted-node-accounts=[trusted SA list for impersonation]:csv:' \
        '--cluster-id=[Istio mesh cluster ID]:id:' \
        '--configmap-namespace-selector=[ConfigMap distribution namespace selector]:selector:' \
        '--disable-kubernetes-client-rate-limiter=[disable client-side rate limiting]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--max-concurrent-reconciles=[max concurrent reconciles]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_istio-csr "$@"
