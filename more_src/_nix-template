autoload -U is-at-least

_nix-template() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-u+[Point to a github repo, and use github api to determine package values]' \
'--from-url=[Point to a github repo, and use github api to determine package values]' \
'-l+[Set license]' \
'--license=[Set license]' \
'-m+[Set maintainer]' \
'--maintainer=[Set maintainer]' \
'-v+[Set version of package]' \
'-p+[Package name to be used in expression]' \
'--pname=[Package name to be used in expression]' \
'-r+[Set root of the nixpkgs directory]' \
'--nixpkgs-root=[Set root of the nixpkgs directory]' \
'-f+[Fetcher to use]: :(github gitlab url zip pypi)' \
'--fetcher=[Fetcher to use]: :(github gitlab url zip pypi)' \
'(-n --nixpkgs)--no-meta[Don'\''t include meta section]' \
'-d[Add comments linking to relevant sections of the Nixpkgs contributor guide.]' \
'--documentation-links[Add comments linking to relevant sections of the Nixpkgs contributor guide.]' \
'-s[Write expression to stdout, instead of PATH]' \
'--stdout[Write expression to stdout, instead of PATH]' \
'-n[Intended be used within nixpkgs, will append pname to file path, and print addition statement]' \
'--nixpkgs[Intended be used within nixpkgs, will append pname to file path, and print addition statement]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':TEMPLATE -- Language or framework template target:(flake stdenv python module mkshell go rust qt test)' \
'::PATH -- directory or file to be written. In the case of a directory, a default.nix will be created. When used with --nixpkgs, it will be appended to nixpkgs-root to determine path location.:_files' \
":: :_nix-template_commands" \
"*::: :->nix-template" \
&& ret=0
    case $state in
    (nix-template)
        words=($line[3] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nix-template-command-$line[3]:"
        case $line[3] in
            (completions)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':SHELL:(zsh bash fish powershell elvish)' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" \
'-f+[Config file location. \[default: $XDG_CONFIG_HOME/nix-template/config.toml\]]' \
'--file=[Config file location. \[default: $XDG_CONFIG_HOME/nix-template/config.toml\]]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
":: :_nix-template__config_commands" \
"*::: :->config" \
&& ret=0
case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nix-template-config-command-$line[1]:"
        case $line[1] in
            (name)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':name:_files' \
&& ret=0
;;
(nixpkgs-root)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':nixpkgs-root:_files' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
&& ret=0
;;
        esac
    ;;
esac
;;
(help)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_nix-template_commands] )) ||
_nix-template_commands() {
    local commands; commands=(
        "completions:Generate shell completion scripts, writes to stdout" \
"config:Set information about nix-template usage. Writes to $XDG_CONFIG_HOME" \
"help:Prints this message or the help of the given subcommand(s)" \
    )
    _describe -t commands 'nix-template commands' commands "$@"
}
(( $+functions[_nix-template__completions_commands] )) ||
_nix-template__completions_commands() {
    local commands; commands=(
        
    )
    _describe -t commands 'nix-template completions commands' commands "$@"
}
