#compdef copyprefix
# _copyprefix — copy/rename object-store key prefixes (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/copyprefix/main.go + pkg/util/objtools CopyBucketConfig on tip.

_copyprefix() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-source-prefix=[prefix to copy from the source bucket]:prefix:' \
        '-destination-prefix=[prefix replacement at destination]:prefix:' \
        '-skip-overwrites[list destination first to skip already-present objects]' \
        '-dry-run[log instead of copying]' \
        '-client-side-copy[force client-side copy even for same-backend pairs]' \
        '-source.backend=[source bucket backend]:backend:(s3 gcs azure swift filesystem)' \
        '-s3.source.bucket-name=[source S3 bucket]:name:' \
        '-s3.source.endpoint=[source S3 endpoint]:url:_urls' \
        '-s3.source.region=[source S3 region]:region:' \
        '-gcs.source.bucket-name=[source GCS bucket]:name:' \
        '-azure.source.account-name=[source Azure account]:name:' \
        '-azure.source.container-name=[source Azure container]:name:' \
        '-destination.backend=[destination bucket backend]:backend:(s3 gcs azure swift filesystem)' \
        '-s3.destination.bucket-name=[destination S3 bucket]:name:' \
        '-s3.destination.endpoint=[destination S3 endpoint]:url:_urls' \
        '-s3.destination.region=[destination S3 region]:region:' \
        '-gcs.destination.bucket-name=[destination GCS bucket]:name:' \
        '-azure.destination.account-name=[destination Azure account]:name:' \
        '-azure.destination.container-name=[destination Azure container]:name:'
}

_copyprefix "$@"
