#compdef very_good
# Documentation: https://cli.vgv.dev/docs/overview
# Very Good CLI - scaffold and manage Dart/Flutter projects

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '(--verbose --no-verbose)--verbose[enable detailed logging]' \
  '(--verbose --no-verbose)--no-verbose[disable detailed logging]' \
  '1:command:(create dart mcp packages test update)' && ret=0

return ret
