#compdef flux-local

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build local Flux Kustomization'
  'diff:diff local Flux resources against cluster'
  'test:run policy tests against local resources'
  'get:get Flux resources from local files'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'flux-local command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '--path[path to flux root]:directory:_directories' \
          '--enable-helm[enable Helm template rendering]' \
          '--skip-crds[skip CRD rendering]' \
          '--skip-secrets[skip secret rendering]' \
          '--output[output format]:format:(yaml json)' \
          '--help[show help]' \
          '*:kustomization:' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '--path[path to flux root]:directory:_directories' \
          '--enable-helm[enable Helm template rendering]' \
          '--output[output format]:format:(yaml diff)' \
          '--help[show help]' \
          '*:kustomization:' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--path[path to flux root]:directory:_directories' \
          '--enable-helm[enable Helm template rendering]' \
          '--help[show help]' && ret=0
        ;;
      get)
        _arguments -s -S \
          '--path[path to flux root]:directory:_directories' \
          '--output[output format]:format:(yaml json)' \
          '--help[show help]' \
          '1:resource-type:(ks hr cluster)' && ret=0
        ;;
    esac
    ;;
esac

return ret
