#compdef speedtest-cli speedtest
# _speedtest-cli — Matt Martz (sivel) speedtest-cli (Python CLI for speedtest.net; download/upload/latency + JSON/CSV reporting + server selection)
# upstream: https://github.com/sivel/speedtest-cli
# Flags from speedtest.py parse_args() on tip (argparse).

_speedtest-cli() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version and exit]' \
        '--no-download[skip the download test]' \
        '--no-upload[skip the upload test]' \
        '--single[use a single connection (typical file transfer)]' \
        '--bytes[show values in bytes instead of bits]' \
        '--share[generate speedtest.net share URL]' \
        '--simple[only show summary lines]' \
        '--csv[CSV output]' \
        '--csv-delimiter=[CSV delimiter character]:char:' \
        '--csv-header[print CSV header row]' \
        '--json[JSON output]' \
        '--list[list speedtest.net servers sorted by distance]' \
        '*--server=[specific server ID to test against (repeatable)]:id:' \
        '*--exclude=[server ID to exclude (repeatable)]:id:' \
        '--mini=[Speedtest Mini server URL]:url:_urls' \
        '--source=[source IP to bind]:ip:' \
        '--timeout=[HTTP timeout (sec)]:sec:' \
        '--secure[use HTTPS to speedtest.net servers]' \
        '--no-pre-allocate[do not preallocate upload buffer]'
}

_speedtest-cli "$@"
