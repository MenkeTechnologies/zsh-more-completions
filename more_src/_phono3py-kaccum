#compdef phono3py-kaccum
# Documentation: https://phonopy.github.io/phono3py/auxiliary-tools.html
# phono3py: compute accumulated lattice thermal conductivity vs frequency

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--temperature=[pick up one temperature point in K]:temperature' \
  '--nsp=[number of points sampled on the x-axis]:points' \
  '--mfp[use mean free path instead of frequency on x-axis]' \
  '--gv[outer product of group velocities over cell volume]' \
  '--average[output traces of tensors divided by 3]' \
  '--trace[output traces of the tensors]' \
  '--gamma[plot phonon linewidth in THz]' \
  '--tau[plot lifetime in ps]' \
  '--cv[plot modal heat capacity in eV/K]' \
  '--gv-norm[plot absolute value of group velocity]' \
  '--pqj[plot averaged phonon-phonon interaction in eV^2]' \
  '--dos[plot phonon DOS]' \
  '*:file:_files -g "*.hdf5"' && ret=0

return ret
