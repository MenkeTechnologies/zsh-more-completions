#compdef filtlong
# Documentation: https://github.com/rrwick/Filtlong
# quality filtering tool for long read sequencing data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '(-t --target_bases)'{-t,--target_bases}'[keep best reads up to this many total bases]:bases:' \
  '(-p --keep_percent)'{-p,--keep_percent}'[keep this percentage of best reads]:percent:' \
  '(-l --min_length)'{-l,--min_length}'[minimum read length threshold]:length:' \
  '(-L --max_length)'{-L,--max_length}'[maximum read length threshold]:length:' \
  '(-q --min_mean_q)'{-q,--min_mean_q}'[minimum mean quality threshold]:quality:' \
  '--min_window_q[minimum window quality threshold]:quality:' \
  '(-a --assembly)'{-a,--assembly}'[reference assembly in FASTA format]:fasta:_files' \
  '(-1 --short_1)'{-1,--short_1}'[reference short reads FASTQ]:fastq:_files' \
  '(-2 --short_2)'{-2,--short_2}'[reference short reads FASTQ]:fastq:_files' \
  '--length_weight[weight given to length score]:weight:' \
  '--mean_q_weight[weight given to mean quality score]:weight:' \
  '--window_q_weight[weight given to window quality score]:weight:' \
  '--trim[remove non-matching bases from read start and end]' \
  '--split[split reads at this many consecutive non-matching bases]:count:' \
  '--window_size[sliding window size for quality measurement]:size:' \
  '--verbose[display detailed information for each read]' \
  '*:input fastq:_files' && ret=0

return ret
