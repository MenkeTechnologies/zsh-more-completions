#compdef strings-static
# Documentation: https://man.archlinux.org/search?q=strings-static
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-a,--all}'[scan whole file, not only data section]' \
  {-f,--print-file-name}'[print name of file before each string]' \
  {-n+,--bytes=}'[minimum string length]:n:' \
  '-w[do not require strings to be terminated]' \
  {-o,--radix=o}'[print offset in octal]' \
  {-O+,--radix=}'[set address radix]:radix:(o d x)' \
  {-T+,--target=}'[binary file format]:bfd:' \
  {-e+,--encoding=}'[character encoding]:encoding:(s S b l B L)' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
