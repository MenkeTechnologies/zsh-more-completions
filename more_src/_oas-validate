#compdef oas-validate
# Documentation: https://github.com/Mermade/oas-kit/blob/main/packages/swagger2openapi/README.md
# Validate and lint Swagger/OpenAPI definitions (oas-kit)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version number]' \
  '--lint[lint the definition]' \
  '--validateSchema=[run schema validation step]:when:(first last never)' \
  '--warnOnly[do not throw on non-patchable errors]' \
  '(-e --encoding)'{-e,--encoding}'=[encoding for input/output files]:encoding' \
  '(-f --fail)'{-f,--fail}'=[path to docs expected to fail]:path:_files' \
  '(-j --jsonschema)'{-j,--jsonschema}'=[path to alternative JSON schema]:file:_files' \
  '(-l --laxurls)'{-l,--laxurls}'[lax checking of empty urls]' \
  '(-m --mediatype)'{-m,--mediatype}'[check media-types against RFC pattern]' \
  '(-n --nopatch)'{-n,--nopatch}'[do not patch minor errors in the source definition]' \
  '(-o --output)'{-o,--output}'=[output conversion result]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[do not show test passes on console, for CI]' \
  '(-r --resolve)'{-r,--resolve}'[resolve external references]' \
  '(-s --stop)'{-s,--stop}'[stop on first error]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-w --whatwg)'{-w,--whatwg}'[enable WHATWG URL parsing]' \
  '(-y --yaml)'{-y,--yaml}'[skip YAML-safe test]' \
  '*:spec:_files' && ret=0

return ret
