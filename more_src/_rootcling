#compdef rootcling
# Documentation: https://github.com/root-project/root/blob/master/core/dictgen/src/rootcling_impl.cxx
# Documentation: https://github.com/root-project/root/blob/master/core/dictgen/src/rootcling-argparse.py
# Reference accessed: 2026-05-27
# Verified: upstream llvm::cl::opt declarations in rootcling_impl.cxx and argparse stubs

# rootcling: ROOT modern dictionary generator.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '-f[overwrite an existing output file]' \
  '-v[display all messages]' \
  '-v0[display no messages]' \
  '-v1[display only error messages]' \
  '-v2[display error and warning messages (default)]' \
  '-v3[display error, warning and note messages]' \
  '-v4[display all messages including debug]' \
  '*-m+[Pcm file loaded before any header (repeatable)]:pcm file:_files -g "*.pcm"' \
  '-rmf+[rootmap file name (.rootmap)]:rootmap file:_files -g "*.rootmap"' \
  '*-rml+[library name containing autoload keys (repeatable)]:library:' \
  '-split[split dictionary putting ClassDef functions in a separate file]' \
  '-s+[target library name (influences pcm naming)]:library:' \
  '-multiDict[enable support for multiple pcms in one library (needs -s)]' \
  '-inlineInputHeader[inline header content within the dictionary]' \
  '-interpreteronly[generate minimal dictionary without IO information]' \
  '-noIncludePaths[do not store header directories; rely on $ROOT_INCLUDE_PATH at runtime]' \
  '*-excludePath+[exclude path from include paths]:path:_files -/' \
  '--lib-list-prefix=[list libraries needed by parsed headers]:prefix:' \
  '-rootbuild[indicate building ROOT itself]' \
  '-cxxmodule[generate a C++ module pcm]' \
  '*-moduleMapFile=[module map file]:file:_files' \
  '-noGlobalUsingStd[do not declare using namespace std in dictionary global scope]' \
  '-noDictSelection[do not run selection rules (hidden, for -onepcm mode)]' \
  '-writeEmptyRootPCM[do not include header files; assume they exist in pch]' \
  '-selSyntaxOnly[validate selection syntax only]' \
  '-failOnWarnings[fail if there are warnings]' \
  '-reflex[behave internally like genreflex]' \
  '*-I+[add include directory]:path:_files -/' \
  '*-D+[define preprocessor macro]:macro:' \
  '*-U+[undefine preprocessor macro]:macro:' \
  '*-W+[compiler diagnostics option]:warning:' \
  '-c[deprecated, ignored]' \
  '-p[deprecated, ignored]' \
  '-cint[deprecated, ignored]' \
  '-gccxml[deprecated, ignored]' \
  '*:header or LinkDef:_files -g "*.(h|hh|hpp|hxx|H|xml)"' && ret=0

return ret
