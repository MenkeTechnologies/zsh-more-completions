#compdef iolatency-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/iolatency.8
# summarize block device I/O latency as a histogram (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[device string, e.g. 202,1]:device' \
  '-i+[match type, e.g. *R* for all reads]:iotype' \
  '-Q[use queue insert as start time]' \
  '-T[timestamp on output]' \
  '::interval:' \
  '::count:' && ret=0

return ret
