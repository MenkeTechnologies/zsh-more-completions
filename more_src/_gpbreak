#compdef gpbreak
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpbreak.html
# Insert a break point in the gain table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'break=[break keyword]:break:' \
  'ants=[ants keyword]:ants:' \
  'feeds=[feeds keyword]:feeds:' \
  '*:visibility dataset:_files' && ret=0

return ret
