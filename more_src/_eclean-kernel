#compdef eclean-kernel
# Gentoo kernel cleanup tool

local ret=1

_arguments -s -S \
  '-a[clean all kernels except the running one]' \
  '-A[clean all kernels]' \
  '-d[enable destructive mode]' \
  '-l[list installed kernels]' \
  '-n[number of kernels to keep]:number:' \
  '-p[pretend mode]' \
  '-r[specify root directory]:directory:_files -/' \
  '-x[exclude kernel]:kernel version:' \
  '--no-mount[do not mount /boot]' \
  '--bootloader=[specify bootloader]:bootloader:(grub lilo yaboot)' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
