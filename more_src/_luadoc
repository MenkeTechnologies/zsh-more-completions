#compdef luadoc
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/luadoc.1.html
# generate HTML documentation from Lua source files

local ret=1

_arguments -s -S \
  '-d+[output directory path; should be an empty, writable directory]:dir:_files -/' \
  '-t+[template directory path]:dir:_files -/' \
  '--noindexpage[do not generate global index page]' \
  '--nofiles[do not generate documentation for files]' \
  '--nomodules[do not generate documentation for modules]' \
  '--doclet=[doclet module to generate output]:module' \
  '--taglet=[taglet module to parse input code]:module' \
  '(-q --quiet)'{-q,--quiet}'[suppress all normal output]' \
  '(-v --version)'{-v,--version}'[print version information]' \
  '*:lua file:_files -g "*.lua"' && ret=0

return ret
