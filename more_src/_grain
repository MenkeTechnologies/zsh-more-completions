#compdef grain

# Zsh completion for grain (WebAssembly-first language compiler)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compile:compile a Grain program'
  'run:compile and run a Grain program'
  'lsp:start the Grain language server'
  'doc:generate documentation'
  'format:format Grain source files'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'grain command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (compile|run)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '(-I --include-dirs)'{-I,--include-dirs}'[include directories]:directories' \
          '(-S --stdlib)'{-S,--stdlib}'[standard library path]:directory:_files -/' \
          '--release[compile in release mode]' \
          '--elide-type-info[remove type info from output]' \
          '--no-wasm-tail-call[disable WebAssembly tail calls]' \
          '--wasi-polyfill[WASI polyfill module]:file:_files' \
          '--use-start-section[use start section for initialization]' \
          '--no-gc[disable garbage collection]' \
          '--no-bulk-memory[disable bulk memory operations]' \
          '--debug[include debug information]' \
          '--wat[output WebAssembly text format]' \
          '1:source file:_files -g "*.gr(N)"' && ret=0
        ;;
      (format)
        _arguments -s -S \
          '--in-place[format files in place]' \
          '*:source file:_files -g "*.gr(N)"' && ret=0
        ;;
      (doc)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'[output directory]:directory:_files -/' \
          '1:source file:_files -g "*.gr(N)"' && ret=0
        ;;
      (lsp)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
