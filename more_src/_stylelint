#compdef stylelint

# Zsh completion for stylelint - CSS/SCSS/Less linter

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  '--config[specify config file]:config file:_files' \
  '--config-basedir[specify config base directory]:directory:_directories' \
  {-f,--formatter}'[specify output formatter]:formatter:(compact json string tap unix verbose github)' \
  '--custom-formatter[specify custom formatter module]:module:_files' \
  {-q,--quiet}'[only report errors]' \
  '--quiet-deprecation-warnings[suppress deprecation warnings]' \
  '--report-descriptionless-disables[report disables without description]' \
  '--report-invalid-scope-disables[report invalid scope disables]' \
  '--report-needless-disables[report needless disables]' \
  '*'{-i,--ignore-path}'[specify ignore file path]:file:_files' \
  '*--ignore-pattern[specify ignore pattern]:glob pattern' \
  '--ignore-disables[ignore all disable comments]' \
  '--disable-default-ignores[disable default ignores]' \
  '--cache[enable caching]' \
  '--cache-location[specify cache location]:path:_files' \
  '--cache-strategy[specify cache strategy]:strategy:(metadata content)' \
  '--max-warnings[set maximum number of warnings]:count' \
  '--fix[automatically fix problems]' \
  '--allow-empty-input[allow empty input]' \
  {-o,--output-file}'[specify output file]:file:_files' \
  '--stdin[accept stdin input]' \
  '--stdin-filename[specify stdin filename]:filename' \
  '--color[force colored output]' \
  '--no-color[disable colored output]' \
  '--print-config[print the config for given file]' \
  '--globby-options[pass options to globby as JSON]:json' \
  '*:file or glob:_files'
