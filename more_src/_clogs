#compdef clogs
# ============================================================================
#  _clogs — Generate a changelog from Git commits containing trailers
#
#  Source-direct extraction from
#    https://github.com/yorickpeterse/clogs/blob/main/src/clogs.inko
#    https://github.com/inko-lang/inko/blob/main/std/src/std/optparse.inko
#
#  Authored by Yorick Peterse (creator of the Inko language).  25 GH stars.
#  Reads conventional-commit-style trailers from `git log` output, groups
#  them under markdown changelog sections, and emits a release entry.
#
#  CLI library taxonomy update: first documented Inko entry.  clogs uses
#  Inko's stdlib `std.optparse` module — `import std.optparse (Options)`
#  brings the `Options` type into scope.  std.optparse is opinionated and
#  lightweight, inspired by getopts, with full Unicode option support.
#  API: `Options.new(name)` constructor + `opts.flag(short, long, desc)`
#  / `opts.single(short, long, value_name, desc)` / `opts.multiple(...)`
#  method-builder + `opts.parse(args) -> Result[Matches, Error]` +
#  `matches.contains?(name)` / `.value(name) -> Option[String]` /
#  `.values(name) -> Array[String]` / `.remaining -> Array[String]`
#  accessors.  Brings cross-language CLI library taxonomy variant count
#  to 76.
#
#  Surface (verbatim from src/clogs.inko `run` function):
#    -h, --help              Show this help message
#    -v, --version           Show the version
#    -c, --config CONFIG     Use the specified configuration file
#    -e, --end REF           The end of the commit range (default: HEAD)
#
#  Positional args (verbatim from `match matches.remaining.get(0)`):
#    init        Generate a default configuration file (clogs.json)
#    <VERSION>   X.Y.Z semantic version to generate changelog for
#
#  Dup-skipped neighbors during hunt (unfit or smaller surface):
#    - idoc (inko-lang/idoc 3 stars, official Inko docgen — smaller surface)
#    - kvi (yorickpeterse/kvi 8 stars, key-value DB — single subcommand)
#    - openflow (yorickpeterse/openflow 7 stars, ventilation controller)
#    - shost (yorickpeterse/shost 6 stars, static HTTP server)
#    - wtml (yorickpeterse/wtml 0 stars, demo only)
# ============================================================================

_clogs() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help message]' \
    '(-v --version)'{-v,--version}'[show clogs version]' \
    '(-c --config)'{-c,--config}'[configuration file]:config file:_files -g "*.json"' \
    '(-e --end)'{-e,--end}'[end of commit range (default HEAD)]:git ref:->gitref' \
    '1:command or version:->cmd_or_version'

  case $state in
    cmd_or_version)
      local -a verbs
      verbs=(
        'init:generate a default configuration file'
      )
      _describe -t commands 'clogs command' verbs
      _message 'or a semantic version (X.Y.Z)'
      ;;
    gitref)
      local -a refs
      refs=(HEAD)
      if command -v git >/dev/null 2>&1; then
        local -a branches tags
        branches=( ${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null)"} )
        tags=( ${(f)"$(git for-each-ref --format='%(refname:short)' refs/tags 2>/dev/null)"} )
        refs+=( $branches $tags )
      fi
      _describe -t refs 'git ref' refs
      ;;
  esac
}

_clogs "$@"
