#compdef claudia

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new AWS Lambda function and API'
  'update:update an existing Lambda function'
  'destroy:destroy the deployed function and API'
  'pack:pack the project for upload (zip)'
  'list:list deployed Claudia projects'
  'add-s3-event-source:wire S3 -> Lambda trigger'
  'add-sns-event-source:wire SNS -> Lambda trigger'
  'add-sqs-event-source:wire SQS -> Lambda trigger'
  'add-cognito-trigger:wire Cognito -> Lambda trigger'
  'add-iot-topic-rule:wire IoT rule -> Lambda'
  'add-kinesis-event-source:wire Kinesis -> Lambda'
  'add-dynamodb-event-source:wire DynamoDB stream -> Lambda'
  'add-cloudwatch-event:wire CloudWatch -> Lambda'
  'add-cloudwatch-log-subscription:wire log subscription'
  'remove-event-source:remove an event source'
  'add-scheduled-event:wire a scheduled CloudWatch event'
  'remove-scheduled-event:remove a scheduled event'
  'allow-unauthenticated:allow unauthenticated API access'
  'add-bot-config:configure as a chat bot'
  'set-cloudfront-trigger:add CloudFront edge trigger'
  'set-version:set/update a stage alias'
  'tag:tag deployed Lambda'
  'test-lambda:invoke deployed Lambda'
  'create-codedeploy-app:set up CodeDeploy'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '--config=[claudia.json file]:file:_files -g "*.json"' \
  '--profile=[AWS profile]:profile:' \
  '--region=[AWS region]:region:' \
  '--source=[source code directory]:dir:_files -/' \
  '--proxy=[HTTPS proxy]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'claudia command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--name=[Lambda function name]:name:' \
          '--region=[AWS region]:region:' \
          '--handler=[handler module.method]:handler:' \
          '--api-module=[API Gateway module]:module:' \
          '--deploy-proxy-api[deploy proxy API]' \
          '--runtime=[Node.js runtime]:runtime:(nodejs20.x nodejs18.x nodejs16.x nodejs14.x)' \
          '--memory=[memory MB]:mb:' \
          '--timeout=[timeout seconds]:s:' \
          '--description=[function description]:text:' \
          '--config=[output config file]:file:_files' \
          '--role=[IAM role name]:role:' \
          '--policies=[IAM policies glob]:glob:' \
          '--no-optional-dependencies[skip optional deps]' \
          '--use-local-dependencies[use existing node_modules]' \
          '--use-s3-bucket=[upload zip to bucket]:bucket:' \
          '--allow-recursion[allow function to invoke itself]' \
          '--security-group-ids=[VPC security groups]:list:' \
          '--subnet-ids=[VPC subnets]:list:' \
          '--set-env=[env vars name=value]:env:' \
          '--set-env-from-json=[env vars from JSON file]:file:_files -g "*.json"' \
          '--keep[keep package zip after deploy]' \
          '--source=[source directory]:dir:_files -/' \
          '--cache-api-config=[API config CloudFormation parameter]:name:' && ret=0 ;;
      (update)
        _arguments \
          '--source=[source directory]:dir:_files -/' \
          '--config=[claudia.json file]:file:_files' \
          '--version=[stage alias]:alias:' \
          '--use-local-dependencies[use existing node_modules]' \
          '--cache-api-config=[API config CFN param]:name:' \
          '--keep[keep zip]' \
          '--set-env=[env vars name=value]:env:' \
          '--set-env-from-json=[env vars from JSON]:file:_files' && ret=0 ;;
      (destroy|list|pack|tag)
        _arguments \
          '--config=[claudia.json file]:file:_files' \
          '--profile=[AWS profile]:profile:' \
          '--region=[AWS region]:region:' && ret=0 ;;
      (add-s3-event-source|add-sns-event-source|add-sqs-event-source)
        _arguments \
          '--bucket=[S3 bucket]:bucket:' \
          '--topic=[SNS topic ARN]:arn:' \
          '--queue=[SQS queue ARN]:arn:' \
          '--events=[event filter]:events:' \
          '--prefix=[key prefix]:prefix:' \
          '--suffix=[key suffix]:suffix:' \
          '--version=[stage alias]:alias:' && ret=0 ;;
      (test-lambda)
        _arguments \
          '--event=[event JSON file]:file:_files -g "*.json"' \
          '--version=[stage alias]:alias:' && ret=0 ;;
    esac ;;
esac

return ret
