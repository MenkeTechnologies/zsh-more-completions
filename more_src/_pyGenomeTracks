#compdef pyGenomeTracks
# Documentation: https://pygenometracks.readthedocs.io/en/latest/content/usage.html
# pyGenomeTracks - plot genomic data tracks

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--tracks=[file with instructions to plot the tracks]:file:_files' \
  '--region=[region to plot (chr:start-end)]:region' \
  '--BED=[file with regions to plot in BED format]:file:_files' \
  '--width=[figure width in centimeters]:cm' \
  '--plotWidth=[width in cm of the central plotting area]:cm' \
  '--height=[figure height in centimeters]:cm' \
  '(-t --title)'{-t,--title=}'[title text for the plot]:title' \
  '(--outFileName -out)'{--outFileName=,-out}'[filename to save the image output]:file:_files' \
  '--fontSize=[font size for plot labels]:size' \
  '--dpi=[resolution for raster image output]:dpi' \
  '--trackLabelFraction=[space dedicated to track labels]:fraction' \
  '--trackLabelHAlign=[horizontal alignment of track labels]:align:(left right center)' \
  '--decreasingXAxis[reverse the x-axis direction]' \
  '--version[show version]' && ret=0

return ret
