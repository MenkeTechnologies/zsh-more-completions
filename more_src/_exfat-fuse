#compdef mount.exfat-fuse mount.exfat exfat-fuse

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n[do not update /etc/mtab]' \
  '-o+[mount options]:options' \
  '-r[read-only mount]' \
  '-v[verbose mode]' \
  '1:device:_files -g "/dev/*(-.)"' \
  '2:mountpoint:_directories' && return 0
