#compdef calgps
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/time/calgps.cpp
# GPSTk GPS calendar generator

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display argument list]' \
  '(-3 --three-months)'{-3,--three-months}'[display last, this and next months]' \
  '(-y --year)'{-y,--year}'[display all months for the current year]' \
  '(-Y --specific-year)'{-Y,--specific-year}'[display all months for a given year]:year' \
  '(-n --no-blurb)'{-n,--no-blurb}'[suppress GPSTk reference in graphic output]' && ret=0

return ret
