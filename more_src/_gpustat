#compdef gpustat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-v,--version}'[show version]' \
  {-a,--show-all}'[show all available information]' \
  '--show-cmd[show command name of running processes]' \
  '--show-full-cmd[show full command line of running processes]' \
  {-u,--show-user}'[show owner of running processes]' \
  {-p,--show-pid}'[show PID of running processes]' \
  {-f,--show-fan}'[show fan speed]' \
  {-e,--show-codec}'[show encoder/decoder utilization]' \
  {-P,--show-power}'[show power usage and limit]' \
  '--show-temp[show GPU temperature]' \
  {-c,--show-cmd}'[show command name of running processes]' \
  '--json[print output in JSON format]' \
  '--no-header[suppress header line]' \
  '--no-color[suppress color output]' \
  '--force-color[force color output even when not a tty]' \
  '--gpuname-width=[set width for GPU name column]:width' \
  {-i,--interval}'=[auto-refresh interval in seconds]:seconds' \
  '(-1 --single-shot)'{-1,--single-shot}'[run once and exit (used with --interval)]' \
  {-w,--watch}'=[watch mode with specified interval]:seconds' \
  && ret=0

return ret
