#compdef 3drefit
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3drefit.html
# AFNI modify attributes of an existing dataset header in place

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-quiet[disable verbose messages]' \
  '-orient[set orientation 3-letter code]:code' \
  '-xorigin[set x edge-voxel center distance]:val' \
  '-yorigin[set y edge-voxel center distance]:val' \
  '-zorigin[set z edge-voxel center distance]:val' \
  '-duporigin[copy origin from another dataset]:dataset:_files' \
  '-dxorigin[add distance to x origin]:val' \
  '-dyorigin[add distance to y origin]:val' \
  '-dzorigin[add distance to z origin]:val' \
  '-xdel[set x voxel dimension]:val' \
  '-ydel[set y voxel dimension]:val' \
  '-zdel[set z voxel dimension]:val' \
  '-keepcen[maintain center when changing voxel dims]' \
  '-xyzscale[scale all voxel dimensions by factor]:factor' \
  '-TR[change repetition time]:tr' \
  '-notoff[remove slice-dependent time offsets]' \
  '-Torg[set time origin]:val' \
  '-newid[change dataset ID code]' \
  '-nowarp[remove all warping information]' \
  '-apar[set anatomy parent dataset]:dataset:_files' \
  '-wpar[set warp parent dataset]:dataset:_files' \
  '-clear_bstat[clear stored sub-brick statistics]' \
  '-redo_bstat[recompute sub-brick statistics]' \
  '-statpar[change statistical parameters]:params' \
  '-markers[add empty AC-PC markers]' \
  '-view[change view]:view:(orig acpc tlrc)' \
  '-space[associate template space]:space' \
  '-cmap[associate colormap type]:cmap' \
  '-label2[set label2 field]:label' \
  '-labeltable[insert label table]:file:_files' \
  '-denote[remove identifying notes]' \
  '-deoblique[replace transform with cardinal]' \
  '-oblique_recenter[adjust origin for oblique coords]' \
  '-byteorder[set byte order string]:order' \
  '-atrcopy[copy header attribute from dataset]:dataset:_files' \
  '-atrstring[store string attribute]:name' \
  '-atrfloat[create/modify float attribute]:name' \
  '-atrint[create/modify int attribute]:name' \
  '-saveatr[copy known attributes to output]' \
  '-nosaveatr[do not save attributes]' \
  '-type[change declared data type]:type' \
  '-copyaux[copy auxiliary data from dataset]:dataset:_files' \
  '-copytables[copy label tables from dataset]:dataset:_files' \
  '-relabel_all[assign sub-brick labels from file]:file:_files' \
  '-relabel_all_str[assign sub-brick labels from string]:str' \
  '-sublabel_prefix[prefix each sub-brick label]:prefix' \
  '-sublabel_suffix[suffix each sub-brick label]:suffix' \
  '-sublabel[attach label to specific sub-brick]:spec' \
  '-substatpar[attach statistical type to sub-brick]:spec' \
  '-unSTAT[remove statistical encodings]' \
  '-addFDR[compute and store FDR curves]' \
  '-FDRmask[mask dataset for FDR]:dataset:_files' \
  '-STATmask[mask dataset for FDR]:dataset:_files' \
  '-unFDR[remove all FDR curves]' \
  '*:dataset:_files' && ret=0

return ret
