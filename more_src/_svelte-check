#compdef svelte-check

# Zsh completion for svelte-check - SvelteKit type checker and diagnostics

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)--version[display version]' \
  '--workspace=[path to workspace]:workspace directory:_directories' \
  '--output=[output format]:format:(human human-verbose machine machine-verbose)' \
  '--watch[enable watch mode]' \
  '--tsconfig=[path to tsconfig file]:tsconfig file:_files -g "tsconfig*.json"' \
  '*--ignore=[glob patterns to ignore]:glob pattern:' \
  '--fail-on-warnings[exit with code 1 when warnings are present]' \
  '--fail-on-hints[exit with code 1 when hints are present]' \
  '--compiler-warnings=[set compiler warning severity]:code\:severity:' \
  '--diagnostic-sources=[diagnostic sources to report]:source:(js svelte css)' \
  '--threshold=[minimum diagnostic level to report]:level:(error warning hint)'
