#compdef bazel
# _bazel-cli — Bazel build system (Google, Java); fast correct deterministic multi-language builds
# upstream: https://github.com/bazelbuild/bazel

_bazel-cli() {
    local -a sub=(
        'analyze-profile:analyze profile'
        'aquery:action query'
        'build:build targets'
        'canonicalize-flags:canonicalize flags'
        'clean:clean output'
        'coverage:run tests + coverage'
        'cquery:configured query'
        'dump:dump internal state'
        'fetch:fetch deps'
        'help:show help'
        'info:print runtime info'
        'license:print licenses'
        'mobile-install:mobile install'
        'mod:manage MODULE.bazel'
        'modquery:module query'
        'print_action:print action'
        'query:dependency graph query'
        'run:build + run'
        'shutdown:shutdown server'
        'sync:sync workspace'
        'test:build + run tests'
        'vendor:vendor commands'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--client_debug+[client debug]:bool:(true false)' \
        '--server_jvm_out+[server jvm out]:file:_files' \
        '--output_base+[output base]:dir:_files -/' \
        '--output_user_root+[output user root]:dir:_files -/' \
        '--max_idle_secs+[max idle secs]:n:' \
        '--noworkspace_rc[no workspace rc]' \
        '--ignore_all_rc_files[ignore all rc]' \
        '--bazelrc+[bazelrc]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bazel subcommand' sub ;;
        args)
            case $words[1] in
                build|test|run|coverage|aquery|cquery|query) _arguments \
                    '-c+[compilation mode]:mode:(fastbuild dbg opt)' \
                    '--compilation_mode+[compilation mode]:mode:(fastbuild dbg opt)' \
                    '-k[keep going]' \
                    '--keep_going[keep going]' \
                    '--jobs+[jobs]:n:' \
                    '-j+[jobs]:n:' \
                    '--config+[config name]:str:' \
                    '--output_groups+[output groups]:groups:' \
                    '--verbose_failures[verbose failures]' \
                    '--cache_test_results+[cache test results]:bool:(true false yes no auto)' \
                    '-t+[cache test results]:bool:(true false yes no auto)' \
                    '--test_arg+[test args]:str:' \
                    '--test_output+[test output]:type:(summary errors all streamed)' \
                    '--test_summary+[test summary]:type:(short terse detailed none testcase)' \
                    '--test_filter+[test filter regex]:regex:' \
                    '--test_size_filters+[test size]:sizes:' \
                    '--test_tag_filters+[test tag filter]:tags:' \
                    '--test_lang_filters+[test lang filter]:langs:' \
                    '--platforms+[platforms]:platforms:' \
                    '--host_platform+[host platform]:platform:' \
                    '--toolchain_resolution_debug+[toolchain debug]:targets:' \
                    '--remote_cache+[remote cache URL]:url:_urls' \
                    '--remote_executor+[remote executor URL]:url:_urls' \
                    '--remote_instance_name+[remote instance]:str:' \
                    '--remote_timeout+[remote timeout]:duration:' \
                    '--define+[var]:KEY=VAL:' \
                    '--copt+[copt]:flag:' \
                    '--linkopt+[linkopt]:flag:' \
                    '--cxxopt+[cxxopt]:flag:' \
                    '--watchfs[watch filesystem]' \
                    '--disk_cache+[disk cache dir]:dir:_files -/' \
                    '--repository_cache+[repository cache dir]:dir:_files -/' \
                    '*:target:' ;;
                clean) _arguments \
                    '--expunge[remove entire output base]' \
                    '--expunge_async[remove output base async]' \
                    '--async[async]' ;;
                info) _arguments '*:key:' ;;
            esac
            ;;
    esac
}

_bazel-cli "$@"
