#compdef tog
# Documentation: https://gameoftrees.org/tog.1.html
# Game of Trees interactive ncurses repository browser

local ret=1
local curcontext="$curcontext" state line

_arguments -C -s \
  '(-h)-h[display usage information]' \
  '(-V --version)'{-V,--version}'[display program version and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'tog command' \
      'log[show commit history]' \
      'diff[show differences between objects]' \
      'blame[show line-by-line history of a file]' \
      'tree[browse repository tree]' \
      'ref[browse references]' && ret=0
    ;;
  args)
    case $line[1] in
      log)
        _arguments -s \
          '-b[display merged commits from other branches]' \
          '-c[start at the specified commit]:commit:' \
          '-r[use repository at the specified path]:repository:_files -/' \
          '*:path:_files' && ret=0
        ;;
      diff)
        _arguments -s \
          '-a[treat file contents as ASCII text]' \
          '-C[set number of context lines]:lines:' \
          '*-c[show differences between commits]:commit:' \
          '-r[use repository at the specified path]:repository:_files -/' \
          '-s[show staged changes instead of work tree changes]' \
          '-w[ignore whitespace-only changes]' \
          '*:object or path:_files' && ret=0
        ;;
      blame)
        _arguments -s \
          '-c[start at the specified commit]:commit:' \
          '-r[use repository at the specified path]:repository:_files -/' \
          '*:path:_files' && ret=0
        ;;
      tree)
        _arguments -s \
          '-c[start at the specified commit]:commit:' \
          '-r[use repository at the specified path]:repository:_files -/' \
          '*:path:_files' && ret=0
        ;;
      ref)
        _arguments -s \
          '-r[use repository at the specified path]:repository:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
