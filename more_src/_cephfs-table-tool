#compdef cephfs-table-tool

# cephfs-table-tool: examine/edit MDS tables
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--filesystem=[filesystem name]:name:' \
  '--rank=[MDS rank]:n:' \
  '--worker-n=[worker count]:n:' \
  '--worker-id=[worker id]:n:' \
  '--force-corrupt[allow corruption]' \
  '--force-init[allow init when exists]' \
  '*:cephfs-table-tool command:(reset show take_inos range destroy init dump)' && ret=0
return ret
