#compdef cephfs-table-tool
# Documentation: https://docs.ceph.com/en/latest/cephfs/disaster-recovery-experts/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cephfs-table-tool: reset/inspect MDS tables (session, snap, inode)
# Usage: cephfs-table-tool <rank|all> <verb> <table>
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:rank:(all)' \
  '2:verb:(reset show take_inos)' \
  '3:table:(session snap inode)' && ret=0
return ret
