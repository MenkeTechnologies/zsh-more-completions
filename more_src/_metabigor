#compdef metabigor
# Documentation: https://github.com/j3ssie/metabigor
# OSINT tool without API keys

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-I)-I[input file]:input file:_files' \
  '(-o)-o[output file]:output file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'net:discover CIDRs and network ranges for ASN/IP/domain/org'
      'cert:query crt.sh for domains and certificates'
      'ip:IP enrichment via Shodan InternetDB'
      'github:code search via grep.app'
      'ipc:cluster IPs by ASN using local database'
      'related:find related domains via OSINT sources'
      'cdn:detect CDN/WAF for IPs'
      'update:update local ASN database'
    )
    _describe -t commands 'metabigor command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      net)
        _arguments \
          '--ip[lookup by IP]' \
          '--domain[lookup by domain]' \
          '--org[lookup by organization]' \
          '--asn[lookup by ASN]' \
          '--dynamic[dynamic mode]' \
          '-o[output file]:output file:_files' && ret=0
        ;;
      cert)
        _arguments \
          '--clean[clean output]' \
          '--wildcard[only wildcard domains]' \
          '--json[json output]' \
          '-o[output file]:output file:_files' && ret=0
        ;;
      ip)
        _arguments \
          '--flat[flat output]' \
          '--csv[csv output]' \
          '--json[json output]' \
          '-c[concurrency]:concurrency' \
          '-o[output file]:output file:_files' && ret=0
        ;;
      related)
        _arguments \
          '-s[source: crt, whois, ua]:source' \
          '-o[output file]:output file:_files' && ret=0
        ;;
      cdn)
        _arguments \
          '--strip-cdn[strip CDN IPs]' \
          '--json[json output]' \
          '-o[output file]:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
