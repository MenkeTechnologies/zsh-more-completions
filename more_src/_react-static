#compdef react-static
# _react-static — Tanner Linsley react-static React static site generator CLI alias (react-static team, JavaScript); custom argparse
# upstream: https://github.com/react-static/react-static

_react-static() {
    local -a sub=(
        'create:create new react-static project'
        'start:start dev server'
        'build:build production site'
        'stage:stage production build'
        'export:export build'
        'bundle:export as bundle'
        'serve:serve build'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--silent[silent]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'react-static subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[project name]:str:' \
                    '-n+[project name]:str:' \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '--location=+[dir]:dir:_files -/' \
                    '-l+[dir]:dir:_files -/' \
                    '--public-path=+[path]:str:' ;;
                start|stage) _arguments \
                    '--config=+[config file]:file:_files -g "static.config.{js,ts}"' \
                    '-c+[config file]:file:_files -g "static.config.{js,ts}"' \
                    '--debug[debug]' \
                    '--no-cache[no cache]' \
                    '--use-https[use https]' \
                    '--public-path=+[path]:str:' ;;
                build) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--staging[staging mode]' \
                    '--debug[debug]' \
                    '--no-cache[no cache]' \
                    '--public-path=+[path]:str:' ;;
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--open[open browser]' \
                    '-o[open browser]' \
                    '--no-cors[no cors]' ;;
            esac
            ;;
    esac
}

_react-static "$@"
