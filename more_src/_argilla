#compdef argilla

# Argilla CLI completion

_argilla_subcommands() {
  local -a subcmds=(
    'server:Manage the Argilla server'
    'login:Log in to Argilla'
    'whoami:Show current user info'
    'info:Show Argilla info'
    'training:Manage training tasks'
  )
  _describe -t commands 'argilla subcommand' subcmds
}

_argilla() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_argilla_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        server)
          _arguments -C \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(start stop database)' \
            '*::arg:->server_args'
          case $state in
            server_args)
              case ${line[1]} in
                start)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '--host=[host to bind to]:host' \
                    '--port=[port to listen on]:port' \
                    '--workers=[number of workers]:workers'
                  ;;
                stop)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]'
                  ;;
                database)
                  _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '1:action:(migrate)'
                  ;;
              esac
              ;;
          esac
          ;;
        login)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--api-url=[Argilla API URL]:url' \
            '--api-key=[API key]:api key' \
            '--workspace=[default workspace]:workspace' \
            '--extra-user-token=[extra user token]:token'
          ;;
        whoami)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        info)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        training)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_argilla "$@"
