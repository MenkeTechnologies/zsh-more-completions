#compdef skytable skyd skysh
# Documentation: https://man.archlinux.org/search?q=skytable
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (skytable|skyd)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '--config=[config file]:config:_files' \
      '--host=[host to bind]:host:_hosts' \
      '--port=[port to bind]:port:' \
      '--noart[disable startup art]' \
      '--nosave[disable persistence]' \
      '--saveduration=[save duration in seconds]:seconds:' \
      '--maxclients=[max clients]:count:' \
      '--maxcon=[max connections per IP]:count:' \
      '--mode=[run mode]:mode:(dev prod)' \
      '*:config file:_files' && ret=0
    ;;
  (skysh)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '--host=[server host]:host:_hosts' \
      '--port=[server port]:port:' \
      '(-e --eval)'{-e,--eval}'=[evaluate command]:command:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
