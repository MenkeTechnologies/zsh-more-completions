#compdef xastir
# Documentation: https://man.archlinux.org/search?q=xastir
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[config dir]:dir:_files -/' \
  '-d+[debug level]:lvl:' \
  '-l+[language code]:lang:' \
  '-g+[geometry]:geom:' \
  '-display+[X display]:display:' && ret=0

return ret
