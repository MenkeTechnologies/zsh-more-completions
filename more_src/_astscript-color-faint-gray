#compdef astscript-color-faint-gray
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astscript_002dcolor_002dfaint_002dgray.html
# astscript-color-faint-gray — generate color images from three FITS channels using asinh transformation

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[do not print the list]' \
  '--cite[show BibTeX citation for this program]' \
  '(-h --hdu)'{-h,--hdu}'[HDU/extension for input channels]:HDU' \
  '(-r --reghdu)'{-r,--reghdu}'[HDU/extension for regions image]:HDU' \
  '--globalhdu[use this HDU for all inputs, ignore --hdu]:HDU' \
  '(-w --weight)'{-w,--weight}'[relative weight for each input channel]:weight' \
  '(-m --minimum)'{-m,--minimum}'[minimum value for each input channel]:value' \
  '(-z --zeropoint)'{-z,--zeropoint}'[zero point magnitude of each input channel]:magnitude' \
  '(-Q --qbright)'{-Q,--qbright}'[parameter for bringing out brighter features]:value' \
  '(-s --stretch)'{-s,--stretch}'[linear stretching parameter for faint features]:value' \
  '(-b --bias)'{-b,--bias}'[constant to add to all pixels (linear)]:value' \
  '(-c --contrast)'{-c,--contrast}'[change the contrast of final image (linear)]:value' \
  '(-G --gamma)'{-G,--gamma}'[gamma scaling (nonlinear)]:value' \
  '--markoptions[options to add marks (passed to ConvertType)]:options' \
  '--coloronly[no grayscale regions, background in color]' \
  '--regions[regions labeled image]:file:_files' \
  '--grayval[gray threshold (highest value to use grayscale)]:value' \
  '--colorval[color threshold (lowest value to have color)]:value' \
  '--graykernelfwhm[kernel FWHM for convolving background image]:fwhm' \
  '--colorkernelfwhm[kernel FWHM for color separation reference image]:fwhm' \
  '--checkparams[print distribution of values used to find parameters]' \
  '(-k --keeptmp)'{-k,--keeptmp}'[keep temporary/auxiliary files]' \
  '(-o --output)'{-o,--output}'[output color image name]:file:_files' \
  '*:input:_files' && ret=0

return ret
