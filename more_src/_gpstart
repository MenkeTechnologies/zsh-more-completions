#compdef gpstart

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d=[coordinator data directory]:dir:_files -/' \
  '-B=[number of segments to start in parallel]:n:' \
  '-R[start in restricted mode]' \
  '-m[start coordinator only (utility mode)]' \
  '-y[do not start standby coordinator]' \
  '-a[do not prompt for confirmation]' \
  '-t=[timeout in seconds waiting for segment startup]:secs:' \
  '-l=[log directory]:dir:_files -/' \
  '--skip-heap-checksum-validation[skip heap checksum consistency check]' \
  '--enable-restricted-mode-resmgmt[enable resource management in restricted mode]' \
  '-v[verbose]' \
  '-q[quiet]'
