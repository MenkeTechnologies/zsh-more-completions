#compdef wl-screenrec
# Documentation: https://github.com/russelltg/wl-screenrec
# Reference accessed: 2026-05-21
# Verified: clap Args struct in upstream src/main.rs.

# Zsh completion for wl-screenrec - high-performance Wayland screen recorder

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-hw[do not use GPU encoder]' \
  '--no-cursor[do not capture cursor]' \
  '(-f --filename)'{-f+,--filename=}'[output file (default screenrecord.mp4)]:file:_files' \
  '(-g --geometry)'{-g+,--geometry=}'[capture region x,y WxH (mutually exclusive with --output)]:geometry:' \
  '(-o --output)'{-o+,--output=}'[output (display) to record]:output:' \
  '(-m --max-fps)'{-m+,--max-fps=}'[limit maximum frame rate]:fps:' \
  '*'{-v,--verbose}'[increase logging verbosity]' \
  '--dri-device=[DRI device for vaapi]:device:_files' \
  '--low-power=[low-power encoding mode]:mode:(auto on off)' \
  '--codec=[video codec]:codec:(auto avc hevc vp8 vp9 av1)' \
  '--ffmpeg-muxer=[ffmpeg muxer]:muxer:' \
  '--ffmpeg-muxer-options=[muxer options key=val,key2=val2]:options:' \
  '--ffmpeg-encoder=[force a specific ffmpeg encoder]:encoder:' \
  '--ffmpeg-encoder-options=[encoder options key=val,key2=val2]:options:' \
  '--audio-codec=[audio codec]:codec:(auto aac mp3 flac opus)' \
  '--audio-bitrate=[audio bitrate (bytes/sec)]:bitrate:' \
  '--ffmpeg-audio-encoder=[force a specific ffmpeg audio encoder]:encoder:' \
  '--encode-pixfmt=[ffmpeg pixel format to encode with]:pixfmt:' \
  '--encode-resolution=[encode resolution WxH]:resolution:' \
  '(-b --bitrate)'{-b+,--bitrate=}'[bitrate to encode at (bytes/sec)]:bitrate:' \
  '--history=[record N seconds in memory until SIGUSR1]:duration:' \
  '--audio[record audio]' \
  '--audio-device=[audio capture device]:device:' \
  '--audio-backend=[ffmpeg audio capture backend]:backend:' \
  '--no-damage[copy every frame, not just damaged frames]' \
  '--gop-size=[GOP (group of pictures) size]:size:' \
  '--generate-completions=[print shell completions to stdout]:shell:(bash elvish fish powershell zsh)' \
  '--capture-backend=[capture backend]:backend:(auto wlr-screencopy ext-image-copy-capture)' \
  '--experimental-vulkan[use Vulkan allocator and encode]'
