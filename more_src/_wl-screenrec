#compdef wl-screenrec

# Zsh completion for wl-screenrec - high-performance screen recorder for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[set Wayland output]:output' \
  '(-g --geometry)'{-g,--geometry}'[set capture region]:geometry' \
  '(-f --filename)'{-f,--filename}'[output file]:file:_files' \
  '--audio[enable audio capture]' \
  '--audio-device[audio device]:device' \
  '--codec[video codec]:codec:(auto h264 hevc vp8 vp9 av1)' \
  '--no-hw[disable hardware encoding]' \
  '--no-damage[capture full frames]' \
  '--low-power[prefer low-power encoding]' \
  '--bitrate[target bitrate]:bitrate' \
  '--encode-resolution[encode resolution]:WxH' \
  '--ffmpeg-muxer[ffmpeg muxer]:muxer' \
  '--ffmpeg-audio-encoder[ffmpeg audio encoder]:encoder' \
  '--ffmpeg-video-encoder[ffmpeg video encoder]:encoder'
