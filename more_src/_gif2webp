#compdef gif2webp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[print version and exit]' \
  '-lossy[encode using lossy compression]' \
  '-mixed[per-frame heuristic lossy or lossless]' \
  '-near_lossless+[near-lossless preprocessing (0..100, off=100)]:level:' \
  '-sharp_yuv[use sharper RGB->YUV conversion]' \
  '-q+[quality factor (0..100)]:q:' \
  '-m+[compression method (0=fast..6=slowest)]:m:(0 1 2 3 4 5 6)' \
  '-min_size[minimize output size]' \
  '-kmin+[min distance between key frames]:n:' \
  '-kmax+[max distance between key frames]:n:' \
  '-f+[filter strength (0..100)]:strength:' \
  '-metadata+[metadata to copy]:list:(all none icc xmp)' \
  '-loop_compatibility[Chrome <M62 compatibility]' \
  '-mt[use multi-threading]' \
  '-v[verbose]' \
  '-quiet[do not print anything]' \
  '-o+[output WebP file]:file:_files -g "*.webp"' \
  '*:input GIF:_files -g "*.gif"' && ret=0

return ret
