local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# docsmode enum values from docstring at line 105
local -a docsmodes=(
  'libreoffice:LibreOffice format'
  'msoffice:Microsoft Office format'
  'desktop:desktop Google Drive (default)'
  'off:disable Google Docs format conversion'
)
local -a log_destinations=(
  'stdout:log to standard output'
  '-:log to standard output (alias)'
  'stderr:log to standard error'
)

# 23 single-dash flags decoded source-direct
# from Arg.align spec list at gdfuseCli.ml:79-145
_arguments -s -S \
  '(- *)-version[show version and exit]' \
  '-verbose[enable verbose logging on stdout]' \
  '-debug[enable debug mode (implies -verbose)]' \
  '-label+[use a specific label to identify the filesystem (default: default)]:label:' \
  '-id+[OAuth2 client ID]:client id:' \
  '-secret+[OAuth2 client secret]:client secret:' \
  '-d[enable FUSE debug output]' \
  '(-s)-m[run in multi-threaded mode (default)]' \
  '(-m)-s[run in single-threaded mode]' \
  '-o+[FUSE mount options (comma-separated; gdfroot=PATH supported)]:mount opts:' \
  '-cc[clear cache]' \
  '-headless[enable headless mode]' \
  '-skiptrash[DANGEROUS: enable permanent deletion (no trash)]' \
  '-config+[custom config file path (default: ~/.gdfuse/[label]/config)]:config file:_files' \
  '-xdgbd[enable XDG Base Directory support]' \
  '-browser+[authorization browser command (default: xdg-open/firefox/chrome)]:browser command:_command_names -e' \
  '-docsmode+[Google Docs mode (implies -cc if changed)]:mode:->docsmodes' \
  '-serviceaccountpath+[service account credentials JSON path]:json file:_files -g "*.json"' \
  '-serviceaccountuser+[G Suite user email to impersonate]:email:' \
  '-log_to+[log destination]:destination:->log_destinations' \
  '-scope+[custom Drive API scope]:scope:' \
  '-redirect_uri+[custom Drive API redirect URI]:url:_urls' \
  '-device[use OAuth2 for devices]' \
  '-port+[loopback port (default: 8080)]:port:' \
  '*:mountpoint:_files -/' && ret=0

case $state in
  docsmodes)
    _describe -t docsmodes 'Google Docs mode' docsmodes && ret=0
    ;;
  log_destinations)
    _describe -t log_destinations 'log destination' log_destinations && ret=0
    ;;
esac

return ret
