#compdef suiclogfft
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suiclogfft.c
# fft of complex log frequency traces to real time traces

local ret=1

_arguments -s -S \
  'sign=[sign]:sign:' \
  'sym=[sym]:sym:' \
  'mode=[mode]:mode:' \
  'key=[key]:key:' \
  'op=[op]:op:' \
  '*:file:_files' && ret=0

return ret
