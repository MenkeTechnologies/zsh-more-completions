#compdef slopearea SlopeArea
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/SlopeAreaCombination.html
# TauDEM: slope-area combination (S^m)(A^n)

local ret=1

_arguments -s -S \
  '-slp[input slope grid (from DinfFlowDir)]:slpfile:_files' \
  '-sca[input contributing area grid (from AreaDinf)]:scafile:_files' \
  '-sa[output slope-area grid]:safile:_files' \
  '-par[slope exponent m and area exponent n (default 2 1)]:m:' \
  '*:file:_files' && ret=0

return ret
