#compdef ipa-advise
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-advise.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-advise.1.

# ipa-advise: provide configuration advice for various integrations
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose -d --debug)'{-v,--verbose,-d,--debug}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[output only errors]' \
  '--log-file=[log to file]:file:_files' \
  '*:advice name:' && ret=0
return ret
