#compdef rsyslogd rsyslog
# Documentation: https://man7.org/linux/man-pages/man8/rsyslogd.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[turn on debug mode]' \
  '-D[run Bison config parser in debug mode]' \
  '-f+[config file]:file:_files -g "*.conf"' \
  '-i+[PID file]:file:_files' \
  '-n[avoid auto-backgrounding]' \
  '-N+[do a config check at level]:level:(1 2 3)' \
  '-o+[generate consolidated config file]:file:_files' \
  '-C[do not change to the root directory]' \
  '-v[print version and exit]' \
  '*::passthrough:' && ret=0

return ret
