#compdef rsyslogd rsyslog

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[enable debug mode]' \
  '-D[run in foreground (alias)]' \
  '-f+[config file]:file:_files -g "*.conf"' \
  '-i+[PID file (NONE to disable)]:file:_files' \
  '-n[do not auto-background]' \
  '-N+[config check at level]:level:(1 2 3)' \
  '-M+[module load path]:dir:_files -/' \
  '-C[no command-line override of config]' \
  '-v[show version]' \
  '-x[disable DNS lookups for messages]' \
  '*::passthrough:' && ret=0

return ret
