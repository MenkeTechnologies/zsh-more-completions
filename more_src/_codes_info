#compdef codes_info
# Documentation: https://confluence.ecmwf.int/display/ECC/codes_info
# Source: ecmwf/eccodes tools/codes_info.cc — print ecCodes version/paths (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)-v[print only the version of ecCodes]' \
    '(- *)-d[print only the definitions path]' \
    '(- *)-s[print only the samples path]' \
    && ret=0

return ret
