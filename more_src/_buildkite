#compdef buildkite-agent bk

# Zsh completion for Buildkite Agent

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start the buildkite agent'
      'annotate:annotate the build page'
      'artifact:manage build artifacts'
      'bootstrap:run a build bootstrap'
      'env:manage environment variables'
      'lock:manage pipeline locks'
      'meta-data:manage build metadata'
      'pipeline:manage pipeline definitions'
      'secret:manage secrets'
      'step:manage build steps'
      'tool:agent utility commands'
      'acknowledge:acknowledge a job'
      'oidc:manage OIDC tokens'
    )
    _describe -t commands 'buildkite-agent command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--token=[agent token]:token' \
          '--name=[agent name]:name' \
          '--priority=[agent priority]:priority' \
          '--tags=[agent tags]:tags' \
          '--tags-from-host[set tags from host]' \
          '--tags-from-ec2[set tags from EC2 metadata]' \
          '--tags-from-ec2-tags[set tags from EC2 instance tags]' \
          '--tags-from-gcp[set tags from GCP metadata]' \
          '--spawn=[number of parallel agents]:count' \
          '--disconnect-after-job[disconnect after single job]' \
          '--disconnect-after-idle-timeout=[disconnect after idle]:seconds' \
          '--cancel-grace-period=[grace period for cancellation]:seconds' \
          '--bootstrap-script=[path to bootstrap script]:script:_files' \
          '--build-path=[path for builds]:path:_directories' \
          '--hooks-path=[path for hooks]:path:_directories' \
          '--plugins-path=[path for plugins]:path:_directories' \
          '--no-color[disable color output]' \
          '--debug[enable debug mode]' \
          '--experiment=[enable experimental features]:experiment' && ret=0
        ;;
      artifact)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(upload download search shasum)' && ret=0
        ;;
      meta-data)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(set get exists keys)' && ret=0
        ;;
      pipeline)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(upload)' && ret=0
        ;;
      annotate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--context=[annotation context]:context' \
          '--style=[annotation style]:style:(success info warning error)' \
          '--append[append to existing annotation]' \
          '1:body' && ret=0
        ;;
      step)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(get update cancel)' && ret=0
        ;;
    esac
    ;;
esac

return ret
