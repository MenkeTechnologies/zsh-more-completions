#compdef cgiwrapper-nollmcrawler
# _cgiwrapper-nollmcrawler — skarnet tipidee CGI bouncer (reject LLM/AI crawlers based on a User-Agent regex list, then exec the real CGI; designed to be plumbed in front of any CGI via tipidee.conf)
# upstream: https://github.com/skarnet/tipidee
# Flags from src/misc/cgiwrapper-nollmcrawler.c on tip.

_cgiwrapper-nollmcrawler() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-d+[pathinfo depth (number of leading path segments mapped to PATH_INFO)]:n:' \
        '(-f --force)'{-f,--force}'[apply the rules even to GET-less methods]' \
        '1:rulesdir:_files -/' \
        '2:bad-regex:' \
        '*:realcgi:_command_names -e'
}

_cgiwrapper-nollmcrawler "$@"
