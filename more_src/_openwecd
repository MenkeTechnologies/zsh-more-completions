#compdef openwecd
# ============================================================================
# _openwecd — zsh completion for the OpenWEC daemon, a GNU/Linux
#              implementation of the Windows Event Collector server
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/cea-sec/openwec
#   Maintainer : CEA-Sec  (French Commissariat à l'Énergie Atomique
#                          security research group)
#   License    : GPL-3.0
#   Language   : Rust
#   Crate      : server v0.3.0  (workspace member)
#   Binary     : openwecd  (server/Cargo.toml [[bin]] name = "openwecd",
#                           path = "src/main.rs")
#   Last push  : 2026-01-27
#
# WHAT IT IS
#   OpenWEC is "an implementation of a Windows Event Collector
#   server running on GNU/Linux" — a server that speaks the
#   Microsoft Windows Event Forwarding (WEF) WS-Management protocol,
#   so Windows endpoints can be configured (via GPO or local policy)
#   to push their event logs to a Linux box instead of a dedicated
#   Windows collector.  The `openwecd` daemon handles the
#   WS-Management endpoint, Kerberos / TLS client authentication
#   (libgssapi), subscription delivery, and output multiplexing to
#   one or more sinks per subscription (TCP, Redis, Kafka, files,
#   UnixDatagram).  A companion `openwec` CLI manages subscriptions,
#   bookmarks, heartbeats, and stats over the same store.
#
# CLI ARGUMENT GRAMMAR  (verbatim from server/src/main.rs clap
#                       command!() builder)
#   openwecd [OPTIONS]
#
#   openwecd has no subcommands;  it runs the daemon.  Configuration
#   is read entirely from the config TOML file (subscriptions,
#   outputs, listeners, Kerberos / TLS, logging, metrics).
#
#   Options:
#     -c, --config <FILE>      Sets a custom config file
#                                [default: $DEFAULT_CONFIG_FILE]
#     -v, --verbosity          Sets the level of verbosity
#                                (repeatable: -v info, -vv debug, -vvv
#                                 trace)
#
#   Standard clap auto-flags (from `command!()` with `cargo` feature):
#     -h, --help               Show help
#     -V, --version            Show version  (set at build time
#                              from server/Cargo.toml `version = "0.3.0"`)
#
#   Defaults:
#     DEFAULT_CONFIG_FILE       /etc/openwec.conf.toml  (per
#                                                       common/src/settings.rs)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `rdkafka = { version = "0.37.0", features =
#   ["zstd", "libz", "external-lz4", "ssl", "sasl", "gssapi"] }`
#   declared in server/Cargo.toml — the canonical Rust Apache Kafka
#   client maintained by fede1024 (fede1024/rust-rdkafka), the
#   async-first wrapper over Magnus Edenhill's librdkafka C library
#   (confluentinc/librdkafka).  rdkafka provides typed Producer +
#   Consumer + AdminClient APIs over the full Kafka 0-9-1+ protocol
#   with idempotent producers, transactional producers, SASL/GSSAPI
#   authentication, OAuth bearer tokens, schema-registry-friendly
#   serializers, and rebalance callbacks.  OpenWEC's
#   `server/src/drivers/kafka.rs` constructs an
#   `rdkafka::producer::FutureProducer` per subscription output and
#   publishes serialized Windows Event Log records onto the
#   configured topic with the topic-level partition strategy declared
#   in the subscription TOML.  Verified via:
#     gh api repos/cea-sec/openwec/contents/server/Cargo.toml
#       → rdkafka = { version = "0.37.0", features = [...] }
#     gh api search/code repo:cea-sec/openwec use rdkafka
#       → server/src/drivers/kafka.rs, doc/outputs.md, cli/src/skell.rs
#   This entry is the Rust=127 leader bump that OPENS Axis 72
#   (Apache Kafka Client Library), pairing with future Go=
#   IBM/sarama (or confluentinc/confluent-kafka-go) and
#   TS-Node=tulios/kafkajs poles to close the axis at 1/1/1.
#
#   No completion for `openwecd` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `openwec` (separate `[[bin]]` in cli/Cargo.toml)
#   is the management CLI;  this completion targets the daemon.
# ============================================================================

_openwecd() {
    _arguments -s \
        '(-c --config)'{-c+,--config=}'[set a custom config file (default /etc/openwec.conf.toml)]:config file:_files -g "*.{toml,conf}"' \
        '*'{-v,--verbosity}'[increase verbosity (repeatable: -v info, -vv debug, -vvv trace)]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_openwecd "$@"
