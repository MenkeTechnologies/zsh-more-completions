#compdef chamber

# Zsh completion for chamber - AWS SSM Parameter Store CLI

local curcontext="$curcontext" state line ret=1

local -a chamber_commands
chamber_commands=(
  'delete:delete a secret'
  'exec:execute a command with secrets in environment'
  'export:export secrets in various formats'
  'find:find secrets by name'
  'history:view secret history'
  'import:import secrets from a file'
  'list:list secrets for a service'
  'list-services:list all services'
  'read:read a specific secret'
  'version:print version'
  'write:write a secret'
)

local -a chamber_global_flags
chamber_global_flags=(
  '--backend=[secrets backend]:backend:(ssm s3 secretsmanager null)'
  '--backend-s3-bucket=[S3 bucket for s3 backend]:bucket:'
  '--kms-key-alias=[KMS key alias]:alias:'
  '(-r --region)'{-r,--region}'=[AWS region]:region:'
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]'
  '--version[show version]'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  "${chamber_global_flags[@]}" \
  '1:command:_describe -t commands command chamber_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      exec)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '--pristine[do not inherit existing environment]' \
          '--strict[fail if any secrets cannot be read]' \
          '1:service:' \
          '*:command and arguments: _normal' && ret=0
        ;;
      export)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '--format=[export format]:format:(json csv tsv dotenv tfvars)' \
          '1:service:' && ret=0
        ;;
      write)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '--skip-unchanged[skip writing if value unchanged]' \
          '1:service:' \
          '2:key:' \
          '3:value:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:service:' \
          '2:key:' && ret=0
        ;;
      read)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:service:' \
          '2:key:' && ret=0
        ;;
      history)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:service:' \
          '2:key:' && ret=0
        ;;
      list)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:service:' && ret=0
        ;;
      find)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:secret name pattern:' && ret=0
        ;;
      import)
        _arguments -s -S \
          "${chamber_global_flags[@]}" \
          '1:service:' \
          '2:file:_files' && ret=0
        ;;
      *)
        _arguments -s -S "${chamber_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
