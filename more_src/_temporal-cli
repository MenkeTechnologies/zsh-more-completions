#compdef temporal-cli temporalcli
# Documentation: https://man.archlinux.org/search?q=temporal-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activity:operate on activities'
  'batch:manage batch operations'
  'cluster:cluster management'
  'completion:generate shell completion'
  'env:manage CLI environments'
  'operator:cluster operator commands'
  'schedule:manage schedules'
  'server:start a Temporal dev server'
  'task-queue:operate on task queues'
  'workflow:operate on workflows'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--env=[environment name]:env:' \
  '--env-file=[env file]:file:_files' \
  '--address=[Temporal address host:port]:addr:' \
  '--namespace=[namespace]:ns:' \
  '--api-key=[API key]:key:' \
  '--tls[enable TLS]' \
  '--tls-cert-path=[client TLS cert]:file:_files' \
  '--tls-key-path=[client TLS key]:file:_files' \
  '--tls-ca-path=[server CA cert]:file:_files' \
  '--tls-server-name=[expected server name]:host:' \
  '--tls-disable-host-verification[disable host verification]' \
  '*--codec-endpoint=[codec server endpoint]:url:' \
  '--codec-auth=[codec server auth header]:auth:' \
  '*--grpc-meta=[gRPC metadata key=value]:kv:' \
  '--output=[output format]:format:(text json)' \
  '--time-format=[time output format]:format:(relative iso8601 raw)' \
  '--color=[color mode]:color:(auto always never)' \
  '--no-json-shorthand-payloads[do not shorten payloads]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'temporal command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (workflow)
        _arguments \
          '*::sub:(start execute show describe terminate cancel reset list count signal query stack signal-with-start trace update result delete)' \
          '--workflow-id=[workflow id]:id:' \
          '--run-id=[run id]:id:' \
          '--task-queue=[task queue]:queue:' \
          '--type=[workflow type]:type:' \
          '--input=[JSON input]:json:' \
          '--input-file=[input from file]:file:_files' && ret=0 ;;
      (activity)
        _arguments \
          '*::sub:(complete fail)' \
          '--workflow-id=[workflow id]:id:' \
          '--run-id=[run id]:id:' \
          '--activity-id=[activity id]:id:' \
          '--reason=[failure reason]:reason:' && ret=0 ;;
      (schedule)
        _arguments \
          '*::sub:(create list describe delete trigger pause unpause backfill)' \
          '--schedule-id=[schedule id]:id:' && ret=0 ;;
      (server)
        _arguments \
          '*::sub:(start-dev)' \
          '--ip=[bind IP]:ip:' \
          '--port=[bind port]:port:' \
          '--metrics-port=[metrics port]:port:' \
          '--ui-port=[Web UI port]:port:' \
          '--db-filename=[SQLite file path]:file:_files' \
          '--namespace=[namespace to create]:ns:' \
          '--log-level=[log level]:level:(debug info warn error)' && ret=0 ;;
      (env)
        _arguments '*::sub:(list get set delete)' && ret=0 ;;
      (operator)
        _arguments '*::sub:(cluster namespace search-attribute)' && ret=0 ;;
      (batch)
        _arguments '*::sub:(describe list terminate)' && ret=0 ;;
      (task-queue)
        _arguments '*::sub:(describe list)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
