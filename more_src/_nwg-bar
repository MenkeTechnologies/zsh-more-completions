#compdef nwg-bar

# Zsh completion for nwg-bar - GTK3 button bar for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --template)'{-t,--template}'[template file]:file:_files -g "*.json"' \
  '(-s --style)'{-s,--style}'[CSS style file]:file:_files -g "*.css"' \
  '(-o --output)'{-o,--output}'[specify output]:output'
