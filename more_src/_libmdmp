#compdef mdmpinfo
# _libmdmp — libyal Windows minidump (.dmp) parser; prints thread list, module list, exception record, system info, memory ranges
# upstream: https://github.com/libyal/libmdmp

_libmdmp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-X[exclusive]' \
        '*:minidump:_files -g "*.(dmp|mdmp)"'
}

_libmdmp "$@"
