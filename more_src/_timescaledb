#compdef timescaledb-tune
# _timescaledb — TimescaleDB tune utility (timescale/timescaledb-tune)
# upstream: https://github.com/timescale/timescaledb-tune

_arguments -s -S \
    '--pg-config=[path to pg_config binary]:file:_files' \
    '--conf-path=[path to postgresql.conf]:file:_files' \
    '--dest-path=[destination path for modified config]:file:_files' \
    '--memory=[total system memory]:memory:' \
    '--cpus=[number of CPUs]:cpus:' \
    '--pg-version=[PostgreSQL version]:version:' \
    '--max-conns=[maximum connections]:connections:' \
    '--max-bg-workers=[maximum background workers]:workers:' \
    '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '--dry-run[show changes without applying]' \
    '(- *)'{-h,--help}'[show help]'
