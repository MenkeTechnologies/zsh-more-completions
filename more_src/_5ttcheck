#compdef 5ttcheck
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/5ttcheck.html
# Source: MRtrix3/mrtrix3 cmd/5ttcheck.cpp — sanity check on 5TT image(s) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-voxels+[output mask images of non-conforming voxels (prefix)]:prefix:_default' \
    '*:5TT image(s):_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
