# WHAT IT IS
#   Kora is "an implementation of a Solana relayer" — a gasless-
#   transaction relayer service maintained by the Solana
#   Foundation.  End users sign a Solana transaction, hand the
#   signed bundle to the Kora HTTP-RPC server, and Kora's signer
#   pool pays the network fee in SOL on their behalf;  the user
#   compensates Kora in a configurable SPL payment token.  The
#   `kora` binary bundles the RPC server, a configuration-
#   validator, an ATA initializer for payment tokens, and an
#   OpenAPI spec generator (feature-gated by `--features docs`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from crates/cli/src/main.rs and
#                       crates/cli/src/args.rs `GlobalArgs`, plus
#                       crates/lib/src/rpc_server/args.rs
#                       `RpcArgs` + `AuthArgs` — clap derive)
#   kora [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options (apply to every subcommand):
#     --rpc-url <URL>               Solana RPC endpoint
#                                   [env: RPC_URL —
#                                   default: http://127.0.0.1:8899]
#     --config <PATH>               Kora config file (TOML)
#                                   [default: kora.toml]
#
#   Subcommands:
#     config <SUBCOMMAND>           Configuration management
#       validate                      Validate config file
#                                     (fast, no RPC calls)
#         --signers-config <PATH>       Path to signers config
#       validate-with-rpc             Validate with RPC (slower
#                                     but more thorough)
#         --signers-config <PATH>       Path to signers config
#
#     rpc <SUBCOMMAND>              RPC server operations
#       start                         Start the Kora RPC server
#         -p, --port <PORT>             HTTP port  [default: 8080]
#         --logging-format <FMT>        Log output format
#                                       (standard|json)
#                                       [default: standard]
#         --signers-config <PATH>       Multi-signer config (TOML)
#                                       (required unless
#                                       --no-load-signer)
#         --no-load-signer              Skip signer initialization
#                                       (testing / non-signing ops)
#         --api-key <KEY>               API key for request auth
#                                       [env: KORA_API_KEY]
#         --hmac-secret <SECRET>        HMAC secret for stronger
#                                       request signature auth
#                                       [env: KORA_HMAC_SECRET]
#
#       initialize-atas               Initialize Associated Token
#                                     Accounts for all payment
#                                     tokens
#         (inherits all `rpc start` arguments above)
#         --fee-payer-key <KEY>         Signer key to use as fee
#                                       payer (defaults to first
#                                       signer in pool)
#         --compute-unit-price <ULP>    Priority fee in
#                                       micro-lamports
#         --compute-unit-limit <CUL>    Compute-unit limit
#         --chunk-size <N>              Number of ATAs to create
#                                       per transaction
#
#     openapi                       Generate OpenAPI documentation
#                                   (only available when built
#                                   with --features docs)
#       -o, --output <PATH>            Output spec path
#                                      [default: openapi.json]
#
#   Standard clap auto-flags:
#     -h, --help                    Show help
#     -V, --version                 Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `solana-sdk = "3.0.0"` plus 12+ other
#   `solana-*` interface crates (solana-client, solana-commitment-
#   config, solana-message, solana-system-interface, solana-
#   transaction-status, solana-transaction-status-client-types,
#   solana-address-lookup-table-interface, solana-loader-v3-
#   interface, solana-loader-v4-interface, solana-program,
#   solana-program-pack, solana-compute-budget-interface) declared
#   in Cargo.toml workspace.dependencies — `solana-sdk` is THE
#   canonical Rust Solana SDK maintained by the Anza / Agave team
#   (anza-xyz/agave, formerly solana-labs/solana, now the
#   production validator implementation forked from solana-labs).
#   solana-sdk re-exports the core Solana primitives (Pubkey,
#   Signature, Keypair, Transaction, Message, Instruction,
#   AccountMeta, Hash, Slot, Epoch), the System Program interface,
#   the Compute Budget interface, the Address Lookup Table
#   interface, the loader v3/v4 deployment interfaces, the RPC
#   client (`solana-client`) with both blocking and tokio-async
#   variants, JSON-RPC subscription handling, and the SPL Token
#   program bindings used by every Solana-on-Rust application.
#   Kora's `crates/cli/src/main.rs` constructs a Solana RPC
#   client via `get_rpc_client(&cli.global_args.rpc_url)`,
#   initializes signers from a TOML config, validates network
#   reachability against an actual Solana cluster, then serves
#   gasless-relayer JSON-RPC over tokio.  Verified via:
#     gh api repos/solana-foundation/kora/contents/Cargo.toml
#       → solana-sdk = "3.0.0"
#       → solana-client = "3.0.10" (via workspace.dependencies)
#       → solana-program = "3.0.0"
#       → ...12 additional solana-* crates pinned at workspace
#         level
#     gh api repos/solana-foundation/kora/contents/crates/cli/
#         Cargo.toml
#       → name = "kora-cli"; [[bin]] name = "kora";
#         path = "src/main.rs"
#     gh api repos/solana-foundation/kora/contents/crates/cli/
#         src/main.rs
#       → enum Commands { Config{...}, Rpc{...}, Openapi{...} }
#       → ConfigCommands { Validate, ValidateWithRpc }
#       → RpcCommands { Start, InitializeAtas }
#   This entry is the Rust=141 leader bump that OPENS Axis 86
#   (Solana SDK Library) at 1/0/0.  Pairing Go and TS-Node bumps
#   will follow at R934 and R935 (Go=141 candidates `solana-go`-
#   based CLIs; TS-Node=141 candidates `@solana/web3.js`-based
#   CLIs).
#
#   No completion for `kora` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_kora() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--rpc-url=[Solana RPC endpoint URL]:url:' \
        '--config=[Kora config file (TOML)]:config:_files -g "*.toml"' \
        '1: :_kora_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                config)
                    _arguments \
                        '1:config subcommand:_kora_config_commands' \
                        '*::arg:->config_args' && ret=0
                    case $state in
                        config_args)
                            case $words[1] in
                                validate|validate-with-rpc)
                                    _arguments \
                                        '--signers-config=[signers config path]:path:_files -g "*.toml"' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
                rpc)
                    _arguments \
                        '1:rpc subcommand:_kora_rpc_commands' \
                        '*::arg:->rpc_args' && ret=0
                    case $state in
                        rpc_args)
                            case $words[1] in
                                start)
                                    _arguments \
                                        '(-p --port)'{-p,--port}'=[HTTP port]:port:' \
                                        '--logging-format=[log format]:format:(standard json)' \
                                        '--signers-config=[multi-signer config]:path:_files -g "*.toml"' \
                                        '--no-load-signer[skip signer initialization]' \
                                        '--api-key=[API key]:key:' \
                                        '--hmac-secret=[HMAC secret]:secret:' && ret=0 ;;
                                initialize-atas)
                                    _arguments \
                                        '(-p --port)'{-p,--port}'=[HTTP port]:port:' \
                                        '--logging-format=[log format]:format:(standard json)' \
                                        '--signers-config=[multi-signer config]:path:_files -g "*.toml"' \
                                        '--no-load-signer[skip signer initialization]' \
                                        '--api-key=[API key]:key:' \
                                        '--hmac-secret=[HMAC secret]:secret:' \
                                        '--fee-payer-key=[signer key for fee payer]:key:' \
                                        '--compute-unit-price=[priority fee in micro-lamports]:ulp:' \
                                        '--compute-unit-limit=[compute-unit limit]:cul:' \
                                        '--chunk-size=[ATAs per transaction]:n:' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
                openapi)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output OpenAPI spec path]:path:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kora_commands] )) ||
_kora_commands() {
    local -a commands
    commands=(
        'config:configuration management'
        'rpc:RPC server operations'
        'openapi:generate OpenAPI documentation (build with --features docs)'
    )
    _describe -t commands 'kora command' commands
}

(( $+functions[_kora_config_commands] )) ||
_kora_config_commands() {
    local -a commands
    commands=(
        'validate:validate config file (fast, no RPC)'
        'validate-with-rpc:validate config with RPC (slower, more thorough)'
    )
    _describe -t commands 'kora config command' commands
}

(( $+functions[_kora_rpc_commands] )) ||
_kora_rpc_commands() {
    local -a commands
    commands=(
        'start:start the Kora RPC server'
        'initialize-atas:initialize ATAs for all payment tokens'
    )
    _describe -t commands 'kora rpc command' commands
}

_kora "$@"
