#compdef objection

# Zsh completion for objection - mobile exploration toolkit (Frida-based)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-N[connect via network]' \
  '--network[connect via network]' \
  '-g+[target Gadget]:gadget' \
  '--gadget=[target Gadget]:gadget' \
  '-S+[startup script]:script:_files -g "*.js"' \
  '--startup-script=[startup script]:script:_files -g "*.js"' \
  '-s+[startup command]:command' \
  '--startup-command=[startup command]:command' \
  '-c+[command to run]:command' \
  '--file-commands=[file with commands]:file:_files' \
  '-d[enable debug mode]' \
  '--debug[enable debug mode]' \
  '-P+[Frida parameters]:params' \
  '--parameters=[Frida parameters]:params' \
  '-H+[connect to host]:host' \
  '--host=[connect to host]:host' \
  '-ah+[API host]:host' \
  '--api-host=[API host]:host' \
  '-ap+[API port]:port' \
  '--api-port=[API port]:port' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'explore:start interactive exploration'
      'patchapk:patch an APK with Frida gadget'
      'patchipa:patch an IPA with Frida gadget'
      'run:run a command without entering REPL'
      'signapk:sign an APK'
      'device-type:detect device type'
      'version:show version'
    )
    _describe -t commands 'objection command' commands && ret=0
    ;;
  args)
    case $line[1] in
      patchapk)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-s+[APK file]:apk:_files -g "*.apk"' \
          '--source=[APK file]:apk:_files -g "*.apk"' \
          '-a+[target architecture]:arch:(arm64-v8a armeabi-v7a x86 x86_64)' \
          '--architecture=[target architecture]:arch:(arm64-v8a armeabi-v7a x86 x86_64)' \
          '-V+[Frida gadget version]:version' \
          '--gadget-version=[Frida gadget version]:version' \
          '-p[pause on start]' \
          '--pause[pause on start]' \
          '-l+[Frida gadget config]:config:_files -g "*.json"' \
          '--gadget-config=[Frida gadget config]:config:_files -g "*.json"' \
          '-N[skip Frida gadget download]' \
          '--skip-cleanup[skip temp file cleanup]' \
          '-2[use apktool 2]' && ret=0
        ;;
      patchipa)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-s+[IPA file]:ipa:_files -g "*.ipa"' \
          '--source=[IPA file]:ipa:_files -g "*.ipa"' \
          '-V+[Frida gadget version]:version' \
          '--gadget-version=[Frida gadget version]:version' \
          '-p[pause on start]' \
          '--pause[pause on start]' \
          '-P+[provisioning profile]:profile:_files' \
          '--provision-file=[provisioning profile]:profile:_files' \
          '-b+[bundle ID]:bundle id' \
          '--bundle-id=[bundle ID]:bundle id' \
          '-c+[codesign identity]:identity' \
          '--codesign-signature=[codesign identity]:identity' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:command' && ret=0
        ;;
    esac
    ;;
esac

return ret
