#compdef husarnet
# Documentation: https://husarnet.com/docs/
# Peer-to-peer VPN

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'join:join a Husarnet network'
      'status:show connection status'
      'setup-server:configure the device as a server'
      'daemon:run the Husarnet daemon'
      'whitelist:manage the whitelist'
      'genid:generate a new device ID'
    )
    _describe -t commands 'husarnet command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      join)
        _arguments -s -S \
          '1:join code:' \
          '2:hostname:' && ret=0
        ;;
      whitelist)
        _arguments -s -S \
          '1:action:(add rm ls)' \
          '*:address:' && ret=0
        ;;
    esac
    ;;
esac

return ret
