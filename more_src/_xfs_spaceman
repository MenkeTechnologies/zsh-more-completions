#compdef xfs_spaceman
# _xfs_spaceman — xfsprogs xfs_spaceman (online XFS space-management tool; subcommands info/freesp summarize allocation, trim issues fstrim, healthcheck probes filesystem health, prealloc reserves space, scrub runs an online scrub; -c run a one-shot command, -V version)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Subcommands from xfsprogs spaceman/init.c on tip.

_xfs_spaceman() {
    _arguments \
        '-V[show version]' \
        '-c+[run command]:command:' \
        '-x[expert mode]' \
        '1:mountpoint:_files -/'
}

_xfs_spaceman "$@"
