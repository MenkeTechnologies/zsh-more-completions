#compdef funcgraph
# Documentation: https://github.com/brendangregg/perf-tools (kernel/funcgraph getopts)
# Reference accessed: 2026-05-29
# funcgraph — graph kernel function calls (ftrace function_graph wrapper).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-a[all info (same as -HPt)]' \
  '-C[measure on-CPU time only]' \
  '-d+[trace duration, and use buffers]:seconds:' \
  '-D[do not show function duration]' \
  '-H[include column headers]' \
  '-m+[max stack depth to show]:depth:' \
  '-p+[trace when this PID is on-CPU]:pid:_pids' \
  '-L+[trace when this TID (thread) is on-CPU]:tid:' \
  '-P[show process names & PIDs]' \
  '-t[show timestamps]' \
  '-T[comment function tails]' \
  '1:funcstring (kernel function pattern e.g. do_nanosleep, do_sys_open):' \
  && ret=0

return ret
