#compdef MFTECmd
# Documentation: https://github.com/EricZimmerman/MFTECmd
# Parses $MFT, $J, $LogFile, $Boot, $SDS, $I30 from NTFS file systems

local ret=1

_arguments -s -S \
  '-f[file to process ($MFT|$J|$Boot|$SDS|$I30)]:file:_files' \
  '--json[directory for JSON results]:directory:_files -/' \
  '--jsonf[filename for JSON output]:filename' \
  '--csv[directory for CSV results]:directory:_files -/' \
  '--csvf[filename for CSV output]:filename' \
  '--body[directory for bodyfile format (requires --bdl)]:directory:_files -/' \
  '--bodyf[filename for bodyfile output]:filename' \
  '--bdl[drive letter for bodyfile]:letter' \
  '--blf[use LF instead of CRLF for newlines]' \
  '--dd[directory for exported FILE record (requires --do)]:directory:_files -/' \
  '--do[FILE record offset (decimal or hex)]:offset' \
  '--de[dump entry details by entry/sequence number]:entry' \
  '--fls[display directory contents (with --de)]' \
  '--ds[dump Security ID details]' \
  '--dr[dump resident files to --csv Resident subdirectory]' \
  '--dt[custom date/time format]:format' \
  '--sn[include DOS filename types]' \
  '--fl[condensed file listing (requires --csv)]' \
  '--at[include all 0x30 attribute timestamps]' \
  '--vss[process Volume Shadow Copies]' \
  '--dedupe[deduplicate by SHA-1]' \
  '--debug[show debug information]' \
  '--trace[show trace information]' && ret=0

return ret
