#compdef aws-iam-authenticator

# Zsh completion for aws-iam-authenticator (AWS IAM credentials for Kubernetes)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:Help about any command'
  'init:Pre-generate certificate, private key, and kubeconfig'
  'server:Run a webhook server'
  'token:Authenticate using AWS IAM and get token for Kubernetes'
  'verify:Verify a token for debugging'
  'version:Print version'
)

_arguments -s -S -C \
  '(-i --cluster-id)'{-i,--cluster-id}'=[Specify the cluster ID]:cluster id' \
  '(-l --log-format)'{-l,--log-format}'=[Set the log format]:format:(text json)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'aws-iam-authenticator command' commands && ret=0
    ;;
  args)
    case $words[1] in
      token)
        _arguments -s -S \
          '(-i --cluster-id)'{-i,--cluster-id}'=[Cluster ID for token]:cluster id' \
          '(-r --role)'{-r,--role}'=[Assume the specified IAM role ARN]:role arn' \
          '--token-only[Only output the token]' \
          '--forward-session-name[Forward the session name to the STS call]' \
          '--cache[Cache the token to a file]' \
          '--region=[The AWS region]:region' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(-i --cluster-id)'{-i,--cluster-id}'=[Cluster ID]:cluster id' \
          '--hostname=[Hostname for the certificate]:hostname' \
          '--address=[Address for the certificate]:address' && ret=0
        ;;
      server)
        _arguments -s -S \
          '--generate-kubeconfig=[Generate a kubeconfig file]:file:_files' \
          '--kubeconfig-pregenerated[Use a pre-generated kubeconfig]' \
          '--state-dir=[Directory for state files]:dir:_files -/' \
          '--master=[API server URL to connect to]:url' \
          '--backend-mode=[Auth backend mode]:mode:(EKSConfigMap MountedFile CRD)' \
          '--ec2-describeinstances-role-arn=[Role ARN for EC2 describe]:role arn' && ret=0
        ;;
      verify)
        _arguments -s -S \
          '(-i --cluster-id)'{-i,--cluster-id}'=[Cluster ID]:cluster id' \
          '(-t --token)'{-t,--token}'=[Token to verify]:token' && ret=0
        ;;
    esac
    ;;
esac

return ret
