#compdef dh-make dh_make

# Zsh completion for dh-make - Debianize source trees

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --copyright)'{-c,--copyright}'=[type of copyright]:license:(gpl gpl2 gpl3 lgpl lgpl2 lgpl3 artistic apache bsd mit custom)' \
  '(-e --email)'{-e,--email}'=[maintainer email address]:email: ' \
  '(-f --file)'{-f,--file}'=[upstream tarball]:tarball:_files -g "*.tar.*(-.)"' \
  '(-n --native)'{-n,--native}'[create a native Debian package]' \
  '(-s --single)'{-s,--single}'[single binary package]' \
  '(-i --indep)'{-i,--indep}'[architecture-independent package]' \
  '(-a --arch)'{-a,--arch}'=[set architecture]:architecture: ' \
  '(-l --library)'{-l,--library}'[library package]' \
  '(-k --kmod)'{-k,--kmod}'[kernel module package]' \
  '(-p --packagename)'{-p,--packagename}'=[set package name]:package name: ' \
  '(-y --yes)'{-y,--yes}'[automatic yes to prompts]' \
  '--createorig[create orig.tar from upstream source]' \
  '--addmissing[add missing files to debian directory]' \
  '--defaultless[skip default questions]' \
  '(-o --overlay)'{-o,--overlay}'[put debian directory on an overlay]' \
  '(-t --templates)'{-t,--templates}'=[use templates from directory]:directory:_directories' \
  '(-d --with-emacs)'{-d,--with-emacs}'[generate emacsen files]' \
  '(-r --with-cdbs)'{-r,--with-cdbs}'[generate CDBS rules file]' && ret=0

return ret
