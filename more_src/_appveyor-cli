#compdef appveyor-cli appveyor
# _appveyor-cli — AppVeyor Hosted CI service appveyor-tools CLI alias (appveyor team, C#); custom argparse
# upstream: https://github.com/appveyor/ci

_appveyor-cli() {
    local -a sub=(
        'AddTest:add test result'
        'AddMessage:add build message'
        'UpdateTest:update test result'
        'DownloadFile:download file'
        'PushArtifact:push build artifact'
        'PushSentryEvent:push sentry event'
        'PushApiArtifact:push api artifact'
        'StartTestSuite:start test suite'
        'EndTestSuite:end test suite'
        'AddCompilationMessage:add compilation message'
        'WaitForJob:wait for job'
        'WaitForLockedBuild:wait for locked build'
        'StopBuild:stop build'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appveyor subcommand' sub ;;
        args)
            case $words[1] in
                PushArtifact) _arguments \
                    '*:file:_files' \
                    '-Path+[path]:file:_files' \
                    '-FileName+[file name]:str:' \
                    '-DeploymentName+[name]:str:' \
                    '-Type+[type]:t:(Auto WebDeployPackage NuGetPackage Zip File)' ;;
                AddTest|UpdateTest) _arguments \
                    '-Name+[test name]:str:' \
                    '-Framework+[framework]:f:(MSTest NUnit XUnit MSpec JUnit Other)' \
                    '-FileName+[file name]:str:' \
                    '-Outcome+[outcome]:o:(Passed Failed Inconclusive NotFound Cancelled Skipped Running NotRunnable)' \
                    '-Duration+[ms]:n:' \
                    '-ErrorMessage+[error message]:str:' \
                    '-ErrorStackTrace+[stack trace]:str:' \
                    '-StdOut+[stdout]:str:' \
                    '-StdErr+[stderr]:str:' ;;
                AddMessage) _arguments \
                    '-Message+[message]:str:' \
                    '-Category+[category]:c:(Information Warning Error)' \
                    '-Details+[details]:str:' ;;
                DownloadFile) _arguments \
                    '-Url+[url]:url:_urls' \
                    '-FileName+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_appveyor-cli "$@"
