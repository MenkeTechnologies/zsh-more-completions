#compdef complementBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/complement.html
# report intervals not covered by features in a file (bedtools complement)

local ret=1

_arguments -s -S \
  '-i[input BED/GFF/VCF file]:file:_files' \
  '-g[genome file with chromosome names and sizes]:file:_files' \
  '-L[limit output to chromosomes present in the input]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
