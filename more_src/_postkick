#compdef postkick
# _postkick — Postfix private-IPC client (sends a one-shot request to a named Postfix service over a local transport endpoint; exposes private IPC for shell scripts)
# upstream: https://github.com/vdukhovni/postfix
# Flags + positional args from postfix/man/man1/postkick.1 on tip.

_postkick() {
    _arguments \
        '-c+[config directory]:dir:_files -/' \
        '*-v[verbose logging (repeat for more)]' \
        '1:class:(public private)' \
        '2:service:' \
        '3:request:'
}

_postkick "$@"
