#compdef setuidgid
# Documentation: https://cr.yp.to/daemontools/setuidgid.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: setuidgid takes no options, only positional account + child argv.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:account:_users' \
  '*::cmd:_command_names' && ret=0

return ret
