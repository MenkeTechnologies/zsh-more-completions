#compdef gu

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'available:list available components'
  'info:print component information'
  'install:install component packages'
  'list:list installed components'
  'rebuild-images:rebuild native image components'
  'remove:remove component packages'
  'update:update GraalVM components'
  'upgrade:upgrade GraalVM to the latest version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-A[auto-accept all licenses]' \
  '--auto-yes[auto-accept all licenses]' \
  '-c+[specify catalog URL]:catalog URL' \
  '--catalog=[specify catalog URL]:catalog URL' \
  '-L[local file mode]' \
  '--local-file[local file mode]' \
  '-N[non-interactive mode]' \
  '--non-interactive[non-interactive mode]' \
  '-u+[custom catalog URL]:URL' \
  '--url=[custom catalog URL]:URL' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'gu command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      install)
        _arguments -s -S \
          '-0[do not process dependencies]' \
          '--no-deps[do not process dependencies]' \
          '-f[force overwrite of existing files]' \
          '--force[force overwrite of existing files]' \
          '-D[do not install dependencies]' \
          '--no-download[do not download, install from local]' \
          '-n[dry run]' \
          '--dry-run[dry run]' \
          '-r[replace existing components]' \
          '--replace[replace existing components]' \
          '*:component:' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '-0[do not process dependencies]' \
          '--no-deps[do not process dependencies]' \
          '-f[force removal]' \
          '--force[force removal]' \
          '*:component:' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-c[show catalog URL]' \
          '-v[verbose]' && ret=0
        ;;
      available)
        _arguments -s -S \
          '-v[verbose]' && ret=0
        ;;
    esac
    ;;
esac

return ret
