#compdef kubectl-netscaler
# Documentation: https://github.com/netscaler/modern-apps-toolkit/blob/main/netscaler-plugin/README.md
# Reference accessed: 2026-05-19
# Verified: netscaler/modern-apps-toolkit netscaler-plugin README +
# Citrix docs (kubectl-netscaler bundled with Citrix Ingress Controller
# 1.32.7+).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --namespace/--kubeconfig/--context (not on this plugin —
# kubectl-netscaler is its own binary, not a kubectl context wrapper).

# kubectl-netscaler: Citrix Ingress Controller diagnostics plugin
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'help:show help'
  'status:show CIC/NetScaler status'
  'conf:print CIC running configuration'
  'support:collect support bundle'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kubectl-netscaler command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (status)
        _arguments \
          '--deployment=[CIC deployment name]:deployment:' \
          '(-l --label)'{-l+,--label=}'[label selector]:label:' \
          '--pod=[CIC pod name]:pod:' \
          '(-i --ingress)'{-i+,--ingress=}'[filter by ingress]:ingress:' \
          '--output=[output format]:fmt:(tabular json)' \
          '(-p --prefix)'{-p+,--prefix=}'[resource name prefix]:prefix:' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' && ret=0
        ;;
      (conf)
        _arguments \
          '--deployment=[CIC deployment]:deployment:' \
          '(-l --label)'{-l+,--label=}'[label selector]:label:' \
          '--pod=[CIC pod]:pod:' && ret=0
        ;;
      (support)
        _arguments \
          '--deployment=[CIC deployment]:deployment:' \
          '(-l --label)'{-l+,--label=}'[label selector]:label:' \
          '--pod=[CIC pod]:pod:' \
          '--appns=[application namespace]:ns:' \
          '(-d --dir)'{-d+,--dir=}'[output dir]:dir:_files -/' \
          '--unhideIP[do not redact IPs]' \
          '--skip-nsbundle[skip NetScaler showtechsupport bundle]' && ret=0
        ;;
    esac
    ;;
esac
return ret
