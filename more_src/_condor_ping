#compdef condor_ping
# Documentation: https://man.archlinux.org/search?q=condor_ping
# Reference accessed: 2026-05-16

# condor_ping: ping HTCondor authorization/security
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-name[daemon name]:name:' \
  '-pool[pool]:pool:' \
  '-address[address]:addr:' \
  '-type[daemon type]:type:(MASTER SCHEDD COLLECTOR NEGOTIATOR STARTD KBDD HAD QUILL CREDD STORAGE GENERIC)' \
  '-debug[debug]' \
  '-config[config file]:file:_files' \
  '-cap[capability]:cap:' \
  '-table[print table]' \
  '-verbose[verbose]' \
  '-quiet[quiet]' \
  '*:authz level (ADVERTISE_MASTER ADVERTISE_SCHEDD ADVERTISE_STARTD READ WRITE NEGOTIATOR ADMINISTRATOR OWNER CONFIG DAEMON CLIENT):' && ret=0
return ret
