#compdef condor_ping
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_ping.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_ping: ping HTCondor authorization/security.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-debug[print debugging information]' \
  '-config[negotiate based on configuration file]' \
  '-address[target the given IP address]:addr:' \
  '-pool[target host (pool)]:pool:' \
  '-name[target daemon by name]:name:' \
  '-type[target daemon by subsystem type]:type:(MASTER SCHEDD COLLECTOR NEGOTIATOR STARTD KBDD HAD CREDD STORAGE GENERIC)' \
  '-quiet[set exit status only; no output]' \
  '-table[output one result per line in table format]' \
  '-verbose[display all available output]' \
  '-long[display result ClassAds]' \
  '-format[print attributes using printf-style format]:format attr:' \
  '-autoformat[autoformat attributes]:list:' \
  '-af[autoformat attributes]:list:' \
  '*:authz level (READ WRITE NEGOTIATOR ADMINISTRATOR OWNER CONFIG DAEMON CLIENT ADVERTISE_MASTER ADVERTISE_SCHEDD ADVERTISE_STARTD):' && ret=0
return ret
