#compdef clj-watson
# Documentation: https://github.com/clj-holmes/clj-watson
# Clojure dependency vulnerability scanner

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(scan)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-p --deps-edn-path)'{-p,--deps-edn-path}'+[path to deps.edn file to scan]:file:_files' \
      '--classpath+[explicit classpath to scan]:classpath:_files' \
      '(-o --output)'{-o,--output}'+[output format]:format:(json edn stdout stdout-simple sarif)' \
      '(-s --suggest-fix)'{-s,--suggest-fix}'[include dependency remediation suggestions]' \
      '*'{-a,--aliases}'+[include deps.edn aliases in analysis]:alias:' \
      '(-t --database-strategy)'{-t,--database-strategy}'+[select vulnerability database]:strategy:(dependency-check github-advisory)' \
      '(-f --fail-on-result)'{-f,--fail-on-result}'[exit non-zero if vulnerabilities are detected]' \
      '(-c --cvss-fail-threshold)'{-c,--cvss-fail-threshold}'+[exit non-zero when CVSS score meets threshold]:score:' \
      '(-w --clj-watson-properties)'{-w,--clj-watson-properties}'+[additional properties file]:file:_files' \
      '--run-without-nvd-api-key[allow execution without an NVD API key]' && ret=0
    ;;
esac

return ret
