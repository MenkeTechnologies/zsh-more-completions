#compdef spotbugs
# Documentation: https://spotbugs.readthedocs.io/en/latest/running.html
# Reference accessed: 2026-05-21
# Verified: upstream spotbugs readthedocs running.html.

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '(-textui -gui -gui1)-textui[run text UI]' \
  '(-textui -gui -gui1)-gui[run graphical UI]' \
  '(-textui -gui -gui1)-gui1[run original graphical UI]' \
  '(-low -medium -high)-low[report low+ priority bugs]' \
  '(-low -medium -high)-medium[report medium+ priority bugs]' \
  '(-low -medium -high)-high[report only high priority bugs]' \
  '-relaxed[suppress false-positive heuristics]' \
  '-workHard[ensure minimum default effort]' \
  '-conserveSpace[equivalent to -effort:min]' \
  '-adjustExperimental[lower priority of experimental patterns]' \
  '-effort=[analysis effort]:level:(min less default more max)' \
  '-project=[project file]:file:_files -g "*.{fb,fbp}"' \
  '-pluginList=[plugin jar list]:jars:' \
  '-home=[SpotBugs home directory]:dir:_files -/' \
  '-onlyAnalyze=[restrict analysis scope]:classes:' \
  '-auxclasspath=[aux classpath]:cp:' \
  '-auxclasspathFromFile=[read classpath from file]:file:_files' \
  '-analyzeFromFile=[read files to analyze from file]:file:_files' \
  '-include=[include filter file]:file:_files -g "*.xml"' \
  '-exclude=[exclude filter file]:file:_files -g "*.xml"' \
  '-bugCategories=[bug categories]:list:' \
  '-visitors=[run named visitors only]:visitors:' \
  '-omitVisitors=[exclude named visitors]:visitors:' \
  '-chooseVisitors=[enable/disable detectors]:visitors:' \
  '-choosePlugins=[enable/disable plugins]:plugins:' \
  '-adjustPriority=[adjust warning priorities]:list:' \
  '-nested=[scan nested JARs]:flag:(true false)' \
  '-sourcepath=[source path]:path:' \
  '-xml=[XML output file]:file:_files' \
  '-html=[HTML output file]:file:_files' \
  '-sarif=[SARIF output file]:file:_files' \
  '-emacs=[Emacs format output]:file:_files' \
  '-xdocs=[xdocs output]:file:_files' \
  '-sortByClass=[sort by class]:file:_files' \
  '-exitcode[set process exit code]' \
  '-printConfiguration[display configuration without analyzing]' \
  '*:project:_files'
