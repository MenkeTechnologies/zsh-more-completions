#compdef spotbugs

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '(-textui -gui)-textui[run text UI]' \
  '(-textui -gui)-gui[run graphical UI]' \
  '(-low -medium -high)-low[report low+ priority bugs]' \
  '(-low -medium -high)-medium[report medium+ priority bugs]' \
  '(-low -medium -high)-high[report only high priority bugs]' \
  '-relaxed[relaxed reporting]' \
  '-train[train mode]' \
  '-workHard[work hard for accurate analysis]' \
  '-conserveSpace[conserve memory]' \
  '-onlyAnalyze=[analyze classes/packages]:classes:' \
  '-auxclasspath=[aux classpath]:cp:' \
  '-include=[include filter file]:file:_files -g "*.xml"' \
  '-exclude=[exclude filter file]:file:_files -g "*.xml"' \
  '-applySuppression[apply suppression filter]' \
  '-bugCategories=[bug categories]:list:' \
  '-reportLevel=[report level]:level:(low medium high)' \
  '-longBugCodes[long bug codes]' \
  '-effort=[analysis effort]:level:(min less default more max)' \
  '-xml=[XML output file]:file:_files' \
  '-xml\:withMessages=[XML with messages output]:file:_files' \
  '-html=[HTML output file]:file:_files' \
  '-sarif=[SARIF output file]:file:_files' \
  '-emacs=[Emacs format output]:file:_files' \
  '-xdocs=[xdocs output]:file:_files' \
  '-sortByClass[sort by class]' \
  '-output=[output file]:file:_files' \
  '-outputFile=[output file]:file:_files' \
  '-progress[show progress]' \
  '-quiet[quiet output]' \
  '-timestampNow[use current timestamp]' \
  '*:project:_files'
