#compdef rlaunch
# Documentation: https://materialsproject.github.io/fireworks/fireworks.scripts.html
# FireWorks rocket launcher (run jobs directly without a queue)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --launchpad_file)'{-l,--launchpad_file}'[path to launchpad file]:file:_files' \
  '(-w --fworker_file)'{-w,--fworker_file}'[path to fworker file]:file:_files' \
  '(-c --config_dir)'{-c,--config_dir}'[path to a directory containing the config file]:dir:_files -/' \
  '--loglvl=[level to print log messages]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-s --silencer)'{-s,--silencer}'[shortcut to mute log messages]' \
  '1:command:(singleshot rapidfire multi)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      singleshot)
        _arguments -s \
          '(-f --fw_id)'{-f,--fw_id}'[specific fw_id to run]:fw_id:' \
          '--offline[run in offline mode]' \
          '--pdb[invoke debugger on error]' && ret=0
        ;;
      rapidfire)
        _arguments -s \
          '--nlaunches=[number of launches (int or infinite)]:n:' \
          '--timeout=[timeout in secs after which to quit]:secs:' \
          '--max_loops=[quit after this many sleep loops]:n:' \
          '--sleep=[sleep time between loops in secs]:secs:' \
          '--local_redirect[redirect stdout and stderr to launch directory]' && ret=0
        ;;
      multi)
        _arguments -s \
          '--nlaunches=[number of FireWorks to run in series per parallel job]:n:' \
          '--sleep=[sleep time between loops in infinite launch mode]:secs:' \
          '--timeout=[timeout in secs after which to quit]:secs:' \
          '--nodefile=[nodefile name or environment variable name]:nodefile:' \
          '--ppn=[processors per node]:n:' \
          '--exclude_current_node[do not use the launching node as compute node]' \
          '--local_redirect[redirect stdout and stderr to launch directory]' \
          '1:num_jobs:' && ret=0
        ;;
    esac
    ;;
esac

return ret
