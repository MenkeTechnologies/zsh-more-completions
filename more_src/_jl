#compdef jl
# Documentation: https://github.com/koenbollen/jl/blob/master/README.md
# jl - JSON Logs, a development tool for working with structured JSON logging

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--color[force colorized output]' \
  '--no-color[do not colorize output]' \
  '--skip-prefix[skip printing truncated bytes before the JSON]' \
  '--skip-suffix[skip printing truncated bytes after the JSON]' \
  '--skip-fields[do not output misc json keys as fields]' \
  '--max-field-length=[omit fields exceeding length, 0 for no limit (default 30)]:length' \
  '(-f --include-fields)'{-f+,--include-fields=}'[always include these json keys as fields (comma separated)]:fields' \
  '--exclude-fields=[always exclude these json keys (comma separated)]:fields' \
  '*:log file:_files' && ret=0

return ret
