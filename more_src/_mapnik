#compdef mapnik
# Documentation: https://github.com/mapnik/mapnik
# Reference accessed: 2026-05-16
# Verified: upstream mapnik/mapnik is a C++ library only - no CLI binary.
# Third-party renderers (nik2img, nik4) exist as separate packages and
# should have their own completion files; do not bundle here.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# mapnik: C++ map rendering library (no CLI binary upstream)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
