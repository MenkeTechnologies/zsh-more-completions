#compdef notab
# Documentation: https://man.archlinux.org/search?q=notab
# Reference accessed: 2026-05-16

# EMBOSS notab: replace tabs with spaces in an ASCII file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[input ASCII text file]:file:_files' \
  '-outfile=[output file]:file:_files' \
  '*:input file:_files' && ret=0
return ret
