#compdef lrcalc
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/lrcalc.1.html
# lrcalc: calculate with Littlewood-Richardson coefficients

local ret=1

_arguments -s -S \
  '-m[option used with skew]' \
  '-mz[option used with mult]' \
  '-a[option used with coprod]' \
  '-r[restrict to partitions in at most given rows]:rows' \
  '-q[calculate quantum coefficients (experimental)]:rows,cols' \
  '-f[calculate fusion coefficients (experimental)]:rows,level' \
  '1:command:(lrcoef mult skew coprod lrtab)' \
  '*:partition:_default' && ret=0

return ret
