#compdef ansible-tower awx-cli tower-cli ansible-automation-controller
# _ansible-tower — Red Hat Ansible ansible-tower awx-cli CLI command-line frontend wrapping the Ansible Automation Controller AWX REST API providing inventory job_template workflow job project credential credential_type team organization user role schedule notification_template ad_hoc-command-run-cancel-monitor-pdb (Red Hat team, Python); click
# upstream: https://www.redhat.com/en/technologies/management/ansible/automation-controller

_ansible-tower() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'config:configuration'
        'inventory:inventory operations'
        'inventory_source:inventory source operations'
        'host:host operations'
        'group:group operations'
        'project:project operations'
        'credential:credential operations'
        'credential_type:credential-type operations'
        'job_template:job template operations'
        'workflow_job_template:workflow template operations'
        'job:job operations'
        'workflow_job:workflow job operations'
        'team:team operations'
        'organization:organization operations'
        'user:user operations'
        'role:role operations'
        'schedule:schedule operations'
        'notification_template:notification template operations'
        'ad_hoc:run ad-hoc command'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--host=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--oauth-token=+[token]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "*.cfg *.ini *.yaml *.yml"' \
        '--conf.path=+[file]:file:_files -g "*.cfg *.ini *.yaml *.yml"' \
        '-f+[format]:f:(json yaml human table id)' \
        '--format=+[format]:f:(json yaml human table id)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ansible-tower subcommand' sub ;;
        args)
            case $words[1] in
                inventory|inventory_source|host|group|project|credential|credential_type|job_template|workflow_job_template|team|organization|user|role|schedule|notification_template) _arguments '1:op:(list get create modify delete launch monitor associate disassociate)' '*:id-or-name:' ;;
                job|workflow_job) _arguments '1:op:(list get cancel relaunch stdout)' '*:id:' ;;
            esac
            ;;
    esac
}

_ansible-tower "$@"
