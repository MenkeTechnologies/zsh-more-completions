#compdef ibchecknet

# ibchecknet: check IB network for symbol/link errors
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-N[no GID check]' \
  '-n[no GID resolution]' \
  '-C[CA name]:name:' \
  '-P[CA port]:port:' \
  '-s[summary only]' \
  '-G[output GID-based]' \
  '-z[show zero values too]' \
  '*::ibchecknet args:_files' && ret=0
return ret
