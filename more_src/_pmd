#compdef pmd

# Zsh completion for PMD - source code analyzer

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:run PMD rules against source code'
  'cpd:run the copy-paste detector'
  'designer:launch the PMD designer'
  'cpd-gui:launch the CPD GUI'
  'ast-dump:dump the AST of a source file'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show PMD version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pmd command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '(-d --dir)'{-d,--dir}'[source files/dirs]:path:_files' \
          '(-R --rulesets)'{-R,--rulesets}'[ruleset files or names]:rulesets:' \
          '(-f --format)'{-f,--format}'[report format]:format:(text textcolor html xml json csv sarif summaryhtml emacs codeclimate yahtml ideaj textpad html5 xslt)' \
          '(-r --report-file)'{-r,--report-file}'[output report file]:file:_files' \
          '--fail-on-violation[fail if violations found]:true/false:(true false)' \
          '--no-fail-on-violation[do not fail on violations]' \
          '--encoding[source file encoding]:encoding:' \
          '--threads[number of threads]:n:' \
          '(-l --use-version)'{-l,--use-version}'[language version]:lang-ver:' \
          '--aux-classpath[auxiliary classpath]:classpath:' \
          '--cache[analysis cache file]:file:_files' \
          '--no-cache[disable cache]' \
          '--debug[debug output]' \
          '--verbose[verbose output]' \
          '--minimum-priority[minimum priority to report]:priority:(1 2 3 4 5)' \
          '--suppress-marker[suppress marker]:marker:' \
          '--show-suppressed[show suppressed violations]' \
          '--property[rule property]:key=value:' \
          '(-P --ruleset-properties)'{-P,--ruleset-properties}'[ruleset properties]:properties:' && ret=0
        ;;
      (cpd)
        _arguments \
          '(-d --dir)'{-d,--dir}'[source files/dirs]:path:_files' \
          '--minimum-tokens[minimum token length]:n:' \
          '--format[output format]:format:(text xml csv csv_with_linecount_per_file vs)' \
          '--language[language]:lang:(java javascript python cpp cs php ruby swift scala kotlin go rust dart plsql matlab apex groovy)' \
          '--encoding[source file encoding]:encoding:' \
          '--exclude[exclude files]:files:_files' \
          '--failOnViolation[fail if duplicates found]' \
          '--skip-duplicate-files[skip duplicate files]' \
          '--skip-blocks[skip blocks marked with]:marker:' \
          '--skip-lexical-errors[skip lexical errors]' \
          '--no-skip-blocks[do not skip blocks]' \
          '--ignore-annotations[ignore annotations]' \
          '--ignore-identifiers[ignore identifiers]' \
          '--ignore-literals[ignore literal values]' \
          '--ignore-usings[ignore using statements]' && ret=0
        ;;
      (ast-dump)
        _arguments \
          '(-l --language)'{-l,--language}'[language]:lang:' \
          '(-f --format)'{-f,--format}'[format]:format:(text xml)' \
          '(-i --file)'{-i,--file}'[input file]:file:_files' \
          '--read-stdin[read source from stdin]' && ret=0
        ;;
    esac
    ;;
esac

return ret
