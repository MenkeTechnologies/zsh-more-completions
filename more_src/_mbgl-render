#compdef mbgl-render
# Documentation: https://github.com/maplibre/maplibre-native/blob/main/bin/render.cpp
# mbgl-render - render a MapLibre GL style to a static image (MapLibre Native)

local ret=1

_arguments -s \
  '--help[show help]' \
  '--backend=[rendering backend]:backend' \
  '(-t --apikey)'{-t,--apikey}'=[API key]:key' \
  '(-s --style)'{-s,--style}'=[map style file or URL]:style:_files' \
  '(-o --output)'{-o,--output}'=[output image file]:file:_files' \
  '(-c --cache)'{-c,--cache}'=[cache database file]:file:_files' \
  '(-a --assets)'{-a,--assets}'=[assets directory]:dir:_files -/' \
  '--debug[enable debug output]' \
  '(-r --ratio)'{-r,--ratio}'=[pixel ratio]:ratio' \
  '--bounds=[map bounds]:bounds' \
  '(-z --zoom)'{-z,--zoom}'=[zoom level]:zoom' \
  '(-x --lon)'{-x,--lon}'=[longitude]:lon' \
  '(-y --lat)'{-y,--lat}'=[latitude]:lat' \
  '(-A --alt)'{-A,--alt}'=[altitude]:alt' \
  '(-f --fov)'{-f,--fov}'=[field of view]:fov' \
  '(-b --bearing)'{-b,--bearing}'=[bearing in degrees]:bearing' \
  '(-p --pitch)'{-p,--pitch}'=[pitch in degrees]:pitch' \
  '(-R --roll)'{-R,--roll}'=[roll in degrees]:roll' \
  '(-w --width)'{-w,--width}'=[image width in pixels]:width' \
  '(-h --height)'{-h,--height}'=[image height in pixels]:height' \
  '(-m --mode)'{-m,--mode}'=[map mode]:mode' && ret=0

return ret
