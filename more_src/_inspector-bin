#compdef inspector-bin
# Documentation: https://github.com/modelcontextprotocol/inspector
# Reference accessed: 2026-05-23
# Verified: npx @modelcontextprotocol/inspector inspector-bin --help.

# Zsh completion for inspector-bin - MCP Inspector (npm package binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-e+[environment variable KEY=VALUE]:env:' \
  '--config=[MCP config file path]:file:_files -g "*.json"' \
  '--server=[server name from config file]:server:' \
  '--cli[enable CLI mode without UI]' \
  '--transport=[transport type]:transport:(stdio sse http)' \
  '--server-url=[server URL for SSE/HTTP]:url:' \
  '*--header=[HTTP header HeaderName\: Value]:header:' \
  '*::server command:_files' && ret=0

return ret
