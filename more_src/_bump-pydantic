#compdef bump-pydantic
# Documentation: https://github.com/pydantic/bump-pydantic
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pydantic/bump-pydantic — codemod tool to migrate Pydantic v1 -> v2.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[show version]' \
  '--help[show help]' \
  '--diff[show diff instead of applying changes]' \
  '*--disable=[disable transformation rule (repeatable)]:rule:' \
  '1:path:_files -/' && ret=0

return ret
