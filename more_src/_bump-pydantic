#compdef bump-pydantic

# Zsh completion for bump-pydantic
# https://github.com/pydantic/bump-pydantic

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[show version]' \
  '--help[show help]' \
  '--diff[show diff instead of applying changes]' \
  '--confirm[ask for confirmation for each change]' \
  '--no-backup[do not create backup files]' \
  '1:path:_files -/' && ret=0

return ret
