#compdef bear
# Documentation: https://github.com/rizsotto/Bear
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Bear (Build EAR) - compilation database generator

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--verbose[run in verbose mode]' \
  '(-o --output)'{-o,--output}'=[specify output file]:output file:_files' \
  '(-a --append)'{-a,--append}'[append to existing output file]' \
  '--config=[specify config file]:config file:_files' \
  '--force-preload[force dynamic linker intercept method]' \
  '--force-wrapper[force compiler wrapper intercept method]' \
  '*::build command:_command_names -e'
