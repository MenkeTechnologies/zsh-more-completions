#compdef pmproxy
# Documentation: https://man.archlinux.org/man/pmproxy.1.en
# Performance Co-Pilot proxy server for metrics and time series

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[show help]' \
  '-A[disable service advertisement]' \
  '(-c --config)'{-c+,--config=}'[path to configuration file]:conffile:_files' \
  '(-d --deprecated)'{-d,--deprecated}'[run in legacy synchronous mode]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground instead of daemon]' \
  '(-F --managed)'{-F,--managed}'[run in foreground with housekeeping]' \
  '(-h --keyhost)'{-h+,--keyhost=}'[alternate key-value server host]:host:_hosts' \
  '(-i --interface)'{-i+,--interface=}'[IP address to accept client connections]:ipaddress' \
  '(-l --log)'{-l+,--log=}'[alternate log file location]:logfile:_files' \
  '-L+[maximum incoming PDU size in bytes]:bytes' \
  '(-p --port)'{-p+,--port=}'[alternate client connection port]:port' \
  '(-r --keyport)'{-r+,--keyport=}'[alternate key-value server port]:port' \
  '(-s --socket)'{-s+,--socket=}'[path to local Unix domain socket]:sockname:_files' \
  '(-t --timeseries)'{-t,--timeseries}'[automatic archive timeseries discovery mode]' \
  '(-U --username)'{-U+,--username=}'[assume identity of specified user]:username:_users' \
  '-x+[redirect startup error output to file]:outfile:_files' && ret=0

return ret
