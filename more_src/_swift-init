#compdef swift-init
# Documentation: https://man.archlinux.org/search?q=swift-init
# Reference accessed: 2026-05-16

# swift-init: start/stop swift services
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'all:all swift services'
  'main:main swift services'
  'proxy:proxy services'
  'account:account services'
  'container:container services'
  'object:object services'
  'replication:replication services'
  'auditor:auditor services'
  'updater:updater services'
  'rest:remaining swift services'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-c[config dir]:dir:_files -/' \
  '--config-dir=[config dir]:dir:_files -/' \
  '-r[max wait for graceful shutdown]:seconds:' \
  '--run-dir=[run dir]:dir:_files -/' \
  '-w[don'\''t wait for running processes]' \
  '--no-wait[don'\''t wait for running processes]' \
  '-o[run once and exit]' \
  '--once[run once and exit]' \
  '-q[suppress output]' \
  '--quiet[suppress output]' \
  '-n[dry-run]' \
  '--no-daemon[do not daemonize]' \
  '-k[kill stale processes]' \
  '--kill-after-timeout[kill stale processes]' \
  '1: :->server' \
  '2:action:(start stop restart shutdown reload force-reload no-daemon no-wait once status)' && ret=0
case $state in
  server) _describe -t commands 'swift-init server' commands && ret=0 ;;
esac
return ret
