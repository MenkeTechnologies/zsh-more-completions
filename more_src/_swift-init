#compdef swift-init
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/common/manager.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a servers=(
  'all:all swift services'
  'main:main swift services (proxy, account, container, object servers)'
  'rest:remaining swift services (auditor/replicator/updater/reaper)'
  'proxy-server:proxy service'
  'account-server:account server'
  'account-auditor:account auditor'
  'account-reaper:account reaper'
  'account-replicator:account replicator'
  'container-server:container server'
  'container-auditor:container auditor'
  'container-replicator:container replicator'
  'container-sharder:container sharder'
  'container-sync:container sync'
  'container-updater:container updater'
  'container-reconciler:container reconciler'
  'object-server:object server'
  'object-auditor:object auditor'
  'object-expirer:object expirer'
  'object-reconstructor:object reconstructor'
  'object-replicator:object replicator'
  'object-updater:object updater'
)
local -a actions=(
  'start:start services'
  'stop:stop services'
  'restart:restart services'
  'shutdown:graceful shutdown'
  'reload:reload services (SIGHUP)'
  'reload-seamless:reload without dropping connections'
  'force-reload:force reload'
  'no-daemon:start interactively'
  'no-wait:do not wait for processes to start'
  'once:run one pass'
  'status:show status'
  'kill:kill all known pids'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[display verbose output]' \
  '(-w --no-wait)'{-w,--no-wait}"[won't wait for server to start before returning]" \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '(-n --no-daemon)'{-n,--no-daemon}'[start server interactively]' \
  '(-g --graceful)'{-g,--graceful}'[send SIGHUP to supporting servers]' \
  '(-c --config-num)'{-c+,--config-num=}'[send command to the Nth server only]:N:' \
  '(-k --kill-wait)'{-k+,--kill-wait=}'[wait N seconds for processes to die (default 15)]:N:' \
  '(-r --run-dir)'{-r+,--run-dir=}'[directory where the pids will be stored]:dir:_files -/' \
  '--strict[return non-zero status code if some config is missing]' \
  '--non-strict[return zero status code even if some config is missing]' \
  '--kill-after-timeout[kill daemon and all children after kill-wait period]' \
  '*:: :->args' && ret=0

case $state in
  args)
    # Last positional is the command; everything before is server(s).
    if (( CURRENT == ${#line[@]} )); then
      _describe -t actions 'swift-init command' actions && ret=0
    fi
    _describe -t servers 'swift-init server' servers && ret=0
    ;;
esac
return ret
