#compdef openapi-changes
# Documentation: https://pb33f.io/openapi-changes/command-arguments/
# Detect breaking changes between OpenAPI specs over time (pb33f)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --base)'{-p,--base}'=[base URL or working directory for relative/remote references]:base' \
  '--base-commit=[commit to compare against when walking history]:commit' \
  '(-c --config)'{-c,--config}'=[path to a breaking-rules config file]:file:_files' \
  '--ext-refs[resolve $ref values inside extension (x-) objects]' \
  '(-R --global-revisions)'{-R,--global-revisions}'[consider all revisions in the limit window]' \
  '(-l --limit)'{-l,--limit}'=[limit the number of revisions inspected]:count' \
  '(-d --limit-time)'{-d,--limit-time}'=[limit history by days instead of revision count]:days' \
  '(-b --no-logo)'{-b,--no-logo}'[skip the startup banner]' \
  '(-r --remote)'{-r,--remote}'[allow remote references to resolve without --base]' \
  '(-t --top)'{-t,--top}'[only compare the latest revision against HEAD]' \
  '(-n --no-color)'{-n,--no-color}'[use the light Roger monochrome terminal theme]' \
  '--roger-mode[alias for --no-color]' \
  '--tektronix[use the Tektronix green monochrome terminal theme]' \
  '1:command:(console summary report markdown-report html-report completion version)' \
  '*:spec:_files' && ret=0

return ret
