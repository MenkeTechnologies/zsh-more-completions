#compdef verifybamid2 VerifyBamID2 VerifyBamID
# Documentation: https://github.com/Griffan/VerifyBamID
# estimate within- and between-ancestry DNA contamination

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--SVDPrefix=[SVD related files prefix]:prefix' \
  '--BamFile=[BAM or CRAM file for the sample]:file:_files' \
  '--Reference=[reference fasta file]:file:_files' \
  '--Seed=[random number seed]:seed' \
  '--NumPC=[number of principal components]:n' \
  '--NumThread=[number of threads]:n' \
  '--FixPC=[known PC coordinates PC1:PC2:PC3]:pcs' \
  '--FixAlpha=[known contamination level]:alpha' \
  '--WithinAncestry[enable within-ancestry assumption]' \
  '--KnownAF=[bed file with known allele frequencies]:file:_files' \
  '--Epsilon=[convergence threshold]:eps' \
  '--OutputPileup[output temporary pileup file]' \
  '--Verbose[print progress information]' \
  '--RefVCF=[reference panel VCF for auxiliary files]:file:_files' \
  '--no-orphans[skip anomalous read pairs]' \
  '--adjust-MQ=[mapping quality coefficient]:n' \
  '--max-depth=[maximum depth limit]:n' \
  '--incl-flags=[required flags filter]:flags' \
  '--excl-flags=[filter flags to skip]:flags' \
  '*:file:_files' && ret=0

return ret
