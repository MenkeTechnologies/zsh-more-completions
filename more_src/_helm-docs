#compdef helm-docs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --chart-search-root)'{-c,--chart-search-root}'[directory to search for charts]:directory:_files -/' \
  '(-d --dry-run)'{-d,--dry-run}'[dry run mode]' \
  '(-g --badge-style)'{-g,--badge-style}'[badge style for values]:style:(flat flat-square for-the-badge plastic)' \
  '(-l --log-level)'{-l,--log-level}'[log level]:level:(panic fatal error warning info debug trace)' \
  '(-o --output-file)'{-o,--output-file}'[output filename]:filename' \
  '(-s --sort-values-order)'{-s,--sort-values-order}'[order for values]:order:(alphanum file)' \
  '(-t --template-files)'{-t,--template-files}'[template files]:template files:_files' \
  '(-u --document-dependency-values)'{-u,--document-dependency-values}'[document dependency values]' \
  '--ignore-file=[file with patterns to ignore]:ignore file:_files' \
  '--values-file=[values file name]:filename' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' && ret=0

return ret
