#compdef unar

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-output-directory[directory to extract to]:dir:_directories' \
  '-force-overwrite[overwrite existing files]' \
  '-force-rename[rename extracted files if they already exist]' \
  '-force-skip[skip files that already exist]' \
  '-force-directory[always create a containing directory]' \
  '-no-directory[never create a containing directory]' \
  '-no-recursion[do not extract archives inside archives]' \
  '-copy-time[copy timestamps from archive to extracted files]' \
  '-password[password for encrypted archives]:password' \
  '-password-encoding[encoding for password]:encoding' \
  '-encoding[string encoding]:encoding' \
  '-indexes[only extract entries at these indexes]:indexes' \
  '-no-quarantine[do not set quarantine flag on extracted files]' \
  '-forks[handling of resource forks]:mode:(visible hidden skip)' \
  '-quiet[suppress output]' \
  '*:archive file:_files -g "*.{zip,rar,7z,tar,gz,bz2,xz,lzma,cab,msi,iso,deb,rpm,cpio,Z,lzh,arj,sit,hqx}"'
