#compdef unar
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/unar.1.html
# Reference accessed: 2026-05-21
# Verified: upstream unar(1) man page.
# Removed from prior file: -no-quarantine (not in man page).

_arguments \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  {-o,-output-directory}'[directory to extract to]:dir:_directories' \
  {-f,-force-overwrite}'[always overwrite existing files]' \
  {-r,-force-rename}'[always rename extracted files if they already exist]' \
  {-s,-force-skip}'[always skip files that already exist]' \
  {-d,-force-directory}'[always create a containing directory]' \
  {-D,-no-directory}'[never create a containing directory]' \
  {-nr,-no-recursion}'[do not extract archives inside archives]' \
  {-t,-copy-time}'[copy timestamps from archive to extracted files]' \
  {-p,-password}'[password for encrypted archives]:password' \
  {-E,-password-encoding}'[encoding for password]:encoding' \
  {-e,-encoding}'[string encoding for filenames]:encoding' \
  {-i,-indexes}'[specify files as indexes as output by lsar]' \
  {-k,-forks}'[handling of resource forks]:mode:(visible hidden skip)' \
  {-q,-quiet}'[run in quiet mode]' \
  '*:archive file:_files -g "*.(zip|rar|7z|tar|gz|bz2|xz|lzma|cab|msi|iso|deb|rpm|cpio|Z|lzh|arj|sit|hqx)"'
