#compdef nuspell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[use dictionary]:dictionary' \
  '-D[list search paths for dictionaries]' \
  '-l[print only misspelled words]' \
  '-G[accept words also from personal dictionary]' \
  '-s[print suggestions for misspelled words]' \
  '-S[use stdin for input]' \
  '*:file:_files' && ret=0

return ret
