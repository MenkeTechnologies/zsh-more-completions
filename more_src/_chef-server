#compdef chef-server-ctl chef-server-fe-ctl chef-server-be-ctl
# _chef-server — Progress Chef chef-server-ctl admin command for the Chef Infra Server (omnibus chef team, Ruby); custom argparse
# upstream: https://github.com/chef/chef-server

_chef-server() {
    local -a sub=(
        'install:install an addon'
        'reconfigure:run chef-solo reconfiguration'
        'show-config:show current config'
        'upgrade:upgrade major version'
        'cleanup:cleanup unused data'
        'cleanse:cleanse server'
        'service-list:list services'
        'status:show service status'
        'start:start services'
        'stop:stop services'
        'restart:restart services'
        'reload:reload services'
        'hup:hup services'
        'int:int services'
        'kill:kill services'
        'once:run services once'
        'tail:tail logs'
        'graceful-kill:graceful kill'
        'help:show help'
        'user-list:list users'
        'user-create:create a user'
        'user-edit:edit a user'
        'user-show:show user info'
        'user-delete:delete a user'
        'org-list:list organizations'
        'org-create:create an organization'
        'org-show:show organization info'
        'org-delete:delete an organization'
        'org-user-add:add user to org'
        'org-user-remove:remove user from org'
        'org-association-request:create org association'
        'org-association-accept:accept org association'
        'org-association-reject:reject org association'
        'backup:create backup'
        'restore:restore from backup'
        'set-secret:set secret'
        'remove-secret:remove secret'
        'show-secret:show secret'
        'reindex:reindex search index'
        'gather-logs:gather support logs'
        'add-server-admin-permissions:add admin permissions'
        'remove-server-admin-permissions:remove admin permissions'
        'grant-server-admin-permissions:grant admin permissions'
        'list-server-admins:list server admins'
        'password:reset password'
        'rename-org:rename an org'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-y[assume yes]' \
        '--yes[assume yes]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'chef-server subcommand' sub ;;
        args)
            case $words[1] in
                user-show|user-edit|user-delete|password) _arguments '1:username:_users' ;;
                org-show|org-delete|rename-org) _arguments '1:org:' ;;
                org-user-add|org-user-remove) _arguments '1:org:' '2:user:_users' ;;
                backup|restore) _arguments \
                    '-d+[dir]:dir:_files -/' \
                    '--dir=+[dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_chef-server "$@"
