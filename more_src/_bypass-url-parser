#compdef bypass-url-parser
# Documentation: https://github.com/laluka/bypass-url-parser
# test many 40X bypasses against a protected URL

local ret=1

_arguments -s -S \
  '(-u --url)'{-u,--url}'[target URL]:url' \
  '(-R --request)'{-R,--request}'[load HTTP raw request from file]:request file:_files' \
  '*'{-H,--header}'[add custom header]:header' \
  '(-m --mode)'{-m,--mode}'[select specific bypass modes]:mode' \
  '(-s --spoofip)'{-s,--spoofip}'[inject IP addresses into headers]:ip' \
  '(-p --spoofport)'{-p,--spoofport}'[inject ports into headers]:port' \
  '(-x --proxy)'{-x,--proxy}'[set HTTP proxy]:proxy' \
  '(-t --threads)'{-t,--threads}'[parallel threads]:threads' \
  '(-T --timeout)'{-T,--timeout}'[request timeout in seconds]:timeout' \
  '(-r --retry)'{-r,--retry}'[retry attempts]:retry' \
  '(-o --outdir)'{-o,--outdir}'[custom output directory]:outdir:_files -/' \
  '(-S --save-level)'{-S,--save-level}'[save results level (0-3)]:level:(0 1 2 3)' \
  '--jsonl[JSON Lines output format]' \
  '--dump-payloads[print all generated payloads]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[show curl commands]' \
  '--request-tls[force HTTPS for request file]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
