#compdef console-ncurses-realizer console-terminal-emulator
# Documentation: source-direct extraction from upstream jdebp/nosh
# source/console-{ncurses-realizer,terminal-emulator}.cpp
# `popt::bool_definition <var>_option('\0', "<long>", "<help>",
# <var>)` declarations.  Both binaries use jdebp's popt-style
# argument-processor framework (a C++ wrapper around the libpopt
# C library) with no short-form aliases - all flags are long-only.
# Reference accessed: 2026-05-30 via gh api.
# jdebp/nosh console framework R132b — 2-stem multi-binary harvest
# of the nosh console-realizer + terminal-emulator pair. Together
# these form the nosh user-mode console framework, an alternative
# to the kernel virtual-terminal driver: console-terminal-emulator
# parses ECMA-48 escape sequences from a child program into a
# memory buffer, and console-ncurses-realizer renders that buffer
# to a curses display in an existing terminal window.

case $service in

  console-ncurses-realizer)
    # Render a nosh console-terminal-emulator memory buffer onto
    # an ncurses display in the current terminal. Used to view
    # the state of a headless console as if it had a screen
    # attached.
    _arguments -s -S \
      '--wrong-way-up[display the buffer from bottom to top]' \
      '--display-only[render only; do NOT forward keyboard input]'
    ;;

  console-terminal-emulator)
    # Run a child program with stdin/stdout connected to a memory-
    # backed terminal emulator. Parses ECMA-48 escape sequences
    # from the child into a memory buffer that other tools (like
    # console-ncurses-realizer) can render.
    _arguments -s -S \
      '--vcsa[maintain a Linux vcsa-compatible (raw fb) display buffer]' \
      '--inverted[begin in inverted video mode (white-on-black inverted)]' \
      '*:program and arguments:_command_names -e'
    ;;

esac
