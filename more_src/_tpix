#compdef tpix
# Documentation: https://github.com/jesvedberg/tpix
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-b --background)'{-b,--background}'[add white background if image is transparent]' \
  '(-p --printname)'{-p,--printname}'[print file name]' \
  '(-n --noresize)'{-n,--noresize}'[disable automatic resizing]' \
  '(-f --fullwidth)'{-f,--fullwidth}'[resize image to fill terminal width]' \
  '(-w --width)'{-w+,--width=}'[specify image width]:pixels' \
  '--height=[specify image height]:pixels' \
  '*:image file:_files'
