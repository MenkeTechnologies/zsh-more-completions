#compdef tpix
# Documentation: https://github.com/jesvedberg/tpix
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/jesvedberg/tpix — cligen (tpix.nim v1.0.3)
_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--background[add white background for transparency]' \
  '--printname[print file or stdin label]' \
  '--noresize[disable auto-resize to terminal width]' \
  '--fullwidth[scale to full terminal width]' \
  '--width=-[target width px]:pixels:' \
  '--height=-[target height px]:pixels:' \
  '*:image file:_files'
