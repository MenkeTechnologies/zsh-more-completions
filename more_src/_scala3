#compdef scala3
# Documentation: https://docs.scala-lang.org/scala3/reference/cli.html
# Reference accessed: 2026-05-16
# Verified: Scala 3.5.0+ uses scala-cli as the official runner.
# Removed from prior file: bogus man.archlinux.org search URL.

# scala3: Scala 3 launcher (scala-cli)
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'compile:compile your code (excluding tests)'
  'run:run your code with provided arguments'
  'test:compile and run tests'
  'package:package code into jar or other format'
  'repl:run interactive Scala shell'
  'console:run interactive Scala shell'
  'fmt:format your code'
  'new:create a new project from template'
  'doc:generate documentation'
  'version:show version'
  'setup-ide:set up IDE integration'
  'shebang:run shebang-style script'
  'publish:publish to a Maven repository'
  'fix:apply scalafix rules'
  'export:export to sbt/Mill/etc'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-new-syntax[use Scala 3 indentation syntax]' \
  '-old-syntax[use Scala 2 brace syntax]' \
  '-indent[allow indentation as block delimiter]' \
  '-no-indent[disable indentation as block delimiter]' \
  '-rewrite[rewrite source on compile]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'scala3 command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
