#compdef mafFilter
# UCSC kent: filter out maf files based on several criteria

local ret=1

_arguments -s -S \
  '-tolerate[just ignore bad input rather than aborting]' \
  '-minCol=[filter out blocks with fewer than N columns (default 1)]:n' \
  '-minRow=[filter out blocks with fewer than N rows (default 2)]:n' \
  '-maxRow=[filter out blocks with >= N rows (default 100)]:n' \
  '-factor[filter out scores below -minFactor * (ncol**2) * nrow]' \
  '-minFactor=[factor to use with -factor (default 5)]:n' \
  '-minScore=[minimum allowed score (alternative to -minFactor)]:n' \
  '-reject=[save rejected blocks in filename]:file:_files' \
  '-needComp=[all alignments must have species as one component]:species' \
  '-overlap[reject overlapping blocks in reference]' \
  '-componentFilter=[filter out blocks without a component in filename]:file:_files' \
  '-speciesFilter=[filter out blocks without a species in filename]:file:_files' \
  '*:maf file:_files -g "*.maf"' && ret=0

return ret
