#compdef CrossResampling
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/jlinda/jlinda-nest/src/main/java/org/jlinda/nest/gpf/CrossResamplingOp.java
# ESA SNAP gpt CrossResampling operator - resample between ERS and Envisat ASAR geometries

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PwarpPolynomialOrder=[order of polynomial function]:order:(1 2 3)' \
  '-PinterpolationMethod=[interpolation method]:method:(CC4P CC6P TS6P TS8P TS16P)' \
  '-PtargetGeometry=[target geometry]:geometry:(ERS Envisat\ ASAR)' \
  '*:graph xml:_files' && ret=0

return ret
