#compdef cypress-cli
# _cypress-cli — Cypress.io end-to-end web testing framework CLI alias (Cypress.io, TypeScript); commander
# upstream: https://github.com/cypress-io/cypress

_cypress-cli() {
    local -a sub=(
        'cache:cache commands'
        'help:show help'
        'info:show install info'
        'install:install Cypress binary'
        'open:open Cypress test runner'
        'run:run tests'
        'verify:verify Cypress'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cypress subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--browser=+[browser]:b:(chrome chromium edge electron firefox webkit)' \
                    '-b+[browser]:b:(chrome chromium edge electron firefox webkit)' \
                    '--ci-build-id=+[ci build id]:str:' \
                    '--component[component testing]' \
                    '--config=+[config]:str:' \
                    '-c+[config]:str:' \
                    '--config-file=+[config file]:file:_files -g "cypress.config.*"' \
                    '-C+[config file]:file:_files -g "cypress.config.*"' \
                    '--e2e[e2e testing]' \
                    '--env=+[env vars]:str:' \
                    '-e+[env vars]:str:' \
                    '--exit[exit after run]' \
                    '--group=+[group]:str:' \
                    '--headed[headed]' \
                    '--headless[headless]' \
                    '--inspect-brk=+[node inspect-brk]:str:' \
                    '--key=+[record key]:str:' \
                    '-k+[record key]:str:' \
                    '--no-exit[no exit after run]' \
                    '--no-runner-ui[no runner UI]' \
                    '--parallel[parallel]' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--project=+[project path]:dir:_files -/' \
                    '-P+[project path]:dir:_files -/' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--record[record results]' \
                    '--reporter=+[reporter]:str:' \
                    '-r+[reporter]:str:' \
                    '--reporter-options=+[reporter options]:str:' \
                    '-o+[reporter options]:str:' \
                    '--runner-ui[runner UI]' \
                    '--spec=+[spec files]:list:_files' \
                    '-s+[spec files]:list:_files' \
                    '--tag=+[tag]:list:' \
                    '-t+[tag]:list:' \
                    '--auto-cancel-after-failures=+[auto cancel after failures]:n:' ;;
                open) _arguments \
                    '--browser=+[browser]:b:(chrome chromium edge electron firefox webkit)' \
                    '-b+[browser]:b:(chrome chromium edge electron firefox webkit)' \
                    '--component[component testing]' \
                    '--config=+[config]:str:' \
                    '-c+[config]:str:' \
                    '--config-file=+[config file]:file:_files' \
                    '-C+[config file]:file:_files' \
                    '--detached[detached]' \
                    '-d[detached]' \
                    '--e2e[e2e testing]' \
                    '--env=+[env vars]:str:' \
                    '-e+[env vars]:str:' \
                    '--global[global]' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--project=+[project path]:dir:_files -/' \
                    '-P+[project path]:dir:_files -/' ;;
                cache) _arguments \
                    '1:cmd:(clear list path prune)' \
                    '*:arg:' ;;
                install) _arguments \
                    '--force[force]' \
                    '-f[force]' ;;
                verify) _arguments '--dev[dev mode]' ;;
                info) _arguments '--dev[dev mode]' ;;
            esac
            ;;
    esac
}

_cypress-cli "$@"
