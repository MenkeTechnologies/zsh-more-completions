#compdef cilium-operator-aws
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-operator-aws/
# Cilium operator for AWS ENI IPAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for cilium-operator-aws]' \
  '(-D --debug)'{-D,--debug}'[enable debugging mode]' \
  '--version[print version information]' \
  '--config=[configuration file]:config:_files' \
  '--config-dir=[configuration directory]:dir:_files -/' \
  '--ipam=[backend to use for IPAM]:backend' \
  '--aws-enable-prefix-delegation[allocate prefixes to ENIs instead of individual IPs]' \
  '--aws-max-results-per-call=[maximum results per AWS API call]:n' \
  '--aws-release-excess-ips[enable releasing excess free IPs from ENI]' \
  '--aws-use-primary-address[use primary ENI address for allocations]' \
  '--ec2-api-endpoint=[AWS EC2 service endpoint]:endpoint' \
  '--eni-gc-interval=[garbage collection interval for unattached ENIs]:interval' \
  '--eni-tags=[tags for ENIs created by Cilium]:tags' \
  '--excess-ip-release-delay=[seconds before releasing excess IPs]:seconds' \
  '--instance-tags-filter=[EC2 instance tags filter]:filter' \
  '--subnet-ids-filter=[subnet IDs filter]:ids' \
  '--subnet-tags-filter=[subnet tags filter]:tags' \
  '--cluster-id=[unique identifier of the cluster]:id' \
  '--cluster-name=[name of the cluster]:name' \
  '--limit-ipam-api-burst=[external API burst limit]:n' \
  '--limit-ipam-api-qps=[external IPAM API queries per second]:n' \
  '--parallel-alloc-workers=[maximum number of parallel IPAM workers]:n' \
  '--enable-ipv4[enable IPv4 support]' \
  '--enable-ipv6[enable IPv6 support]' \
  '--enable-metrics[enable Prometheus metrics]' \
  '--k8s-kubeconfig-path=[absolute path of the kubernetes kubeconfig file]:path:_files' \
  '--k8s-namespace=[namespace in which Cilium Operator is deployed]:namespace' \
  '--operator-prometheus-serve-addr=[address to serve Prometheus metrics]:addr' \
  '--skip-crd-creation[do not create Kubernetes Custom Resource Definitions]' \
  '*::arg:_default' && ret=0

return ret
