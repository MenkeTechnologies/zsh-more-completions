_componentize-js() {
    local -a wasi_features=(stdio random clocks http fetch-event)

    _arguments -s -S \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-w --wit)'{-w,--wit}'=[WIT path to build with (required; .wit file or directory containing .wit files)]:path:_files -g "*.wit" -/' \
        '(-o --out)'{-o,--out}'=[output component file (required)]:path:_files -g "*.wasm"' \
        '(-n --world-name)'{-n,--world-name}'=[WIT world name to build (if .wit has multiple worlds)]:name:' \
        '--runtime-args=[arguments to pass to the SpiderMonkey runtime]:args:' \
        '--aot[enable weval AOT compilation (longer build, much faster runtime startup + steady-state)]' \
        '--engine=[provide a custom ComponentizeJS engine build path (.wasm)]:path:_files -g "*.wasm"' \
        '*-d=[disable a WASI feature in the produced component]:feature:($wasi_features)' \
        '*--disable=[disable a WASI feature (stdio / random / clocks / http / fetch-event; repeat for multiple)]:feature:($wasi_features)' \
        '--preview2-adapter=[provide a custom preview2 adapter path (.wasm)]:path:_files -g "*.wasm"' \
        '--use-debug-build[use a debug build of StarlingMonkey (the SpiderMonkey-on-Wasm distribution)]' \
        '--debug-bindings[enable debug logging for jco bindings generation]' \
        '--enable-wizer-logging[enable debug logging for calls in the generated component]' \
        '--wizer-bin=[specify a path to a local wizer binary (instead of the bundled @bytecodealliance/wizer)]:path:_files' \
        '--weval-bin=[specify a path to a local weval binary (instead of the bundled @bytecodealliance/weval)]:path:_files' \
        '--aot-cache-dir=[specify a custom AOT weval cache directory]:path:_files -/' \
        '--aot-min-stack-size=[set the minimum stack size (RUST_MIN_STACK) for weval AOT compilation]:bytes:' \
        '1:JS source file to build:_files -g "*.(js|mjs|cjs|ts)"'
}

_componentize-js "$@"
