#compdef trufflehog

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::arg:->args' \
  && ret=0

case $state in
  command)
    local -a commands=(
      'git:scan git repositories'
      'github:scan GitHub repositories'
      'gitlab:scan GitLab repositories'
      's3:scan S3 buckets'
      'filesystem:scan the filesystem'
      'syslog:scan syslog'
      'circleci:scan CircleCI'
      'docker:scan Docker images'
      'travisci:scan Travis CI'
      'gcs:scan Google Cloud Storage'
      'postman:scan Postman'
      'jenkins:scan Jenkins'
      'elasticsearch:scan Elasticsearch'
      'huggingface:scan Hugging Face'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      git)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--json[output as JSON]' \
          '--json-legacy[output in legacy JSON format]' \
          '--concurrency[number of concurrent workers]:workers' \
          '--no-verification[disable credential verification]' \
          '--only-verified[only report verified results]' \
          '--results[output format]:format:(json plain)' \
          '--filter-unverified[filter unverified results]' \
          '--filter-entropy[filter by entropy]:threshold' \
          '--since-commit[scan from this commit]:commit' \
          '--branch[scan specific branch]:branch' \
          '--max-depth[max commit depth]:depth' \
          '--include-paths[file with include path patterns]:file:_files' \
          '--exclude-paths[file with exclude path patterns]:file:_files' \
          '--exclude-detectors[detectors to exclude]:detectors' \
          '--fail[exit with code 183 if results are found]' \
          '--no-update[disable version checking]' \
          '*:repository URI or path:_files' \
          && ret=0
        ;;
      github)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--json[output as JSON]' \
          '--concurrency[number of concurrent workers]:workers' \
          '--no-verification[disable credential verification]' \
          '--only-verified[only report verified results]' \
          '--token[GitHub token]:token' \
          '--endpoint[GitHub API endpoint]:endpoint' \
          '--repo[GitHub repo to scan]:repo' \
          '--org[GitHub org to scan]:org' \
          '--include-paths[file with include path patterns]:file:_files' \
          '--exclude-paths[file with exclude path patterns]:file:_files' \
          '--include-forks[include forked repos]' \
          '--include-members[include member repos]' \
          '--fail[exit with code 183 if results are found]' \
          && ret=0
        ;;
      filesystem)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--json[output as JSON]' \
          '--concurrency[number of concurrent workers]:workers' \
          '--no-verification[disable credential verification]' \
          '--only-verified[only report verified results]' \
          '--include-paths[file with include path patterns]:file:_files' \
          '--exclude-paths[file with exclude path patterns]:file:_files' \
          '--fail[exit with code 183 if results are found]' \
          '*:path:_files' \
          && ret=0
        ;;
      s3)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--json[output as JSON]' \
          '--concurrency[number of concurrent workers]:workers' \
          '--no-verification[disable credential verification]' \
          '--only-verified[only report verified results]' \
          '--bucket[S3 bucket to scan]:bucket' \
          '--fail[exit with code 183 if results are found]' \
          && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '--json[output as JSON]' \
          '--concurrency[number of concurrent workers]:workers' \
          '--no-verification[disable credential verification]' \
          '--only-verified[only report verified results]' \
          '--fail[exit with code 183 if results are found]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
