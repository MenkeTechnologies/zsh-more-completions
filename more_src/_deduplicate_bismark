#compdef deduplicate_bismark
# Documentation: https://github.com/FelixKrueger/Bismark/blob/master/deduplicate_bismark
# deduplicate_bismark: remove alignments to the same position from Bismark BAM/SAM files

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-s --single -p --paired)'{-s,--single}'[deduplicate single-end Bismark files]' \
  '(-p --paired -s --single)'{-p,--paired}'[deduplicate paired-end Bismark files]' \
  '(-o --outfile)'{-o+,--outfile=}'[basename of the output file]:basename:' \
  '--output_dir=[output directory]:dir:_files -/' \
  '(--barcode --umi)'{--barcode,--umi}'[consider a barcode/UMI while deduplicating]' \
  '--bclconvert[extract UMI from internal position as produced by bcl-convert]' \
  '(--bam --sam)--bam[write output in BAM format]' \
  '(--bam --sam)--sam[write output in SAM format]' \
  '--multiple[treat all input files as one sample and concatenate]' \
  '--samtools_path=[path to Samtools installation]:path:_files -/' \
  '*:Bismark file:_files' && ret=0

return ret
