#compdef agentswarm
# Documentation: https://github.com/VRSEN/agentswarm-cli
# Reference accessed: 2026-05-22
# Verified: @vrsen/agentswarm and agentswarm-cli bin/agentswarm launcher passthrough.

# Zsh completion for agentswarm - Agency Swarm terminal UI launcher

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:argument:' && ret=0

return ret
