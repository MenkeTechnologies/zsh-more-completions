#compdef angr

# angr: symbolic execution framework (Python; CLI wrapper)
# Documentation: https://docs.angr.io/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:Python script or binary:_files' && ret=0
return ret
