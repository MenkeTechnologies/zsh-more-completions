#compdef grads gradsc gradsdap gradsdods gradshdf grads-cli
# _grads — COLA Center for Ocean-Land-Atmosphere Studies GrADS Grid Analysis and Display System geophysical data plotting (cola team, C); custom argparse
# upstream: https://github.com/COLA-SVR/GrADS

_grads() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-b[batch mode no graphics]' \
        '-c+[startup command]:str:' \
        '-d[no DAP support]' \
        '-e[remote authentication]' \
        '-g+[geometry]:str:' \
        '-l[landscape orientation]' \
        '-p[portrait orientation]' \
        '-x[do not exit on error]' \
        '-u[ignore user defaults]' \
        '-H+[hardcopy file]:file:_files' \
        '-C[batch mode color]' \
        '-W+[window width]:n:' \
        '-S[silent mode]' \
        '-T[no title bar]' \
        '-X[force X11 display]' \
        '-display+[X display]:str:' \
        '-printenv[print environment]' \
        '-V+[verbose level]:n:' \
        '-fb+[buffer count]:n:' \
        '-bg+[background color]:color:' \
        '-fg+[foreground color]:color:' \
        '*:script file:_files -g "*.gs *.grads"'
}

_grads "$@"
