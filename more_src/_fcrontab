#compdef fcrontab
# Documentation: https://man.archlinux.org/man/fcrontab.1.en
# fcron: install, edit, list and remove a user's fcrontab

local ret=1

_arguments -s \
  '-u[specify the user whose fcrontab is managed]:user:_users' \
  '-l[list current fcrontab to standard output]' \
  '-e[edit the current fcrontab]' \
  '-r[remove user fcrontab]' \
  '-z[reset fcrontab, discarding daemon-stored metadata]' \
  '-n[ignore previous version, do not preserve execution history]' \
  '-c[use alternate config file]:file:_files' \
  '-d[activate debug mode]' \
  '-h[display a brief description of the options]' \
  '-V[display version and license information]' \
  '*:file:_files' && ret=0

return ret
