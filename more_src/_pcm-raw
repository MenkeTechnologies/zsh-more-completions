#compdef pcm-raw
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-raw.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-raw: Intel PCM raw event-based counter access tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-json[JSON output to stdout]' \
  '-json=-[JSON output to file]:file:_files' \
  '*-e[custom event to monitor (repeatable)]:event:' \
  '-el[file containing events]:file:_files' \
  '-out[write all output to file]:file:_files' \
  '-tab[use tab as separator instead of comma]' \
  '-l[use locale for printing values]' \
  '-tr[transpose output]' \
  '-ext[add headers to transposed output]' \
  '-single-header[merge transposed headers]' \
  '-s[print sample separator lines]' \
  '-f[flush each output line]' \
  '-pid[restrict to PID]:pid:' \
  '-yc[enable specific cores]' \
  '--yescores[enable specific cores]' \
  '-i=-[number of iterations]:n:' \
  '-r[reset PMU configuration]' \
  '--reset[reset PMU configuration]' \
  '-v[verbose mode]' \
  '-edp[edp output mode]' \
  '-ep[event list directory path]:dir:_files -/' \
  '*::pcm-raw args:_files' && ret=0
return ret
