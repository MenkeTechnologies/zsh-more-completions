#compdef goverlay
# Documentation: https://man.archlinux.org/search?q=goverlay
# Reference accessed: 2026-05-16

# Zsh completion for goverlay - graphical MangoHud/vkBasalt/ReplaySorcery configurator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
