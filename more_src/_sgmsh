#compdef sgmsh
# _sgmsh — Schroedinger Squid Grid Mesh shell helper (interactive shell over Squid Grid mesh APIs used by the chaos cluster team; -h help, -V version, -s server, -u user, -p password, -c run command then exit, -l log file, -v verbose; once inside: show, list, exec, ping, status, halt, reboot per node/group)
# upstream: distro-shipped (squid-grid-mesh)
# Common flag shape from chaos/sgmsh wrapper on tip.

_sgmsh() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-s+[server]:host:_hosts' \
        '-u+[user]:user:_users' \
        '-p+[password]:password:' \
        '-c+[command]:command:' \
        '-l+[log file]:file:_files' \
        '-v[verbose]' \
        '*::command:'
}

_sgmsh "$@"
