#compdef flashpca
# Documentation: https://github.com/gabraham/flashpca
# flashpca: fast principal component analysis of genotype data

local ret=1

_arguments -s -S \
  '--bfile=[input PLINK dataset]:prefix:_files' \
  '--ndim=[number of dimensions to compute]:num' \
  '--numthreads=[parallel processing threads]:num' \
  '--seed=[random seed]:num' \
  '--suffix=[custom suffix for output files]:suffix' \
  '--outpc=[principal components output]:file:_files' \
  '--outvec=[eigenvectors output]:file:_files' \
  '--outval=[eigenvalues output]:file:_files' \
  '--outpve=[proportion variance explained output]:file:_files' \
  '--outload=[SNP loadings output]:file:_files' \
  '--outmeansd=[means and standard deviations output]:file:_files' \
  '--outproj=[projections output]:file:_files' \
  '--stand=[standardization option]:method' \
  '--div=[divisor]:val' \
  '--project[project new samples]' \
  '--inmeansd=[input means/SDs file]:file:_files' \
  '--inload=[input loadings file]:file:_files' \
  '--mem=[memory limit]:val' \
  '--check[verify decomposition accuracy]' \
  '(-v --verbose)'{-v,--verbose}'[detailed output]' \
  '--help[display options]' \
  '*:file:_files' && ret=0

return ret
