#compdef git-secret

local curcontext="$curcontext" state line ret=1

_git-secret_commands() {
  local -a commands=(
    'init:Initialize git-secret in a repository'
    'tell:Add a person to the list of authorized users'
    'add:Add a file to the secret list'
    'hide:Encrypt all added files'
    'reveal:Decrypt all hidden files'
    'remove:Remove a file from the secret list'
    'list:List all added files'
    'clean:Remove all encrypted files'
    'whoknows:List authorized users'
    'changes:Show changes between hidden and revealed files'
    'cat:Decrypt and print a file to stdout'
  )
  _describe -t commands 'git-secret command' commands
}

_arguments -s -S -C \
  '1:command:_git-secret_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      tell)
        _arguments -s -S \
          '-m[add email to authorized list]:email' \
          '-d[specify GPG home directory]:directory:_directories' \
          '*:public key file:_files' && ret=0
        ;;
      add)
        _arguments -s -S \
          '-f[force add]' \
          '*:file:_files' && ret=0
        ;;
      hide)
        _arguments -s -S \
          '-d[specify GPG home directory]:directory:_directories' \
          '-m[clean removed files]' && ret=0
        ;;
      reveal)
        _arguments -s -S \
          '-d[specify GPG home directory]:directory:_directories' \
          '-p[specify password]:password' \
          '-f[force overwrite]' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '-c[also clean encrypted file]' \
          '*:file:_files' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-l[list all files]' && ret=0
        ;;
      whoknows)
        _arguments -s -S \
          '-l[show email only]' && ret=0
        ;;
      changes)
        _arguments -s -S \
          '-d[specify GPG home directory]:directory:_directories' \
          '-p[specify password]:password' \
          '*:file:_files' && ret=0
        ;;
      cat)
        _arguments -s -S \
          '-d[specify GPG home directory]:directory:_directories' \
          '-p[specify password]:password' \
          '*:file:_files' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '-v[verbose mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
