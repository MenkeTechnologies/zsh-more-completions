#compdef acpibin
# Documentation: acpibin
# Source: acpica/acpica source/tools/acpibin/abmain.c (master) — AML binary file utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[compare AML files (dump all mismatches)]:file1 file2:_files -g "*.aml"' \
    '-c+[compare AML files (first 100 mismatches)]:file1 file2:_files -g "*.aml"' \
    '-d+[dump AML binary to text]:in out:_files -g "*.aml"' \
    '-o+[start comparison at offset]:offset:_default' \
    '-h+[show table header for AML file]:file:_files -g "*.aml"' \
    '-s+[update checksum for AML file]:file:_files -g "*.aml"' \
    '-t[terse mode]' \
    '(-v -vd)-v[show version]' \
    '(-v -vd)-vd[show build date]' \
    '*::file:_files -g "*.aml"' \
    && ret=0

return ret
