#compdef megadl
# megadl — download files and folders from MEGA.nz

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--path=[local download path]:download path:_files -/' \
  '--no-progress[disable progress indicator]' \
  '--print-names[print downloaded file names]' \
  '--choose-files[interactively choose which files to download]' \
  '--limit-speed=[limit download speed]:speed:' \
  '--proxy=[proxy URL]:proxy URL:' \
  '--netif=[network interface to use]:interface:_net_interfaces' \
  '--ip-proto=[IP protocol version]:protocol:(v4 v6)' \
  '--config=[load configuration from a file]:config file:_files' \
  '--ignore-config-file[do not load configuration file]' \
  '--debug=[enable debugging output]:debug flags:' \
  '(- *)--version[show version]' \
  '--reload[reload filesystem cache]' \
  '--no-ask-password[never ask interactively for a password]' \
  '--disable-previews[do not generate previews on upload]' \
  '*:MEGA URL:' && ret=0

return ret
