#compdef gout
# Documentation: https://www.systutorials.com/docs/linux/man/1-scotch_gout/
# Scotch: output Scotch graphs and mappings to display/visualization formats

local ret=1

_arguments -s \
  '-h[display help]' \
  '-mn[do not read mapping data]' \
  '-g-[set geometry parameters (n,p,r modifiers)]:geometry' \
  '-o-[select output file type (i,m,p,t and modifiers)]:output type' \
  '-V[display version and copyright]' \
  '*:file:_files' && ret=0

return ret
