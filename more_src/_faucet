#compdef faucet
# ---------------------------------------------------------------------------
# faucet — turn any SQL database into a secure governed REST API with
#          RBAC and native MCP server for AI agents (Go, 96★)
#
# upstream: https://github.com/faucetdb/faucet
# project: faucetdb (faucetdb.io)
# license: Apache-2.0
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from cmd/faucet/cli/*.go on the faucet tip — root.go AddCommand tree +
# serve.go / db.go / key.go / role.go / admin.go / mcp.go / benchmark.go /
# config_cmd.go / openapi.go / status.go / stop.go / version.go.
#
# Direct deps from go.mod (selected):
#   github.com/jmoiron/sqlx                 ← canonical Go SQL toolkit
#                                             (this axis) for stdlib database/sql
#                                             extension with named params +
#                                             struct scanning
#   github.com/spf13/cobra + viper          (CLI + config with FAUCET_* env prefix)
#
# === AXIS 160 CONTINUES — async SQL toolkit ecosystem ===
# Axis position: Go=215 continues Axis 160 (slot 2/0/0).  Canonical Go SQL
# toolkit is `jmoiron/sqlx` by Jason Moiron — the de facto standard for
# stdlib `database/sql` extension in production Go code.  Beautiful name
# parallel: Rust `sqlx` (Ryan Leckey, async + compile-time) ↔ Go `sqlx`
# (Jason Moiron, sync + struct-scanning).  Powers Mattermost, gitea,
# gocraft/dbr, the daptin headless CMS, and innumerable Go web services.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=215   _rdap-srv            ← previous round (axis 160 OPENS at 1/0/0)
#   Go=215     ← THIS FILE          (axis 160 continues, slot 2/0/0)
#   TS-Node=215 ← next round        (axis 160 CLOSES at triple-215, slot 1/1/1)
# ---------------------------------------------------------------------------

_faucet() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'serve:start the faucet HTTP server'
        'stop:stop the daemonized faucet server'
        'status:show daemon status'
        'version:show faucet version'
        'db:manage databases (add/list/remove/test/schema/lock/unlock/diff/promote)'
        'key:manage API keys (create/list/revoke)'
        'role:manage RBAC roles (list/create)'
        'admin:manage admin users (create/list)'
        'openapi:emit OpenAPI 3 spec for the generated REST surface'
        'mcp:start the Model Context Protocol server (stdio or http)'
        'benchmark:benchmark database performance'
        'config:manage config (init/show/set/get)'
        'help:help about a subcommand'
    )

    _arguments -C \
        '--config=[config file (default ./faucet.yaml)]:file:_files -g "*.(yaml|yml)"' \
        '--data-dir=[data directory for SQLite config (default ~/.faucet)]:dir:_files -/' \
        '(- *)'{-h,--help}'[help for faucet]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'faucet command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                serve)
                    _arguments \
                        '(-p --port)'{-p,--port=}'[HTTP listen port (default 8080)]:port:_ports' \
                        '--host=[HTTP listen host (default 0.0.0.0)]:host:_hosts' \
                        '--no-ui[disable the admin UI]' \
                        '--dev[enable development mode (verbose logging, CORS *)]' \
                        '--foreground[run in foreground (Docker, systemd, etc.)]' \
                        '(-h --help)'{-h,--help}'[help for serve]' && ret=0
                    ;;
                db)
                    local -a dbcmds
                    dbcmds=(
                        'add:add a database service'
                        'list:list configured databases'
                        'remove:remove a database service by name'
                        'test:test a database connection'
                        'schema:introspect and show the schema'
                        'lock:lock the schema (block migrations)'
                        'unlock:unlock the schema'
                        'diff:diff the current schema against the cached one'
                        'promote:promote a draft schema to live'
                    )
                    _describe -t commands 'faucet db command' dbcmds && ret=0
                    ;;
                key)
                    local -a kcmds
                    kcmds=(
                        'create:create an API key (--role required, --label optional)'
                        'list:list keys (--json)'
                        'revoke:revoke an API key by prefix'
                    )
                    _describe -t commands 'faucet key command' kcmds && ret=0
                    ;;
                role)
                    local -a rcmds
                    rcmds=(
                        'list:list roles (--json)'
                        'create:create a role (--name required, --description optional)'
                    )
                    _describe -t commands 'faucet role command' rcmds && ret=0
                    ;;
                admin)
                    local -a acmds
                    acmds=(
                        'create:create an admin user (--email required, --password prompted)'
                        'list:list admin users (--json)'
                    )
                    _describe -t commands 'faucet admin command' acmds && ret=0
                    ;;
                config)
                    local -a ccmds
                    ccmds=(
                        'init:create a faucet.yaml config (--force to overwrite)'
                        'show:show the effective configuration'
                        'set:set a config key to a value'
                        'get:get a config key'
                    )
                    _describe -t commands 'faucet config command' ccmds && ret=0
                    ;;
                mcp)
                    _arguments \
                        '--transport=[MCP transport mode (default stdio)]:transport:(stdio http)' \
                        '--port=[HTTP port (only with --transport http, default 3001)]:port:_ports' && ret=0
                    ;;
                benchmark)
                    _arguments \
                        '--driver=[database driver]:driver:(postgres mysql mssql oracle snowflake sqlite)' \
                        '--dsn=[connection string (required)]:dsn:' \
                        '--duration=[test duration (default 30s)]:duration:' \
                        '--concurrency=[number of concurrent workers (default 10)]:n:' \
                        '--table=[table to query (auto-detected if omitted)]:table:' && ret=0
                    ;;
                stop|status|version|openapi)
                    _arguments \
                        '(-h --help)'{-h,--help}'[help for command]' && ret=0
                    ;;
                help)
                    _describe -t commands 'faucet command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_faucet "$@"
