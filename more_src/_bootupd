#compdef bootupd bootupctl
# _bootupd — coreos/bootupd (managed BIOS+EFI bootloader updater for ostree/Silverblue/Fedora CoreOS; bootupctl is the user-facing client; subcommands: status, update, adopt-and-update, validate, install; --component selects bios|efi, --json output, --user-mode bypass system check)
# upstream: https://github.com/coreos/bootupd
# Subcommands from bootupd src/bin/bootupctl.rs on tip.

_bootupd() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--json[json output]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'bootupd command' '(status update adopt-and-update validate install backend)' ;;
        args)
            case $line[1] in
                status) _arguments '--print-if-available[print if available]' ;;
                update|adopt-and-update|validate) _arguments '--component+[component]:component:(BIOS EFI)' ;;
                install) _arguments \
                    '--auto[detect components automatically]' \
                    '--src-root+[source root]:dir:_files -/' \
                    '--device+[device]:device:_files -g "/dev/*"' \
                    '--target-root+[target root]:dir:_files -/' ;;
                backend) _describe -t commands 'backend subcommand' '(status install update generate-update-metadata)' ;;
            esac
            ;;
    esac
}

_bootupd "$@"
