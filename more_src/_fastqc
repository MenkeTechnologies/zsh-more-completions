#compdef fastqc
# Documentation: https://man.archlinux.org/search?q=fastqc
# Reference accessed: 2026-05-16

# FastQC: quality control reports for raw NGS reads
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --outdir)'{-o,--outdir=}'[output directory]:dir:_files -/' \
  '--casava[CASAVA pre-processing]' \
  '--nano[Nanopore long-read mode]' \
  '--nofilter[do not filter reads]' \
  '--extract[extract zip file output]' \
  '--noextract[do not extract zip output]' \
  '--nogroup[do not group bases for plots > 50bp]' \
  '--min_length=[minimum read length]:n:' \
  '(-f --format)'{-f,--format=}'[force input format]:fmt:(bam sam bam_mapped sam_mapped fastq fastq.gz fq.gz)' \
  '(-t --threads)'{-t,--threads=}'[threads]:n:' \
  '(-c --contaminants)'{-c,--contaminants=}'[contaminant file]:file:_files' \
  '(-a --adapters)'{-a,--adapters=}'[adapter file]:file:_files' \
  '(-l --limits)'{-l,--limits=}'[limits file]:file:_files' \
  '(-k --kmers)'{-k,--kmers=}'[k-mer length 2-10]:n:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
  '(-d --dir)'{-d,--dir=}'[temp directory]:dir:_files -/' \
  '*:FASTQ/BAM file:_files -g "*.(fastq|fq|fastq.gz|fq.gz|bam|sam)"' && ret=0
return ret
