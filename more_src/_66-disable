#compdef 66-disable
# 66-disable — disable a 66 service (Obarun/s6)

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-t[set tree name]:tree name:' \
  '-F[force disable even if already disabled]' \
  '-S[also stop the service before disabling]' \
  '*:service name:'
