#compdef bit2fasm
# Documentation: https://github.com/SymbiFlow/prjxray/blob/master/utils/bit2fasm.py
# Project X-Ray: convert a 7-series bitstream to FASM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--db-root=[database root]:dir:_files -/' \
  '--bits-file=[output filename for bitread output]:file:_files' \
  '--part=[name of part being targetted]:part' \
  '--bitread=[bitread tool to use]:file:_files' \
  '--frame_range=[frame range to use with bitread]:range' \
  '--verbose[print lines for unknown tiles and bits]' \
  '--canonical[output canonical bitstream]' \
  '1:bit file:_files' && ret=0

return ret
