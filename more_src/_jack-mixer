#compdef jack-mixer jack_mixer
# Documentation: https://github.com/jack-mixer/jack_mixer
# Reference accessed: 2026-05-16
# Verified: jack-mixer/jack_mixer upstream + jack_mixer.1 manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -V/--version and -n/--name flags (no --version flag in
# upstream; client name is positional, not a flag); missing -d/--debug.

# jack-mixer: GTK volume mixer for JACK
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[load mixer project config]:file:_files -g "*.(xml|jmprj)(-.)"' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '1:JACK client name:' && ret=0
return ret
