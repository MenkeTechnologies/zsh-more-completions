#compdef sparse

# Zsh completion for sparse (Linux kernel semantic checker for C)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-W+[enable warning]:warning:(
    address-space bitwise cast-to-as cast-truncate context
    decl default-bitfield-sign designated-init do-while
    enum-mismatch external-function-has-definition init-cstring
    memcpy-max-count non-pointer-null old-initializer
    one-bit-signed-bitfield override-init override-init-all
    paren-string ptr-subtraction-blows return-void
    sizeof-bool sparse-all sparse-error
    tautological-compare transparent-union typesign undef
    unknown-attribute vla
  )' \
  '-Wno-+[disable warning]:warning' \
  '*-D+[define preprocessor macro]:macro definition' \
  '*-U+[undefine preprocessor macro]:macro name' \
  '*-I+[add include path]:directory:_files -/' \
  '-gcc-base-dir[GCC base directory]:directory:_files -/' \
  '-multiarch-dir[multiarch directory name]:directory' \
  '-arch[set target architecture]:architecture:(i386 x86_64 arm arm64 mips ppc ppc64 s390 s390x)' \
  '-m32[set 32-bit mode]' \
  '-m64[set 64-bit mode]' \
  '-v[increase verbosity]' \
  '-ventry[show function entry checks]' \
  '-vdead[show dead code paths]' \
  '-fmem-report[report memory usage]' \
  '-ftabstop[set tab size]:size' \
  '-nostdinc[do not search standard include directories]' \
  '-Wsparse-all[enable all sparse warnings]' \
  '-Wsparse-error[treat sparse warnings as errors]' \
  '*:C source file:_files -g "*.c(N)"' && ret=0

return ret
