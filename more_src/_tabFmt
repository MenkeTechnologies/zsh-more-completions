#compdef tabFmt
# UCSC kent: format a tab-separated file for human readability

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-right[right-justify]' \
  '-numRight[right-justify numeric appearing columns]' \
  '-passNoTab[pass through lines with no tabs]' \
  ':in file:_files' \
  '::out file:_files' && ret=0

return ret
