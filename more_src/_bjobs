#compdef bjobs
# Documentation: https://man.archlinux.org/search?q=bjobs
# Reference accessed: 2026-05-16

# bjobs: display LSF job info
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-a[all jobs (incl finished)]' \
  '-d[done jobs only]' \
  '-r[running only]' \
  '-s[suspended only]' \
  '-p[pending only]' \
  '-u[user]:user:_users' \
  '-q[queue]:queue:' \
  '-m[host]:host:_hosts' \
  '-w[wide format]' \
  '-l[long format]' \
  '-W[wall-clock format]' \
  '-A[array summary]' \
  '-G[group]:group:_groups' \
  '-J[job name]:name:' \
  '-N[email summary]' \
  '-X[expand wildcards]' \
  '-app[app profile]:app:' \
  '-P[project]:project:' \
  '-o[output fields]:fields:' \
  '-noheader[no header]' \
  '*:jobid:' && ret=0
return ret
