#compdef wsk

local curcontext="$curcontext" state line ret=1
local -a top

top=(
  'action:work with actions'
  'trigger:work with triggers'
  'rule:work with rules'
  'package:work with packages'
  'activation:work with activations'
  'namespace:work with namespaces'
  'api:work with APIs (API Gateway)'
  'list:list entities in the current namespace'
  'property:work with whisk properties'
  'sdk:work with the SDK'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --auth)'{-u,--auth=}'[authorization key]:key:' \
  '--apihost=[API host]:host:_hosts' \
  '--apiversion=[API version]:version:' \
  '(-i --insecure)'{-i,--insecure}'[bypass cert checking]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->op' \
  '*::arg:->args' && ret=0

case $state in
  (op)
    _describe -t top 'wsk command' top && ret=0
    ;;
  (args)
    case $line[1] in
      (action)
        _values 'action verb' \
          'create' 'update' 'invoke' 'get' 'delete' 'list' && ret=0
        ;;
      (trigger)
        _values 'trigger verb' \
          'fire' 'create' 'update' 'get' 'delete' 'list' && ret=0
        ;;
      (rule)
        _values 'rule verb' \
          'enable' 'disable' 'status' 'create' 'update' 'get' 'delete' 'list' && ret=0
        ;;
      (package)
        _values 'package verb' \
          'bind' 'create' 'update' 'get' 'delete' 'list' 'refresh' && ret=0
        ;;
      (activation)
        _values 'activation verb' \
          'list' 'get' 'logs' 'result' 'poll' && ret=0
        ;;
      (namespace)
        _values 'namespace verb' 'list' 'get' && ret=0
        ;;
      (api)
        _values 'api verb' \
          'create' 'get' 'list' 'delete' && ret=0
        ;;
      (property)
        _values 'property verb' 'set' 'unset' 'get' && ret=0
        ;;
      (sdk)
        _values 'sdk verb' 'install' && ret=0
        ;;
    esac
    ;;
esac

return ret
