#compdef uvplt
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvplt.html
# MIRIAD uvplt - plot visibility data

local ret=1

_arguments -s -S \
  'vis=[input visibility file(s)]:vis:_files' \
  'line=[line type channel selection]:line' \
  'select=[visibility selection criteria]:select' \
  'stokes=[Stokes/polarization selection]:stokes' \
  'axis=[x-axis,y-axis (time,amplitude,phase,uvdistance,...)]:axis' \
  'xrange=[plot range for x-axis]:xrange' \
  'yrange=[plot range for y-axis]:yrange' \
  'average=[time-averaging interval in minutes]:average' \
  'hann=[Hanning smoothing length (odd <15)]:hann' \
  'inc=[plot every INCth point]:inc' \
  'options=[nocal,nopol,nopass,nofqav,nobase,notitle,2pass,scalar,avall,unwrap,rms,mrms,noerr,all,flagged,nanosec,days,hours,seconds,xind,yind,equal,zero,symbols,nocolour,dots,source,inter,log]:options' \
  'nxy=[number of subplot rows and columns]:nxy' \
  'size=[PGPLOT character sizes]:size' \
  'device=[PGPLOT output device/type]:device' \
  'log=[output logfile name]:log:_files' \
  'subtitle=[second title line]:subtitle' \
  'comment=[one-line comment to logfile]:comment' \
  '*:visibility data:_files' && ret=0

return ret
