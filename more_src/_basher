#compdef basher

local -a subcommands
subcommands=(
  'commands:List available commands'
  'help:Show help for a command'
  'init:Configure shell environment'
  'install:Install a package'
  'uninstall:Uninstall a package'
  'link:Link a local directory as a package'
  'list:List installed packages'
  'outdated:Show outdated packages'
  'upgrade:Upgrade a package'
  'package-path:Show install path of a package'
  'include:Include a package library'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      install)
        _arguments \
          '(-f --force)'{-f,--force}'[Force install]' \
          '(-g --global)'{-g,--global}'[Install globally]' \
          '(-s --ssh)'{-s,--ssh}'[Use SSH for cloning]' \
          '1:package:'
        ;;
      uninstall)
        _arguments '1:package:'
        ;;
      link)
        _arguments \
          '1:directory:_directories' \
          '2:package name:'
        ;;
      upgrade)
        _arguments '1:package:'
        ;;
      package-path)
        _arguments '1:package:'
        ;;
      include)
        _arguments \
          '1:package:' \
          '2:library file:'
        ;;
      init)
        _arguments \
          '--shell=[Shell type]:shell:(bash zsh fish)'
        ;;
    esac
    ;;
esac
