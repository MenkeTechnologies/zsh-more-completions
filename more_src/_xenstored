#compdef xenstored
# Documentation: https://github.com/xen-project/xen/blob/master/tools/xenstored/core.c
# Reference accessed: 2026-05-21
# Verified: upstream xenstored core.c getopt_long table and usage strings.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-H,--help}'[show help]' \
  '(-F --pid-file)'{-F+,--pid-file=}'[file for daemon pid to be written]:file:_files' \
  '(-N --no-fork)'{-N,--no-fork}'[do not fork]' \
  '(-T --trace-file)'{-T+,--trace-file=}'[file for trace logging]:file:_files' \
  '--trace-control=[activate/deactivate a trace switch (+/-switch)]:switch:' \
  '(-E --entry-nb)'{-E+,--entry-nb=}'[limit entries per domain]:nb:' \
  '(-S --entry-size)'{-S+,--entry-size=}'[limit entry size per domain]:size:' \
  '(-W --watch-nb)'{-W+,--watch-nb=}'[limit watches per domain]:nb:' \
  '(-t --transaction)'{-t+,--transaction=}'[limit transactions per domain]:nb:' \
  '(-A --perm-nb)'{-A+,--perm-nb=}'[limit permissions per node]:nb:' \
  '(-M --path-max)'{-M+,--path-max=}'[limit Xenstore node path length]:chars:' \
  '*'{-Q+,--quota=}'[set quota <what>=<nb>]:what=nb:' \
  '*'{-q+,--quota-soft=}'[set soft quota <what>=<nb>]:what=nb:' \
  '*'{-w+,--timeout=}'[set timeout <what>=<seconds>]:what=sec:' \
  '(-K --keep-orphans)'{-K,--keep-orphans}'[do not delete nodes when domain is deleted]' \
  '(-m --master-domid)'{-m+,--master-domid=}'[domid of the domain running xenstored]:domid:' \
  '(-U --live-update)'{-U,--live-update}'[live-update mode]' && ret=0

return ret
