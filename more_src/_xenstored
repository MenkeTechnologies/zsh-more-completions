#compdef xenstored
# Documentation: https://man.archlinux.org/search?q=xenstored
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-D[no fork (debug)]' \
  '-F+[pid file]:file:_files' \
  '-N[no fork (foreground)]' \
  '-P[verbose port logging]' \
  '-T+[trace file]:file:_files' \
  '-A+[max retries on transaction]:n:' \
  '-M+[max transactions]:n:' \
  '-Q+[max in-flight requests]:n:' \
  '-q+[max requests per second]:n:' \
  '-w+[max number of watches]:n:' \
  '-W+[max watch-events per connection]:n:' \
  '-t+[transaction timeout sec]:sec:' \
  '-R+[max transactional nodes per dom]:n:' \
  '-S+[max nodes per dom]:n:' \
  '-p[set up entry permissions]' \
  '-r[reload state]' \
  '-L+[live update startup info]:info:' \
  '-K+[keep file descriptor open]:fd:' && ret=0

return ret
