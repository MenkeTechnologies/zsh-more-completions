#compdef radiff radiff-cli
# _radiff — radare2 radiff binary diff CLI alias (radareorg, C); custom argparse
# upstream: https://github.com/radareorg/radare2

_radiff() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[architecture]:str:' \
        '-A[analyze]' \
        '-b+[bits]:n:(16 32 64)' \
        '-B+[base address]:str:' \
        '-c[graphical diff with rcc]' \
        '-C[compare graphs of functions]' \
        '-d[directory diff]' \
        '-D[show disasm of differences]' \
        '-e+[expression]:str:' \
        '-g[graph diff]' \
        '-H[show file hashes]' \
        '-i[diff binary info]' \
        '-j[json output]' \
        '-m+[output mode]:m:(plain bytes radare)' \
        '-n[fix dups]' \
        '-O[diff comments]' \
        '-p+[set patch]:str:' \
        '-q[quiet]' \
        '-r[ratio]' \
        '-s[bytes per line]' \
        '-S+[seek to address]:str:' \
        '-t+[similarity threshold]:n:' \
        '-T[show timings]' \
        '-u[unified output]' \
        '-U[unified output]' \
        '-v[verbose]' \
        '-w[wider output]' \
        '-x[show two columns hex disasm]' \
        '-X[show side by side disasm]' \
        '-z[diff strings]' \
        '-Z[diff strings (extended)]' \
        '*:file:_files'
}

_radiff "$@"
