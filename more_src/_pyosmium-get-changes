#compdef pyosmium-get-changes
# Documentation: https://docs.osmcode.org/pyosmium/latest/user_manual/10-Replication-Tools/
# Download OSM replication change files (diffs) from a replication server.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*-v[increase verbosity (repeatable)]' \
  '(-o --outfile)'{-o+,--outfile=}'[diff output file (else only sequence ID printed)]:file:_files' \
  '--format=[output data format]:format:_default' \
  '--server=[base URL of the replication server]:url:_urls' \
  '--diff-type=[replication server file format (default osc.gz)]:type:_default' \
  '--cookie=[Netscape-style cookie jar file]:file:_files' \
  '(-s --size)'{-s+,--size=}'[max data to load in MB]:mb:_default' \
  '(-I --start-id)'{-I+,--start-id=}'[sequence ID to start with]:id:_default' \
  '(-D --start-date)'{-D+,--start-date=}'[date to start updates]:date:_default' \
  '(-O --start-osm-data)'{-O+,--start-osm-data=}'[start at newest object date in file]:file:_files' \
  '--end-id=[last sequence ID to download]:id:_default' \
  '(-E --end-date)'{-E+,--end-date=}'[do not download diffs later than date]:date:_default' \
  '(-f --sequence-file)'{-f+,--sequence-file=}'[sequence file for tracking progress]:file:_files' \
  '--ignore-osmosis-headers[ignore replication info in file headers]' \
  '(-d --no-deduplicate)'{-d,--no-deduplicate}'[do not deduplicate diffs]' \
  '--socket-timeout=[timeout for file downloads]:seconds:_default' && ret=0

return ret
