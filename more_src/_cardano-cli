#compdef cardano-cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'address:payment address commands'
  'stake-address:stake address commands'
  'key:key utility commands'
  'transaction:transaction commands'
  'node:node operation commands'
  'stake-pool:stake pool commands'
  'query:node query commands'
  'genesis:genesis block commands'
  'governance:governance commands'
  'text-view:commands for text view encoded files'
  'ping:ping a cardano node'
  'latest:latest era commands'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cardano-cli command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (address)
        local -a addr_cmds=(
          'key-gen:create address key pair'
          'key-hash:print verification key hash'
          'build:build a payment address'
          'info:print address information'
        )
        _arguments '1:address command:_describe -t addr-cmds "address command" addr_cmds' \
          '--mainnet[use mainnet]' \
          '--testnet-magic=[testnet network magic]:magic number' \
          '*:arguments' && ret=0
        ;;
      (transaction)
        local -a tx_cmds=(
          'build:build a transaction'
          'build-raw:build a raw transaction'
          'sign:sign a transaction'
          'submit:submit a transaction'
          'calculate-min-fee:calculate minimum fee'
          'calculate-min-required-utxo:calculate minimum required UTxO'
          'hash-script-data:hash script data'
          'txid:print a transaction identifier'
          'view:print a transaction'
          'policyid:calculate policy ID'
          'witness:create a transaction witness'
          'assemble:assemble a transaction'
        )
        _arguments '1:transaction command:_describe -t tx-cmds "transaction command" tx_cmds' \
          '*:arguments' && ret=0
        ;;
      (query)
        local -a query_cmds=(
          'protocol-parameters:get current protocol parameters'
          'tip:get the node tip'
          'stake-pools:get the node current set of stake pool IDs'
          'stake-distribution:get the node current stake distribution'
          'stake-address-info:get stake address info'
          'utxo:get the UTxO set'
          'ledger-state:dump the current ledger state'
          'protocol-state:dump the current protocol state'
          'stake-snapshot:obtain stake snapshot'
          'pool-params:dump the pool parameters'
          'leadership-schedule:get the leadership schedule'
          'kes-period-info:get KES period info'
          'tx-mempool:local mempool info'
          'slot-number:get the slot number for a UTC time'
          'ref-script-size:calculate reference script size'
        )
        _arguments '1:query command:_describe -t query-cmds "query command" query_cmds' \
          '--mainnet[use mainnet]' \
          '--testnet-magic=[testnet network magic]:magic number' \
          '--socket-path=[node socket path]:socket:_files' \
          '--out-file=[output file]:file:_files' \
          '*:arguments' && ret=0
        ;;
      (node)
        local -a node_cmds=(
          'key-gen:create node key pair'
          'key-gen-KES:create KES key pair'
          'key-gen-VRF:create VRF key pair'
          'key-hash-VRF:print VRF key hash'
          'new-counter:create new certificate issue counter'
          'issue-op-cert:issue operational certificate'
        )
        _arguments '1:node command:_describe -t node-cmds "node command" node_cmds' \
          '*:arguments' && ret=0
        ;;
      (stake-pool)
        local -a pool_cmds=(
          'registration-certificate:create registration certificate'
          'deregistration-certificate:create deregistration certificate'
          'id:build pool ID from cold verification key'
          'metadata-hash:print hash of pool metadata'
        )
        _arguments '1:stake-pool command:_describe -t pool-cmds "stake-pool command" pool_cmds' \
          '*:arguments' && ret=0
        ;;
      (key)
        local -a key_cmds=(
          'verification-key:get verification key from signing key'
          'non-extended-key:get non-extended key from extended key'
          'convert-byron-key:convert a Byron key'
          'convert-byron-genesis-vkey:convert a Byron genesis key'
          'convert-itn-key:convert an ITN key'
          'convert-itn-extended-key:convert an ITN extended key'
          'convert-itn-bip32-key:convert an ITN BIP32 key'
          'convert-cardano-address-key:convert a cardano-address key'
        )
        _arguments '1:key command:_describe -t key-cmds "key command" key_cmds' \
          '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
