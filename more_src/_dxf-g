#compdef dxf-g
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=dxf-g&sektion=1
# BRL-CAD DXF to geometry database converter

local ret=1

_arguments -s \
  '-c[use only first color seen per layer]' \
  '-d[set debug flag (core dump on failure)]' \
  '-v[very verbose output on stderr]' \
  '-s[scale factor applied to DXF input]:scale' \
  '-t[max distance (mm) between two vertices]:tolerance' \
  '1:input.dxf:_files' \
  '2:output:_files -g "*.g"' && ret=0

return ret
