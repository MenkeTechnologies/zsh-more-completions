#
# THE proto-loader-gen-types CLI — yargs + protobufjs + @grpc/proto-loader
#
# proto-loader-gen-types is in packages/proto-loader/bin/
# proto-loader-gen-types.ts.  Uses yargs for argument parsing
# with extensive option coverage.
#
# Source:
#     const argv = await yargs
#         .parserConfiguration({ 'parse-positional-numbers': false })
#         .option('keepCase', boolDefaultFalseOption)
#         .option('longs',  { string: true, default: 'Long' })
#         .option('enums',  { string: true, default: 'number' })
#         .option('bytes',  { string: true, default: 'Buffer' })
#         .option('defaults', boolDefaultFalseOption)
#         .option('arrays',  boolDefaultFalseOption)
#         .option('objects', boolDefaultFalseOption)
#         .option('oneofs',  boolDefaultFalseOption)
#         .option('json',    boolDefaultFalseOption)
#         .option('verbose', { boolean: true })
#         .option('includeComments', boolDefaultFalseOption)
#         .option('includeDirs', { array: true, alias: 'I' })
#         .option('outDir',   { alias: 'O', normalize: true })
#         .option('grpcLib',  { string: true })
#         .option('inputTemplate', { string: true, default: '%s' })
#         .option('outputTemplate', { string: true, default: '%s__Output' })
#         .option('inputBranded',  boolDefaultFalseOption)
#         .option('outputBranded', boolDefaultFalseOption)
#         .option('targetFileExtension', { string: true, default: '.ts' })
#         .option('importFileExtension', { string: true, default: '' })
#         .demandOption(['outDir'])
#         .demand(1)
#         .usage('$0 [options] filenames...')
#         .argv;
#
# Required flags:
#   -O, --outDir DIR              output directory (REQUIRED)
#
# Positional:
#   FILENAMES...                  .proto files (at least one
#                                 REQUIRED)
#
# Field representation flags (boolean):
#   --keepCase                    preserve original field name case
#   --defaults                    output default values for omitted fields
#   --arrays                      defaults for omitted repeated fields
#   --objects                     defaults for omitted message fields
#   --oneofs                      output virtual oneof fields
#   --json                        Infinity/NaN as strings;
#                                 auto-decode google.protobuf.Any
#   --includeComments             generate doc comments from .proto
#
# Type representation flags (string):
#   --longs {String|Number}       64-bit integer representation
#                                 (default: Long object)
#   --enums {String}              enum representation (default: number)
#   --bytes {Array|String|Buffer} bytes representation (default: Buffer)
#
# Template flags:
#   --inputTemplate FMT           input type name template
#                                 (default '%s')
#   --outputTemplate FMT          output type name template
#                                 (default '%s__Output')
#   --inputBranded                add phantom branding to input types
#   --outputBranded               add phantom branding to output types
#   --targetFileExtension EXT     output file extension (default .ts)
#   --importFileExtension EXT     import-specifier extension
#                                 (default empty)
#
# Library targeting:
#   --grpcLib MODULE              gRPC library to target
#                                 (typically @grpc/grpc-js)
#
# Search paths:
#   -I, --includeDirs DIRS        include directories (multiple)
#
# Diagnostics:
#   -v, --verbose                 verbose stderr output
#
# Standard:
#   -h, --help                    show help (yargs default)
#
# @grpc/grpc-js is referenced via --grpcLib '@grpc/grpc-js'
# to determine which service-definition types to emit (vs
# alternative gRPC implementations like @grpc/grpc).
#
# Five-axis distinctness from tonic (R685) + grpc-go (R686):
#
#   1. PURE JAVASCRIPT — @grpc/grpc-js is pure JS over Node's
#      http2 module.  tonic uses hyper (Rust); grpc-go has
#      its own HTTP/2 stack.
#
#   2. @grpc/proto-loader DYNAMIC LOADING — dynamic .proto
#      loading at runtime (vs static code-gen).  tonic uses
#      tonic-build at Cargo build time; grpc-go uses protoc-
#      gen-go-grpc.  @grpc/grpc-js + @grpc/proto-loader
#      uniquely supports both static AND dynamic loading.
#
#   3. SEPARATE INPUT/OUTPUT TYPES — proto-loader-gen-types
#      emits permissive input types + restricted output types
#      separately, reflecting protobuf's "wire format" duality.
#      tonic + grpc-go use single message type.
#
#   4. BRANDED TYPES — phantom branding for type-safe
#      discrimination of structurally identical protobuf
#      messages.  Unique to proto-loader-gen-types.
#
#   5. GOOGLE / grpc-org PURE-JS PROVENANCE — same Google team
#      as grpc-go (R686), but pure-JS implementation rather
#      than Cgo.  Distinct from Hyperium (community).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/grpc/grpc-node/blob/master/packages/proto-loader/bin/proto-loader-gen-types.ts
# yargs .option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-O --outDir)'{-O+,--outDir=}'[output directory (REQUIRED)]:directory:_files -/' \
    '*'{-I+,--includeDirs=}'[include directory for imported .proto files]:directory:_files -/' \
    '--keepCase[preserve original field name case]' \
    '--longs=[64-bit integer representation]:type:(String Number)' \
    '--enums=[enum representation]:type:(String)' \
    '--bytes=[bytes representation]:type:(Array String Buffer)' \
    '--defaults[output default values for omitted fields]' \
    '--arrays[defaults for omitted repeated fields]' \
    '--objects[defaults for omitted message fields]' \
    '--oneofs[output virtual oneof fields]' \
    '--json[Infinity/NaN as strings; auto-decode google.protobuf.Any]' \
    '--includeComments[generate doc comments from .proto]' \
    '--inputTemplate=[input type name template]:template:_default' \
    '--outputTemplate=[output type name template]:template:_default' \
    '--inputBranded[add phantom branding to input types]' \
    '--outputBranded[add phantom branding to output types]' \
    '--targetFileExtension=[output file extension]:extension:_default' \
    '--importFileExtension=[import-specifier extension]:extension:_default' \
    '--grpcLib=[gRPC library to target]:library:(@grpc/grpc-js @grpc/grpc)' \
    '(-v --verbose)'{-v,--verbose}'[verbose stderr output]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:.proto file:_files -g "*.proto"' \
    && ret=0

return ret
