#compdef ledger2beancount
# Documentation: https://ledger2beancount.readthedocs.io/guide/
# ledger2beancount - convert a Ledger journal file to Beancount format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[use configuration FILE (.yml/.yaml)]:file:_files -g "*.(yml|yaml)"' \
  '*:ledger file:_files' && ret=0

return ret
