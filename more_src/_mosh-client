#compdef mosh-client
# Documentation: https://man.archlinux.org/search?q=mosh-client
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:IP address' \
  '2:UDP port' && ret=0

return ret
