#compdef mosh-client
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mosh-client.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:IP address' \
  '2:UDP port' && ret=0

return ret
