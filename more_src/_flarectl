#compdef flarectl
# Documentation: https://github.com/cloudflare/cloudflare-go/tree/master/cmd/flarectl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flarectl: Cloudflare CLI from cloudflare-go.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ips:print Cloudflare IP ranges'
      'i:print Cloudflare IP ranges'
      'user:user information'
      'u:user information'
      'zone:zone information'
      'z:zone information'
      'dns:DNS records'
      'd:DNS records'
      'user-agents:user-agent blocking'
      'ua:user-agent blocking'
      'pagerules:page rules'
      'p:page rules'
      'railgun:railgun information'
      'r:railgun information'
      'firewall:firewall'
      'f:firewall'
      'origin-ca-root-cert:print Origin CA Root Certificate (PEM)'
      'ocrc:print Origin CA Root Certificate (PEM)'
      'help:show help'
      'h:show help'
    )
    _describe -t commands 'flarectl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      zone|z)
        local -a subcmds=(
          'list:list zones'
          'create:create a zone'
          'delete:delete a zone'
          'check:check zone activation'
          'info:show zone info'
          'lockdown:zone lockdown'
        )
        _describe -t subcmds 'zone subcommand' subcmds && ret=0
        ;;
      dns|d)
        _arguments -s -S \
          '--zone=[zone name]:zone:' \
          '--name=[record name]:name:' \
          '--type=[record type]:type:(A AAAA CNAME MX TXT NS SRV LOC CAA CERT DNSKEY DS NAPTR SMIMEA SSHFP TLSA URI)' \
          '--content=[record content]:content:' \
          '--ttl=[TTL value]:ttl:' \
          '--priority=[MX priority]:priority:' \
          '--proxy=[enable proxy]:proxy:(true false)' \
          '--id=[record ID]:id:' \
          '1:action:(list create update delete create-or-update)' && ret=0
        ;;
      user|u)
        local -a subcmds=(
          'info:show user info'
          'update:update user settings'
        )
        _describe -t subcmds 'user subcommand' subcmds && ret=0
        ;;
      firewall|f)
        local -a subcmds=(
          'list:list firewall rules'
          'create:create a firewall rule'
          'update:update a firewall rule'
          'delete:delete a firewall rule'
        )
        _describe -t subcmds 'firewall subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
