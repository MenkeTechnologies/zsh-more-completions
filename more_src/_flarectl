#compdef flarectl

# Zsh completion for flarectl - Cloudflare CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-e --email)'{-e,--email}'[Cloudflare account email]:email' \
  '(-k --key)'{-k,--key}'[Cloudflare API key]:key' \
  '--token=[Cloudflare API token]:token' \
  '--account-id=[Cloudflare account ID]:account id' \
  '--json[output as JSON]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'zone:Manage zones'
      'dns:Manage DNS records'
      'user:Manage user settings'
      'ips:List Cloudflare IP ranges'
      'pagerules:Manage page rules'
      'railgun:Manage railgun'
      'firewall:Manage firewall rules'
    )
    _describe -t commands 'flarectl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      zone)
        local -a subcmds=(
          'list:List zones'
          'create:Create a zone'
          'delete:Delete a zone'
          'check:Check zone activation'
          'info:Show zone info'
          'lockdown:Zone lockdown'
        )
        _describe -t subcmds 'zone subcommand' subcmds && ret=0
        ;;
      dns)
        _arguments -s -S \
          '--zone=[zone name]:zone' \
          '--name=[record name]:name' \
          '--type=[record type]:type:(A AAAA CNAME MX TXT NS SRV LOC CAA CERT DNSKEY DS NAPTR SMIMEA SSHFP TLSA URI)' \
          '--content=[record content]:content' \
          '--ttl=[TTL value]:ttl' \
          '--priority=[MX priority]:priority' \
          '--proxy=[enable proxy]:proxy:(true false)' \
          '--id=[record ID]:id' \
          '1:action:(list create update delete create-or-update)' && ret=0
        ;;
      user)
        local -a subcmds=(
          'info:Show user info'
          'update:Update user settings'
        )
        _describe -t subcmds 'user subcommand' subcmds && ret=0
        ;;
      firewall)
        local -a subcmds=(
          'list:List firewall rules'
          'create:Create a firewall rule'
          'update:Update a firewall rule'
          'delete:Delete a firewall rule'
        )
        _describe -t subcmds 'firewall subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
