#compdef supabase-cli
# Documentation: https://supabase.com/docs/reference/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: supabase-cli is an alias name for the supabase binary; see _supabase.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:set up local development configuration'
  'login:authenticate with Supabase'
  'link:connect to a hosted Supabase instance'
  'start:launch local development environment'
  'stop:shut down local stack'
  'status:show status'
  'db:manage database operations'
  'migration:handle schema migrations'
  'gen:generate types and signing keys'
  'test:run pgTAP tests'
  'projects:manage projects'
  'orgs:manage organizations'
  'branches:manage preview branches'
  'config:update project configurations'
  'functions:manage Edge Functions'
  'secrets:manage secrets'
  'sso:manage SSO providers'
  'domains:manage custom domains'
  'network-restrictions:manage network restrictions'
  'network-bans:manage network bans'
  'ssl-enforcement:manage SSL enforcement'
  'storage:manage storage buckets'
  'seed:populate initial data'
  'inspect:inspect database'
  'services:display service versions'
  'telemetry:manage analytics settings'
  'completion:generate shell completions'
)

_arguments -s -S \
  '--debug[output debug logs to stderr]' \
  '--experimental[enable experimental features]' \
  '--workdir=[project directory]:directory:_files -/' \
  '--profile=[configuration profile]:profile:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(env pretty json toml yaml)' \
  '--yes[skip confirmation prompts]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'supabase command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      db)
        local -a db_cmds=(
          'diff:diff local database with migrations'
          'dump:dump data or schema from remote database'
          'lint:lint local database for errors'
          'pull:pull remote database changes'
          'push:push local database changes'
          'reset:reset local database to clean state'
          'start:start local database'
        )
        _describe -t commands 'db command' db_cmds && ret=0
        ;;
      functions)
        local -a fn_cmds=(
          'delete:delete a function'
          'deploy:deploy a function'
          'list:list all functions'
          'new:create a new function'
          'serve:serve functions locally'
        )
        _describe -t commands 'functions command' fn_cmds && ret=0
        ;;
      migration)
        local -a mig_cmds=(
          'list:list all migrations'
          'new:create a new migration'
          'fetch:fetch migrations from remote'
          'repair:repair migration history'
          'squash:squash migrations'
          'up:apply pending migrations'
          'down:revert applied migrations'
        )
        _describe -t commands 'migration command' mig_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
