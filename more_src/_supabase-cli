#compdef supabase

# Zsh completion for Supabase CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a Supabase project'
  'login:authenticate with Supabase'
  'link:link to a Supabase project'
  'start:start Supabase locally'
  'stop:stop Supabase locally'
  'status:show local Supabase status'
  'db:manage local Supabase database'
  'gen:generate types and keys'
  'migration:manage database migrations'
  'functions:manage Supabase Edge Functions'
  'secrets:manage Supabase secrets'
  'storage:manage Supabase Storage'
  'domains:manage custom domains'
  'vanity-subdomains:manage vanity subdomains'
  'network-bans:manage network bans'
  'network-restrictions:manage network restrictions'
  'orgs:manage Supabase organizations'
  'projects:manage Supabase projects'
  'branches:manage preview branches'
  'ssl-enforcement:manage SSL enforcement'
  'sso:manage single sign-on'
  'completion:generate shell completions'
  'help:show help'
)

_arguments -s -S \
  '--debug[output debug logs]' \
  '--experimental[enable experimental features]' \
  '--workdir=[project directory]:directory:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'supabase command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      db)
        local -a db_cmds=(
          'diff:diff local database with migrations'
          'dump:dump data or schema from remote database'
          'lint:lint local database for errors'
          'pull:pull remote database changes'
          'push:push local database changes'
          'remote:manage remote database'
          'reset:reset local database to clean state'
          'start:start local database'
        )
        _describe -t commands 'db command' db_cmds && ret=0
        ;;
      functions)
        local -a fn_cmds=(
          'delete:delete a Function'
          'deploy:deploy a Function'
          'download:download a Function'
          'list:list all Functions'
          'new:create a new Function'
          'serve:serve Functions locally'
        )
        _describe -t commands 'functions command' fn_cmds && ret=0
        ;;
      migration)
        local -a mig_cmds=(
          'list:list all migrations'
          'new:create a new migration'
          'repair:repair migration history'
          'squash:squash migrations'
          'up:apply pending migrations'
        )
        _describe -t commands 'migration command' mig_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
