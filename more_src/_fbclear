#compdef fbclear
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=fbclear&sektion=1
# BRL-CAD clear a framebuffer to a color

local ret=1

_arguments -s \
  '-c[load standard linear colormap and reset pan/zoom]' \
  '-F[framebuffer device to clear]:device' \
  '-w[framebuffer width]:width' \
  '-n[framebuffer height]:height' \
  '-s[square framebuffer size]:size' \
  '*:color value:_default' && ret=0

return ret
