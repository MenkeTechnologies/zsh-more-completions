#compdef nsxiv

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a[play animations of multi-frame images]' \
  '-b[do not show info bar at bottom]' \
  '-c[remove all orphaned cache files]' \
  '-e+[embed into window with given X Window ID]:window ID:' \
  '-f[start in fullscreen mode]' \
  '-G+[set image gamma]:gamma (-32..32):' \
  '-g+[set window geometry]:geometry:' \
  '-h[print help and exit]' \
  '-i[read file list from stdin]' \
  '-N+[set X window resource name]:name:' \
  '-n+[start at image number]:number:' \
  '-o[print selected files to stdout on exit]' \
  '-p[enable private mode (no cache)]' \
  '-q[be quiet (suppress warnings)]' \
  '-r[search directories recursively]' \
  '-S+[start slideshow with interval]:seconds:' \
  '-s+[set scale mode]:mode:(d f w h)' \
  '-t[start in thumbnail mode]' \
  '-v[print version and exit]' \
  '-Z[auto-zoom image to fit window]' \
  '-z+[set zoom level]:zoom percent:' \
  '-0[null-terminated file list from stdin (with -i)]' \
  '*:image file:_files -g "*.{png,jpg,jpeg,gif,bmp,tiff,tif,webp,svg,ico,xpm,ppm,pgm,pbm,pnm}(-.)"' && ret=0

return ret
