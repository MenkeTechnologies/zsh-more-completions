#compdef pynguin
# Documentation: https://pynguin.readthedocs.io/latest/user/quickstart.html
# pynguin - automated unit test generation for Python

local ret=1

_arguments -s -S \
  '--project-path=[path to the project the generator creates tests for]:dir:_files -/' \
  '--output-path=[path to store generated test files]:dir:_files -/' \
  '--module-name=[module for which the generator creates tests]:module:' \
  '(-v)-v[enable verbose logging output to the console]' \
  '--log-file=[file path for writing log messages]:file:_files' \
  '*:arg:' && ret=0

return ret
