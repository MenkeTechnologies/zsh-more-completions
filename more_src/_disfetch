#compdef disfetch
# Documentation: https://github.com/q60/disfetch
# disfetch - yet another fetch but small and useless

local ret=1

_arguments -s -S \
  '-h[display help message and exit]' \
  '-l[set a custom distro logo by name]:logo:' \
  '-m[disable colors and formatting, monochrome mode]' \
  '-n[disable decorations, display only system information]' && ret=0

return ret
