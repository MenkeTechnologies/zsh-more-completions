#compdef sadf
# _sadf — sysstat sadf system activity data formatter CLI (Sebastien Godard / sysstat team, C); custom argparse
# upstream: https://github.com/sysstat/sysstat

_sadf() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[convert old style daily file]' \
        '-C[convert old style daily file (compatibility)]' \
        '-d[output as semicolon-delimited]' \
        '-D[output as PCP archive]' \
        '-e+[end time]:str:' \
        '-g[output as svg]' \
        '-H[show file headers]' \
        '-j[output as json]' \
        '-l[only daily summary]' \
        '-O+[output options]:list:' \
        '-p[output as ppm]' \
        '-P+[cpu list]:list:' \
        '-r[output as raw data]' \
        '-s+[start time]:str:' \
        '-t[show timezone]' \
        '-T[show local timezone]' \
        '-U[force UTC timestamps]' \
        '-x[output as XML]' \
        '*:file:_files'
}

_sadf "$@"
