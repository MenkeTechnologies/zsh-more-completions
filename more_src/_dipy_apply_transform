#compdef dipy_apply_transform
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_apply_transform.html
# DIPY: apply an affine or diffeomorphic transform to images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--transform_type=[transformation type]:type:(affine diffeomorphic)' \
  '--interpolation=[interpolation method]:method:(linear nearest)' \
  '--out_dir=[directory for saving transformed files]:dir:_files -/' \
  '--out_file=[output filename]:file:_files' \
  '*:input (static moving transform_map):_files' && ret=0

return ret
