#compdef autogenstudio
# Documentation: https://github.com/microsoft/autogen/tree/main/python/packages/autogen-studio
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for autogenstudio - AutoGen Studio multi-agent UI launcher

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'autogenstudio command' \
      'ui[launch the web interface]' \
      'lite[lightweight prototyping mode]' \
      'version[show version]' && ret=0
    ;;
  args)
    case $line[1] in
      ui)
        _arguments \
          '--host[host address]:host:' \
          '--port[port number]:port:' \
          '--appdir[application directory]:dir:_directories' \
          '--reload[enable auto-reload]' \
          '--database-uri[database URI]:uri:' \
          '--upgrade-database[upgrade database schema]' && ret=0
        ;;
      lite)
        _arguments \
          '--team[team file path]:file:_files' \
          '--port[port number]:port:' \
          '--session-name[custom session name]:name:' \
          '--auto-open[auto open the interface]' && ret=0
        ;;
    esac
    ;;
esac

return ret
