#compdef sumologic-cli sumo-cli sumologic sumo
# _sumologic-cli — Sumo Logic sumologic-cli CLI command-line frontend wrapping the Sumo Logic cloud-native machine data analytics SaaS log management security observability platform CLI providing login logout whoami search query export import collector source folder content monitor monitor-folder dashboard role user partition fer-field-extraction-rule schedule-search lookup-table service-account (Sumo Logic team, Go); cobra
# upstream: https://www.sumologic.com/

_sumologic-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'search:search logs'
        'export:export logs'
        'import:import data'
        'collector:collector operations'
        'source:source operations'
        'folder:folder operations'
        'content:content operations'
        'monitor:monitor operations'
        'monitor-folder:monitor folder operations'
        'dashboard:dashboard operations'
        'role:role operations'
        'user:user operations'
        'partition:partition operations'
        'fer:field extraction rule operations'
        'scheduled-search:scheduled search ops'
        'lookup-table:lookup table operations'
        'service-account:service account operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-id=+[id]:str:' \
        '--access-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--deployment=+[d]:d:(us1 us2 eu au de jp ca in fed)' \
        '--cookie-file=+[file]:file:_files' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sumologic subcommand' sub ;;
        args)
            case $words[1] in
                collector|source|folder|content|monitor|monitor-folder|dashboard|role|user|partition|fer|scheduled-search|lookup-table|service-account) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                search|export) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_sumologic-cli "$@"
