#compdef half_mt
# Documentation: https://www.libraw.org/docs/Samples-LibRaw.html
# LibRaw sample: multithreaded emulation of dcraw -h (half-size color images)

local ret=1

_arguments -s -S \
  '-a[automatic white balance over the entire image]' \
  '-w[use camera white balance]' \
  '-T[output in TIFF format]' \
  '-J+[number of parallel threads]:threads' \
  '*:RAW file:_files' && ret=0

return ret
