#compdef nais
# Documentation: https://cli.nais.io
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activity:show platform activity'
  'alpha:experimental features'
  'api:API proxy / schema'
  'app:application management'
  'auth:authentication (login/logout/print-access-token)'
  'completion:shell completion setup'
  'config:configuration management'
  'debug:debug utilities'
  'defaults:default settings'
  'device:naisdevice management'
  'issues:issue tracking'
  'job:job operations'
  'kafka:Kafka management'
  'kubeconfig:Kubernetes config helpers'
  'log:log retrieval'
  'members:team membership management'
  'opensearch:OpenSearch operations'
  'postgres:Postgres database management'
  'secret:secret management'
  'status:platform status'
  'validate:configuration validation'
  'valkey:Valkey operations'
  'vulnerability:vulnerability scanning'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--context=[Kubernetes context]:context:' \
  '--cluster=[target cluster]:cluster:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nais command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (alpha)
        _arguments '*::sub:(apply krakend mcp)' && ret=0 ;;
      (api)
        _arguments '*::sub:(proxy schema)' && ret=0 ;;
      (app)
        _arguments '*::sub:(activity env files issues list log restart status)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout print-access-token)' && ret=0 ;;
      (config)
        _arguments '*::sub:(activity create delete get list set unset)' && ret=0 ;;
      (defaults)
        _arguments '*::sub:(get list set unset)' && ret=0 ;;
      (device)
        _arguments '*::sub:(config connect disconnect doctor gateway status)' && ret=0 ;;
      (job)
        _arguments '*::sub:(activity issues list log run trigger)' && ret=0 ;;
      (kafka)
        _arguments '*::sub:(credentials grant-access list)' && ret=0 ;;
      (members)
        _arguments '*::sub:(add list remove set-role)' && ret=0 ;;
      (opensearch)
        _arguments '*::sub:(create credentials delete get list update)' && ret=0 ;;
      (postgres)
        _arguments '*::sub:(enable-audit grant list migrate password prepare proxy psql revoke users verify-audit)' && ret=0 ;;
      (secret)
        _arguments '*::sub:(activity create delete get list set unset)' && ret=0 ;;
      (valkey)
        _arguments '*::sub:(create credentials delete get list update)' && ret=0 ;;
      (vulnerability)
        _arguments '*::sub:(list search summary)' && ret=0 ;;
      (validate)
        _arguments \
          '(-f --file)'{-f+,--file=}'[file to validate]:file:_files -g "*.{yaml,yml,json}"' \
          '*::file:_files' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
