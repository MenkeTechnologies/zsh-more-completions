#compdef dsrdump dcmsr
# Documentation: https://support.dcmtk.org/docs-snapshot/dsrdump.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmsr/apps/dsrdump.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmsr/apps/dsrdump.cc OFCommandLine setup + dcmsr/docs/dsrdump.man.
# No standalone "dcmsr" binary ships in upstream DCMTK (the dcmsr/apps directory
# contains dsrdump.cc, dsr2html.cc, dsr2xml.cc, xml2dsr.cc). This completion is
# bound to dsrdump as primary and dcmsr as alias.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(-Ip --processing-details)'{-Ip,--processing-details}'[show currently processed content item]' \
  '(-Er --unknown-relationship)'{-Er,--unknown-relationship}'[accept unknown/missing relationship type]' \
  '(-Ev --invalid-item-value)'{-Ev,--invalid-item-value}'[accept invalid content item value]' \
  '(-Ec --ignore-constraints)'{-Ec,--ignore-constraints}'[ignore relationship content constraints]' \
  '(-Ee --ignore-item-errors)'{-Ee,--ignore-item-errors}'[do not abort on content item errors, just warn]' \
  '(-Ei --skip-invalid-items)'{-Ei,--skip-invalid-items}'[skip invalid content items (incl. sub-tree)]' \
  '(-Dv --disable-vr-checker)'{-Dv,--disable-vr-checker}'[disable check for VR-conformant string values]' \
  '(+U8 --convert-to-utf8)'{+U8,--convert-to-utf8}'[convert affected element values to UTF-8]' \
  '(+Pf --print-filename)'{+Pf,--print-filename}'[print header with filename for each document]' \
  '(-Ph --no-document-header)'{-Ph,--no-document-header}'[do not print general document information]' \
  '(+Pn --number-nested-items)'{+Pn,--number-nested-items}'[print position string in front of each line]' \
  '(-Pn --indent-nested-items)'{-Pn,--indent-nested-items}'[indent nested items by spaces (default)]' \
  '(+Pl --print-long-values)'{+Pl,--print-long-values}'[print long item values completely]' \
  '(-Pl --shorten-long-values)'{-Pl,--shorten-long-values}'[print long item values shortened (default)]' \
  '(+Pu --print-instance-uid)'{+Pu,--print-instance-uid}'[print SOP instance UID of referenced objects]' \
  '(-Ps --print-sopclass-short)'{-Ps,--print-sopclass-short}'[print short SOP class name (default)]' \
  '(+Ps --print-sopclass-long)'{+Ps,--print-sopclass-long}'[print long SOP class name of referenced objects]' \
  '(+Psu --print-sopclass-uid)'{+Psu,--print-sopclass-uid}'[print SOP class UID of referenced objects]' \
  '(+Pc --print-all-codes)'{+Pc,--print-all-codes}'[print all codes (incl. concept name codes)]' \
  '(+Pi --print-invalid-codes)'{+Pi,--print-invalid-codes}'[print invalid codes (for debugging)]' \
  '(-Pi --no-invalid-codes)'{-Pi,--no-invalid-codes}'[print text "invalid code" instead (default)]' \
  '(+Pt --print-template-id)'{+Pt,--print-template-id}'[print template identification information]' \
  '(+Pe --indicate-enhanced)'{+Pe,--indicate-enhanced}'[indicate that enhanced mode is used for codes]' \
  '(-Pe --no-enhanced-mode)'{-Pe,--no-enhanced-mode}'[do not indicate enhanced mode (default)]' \
  '(+C --print-color)'{+C,--print-color}'[use ANSI escape codes for colored output]' \
  '(-C --no-color)'{-C,--no-color}'[do not use any ANSI escape codes (default)]' \
  '*:dsrfile-in:_files'
