#compdef pixi-unpack
# _pixi-unpack — unpack a pixi-pack archive into a usable conda env (Quantco/pixi-pack)
# upstream: https://github.com/Quantco/pixi-pack
# Flags from src/bin/pixi-unpack.rs (clap).

_pixi-unpack() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-o --output-directory)'{-o+,--output-directory=}'[where to unpack the environment]:dir:_files -/' \
        '(-e --env-name)'{-e+,--env-name=}'[name of the unpacked environment subdir]:name:' \
        '(-s --shell)'{-s+,--shell=}'[shell to write the activation script for]:shell:(bash zsh xonsh cmd powershell fish nushell)' \
        '*'{-v,--verbose}'[increase verbosity]' \
        '*'{-q,--quiet}'[decrease verbosity]' \
        '1:pack file (tar / self-extracting / dir):_files' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                completion)
                    _arguments \
                        '(-s --shell)'{-s+,--shell=}'[shell]:shell:(bash zsh fish powershell elvish)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pixi-unpack_commands] )) ||
_pixi-unpack_commands() {
    local -a commands
    commands=(
        'completion:generate a shell completion script'
    )
    _describe -t commands 'pixi-unpack command' commands
}

_pixi-unpack "$@"
