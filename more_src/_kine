#compdef kine

_kine() {
  _arguments \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--endpoint[Storage endpoint]:endpoint:' \
    '--ca-file[CA certificate file]:file:_files' \
    '--cert-file[Client certificate file]:file:_files' \
    '--key-file[Client key file]:file:_files' \
    '--listen-address[Listen address]:address:' \
    '--server-cert-file[Server certificate file]:file:_files' \
    '--server-key-file[Server key file]:file:_files' \
    '--datastore-endpoint[Datastore endpoint (e.g. sqlite, mysql, postgres)]:endpoint:' \
    '--datastore-cafile[Datastore CA certificate]:file:_files' \
    '--datastore-certfile[Datastore client certificate]:file:_files' \
    '--datastore-keyfile[Datastore client key]:file:_files' \
    '--datastore-max-idle-connections[Max idle connections]:count:' \
    '--datastore-max-open-connections[Max open connections]:count:' \
    '--datastore-connection-max-lifetime[Max connection lifetime]:duration:' \
    '--metrics-bind-address[Metrics bind address]:address:' \
    '--watch-progress-notify-interval[Watch progress notify interval]:duration:' \
    '--debug[Enable debug logging]' \
    '(-v --version)'{-v,--version}'[Print version]'
}

_kine "$@"
