#compdef prosodyctl
# Documentation: https://man.archlinux.org/search?q=prosodyctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'about:show installation info'
  'adduser:add user (jid)'
  'passwd:change user password'
  'deluser:delete user'
  'reload:reload config'
  'status:show server status'
  'start:start server'
  'stop:stop server'
  'restart:restart server'
  'shell:open admin shell'
  'cert:manage certificates'
  'install:install plugin'
  'remove:remove plugin'
  'list:list plugins'
  'check:check configuration'
)

_arguments -C \
  '--root[do not switch user]' \
  '--config=[config file]:file:_files -g "*.cfg.lua"' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'prosodyctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cert)
        _values 'cert action' generate request import && ret=0
        ;;
      (check)
        _values 'check what' config features dns certs disabled turn connectivity && ret=0
        ;;
    esac
    ;;
esac

return ret
