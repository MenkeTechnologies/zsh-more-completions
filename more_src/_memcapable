#compdef memcapable
# Documentation: https://man.archlinux.org/man/memcapable.1.en
# Check a Memcached server's capabilities and compatibility (libmemcached)

local ret=1

_arguments -s -S \
  '-h+[hostname to connect to (default localhost)]:hostname:_hosts' \
  '-p+[port number to connect to (default 11211)]:port' \
  '-c[abort when detecting an error from the server]' \
  '-v[print the comparison when an error is detected]' \
  '-t+[timeout in seconds for an IO operation]:seconds' && ret=0

return ret
