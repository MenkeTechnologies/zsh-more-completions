#compdef elp
# Documentation: https://whatsapp.github.io/erlang-language-platform/docs/get-started/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elp: WhatsApp Erlang Language Platform (Erlang IDE/LSP toolchain)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'eqwalize:run eqWAlizer typechecker on a module'
  'eqwalize-all:run eqWAlizer against all source modules in a project'
  'eqwalize-app:run eqWAlizer on opted-in modules in an application'
  'eqwalize-target:run eqWAlizer on opted-in modules in a Buck target'
  'eqwalize-stats:return statistics about code quality for eqWAlizer'
  'lint:parse files and emit diagnostics, optionally apply fixes'
  'server:launch an LSP server'
  'shell:start an interactive ELP shell'
  'generate-completions:generate shell completions'
  'parse-all:dump AST for all files in a project'
  'parse-elp:tree-sitter parse all files in a project'
  'build-info:generate build info file'
  'project-info:generate project info file'
  'explain:explain a diagnostic code'
  'glean:Glean indexer'
  'version:display version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--log-file=[specify a log file]:file:_files' \
  '--no-log-buffering[disable log buffering]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'elp command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate-completions)
        _arguments '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
