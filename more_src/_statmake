#compdef statmake
# _statmake — Daltonmaag statmake CLI for compiling OpenType STAT design-axis-values table from an external statmake.yaml description into variable-font OTF/TTF for STAT axis ranges named instances and AxisValueRecord types 1-4 (daltonmaag team, Python); argparse
# upstream: https://github.com/daltonmaag/statmake

_statmake() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input description]:file:_files -g "*.yaml *.yml *.plist *.json"' \
        '--input=+[input description]:file:_files -g "*.yaml *.yml *.plist *.json"' \
        '-o+[output font]:file:_files -g "*.otf *.ttf"' \
        '--output=+[output font]:file:_files -g "*.otf *.ttf"' \
        '-f+[font file]:file:_files -g "*.otf *.ttf"' \
        '--font=+[font file]:file:_files -g "*.otf *.ttf"' \
        '-m+[mapping file]:file:_files -g "*.yaml *.yml *.plist *.json"' \
        '--mapping=+[mapping file]:file:_files -g "*.yaml *.yml *.plist *.json"' \
        '--no-stat[no STAT table]' \
        '--no-fvar[no fvar updates]' \
        '--no-name[no name updates]' \
        '*:font and stylespace:_files -g "*.otf *.ttf *.yaml *.yml *.plist *.json"'
}

_statmake "$@"
