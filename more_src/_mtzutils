#compdef mtzutils
# CCP4: edit, copy, and combine MTZ reflection files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN1[first input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLIN2[second input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLOUT[output MTZ reflection file]:mtz:_files' \
  '*:keyword:(SYMMETRY CELL TITLE COLUMN_LABELS RESOLUTION AXIS RZONE SCALE HISTORY INCLUDE EXCLUDE UNIQUE CONCAT MERGE ONEFILE HEADER RUN GO END)' && ret=0

return ret
