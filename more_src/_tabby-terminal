#compdef tabby
# _tabby-terminal — Tabby (formerly Terminus) Electron cross-platform terminal (Eugene Pankov); SSH/Serial/Telnet/Local with profiles
# upstream: https://github.com/Eugeny/tabby

_tabby-terminal() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug]' \
        '(-p --profile)'{-p,--profile}'+[profile]:profile:' \
        '(-c --command)'{-c,--command}'+[command]:cmd:_command_names -e' \
        '--background[start in background]' \
        '--integration[install OS integration]' \
        '--uninstall[uninstall OS integration]' \
        '--no-update[skip updates]' \
        '--inspect[node --inspect]' \
        '--inspect-brk[node --inspect-brk]' \
        '--working-directory+[cwd]:dir:_files -/' \
        '*:cmd or args:'
}

_tabby-terminal "$@"
