#compdef zellij

# Zsh completion for zellij (terminal multiplexer)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '--max-panes=[Maximum panes on screen]:count' \
  '--data-dir=[Change where zellij looks for plugins]:dir:_directories' \
  '--server=[Change the path of the server socket]:path:_files' \
  '-s+[Specify name of a new session]:name' \
  '--session=[Specify name of a new session]:name' \
  '-l+[Name of a predefined layout to load]:layout:_files' \
  '--layout=[Name of a predefined layout to load]:layout:_files' \
  '-c+[Change where zellij looks for configuration]:file:_files' \
  '--config=[Change where zellij looks for configuration]:file:_files' \
  '--config-dir=[Change where zellij looks for configuration dir]:dir:_directories' \
  '-d[Debug mode]' \
  '--debug[Debug mode]' \
  '-h[Print help information]' \
  '--help[Print help information]' \
  '-V[Print version information]' \
  '--version[Print version information]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'options:Change the behaviour of zellij'
      'setup:Setup zellij and generate completions'
      'list-sessions:List active sessions'
      'ls:List active sessions'
      'list-aliases:List configured aliases'
      'attach:Attach to a session'
      'a:Attach to a session'
      'kill-session:Kill the specific session'
      'kill-all-sessions:Kill all sessions'
      'delete-session:Delete a session from resurrection'
      'delete-all-sessions:Delete all sessions from resurrection'
      'action:Send actions to a specific session'
      'run:Run a command in a new pane'
      'plugin:Load a plugin'
      'edit:Edit a file in a new pane'
      'convert-config:Convert an old config file to the new KDML format'
      'convert-layout:Convert an old layout file to the new KDL format'
      'convert-theme:Convert an old theme file to the new KDL format'
      'pipe:Send data to one or more plugins'
    )
    _describe -t commands 'zellij command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      attach|a)
        _arguments -s -S \
          '-c[Create a session if one does not exist]' \
          '--create[Create a session if one does not exist]' \
          '-f[If the session exists and is attached, force a new attach]' \
          '--force-run-commands[If the session exists, force run commands]' \
          '-b[Whether to launch with a specified index]:index' \
          '--index=[Whether to launch with a specified index]:index' \
          '-h[Print help information]' \
          '--help[Print help information]' \
          '1:session name:->sessions' && ret=0
        ;;
      kill-session)
        _arguments -s -S \
          '-h[Print help information]' \
          '--help[Print help information]' \
          '1:session name:->sessions' && ret=0
        ;;
      delete-session)
        _arguments -s -S \
          '-f[Kill session if it is running before deleting]' \
          '--force[Kill session if it is running before deleting]' \
          '-h[Print help information]' \
          '--help[Print help information]' \
          '1:session name:->sessions' && ret=0
        ;;
      setup)
        _arguments -s -S \
          '--dump-config[Dump the default configuration file to stdout]' \
          '--clean[Remove all session state and cache]' \
          '--check[Check the configuration]' \
          '--dump-layout=[Dump a default layout to stdout]:layout' \
          '--dump-swap-layout=[Dump a default swap layout to stdout]:layout' \
          '--dump-plugins[Dump the builtin plugins to stdout]' \
          '--generate-completion=[Generate completions for the specified shell]:shell:(zsh bash fish elvish)' \
          '--generate-auto-start=[Generate an auto-start script for the specified shell]:shell:(zsh bash fish)' \
          '-h[Print help information]' \
          '--help[Print help information]' && ret=0
        ;;
      action)
        local -a actions=(
          'write:Write bytes to the terminal'
          'write-chars:Write characters to the terminal'
          'resize:Resize focused pane in specified direction'
          'focus-next-pane:Change focus to the next pane'
          'focus-previous-pane:Change focus to the previous pane'
          'move-focus:Move the focused pane in the specified direction'
          'move-focus-or-tab:Move focus or switch tab'
          'move-pane:Move the focused pane in the specified direction'
          'dump-screen:Dump the focused panes screen to a file'
          'edit-scrollback:Open the focused pane scrollback in default editor'
          'scroll-up:Scroll up in the focused pane'
          'scroll-down:Scroll down in the focused pane'
          'scroll-to-bottom:Scroll to bottom in the focused pane'
          'scroll-to-top:Scroll to top in the focused pane'
          'page-scroll-up:Scroll up a page in the focused pane'
          'page-scroll-down:Scroll down a page in the focused pane'
          'half-page-scroll-up:Scroll up half page in the focused pane'
          'half-page-scroll-down:Scroll down half page in the focused pane'
          'toggle-fullscreen:Toggle between fullscreen focused pane and normal'
          'toggle-pane-frames:Toggle frames around panes'
          'toggle-active-sync-tab:Toggle between sending text to all panes and just focused'
          'new-pane:Open a new pane'
          'close-pane:Close the focused pane'
          'rename-pane:Rename the focused pane'
          'rename-tab:Rename the focused tab'
          'undo-rename-pane:Remove a previously set pane name'
          'undo-rename-tab:Remove a previously set tab name'
          'go-to-tab:Go to the specified tab'
          'go-to-next-tab:Go to the next tab'
          'go-to-previous-tab:Go to the previous tab'
          'close-tab:Close the current tab'
          'new-tab:Open a new tab'
          'switch-mode:Switch input mode'
          'toggle-pane-embed-or-floating:Embed focused pane or float it'
          'toggle-floating-panes:Show or hide floating panes'
          'query-tab-names:Query all tab names'
          'start-or-reload-plugin:Start or reload a plugin'
          'launch-or-focus-plugin:Launch or focus a plugin'
          'launch-plugin:Launch a plugin'
        )
        _describe -t actions 'zellij action' actions && ret=0
        ;;
      run)
        _arguments -s -S \
          '-d+[Direction to open pane]:direction:(down right up left)' \
          '--direction=[Direction to open pane]:direction:(down right up left)' \
          '-f[Open pane as floating]' \
          '--floating[Open pane as floating]' \
          '--in-place[Open pane in-place, replacing current one]' \
          '-n+[Name of the new pane]:name' \
          '--name=[Name of the new pane]:name' \
          '-c[Close the pane immediately on exit]' \
          '--close-on-exit[Close the pane immediately on exit]' \
          '-s[Start the command suspended]' \
          '--start-suspended[Start the command suspended]' \
          '--cwd=[Working directory for pane]:dir:_directories' \
          '-h[Print help information]' \
          '--help[Print help information]' \
          '*::command:_command_names -e' && ret=0
        ;;
      edit)
        _arguments -s -S \
          '-d+[Direction to open pane]:direction:(down right up left)' \
          '--direction=[Direction to open pane]:direction:(down right up left)' \
          '-l+[Line number to open at]:line' \
          '--line-number=[Line number to open at]:line' \
          '-f[Open pane as floating]' \
          '--floating[Open pane as floating]' \
          '--in-place[Open pane in-place]' \
          '--cwd=[Working directory for pane]:dir:_directories' \
          '-h[Print help information]' \
          '--help[Print help information]' \
          '1:file:_files' && ret=0
        ;;
    esac

    if [[ $state == sessions ]]; then
      local -a sessions
      sessions=( ${(f)"$(zellij list-sessions 2>/dev/null | awk '{print $1}')"} )
      _describe -t sessions 'session' sessions && ret=0
    fi
    ;;
esac

return ret
