#compdef yb-ts-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'are_tablets_running:check if all tablets are running'
  'is_tablet_server_ready:check if server is ready'
  'set_flag:set a flag value'
  'refresh_flags:refresh flags from config'
  'reload_certificates:reload TLS certs'
  'remote_bootstrap:remote bootstrap a tablet'
  'list_tablets:list local tablets'
  'list_tablets_for_table:list tablets for a table'
  'delete_tablet:delete a tablet'
  'tablet_leader_stepdown:step down a tablet leader'
  'unsafe_config_change:unsafe Raft config change'
  'count_intents:count transaction intents'
  'flush_tablet:flush a specific tablet'
  'flush_all_tablets:flush all tablets'
  'compact_tablet:compact a specific tablet'
  'compact_all_tablets:compact all tablets'
  'remote_log_dump:dump remote log'
  'restart:restart the tablet server'
  'status:show tserver status'
  'set_metric_threshold:set metric threshold'
  'clear_universe_uuid:clear universe UUID'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--server_address=[tablet server address]:addr:' \
  '--certs_dir_name=[TLS certs dir]:dir:_files -/' \
  '--timeout_ms=[RPC timeout]:ms:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'yb-ts-cli subcommand' subcommands && ret=0
    ;;
esac

return ret
