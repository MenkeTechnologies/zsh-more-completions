#compdef cbindgen

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to cbindgen.toml]:config file:_files' \
  '--crate=[crate name]:crate' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '--lang=[target language]:language:(c c++ cython)' \
  '--cpp-compat[add C++ compatibility]' \
  '--only-tagged-enum[only generate tagged enums]' \
  '--lockfile=[path to Cargo.lock]:lockfile:_files -g "*.lock"' \
  '--metadata=[path to Cargo metadata]:metadata file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--verify[verify output matches existing file]' \
  '--depfile=[write a depfile]:depfile:_files' \
  '--profile=[cargo profile]:profile:(dev release test bench)' \
  '1:crate directory:_directories' && ret=0

return ret
