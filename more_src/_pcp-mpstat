#compdef pcp-mpstat

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-A+[archive]:file:_files' \
  '-H+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-P+[cpu]:cpu:(ALL ON OFF)' \
  '-V[show version]' \
  '-Z+[timezone]:tz:' \
  '-z[archive timezone]' \
  '*:interval count:' && ret=0

return ret
