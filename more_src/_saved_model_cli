#compdef saved_model_cli
# Documentation: https://man.archlinux.org/search?q=saved_model_cli
# Reference accessed: 2026-05-16

# saved_model_cli: inspect / run / aot-compile TensorFlow SavedModels
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'show:show metadata for SavedModel'
  'run:run a graph with given inputs'
  'scan:scan SavedModel for compatibility issues'
  'aot_compile_cpu:AOT compile SavedModel for CPU'
  'convert:convert a SavedModel (TFLite, etc.)'
  'freeze:freeze SavedModel into a constant graph'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--dir=[SavedModel directory]:dir:_files -/' \
  '--tag_set=[tag set]:tags:' \
  '--signature_def=[signature def key]:key:' \
  '--all[show all info]' \
  '--input_exprs=[input expressions]:expr:' \
  '--inputs=[inputs (key=file)]:inputs:' \
  '--input_examples=[example inputs]:examples:' \
  '--outdir=[output dir]:dir:_files -/' \
  '--overwrite[overwrite existing files]' \
  '--tf_debug[run with tf-debugger]' \
  '--worker=[worker target]:worker:' \
  '--init_tpu[init TPU]' \
  '--cpu_name=[target CPU name]:cpu:' \
  '--tag_def[tag def]:tag:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'saved_model_cli command' commands && ret=0 ;;
esac
return ret
