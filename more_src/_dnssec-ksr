#compdef dnssec-ksr
# Documentation: https://bind9.readthedocs.io/en/latest/manpages.html
# Source: isc-projects/bind9 bin/dnssec/dnssec-ksr.rst — generate Key Signing Requests/SKRs for offline KSK signing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-e+[end date for keys/SKRs]:date_or_offset:_default' \
    '-F[FIPS mode]' \
    '-f+[SKR file to sign]:file:_files' \
    '(- *)-h[show help]' \
    '-i+[start date for keys/SKRs]:date_or_offset:_default' \
    '-K+[key file directory]:dir:_directories' \
    '-k+[dnssec-policy name]:policy:_default' \
    '-l+[config file with dnssec-policy]:file:_files' \
    '-o[create KSKs instead of ZSKs]' \
    '(- *)-V[show version]' \
    '-v+[debugging level]:level:_default' \
    '1:command:(keygen request sign)' \
    '2:zone:_default' \
    && ret=0

return ret
