#compdef cmfetch
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/cmfetch.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmfetch: retrieve CM(s) by name from a CM database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[treat name argument as a file of names]' \
  '-o[output file]:file:_files' \
  '--index[index a CM database file]' \
  '*:CM database file and name:_files' && ret=0
return ret
