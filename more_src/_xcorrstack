#compdef xcorrstack
# Documentation: https://bio3d.colorado.edu/imod/doc/man/xcorrstack.html
# xcorrstack - cross-correlate images in a stack with a reference image

local ret=1

_arguments -s -S \
  '(-st --stack)'{-st,-stack}'[input file with stack of images to correlate]:file:_files' \
  '(-sin --single)'{-sin,-single}'[input file with single image to correlate with]:file:_files' \
  '(-o --output)'{-o,-output}'[output file for correlation images]:file:_files' \
  '(-se --sections)'{-se,-sections}'[starting and ending sections in the stack]:start,end' \
  '-rad1[low spatial frequencies in the correlation filter]:radius' \
  '-rad2[high spatial frequencies in the correlation filter]:radius' \
  '-sig1[sigma to filter low frequencies in the correlation]:sigma' \
  '-sig2[sigma for the Gaussian rolloff at high frequencies]:sigma' \
  '(-m --mode)'{-m,-mode}'[mode for correlation images (0 byte, 1 short, 2 float)]:mode' \
  '(-sp --split)'{-sp,-split}'[split single image into corners]' \
  '(-f --fill)'{-f,-fill}'[value to fill when embedding image into a larger one]:value' \
  '(-p --param)'{-p,-param}'[read parameter entries from this file]:file:_files' \
  '(-h --help)'{-h,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
