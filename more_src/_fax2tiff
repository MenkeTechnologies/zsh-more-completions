#compdef fax2tiff
# Documentation: fax2tiff usage (libtiff 4.7.1)
# Source: create a Class F fax TIFF from raw fax data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-3 -4 -U)-3[input is G3-encoded (default)]' \
    '(-3 -4 -U)-4[input is G4-encoded]' \
    '(-3 -4 -U)-U[input is uncompressed]' \
    '(-1 -2)-1[input is 1D-encoded (G3 only, default)]' \
    '(-1 -2)-2[input is 2D-encoded (G3 only)]' \
    '(-P -A)-P[input not EOL-aligned (default)]' \
    '(-P -A)-A[input is EOL-aligned (G3 only)]' \
    '(-M -L)-M[input has MSB2LSB bit order]' \
    '(-M -L)-L[input has LSB2MSB bit order (default)]' \
    '(-B -b -W -w)-B[input min 0 = black]' \
    '(-B -b -W -w)-b[input min 0 = black]' \
    '(-B -b -W -w)-W[input min 0 = white (default)]' \
    '(-B -b -W -w)-w[input min 0 = white]' \
    '-R+[input resolution (lines/inch, default 196)]:n:' \
    '-X+[input width (default 1728)]:n:' \
    '-o+[output TIFF file]:file:_files' \
    '(-7 -8 -u)-7[generate G3-encoded output (default)]' \
    '(-7 -8 -u)-8[generate G4-encoded output]' \
    '(-7 -8 -u)-u[generate uncompressed output]' \
    '-5[generate 1D-encoded output]' \
    '-6[generate 2D-encoded output]' \
    '-c+[compression scheme]:scheme:(none g3 g4 packbits lzw)' \
    '*:raw fax input:_files' \
    && ret=0

return ret
