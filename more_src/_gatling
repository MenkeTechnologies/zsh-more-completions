#compdef gatling

# Zsh completion for Gatling load testing tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-sf+[simulations folder]:directory:_directories' \
  '-rf+[results folder]:directory:_directories' \
  '-rsf+[resources folder]:directory:_directories' \
  '-s+[simulation class to run]:simulation class' \
  '-rd+[run description]:description' \
  '-nr[no reports - do not generate reports]' \
  '--run-mode=[run mode]:mode' \
  && ret=0

return ret
