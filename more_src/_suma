#compdef suma
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/suma.html
# AFNI SUMA surface visualization and analysis tool

local ret=1

_arguments -s \
  '-spec[load surfaces from spec file]:spec file:_files' \
  '-sv[anatomical surface volume]:dataset:_files' \
  '-ah[AFNI host name or IP]:host:_hosts' \
  '-i[load surface, type auto-detected]:surface:_files' \
  '-i_TYPE[load surface with explicit type]:surface:_files' \
  '-t_TYPE[surface type and name]:surface:_files' \
  '-tsn[surface type, state and name]:surface:_files' \
  '-onestate[make all input surfaces appear at once]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-niml[listen for NIML communication with AFNI]' \
  '-noniml[disable NIML communication]' \
  '-novolreg[ignore volume registration transforms]' \
  '-noxform[same as -novolreg]' \
  '-setenv[set environment variable]:var' \
  '-trace[enable debug and memory tracing]' \
  '-TRACE[extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing]' \
  '-dev[access experimental options]' \
  '-np[port offset]:offset' \
  '-npq[port offset quietly]:offset' \
  '-npb[port offset bloc]:bloc' \
  '-drive_com[execute DriveSuma commands]:command' \
  '-cdset[load and display CIFTI dataset]:dataset:_files' \
  '-gdset[load and display graph dataset]:dataset:_files' \
  '-tract[load and display tractography dataset]:dataset:_files' \
  '-vol[load and display volume]:dataset:_files' \
  '-input[read dataset as input]:dataset:_files' \
  '-update_env[update environment configuration]' \
  '-default_env[show default environment values]' \
  '-environment[list environment variables]' \
  '-progs[list SUMA package programs]' \
  '-version[show version]' \
  '(-h -help -HELP)-h[mini help]' \
  '(-h -help -HELP)-help[full help]' \
  '(-h -help -HELP)-HELP[extreme help]' \
  '-h_view[open help in text editor]' \
  '-h_web[open help in browser]' \
  '-h_find[search help for words]:word' \
  '*:surface:_files' && ret=0

return ret
