#compdef pegasus-remove
# Documentation: https://pegasus.isi.edu/documentation/manpages/pegasus-remove.html
# pegasus-remove - remove a workflow that has been planned and submitted

local ret=1

_arguments -s -S \
  '(-d --dagid)'{-d,--dagid}'=[the workflow dagid to remove]:dagid' \
  '(-v --verbose)'{-v,--verbose}'[raise debug level, each invocation increases by 1]' \
  '*:rundir:_files -/' && ret=0

return ret
