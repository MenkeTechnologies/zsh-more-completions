#compdef localtonet
# Documentation: https://localtonet.com/documents/linux
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--authtoken=[authenticate using token from dashboard]:token:' \
  '--install-service[register Localtonet as a systemd service]' \
  '--start-service[start the Localtonet service]' \
  '--stop-service[stop the running Localtonet service]' \
  '--status-service[return current status of the service]' \
  '--remove-service[stop and unregister the service from the OS]' \
  '--remote-port=[remote port for tunnel]:port:' \
  '--local-addr=[local address for tunnel]:address:' \
  '*::extra:' && ret=0

return ret
