#compdef localtonet

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--authtoken=[authenticate using token from dashboard]:token:' \
  '--token=[authenticate using token (alias)]:token:' \
  '--install-service[install as systemd service (Linux)]' \
  '--start-service[start the installed service]' \
  '--stop-service[stop the installed service]' \
  '--uninstall-service[uninstall the systemd service]' \
  '--service-status[show service status]' \
  '--region=[server region]:region:(us eu asia)' \
  '--type=[tunnel type]:type:(http https tcp udp tls fileserver proxy)' \
  '--port=[local port to expose]:port:' \
  '--host=[local host to expose]:host:_hosts' \
  '--subdomain=[custom subdomain (paid plans)]:subdomain:' \
  '--no-color[disable ANSI color output]' \
  '--verbose[verbose output]' \
  '*::extra:' && ret=0

return ret
