#compdef nighthawk_client
# Documentation: https://github.com/envoyproxy/nighthawk
# Envoy L7 (HTTP/HTTPS/HTTP2/HTTP3) performance characterization load tester

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--rps=[target requests-per-second rate]:rps:' \
  '--connections=[max concurrent connections per event loop]:count:' \
  '--duration=[number of seconds the test should run]:seconds:' \
  '--timeout=[connection and request timeout in seconds]:seconds:' \
  '--h2[use HTTP/2]' \
  '--protocol=[HTTP protocol to use]:protocol:' \
  '--concurrency=[number of concurrent event loops]:concurrency:' \
  '--output-format=[output format]:format:(human json yaml dotted fortio fortio-pedantic)' \
  '--prefetch-connections[prefetch connections before benchmarking]' \
  '--burst-size=[release requests in bursts of the specified size]:size:' \
  '--address-family=[IP address family to use]:family:(auto v4 v6)' \
  '--request-method=[HTTP request method]:method:(GET HEAD POST PUT DELETE CONNECT OPTIONS TRACE PATCH)' \
  '*--request-header=[HTTP request header "key:value"]:header:' \
  '--request-body-size=[request body size in bytes]:bytes:' \
  '--tls-context=[TLS context as JSON]:json:' \
  '--transport-socket=[transport socket configuration as JSON]:json:' \
  '--max-pending-requests=[max pending requests]:count:' \
  '--max-active-requests=[max active requests]:count:' \
  '--max-requests-per-connection=[max requests per connection]:count:' \
  '--max-concurrent-streams=[max concurrent streams on a connection]:count:' \
  '--sequencer-idle-strategy=[idle strategy of the sequencer]:strategy:(spin poll sleep)' \
  '--trace=[trace data sink URI]:uri:' \
  '--termination-predicate=[terminate when a counter reaches a threshold]:predicate:' \
  '--failure-predicate=[fail when a counter reaches a threshold]:predicate:' \
  '--no-default-failure-predicates[do not register default failure predicates]' \
  '--open-loop[run in open-loop mode]' \
  '--jitter-uniform=[add uniformly distributed jitter to request timing]:duration:' \
  '--nighthawk-service=[nighthawk gRPC service URI]:uri:' \
  '--label=[label, repeat for multiple]:label:' \
  '--simple-warmup[perform a simple warmup before benchmarking]' \
  '--no-duration[run until interrupted instead of for a fixed duration]' \
  '--verbosity=[logging verbosity]:level:(trace debug info warn error critical)' \
  '*:target uri:' && ret=0

return ret
