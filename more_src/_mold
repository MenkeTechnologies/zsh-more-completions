#compdef mold

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '*-l[link library]:library' \
  '*-L[library search path]:directory:_directories' \
  '-shared[create shared library]' \
  '-static[create static binary]' \
  '-pie[create position-independent executable]' \
  '-no-pie[do not create position-independent executable]' \
  '--sysroot[set system root]:directory:_directories' \
  '*-rpath[add runtime library path]:path:_directories' \
  '-soname[set shared object name]:name' \
  '--version-script[version script]:file:_files' \
  '-Map[write link map]:file:_files' \
  '--threads[number of threads]:threads' \
  '--hash-style[hash style]:style:(sysv gnu both)' \
  '--build-id[generate build ID]' \
  '--no-undefined[report undefined symbols]' \
  '--as-needed[link only needed libraries]' \
  '--no-as-needed[link all specified libraries]' \
  '--whole-archive[include entire archive]' \
  '--no-whole-archive[include only needed objects from archive]' \
  '*-z[linker keyword]:keyword:(now lazy relro norelro text notext defs nodefs)' \
  '--dynamic-linker[set dynamic linker]:path:_files' \
  '(-e --entry)'{-e,--entry}'[set entry point]:symbol' \
  '-init[initialization function]:symbol' \
  '-fini[finalization function]:symbol' \
  '--gc-sections[garbage collect unused sections]' \
  '--print-gc-sections[print removed sections]' \
  '--icf[identical code folding]:mode:(none safe all)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:input file:_files' && ret=0
return ret
