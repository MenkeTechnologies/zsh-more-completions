#compdef chrome-history
# Documentation: https://man.archlinux.org/search?q=chrome-history
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-v[Show version]'
    '--version[Show version]'
    '-n[Number of results]:count'
    '--limit[Number of results]:count'
    '*:search query:'
)

_arguments -s -S $arguments
