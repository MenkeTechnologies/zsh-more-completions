#compdef cloudsploit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--cloud[cloud provider]:provider:(aws azure gcp oracle github)' \
  '--config[config file]:file:_files -g "*.json(|.js)"' \
  '--compliance[compliance framework]:framework:(hipaa pci cis1 cis2)' \
  '--plugin[specific plugin to run]:plugin:' \
  '--ignore-ok[suppress passing results]' \
  '--csv[output results to CSV file]:file:_files' \
  '--json[output results to JSON file]:file:_files' \
  '--junit[output results to JUnit XML]:file:_files' \
  '--console[output format]:format:(none text)' \
  '--collection[collection file]:file:_files' \
  '--remediate[auto-remediate findings]' \
  '--suppress[suppress specific plugins]:plugins:' \
  '(-h --help)'{-h,--help}'[show help]' \
  && ret=0

return ret
