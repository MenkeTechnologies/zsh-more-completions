#compdef mesh-cfgclient
# Documentation: https://manpages.debian.org/trixie/bluez-meshd/mesh-cfgclient.1.en.html
# mesh-cfgclient — BlueZ Bluetooth Mesh network configuration client

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '--config=[configuration file]:file:_files' \
  '--address-start=[starting unicast address for remote nodes]:address:' \
  '--address-range=[net index for provisioning subnet]:range:' \
  '--net-index=[network index]:index:' \
  '--monitor[enable monitor output]' \
  '--timeout=[timeout in seconds for non-interactive mode]:seconds:' \
  '*:command:(create discover-unprovisioned appkey-create appkey-import appkey-update appkey-delete subnet-create subnet-import subnet-update subnet-delete subnet-set-phase list-unprovisioned provision node-import list-nodes keys)' && ret=0

return ret
