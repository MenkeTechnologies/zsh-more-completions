#compdef chef-zero
# _chef-zero — Chef chef-zero CLI for the in-memory Chef Server running as standalone process for development testing supporting REST API endpoints for cookbooks nodes roles data-bags environments clients (chef team, Ruby); getopt
# upstream: https://github.com/chef/chef-zero

_chef-zero() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-H+[host]:h:_hosts' \
        '--host=+[host]:h:_hosts' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-d[daemonize]' \
        '--daemon[daemonize]' \
        '-D+[data dir]:dir:_files -/' \
        '--data-store=+[data dir]:dir:_files -/' \
        '--osc-compat[OSC compat]' \
        '--enterprise[enterprise mode]' \
        '--multi-org[multi-org]' \
        '--no-multi-org[no multi-org]' \
        '--single-org=+[org]:str:' \
        '--ssl[enable SSL]' \
        '--log-level=+[level]:l:(debug info warn error fatal)' \
        '-l+[log level]:l:(debug info warn error fatal)' \
        '--log-file=+[file]:file:_files' \
        '--socket[use UNIX socket]' \
        '--no-socket[no UNIX socket]' \
        '--listen=+[host:port]:str:' \
        '-L+[host:port]:str:' \
        '-N[no socket]' \
        '--no-color[no color]' \
        '--cookies[enable cookies]' \
        '--pid-file=+[file]:file:_files' \
        '--certfile=+[file]:file:_files -g "*.pem *.crt"' \
        '--keyfile=+[file]:file:_files -g "*.pem *.key"' \
        '--no-signal-handler[no signal handler]'
}

_chef-zero "$@"
