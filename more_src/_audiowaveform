#compdef audiowaveform
# Documentation: https://github.com/bbc/audiowaveform
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# BBC audiowaveform — Options::parseCommandLine in src/Options.cpp (boost program_options).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-i --input-filename)'{-i,--input-filename}"=[input media/dat/json]:file:_files" \
  '(-o --output-filename)'{-o,--output-filename}"=[output wav/dat/png/json]:file:_files" \
  '--split-channels[multi-channel outputs]' \
  '--input-format=[force input format]:format:(mp3 wav flac ogg raw opus dat json)' \
  '--output-format=[force output format]:format:(wav dat png json)' \
  '(-z --zoom)'{-z,--zoom}"=[samples per pixel]:zoom" \
  '--pixels-per-second=[zoom by px/sec]:int' \
  '(-b --bits)'{-b,--bits}"=[8 or 16]:int:(8 16)" \
  '(-s --start)'{-s,--start}"=[start seconds]:float" \
  '(-e --end)'{-e,--end}"=[end seconds]:float" \
  '(-w --width)'{-w,--width}"=[PNG width]:int" \
  '(-h --height)'{-h,--height}"=[PNG height]:int" \
  '(-c --colors)'{-c,--colors}"=[color scheme]:scheme:(audition audacity)" \
  '--waveform-style=[style]:style:(normal bars)' \
  '--bar-width=[bar width px]:int' \
  '--bar-gap=[bar gap px]:int' \
  '--waveform-color=[rrggbb color(s)]' \
  '--compression=[PNG level -1..9]:int' \
  '--raw-samplerate=[Hz for raw input]:int' \
  '--raw-channels=[channels for raw input]:int' \
  '--raw-format=[raw sample format]:fmt:(s8 u8 s16le s16be s24le s24be s32le s32be f32le f32be f64le f64be)' && ret=0

return ret
