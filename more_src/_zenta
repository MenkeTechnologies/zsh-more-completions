#compdef zenta

_zenta() {
    local line state
    local -a commands
    commands=(
        'now:Start a breathing session'
        'anchor:Interactive breathing to find rhythm'
        'reflect:Evening review/reflection mode'
    )

    _arguments -C \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'zenta command' commands
            ;;
        args)
            case $line[1] in
                now)
                    _arguments '--quick[Quick 1-breath cycle]'
                    ;;
            esac
            ;;
    esac
}

_zenta "$@"
