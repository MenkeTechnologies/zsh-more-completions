#compdef dumphint
# Print the hint tables of a linearized PDF file (to stdout) in an easy-to-read form
# Documentation: https://web.mit.edu/ghostscript/www/Psfiles.htm
# Reference accessed: 2026-06-21

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:linearized PDF file:_files -g "*.(pdf|PDF)"' && ret=0

return ret
