#compdef dns-controller-manager-next-generation
# _dns-controller-manager-next-generation — Gardener external-dns-management v2 controller
# upstream: https://github.com/gardener/external-dns-management
# Flags from cmd/nextgen/app/app.go on tip.

_dns-controller-manager-next-generation() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[next-generation config file]:file:_files -g "*.(yaml|yml)"' \
        '-v[force debug log level]' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_dns-controller-manager-next-generation "$@"
