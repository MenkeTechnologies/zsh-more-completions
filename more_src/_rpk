#compdef rpk

local -a _rpk_commands
_rpk_commands=(
  'acl:manage ACLs'
  'cluster:manage cluster'
  'container:manage Redpanda containers'
  'debug:debug tools'
  'generate:generate configurations'
  'group:manage consumer groups'
  'help:help about any command'
  'iotune:measure I/O performance'
  'plugin:manage plugins'
  'profile:manage rpk profiles'
  'redpanda:manage Redpanda'
  'registry:manage schema registry'
  'topic:manage topics'
  'transform:manage data transforms'
  'version:show version'
  'cloud:manage Redpanda Cloud'
  'connect:manage Redpanda Connect'
  'security:manage security'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--brokers[broker addresses]:brokers' \
  '--config[config file]:file:_files' \
  '--api-urls[admin API URLs]:urls' \
  '--tls-cert[TLS certificate]:file:_files' \
  '--tls-key[TLS key]:file:_files' \
  '--tls-truststore[TLS CA certificate]:file:_files' \
  '--sasl-mechanism[SASL mechanism]:mechanism:(SCRAM-SHA-256 SCRAM-SHA-512)' \
  '--user[SASL username]:user' \
  '--password[SASL password]:password' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'rpk commands' _rpk_commands
    ;;
  args)
    case "$words[1]" in
      topic)
        local -a topic_cmds=(
          'add-partitions:add partitions to a topic'
          'alter-config:alter topic configuration'
          'consume:consume records'
          'create:create a topic'
          'delete:delete a topic'
          'describe:describe a topic'
          'list:list topics'
          'produce:produce records'
          'trim-prefix:trim prefix from topic'
        )
        _arguments -C '1:subcommand:->subcmds' '*::arg:->subargs'
        case "$state" in
          subcmds) _describe -t commands 'topic commands' topic_cmds ;;
          subargs)
            case "$words[1]" in
              create)
                _arguments \
                  '(-p --partitions)'{-p,--partitions}'[partitions]:count' \
                  '(-r --replicas)'{-r,--replicas}'[replication factor]:factor' \
                  '(-c --topic-config)'{-c,--topic-config}'[topic config key=val]:config' \
                  '*:topic name'
                ;;
              produce)
                _arguments \
                  '(-k --key)'{-k,--key}'[record key]:key' \
                  '(-H --header)'{-H,--header}'[header key:val]:header' \
                  '--compression[compression]:codec:(none gzip snappy lz4 zstd)' \
                  '-f[format string]:format' \
                  '*:topic name'
                ;;
              consume)
                _arguments \
                  '(-g --group)'{-g,--group}'[consumer group]:group' \
                  '(-n --num)'{-n,--num}'[number of records]:count' \
                  '(-o --offset)'{-o,--offset}'[offset]:offset:(start end)' \
                  '-f[format string]:format' \
                  '--partitions[partitions]:partitions' \
                  '*:topic name'
                ;;
              delete)
                _arguments '*:topic name'
                ;;
              describe)
                _arguments \
                  '--print-all[print all details]' \
                  '-p[print partitions]' \
                  '-s[print summary]' \
                  '-c[print configs]' \
                  '*:topic name'
                ;;
            esac
            ;;
        esac
        ;;
      group)
        _arguments -C '1:subcommand:(describe delete list seek)' '*::arg:->gargs'
        ;;
      cluster)
        _arguments -C '1:subcommand:(config health info license logdirs maintenance metadata offsets partitions self-test storage txn)' '*::arg:->cargs'
        ;;
      acl)
        _arguments -C '1:subcommand:(create delete list user)' '*::arg:->aargs'
        ;;
      container)
        _arguments -C '1:subcommand:(start stop purge status)' '*::arg:->ctargs'
        ;;
      registry)
        _arguments -C '1:subcommand:(compatibility mode schema subject)' '*::arg:->rargs'
        ;;
      profile)
        _arguments -C '1:subcommand:(create delete edit list print-defaults set use current)' '*::arg:->pargs'
        ;;
      redpanda)
        _arguments -C '1:subcommand:(admin check config mode start stop tune)' '*::arg:->rdargs'
        ;;
    esac
    ;;
esac
