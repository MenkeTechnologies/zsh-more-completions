#compdef bundle bundler
# Documentation: bundle help + bundler.io docs
# Source: Ruby Bundler — gem dependency manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'add:add a gem to the Gemfile'
    'binstubs:install binstubs for a gem'
    'cache:package .gem files into vendor/cache'
    'check:check that gems are installed'
    'clean:remove unused gems'
    'config:set or list bundler config'
    'console:start IRB with the bundle loaded'
    'doctor:diagnose issues with the bundle'
    'exec:execute a command within the bundle context'
    'fund:list gems requesting funding'
    'gem:scaffold a new gem'
    'help:show help for a subcommand'
    'info:print information about a gem'
    'init:create a new Gemfile'
    'inject:add a gem to the Gemfile (alias of add)'
    'install:install the dependencies in Gemfile'
    'list:list installed gems'
    'lock:generate or update Gemfile.lock'
    'open:open the source of a gem'
    'outdated:list outdated gems'
    'platform:display platform info'
    'plugin:manage bundler plugins'
    'pristine:restore installed gems to pristine state'
    'remove:remove a gem from the Gemfile'
    'show:show installed gems'
    'update:update gem versions'
    'version:show bundler version'
    'viz:visualize the dependency graph'
)

local -a global_opts
global_opts=(
    '(-V --verbose)'{-V,--verbose}'[verbose logging]'
    '--no-color[disable colored output]'
    '(-r --retry)'{-r,--retry=}'[number of network retries]:n:'
)

_arguments -C \
    $global_opts \
    '(- *)--help[show help]' \
    '(- *)--version[show bundler version]' \
    '1: :->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        _describe -t bundle-verbs 'bundle subcommand' verbs && ret=0
        ;;
    args)
        case $line[1] in
            install)
                _arguments \
                    $global_opts \
                    '(-j --jobs)'{-j,--jobs=}'[parallel jobs]:n:' \
                    '--deployment[deployment mode]' \
                    '--frozen[disallow Gemfile.lock updates]' \
                    '*--without=[gem groups to skip]:groups:' \
                    '*--with=[gem groups to include]:groups:' \
                    '--binstubs=[install binstubs in DIR]:dir:_files -/' \
                    '--clean[remove unused gems after install]' \
                    '--full-index[do not use compact index]' \
                    '--gemfile=[use a different Gemfile]:file:_files' \
                    '--local[do not contact remote sources]' \
                    '--no-cache[do not update cached gems]' \
                    '--no-prune[do not remove unused gems]' \
                    '--path=[install gems to PATH]:dir:_files -/' \
                    '--quiet[suppress install output]' \
                    '--redownload[redownload every gem]' \
                    '--shebang=[ruby shebang for binstubs]:ruby:' \
                    '--standalone=[generate standalone bundler]:groups:' \
                    '--system[install gems system-wide]' \
                    '--trust-policy=[gem trust policy]:policy:(NoSecurity AlmostNoSecurity LowSecurity MediumSecurity HighSecurity)' \
                    && ret=0
                ;;
            add)
                _arguments \
                    $global_opts \
                    '--version=[gem version constraint]:version:' \
                    '--group=[Gemfile group]:group:' \
                    '--source=[gem source]:source:' \
                    '--git=[git URL]:url:' \
                    '--branch=[git branch]:branch:' \
                    '--skip-install[do not install]' \
                    '1:gem name:' \
                    && ret=0
                ;;
            exec)
                _arguments \
                    $global_opts \
                    '*:command + args:_command_names -e' \
                    && ret=0
                ;;
            *)
                _files && ret=0
                ;;
        esac
        ;;
esac

return ret
