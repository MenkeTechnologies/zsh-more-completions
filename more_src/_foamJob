#compdef foamJob
# Documentation: https://man.archlinux.org/search?q=foamJob
# Reference accessed: 2026-05-16

# OpenFOAM foamJob: submit OpenFOAM solver as a background job
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-screen[also output to screen]' \
  '-append[append to log file]' \
  '-wait[wait for job to finish]' \
  '-version[OpenFOAM version]:version:' \
  '-parallel[parallel mode]' \
  '*::OpenFOAM solver and args:_files' && ret=0
return ret
