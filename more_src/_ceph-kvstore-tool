#compdef ceph-kvstore-tool
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-kvstore-tool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-kvstore-tool: leveldb/rocksdb store inspection
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:store backend:(leveldb rocksdb bluestore-kv)' \
  '2:store path:_files -/' \
  '*:kvstore command:(list list-crc dump exists get crc get-size stats histogram set rm rm-prefix compact compact-prefix compact-range destructive-repair store-copy store-crc)' && ret=0
return ret
