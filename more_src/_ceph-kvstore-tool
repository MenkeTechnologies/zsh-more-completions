#compdef ceph-kvstore-tool

# ceph-kvstore-tool: leveldb/rocksdb store inspection
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '1:store backend:(leveldb rocksdb bluestore-kv)' \
  '2:store path:_files -/' \
  '*:kvstore command:(list list-crc dump exists get crc compact compact-prefix compact-range destructive-repair stats histogram)' && ret=0
return ret
