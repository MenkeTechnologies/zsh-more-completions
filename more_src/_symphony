#compdef symphony
# Documentation: https://github.com/coin-or/SYMPHONY
# SYMPHONY mixed-integer linear programming solver

local ret=1

_arguments -s \
  '-h[display help]' \
  '-F[read model from file in MPS format]:model:_files' \
  '-L[read model in LP format from file]:model:_files' \
  '-D[specify GMPL data file]:data:_files' \
  '-T[run test with MIPLIB3 models]:dir:_files -/' \
  '-f[read parameters from parameter file]:file:_files' \
  '-d[stop at first feasible solution]' \
  '-a[enable/disable primal heuristics]:flag:(0 1)' \
  '-b[enable/disable reliability branching]:flag:(0 1)' \
  '-s[maximum candidates for strong branching]:cands' \
  '-l[limit strong branching time]:flag:(0 1)' \
  '-q[tighten root bounds]:flag:(0 1)' \
  '-r[reduced cost tightening]:flag:(0 1)' \
  '-j[generate CGL cuts]:flag:(0 1)' \
  '-w[hot starting in strong branching]:flag:(0 1)' \
  '-e[pre-processing level]:level' \
  '-i[maximum presolve iterations]:iters' \
  '-t[wallclock time limit]:time' \
  '-g[gap limit]:gap' \
  '-n[node limit]:nodes' \
  '-u[initial upper bound]:ub' \
  '-p[additional threads/processors]:procs' \
  '-k[node selection rule]:rule' \
  '-v[verbosity level]:level' \
  '-c[candidate comparison rule]:rule' \
  '-m[maximum cuts per iteration]:max' \
  '-z[diving threshold]:n' \
  '-o[output tree information to file]:file:_files' \
  '*:file:_files' && ret=0

return ret
