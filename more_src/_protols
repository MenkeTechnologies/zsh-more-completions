#compdef protols
# Documentation: https://github.com/coder3101/protols
# protols - Protocol Buffers (protobuf) language server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '--version[display version information]' \
  '*'{-i,--include-paths}'=[set include paths for proto files, comma-separated]:paths:_files -/' \
  '--stdio[use stdin/stdout for communication, default]' \
  '--socket=[use TCP communication with specific address and port]:addr' \
  '--port=[use TCP communication on localhost with specific port]:port' \
  '--pipe=[use Unix domain socket or named pipe]:path:_files' && ret=0

return ret
