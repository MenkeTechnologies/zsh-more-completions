#compdef ffuf2
# _ffuf2 — Joohoi ffuf2 CLI command-line frontend wrapping the ffuf Fast web Fuzzer written in Go open-source content discovery directory brute force virtual host discovery GET parameter and POST parameter fuzzing filter mode matcher mode automatic-calibration multiple-wordlist-mode-pitchfork-clusterbomb HTML-JSON-CSV-output Markdown-output recursion request-file-mode Burp Suite raw-request-replay rate-limit auto-calibration colors per-host (Joohoi team, Go); flag
# upstream: https://github.com/ffuf/ffuf

_ffuf2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[target URL]:str:' \
        '-w+[wordlist:keyword]:str:' \
        '*-w+[wordlist:keyword]:str:' \
        '-H+[header name: value]:str:' \
        '*-H+[header]:str:' \
        '-X+[HTTP method]:m:(GET HEAD POST PUT DELETE PATCH OPTIONS TRACE)' \
        '-d+[POST data]:str:' \
        '-b+[cookie header]:str:' \
        '-r[follow redirects]' \
        '-c[colorize output]' \
        '-config+[file]:file:_files -g "*.json"' \
        '-x+[proxy URL]:str:' \
        '-replay-proxy+[url]:str:' \
        '-recursion[recursion]' \
        '-recursion-depth+[N]:n:' \
        '-recursion-strategy+[s]:s:(default greedy)' \
        '-mc+[match codes]:str:' \
        '-ml+[match lines]:str:' \
        '-mr+[match regex]:str:' \
        '-ms+[match size]:str:' \
        '-mw+[match words]:str:' \
        '-mt+[match time ms]:str:' \
        '-fc+[filter codes]:str:' \
        '-fl+[filter lines]:str:' \
        '-fr+[filter regex]:str:' \
        '-fs+[filter size]:str:' \
        '-fw+[filter words]:str:' \
        '-ft+[filter time ms]:str:' \
        '-ac[auto calibration]' \
        '-acc+[auto calibration custom]:str:' \
        '-ack+[auto calibration keyword]:str:' \
        '-mode+[mode]:m:(clusterbomb pitchfork sniper)' \
        '-t+[threads]:n:' \
        '-rate+[N]:n:' \
        '-p+[delay sec]:str:' \
        '-timeout+[sec]:n:' \
        '-maxtime+[sec]:n:' \
        '-maxtime-job+[sec]:n:' \
        '-o+[output file]:file:_files' \
        '-of+[output format]:f:(json ejson html md csv ecsv all)' \
        '-od+[output dir]:dir:_files -/' \
        '-or[only matched output]' \
        '-s[silent mode]' \
        '-sa[stop on all errors]' \
        '-se[stop on spurious errors]' \
        '-sf[stop on too many 403]' \
        '-noninteractive[non interactive]' \
        '-json[JSON output]' \
        '-ic[ignore wordlist comments]' \
        '-input-cmd+[command]:str:' \
        '-input-num+[N]:n:' \
        '-e+[extensions]:str:' \
        '-D[DirSearch wordlist compatibility]' \
        '-debug-log+[file]:file:_files' \
        '*:args:'
}

_ffuf2 "$@"
