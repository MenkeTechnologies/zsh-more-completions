#compdef eix-sync
# Gentoo eix sync wrapper

local ret=1

_arguments -s -S \
  '-q[quiet mode]' \
  '-i[ignore sync errors]' \
  '-S[sync only, do not update eix database]' \
  '-u[update only, do not sync]' \
  '-M[run emerge --metadata]' \
  '-t[use timestamps for eix update]' \
  '-F[force sync]' \
  '-c[clear eix cache]' \
  '-a[sync all overlays]' \
  '-H[suppress status line]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
