#compdef terravision
# Documentation: https://github.com/patrickchugh/terravision
# terravision - generate cloud architecture diagrams from Terraform code

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--source=[Terraform directory or Git repository URL]:source' \
  '--format=[output format]:format:(png svg pdf drawio)' \
  '--outfile=[custom output filename]:file:_files' \
  '--workspace=[Terraform workspace]:workspace' \
  '*--varfile=[variable file path]:file:_files' \
  '--planfile=[pre-generated Terraform plan JSON file]:file:_files' \
  '--graphfile=[pre-generated graph DOT file]:file:_files' \
  '--ai-annotate=[enable AI annotations]:backend:(ollama bedrock restapi)' \
  '--simplified[high-level view excluding networking infrastructure]' \
  '--show[automatically open diagram after generation]' \
  '1:command:(draw visualise)' \
  '*::arg:_files' && ret=0

return ret
