#compdef vsphere-astrolabe astrolabe
# _vsphere-astrolabe — Astrolabe vSphere snapshot/clone CLI (Velero vSphere plugin bundles this binary for FCD operations)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-vsphere
# Source: cmd/vsphere-astrolabe/main.go on tip; subcommands come from github.com/vmware-tanzu/astrolabe/pkg/cmd CliCore (cobra).

_vsphere-astrolabe() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[Astrolabe config directory]:dir:_files -/' \
        '--confDir=[Astrolabe config directory]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                show:'show information about a protected entity'
                ls:'list protected entities of a given type'
                lspes:'list protected entity instances of a type'
                copy:'copy a protected entity from one type to another (e.g. ivd -> s3)'
                snapshot:'create or list snapshots of a protected entity'
                deletesnapshot:'delete a snapshot of a protected entity'
                getmd:'get the metadata of a protected entity'
                gets:'serialize a protected entity to disk'
                server:'run the Astrolabe HTTP server'
            )
            _describe -t commands 'astrolabe subcommand' subs
            ;;
    esac
}

_vsphere-astrolabe "$@"
