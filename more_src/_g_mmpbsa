#compdef g_mmpbsa
# Documentation: https://g-mmpbsa.readthedocs.io/en/stable/commands/run.html
# MM/PBSA binding-energy calculation for GROMACS trajectories

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-f[input trajectory or configuration]:traj:_files' \
  '-s[input structure (tpr)]:tpr:_files -g "*.tpr"' \
  '-n[index file with groups]:ndx:_files -g "*.ndx"' \
  '-i[input parameters for PBSA calculations]:mdp:_files' \
  '-ipdb[optional PDB for residue energy output]:pdb:_files -g "*.pdb"' \
  '-opdb[output PDB with residue energy in b-factor]:pdb:_files' \
  '-mm[vacuum MM energy over time]:xvg:_files' \
  '-pol[polar solvation energy over time]:xvg:_files' \
  '-apol[apolar solvation energy over time]:xvg:_files' \
  '-mmcon[residue-wise vacuum MM energy per frame]:dat:_files' \
  '-pcon[residue-wise polar solvation energy per frame]:dat:_files' \
  '-apcon[residue-wise non-polar solvation energy per frame]:dat:_files' \
  '-o[final binding energy and components]:dat:_files' \
  '-os[summary of binding energy over frames (CSV)]:csv:_files' \
  '-ores[summary of residue contributions (CSV)]:csv:_files' \
  '-b[first frame time]:time' \
  '-e[last frame time]:time' \
  '-dt[frame sampling interval]:time' \
  '-tu[time unit]:unit:(fs ps ns us ms s)' \
  '-[no]mme[calculate vacuum MM energy]' \
  '-[no]pbsa[enable polar/non-polar solvation]' \
  '-[no]diff[calculate energy difference between groups]' \
  '-[no]decomp[residue-wise energy decomposition]' \
  '-[no]incl_14[include 1-4 atom pairs in MM]' \
  '-[no]ddc[distance-dependent dielectric constant]' \
  '-[no]focus[region-specific focusing]' \
  '-[no]silent[suppress APBS output]' \
  '-pdie[solute dielectric constant (default 1.0)]:value' \
  '-rvdw[default van der Waals radius nm (default 0.1)]:value' \
  '-ndots[dots per sphere for SASA (default 24)]:n' \
  '-unit1[select protein/first group]:group' \
  '-unit2[select ligand/second group]:group' \
  '-xvg[plot format]:fmt:(xmgrace xmgr none)' \
  '*:file:_files' && ret=0

return ret
