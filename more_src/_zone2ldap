#compdef zone2ldap
# Documentation: https://doc.powerdns.com/authoritative/manpages/zone2ldap.1.html
# Transform BIND zone files into LDIF format for LDAP insertion

local ret=1

_arguments -s -S \
  '--help[display a summary of available options]' \
  '--basedn=[base DN where directory objects are stored]:dn:' \
  '--dnsttl[include dnsttl attribute in every entry]' \
  '--layout=[directory entry arrangement method]:layout:(simple tree)' \
  '--named-conf=[path to BIND named.conf to parse]:path:_files' \
  '--resume[proceed despite conversion errors]' \
  '--verbose[enable detailed output]' \
  '--zone-file=[zone file path for conversion]:path:_files' \
  '--zone-name=[zone name when processing zone data]:name:' && ret=0

return ret
