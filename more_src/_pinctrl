#compdef pinctrl
# Documentation: https://github.com/raspberrypi/utils/blob/master/pinctrl/README.md
# Raspberry Pi GPIO and pin mux inspector/setter (replacement for raspi-gpio)

local ret=1

_arguments -s \
  '(-h)-h[show help]' \
  '(-p)-p[switch UI to 40-way header pin numbering]' \
  '(-v)-v[verbose output]' \
  '(-e)-e[echo command being run]' \
  '(-l)-l[list known GPIO chips]' \
  '-c[select GPIO chip]:chip:' \
  '1:command:(get set poll funcs lev level)' \
  '*:: :->args' && ret=0

case $state in
  args)
    _values 'set option' \
      'ip[set GPIO as input]' \
      'op[set GPIO as output]' \
      'no[set GPIO to no function]' \
      'a0[alternate function 0]' \
      'a1[alternate function 1]' \
      'a2[alternate function 2]' \
      'a3[alternate function 3]' \
      'a4[alternate function 4]' \
      'a5[alternate function 5]' \
      'a6[alternate function 6]' \
      'a7[alternate function 7]' \
      'a8[alternate function 8]' \
      'pu[in-pad pull up]' \
      'pd[in-pad pull down]' \
      'pn[pull none]' \
      'dh[drive high level]' \
      'dl[drive low level]' && ret=0
    ;;
esac

return ret
