#compdef ah artifacthub
# Documentation: https://github.com/artifacthub/hub (cmd/ah/ah.go + cmd/ah/lint.go)
# Reference accessed: 2026-05-29
# ArtifactHub command-line tool (lint repository packages).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'lint:lint Artifact Hub repository packages'
  'version:show ah version information'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'ah subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      lint)
        _arguments \
          '(-k --kind)'{-k,--kind=}'[repository kind to lint]:kind:(argo-template backstage bootc coredns falco gatekeeper headlamp helm helm-plugin inspektor-gadget kagent kcl keda-scaler keptn knative-client-plugin krew kubearmor kubewarden kyverno meshery olm opa opencost radius tbaction tekton-pipeline tekton-stepaction tekton-task)' \
          '(-p --path)'{-p,--path=}'[base directory containing packages (default .)]:dir:_directories' \
          '--tekton-versioning=[Tekton versioning strategy]:strategy:(directory git)' && ret=0
        ;;
    esac
    ;;
esac

return ret
