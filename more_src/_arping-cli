#compdef arping
# Documentation: https://man.archlinux.org/search?q=arping
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-A[only ARP REQUEST]' \
  '-b[only broadcast]' \
  '-c+[count]:n:' \
  '-D[duplicate detection mode]' \
  '-f[exit on reply]' \
  '-I+[interface]:if:_net_interfaces' \
  '-i+[interval s]:s:' \
  '-q[quiet]' \
  '-s+[source IP]:ip:' \
  '-S+[source IP]:ip:' \
  '-t+[target MAC]:mac:' \
  '-T+[target IP]:ip:' \
  '-U[update neighbours]' \
  '-w+[deadline s]:s:' \
  '-i+[wait between ms]:ms:' \
  '*: :' && ret=0

return ret
