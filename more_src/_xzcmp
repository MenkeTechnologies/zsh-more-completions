#compdef xzcmp xzdiff lzcmp lzdiff
# _xzcmp — XZ Utils xzcmp / xzdiff (decompress .xz/.lzma/.gz/.bz2/.lz/.zst inputs to temp files then run cmp(1) or diff(1); --help/--version are local, all other options forwarded)
# upstream: https://github.com/tukaani-project/xz
# Forwarded options match cmp(1) / diff(1); see xz/src/scripts/xzdiff.in on tip.

_xzcmp() {
    _arguments \
        '--help[show help + exit]' \
        '--version[show version + exit]' \
        '*:file:_files'
}

_xzcmp "$@"
