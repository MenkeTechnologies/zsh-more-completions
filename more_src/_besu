#compdef besu
# Documentation: https://besu.hyperledger.org/public-networks/reference/cli/options
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'blocks:import/export blocks'
  'public-key:print derived public key'
  'password:hash password'
  'operator:operator actions'
  'rlp:RLP encode/decode actions'
  'storage:storage operations'
  'subscribe:subscribe to events'
  'retesteth:run retesteth tool'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-file=[Besu config TOML]:file:_files' \
  '--data-path=[data directory]:dir:_files -/' \
  '--genesis-file=[custom genesis JSON]:file:_files' \
  '--network=[network]:net:(MAINNET SEPOLIA HOLESKY HOODI EPHEMERY DEV CLASSIC KOTTI MORDOR ASTOR FUTUREEIPS EXPERIMENTALEIPS SHANDONG GOERLI RINKEBY ROPSTEN)' \
  '--network-id=[custom network ID]:n:' \
  '--profile=[node profile]:p:(default minimalist_staker staker enterprise)' \
  '--sync-mode=[sync mode]:mode:(FAST FULL SNAP CHECKPOINT X_SNAP X_CHECKPOINT)' \
  '--bonsai-historical-block-limit=[bonsai history blocks]:n:' \
  '--rpc-http-enabled[enable HTTP-RPC]' \
  '--rpc-http-host=[HTTP-RPC host]:host:' \
  '--rpc-http-port=[HTTP-RPC port]:port:' \
  '--rpc-http-cors-origins=[CORS origins csv]:list:' \
  '--rpc-http-api=[HTTP API csv]:apis:' \
  '--rpc-http-authentication-enabled[enable HTTP RPC auth]' \
  '--rpc-ws-enabled[enable WS-RPC]' \
  '--rpc-ws-host=[WS-RPC host]:host:' \
  '--rpc-ws-port=[WS-RPC port]:port:' \
  '--rpc-ws-api=[WS API csv]:apis:' \
  '--graphql-http-enabled[enable GraphQL]' \
  '--engine-rpc-enabled[enable engine RPC]' \
  '--engine-rpc-port=[engine RPC port]:port:' \
  '--engine-jwt-secret=[JWT secret file]:file:_files' \
  '--engine-host-allowlist=[engine vhost csv]:list:' \
  '--p2p-enabled[enable P2P]' \
  '--p2p-host=[P2P host]:host:' \
  '--p2p-port=[P2P port]:port:' \
  '--max-peers=[max peers]:n:' \
  '--bootnodes=[bootnodes csv]:list:' \
  '--node-private-key-file=[node private key file]:file:_files' \
  '--miner-enabled[enable mining]' \
  '--miner-coinbase=[coinbase address]:addr:' \
  '--miner-extra-data=[extra data]:data:' \
  '--metrics-enabled[enable metrics]' \
  '--metrics-host=[metrics host]:host:' \
  '--metrics-port=[metrics port]:port:' \
  '--metrics-protocol=[metrics protocol]:proto:(prometheus opentelemetry none)' \
  '--logging=[log level]:lvl:(OFF FATAL ERROR WARN INFO DEBUG TRACE ALL)' \
  '--Xplugins-external-enabled[enable external plugins]' \
  '--plugins=[plugins csv]:list:' \
  '--snapsync-server-enabled[enable snap sync server]' \
  '--api-gas-price-blocks=[API gas price blocks]:n:' \
  '--api-gas-price-percentile=[API gas price percentile]:pct:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'besu command' commands && ret=0 ;;
esac

return ret
