#compdef bigBedToBed
# _bigBedToBed — UCSC Kent Lab bigBedToBed convert UCSC indexed bigBed binary to ASCII BED format (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigBed.html

_bigBedToBed() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-chrom=+[chromosome name]:str:' \
        '-start=+[start position]:n:' \
        '-end=+[end position]:n:' \
        '-maxItems=+[N]:n:' \
        '-header[include header]' \
        '-bedPlusFields=+[N]:n:' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '*:in_bigbed out_bed:_files -g "*.bb *.bigbed *.bed"'
}

_bigBedToBed "$@"
