#compdef parsl-perf
# Documentation: https://parsl.readthedocs.io/en/stable/userguide/advanced/parsl_perf.html
# parsl-perf - measure Parsl throughput performance with a synthetic workload

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[Python config file with a config variable or fresh_config function]:file:_files -g "*.py"' \
  '--resources=[parsl_resource_specification as JSON]:json' \
  '--time=[target runtime in seconds (default 120)]:seconds' \
  '--iterate=[batch-sizing algorithm: estimate, exponential, or a sequence]:mode' && ret=0

return ret
