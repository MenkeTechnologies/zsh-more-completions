#compdef nodeset
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --count)'{-c,--count}'[count nodes in nodeset]' \
  '(-e --expand)'{-e,--expand}'[expand nodeset to list all nodes]' \
  '(-f --fold)'{-f,--fold}'[fold nodeset into compact form]' \
  '(-l --list)'{-l,--list}'[list node groups]' \
  '(-r --regroup)'{-r,--regroup}'[regroup nodeset using node groups]' \
  '(-s --separator)'{-s,--separator}'[output separator for expand]:separator:' \
  '(-S --output-separator)'{-S,--output-separator}'[output separator]:separator:' \
  '(-a --all)'{-a,--all}'[use all nodes from configured groups]' \
  '*'{-x,--exclude}'[exclude these nodes]:nodeset:' \
  '*'{-i,--intersection}'[compute intersection with nodeset]:nodeset:' \
  '(-X --xor)'{-X,--xor}'[compute symmetric difference]:nodeset:' \
  '--autostep[auto-step for ranges]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '--groupsource=[specify group source]:source:' \
  '(-G --groupbase)'{-G,--groupbase}'[use group base directory]:directory:_directories' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-R --rangeset)'{-R,--rangeset}'[treat arguments as rangesets]' \
  '*:nodeset expression:' && ret=0
return ret
