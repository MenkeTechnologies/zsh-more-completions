#compdef mongokerberos

# mongokerberos: Kerberos configuration validator for MongoDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--mode=[mode]:mode:(server client)' \
  '--username=[user]:user:_users' \
  '--gssapiServiceName=[GSSAPI service name]:name:' \
  '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
  '*::mongokerberos args:_files' && ret=0
return ret
