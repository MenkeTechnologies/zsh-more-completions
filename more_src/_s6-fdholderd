#compdef s6-fdholderd
# _s6-fdholderd — s6 fdholder s6-fdholderd (the actual fd-holder daemon: accepts UCSPI-Unix clients, stores file descriptors with a TTL + id, and hands them back on request; runs inside s6-fdholder-daemon)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholderd.c on tip.

_s6-fdholderd() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-1[print socket info on fd 1 when ready]' \
        '-c+[max simultaneous clients]:n:' \
        '-n+[max stored fds]:n:' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '(-i -x)-i+[accessrules directory]:dir:_files -/' \
        '(-i -x)-x+[accessrules cdb file]:file:_files'
}

_s6-fdholderd "$@"
