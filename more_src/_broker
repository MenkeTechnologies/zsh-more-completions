# ============================================================================
# _broker — zsh completion for snyk/broker (npm `snyk-broker`, binaries
#            `broker` AND `snyk-broker`), "a broker system between a public
#            service and a private service" — TS-Node=149 leader bump
#            CLOSING Axis 94 OAuth2 / oauth2-rs at 1/1/1 (triple-149
#            landmark)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/snyk/broker
#   Maintainer : Snyk Ltd.
#   License    : Apache-2.0
#   Stars      : 118
#   Language   : TypeScript (Node.js)
#   Package    : snyk-broker
#   Binaries   : broker AND snyk-broker  (package.json bin:
#                {"snyk-broker": "./dist/cli/index.js",
#                 "broker":      "./dist/cli/index.js"})
#   Last push  : 2026-05-29
#
# WHAT IT IS
#   Snyk Broker is "a broker system between a public service and
#   a private service" — a paired tunnel daemon that lets a
#   public SaaS (e.g. snyk.io) safely reach a customer's
#   on-prem source-control / artifact repository (GitHub
#   Enterprise, Bitbucket Server, GitLab, Artifactory,
#   container registries, Jira) through an outbound WebSocket
#   that the customer initiates.  The "server" side runs in
#   Snyk's cloud and acts as the SaaS-facing reverse proxy;
#   the "client" side runs inside the customer network,
#   maintains the WebSocket connection back to the server,
#   and applies a configurable allow-list of URL paths
#   (templated with `{user}`/`{token}` placeholders) that
#   gate which requests the server is permitted to make.  The
#   `init <template>` command scaffolds the per-template
#   client-side `accept.json` + `.env` files for each
#   supported integration.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cli/index.ts + cli/help.
#                       ts — broker uses minimist (NOT yargs or
#                       commander) for arg parsing, with a
#                       hand-rolled `if (args._[0] === 'init')
#                       ...` dispatch)
#   broker <COMMAND> [OPTIONS]
#
#   Commands:
#     client                         Run the broker in CLIENT
#                                    mode (initiates outbound
#                                    WebSocket to the broker
#                                    server)
#     server                         Run the broker in SERVER
#                                    mode (accepts inbound
#                                    WebSocket from the broker
#                                    client)
#     init <TEMPLATE>                Generate the client broker
#                                    files for a template
#                                    Supported templates:
#                                      github-com
#                                      github-enterprise
#                                      bitbucket-server
#                                      gitlab
#
#   Options:
#     -h, --help                     Print help and exit
#     --port <PORT>                  Local port for the broker
#                                    to listen on
#                                    [default: 7341]
#
#   Configuration: every flag also reads from environment
#   variables (BROKER_TOKEN, BROKER_SERVER_URL,
#   BROKER_CLIENT_URL, BROKER_HEALTHCHECK_PATH, GITHUB_TOKEN,
#   BITBUCKET_USERNAME, BITBUCKET_PASSWORD, GITLAB_TOKEN,
#   ACCEPT, LOG_LEVEL, etc. — see UNIVERSAL.md in the upstream
#   repo for the full list).
#
# AXIS / CORPUS POSITION
#   Direct dependency on `simple-oauth2 ^5.1.0` declared in
#   package.json — `simple-oauth2` is THE canonical Node.js
#   OAuth2 client library maintained by Lelylan (lelylan/
#   simple-oauth2, 1.7K+ stars, ~1.5M npm downloads/week; the
#   predominant Promise-based OAuth2 client for the Node
#   ecosystem alongside `panva/openid-client` for OIDC-strict
#   flows).  simple-oauth2 implements RFC 6749 §4.1 (Authorization
#   Code), §4.2 (Implicit), §4.3 (Resource Owner Password), and
#   §4.4 (Client Credentials), plus RFC 7636 PKCE.  It exposes
#   the typed `new AuthorizationCode({ client, auth, options })`
#   / `new ClientCredentials({ ... })` / `new ResourceOwnerPassword
#   ({ ... })` / `new ImplicitFlow({ ... })` flow constructors;
#   the typed `client.authorizeURL({ redirect_uri, scope, state })`
#   helper that builds an RFC 6749 §4.1.1 authorize URL; the
#   `client.getToken({ code, redirect_uri, scope })` /
#   `client.getToken({ scope })` / `client.getToken({ username,
#   password, scope })` token-exchange methods returning a
#   typed `AccessToken` with `.token`, `.expired()`, `.refresh()`,
#   `.revoke()`, `.revokeAll()`;  pluggable HTTP transport via
#   `wreck` (or any other axios-shaped adapter);  and full
#   custom `userInfo` / `serverError` / `errorMessages`
#   customization.  snyk-broker's
#   `lib/client/auth/*.ts` constructs `new AuthorizationCode({
#   client: { id, secret }, auth: { tokenHost, authorizePath,
#   tokenPath } })` for each supported integration (GitHub
#   Enterprise OAuth2 App, GitLab OAuth2 App, etc.) and runs
#   the refresh-on-401 retry loop for every gated request.
#   Verified via:
#     gh api repos/snyk/broker/contents/package.json
#       → "simple-oauth2": "^5.1.0"
#       → "bin": {"snyk-broker": "./dist/cli/index.js",
#                  "broker":      "./dist/cli/index.js"}
#       → license = "Apache-2.0"
#     gh api repos/snyk/broker/contents/cli/index.ts
#       → const args = minimist(process.argv.slice(2),
#           { boolean: ['help'], alias: { h: 'help' } });
#       → if (command === 'init') { init(templateName) }
#         else { exec(args); }
#     gh api repos/snyk/broker/contents/cli/help.ts
#       → Commands: client | server | init <template>
#       → Flags: -h, --help, --port PORT
#   This entry is the TS-Node=149 leader bump that CLOSES Axis
#   94 (OAuth2 / ramosbugs/oauth2-rs) at 1/1/1 three-language
#   symmetry — pairing Rust=oauth2 via adriankumpf/tesla_auth
#   (R965 _tesla_auth), Go=golang.org/x/oauth2 via rudrankriyam/
#   Google-Health-CLI (R966 _ghealth), and TS-Node=simple-oauth2
#   via snyk/broker (this entry).  Triple-149 landmark on commit.
#   Axis 94 = 87th axis closed.
#
#   No completion for `broker` or `snyk-broker` ships with
#   Apple zsh (/usr/share/zsh/*/functions) or Homebrew
#   zsh-completions (/opt/homebrew/share/zsh/site-functions) —
#   confirmed absent.
# ============================================================================

_broker() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '--port=[local port (default 7341)]:port:' \
        '1: :_broker_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        ':template:(github-com github-enterprise bitbucket-server gitlab)' && ret=0 ;;
                client|server)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_broker_commands] )) ||
_broker_commands() {
    local -a commands
    commands=(
        'client:run the broker in CLIENT mode'
        'server:run the broker in SERVER mode'
        'init:generate client broker files for a template'
    )
    _describe -t commands 'broker command' commands
}

_broker "$@"
