#compdef ncl_filedump
# NCL tool to dump contents of GRIB/HDF/netCDF/shapefile data files

local ret=1

_arguments -s -S \
  '-h[show short usage message]' \
  '-c[output coordinate variables and declarations]' \
  '-v[output data values for the specified variable(s)]:vars:' \
  '-sed[GRIB only: include specified single element dimensions]:dims:(Initial_time Forecast_time Level Ensemble Probability All None)' \
  '-itime[GRIB only: set time record dimension to initial_time]' \
  '-ftime[GRIB only: set time record dimension to forecast_time]' \
  '-tps[GRIB only: remove time period suffix from variable names]' \
  '*:input file:_files' && ret=0

return ret
