#compdef grcov

# Zsh completion for grcov (Rust code coverage tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-b --binary-path)'{-b,--binary-path}'[path to compiled binaries]:path:_files -/' \
  '(-t --output-type)'{-t,--output-type}'[output format]:format:(ade lcov coveralls coveralls+ files html cobertura markdown)' \
  '--output-path[output directory or file]:path:_files' \
  '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
  '(-s --source-dir)'{-s,--source-dir}'[source root directory]:directory:_files -/' \
  '(-p --prefix-dir)'{-p,--prefix-dir}'[prefix to add to paths]:prefix' \
  '--ignore[ignore files matching pattern]:pattern' \
  '--ignore-not-existing[ignore source files that do not exist]' \
  '--keep-only[keep only files matching pattern]:pattern' \
  '--path-mapping[path mapping]:mapping' \
  '--branch[enable branch coverage]' \
  '--no-branch[disable branch coverage]' \
  '--filter[filter results]:filter:(covered uncovered)' \
  '--llvm[use llvm tools]' \
  '--token[coveralls repo token]:token' \
  '--commit-sha[commit SHA]:sha' \
  '--service-name[CI service name]:name' \
  '--service-number[CI build number]:number' \
  '--service-job-id[CI job ID]:id' \
  '--service-pull-request[pull request number]:number' \
  '--vcs-branch[VCS branch name]:branch' \
  '(-j --threads)'{-j,--threads}'[number of threads]:threads' \
  '--guess-directory-when-missing[guess source directory]' \
  '--excl-line[exclude lines matching regex]:regex' \
  '--excl-start[exclude region start regex]:regex' \
  '--excl-stop[exclude region stop regex]:regex' \
  '--excl-br-line[exclude branch lines matching regex]:regex' \
  '--excl-br-start[exclude branch region start]:regex' \
  '--excl-br-stop[exclude branch region stop]:regex' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:coverage data:_files' && ret=0

return ret
