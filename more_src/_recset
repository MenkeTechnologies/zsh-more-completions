#compdef recset
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recset (GNU Recutils)

_arguments -s -S \
  '-t+[select record type]:record type:' \
  '-e+[selection expression]:expression:' \
  '-n+[record number to modify]:record number:' \
  '-f+[field name to set]:field name:' \
  '-s+[set field to value]:value:' \
  '-a+[add value to field]:value:' \
  '-d[delete field]' \
  '-S+[set if field exists, add if not]:value:' \
  '-i[case-insensitive matching]' \
  '--force[force operation even if errors exist]' \
  '--no-auto[do not generate auto fields]' \
  '--verbose[print verbose output]' \
  '*:file:_files'
