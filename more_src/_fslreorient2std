#compdef fslreorient2std
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/other/orientation.html
# fslreorient2std - reorient image to match approximate orientation of MNI152 templates

local ret=1

_arguments -s -S \
  '-m[output the reorientation transformation matrix to file]:matrix file:_files' \
  '1:input image:_files' \
  '2:output image:_files' && ret=0

return ret
