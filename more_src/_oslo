#compdef oslo
# Documentation: https://github.com/OpenSLO/oslo
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

# oslo: OpenSLO spec validator/converter (cobra)
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'validate:validate OpenSLO documents'
  'fmt:format OpenSLO documents'
  'convert:convert OpenSLO documents'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'oslo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (validate|fmt|convert)
        _arguments \
          '(-f --file)'{-f+,--file=}'[file or directory]:file:_files' \
          '(-R --recursive)'{-R,--recursive}'[recurse into directory]' && ret=0 ;;
    esac ;;
esac

return ret
