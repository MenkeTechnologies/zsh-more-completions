#compdef auditbeat2
# _auditbeat2 — Elastic auditbeat2 CLI command-line frontend wrapping the Auditbeat lightweight audit data shipper from the Elastic Beats family providing run setup test export keystore show modules version completion file-integrity-monitoring system-process-host-package-socket-user audit-rules-event-source kernel-audit OSquery system-events-correlation (Elastic Beats team, Go); cobra
# upstream: https://www.elastic.co/beats/auditbeat

_auditbeat2() {
    local -a sub=(
        'run:run auditbeat'
        'setup:setup index pipelines templates'
        'test:test config or output'
        'export:export config or template'
        'keystore:keystore operations'
        'show:show audit info'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "auditbeat.yml *.yml *.yaml"' \
        '-d+[selectors]:str:' \
        '-e[log to stderr]' \
        '-E+[k=v]:str:' \
        '-M+[module setting]:str:' \
        '-N[disable publishing]' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '--strict.perms[strict perms]' \
        '--system.hostfs=+[dir]:dir:_files -/' \
        '--httpprof=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'auditbeat subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments '1:target:(--index-management --pipelines --dashboards --machine-learning --policy)' '*:arg:' ;;
                test) _arguments '1:target:(config output)' ;;
                export) _arguments '1:target:(config ilm-policy index-pattern template dashboard)' ;;
                keystore) _arguments '1:op:(add create list remove)' '*:key:' ;;
                show) _arguments '1:target:(auditd-rules auditd-status)' ;;
            esac
            ;;
    esac
}

_auditbeat2 "$@"
