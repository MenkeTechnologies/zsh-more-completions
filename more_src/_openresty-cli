#compdef openresty-cli openresty
# _openresty-cli — OpenResty openresty-cli CLI command-line frontend to OpenResty NGINX-based web platform with Lua-Lua-resty-libraries Lua-JIT integration providing reload upgrade configtest signal-master worker process management content phase Lua-VM-state cache flush HTTP-Lua-LuaJIT-FFI scripting (OpenResty team, C); getopt
# upstream: https://openresty.org/

_openresty-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-?[show usage]' \
        '-t[test config]' \
        '-T[test config and dump]' \
        '-q[suppress non-error messages]' \
        '-s+[signal]:s:(stop quit reopen reload)' \
        '-c+[config file]:file:_files -g "nginx.conf *.conf"' \
        '-p+[prefix]:dir:_files -/' \
        '-e+[error log]:file:_files' \
        '-g+[directive]:str:' \
        '*::'
}

_openresty-cli "$@"
