#compdef pueue pueued
# _pueue-cli — Pueue Rust task scheduler / queue (Arne Beer); long-running shell-command queueing daemon
# upstream: https://github.com/Nukesor/pueue

_pueue-cli() {
    local -a sub=(
        'add:add a task'
        'remove:remove a task'
        'switch:swap positions of two tasks'
        'stash:stash a task'
        'enqueue:enqueue a stashed task'
        'start:start tasks'
        'restart:restart finished/failed tasks'
        'pause:pause running tasks'
        'kill:kill running tasks'
        'send:send stdin to running task'
        'edit:edit a stashed task'
        'group:manage groups'
        'status:show task status'
        'format-status:formatted status'
        'log:print task output'
        'follow:follow a running task'
        'wait:wait for tasks to finish'
        'clean:remove finished tasks'
        'reset:reset queue state'
        'shutdown:stop the daemon'
        'parallel:set parallel tasks per group'
        'completions:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files -g "*.yml"' \
        '(-p --profile)'{-p,--profile}'+[profile]:profile:' \
        '--color+[color]:when:(auto always never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pueue subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '(-w --working-directory)'{-w,--working-directory}'+[cwd]:dir:_files -/' \
                    '(-e --escape)'{-e,--escape}'[escape command]' \
                    '(-s --start-immediately)'{-s,--start-immediately}'[start immediately]' \
                    '(-i --immediate)'{-i,--immediate}'[immediate]' \
                    '(-S --stashed)'{-S,--stashed}'[stashed]' \
                    '(-d --delay)'{-d,--delay}'+[delay]:duration:' \
                    '(-l --label)'{-l,--label}'+[label]:label:' \
                    '(-g --group)'{-g,--group}'+[group]:group:' \
                    '(-a --after)'{-a,--after}'+[after task ids]:ids:' \
                    '(-p --print-task-id)'{-p,--print-task-id}'[print task id]' \
                    '*::command:_command_names -e' ;;
                start|pause|kill|restart|remove|stash|enqueue|edit|status|log|follow|wait|switch|clean|reset|send) _arguments \
                    '(-g --group)'{-g,--group}'+[group]:group:' \
                    '*:task id:' ;;
                group) _arguments '1:group cmd:(add remove parallel list)' '*:args:' ;;
                completions) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_pueue-cli "$@"
