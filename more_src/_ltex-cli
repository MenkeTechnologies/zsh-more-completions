#compdef ltex-cli
# _ltex-cli — LTeX Project ltex-cli CLI grammar and spell-checker for LaTeX Markdown reStructuredText AsciiDoc XHTML XML BibTeX wrapping LanguageTool LTeX-LS server checking writing-style rule violations word-spelling pattern-based matches in 30+ languages emitting JSON CSV human-readable issues (Julian Valentin team, Java); custom argparse
# upstream: https://valentjn.github.io/ltex/

_ltex-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l+[language]:l:(en en-US en-GB en-AU en-CA en-NZ en-ZA de de-DE de-AT de-CH fr es it nl pt pt-BR pt-PT ru ro pl uk sv da nb nn fa el ja zh-CN auto)' \
        '--language=+[lang]:str:' \
        '--server-command=+[cmd]:file:_files' \
        '--server-mode=+[mode]:m:(external single)' \
        '--server-host=+[host]:str:' \
        '--server-port=+[port]:n:' \
        '--server-cwd=+[dir]:dir:_files -/' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[l]:l:(trace debug info warning error)' \
        '--http-server-uri=+[uri]:str:' \
        '--client-config=+[file]:file:_files -g "*.json"' \
        '--config-file=+[file]:file:_files -g "*.json *.yaml *.yml"' \
        '--no-aux-config-loading[no aux config loading]' \
        '--no-check-frontmatter[no frontmatter check]' \
        '-f+[output format]:f:(plain plaintext json checkstyle htmlbody-attribute html)' \
        '--format=+[format]:f:(plain plaintext json checkstyle htmlbody-attribute html)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '*:input file:_files -g "*.tex *.md *.rst *.adoc *.xhtml *.html *.txt *.bib *.xml *.org"'
}

_ltex-cli "$@"
