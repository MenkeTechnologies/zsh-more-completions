#compdef lossless-cut losslesscut
# Documentation: https://github.com/mifi/lossless-cut/blob/master/docs/cli.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# LosslessCut: GUI for fast loss-less video/audio editing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--no-sandbox[Electron: disable sandbox]' \
  '--disable-gpu[Electron: disable GPU]' \
  '--enable-logging[Electron: enable logging]' \
  '--user-data-dir=[Electron user data dir]:dir:_files -/' \
  '*:media file:_files -g "*.(mp4|mkv|mov|avi|webm|m4a|mp3|flac|wav|aac|ogg|opus)"' && ret=0
return ret
