#compdef graphql-codegen

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[path to config file]:config file:_files' \
  '--config=[path to config file]:config file:_files' \
  '-w[watch for changes]' \
  '--watch[watch for changes]' \
  '-s[silent mode, only show errors]' \
  '--silent[silent mode, only show errors]' \
  '-e[exit on error]' \
  '--errors-only[only show errors]' \
  '-r+[require module before execution]:module' \
  '--require=[require module before execution]:module' \
  '-o+[override output target]:output path:_files' \
  '--overwrite[overwrite existing files]' \
  '-p+[specific project name]:project' \
  '--project=[specific project name]:project' \
  '--profile[enable profiling]' \
  '--check[check if files are up to date]' \
  '--verbose[enable verbose logging]' \
  '--debug[enable debug logging]' && ret=0

return ret
