local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "codegen.{yml,yaml,ts,js,json}"' \
  '(-w --watch)'{-w,--watch}'[watch for changes]' \
  '(-s --silent)'{-s,--silent}'[silent mode, only show errors]' \
  '(-e --errors-only)'{-e,--errors-only}'[only show errors]' \
  '(-r --require)'{-r+,--require=}'[require module before execution]:module:' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite existing files (default)]' \
  '(-p --project)'{-p+,--project=}'[specific project name]:project:' \
  '--profile[enable profiling]' \
  '--check[check if files are up-to-date]' \
  '--verbose[enable verbose logging]' \
  '--debug[enable debug logging]' && ret=0

return ret
