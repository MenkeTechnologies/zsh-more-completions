#compdef crap4rs
# Documentation: https://man.archlinux.org/search?q=crap4rs
# Reference accessed: 2026-05-16
# Source: cargo binstall crap4rs@0.5.0
# Probed via: completions zsh
# Repository: https://github.com/breezy-bays-labs/crap-rs

autoload -U is-at-least

_crap4rs() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--coverage=[Path to LCOV coverage file (from \`cargo llvm-cov --lcov\`). Required for analysis; not required for \`crap4rs completions\`]:FILE:_files' \
'--src=[Root directory of Rust source files to analyze \[default\: src\]]:DIR:_files -/' \
'--metric=[Complexity metric to use \[default\: cognitive\]]:METRIC:((cognitive\:"Nesting depth + structural complexity (default for Rust)"
cyclomatic\:"Decision-point count, classic CRAP metric"))' \
'--config=[Path to config file (default\: auto-discover crap4rs.toml)]:FILE:_files' \
'--view=[Resolve and apply a saved view preset from \`crap4rs.toml\`]:NAME:_default' \
'--baseline=[Path to a previously-emitted crap4rs JSON envelope, used as the baseline for delta analysis]:FILE:_files' \
'*-f+[Output format(s)]:FORMAT:_default' \
'*--format=[Output format(s)]:FORMAT:_default' \
'--threshold=[CRAP score threshold — functions above this fail the check \[default\: 25\]]:THRESHOLD:_default' \
'*--exclude=[Glob patterns to exclude from analysis (repeatable)]:EXCLUDE:_default' \
'--diff=[Git ref to diff against — only analyze functions in changed files/hunks]:REF:_default' \
'--min-coverage=[Lower bound (inclusive) on coverage_percent for the displayed view]:PCT:_default' \
'--max-coverage=[Upper bound (inclusive) on coverage_percent for the displayed view]:PCT:_default' \
'--sort-by=[Sort key for the displayed view (default\: crap descending)]:KEY:((crap\:"CRAP score descending (default — investigator'\''s first cut)"
coverage\:"Coverage percent ascending (lowest coverage first)"
complexity\:"Complexity descending (most complex first)"
path\:"Alphabetical by file_path, then CRAP descending within file"))' \
'--top=[Truncate the displayed view to the top N highest-CRAP rows]:N:_default' \
'--group-by=[Aggregate the displayed view by a key. Today\: \`file\` only]:KEY:((file\:"Aggregate by source file path"))' \
'--delta-top=[Truncate the delta block to the top N rows by \`--delta-sort\`. \`--delta-top 0\` means "no limit". Independent of \`--top\`, which truncates the analysis view (\`view.shown\`)]:N:_default' \
'--delta-sort=[Sort key for the delta block]:KEY:((score-delta\:"Magnitude of change descending — regressions first (default)"
current-crap\:"Current CRAP score descending; \`Removed\` rows last"
baseline-crap\:"Baseline CRAP score descending; \`Added\` rows last"
path\:"Alphabetical by file_path then qualified_name"))' \
'*--delta-only=[Comma-separated list of change kinds to include in the delta block\: \`added\`, \`removed\`, \`modified\`. Default\: all three]:KINDS:(added removed modified)' \
'--color=[When to use terminal colors]:COLOR:((auto\:"Colorize when writing to a terminal"
always\:"Always colorize output"
never\:"Never colorize output"))' \
'--md-top=[Number of rows in the markdown top-N table (default 10)]:N:_default' \
'--strict[Use strict threshold (15) — for high-quality or safety-critical code]' \
'--lenient[Use lenient threshold (40) — for legacy or transitional code]' \
'--no-fail[Always exit 0, even when threshold violations exist]' \
'--delta-gate[Fail the build (exit 1) when the baseline comparison introduces new threshold violations]' \
'--minimal-view[Omit the denormalized \`view.shown\` row array from JSON output]' \
'--no-gitignore[Do not respect .gitignore files]' \
'--only-failing[Only show functions that exceed the threshold]' \
'-v[Show parse diagnostics and matching statistics]' \
'--verbose[Show parse diagnostics and matching statistics]' \
'-q[Suppress report output, only set exit code]' \
'--quiet[Suppress report output, only set exit code]' \
'--breakdown[Show complexity contributors for functions exceeding threshold]' \
'--explain[Explain nested breakdown increments in table output]' \
'--md-full-table[Render the full per-function table in markdown output]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_crap4rs_commands" \
"*::: :->crap-core" \
&& ret=0
    case $state in
    (crap-core)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:crap4rs-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash zsh fish powershell elvish nushell)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_crap4rs__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:crap4rs-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_crap4rs_commands] )) ||
_crap4rs_commands() {
    local commands; commands=(
'completions:Generate a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'crap4rs commands' commands "$@"
}
(( $+functions[_crap4rs__subcmd__completions_commands] )) ||
_crap4rs__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'crap4rs completions commands' commands "$@"
}
(( $+functions[_crap4rs__subcmd__help_commands] )) ||
_crap4rs__subcmd__help_commands() {
    local commands; commands=(
'completions:Generate a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'crap4rs help commands' commands "$@"
}
(( $+functions[_crap4rs__subcmd__help__subcmd__completions_commands] )) ||
_crap4rs__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'crap4rs help completions commands' commands "$@"
}
(( $+functions[_crap4rs__subcmd__help__subcmd__help_commands] )) ||
_crap4rs__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'crap4rs help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_crap4rs" ]; then
    _crap4rs "$@"
else
    compdef _crap4rs crap4rs
fi
