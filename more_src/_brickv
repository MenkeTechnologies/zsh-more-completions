#compdef brickv
# Documentation: https://man.archlinux.org/search?q=brickv
# Reference accessed: 2026-05-16

# brickv: Tinkerforge Brick Viewer (Qt GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*::brickv args:_files' && ret=0
return ret
