#compdef brickv
# Documentation: https://www.tinkerforge.com/en/doc/Software/Brickv.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# brickv - Tinkerforge Brick Viewer (Qt GUI); upstream docs document no CLI flags
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*::brickv args:_files' && ret=0
return ret
