#compdef lld ld.lld
# _lld-bin — LLVM lld linker (LLVM project, C++); drop-in ld replacement with ELF/COFF/Mach-O/wasm backends
# upstream: https://github.com/llvm/llvm-project

_lld-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-flavor=+[flavor]:flavor:(gnu darwin link wasm)' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-L+[library path]:dir:_files -/' \
        '--library-path=+[library path]:dir:_files -/' \
        '-l+[library]:str:' \
        '--library=+[library]:str:' \
        '-static[static]' \
        '-shared[shared]' \
        '--shared[shared]' \
        '-Bdynamic[dynamic library]' \
        '-Bstatic[static library]' \
        '-rpath+[rpath]:path:_files -/' \
        '--rpath=+[rpath]:path:_files -/' \
        '-soname=+[soname]:str:' \
        '--soname=+[soname]:str:' \
        '-T+[linker script]:file:_files' \
        '--script=+[linker script]:file:_files' \
        '--gc-sections[gc sections]' \
        '--no-gc-sections[no gc sections]' \
        '--strip-all[strip all]' \
        '-s[strip all]' \
        '--strip-debug[strip debug]' \
        '-S[strip debug]' \
        '-z+[option]:str:' \
        '-Map=+[link map file]:file:_files' \
        '-M[print link map]' \
        '--print-map[print link map]' \
        '--build-id=+[build id]:val:(none uuid sha1 fast md5 0xHEX)' \
        '--lto=+[lto]:val:(thin full)' \
        '--lto-O+[lto optimization]:n:' \
        '--thinlto-jobs=+[thinlto jobs]:n:' \
        '-e+[entry point]:str:' \
        '--entry=+[entry point]:str:' \
        '*:file:_files'
}

_lld-bin "$@"
