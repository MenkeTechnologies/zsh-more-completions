#compdef suxgraph
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/graphics/xplot/suxgraph.c
# X-windows graph plot of SU data via xgraph

local ret=1

_arguments -s -S \
  'nplot=[number of traces]:ntraces' \
  'ntr=[alias for nplot]:ntraces' \
  'd1=[sampling interval in the fast dimension]:d1' \
  'd2=[sampling interval in the slow dimension]:d2' \
  'f1=[first sample in the fast dimension]:f1' \
  'f2=[first sample in the slow dimension]:f2' \
  'verbose=[print useful information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
