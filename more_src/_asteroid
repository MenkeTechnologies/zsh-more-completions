#compdef asteroid
# Asteroid: species tree inference from gene trees with missing data correction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input-gene-trees)'{-i,--input-gene-trees}'[file with one gene tree per line (newick)]:file:_files' \
  '(-r --random-starting-trees)'{-r,--random-starting-trees}'[number of random starting trees (0 = ASTRID tree)]:n:' \
  '(-b --bs-replicates)'{-b,--bs-replicates}'[number of bootstrap trees to compute]:n:' \
  '--input-bs-gene-trees[gene trees used for bootstrapping]:file:_files' \
  '(-p --prefix)'{-p,--prefix}'[prefix for output files]:prefix:' \
  '(-m --gene-species-mapping)'{-m,--gene-species-mapping}'[mapping file of genes to species]:file:_files' \
  '--seed[random seed]:seed:' \
  '(-n --no-correction)'{-n,--no-correction}'[disable missing data correction (equivalent to ASTRID)]' \
  '--min-bl[contract branches shorter than this into polytomies]:length:' \
  '--use-gene-bl[use gene tree branch lengths for distance matrices]' && ret=0

return ret
