#compdef wazuh-agent

_wazuh_commands() {
    local -a commands
    commands=(
        'start:Start the Wazuh agent'
        'stop:Stop the Wazuh agent'
        'restart:Restart the Wazuh agent'
        'status:Show the Wazuh agent status'
        'info:Show agent information'
        'register:Register the agent with a manager'
        'unregister:Unregister the agent'
        'help:Show help'
    )
    _describe -t commands 'wazuh-agent command' commands
}

_wazuh() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '(-d --debug)'{-d,--debug}'[Enable debug mode]' \
        '(-f --foreground)'{-f,--foreground}'[Run in foreground]' \
        '(-c --config)'{-c,--config}'[Configuration file]:file:_files' \
        '(-t --test-config)'{-t,--test-config}'[Test configuration file]' \
        '-V[Show version and compile info]' \
        '1:command:_wazuh_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                register)
                    _arguments \
                        '-m[Manager IP address]:address:_hosts' \
                        '-p[Agent port]:port:' \
                        '-A[Agent name]:name:' \
                        '-G[Agent groups]:groups:' \
                        '-D[Installation directory]:dir:_directories' \
                        '-k[Agent key]:key:' \
                        '-P[Registration password]:password:' \
                        '-x[PEM certificate file]:file:_files' \
                        '-g[Agent group]:group:' \
                        '-i[Let the manager set the agent ID]'
                    ;;
            esac
            ;;
    esac
}

_wazuh "$@"
