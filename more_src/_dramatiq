#compdef dramatiq

# Completion for dramatiq - Python distributed task processing library

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-p,--processes}'=[number of worker processes]:processes' \
  {-t,--threads}'=[number of worker threads per process]:threads' \
  '*'{-Q,--queues}'=[listen to specific queues]:queue name' \
  '--pid-file=[PID file path]:pid file:_files' \
  '--log-file=[log file path]:log file:_files' \
  '--use-spawn[start subprocesses with spawn instead of fork]' \
  '--fork-id=[fork ID]:fork ID' \
  '--worker-shutdown-timeout=[worker shutdown timeout in milliseconds]:timeout (ms)' \
  {-v,--verbose}'[turn on verbose log output]' \
  '*:modules' && ret=0

return ret
