#compdef muesli
# Documentation: https://man.archlinux.org/search?q=muesli
# Reference accessed: 2026-05-16
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_muesli
# Repository: MenkeTechnologies/zsh-more-completions (src/_muesli)

# Zsh completion for muesli (Wispr Flow engine)

local -a commands
commands=(
  'spec:Inspect the command contract'
  'info:Get system and app information'
  'meetings:Manage meeting transcripts'
  'dictations:Manage dictations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'

case $words[1] in
  meetings)
    local -a meeting_cmds
    meeting_cmds=('list' 'get' 'update-notes')
    _arguments \
      '1: :_describe -t meeting_cmds "meeting command" meeting_cmds'
    ;;
  dictations)
    _arguments '1:command:(list)'
    ;;
esac
