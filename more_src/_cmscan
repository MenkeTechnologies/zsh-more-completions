#compdef cmscan
# Documentation: https://man.archlinux.org/search?q=cmscan
# Reference accessed: 2026-05-16

# Infernal cmscan: search nucleic-acid sequence against a CM database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-g --glocal)'{-g,--glocal}'[force global alignment search]' \
  '-Z[poll for the number of CMs in the database]:size:' \
  '--tabfile[output tab-delimited per-hit file]:file:_files' \
  '-o[redirect output to file]:file:_files' \
  '--tblout[save parseable table of per-sequence hits]:file:_files' \
  '--fmt[output table format]:fmt:(1 2 3)' \
  '--clanin[clan information file for redundancy filter]:file:_files' \
  '--oclan[mark hits that overlap in same clan]' \
  '--oskip[skip overlap report]' \
  '--cpu[number of parallel CPU threads]:n:' \
  '--mxsize[soft memory cap for CM banded matrix (MB)]:MB:' \
  '--smxsize[soft memory cap for HMM banded matrix (MB)]:MB:' \
  '-E[report sequences <= this E-value]:Eval:' \
  '-T[report sequences with bit score >= this]:bits:' \
  '--incE[include hits in output up to this E-value]:Eval:' \
  '--incT[include hits with bit score >= this]:bits:' \
  '--cut_ga[use CM GA gathering cutoffs]' \
  '--cut_nc[use CM NC noise cutoffs]' \
  '--cut_tc[use CM TC trusted cutoffs]' \
  '--max[maximum sensitivity (turn off filters)]' \
  '--nohmm[do not use HMM filter]' \
  '--nohmmonly[disallow HMM-only models]' \
  '--rfam[run in Rfam pipeline mode]' \
  '--hmmonly[force HMM-only mode]' \
  '--FZ[set filter thresholds for Z Mb of sequence]:Mb:' \
  '--Fmid[filter threshold for HMM Forward filter]:val:' \
  '--anytrunc[allow truncated hits at any sequence position]' \
  '--notrunc[do not consider truncated hits]' \
  '--toponly[only search top strand]' \
  '--bottomonly[only search bottom strand]' \
  '--midthresh[apply mid-threshold filters]' \
  '--seed[random seed]:n:' \
  '*:CM database and sequence file:_files' && ret=0
return ret
