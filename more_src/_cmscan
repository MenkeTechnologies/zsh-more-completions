#compdef cmscan
# Documentation: https://manpages.debian.org/testing/infernal/cmscan.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmscan: search nucleic-acid sequence against a CM database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-g --glocal)'{-g,--glocal}'[force global alignment search]' \
  '-Z[search space size in megabases]:size:' \
  '-o[redirect main output to file]:file:_files' \
  '--tblout[save tabular per-sequence hits to file]:file:_files' \
  '--fmt[tabular output format]:fmt:(1 2)' \
  '--acc[use accessions instead of names]' \
  '--noali[omit alignment section]' \
  '--notextw[unlimited line length in output]' \
  '--textw[output line length]:n:' \
  '--verbose[include extra pipeline statistics]' \
  '--clanin[clan information file]:file:_files' \
  '--oclan[mark hits that overlap in same clan]' \
  '--oskip[skip overlap report]' \
  '--cpu[number of parallel CPU threads]:n:' \
  '--mxsize[CM banded matrix memory cap (MB)]:MB:' \
  '--smxsize[HMM banded matrix memory cap (MB)]:MB:' \
  '-E[report hits <= this E-value]:Eval:' \
  '-T[report hits with bit score >= this]:bits:' \
  '--incE[include hits up to this E-value]:Eval:' \
  '--incT[include hits with bit score >= this]:bits:' \
  '--cut_ga[use CM GA gathering cutoffs]' \
  '--cut_nc[use CM NC noise cutoffs]' \
  '--cut_tc[use CM TC trusted cutoffs]' \
  '--max[maximum sensitivity (turn off filters)]' \
  '--nohmm[disable HMM filter]' \
  '--mid[disable SSV/Viterbi stages]' \
  '--default[standard filter pipeline]' \
  '--rfam[strict filter pipeline for large databases]' \
  '--hmmonly[force HMM-only mode]' \
  '--FZ[set filter thresholds for Z Mb of sequence]:Mb:' \
  '--anytrunc[allow truncated hits at any position]' \
  '--notrunc[disable truncated hit detection]' \
  '--toponly[only search top strand]' \
  '--bottomonly[only search bottom strand]' \
  '--seed[random seed]:n:' \
  '--devhelp[show developer options]' \
  '*:CM database and sequence file:_files' && ret=0
return ret
