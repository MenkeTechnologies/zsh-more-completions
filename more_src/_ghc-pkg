#compdef ghc-pkg

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:create and initialise a package database'
  'register:register a package using an installed package description'
  'update:register a package, overwriting any other with the same name'
  'unregister:unregister specified packages'
  'expose:expose the specified package'
  'hide:hide the specified package'
  'trust:trust the specified package'
  'distrust:distrust the specified package'
  'list:list registered packages'
  'dot:generate a graph of package dependencies'
  'find-module:find module in registered packages'
  'latest:print the latest version of a package'
  'describe:print a package description'
  'field:show a field of the package description'
  'check:check the consistency of package databases'
  'dump:print full description of all packages'
  'recache:recache the package database'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--user[use the current user package database]' \
  '--global[use the global package database]' \
  '--package-db=[use the specified package database]:database:_files -/' \
  '--global-package-db=[location of the global package database]:dir:_files -/' \
  '--no-user-package-db[never read the user package database]' \
  '--user-package-db=[location of the user package database]:dir:_files -/' \
  '--force[ignore missing dependencies, directories, and libraries]' \
  '--force-files[ignore missing directories and libraries only]' \
  '--enable-multi-instance[allow registering multiple instances of the same package version]' \
  '--expand-env-vars[expand environment variables in input package descriptions]' \
  '--expand-pkgroot[expand pkgroot-relative paths to absolute]' \
  '--no-expand-pkgroot[preserve pkgroot-relative paths]' \
  '--simple-output[print easy-to-parse output for some commands]' \
  '--show-unit-ids[print unit-ids instead of package identifiers]' \
  '--names-only[only print package names, not versions]' \
  '--ignore-case[ignore case for substring matching]' \
  '--ipid[interpret package arguments as installed package IDs]' \
  '--unit-id[interpret package arguments as unit IDs]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ghc-pkg subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _files -/ && ret=0
        ;;
      (register|update)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
