#compdef bgpdump
# Documentation: https://github.com/RIPE-NCC/bgpdump (bgpdump.c usage block)
# Reference accessed: 2026-05-30
# bgpdump — utility for parsing MRT-format BGP routing dump files (Zebra/Quagga/MRT).
# Maintained by RIPE NCC.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-H -m -M)-H[multi-line human-readable format (default)]' \
  '(-H -m -M)-m[one-line per entry with Unix timestamps]' \
  '(-H -m -M)-M[one-line per entry with human-readable timestamps]' \
  '-O+[redirect output to file instead of stdout]:file:_files' \
  '(-s -v)-s[log to syslog (default)]' \
  '(-s -v)-v[log to stderr]' \
  '-q[quiet mode]' \
  '-t+[timestamp source (only for -m / -M modes)]:source:(dump change)' \
  '-p[show packet index at second position in one-line output]' \
  '-l[display large communities field after regular communities]' \
  '-u[show unassigned attributes in one-line mode]' \
  '(- *)-T[run unit tests and exit]' \
  '*:MRT file:_files -g "*.(mrt|bz2|gz|bgp)"' \
  && ret=0

return ret
