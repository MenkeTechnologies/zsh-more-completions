#compdef burn
# _burn — Tracel-AI Burn deep learning framework Rust CLI (Tracel AI, Rust); clap-rs
# upstream: https://github.com/tracel-ai/burn

_burn() {
    local -a sub=(
        'new:create a new burn project'
        'train:train a model'
        'infer:run inference'
        'export:export model'
        'bench:benchmark'
        'check:check setup'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'burn subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:project-name:' \
                    '--template=+[template]:tmpl:' \
                    '--backend=+[backend]:b:(wgpu tch ndarray cuda candle)' ;;
                train|infer) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--data=+[data dir]:dir:_files -/' \
                    '--output=+[output dir]:dir:_files -/' \
                    '--device=+[device]:dev:(cpu gpu cuda metal)' \
                    '--batch-size=+[batch size]:n:' \
                    '--epochs=+[epochs]:n:' \
                    '--lr=+[learning rate]:f:' ;;
                export) _arguments \
                    '--model=+[model file]:file:_files' \
                    '--format=+[format]:fmt:(onnx safetensors burn)' \
                    '--output=+[output file]:file:_files' ;;
                bench) _arguments \
                    '--backend=+[backend]:b:(wgpu tch ndarray cuda candle)' \
                    '--shape=+[shape]:shape:' \
                    '--iterations=+[iterations]:n:' ;;
                check) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_burn "$@"
