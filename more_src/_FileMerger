#compdef FileMerger
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: merge several MS files into one

local ret=1

_arguments -s -S \
  '*-in[input files]:input files:_files' \
  '-in_type[input file type]:type:' \
  '-out[output file]:output file:_files' \
  '-annotate_file_origin[preserve original filenames as metadata]' \
  '-append_method[how consensusXML features combine]:method:(append_rows append_cols)' \
  '-rt_concat:gap[gap in seconds between input RT ranges]:gap:' \
  '-rt_concat:trafo_out[output RT transformation files]:files:_files' \
  '-raw:rt_auto[auto-generate sequential retention times]' \
  '-raw:rt_custom[assign custom retention times]:rts:' \
  '-raw:rt_filename[extract retention time from filename]' \
  '-raw:ms_level[assign MS level when absent]:level:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
