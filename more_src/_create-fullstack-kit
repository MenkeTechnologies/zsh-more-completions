#compdef create-fullstack-kit
# Documentation: https://www.npmjs.com/package/create-fullstack-kit
# Reference accessed: 2026-05-23
# Verified: npm view create-fullstack-kit bin; npm readme Options section.

# Zsh completion for create-fullstack-kit - monorepo fullstack starter kit generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--frontend=[frontend framework]:frontend:(next)' \
  '--ui=[UI library]:ui:(shadcn)' \
  '--backend=[backend framework]:backend:(nest express)' \
  '--auth=[authentication mode]:auth:(oauth)' \
  '--db=[database ORM]:db:(prisma)' \
  ':project name:' && ret=0

return ret
