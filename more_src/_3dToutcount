#compdef 3dToutcount
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dToutcount.html
# AFNI: count outliers at each time point

local ret=1

_arguments -s -S \
  '-mask[restrict counting to voxels in mask]:mset:_files' \
  '-qthr[outlier threshold (0<q<1, default 0.001)]:q:' \
  '-autoclip[auto remove small-valued voxels]' \
  '-automask[auto generate a mask]' \
  '-fraction[output proportion not raw count]' \
  '-range[show median+/-3.5*MAD per timepoint]' \
  '-save[save dataset of outlier Q-values]:prefix:' \
  '-polort[detrend with polynomials of order nn]:nn:' \
  '-legendre[use Legendre polynomials for detrending]' \
  '*:dataset:_files' && ret=0

return ret
