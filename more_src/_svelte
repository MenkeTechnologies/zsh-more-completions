#compdef sv create-svelte
# Documentation: https://svelte.dev/docs/cli/overview
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: 'sv' is the Svelte CLI (sveltejs/cli). The `_svelte-kit` completion
# in this collection handles svelte-kit. create-svelte is the legacy alias.

_svelte() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'create:create a new Svelte/SvelteKit project'
    'add:add an integration/add-on to a project'
    'check:validate project setup'
    'migrate:migrate a project between versions'
  )
  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sv command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        create)
          _arguments -s -S \
            '--template=[project template]:template:(minimal demo library)' \
            '--types=[add type checking]:types:(ts jsdoc)' \
            '--no-types[do not add type checking]' \
            '--no-add-ons[skip add-on selection]' \
            '--no-install[skip package installation]' \
            '1:directory:_files -/' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '--no-preconditions[skip checking preconditions]' \
            '--no-install[skip package installation]' \
            '1:integration:(better-auth drizzle eslint mcp mdsvex paraglide playwright prettier storybook sveltekit-adapter tailwindcss vitest)' \
            && ret=0
          ;;
        check)
          _arguments -s -S \
            '--workspace=[path to workspace]:workspace:_files -/' \
            '--watch[watch for changes]' \
            '--preserveWatchOutput[preserve watch output]' \
            '--fail-on-warnings[fail on warnings]' \
            '--compiler-warnings=[set compiler warning handling]:treatment:' \
            '--diagnostic-sources=[diagnostic source filter]:sources:(js svelte css)' \
            '--threshold=[threshold]:threshold:(error warning)' \
            '--output=[output format]:format:(human human-verbose machine machine-verbose)' \
            '--tsconfig=[path to tsconfig]:tsconfig:_files -g "tsconfig*.json"' \
            '--no-tsconfig[do not use tsconfig]' \
            '--ignore=[paths to ignore (comma separated)]:paths:' \
            '--incremental[enable incremental mode]' \
            '--tsgo[use tsgo]' \
            && ret=0
          ;;
        migrate)
          _arguments -s -S \
            '1:migration:(svelte-4 sveltekit-2 package self-closing-tags svelte-5)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_svelte "$@"
