#compdef svelte-kit sv create-svelte

# Zsh completion for SvelteKit CLI (sv)

_svelte() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  case $prog in
    sv)
      local -a commands=(
        'create:create a new SvelteKit project'
        'add:add integrations to a project'
        'check:check your project for errors'
        'migrate:migrate your project between versions'
      )
      _arguments -s -S \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'sv command' commands && ret=0
          ;;
        (args)
          case ${words[1]} in
            create)
              _arguments -s -S \
                '--template=[project template]:template:(minimal demo library)' \
                '--types=[add type checking]:types:(ts jsdoc)' \
                '--no-types[do not add type checking]' \
                '--no-add-ons[skip add-on selection]' \
                '--no-install[skip package installation]' \
                '1:directory:_files -/' \
                && ret=0
              ;;
            add)
              _arguments -s -S \
                '--no-preconditions[skip checking preconditions]' \
                '--no-install[skip package installation]' \
                '1:integration:(drizzle eslint lucia mdsvex paraglide playwright prettier storybook tailwindcss vitest)' \
                && ret=0
              ;;
            check)
              _arguments -s -S \
                '--workspace=[path to workspace]:workspace:_files -/' \
                '--watch[watch for changes]' \
                '--fail-on-warnings[fail on warnings]' \
                '--fail-on-hints[fail on hints]' \
                '--compiler-warnings=[set compiler warning handling]:treatment:' \
                '--diagnostic-sources=[diagnostic source filter]:sources:(js svelte)' \
                '--threshold=[threshold]:threshold:(error warning)' \
                '--output=[output format]:format:(human machine human-verbose)' \
                '--tsconfig=[path to tsconfig]:tsconfig:_files -g "tsconfig*.json"' \
                && ret=0
              ;;
            migrate)
              _arguments -s -S \
                '1:migration:(svelte-4 sveltekit-2 package self-closing-tags svelte-5)' \
                && ret=0
              ;;
          esac
          ;;
      esac
      ;;
    *)
      _arguments -s -S \
        '--help[display help]' \
        '--version[display version]' \
        '*:files:_files' \
        && ret=0
      ;;
  esac

  return ret
}

_svelte "$@"
