#compdef mp3packer
# Documentation: https://github.com/anders/mp3packer/blob/master/mp3packer.html
# mp3packer - losslessly repack MP3 files and minimize the bit reservoir

local ret=1

_arguments -s \
  '-b+[set minimum bitrate for output frames]:bitrate' \
  '-t[remove non-MP3 data at file beginning]' \
  '-s[remove non-MP3 data at file end]' \
  '-z[perform lossless recompression (brute-force)]' \
  '--workers=[thread count for -z processing]:count' \
  '-a+[append custom string to output filename]:string' \
  '-A[process files already containing the -a string]' \
  '-u[update input file in-place; backup to output]' \
  '-w[silence entire frame on error]' \
  '-r[force bit reservoir minimization always]' \
  '-R[maximize bit reservoir at every frame]' \
  '--keep-ok=[which files to retain after success]:mode:(out both)' \
  '--keep-bad=[which files to retain after errors]:mode:(in out both)' \
  '--copy-time[copy timestamps from input to output]' \
  '-f[force overwriting existing output files]' \
  '--process=[select processing algorithm for -z]:algo:(base sse41)' \
  '-i[print file information and exit]' \
  '--ib[print minimum CBR bitrate only]' \
  '--nice=[adjust program priority]:value' \
  '--debug=[output debugging information]:what:(in out huff all)' \
  '*:mp3 file:_files -g "*.mp3"' && ret=0

return ret
