#compdef cargo-unmaintained
# Documentation: https://crates.io/crates/cargo-unmaintained
# find unmaintained packages in Cargo dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--all-targets[consider all targets, not just the host]' \
  '--color[when to use color]:when:(always auto never)' \
  '--fail-fast[exit as soon as an unmaintained package is found]' \
  '--json[output JSON (experimental)]' \
  '--max-age[max age in days of a repository last commit]:days' \
  '--no-cache[do not cache data on disk for future runs]' \
  '--no-exit-code[do not set exit status when unmaintained packages found]' \
  '--no-warnings[do not show warnings]' \
  '(-p --package)'{-p,--package}'[check only whether package NAME is unmaintained]:package' \
  '--purge[remove all cached data from disk and exit]' \
  '--save-token[read a personal access token from stdin and save it]' \
  '--tree[show paths to unmaintained packages]' \
  '--verbose[show information about what cargo-unmaintained is doing]' && ret=0

return ret
