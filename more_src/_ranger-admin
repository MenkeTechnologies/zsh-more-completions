#compdef ranger-admin

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start the Apache Ranger Admin service'
  'stop:stop the Apache Ranger Admin service'
  'restart:stop and start the Apache Ranger Admin service'
  'metric:collect metrics from the service'
  'version:display version information'
)

_arguments -C \
  '(- *)--help[show help]' \
  '-type=[metric type]:type:(policies audits usergroup services database contextenrichers denyconditions)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ranger-admin subcommand' subcommands && ret=0
    ;;
esac

return ret
