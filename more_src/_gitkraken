#compdef gitkraken
# _gitkraken — Axosoft GitKraken cross-platform Git GUI CLI (Axosoft, Electron); custom argparse
# upstream: https://www.gitkraken.com

_gitkraken() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--path=+[repo path]:dir:_files -/' \
        '-p+[repo path]:dir:_files -/' \
        '--new[new instance]' \
        '-n[new instance]' \
        '--no-sandbox[no sandbox]' \
        '--disable-gpu[disable gpu]' \
        '--open=+[file to open]:file:_files' \
        '-o+[file to open]:file:_files' \
        '--profile=+[profile]:str:' \
        '--config=+[config file]:file:_files' \
        '--workspace=+[workspace]:str:' \
        '-w+[workspace]:str:' \
        '--clone-url=+[clone URL]:url:_urls' \
        '-c+[clone URL]:url:_urls' \
        '--init=+[init path]:dir:_files -/' \
        '-i+[init path]:dir:_files -/' \
        '--checkout-ref=+[ref]:str:' \
        '--diff=+[diff between]:str:' \
        '--user-data-dir=+[user data dir]:dir:_files -/' \
        '*:arg:'
}

_gitkraken "$@"
