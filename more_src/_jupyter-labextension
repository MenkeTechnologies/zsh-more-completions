#compdef jupyter-labextension

local -a subcmds

subcmds=(
    'install:Install a labextension'
    'develop:Install a source extension in development mode'
    'build:Build a labextension'
    'uninstall:Uninstall a labextension'
    'list:List installed labextensions'
    'enable:Enable a labextension'
    'disable:Disable a labextension'
    'lock:Lock a labextension'
    'unlock:Unlock a labextension'
    'check:Check labextension'
    'update:Update a labextension'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options'

case $state in
    subcmd)
        _describe -t commands 'jupyter-labextension subcommand' subcmds
        ;;
    options)
        case $words[1] in
            install)
                _arguments \
                    '--no-build[Do not build after install]' \
                    '--pin-version-as=[Pin version]:version' \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            develop)
                _arguments \
                    '--overwrite[Overwrite existing files]' \
                    '--symlink[Create symlinks instead of copies]' \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            build)
                _arguments \
                    '--development[Build in development mode]' \
                    '--source-map[Generate source maps]' \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            uninstall)
                _arguments \
                    '--no-build[Do not build after uninstall]' \
                    '--all[Uninstall all extensions]' \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            list)
                _arguments \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)'
                ;;
            enable|disable|lock|unlock)
                _arguments \
                    '--level=[Config level]:(user sys_prefix system)' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            update)
                _arguments \
                    '--all[Update all extensions]' \
                    '--no-build[Do not build after update]' \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
            check)
                _arguments \
                    '--debug[Set debug mode]' \
                    '--log-level=[Set log level]:(DEBUG INFO WARN ERROR CRITICAL)' \
                    '*:extension'
                ;;
        esac
        ;;
esac
