#compdef minify-js

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '--mode=+[mode]:mode:(global module)' \
  '*:js file:_files -g "*.js"' && ret=0

return ret
