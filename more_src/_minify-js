#compdef minify-js
# Documentation: https://man.archlinux.org/search?q=minify-js
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '--mode=+[mode]:mode:(global module)' \
  '*:js file:_files -g "*.js"' && ret=0

return ret
