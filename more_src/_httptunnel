#compdef htc hts

local curcontext="$curcontext" state line ret=1

case $service in
  (htc)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-A --forward-address)'{-A,--forward-address}'=[forward to address]:host\:port:' \
      '(-P --forward-port)'{-P,--forward-port}'=[forward to port]:port:' \
      '(-F --forward-host)'{-F,--forward-host}'=[forward to host]:host:_hosts' \
      '(-p --content-length)'{-p,--content-length}'=[content length]:length:' \
      '(-c --strict-content-length)'{-c,--strict-content-length}'[strict content length]' \
      '(-S --proxy)'{-S,--proxy}'=[HTTP proxy]:proxy:' \
      '(-U --proxy-authorization)'{-U,--proxy-authorization}'=[proxy auth]:user\:password:' \
      '(-k --keep-alive)'{-k,--keep-alive}'=[keep-alive interval]:seconds:' \
      '(-B --proxy-buffer-size)'{-B,--proxy-buffer-size}'=[proxy buffer size]:bytes:' \
      '(-M --max-connection-age)'{-M,--max-connection-age}'=[max connection age]:seconds:' \
      '(-w --no-cache)'{-w,--no-cache}'[disable caching]' \
      '(-d --device)'{-d,--device}'=[tunnel device]:device:_files' \
      '*:host\:port:' && ret=0
    ;;
  (hts)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-F --forward-port)'{-F,--forward-port}'=[forward to port]:host\:port:' \
      '(-p --content-length)'{-p,--content-length}'=[content length]:length:' \
      '(-c --strict-content-length)'{-c,--strict-content-length}'[strict content length]' \
      '(-M --max-connection-age)'{-M,--max-connection-age}'=[max connection age]:seconds:' \
      '(-w --no-cache)'{-w,--no-cache}'[disable caching]' \
      '(-d --device)'{-d,--device}'=[tunnel device]:device:_files' \
      '(-m --mime-type)'{-m,--mime-type}'=[MIME type]:type:' \
      '*:port:' && ret=0
    ;;
esac

return ret
