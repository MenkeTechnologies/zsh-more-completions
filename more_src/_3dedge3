#compdef 3dedge3
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dedge3.html
# AFNI: 3D edge detection (Canny/Deriche)

local ret=1

_arguments -s -S \
  '-input[input dataset]:dataset:_files' \
  '-verbose[informational messages during processing]' \
  '-prefix[output dataset prefix]:prefix:' \
  '-datum[output data type]:type:(byte short float)' \
  '-fscale[auto scale output to max integer range]' \
  '-gscale[uniform scaling across sub-bricks]' \
  '-nscale[disable scaling for byte/short output]' \
  '-scale_floats[multiply float input by value]:val:' \
  '-automask[generate internal mask]' \
  '*:dataset:_files' && ret=0

return ret
