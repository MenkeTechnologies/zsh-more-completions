#compdef rasusa
# Documentation: https://github.com/mbhall88/rasusa
# randomly subsample reads or alignments to a depth of coverage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show program version]' \
  '1:command:((
    reads\:"randomly subsample reads (FASTA/Q, unaligned SAM/BAM/CRAM)"
    aln\:"randomly subsample alignments to a specified depth of coverage"
    cite\:"obtain bibtex formatted citation"
    help\:"display help information"
  ))' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      reads)
        _arguments -s -S \
          '(-c --coverage)'{-c,--coverage}'[desired depth of coverage]:coverage:' \
          '(-g --genome-size)'{-g,--genome-size}'[genome size to calculate coverage]:size:' \
          '(-b --bases)'{-b,--bases}'[explicitly set number of bases required]:bases:' \
          '(-n --num)'{-n,--num}'[subsample to a specific number of reads]:num:' \
          '(-f --frac)'{-f,--frac}'[subsample to a fraction of the reads]:frac:' \
          '(-o --output)'{-o,--output}'[output filepath(s), stdout if unset]:output:_files' \
          '(-e --strict)'{-e,--strict}'[exit with error if coverage cannot be met]' \
          '(-s --seed)'{-s,--seed}'[random seed for reproducibility]:seed:' \
          '(-Z --compress-type)'{-Z,--compress-type}'[compression algorithm]:type:(u b g l x z)' \
          '(-O --output-format)'{-O,--output-format}'[output format]:format:' \
          '(-l --compress-level)'{-l,--compress-level}'[compression level]:level:' \
          '-v[enable verbose logging]' \
          '*:input:_files' && ret=0
        ;;
      aln)
        _arguments -s -S \
          '(-c --coverage)'{-c,--coverage}'[desired depth of coverage]:coverage:' \
          '(-o --output)'{-o,--output}'[output file path, stdout default]:output:_files' \
          '(-O --output-format)'{-O,--output-format}'[output format]:format:(s b c)' \
          '(-s --seed)'{-s,--seed}'[random seed for reproducibility]:seed:' \
          '--strategy[choose stream or fetch approach]:strategy:(stream fetch)' \
          '--swap-distance[max distance bp for read swapping in stream mode]:dist:' \
          '--step-size[step size when scanning for overlapping reads]:step:' \
          '--batch-size[genomic window size to cache in fetch mode]:size:' \
          '*:input:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
