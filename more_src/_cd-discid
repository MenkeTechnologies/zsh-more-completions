#compdef cd-discid
# Documentation: https://manpages.debian.org/bookworm/cd-discid/cd-discid.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm cd-discid(1) manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# cd-discid: read CD TOC and print CDDB disc ID
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--musicbrainz[output TOC suitable for MusicBrainz disc ID]' \
  '*:CD device:_files -g "/dev/(cdrom|cd0a|sr*)(-.)"' && ret=0
return ret
