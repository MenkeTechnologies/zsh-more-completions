#compdef svviz2
# Documentation: https://github.com/nspies/svviz2
# svviz2 - visual evaluation of read support for structural variation

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --ref)'{-r,--ref}'[reference fasta file]:fasta:_files' \
  '(-V --variants)'{-V,--variants}'[variants to analyze (vcf or bcf)]:variants:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory for visualizations]:dir:_files -/' \
  '--format[output format]:format:(pdf png svg)' \
  '--savereads[output the read realignments]' \
  '--min-mapq[only use reads with mapq >= value]:mapq' \
  '--align-distance[distance from breakpoint to align reads]:dist' \
  '--batch-size[number of reads to align per batch]:n' \
  '--downsample[downsample to this many reads]:n' \
  '--aligner[aligner to use]:aligner:(bwa ssw)' \
  '--only-realign-locally[only realign reads locally]' \
  '--fast[skip realignment of reads far from breakpoints]' \
  '--first-variant[index of first variant to analyze]:n' \
  '--last-variant[index of last variant to analyze]:n' \
  '--render-only[only render, do not realign]' \
  '--no-render[do not render visualizations]' \
  '--dotplots-only[only produce dotplots]' \
  '--no-dotplots[do not produce dotplots]' \
  '--report-only[only produce report]' \
  '--no-report[do not produce report]' \
  '--only-plot-context[only plot the context]' \
  '--also-plot-context[also plot the context]' \
  '*:bam:_files' && ret=0

return ret
