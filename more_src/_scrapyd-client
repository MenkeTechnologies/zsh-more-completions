#compdef scrapyd-client scrapyd-deploy
# Documentation: https://man.archlinux.org/search?q=scrapyd-client
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'targets:list configured deploy targets'
  'projects:list projects on a Scrapyd server'
  'spiders:list spiders for a project'
  'schedule:schedule a spider run'
  'deploy:deploy a Scrapy project to scrapyd'
  'job:job control commands (cancel/list)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--target=[target name]:target:' \
  '--project=[project name]:project:' \
  '--url=[Scrapyd URL]:url:' \
  '--username=[basic auth username]:user:' \
  '--password=[basic auth password]:password:' \
  '--include-egg=[include egg in deploy]:bool:(true false)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'scrapyd-client command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (schedule)
        _arguments \
          '--arg=[spider argument k=v]:kv:' \
          '*--setting=[scrapy setting]:setting:' \
          '*::spider:' && ret=0 ;;
      (deploy)
        _arguments \
          '--list-targets[list targets]' \
          '--list-projects=[list projects on target]:target:' \
          '--build-egg=[build egg to file]:file:_files' \
          '*::target_project:' && ret=0 ;;
      (job)
        _arguments \
          '*::sub:(cancel list)' && ret=0 ;;
    esac ;;
esac

return ret
