#compdef mongosh
# _mongosh — MongoDB Shell (modern replacement for the deprecated `mongo` legacy shell; JS REPL + connection helper)
# upstream: https://github.com/mongodb-js/mongosh
# Flags from packages/arg-parser/src/cli-options.ts on tip (Zod schema parsed by yargs-parser).

_mongosh() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '--build-info[print build info and exit]' \
        '--shell[start interactive shell after evaluating files/-eval]' \
        '--nodb[do not connect to any server on startup]' \
        '--norc[do not load mongoshrc.js on startup]' \
        '--quiet[suppress startup banner]' \
        '--verbose[verbose logging]' \
        '--ipv6[enable IPv6]' \
        '--retryWrites[enable retryWrites]' \
        '--skipStartupWarnings[suppress startup warnings]' \
        '--apiVersion=[server API version]:ver:' \
        '--apiStrict[require server to support all client commands]' \
        '--apiDeprecationErrors[treat deprecated server commands as errors]' \
        '--host=[mongod/mongos host]:host:_hosts' \
        '--port=[mongod/mongos port]:port:' \
        '--db=[database name]:db:' \
        '(-u --username)'{-u+,--username=}'[auth username]:user:' \
        '(-p --password)'{-p+,--password=}'[auth password]:pwd:' \
        '--authenticationDatabase=[authentication database]:db:' \
        '--authenticationMechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-X509 MONGODB-AWS GSSAPI PLAIN)' \
        '--awsAccessKeyId=[AWS access key]:key:' \
        '--awsSecretAccessKey=[AWS secret key]:secret:' \
        '--awsSessionToken=[AWS session token]:token:' \
        '--awsIamSessionToken=[AWS IAM session token]:token:' \
        '--gssapiServiceName=[GSSAPI service name]:name:' \
        '--sspiHostnameCanonicalization=[SSPI hostname canonicalization]:mode:' \
        '--sspiRealmOverride=[SSPI realm override]:realm:' \
        '--jsContext=[JS context]:ctx:(repl plain-vm auto)' \
        '--exposeAsyncRewriter[expose async-rewriter API]' \
        '--keyVaultNamespace=[CSFLE key vault namespace]:ns:' \
        '--kmsURL=[KMS provider URL]:url:_urls' \
        '--csfleLibraryPath=[CSFLE library path]:file:_files' \
        '--cryptSharedLibPath=[crypt_shared library path]:file:_files' \
        '--oidcFlows=[allowed OIDC auth flows]:flows:' \
        '--oidcRedirectUri=[OIDC redirect URI]:url:_urls' \
        '--oidcTrustedEndpoint[mark the connection endpoint as OIDC-trusted]' \
        '--oidcIdTokenAsAccessToken[send the OIDC ID token as access token]' \
        '--oidcNoNonce[disable OIDC nonce]' \
        '--oidcDumpTokens=[dump OIDC tokens]:mode:(redacted include-secrets)' \
        '--browser=[browser command for OIDC flow (false = none)]:cmd:' \
        '--tls[enable TLS]' \
        '--tlsCAFile=[TLS CA file]:file:_files' \
        '--tlsCertificateKeyFile=[TLS client cert+key PEM]:file:_files' \
        '--tlsCertificateKeyFilePassword=[client key passphrase]:pwd:' \
        '--tlsCertificateSelector=[OS cert store selector]:sel:' \
        '--tlsCRLFile=[TLS CRL file]:file:_files' \
        '--tlsDisabledProtocols=[comma-separated disabled TLS protocols]:list:' \
        '--tlsAllowInvalidCertificates[allow invalid server certificates]' \
        '--tlsAllowInvalidHostnames[allow invalid hostnames]' \
        '--tlsFIPSMode[enforce FIPS mode]' \
        '--tlsUseSystemCA[use system CA store]' \
        '*--eval=[evaluate JS expression (repeatable)]:js:' \
        '*'{-f+,--file=}'[execute JS file (repeatable)]:file:_files' \
        '--json=[output as EJSON]:mode:(relaxed canonical)' \
        '--locale=[i18n locale]:locale:' \
        '--deepInspect[deep inspect of results]' \
        '*:connection-string-or-file:_files'
}

_mongosh "$@"
