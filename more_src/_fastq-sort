#compdef fastq-sort
# Documentation: https://github.com/dcjones/fastq-tools
# sort fastq entries by various keys

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this message]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '(-r --reverse)'{-r,--reverse}'[sort in reverse (descending) order]' \
  '(-i --id)'{-i,--id}'[sort alphabetically by read identifier]' \
  '(-n --idn)'{-n,--idn}'[sort alphanumerically by read identifier (samtools sort -n)]' \
  '(-s --seq)'{-s,--seq}'[sort alphabetically by sequence]' \
  '(-R --random)'{-R,--random}'[randomly shuffle the sequences]' \
  '--seed=[seed to use for random shuffle]:seed:' \
  '(-G --gc)'{-G,--gc}'[sort by GC content]' \
  '(-M --mean-qual)'{-M,--mean-qual}'[sort by median quality score]' \
  '(-S --buffer-size)'{-S,--buffer-size=}'[amount of memory to use for sorting]:size:' \
  '(-T --temporary-directory)'{-T,--temporary-directory=}'[write temporary files here instead of TMPDIR]:dir:_files -/' \
  '*:fastq file:_files' && ret=0

return ret
