#compdef files-to-prompt
# Documentation: https://github.com/simonw/files-to-prompt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for files-to-prompt
# https://github.com/simonw/files-to-prompt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-e --extension)'{-e,--extension}'[only include files with extension]:extension:' \
  '(-i --ignore)'{-i,--ignore}'[glob patterns to ignore]:pattern:' \
  '--include-hidden[include hidden files]' \
  '--ignore-gitignore[do not respect .gitignore]' \
  '(-c --cxml)'{-c,--cxml}'[output in Claude XML format]' \
  '(-m --markdown)'{-m,--markdown}'[output as Markdown]' \
  '(-n --line-numbers)'{-n,--line-numbers}'[include line numbers]' \
  '(-o --output)'{-o,--output}'[write output to file]:file:_files' \
  '(-0 --null)'{-0,--null}'[use NUL character as separator]' \
  '*:path:_files' && ret=0

return ret
