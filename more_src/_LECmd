#compdef LECmd
# Documentation: https://github.com/EricZimmerman/LECmd
# Lnk Explorer Command line edition

local ret=1

_arguments -s -S \
  '-d[directory to recursively process]:directory:_files -/' \
  '-f[file to process]:file:_files' \
  '-q[only show the filename being processed]' \
  '-r[only process lnk files pointing to removable drives]' \
  '--all[process all files vs only *.lnk]' \
  '--csv[directory for CSV results]:directory:_files -/' \
  '--csvf[filename for CSV output]:filename' \
  '--xml[directory for XML results]:directory:_files -/' \
  '--html[directory for XHTML results]:directory:_files -/' \
  '--json[directory for JSON output]:directory:_files -/' \
  '--pretty[human readable JSON layout]' \
  '--nid[suppress Target ID list details]' \
  '--neb[suppress Extra blocks information]' \
  '--dt[custom date/time format]:format' \
  '--mp[display higher precision for timestamps]' && ret=0

return ret
