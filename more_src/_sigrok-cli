#compdef sigrok-cli
# Documentation: https://sigrok.org/wiki/Sigrok-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# libsigrok decode CLI: flags taken from upstream wiki.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-L --list-supported)'{-L,--list-supported}'[list supported drivers, formats, decoders]' \
  '(-d --driver)'{-d+,--driver=}'[hardware driver]:driver:' \
  '(-c --config)'{-c+,--config=}'[device options (e.g. samplerate)]:opt:' \
  '(-C --channels)'{-C+,--channels=}'[channels to use]:chans:' \
  '(-g --channel-group)'{-g+,--channel-group=}'[operate on specific channel group]:group:' \
  '(-i --input-file)'{-i+,--input-file=}'[load data from file]:file:_files' \
  '(-I --input-format)'{-I+,--input-format=}'[input format]:fmt:' \
  '(-o --output-file)'{-o+,--output-file=}'[save output to file]:file:_files' \
  '(-O --output-format)'{-O+,--output-format=}'[output format]:fmt:' \
  '(-t --triggers)'{-t+,--triggers=}'[trigger conditions]:trig:' \
  '(-w --wait-trigger)'{-w,--wait-trigger}'[suppress pre-trigger data]' \
  '--time=[sample for milliseconds]:ms:' \
  '--samples=[acquire N samples]:n:' \
  '--frames=[acquire N frames]:n:' \
  '--continuous[sample continuously]' \
  '(-P --protocol-decoders)'{-P+,--protocol-decoders=}'[decoders to use]:decoders:' \
  '(-A --protocol-decoder-annotations)'{-A+,--protocol-decoder-annotations=}'[annotation output]:ann:' \
  '(-M --protocol-decoder-meta)'{-M+,--protocol-decoder-meta=}'[show decoder metadata]:meta:' \
  '(-B --protocol-decoder-binary)'{-B+,--protocol-decoder-binary=}'[output binary decoder data]:bin:' \
  '--show[display info about selected device/decoder]' \
  '--scan[detect available devices]' \
  '(-l --loglevel)'{-l+,--loglevel=}'[set debug verbosity level]:level:(0 1 2 3 4 5)' \
  '--get=[retrieve variable value]:var:' \
  '--set[set variables without acquisition]' \
  '*::args:_default' && ret=0

return ret
