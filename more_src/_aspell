#compdef aspell
# Documentation: aspell --help on Aspell 0.60.8
# Source: GNU Aspell — interactive spell checker (replaces ispell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'usage:brief usage'
    'help:detailed help'
    'check:spellcheck a file'
    'pipe:ispell -a compatibility mode'
    'list:list misspelled words from stdin'
    'dump:dump configuration / dicts / filters / modes / dictionaries'
    'config:print value of an option'
    'soundslike:print sounds-like equivalents'
    'munch:generate possible root words and affixes'
    'expand:expand affix flags (1..4)'
    'clean:clean a word list'
    'filter:filter as if spellchecking'
    'version:print version'
    'munch-list:reduce word list via affix compression'
    'conv:convert between encodings'
    'norm:perform Unicode normalization'
    'create:create personal / repl / master dictionary'
    'merge:merge personal / repl / master dictionary'
)

_arguments -s -C \
    '--conf=[main configuration file]:file:_files' \
    '--conf-dir=[location of main config file]:dir:_files -/' \
    '--data-dir=[location of language data files]:dir:_files -/' \
    '--add-dict-alias=[create dictionary alias]:alias:' \
    '--rem-dict-alias=[remove dictionary alias]:alias:' \
    '--dict-dir=[location of word list]:dir:_files -/' \
    '--encoding=[expected data encoding]:enc:' \
    '*--add-filter=[add a filter]:filter:' \
    '*--rem-filter=[remove a filter]:filter:' \
    '--mode=[filter mode]:mode:(none url email html tex sgml nroff markdown texinfo perl)' \
    '(-e --mode=email -H --mode=html -t --mode=tex -n --mode=nroff -M --mode=markdown)-e[Email mode]' \
    '(-e --mode=email -H --mode=html -t --mode=tex -n --mode=nroff -M --mode=markdown)-H[HTML mode]' \
    '(-e --mode=email -H --mode=html -t --mode=tex -n --mode=nroff -M --mode=markdown)-t[TeX mode]' \
    '(-e --mode=email -H --mode=html -t --mode=tex -n --mode=nroff -M --mode=markdown)-n[Nroff mode]' \
    '(-e --mode=email -H --mode=html -t --mode=tex -n --mode=nroff -M --mode=markdown)-M[Markdown mode]' \
    '--home-dir=[location for personal files]:dir:_files -/' \
    '(-W --ignore)'{-W,--ignore=}'[ignore words <= N chars]:n:' \
    '--ignore-case[ignore case when checking]' \
    '--dont-ignore-case[do not ignore case]' \
    '--keyboard=[keyboard for typo analysis]:layout:' \
    '(-l --lang)'{-l,--lang=}'[language code]:lang:' \
    '(-d --master)'{-d,--master=}'[base name of main dictionary]:name:' \
    '--normalize[enable Unicode normalization]' \
    '--norm-form=[Unicode normalization form]:form:(none nfd nfc comp)' \
    '(-p --personal)'{-p,--personal=}'[personal dictionary file]:file:_files' \
    '--repl=[replacements list file]:file:_files' \
    '(-C -B --run-together --dont-run-together)'{-C,-B}'[allow / disallow run-together words]' \
    '--size=[word list size]:size:(10 20 30 40 50 60 70 80 90)' \
    '--sug-mode=[suggestion mode]:mode:(ultra fast normal slow bad-spellers)' \
    '(-?|usage|help|check|pipe|list|version|dump|config|soundslike|munch|expand|clean|filter|munch-list|conv|norm|create|merge)1:verb:->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        _describe -t aspell-verbs 'aspell command' verbs && ret=0
        ;;
    args)
        case $line[1] in
            check) _files && ret=0 ;;
            config) _message 'option key' && ret=0 ;;
            *) _files && ret=0 ;;
        esac
        ;;
esac

return ret
