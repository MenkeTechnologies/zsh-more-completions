#compdef postsrsd
# Documentation: https://man.archlinux.org/search?q=postsrsd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --secret)'{-s,--secret}'+[secret file]:file:_files' \
  '(-d --domain)'{-d,--domain}'+[primary domain]:domain:' \
  '(-D --daemon)'{-D,--daemon}'[run as daemon]' \
  '(-f --forward-port)'{-f,--forward-port}'+[forward port]:port:' \
  '(-r --reverse-port)'{-r,--reverse-port}'+[reverse port]:port:' \
  '(-l --listen-addr)'{-l,--listen-addr}'+[listen address]:addr:' \
  '(-u --user)'{-u,--user}'+[user]:user:_users' \
  '(-c --chroot)'{-c,--chroot}'+[chroot dir]:dir:_files -/' \
  '(-p --pid-file)'{-p,--pid-file}'+[pid file]:file:_files' \
  '(-X --exclude-domains)'{-X,--exclude-domains}'+[domain list]:domains:' \
  '(-A --always-rewrite)'{-A,--always-rewrite}'[always rewrite]' \
  '(-N --hash-length)'{-N,--hash-length}'+[hash length]:n:' \
  '(-t --time-validity)'{-t,--time-validity}'+[validity days]:days:' \
  '(-C --config)'{-C,--config}'+[config file]:file:_files' && ret=0

return ret
