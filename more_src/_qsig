#compdef qsig
# Documentation: https://man.archlinux.org/search?q=qsig
# Reference accessed: 2026-05-16

# qsig: send a signal to a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[signal]:signal:' \
  '-W[wait]:delay:' \
  '*:jobid:' && ret=0
return ret
