#compdef qsig
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qsig.htm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qsig: send a signal to a PBS/TORQUE job
local curcontext="$curcontext" ret=1
_arguments -C \
  '-s+[signal to send (name, no-SIG name, number, suspend, resume)]:signal:' \
  '-a[run the command asynchronously]' \
  '*:jobid:' && ret=0
return ret
