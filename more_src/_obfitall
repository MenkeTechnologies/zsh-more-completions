#compdef obfitall
# Documentation: https://openbabel.org/docs/Command-line_tools.html
# Open Babel: superimpose all molecules of a file onto a reference using a SMARTS pattern

local ret=1

_arguments -s -S \
  ':SMARTS pattern:' \
  ':fixed reference file:_files' \
  ':file to move/fit:_files' && ret=0

return ret
