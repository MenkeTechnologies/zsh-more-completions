#compdef ic-repl
# _ic-repl — Internet Computer canister REPL (dfinity/ic-repl)
# upstream: https://github.com/dfinity/ic-repl
# Flags from src/main.rs (clap derive).

_ic-repl() {
    local -a args
    args=(
        '(-r --replica)'{-r+,--replica=}'[replica URL (local / ic / explicit URL)]:replica:(local ic)'
        '(-o --offline)'{-o,--offline}'[offline mode (signed messages stored in messages.json)]'
        '(-f --format)'{-f+,--format=}'[offline output format]:format:(ascii json png ascii_no_url png_no_url)'
        '(-u --url)'{-u+,--url=}'[URL embedded in QR code for offline ascii/png]:url:'
        '(-c --config)'{-c+,--config=}'[Candid random-value generation config file]:file:_files'
        '(-i --interactive)'{-i,--interactive}'[enter REPL after running the script]'
        '(-s --send)'{-s+,--send=}'[send signed messages from FILE]:file:_files -g "*.json"'
        '(-v --verbose)'{-v,--verbose}'[verbose mode (also outputs non-text values)]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '1:ic-repl script file:_files -g "*.sh"'
        '*::extra args for __main:'
    )
    _arguments -s -S $args
}

_ic-repl "$@"
