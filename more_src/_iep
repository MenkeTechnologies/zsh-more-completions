#compdef iep
# Documentation: https://man.archlinux.org/search?q=iep
# Reference accessed: 2026-05-16

# EMBOSS iep: calculate the isoelectric point of protein(s)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-amino=[amino acid count]:n:' \
  '-carboxyl=[carboxyl count]:n:' \
  '-pkdata=[pK data file]:file:_files' \
  '-step=[step size for pH increment]:step:' \
  '-lysinemodified[treat lysines as modified]' \
  '-disulphides=[number of disulphide bonds]:n:' \
  '-notermini[ignore termini in pI calculation]' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-plot[produce graph output]' \
  '-report[produce report output]' \
  '-outfile=[output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
