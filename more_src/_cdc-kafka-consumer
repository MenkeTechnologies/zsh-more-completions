#compdef cdc-kafka-consumer
# _cdc-kafka-consumer — TiCDC reference Kafka downstream consumer
# upstream: https://github.com/pingcap/tiflow
# Flags from cmd/kafka-consumer/main.go on tip.

_cdc-kafka-consumer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-config=[changefeed config file]:file:_files' \
        '-upstream-uri=[upstream Kafka URI]:uri:' \
        '-downstream-uri=[downstream sink URI]:uri:' \
        '-schema-registry-uri=[schema-registry URI]:uri:' \
        '-upstream-tidb-dsn=[upstream TiDB DSN]:dsn:' \
        '-consumer-group-id=[Kafka consumer group id]:id:' \
        '-log-file=[log file path]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-tz=[Kafka consumer time zone]:tz:' \
        '-ca=[Kafka CA cert file]:file:_files' \
        '-cert=[Kafka client cert file]:file:_files' \
        '-key=[Kafka client key file]:file:_files' \
        '-enable-profiling[enable pprof endpoint]'
}

_cdc-kafka-consumer "$@"
