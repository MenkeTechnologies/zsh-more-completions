#compdef calcure

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--folder+[set folder for data files]:directory:_files -/' \
  '--config+[set config file path]:config:_files' \
  '--task+[task to add from CLI]:task:' \
  '--event+[event to add from CLI]:event:' \
  '--privacy[start in privacy mode]' && ret=0

return ret
