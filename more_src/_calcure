#compdef calcure
# Documentation: https://anufrievroman.gitbook.io/calcure/user-arguments
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[display help page at startup]' \
  '-v[show version information and exits]' \
  '-j[open the application on the journal page]' \
  '-i[launch using the Persian calendar system]' \
  '-p[enable privacy mode]' \
  '--folder=[custom folder for storing data files]:directory:_files -/' \
  '--config=[alternative configuration file]:config:_files' \
  '--task=[create a new task without launching the program]:task:' \
  '--event=[create a new event (YYYY-MM-DD-text)]:event:' && ret=0

return ret
