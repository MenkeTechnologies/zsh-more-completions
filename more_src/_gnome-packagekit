#compdef gnome-packagekit gpk-application gpk-update-viewer gpk-prefs gpk-log
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/gpk-application.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu focal gpk-application(1) manpage. Only --verbose documented;
# rest are standard GTK options inherited from GApplication.

# gnome-packagekit (gpk-application): PackageKit GTK frontend
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--verbose[enable verbose output]' \
  '--display=[X display to use]:display:' && ret=0
return ret
