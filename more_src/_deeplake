#compdef deeplake activeloop
# Documentation: https://man.archlinux.org/search?q=deeplake
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:log in to Deep Lake / Activeloop platform'
  'logout:log out of Activeloop'
  'list:list datasets'
  'create:create a new dataset'
  'load:load a dataset summary'
  'delete:delete a dataset'
  'push:push a dataset version'
  'pull:pull a dataset'
  'connect:connect a managed dataset'
  'reset:reset the dataset'
  'history:show dataset version history'
  'tags:list/manage tags'
  'tensor:tensor management'
  'vis:open the dataset in the web UI'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--token=[Activeloop token]:token:' \
  '--username=[username]:user:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'deeplake command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|load|delete|reset)
        _arguments \
          '*::dataset:' \
          '--read-only[open read-only]' \
          '--overwrite[overwrite existing]' && ret=0 ;;
      (tensor)
        _arguments \
          '*::sub:(create delete list info)' \
          '--name=[tensor name]:name:' \
          '--htype=[tensor htype]:htype:(image generic class_label bbox audio video text json point_cloud)' \
          '--dtype=[dtype]:dtype:' && ret=0 ;;
      (tags)
        _arguments '*::sub:(list add remove)' && ret=0 ;;
      (connect)
        _arguments \
          '--dataset=[dataset URI]:uri:' \
          '--token=[token]:token:' \
          '--read-only[open read-only]' && ret=0 ;;
    esac ;;
esac

return ret
