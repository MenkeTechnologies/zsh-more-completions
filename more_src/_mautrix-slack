_mautrix-slack() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help and exit]' \
        '(- *)'{-v,--version}'[show bridge version and exit]' \
        '(- *)--version-json[print JSON version object and exit]' \
        '(-c --config)'{-c,--config}'=[config file path (default config.yaml)]:path:_files -g "*.yaml *.yml"' \
        '(-e --generate-example-config)'{-e,--generate-example-config}'[save example config and quit]' \
        '(-n --no-update)'{-n,--no-update}'[do not save updated config to disk]' \
        '(-r --registration)'{-r,--registration}'=[appservice registration path (default registration.yaml)]:path:_files -g "*.yaml *.yml"' \
        '(-g --generate-registration)'{-g,--generate-registration}'[generate appservice registration and quit]' \
        '--ignore-unsupported-database[run even if the database schema is too new]' \
        '--ignore-foreign-tables[run even if the DB contains tables from other programs]' \
        '--ignore-unsupported-server[run even if the Matrix homeserver advertises an outdated CSAPI version]'
}

_mautrix-slack "$@"
