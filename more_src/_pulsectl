#compdef pulsectl

# Zsh completion for pulsectl - PulseAudio CLI controller

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'list:list PulseAudio objects'
      'set-volume:set volume for a sink or source'
      'set-mute:mute or unmute a sink or source'
      'set-default:set default sink or source'
      'move:move a stream to a different sink or source'
      'info:show PulseAudio server info'
      'upload-sample:upload audio sample to server'
      'play-sample:play a cached audio sample'
      'remove-sample:remove a cached audio sample'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '1:type:(sinks sources sink-inputs source-outputs cards modules)' \
          && ret=0
        ;;
      (set-volume|set-mute|set-default)
        _arguments \
          '1:type:(sink source sink-input source-output)' \
          '2:index or name:' \
          '3:value:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
