#compdef kubepug

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-walk[walk through all API versions]' \
  '(-c --cluster)'{-c,--cluster}'[cluster name]:cluster' \
  '--context[kubernetes context]:context' \
  '--error-on-deprecated[exit with error code on deprecated APIs]' \
  '--error-on-deleted[exit with error code on deleted APIs]' \
  '(-f --format)'{-f,--format}'[output format]:format:(plain json yaml)' \
  '(-i --input-file)'{-i,--input-file}'[input file]:file:_files' \
  '(-K --k8s-version)'{-K,--k8s-version}'[Kubernetes version to check against]:version' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'[path to kubeconfig file]:file:_files' \
  '(-s --swagger-dir)'{-s,--swagger-dir}'[directory containing swagger files]:dir:_files -/' && ret=0

return ret
