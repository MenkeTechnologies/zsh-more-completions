#compdef sbopkg

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-B[batch mode]' \
  '-d+[diff mode]:flag:(0 1)' \
  '-D[dialog mode]' \
  '-e+[on error]:flag:(stop continue ask)' \
  '-f+[config file]:file:_files' \
  '-g[get only - download but do not build]' \
  '-i+[install pkg]:pkg:' \
  '-k[keep package after install]' \
  '-l[list available repositories]' \
  '-n[no install - build only]' \
  '-o[overwrite existing package]' \
  '-p+[search packages by name]:query:' \
  '-q+[queue file]:file:_files -g "*.sqf"' \
  '-r+[remove pkg]:pkg:' \
  '-R[reset state]' \
  '-s+[sync repository]:repo:' \
  '-S+[set repository]:repo:' \
  '-u[show updates]' \
  '-v[verbose]' && ret=0

return ret
