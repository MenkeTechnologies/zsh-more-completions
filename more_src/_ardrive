#compdef ardrive
# Documentation: https://man.archlinux.org/search?q=ardrive
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create-drive:create a new ArDrive (public or private)'
  'create-folder:create a folder under a parent'
  'upload-file:upload a file or folder'
  'create-manifest:create an Arweave path manifest'
  'move-file:move a file to a new parent folder'
  'move-folder:move a folder to a new parent folder'
  'rename-file:rename a file'
  'rename-folder:rename a folder'
  'rename-drive:rename a drive'
  'retry-tx:retry an unbundled transaction'
  'file-info:show file metadata'
  'folder-info:show folder metadata'
  'drive-info:show drive metadata'
  'list-folder:list folder children'
  'list-drive:list a drive content tree'
  'list-all-drives:list drives for a wallet address'
  'download-file:download a single file'
  'download-folder:download a folder tree'
  'download-drive:download an entire drive'
  'generate-seedphrase:generate a recovery seedphrase'
  'generate-wallet:create a wallet file from seedphrase'
  'get-address:show Arweave address for a wallet'
  'get-balance:show AR/Winston balance'
  'send-ar:transfer AR between wallets'
  'get-drive-key:derive a private drive key'
  'get-file-key:derive a file encryption key'
  'last-tx:show most recent wallet transaction'
  'base-reward:show base transaction reward'
  'get-mempool:show mempool transactions'
  'create-tx:create an offline signed transaction'
  'send-tx:broadcast a transaction'
  'tx-status:check transaction status'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --wallet-file)'{-w+,--wallet-file=}'[wallet file]:file:_files -g "*.json"' \
  '(-s --seed-phrase)'{-s+,--seed-phrase=}'[wallet seed phrase]:phrase:' \
  '--dry-run[preview without broadcasting]' \
  '--turbo[use ArDrive Turbo for upload]' \
  '--boost=[fee multiplier]:n:' \
  '--gateway=[Arweave gateway URL]:url:' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ardrive command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create-drive)
        _arguments \
          '(-n --drive-name)'{-n+,--drive-name=}'[drive name]:name:' \
          '(-p --drive-password)'{-p+,--drive-password=}'[private drive password]:password:' \
          '--drive-key=[hex drive key for private drive]:key:' && ret=0 ;;
      (upload-file)
        _arguments \
          '(-l --local-path)'{-l+,--local-path=}'[file or folder to upload]:path:_files' \
          '(-F --parent-folder-id)'{-F+,--parent-folder-id=}'[parent folder id]:id:' \
          '(-d --drive-id)'{-d+,--drive-id=}'[drive id]:id:' \
          '--dest-file-name=[destination file name]:name:' \
          '--content-type=[override content-type]:type:' \
          '(-p --drive-password)'{-p+,--drive-password=}'[private drive password]:password:' && ret=0 ;;
      (download-file|download-folder|download-drive)
        _arguments \
          '(-i --file-id)'{-i+,--file-id=}'[file id]:id:' \
          '(-F --folder-id)'{-F+,--folder-id=}'[folder id]:id:' \
          '(-d --drive-id)'{-d+,--drive-id=}'[drive id]:id:' \
          '--dest-folder-path=[output folder]:dir:_files -/' \
          '(-p --drive-password)'{-p+,--drive-password=}'[private drive password]:password:' \
          '--max-depth=[max recursion depth]:n:' && ret=0 ;;
      (list-folder)
        _arguments \
          '(-F --parent-folder-id)'{-F+,--parent-folder-id=}'[folder id]:id:' \
          '--max-depth=[max depth]:n:' \
          '--all[include hidden]' && ret=0 ;;
      (list-drive)
        _arguments \
          '(-d --drive-id)'{-d+,--drive-id=}'[drive id]:id:' \
          '--max-depth=[max depth]:n:' && ret=0 ;;
      (file-info|folder-info|drive-info)
        _arguments \
          '(-i --file-id)'{-i+,--file-id=}'[file id]:id:' \
          '(-F --folder-id)'{-F+,--folder-id=}'[folder id]:id:' \
          '(-d --drive-id)'{-d+,--drive-id=}'[drive id]:id:' && ret=0 ;;
      (send-ar)
        _arguments \
          '--ar-amount=[amount in AR]:amount:' \
          '--dest-address=[destination address]:addr:' && ret=0 ;;
    esac ;;
esac

return ret
