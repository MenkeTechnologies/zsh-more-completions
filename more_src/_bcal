#compdef bcal
# Documentation: https://github.com/jarun/bcal
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bcal: storage and general-purpose byte calculator

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-b+[start in REPL mode or evaluate expression]:expr:' \
  '-c+[show positive integer N in binary/decimal/hex]:n:' \
  '-p+[show bit position with bit value for N]:n:' \
  '-f+[convert CHS<->LBA]:loc:' \
  '-s+[set sector size (default 512)]:bytes:' \
  '-m[show minimal output]' \
  '-H[show integral math results in hex]' \
  '-d[enable debug information and logs]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args: _default' && ret=0

return ret
