#compdef cmpress
# Documentation: https://man.archlinux.org/search?q=cmpress
# Reference accessed: 2026-05-16

# Infernal cmpress: prepare CM database for cmscan (build SSI/idx files)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-F[force - overwrite existing binary files]' \
  '*:CM database file:_files' && ret=0
return ret
