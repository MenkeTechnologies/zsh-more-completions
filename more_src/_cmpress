#compdef cmpress
# Documentation: https://manpages.debian.org/testing/infernal/cmpress.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Infernal cmpress: prepare CM database for cmscan (build SSI/idx files)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-F[force overwrite of existing binary files]' \
  '*:CM database file:_files' && ret=0
return ret
