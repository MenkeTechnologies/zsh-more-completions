#compdef ko

# Zsh completion for ko (Build and deploy Go containers)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:Build and publish container images from Go binaries'
      'resolve:Fill in image digests for import paths in YAML'
      'apply:Apply the input files to the current cluster'
      'create:Create the input files on the current cluster'
      'delete:Delete resources from the current cluster'
      'run:Build an image, then run it in a container'
      'login:Log in to a container registry'
      'version:Print the version'
    )
    _describe -t commands 'ko command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '-h[Print help]'
      '--help[Print help]'
      '-B[Do not append the build timestamp]'
      '--base-import-paths[Use the base path without MD5 hash]'
      '--bare[Alias for --base-import-paths]'
      '--disable-optimizations[Disable compiler optimizations]'
      '--image-label=[Label to add to the image]:key=value'
      '--image-refs=[Path to file for image references]:file:_files'
      '--insecure-registry[Push to insecure registry over HTTP]'
      '-L[Build for local Docker daemon]'
      '--local[Build for local Docker daemon]'
      '--oci-layout-path=[Path to OCI layout]:dir:_directories'
      '--platform=[Target platform]:platform'
      '--push[Push image to registry (default true)]'
      '--sbom=[SBOM media type]:type:(none spdx cyclonedx go.version-m)'
      '--sbom-dir=[Directory to write SBOMs]:dir:_directories'
      '--tag-only[Only use provided tags for images]'
      '-t+[Tag for the built image]:tag'
      '--tags=[Tags for the built image]:tags'
      '--tarball=[Path to save tarball]:file:_files'
    )

    case ${words[1]} in
      build)
        _arguments -s -S \
          $common_flags \
          '*:importpath' && ret=0
        ;;
      resolve)
        _arguments -s -S \
          $common_flags \
          '-f+[Path to a file to resolve]:file:_files' \
          '--filename=[Path to a file to resolve]:file:_files' \
          '-R[Process the directory recursively]' \
          '--recursive[Process the directory recursively]' \
          '-l+[Selector (label query) to filter on]:selector' \
          '--selector=[Selector (label query) to filter on]:selector' \
          '*:importpath' && ret=0
        ;;
      apply)
        _arguments -s -S \
          $common_flags \
          '-f+[Filename, directory, or URL to apply]:file:_files' \
          '--filename=[Filename, directory, or URL to apply]:file:_files' \
          '-R[Process the directory recursively]' \
          '--recursive[Process the directory recursively]' \
          '-l+[Selector (label query) to filter on]:selector' \
          '--selector=[Selector (label query) to filter on]:selector' \
          '--watch[Watch for changes and re-apply]' \
          '-W[Watch for changes and re-apply]' \
          '*:importpath' && ret=0
        ;;
      create)
        _arguments -s -S \
          $common_flags \
          '-f+[Filename, directory, or URL to create]:file:_files' \
          '--filename=[Filename, directory, or URL to create]:file:_files' \
          '-R[Process the directory recursively]' \
          '--recursive[Process the directory recursively]' \
          '-l+[Selector (label query) to filter on]:selector' \
          '--selector=[Selector (label query) to filter on]:selector' \
          '*:importpath' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-f+[Filename, directory, or URL to delete]:file:_files' \
          '--filename=[Filename, directory, or URL to delete]:file:_files' \
          '-R[Process the directory recursively]' \
          '--recursive[Process the directory recursively]' \
          '-l+[Selector (label query) to filter on]:selector' \
          '--selector=[Selector (label query) to filter on]:selector' && ret=0
        ;;
      run)
        _arguments -s -S \
          $common_flags \
          '--image=[Run an existing image instead of building]' \
          '*:importpath' && ret=0
        ;;
      login)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-u+[Username]:username' \
          '--username=[Username]:username' \
          '-p+[Password]:password' \
          '--password=[Password]:password' \
          '--password-stdin[Read password from stdin]' \
          '1:registry' && ret=0
        ;;
    esac
    ;;
esac

return ret
