#compdef ionic2
# _ionic2 — Drifty Co Ionic Framework ionic2 CLI command-line frontend wrapping the Ionic Framework Ionic CLI complete command-line interface for Ionic apps open-source cross-platform mobile-app-development built-on-top-of-Capacitor-or-Cordova originally Drifty Co written in TypeScript Node start g generate build serve deploy run cordova capacitor ssh ssh-add ssh-generate config repair docs help info link login logout monitoring push payments deploy enterprise integrations doctor analytics test telemetry codecov (Drifty Co Ionic team Max Lynch Ben Sperry Adam Bradley, TypeScript); commander
# upstream: https://ionicframework.com/

_ionic2() {
    local -a sub=(
        'build:build app'
        'cap:Capacitor operations'
        'capacitor:Capacitor operations'
        'completion:generate shell completion'
        'config:configure CLI'
        'cordova:Cordova operations'
        'cwd:print cwd'
        'deploy:Ionic Appflow deploy'
        'docs:open docs'
        'doctor:diagnose project'
        'enterprise:Ionic Enterprise operations'
        'g:generate (alias)'
        'generate:scaffold a feature'
        'help:show help'
        'info:show env info'
        'init:initialize an app'
        'integrations:integration ops'
        'link:link project to Appflow'
        'live-reload:enable live reload'
        'login:authenticate'
        'logout:revoke session'
        'monitoring:monitoring operations'
        'platform:platform operations'
        'plugin:plugin operations'
        'push:push notifications'
        'repair:repair install'
        'run:run on device'
        'serve:run dev server'
        'signup:sign up an account'
        'ssh:SSH operations'
        'start:create a new app'
        'state:state operations'
        'telemetry:telemetry config'
        'upload:upload to Appflow'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[no color]' \
        '--no-interactive[non interactive]' \
        '--confirm[confirm]' \
        '--token=+[token]:str:' \
        '--type=+[t]:t:(angular vue react ionic-angular ionic1)' \
        '--prod[production]' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--config=+[file]:file:_files -g "ionic.config.json *.json"' \
        '--platform=+[p]:p:(ios android browser)' \
        '-p+[platform]:p:(ios android browser)' \
        '--target=+[name]:str:' \
        '-t+[target]:str:' \
        '--device[device]' \
        '--emulator[emulator]' \
        '--livereload[live reload]' \
        '-l[live reload]' \
        '--external[external]' \
        '--ssl[use SSL]' \
        '--proxy=+[url]:str:' \
        '--port=+[port]:n:' \
        '--public-host=+[host]:_hosts' \
        '--source-map[source maps]' \
        '--lab[run lab]' \
        '--lab-host=+[host]:_hosts' \
        '--lab-port=+[port]:n:' \
        '--open[open browser]' \
        '-o[open]' \
        '--browser=+[name]:str:' \
        '--browser-option=+[opt]:str:' \
        '--list[list]' \
        '--display-name=+[name]:str:' \
        '--package-id=+[id]:str:' \
        '--app-id=+[id]:str:' \
        '--bundle-id=+[id]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--module=+[name]:str:' \
        '-m+[module]:str:' \
        '--scss=+[v]:v:(true false)' \
        '--spec=+[v]:v:(true false)' \
        '--export[export]' \
        '--standalone[standalone]' \
        '--routing[routing]' \
        '--no-build[no build]' \
        '--build[build]' \
        '--variant=+[v]:str:' \
        '--keystorepath=+[file]:_files' \
        '--keystorealias=+[name]:str:' \
        '--keystorepass=+[password]:str:' \
        '--keystorealiaspass=+[password]:str:' \
        '--release[release]' \
        '--app=+[id]:str:' \
        '--channel=+[name]:str:' \
        '--build-id=+[id]:str:' \
        '--snapshot=+[id]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ionic subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments '1:name:' '2:template:' '*:arg:' ;;
                g|generate) _arguments '1:type:(page component service module pipe directive guard provider tabs)' '*:name:' ;;
                build|serve|run) _arguments '*:platform:(ios android browser)' ;;
                cap|capacitor) _arguments '1:op:(add build copy doctor init ls open run sync update)' '*:platform:(ios android web)' ;;
                cordova) _arguments '1:op:(build compile emulate platform plugin prepare requirements resources run state run)' '*:arg:' ;;
                deploy) _arguments '1:op:(build manifest add deploy)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ionic2 "$@"
