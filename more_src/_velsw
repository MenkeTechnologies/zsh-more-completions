#compdef velsw
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/velsw.html
# MIRIAD: change the spectral axis type of an image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'axis=[spectral type to convert to]:axis:(FREQ ENER WAVN VRAD WAVE VOPT ZOPT AWAV VELO BETA)' \
  'options=[altspc]:options:(altspc)' \
  '*:image:_files' && ret=0

return ret
