#compdef cargo-chef

# Zsh completion for cargo-chef - cache Rust dependencies for Docker builds

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'prepare:generate a recipe.json from the current project'
  'cook:cook the dependencies according to a recipe.json'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'cargo-chef command' commands && ret=0
    ;;
  args)
    case $words[1] in
      prepare)
        _arguments \
          '--recipe-path[output recipe path]:file:_files' \
          '--bin[main binary name]:binary:' \
          '--manifest-path[path to Cargo.toml]:file:_files' && ret=0
        ;;
      cook)
        _arguments \
          '--recipe-path[input recipe path]:file:_files' \
          '--release[build in release mode]' \
          '--no-build[do not actually build]' \
          '--no-std[do not use std]' \
          '--profile[build profile]:profile:(dev release)' \
          '--target[target triple]:target:' \
          '--target-dir[directory for build artifacts]:dir:_directories' \
          '--bin[build only the specified binary]:binary:' \
          '--package[build only the specified package]:package:' \
          '--workspace[build all packages in workspace]' \
          '--all-targets[build all targets]' \
          '--tests[build tests]' \
          '--examples[build examples]' \
          '--benches[build benches]' \
          '--features[features to activate]:features:' \
          '--no-default-features[do not activate default features]' \
          '--all-features[activate all features]' \
          '--timings[output build timings]' \
          '--manifest-path[path to Cargo.toml]:file:_files' \
          '--locked[require Cargo.lock to be up to date]' \
          '--offline[run without accessing the network]' \
          '--frozen[require Cargo.lock and cache to be up to date]' \
          '--zigbuild[use cargo-zigbuild]' \
          '--clippy[run clippy on dependencies]' && ret=0
        ;;
    esac
    ;;
esac

return ret
