#compdef cube2
# Documentation: https://manpages.debian.org/bookworm/cube2/cube2.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm cube2(6) manpage OPTIONS section. Same engine
# flags as sauerbraten. -f without arg disables shaders entirely.

# Cube 2: 3D OpenGL game engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[run as dedicated server (no client)]' \
  '-w[window width in pixels]:width:' \
  '-h[window height in pixels]:height:' \
  '-z[z-buffer precision in bits]:depth:' \
  '-b[bits per pixel]:bpp:' \
  '-a[Full Scene Antialiasing samples]:samples:' \
  '-t[run in windowed mode]' \
  '-k[add directory to data search paths]:dir:_files -/' \
  '-f[shader precision (0-3; 0 disables shaders)]:n:(0 1 2 3)' \
  '*::extra args:_files' && ret=0
return ret
