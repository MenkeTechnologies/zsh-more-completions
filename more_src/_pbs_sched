#compdef pbs_sched

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[alarm seconds]:sec:' \
  '-c+[config file]:file:_files' \
  '-d+[home directory]:dir:_files -/' \
  '-L+[log file]:file:_files' \
  '-N[do not detach]' \
  '-p+[priv file]:file:_files' \
  '-R+[port]:port:' \
  '-S+[server name]:host:_hosts' \
  '-s+[server port]:port:' && ret=0

return ret
