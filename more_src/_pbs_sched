#compdef pbs_sched
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/pbs_sched.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a+[time in seconds to wait for a schedule run to finish]:sec:' \
  '-c+[configuration file]:file:_files' \
  '-d+[PBS home directory]:dir:_files -/' \
  '-L+[log file path]:file:_files' \
  '-p+[print file for stdout/stderr]:file:_files' \
  '-R+[resource monitor port]:port:' \
  '-S+[scheduler port]:port:' && ret=0

return ret
