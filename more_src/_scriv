#compdef scriv

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'create:Create a new changelog fragment'
      'collect:Collect changelog fragments into CHANGELOG'
      'github-release:Create a GitHub release from latest changelog'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--edit[open fragment in editor]' \
          '--no-edit[do not open fragment in editor]' && ret=0
        ;;
      (collect)
        _arguments \
          '--edit[open changelog in editor after collecting]' \
          '--no-edit[do not open changelog in editor]' \
          '--add[git add the changelog]' \
          '--no-add[do not git add]' \
          '--version+[version to collect for]:version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
