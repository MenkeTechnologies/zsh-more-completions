#compdef create-foundry
# Documentation: https://www.npmjs.com/package/create-foundry
# Reference accessed: 2026-05-23
# Verified: npx create-foundry --help.

# Zsh completion for create-foundry - scaffold an IncuBrain Foundry project

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --template)'{-t,--template=}'[project template]:template:(default)' \
  ':project directory:_directories' && ret=0

return ret
