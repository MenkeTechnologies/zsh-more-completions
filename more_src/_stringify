#compdef stringify
# UCSC kent: convert file to C strings

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-var=[create a variable with this name containing the string]:name:' \
  '-static[put static in front of the variable]' \
  '-array[create an array of strings, one for each line]' \
  ':in txt:_files' && ret=0

return ret
