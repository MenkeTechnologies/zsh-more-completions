#compdef qmail-inject

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[do not add From, Message-ID, Date]' \
  '-A[add headers (default)]' \
  '-f+[envelope sender]:sender:' \
  '-F+[envelope sender (qmail-queue env)]:sender:' \
  '-h[treat all argv as headers]' \
  '-H[do not treat argv as headers]' \
  '-n[stop after generating headers]' \
  '-N[default - do not stop]' \
  '-q[quiet]' \
  '-Q[verbose (default)]' \
  '-s[single recipient mode]' \
  '-S[multiple recipient mode]' \
  '*:recipient:_email_addresses' && ret=0

return ret
