#compdef qmail-inject
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/qmail-inject.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[send to recip args only; ignore header recipient addresses]' \
  '-A[send to recip args; fall back to header addresses (default)]' \
  '-h[send to header recipient addresses]' \
  '-H[send to header recipient addresses AND recip args]' \
  '-f+[envelope sender address for qmail-queue]:sender:' \
  '-n[print the message rather than feeding to qmail-queue]' \
  '-N[feed resulting message to qmail-queue (default)]' \
  '*:recipient:_email_addresses' && ret=0

return ret
