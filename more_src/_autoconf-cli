#compdef autoconf-cli
# _autoconf-cli — GNU autoconf generate configure scripts CLI alias (GNU team, M4); custom argparse
# upstream: https://www.gnu.org/software/autoconf/

_autoconf-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f[force]' \
        '--force[force]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-W+[warning category]:c:(all none cross syntax obsolete unsupported error)' \
        '--warnings=+[warning category]:c:(all none cross syntax obsolete unsupported error)' \
        '-B+[file dir]:dir:_files -/' \
        '--prepend-include=+[file dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '--include=+[include dir]:dir:_files -/' \
        '-t+[trace macros]:str:' \
        '--trace=+[trace macros]:str:' \
        '-i[initialization warnings]' \
        '--initialization[initialization warnings]' \
        '*:template file:_files -g "*.{ac,in,m4}"'
}

_autoconf-cli "$@"
