#compdef bean-bake
# Documentation: https://manpages.debian.org/testing/beancount/bean-bake.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bean-bake: bake a static web view of a Beancount ledger (Beancount v2; removed in v3)

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--port=[server port]:port:' \
  '(-q --quiet)'{-q,--quiet}'[suppress server logging]' \
  '--debug[enable debug mode (auto-reload CSS)]' \
  '--incognito[hide numbers in output]' \
  '--no-source[do not render the source]' \
  '--no-colons[do not render colons in filenames (Windows)]' \
  '--view=[render only specified view URL]:url:' \
  '(--public --inaddr-any)'{--public,--inaddr-any}'[listen on any address]' \
  '--first-month=[first month of calendar year]:n:' \
  '(--render-all-pages --full)'{--render-all-pages,--full}'[render all pages]' \
  '1:input:_files -g "*.beancount"' \
  '2:output:_files'
