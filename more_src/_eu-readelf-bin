#compdef eu-readelf
# _eu-readelf-bin — elfutils readelf (Ulrich Drepper, Red Hat); read ELF binaries, DWARF debug data
# upstream: https://sourceware.org/elfutils

_eu-readelf-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[all info]' \
        '(-h --file-header)'{-h,--file-header}'[file header]' \
        '(-l --program-headers --segments)'{-l,--program-headers,--segments}'[program headers]' \
        '(-S --section-headers --sections)'{-S,--section-headers,--sections}'[section headers]' \
        '(-g --section-groups)'{-g,--section-groups}'[section groups]' \
        '(-e --exception)'{-e,--exception}'[exception data]' \
        '(-s --symbols)'{-s,--symbols}'[symbol table]' \
        '(-n --notes)'{-n,--notes}'[notes]' \
        '(-r --relocs)'{-r,--relocs}'[relocations]' \
        '(-u --unwind)'{-u,--unwind}'[unwind info]' \
        '(-d --dynamic)'{-d,--dynamic}'[dynamic section]' \
        '(-V --version-info)'{-V,--version-info}'[version sections]' \
        '(-A --arch-specific)'{-A,--arch-specific}'[arch specific]' \
        '(-c --archive-index)'{-c,--archive-index}'[archive index]' \
        '(-x --hex-dump)'{-x,--hex-dump}'+[hex dump section]:section:' \
        '(-p --string-dump)'{-p,--string-dump}'+[string dump section]:section:' \
        '(-w --debug-dump)'{-w,--debug-dump}'+[dwarf section]:section:(abbrev addr aranges decodedline exception frame gdb_index info loc loclists macinfo macro pubnames pubtypes ranges rnglists str str_offsets trace_aranges trace_abbrev trace_info)' \
        '(-N --numeric-addresses)'{-N,--numeric-addresses}'[no symbolize]' \
        '(-D --use-dynamic)'{-D,--use-dynamic}'[use dynamic symbols]' \
        '(-W --wide)'{-W,--wide}'[wide output]' \
        '--strings[print printable strings]' \
        '--decompress[decompress sections]' \
        '--elf-section+[ELF section]:section:' \
        '--symbol-versions[show symbol versions]' \
        '(-z --decompress)'{-z,--decompress}'[decompress before dump]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-readelf-bin "$@"
