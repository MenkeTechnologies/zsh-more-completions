#compdef gh-profile
# Documentation: https://github.com/gabe565/gh-profile
# gh-profile - GitHub CLI extension to manage multiple gh config profiles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(create c new add switch activate active sw s rename mv list ls l remove delete rm d show)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      switch|activate|active|sw|s)
        _arguments -s -S \
          '(-l --local-dir)'{-l,--local-dir}'[activate profile for current directory only]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:profile:' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:profile:' && ret=0
        ;;
    esac
    ;;
esac

return ret
