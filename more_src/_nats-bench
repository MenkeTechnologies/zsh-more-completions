#compdef nats-bench
# Documentation: https://man.archlinux.org/search?q=nats-bench
# Reference accessed: 2026-05-16

_arguments -s \
  '-s[server URLs]:urls:' \
  '-tls[use TLS]' \
  '-np[concurrent publishers]:n:' \
  '-ns[concurrent subscribers]:n:' \
  '-n[message count]:n:' \
  '-ms[message size]:n:' \
  '-csv[CSV output]:file:_files' \
  '-creds[credentials]:file:_files' \
  '-nkey[NKey seed]:file:_files' \
  '-h[show help]' \
  '*:subject:'
