#compdef meshconv
# Documentation: https://www.patrickmin.com/meshconv/
# meshconv - 3D model format converter

local ret=1

_arguments -s -S \
  '-c[specify output format]:format:(obj off ply dxf vrml stl js xml3d)' \
  '-tri[triangulate geometry during conversion]' \
  '-mat[convert VRML materials to PLY materials]' \
  '-ascii[write ASCII output (STL)]' \
  '-kd[keep duplicate vertices]' \
  '-license[display license information]' \
  '*:model file:_files -g "*.{obj,off,ply,dxf,wrl,stl,3ds,json}"' && ret=0

return ret
