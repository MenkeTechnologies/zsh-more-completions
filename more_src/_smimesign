#compdef smimesign

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--sign[create a signature]' \
  '-s[create a signature]' \
  '--verify[verify a signature]' \
  '--list-keys[list available keys]' \
  '-u+[specify signing identity]:identity' \
  '--local-user=[specify signing identity]:identity' \
  '-b[create ASCII armored output]' \
  '--armor[create ASCII armored output]' \
  '-a[create ASCII armored output]' \
  '--detach-sign[create a detached signature]' \
  '--status-fd=[write status to file descriptor]:fd' \
  '--include-certs=[include N certificates in signature]:count' \
  '--timestamp-authority=[timestamp authority URL]:URL' && ret=0

return ret
