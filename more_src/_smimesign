#compdef smimesign
# Documentation: https://github.com/github/smimesign
# Reference accessed: 2026-05-21
# Verified: upstream main.go flag definitions at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(--sign -s --verify --list-keys)'{-s,--sign}'[create a signature]' \
  '(--sign -s --verify --list-keys)--verify[verify a signature]' \
  '(--sign -s --verify --list-keys)--list-keys[display available signing identities]' \
  '(-u --local-user)'{-u+,--local-user=}'[specify USER-ID for signing]:identity:' \
  '(-b --detach-sign)'{-b,--detach-sign}'[create a detached signature]' \
  '(-a --armor)'{-a,--armor}'[create ASCII armored output]' \
  '--status-fd=[write status strings to file descriptor]:fd:' \
  '--keyid-format=[select key ID display format]:format:(long short)' \
  '(-t --timestamp-authority)'{-t+,--timestamp-authority=}'[RFC3161 timestamp authority URL]:URL:' \
  '--include-certs=[number of certificates to include in signature]:count:' \
  '*:file:_files' && ret=0

return ret
