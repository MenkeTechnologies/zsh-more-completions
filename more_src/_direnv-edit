#compdef direnv-edit
# _direnv-edit — direnv shell environment switcher edit subcommand alias (Zimbatm / direnv team, Go); custom argparse
# upstream: https://github.com/direnv/direnv

_direnv-edit() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--editor=+[editor command]:str:' \
        '*:envrc:_files -g ".envrc *.envrc"'
}

_direnv-edit "$@"
