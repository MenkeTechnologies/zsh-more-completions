#compdef 1dsvd
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dsvd.html
# Compute SVD of the matrix formed by the 1D file(s)

local ret=1

_arguments -s -S \
  '(-vmean)-one[make first vector consist entirely of ones]' \
  '(-one)-vmean[remove mean from each vector]' \
  '-vnorm[normalize L2-norm of each vector to 1 before SVD]' \
  '-cond[output only the condition number]' \
  '-sing[output only singular values]' \
  '-sort[sort singular values in descending order (default)]' \
  '-nosort[skip sorting singular values]' \
  '-asort[sort singular values in ascending order]' \
  '-1Dleft[output only left eigenvectors in 1D format]' \
  '-nev[with -1Dleft, output only first n eigenvectors]:n' \
  '*:file:_files' && ret=0

return ret
