#compdef check_disk
# Documentation: https://www.monitoring-plugins.org/doc/man/check_disk.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Nagios monitoring-plugins: check disk usage and inode usage thresholds

_arguments -s \
  '(-w --warning)'{-w,--warning}'=[warning threshold]:threshold:' \
  '(-c --critical)'{-c,--critical}'=[critical threshold]:threshold:' \
  '(-W --iwarning)'{-W,--iwarning}'=[inode warning]:threshold:' \
  '(-K --icritical)'{-K,--icritical}'=[inode critical]:threshold:' \
  '*'{-p,--path,--partition}'=[path/partition]:path:_files -/' \
  '*'{-x,--exclude_device}'=[exclude device]:device:' \
  '*'{-X,--exclude-type}'=[exclude fs type]:type:' \
  '*'{-N,--include-type}'=[include fs type]:type:' \
  '(-e --errors-only)'{-e,--errors-only}'[only show errors]' \
  '(-f --freespace-ignore-reserved)'{-f,--freespace-ignore-reserved}'[ignore reserved]' \
  '(-A --all)'{-A,--all}'[explicitly select all]' \
  '*'{-i,--ignore-ereg-path,--ignore-ereg-partition}'=[ignore regex path]:regex:' \
  '*'{-I,--ignore-eregi-path,--ignore-eregi-partition}'=[ignore regex path (i)]:regex:' \
  '*'{-r,--ereg-path,--ereg-partition}'=[regex path]:regex:' \
  '*'{-R,--eregi-path,--eregi-partition}'=[regex path (i)]:regex:' \
  '*'{-M,--mountpoint}'[display mountpoint]' \
  '(-u --units)'{-u,--units}'=[units]:unit:(B kB MB GB TB)' \
  '(-k --kilobytes)'{-k,--kilobytes}'[kilobytes]' \
  '(-m --megabytes)'{-m,--megabytes}'[megabytes]' \
  '(-l --local)'{-l,--local}'[only local fs]' \
  '(-L --stat-remote-fs)'{-L,--stat-remote-fs}'[stat remote fs]' \
  '(-P --iperfdata)'{-P,--iperfdata}'[inode perf data]' \
  '(-g --group)'{-g,--group}'=[group name]:name:' \
  '(-C --clear)'{-C,--clear}'[clear thresholds before next set]' \
  '(-E --exact-match)'{-E,--exact-match}'[exact match]' \
  '(-n --ignore-missing)'{-n,--ignore-missing}'[ignore missing paths]' \
  '--display-unit=[display unit]:unit:' \
  '--output-format=[output format]:fmt:' \
  '--extra-opts=[extra opts]:section:' \
  '(-t --timeout)'{-t,--timeout}'=[timeout]:s:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
