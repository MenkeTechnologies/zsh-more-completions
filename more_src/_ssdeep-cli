#compdef ssdeep-cli
# _ssdeep-cli — Jesse Kornblum ssdeep fuzzy hashing program CLI alias (ssdeep-project team, C); custom argparse
# upstream: https://github.com/ssdeep-project/ssdeep

_ssdeep-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-m+[match against file]:file:_files' \
        '-k+[match against another file of hashes]:file:_files' \
        '-d[directory mode]' \
        '-p[pretty match mode]' \
        '-t+[threshold]:n:' \
        '-x+[compare two known files of hashes]:file:_files' \
        '-a[display all matches]' \
        '-g[clustering mode]' \
        '-r[recursive mode]' \
        '-b[print only base name]' \
        '-l[print relative file path]' \
        '-c[output in CSV format]' \
        '-s[silent mode]' \
        '-v[verbose mode]' \
        '-w+[width]:n:' \
        '-B[multi-thread mode]' \
        '-C+[chunk size]:n:' \
        '-j+[threads]:n:' \
        '-F+[byte order]:str:' \
        '*:files:_files'
}

_ssdeep-cli "$@"
