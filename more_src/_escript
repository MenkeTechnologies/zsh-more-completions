#compdef escript
# _escript — Erlang escript runner (Ericsson, Erlang); run Erlang programs as scripts without compile step
# upstream: https://github.com/erlang/otp

_escript() {
    _arguments \
        '-c[compile escript]' \
        '-e+[execute expression]:str:' \
        '-i[interpret escript]' \
        '-s[only check syntax]' \
        '-d[debug]' \
        '*:script:_files'
}

_escript "$@"
