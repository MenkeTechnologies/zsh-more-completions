#compdef pdb_shiftres
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Shifts the residue numbering by a given number, e.g. -10 or --5

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[shift amount, e.g. -10 or --5]:shift' \
  '*:PDB file:_files' && ret=0

return ret
