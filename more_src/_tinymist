#compdef tinymist
# Documentation: https://man.archlinux.org/search?q=tinymist
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--listen[listen on address]:address:' \
  '*--font-path[add font search path]:path:_directories' \
  '--root[set root directory]:root:_directories' \
  '--mirror[mirror mode]:mode:(all completion packages)' \
  '--persist[persist server state]' \
  '--prefer-theme[prefer light or dark theme]:theme:(light dark)' \
  '*:file:_files' && ret=0

return ret
