#compdef tinymist
# Documentation: https://myriad-dreamin.github.io/tinymist/feature/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lsp:start Language Server Protocol server'
  'dap:start Debug Adapter Protocol server'
  'preview:start preview server for a typ file'
  'compile:compile a Typst document'
  'test:execute tests'
  'completion:generate shell completion script'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--save-lock[save compilation commands to lock file]' \
  '--lockfile=[custom lock file location]:file:_files' \
  '--verbose[enable verbose output]' \
  '--log-filter=[log filter expression]:filter' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tinymist command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (compile|preview|test)
        _arguments '*:file:_files -g "*.typ"' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
