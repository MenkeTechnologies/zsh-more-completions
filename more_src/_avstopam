#compdef avstopam
# Documentation: man avstopam (Netpbm)
# Source: convert an AVS X (Stardent) image file to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:avs file:_files -g "*.(avs|x)"' \
    && ret=0

return ret
