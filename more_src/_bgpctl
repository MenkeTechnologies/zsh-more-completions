#compdef bgpctl
# _bgpctl — OpenBSD bgpctl (control + introspect the running bgpd(8) daemon; show neighbors/rib/fib/network/sets/flowspec, manage announce/withdraw, reload, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/bgpctl)
# Flags + commands from usr.sbin/bgpctl/bgpctl.8 on tip.

_bgpctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-j[output as JSON]' \
        '-n[show numeric neighbor IPs instead of description]' \
        '-s+[control socket]:file:_files' \
        '-V[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'bgpctl command' \
                '(show:show subsystem state (summary|neighbor|rib|fib|network|sets|flowspec|nexthop|metric|interface|tables) fib:fib couple/decouple/reload neighbor:up/down/clear a peer reload:reload bgpd configuration log:set log level (brief|verbose|reload) network:add/delete/flush/show network announcements flowspec:add/delete/flush/show flowspec rules)'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(summary neighbor rib fib network sets flowspec nexthop metric interface tables)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple reload)' ;;
                log) _describe -t commands 'log level' '(brief verbose reload)' ;;
                network|flowspec) _describe -t commands 'subcommand' '(add delete flush show bulk)' ;;
                neighbor) _describe -t commands 'neighbor subcommand' '(up down clear destroy)' ;;
            esac
            ;;
    esac
}

_bgpctl "$@"
