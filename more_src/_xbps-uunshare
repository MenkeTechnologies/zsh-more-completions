#compdef xbps-uunshare
# Documentation: https://man.archlinux.org/search?q=xbps-uunshare
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-b+[bind mount /src:/dest]:bind:' \
  '1:chroot_dir:_files -/' \
  '*::command:_command_names' && ret=0

return ret
