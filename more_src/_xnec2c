#compdef xnec2c
# Documentation: https://man.archlinux.org/search?q=xnec2c
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input)'{-i,--input}'+[input file]:file:_files -g "*.nec"' \
  '(-o --optimize)'{-o,--optimize}'[optimization]' \
  '(-O --debug-optimize)'{-O,--debug-optimize}'[debug optimization]' \
  '(-j --jobs)'{-j,--jobs}'+[jobs]:n:' \
  '(-b --batch)'{-b,--batch}'[batch mode]' \
  '(-q --quit)'{-q,--quit}'[quit after batch]' \
  '(-P --pixmap-dir)'{-P,--pixmap-dir}'+[pixmap dir]:dir:_files -/' \
  '(-D --debug)'{-D,--debug}'+[debug level]:lvl:' \
  '*:nec file:_files -g "*.nec"' && ret=0

return ret
