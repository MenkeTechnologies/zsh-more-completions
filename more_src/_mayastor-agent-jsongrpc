#compdef mayastor-agent-jsongrpc agent-jsongrpc
# _mayastor-agent-jsongrpc — Mayastor JSON-gRPC adapter agent (front-ends the Core agent with a JSON-gRPC API)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/agents/src/bin/jsongrpc/main.rs CliArgs on tip (clap).

_mayastor-agent-jsongrpc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-J --json-grpc-server-addr)'{-J,--json-grpc-server-addr}'=[JSON-gRPC bind address]:addr:' \
        '(-z --core-grpc)'{-z,--core-grpc}'=[core gRPC URL to connect to]:url:_urls'
}

_mayastor-agent-jsongrpc "$@"
