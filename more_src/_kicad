#compdef kicad
# Documentation: https://man.archlinux.org/search?q=kicad
# Reference accessed: 2026-05-16

# Zsh completion for kicad - KiCad EDA suite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.{kicad_pro,pro}"' && ret=0

return ret
