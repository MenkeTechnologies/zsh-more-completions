#compdef master
# _master — Postfix master(8) daemon (the resident process that forks postfix child daemons on demand per master.cf; usually controlled via the postfix(1) wrapper rather than invoked directly)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man8/master.8 on tip.

_master() {
    _arguments \
        '-c+[config directory]:dir:_files -/' \
        '-D[run debugger after init (uses main.cf debugger_command)]' \
        '-d[keep stdin/stdout/stderr + controlling tty (debug only)]' \
        '-e+[terminate after N seconds]:sec:' \
        '-i[init mode (PID 1 only; do not become session/process-group leader)]' \
        '-s[do not redirect stdout to /dev/null (for maillog_file=/dev/stdout)]' \
        '-t[test if master is running (zero exit if pid file is unlocked)]' \
        '*-v[verbose logging (repeat for more, propagated to children)]' \
        '-w[wait for background master to finish init before exiting foreground]'
}

_master "$@"
