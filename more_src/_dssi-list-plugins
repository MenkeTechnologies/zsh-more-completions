#compdef dssi-list-plugins
# Documentation: https://man.archlinux.org/search?q=dssi-list-plugins
# Reference accessed: 2026-05-16

# dssi-list-plugins: list installed DSSI audio plugins on the system
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[verbose output]' \
  '*::dssi-list-plugins args:_files' && ret=0
return ret
