#compdef mustache-cli
# _mustache-cli — Mustache logic-less templates CLI alias (mustache project, JavaScript/Ruby); custom argparse
# upstream: https://github.com/mustache/mustache

_mustache-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--render=+[render template with data]:file:_files' \
        '-r+[render template with data]:file:_files' \
        '--compile=+[compile template]:file:_files -g "*.mustache *.tpl"' \
        '-c+[compile template]:file:_files -g "*.mustache *.tpl"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--partial=+[partial]:list:' \
        '-p+[partial]:list:' \
        '--data=+[data file]:file:_files -g "*.json *.yml *.yaml"' \
        '-d+[data file]:file:_files -g "*.json *.yml *.yaml"' \
        '--layout=+[layout file]:file:_files' \
        '-l+[layout file]:file:_files' \
        '--strict[strict mode]' \
        '-s[strict mode]' \
        '*:template:_files -g "*.mustache *.tpl"'
}

_mustache-cli "$@"
