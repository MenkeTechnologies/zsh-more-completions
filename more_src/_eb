#compdef eb

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize an EB application'
  'create:create a new environment'
  'deploy:deploy code to an environment'
  'status:show environment status'
  'health:show environment health'
  'events:show environment events'
  'logs:retrieve logs'
  'ssh:SSH into an instance'
  'terminate:terminate an environment'
  'list:list environments'
  'console:open AWS console for the environment'
  'scale:scale environment instances'
  'swap:swap environment CNAMEs'
  'codesource:configure code source'
  'config:edit environment configuration'
  'labs:experimental commands'
  'local:run application locally'
  'platform:manage platforms'
  'printenv:print environment variables'
  'setenv:set environment variables'
  'tags:manage environment tags'
  'abort:abort a running deployment'
  'appversion:manage application versions'
  'clone:clone an environment'
  'restore:restore a terminated environment'
  'upgrade:upgrade an environment platform'
  'use:set the default environment'
  'migrate:migrate from older versions'
  'open:open the environment URL in browser'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[debug output]' \
  '--no-verify-ssl[do not verify SSL]' \
  '--profile=[AWS profile]:profile:' \
  '--quiet[quiet output]' \
  '--region=[AWS region]:region:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'eb subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (platform)
        _values 'platform action' \
          'list' 'select' 'show' 'use' 'create' 'init' 'events' 'logs' 'status' 'delete' && ret=0
        ;;
      (labs)
        _values 'labs action' \
          'cleanup-versions' 'convert-dockerrun' 'download' 'quicklink' 'setup-cwl' && ret=0
        ;;
      (local)
        _values 'local action' \
          'run' 'open' 'logs' 'status' 'setenv' 'printenv' && ret=0
        ;;
      (config)
        _values 'config action' \
          'put' 'get' 'list' 'delete' 'save' && ret=0
        ;;
      (appversion)
        _values 'appversion action' 'lifecycle' 'delete' 'create' && ret=0
        ;;
      (tags)
        _values 'tags action' 'add' 'delete' 'list' 'update' && ret=0
        ;;
      (codesource)
        _values 'codesource' 'codecommit' 'local' && ret=0
        ;;
    esac
    ;;
esac

return ret
