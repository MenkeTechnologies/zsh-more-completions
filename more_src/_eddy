#compdef eddy
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/diffusion/eddy/users_guide/index.html
# eddy - correct eddy current distortions and subject movement in diffusion data

local ret=1

_arguments -s -S \
  '--imain=[input diffusion-weighted images]:file:_files' \
  '--mask=[brain mask]:file:_files' \
  '--acqp=[acquisition parameters text file]:file:_files' \
  '--index=[image-to-acqp index text file]:file:_files' \
  '--bvecs=[diffusion gradient directions]:file:_files' \
  '--bvals=[diffusion b-values]:file:_files' \
  '--out=[output basename]:file:_files' \
  '--topup=[topup output basename]:basename:_files' \
  '--field=[off-resonance field]:file:_files' \
  '--field_mat=[field-to-image registration matrix]:file:_files' \
  '--json=[json file with slice timing]:file:_files' \
  '--slspec=[slice specification text file]:file:_files' \
  '--flm=[first level EC model (movement/linear/quadratic/cubic)]:model:(movement linear quadratic cubic)' \
  '--slm=[second level EC model (none/linear/quadratic)]:model:(none linear quadratic)' \
  '--fwhm=[FWHM for conditioning filter]:fwhm:' \
  '--niter=[number of iterations]:n:' \
  '--interp=[interpolation model (spline/trilinear)]:interp:(spline trilinear)' \
  '--resamp=[resampling method (jac/lsr)]:resamp:(jac lsr)' \
  '--fep[fill empty planes in x/y/z direction]' \
  '--nvoxhp=[number of voxels used for hyperparameter estimation]:n:' \
  '--ff=[fudge factor for hyperparameter cost function]:ff:' \
  '--dont_sep_offs_move[do not attempt to separate field offset from movement]' \
  '--dont_peas[do not perform post-eddy alignment of shells]' \
  '--repol[detect and replace outlier slices]' \
  '--ol_nstd=[number of std deviations for outlier detection]:n:' \
  '--ol_nvox=[minimum voxels in a slice for outlier detection]:n:' \
  '--ol_type=[type of outliers (sw/gw/both)]:type:(sw gw both)' \
  '--ol_pos[detect positive outliers as well]' \
  '--ol_sqr[detect outliers based on sum of squares]' \
  '--mb=[multi-band factor]:n:' \
  '--mb_offs=[multi-band slice offset]:n:' \
  '--mporder=[order of slice-to-volume movement model]:n:' \
  '--s2v_niter=[slice-to-volume iterations]:n:' \
  '--s2v_lambda=[slice-to-volume regularisation weight]:n:' \
  '--s2v_interp=[slice-to-volume interpolation]:interp:(spline trilinear)' \
  '--estimate_move_by_susceptibility[estimate susceptibility-by-movement]' \
  '--mbs_niter=[susceptibility-by-movement iterations]:n:' \
  '--mbs_lambda=[susceptibility-by-movement regularisation]:n:' \
  '--mbs_ksp=[susceptibility-by-movement knot spacing mm]:n:' \
  '--b_range=[b-value range for shell detection]:range:' \
  '--cnr_maps[write shell-wise CNR maps]' \
  '--residuals[write residuals (data minus model prediction)]' \
  '--data_is_shelled[bypass shell checking]' \
  '--nthr=[number of threads]:n:' \
  '--verbose[verbose output]' \
  '--very_verbose[very verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
