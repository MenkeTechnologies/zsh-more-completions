#compdef maestro

# Zsh completion for maestro - Maestro mobile UI testing

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_maestro_global_flags=(
  '--host=[host address]:host:_hosts'
  '--port=[port number]:port:'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -s -S -C \
  "${_maestro_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'test:Run Maestro flow tests'
      'cloud:Run flows on Maestro Cloud'
      'upload:Upload an app to Maestro Cloud'
      'record:Record a flow'
      'hierarchy:Print the view hierarchy'
      'studio:Launch Maestro Studio'
      'download-drivers:Download platform drivers'
      'query:Query the view hierarchy'
    )
    _describe -t commands 'maestro commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      test)
        _arguments -s -S \
          "${_maestro_global_flags[@]}" \
          '*'{-e,--env}'=[set environment variable]:variable (KEY=VALUE):' \
          '--device=[device to run on]:device:' \
          '--format=[output format]:format:(junit)' \
          '--output=[output file]:output file:_files' \
          '--debug-output=[debug output directory]:directory:_files -/' \
          '--flatten-debug-output[flatten debug output directory structure]' \
          '--continuous[run in continuous mode]' \
          '--config=[configuration file]:config file:_files' \
          '--shards=[number of shards]:shards:' \
          '--shard-split=[shard split strategy]:split:' \
          '--shard-all[distribute all flows to all shards]' \
          '*--include-tags=[include flows with tag]:tag:' \
          '*--exclude-tags=[exclude flows with tag]:tag:' \
          '*:flow files:_files -g "*.yaml"' && ret=0
        ;;
      cloud)
        _arguments -s -S \
          "${_maestro_global_flags[@]}" \
          '--apiKey=[API key]:key:' \
          '--apiUrl=[API URL]:url:' \
          '--app-file=[path to app file]:app file:_files' \
          '--async[run asynchronously]' \
          '--android-api-level=[Android API level]:level:' \
          '--ios-version=[iOS version]:version:' \
          '*--include-tags=[include flows with tag]:tag:' \
          '*--exclude-tags=[exclude flows with tag]:tag:' \
          '--name=[test run name]:name:' \
          '--device-locale=[device locale]:locale:' \
          '*:flow files:_files -g "*.yaml"' && ret=0
        ;;
      record)
        _arguments -s -S \
          "${_maestro_global_flags[@]}" \
          '--continuous[run in continuous mode]' \
          '*'{-e,--env}'=[set environment variable]:variable (KEY=VALUE):' \
          '*:flow files:_files -g "*.yaml"' && ret=0
        ;;
      query)
        _arguments -s -S \
          "${_maestro_global_flags[@]}" \
          '*'{-e,--env}'=[set environment variable]:variable (KEY=VALUE):' && ret=0
        ;;
      hierarchy|studio|download-drivers|upload)
        _arguments -s -S \
          "${_maestro_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
