#compdef timescaledb-parallel-copy
# Documentation: https://github.com/timescale/timescaledb-parallel-copy/blob/master/cmd/timescaledb-parallel-copy/main.go
# Reference accessed: 2026-05-27
# Verified: upstream flag.* calls in cmd/timescaledb-parallel-copy/main.go (timescale/timescaledb-parallel-copy)

# timescaledb-parallel-copy: parallelized COPY for TimescaleDB

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--connection=[PostgreSQL connection url]:url:' \
  '--db-name=[(deprecated) database name where destination table exists]:name:' \
  '--table=[destination table for insertions]:name:' \
  '--schema=[destination table schema]:name:' \
  '--truncate[truncate destination table before insert]' \
  '--copy-options=[additional options to pass to COPY]:options:' \
  '--split=[character to split CSV fields by]:char:' \
  '--quote=[QUOTE character to use during COPY]:char:' \
  '--escape=[ESCAPE character to use during COPY]:char:' \
  '--file=[file to read from rather than stdin]:file:_files' \
  '--columns=[comma-separated columns present in CSV]:cols:' \
  '--column-mapping=[column mapping from CSV to database columns]:mapping:' \
  '--auto-column-mapping[automatically map CSV headers to database columns]' \
  '--skip-header[skip the first line of input]' \
  '--header-line-count=[(deprecated) number of header lines]:n:' \
  '--skip-lines=[skip the first N lines of input]:n:' \
  '--skip-batch-errors[continue copying even if a batch fails]' \
  '--import-id=[ImportID to guarantee idempotency]:id:' \
  '--batch-size=[number of rows per insert]:n:' \
  '--buffer-byte-size=[number of bytes to buffer]:bytes:' \
  '--batch-byte-size=[max bytes to send in a batch]:bytes:' \
  '--limit=[number of rows to insert overall]:n:' \
  '--workers=[number of parallel requests to make]:n:' \
  '--log-batches[time individual batches]' \
  '--reporting-period=[period to report insert stats]:duration:' \
  '--verbose[print more information about copying statistics]' \
  '--on-conflict-do-nothing[skip duplicate rows on unique constraint violations]' \
  '--version[show the version of this tool]' \
  '--disable-direct-compress[disable using direct compress to write data]' \
  '--enable-client-side-sorting[guarantee data order client side]' \
  '--disable-windows-1252-handling[disable automatic encoding handling]' \
  '--no-retry[disable retrying on recoverable errors]' \
  '--retry-timeout=[abort retrying recoverable errors after this duration]:duration:' && ret=0

return ret
