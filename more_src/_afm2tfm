#compdef afm2tfm
# Documentation: afm2tfm --help (TeX Live 2026 dvips support)
# Source: convert Adobe Font Metric (AFM) to TeX Font Metric (TFM), optionally emitting VPL for VF construction.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[print help]' \
    '(- *)--version[print version]' \
    '-a[omit heuristic adjustment of heights for accents]' \
    '-c[REAL: height of small caps made with -V (default 0.8)]:height:' \
    '-e[widen (extend) characters by factor REAL]:factor:' \
    '-O[use octal for all character codes in the vpl file]' \
    '-p[read/download ENCFILE for the PostScript encoding]:encoding:_files -g "*.enc"' \
    '-s[oblique (slant) characters by REAL]:slant:' \
    '-t[read ENCFILE for the encoding of the vpl file]:encoding:_files -g "*.enc"' \
    '-T[equivalent to -p ENCFILE -t ENCFILE]:encoding:_files -g "*.enc"' \
    '-u[output only characters from encodings, nothing extra]' \
    '-v[make a VPL file for conversion to VF]:vpl:_files -g "*.vpl"' \
    '-V[like -v, but synthesize smallcaps as lowercase]:vpl:_files -g "*.vpl"' \
    '1:afm input:_files -g "*.afm"' \
    '2:tfm output:_files -g "*.tfm"' \
    && ret=0

return ret
