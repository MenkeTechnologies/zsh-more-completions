#compdef circom

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-o+[output directory]:directory:_directories' \
  '--output=[output directory]:directory:_directories' \
  '--r1cs[generate R1CS file]' \
  '--wasm[generate WebAssembly witness calculator]' \
  '--sym[generate symbols file]' \
  '--json[generate JSON constraints file]' \
  '--wat[generate WebAssembly text format]' \
  '--c[generate C witness calculator]' \
  '-p[print the constraint system]' \
  '--prime=[prime field to use]:prime:(bn128 bls12381 goldilocks grumpkin pallas vesta secq256r1)' \
  '--O0[no optimization]' \
  '--O1[constraint simplification]' \
  '--O2[full optimization (default)]' \
  '-l+[library search path]:directory:_directories' \
  '--link=[library search path]:directory:_directories' \
  '--inspect[print detailed constraint information]' \
  '--use_old_simplification_heuristics[use old simplification]' \
  '--simplification_substitution[enable substitution simplification]' \
  '--verbose[verbose output]' \
  '*:circom files:_files -g "*.circom"' && ret=0

return ret
