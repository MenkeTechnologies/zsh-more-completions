#compdef annie
# _annie — Annie media downloader (Go, predecessor of lux); fast multi-thread video downloader for YouTube/Bilibili/Tumblr/Pixiv
# upstream: https://github.com/iawia002/annie

_annie() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-i[info only]' \
        '-d[show debug]' \
        '-o+[output dir]:dir:_files -/' \
        '-O+[output filename]:name:' \
        '-c+[cookie file]:file:_files' \
        '-f+[stream format id]:id:' \
        '-F+[file with URL list]:file:_files' \
        '-j[print parsed JSON]' \
        '-eto+[ext type override]:ext:' \
        '-x+[proxy]:proxy:' \
        '-s+[socks5 proxy]:proxy:' \
        '-r+[refer]:url:_urls' \
        '-n+[max thread]:n:' \
        '-cs+[chunk size]:n:' \
        '-rl+[max retries]:n:' \
        '-p[playlist]' \
        '-aria2[output aria2 input file]' \
        '-itag+[item start tag]:n:' \
        '-eitag+[item end tag]:n:' \
        '-s2+[item end]:n:' \
        '*:URL:_urls'
}

_annie "$@"
