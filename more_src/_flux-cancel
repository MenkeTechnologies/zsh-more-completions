#compdef flux-cancel
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-cancel.html
# cancel one or more Flux jobs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --dry-run)'{-n,--dry-run}'[print count of jobs that would be canceled]' \
  '(-m --message)'{-m,--message=}'[set optional exception note]:note' \
  '(-u --user)'{-u,--user=}'[set target user]:user' \
  '(-S --states)'{-S,--states=}'[set target job states]:states' \
  '(-q --quiet)'{-q,--quiet}'[suppress output if no jobs match]' \
  '*:jobid:_default' && ret=0

return ret
