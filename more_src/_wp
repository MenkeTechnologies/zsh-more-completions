#compdef wp

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--path+[path to WordPress installation]:directory:_files -/' \
  '--url+[WordPress site URL]:URL:_urls' \
  '--ssh+[SSH connection string]:connection:' \
  '--http+[HTTP authentication]:user\:password:' \
  '--user+[set WordPress user]:user:' \
  '--skip-plugins+[skip loading plugins]:plugins:' \
  '--skip-themes+[skip loading themes]:themes:' \
  '--skip-packages[skip loading packages]' \
  '--require+[load PHP file before running command]:file:_files -g "*.php(-.)"' \
  '--exec+[execute PHP code before running command]:code:' \
  '--color[enable color output]' \
  '--no-color[disable color output]' \
  '--debug[show debug information]' \
  '--prompt[prompt the user for values]' \
  '--quiet[suppress informational messages]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'cache:manage the WordPress object cache'
      'cap:manage user capabilities'
      'cli:review CLI information'
      'comment:manage comments'
      'config:manage wp-config.php'
      'core:manage WordPress core'
      'cron:manage WP-Cron events and schedules'
      'db:perform database operations'
      'embed:inspect oEmbed providers'
      'eval:execute arbitrary PHP code'
      'eval-file:load and execute a PHP file'
      'export:export WordPress content to a WXR file'
      'find:find WordPress installations'
      'help:get help on a command'
      'i18n:manage translations and language packs'
      'import:import content from a WXR file'
      'language:manage installed languages'
      'maintenance-mode:manage maintenance mode'
      'media:manage media attachments'
      'menu:manage menus and menu items'
      'network:manage WordPress multisite network'
      'option:manage options'
      'package:manage WP-CLI packages'
      'plugin:manage plugins'
      'post:manage posts'
      'post-type:manage post types'
      'rewrite:manage rewrite rules'
      'role:manage user roles'
      'scaffold:generate starter code'
      'search-replace:search/replace in the database'
      'server:launch built-in PHP web server'
      'shell:open an interactive PHP console'
      'sidebar:manage sidebars'
      'site:manage sites in a multisite network'
      'super-admin:manage super admin users'
      'taxonomy:manage taxonomies'
      'term:manage taxonomy terms'
      'theme:manage themes'
      'transient:manage transients'
      'user:manage users'
      'widget:manage widgets'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (plugin)
        local -a subcmds=(
          'activate:activate a plugin'
          'deactivate:deactivate a plugin'
          'delete:delete a plugin'
          'get:get details about a plugin'
          'install:install a plugin'
          'is-active:check if plugin is active'
          'is-installed:check if plugin is installed'
          'list:list installed plugins'
          'path:get path to a plugin'
          'search:search the plugin directory'
          'status:show status of plugins'
          'toggle:toggle a plugin'
          'uninstall:uninstall a plugin'
          'update:update a plugin'
          'verify-checksums:verify plugin checksums'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (theme)
        local -a subcmds=(
          'activate:activate a theme'
          'delete:delete a theme'
          'disable:disable a theme on multisite'
          'enable:enable a theme on multisite'
          'get:get details about a theme'
          'install:install a theme'
          'is-active:check if theme is active'
          'is-installed:check if theme is installed'
          'list:list installed themes'
          'mod:manage theme modifications'
          'path:get path to a theme'
          'search:search the theme directory'
          'status:show status of themes'
          'update:update a theme'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (core)
        local -a subcmds=(
          'check-update:check for WordPress updates'
          'download:download WordPress core'
          'install:install WordPress'
          'is-installed:check if WordPress is installed'
          'multisite-convert:convert to multisite'
          'multisite-install:install multisite'
          'update:update WordPress'
          'update-db:update the WordPress database'
          'verify-checksums:verify core checksums'
          'version:display WordPress version'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (db)
        local -a subcmds=(
          'check:check the database'
          'clean:remove all tables'
          'cli:open MySQL CLI'
          'columns:display columns for a table'
          'create:create the database'
          'drop:delete the database'
          'export:export the database'
          'import:import a database dump'
          'optimize:optimize the database'
          'prefix:display the table prefix'
          'query:execute a SQL query'
          'repair:repair the database'
          'reset:remove all tables and recreate'
          'search:search the database'
          'size:display database size'
          'tables:list database tables'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
      (user)
        local -a subcmds=(
          'add-cap:add a capability to a user'
          'add-role:add a role to a user'
          'create:create a new user'
          'delete:delete a user'
          'get:get details about a user'
          'import-csv:import users from CSV'
          'list:list users'
          'meta:manage user meta'
          'remove-cap:remove a capability from a user'
          'remove-role:remove a role from a user'
          'reset-password:reset password for user'
          'session:manage user sessions'
          'set-role:set the role of a user'
          'spam:mark a user as spam'
          'term:manage user terms'
          'unspam:remove spam flag from a user'
          'update:update a user'
        )
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
