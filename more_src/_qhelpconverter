#compdef qhelpconverter
# _qhelpconverter — Qt Assistant qhelpconverter (GUI/CLI tool that migrates legacy Qt 3 .adp/.dcf documentation projects into modern Qt 5/6 .qhp + .qhcp format consumable by qhelpgenerator/Qt Assistant)
# upstream: https://github.com/qt/qttools (src/qhelpconverter)
# Argument shape from qttools src/qhelpconverter/main.cpp on tip.

_qhelpconverter() {
    _arguments \
        '--help[show help]' \
        '*:input file:_files -g "*.(adp|dcf)"'
}

_qhelpconverter "$@"
