#compdef mdbook-private
# _mdbook-private — strip private sections from mdbook content (RealAtix/mdbook-private)
# upstream: https://github.com/RealAtix/mdbook-private
# Subcommands from src/main.rs (clap).

_mdbook-private() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-private "$@"
