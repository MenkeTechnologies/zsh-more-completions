#compdef plotEnrichment
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotEnrichment.html
# deepTools: plot signal enrichment in genomic regions as fraction of total reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bamfiles)'{-b,--bamfiles}'[indexed BAM files]:bam:_files -g "*.bam"' \
  '--BED[BED/GTF files defining regions]:file:_files' \
  '(-o --plotFile)'{-o,--plotFile}'[output plot file]:file:_files' \
  '--attributeKey[GTF attribute key for labels]:key:' \
  '(-l --labels)'{-l,--labels}'[custom sample labels]:labels:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '--regionLabels[custom labels for BED/GTF regions]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--outRawCounts[output raw counts file]:file:_files' \
  '--perSample[group plots by sample]' \
  '--variableScales[allow y-axis auto-adjustment]' \
  '--plotHeight[height in cm]:cm:' \
  '--plotWidth[width in cm]:cm:' \
  '--colors[line colors]:colors:' \
  '--numPlotsPerRow[plots per row]:n:' \
  '--alpha[bar transparency (0-1)]:alpha:' \
  '--Offset[read position offset]:offset:' \
  '(-r --region)'{-r,--region}'[genomic region to process]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of regions to exclude]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show version]' \
  '--keepExons[treat each exon as separate region]' \
  '(-e --extendReads)'{-e,--extendReads}'[extend reads to fragment size]:length:' \
  '--ignoreDuplicates[count duplicate reads only once]' \
  '--minMappingQuality[minimum mapping quality threshold]:qual:' \
  '--centerReads[center reads by fragment length]' \
  '--samFlagInclude[include reads matching SAM flag]:flag:' \
  '--samFlagExclude[exclude reads matching SAM flag]:flag:' \
  '--minFragmentLength[minimum fragment length]:length:' \
  '--maxFragmentLength[maximum fragment length]:length:' && ret=0

return ret
