#compdef putty

_arguments -s \
  '--display+[X display]:display:' \
  '-fn+[normal font]:font:' \
  '-fb+[bold font]:font:' \
  '-fw+[wide font]:font:' \
  '-fwb+[wide bold font]:font:' \
  '-geometry+[window geometry]:spec:' \
  '-sl+[scrollback lines]:n:' \
  '-fg+[foreground color]:color:' \
  '-bg+[background color]:color:' \
  '-bfg+[bold foreground]:color:' \
  '-bbg+[bold background]:color:' \
  '-cfg+[cursor foreground]:color:' \
  '-cbg+[cursor background]:color:' \
  '-title+[window title]:title:' \
  '-sb[show scrollbar]' \
  '+sb[hide scrollbar]' \
  '-log+[log file]:file:_files' \
  '-sessionlog+[session log file]:file:_files' \
  '-sshlog+[SSH log file]:file:_files' \
  '-sshrawlog+[raw SSH log]:file:_files' \
  '-logoverwrite[overwrite logs]' \
  '-logappend[append logs]' \
  '-cs+[character set]:cs:' \
  '-nethack[NetHack keypad]' \
  '(- *)-help[show help]' \
  '-pgpfp[PGP fingerprints]' \
  '-load+[load session]:session:' \
  '-ssh[SSH]' '-telnet[Telnet]' '-rlogin[rlogin]' '-supdup[SUPDUP]' '-raw[raw]' '-ssh-connection[bare ssh-connection]' '-serial[serial]' \
  '-proxycmd+[proxy command]:cmd:' \
  '-l+[login user]:user:_users' \
  '*-L+[local forward]:forward:' \
  '*-R+[remote forward]:forward:' \
  '-D+[dynamic forward]:port:' \
  '-P+[port]:port:' \
  '-A[enable agent forwarding]' \
  '-a[disable agent forwarding]' \
  '-X[X11 forwarding]' \
  '-x[no X11]' \
  '-t[PTY]' \
  '-T[no PTY]' \
  '-C[compression]' \
  '-1[SSH v1]' \
  '-2[SSH v2]' \
  '-4[IPv4]' \
  '-6[IPv6]' \
  '-i+[private key]:file:_files' \
  '-noagent[no Pageant]' \
  '-agent[use Pageant]' \
  '-no-trivial-auth[reject trivial auth]' \
  '*-hostkey+[accept host key]:key:' \
  '-sercfg+[serial config]:cfg:' \
  ':host:_hosts'
