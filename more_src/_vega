#compdef vega

# Vega: web application security scanner (Subgraph)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-data[data dir]:dir:_files -/' \
  '-clean[clean data on exit]' \
  '-target[scan target URL]:url:' \
  '-options[options file]:file:_files' \
  '-headless[run without GUI]' \
  '*::vega args:_files' && ret=0
return ret
