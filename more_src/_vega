#compdef vega

# Vega: web vulnerability scanner GUI (Subgraph)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-clean[clear workspace and exit]' \
  '-data[data directory]:dir:_files -/' \
  '-log[log file]:file:_files' \
  '-vmargs[pass JVM args]:args:' \
  '*::Vega args:_files' && ret=0
return ret
