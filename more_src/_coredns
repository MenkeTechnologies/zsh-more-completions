#compdef coredns
# Documentation: https://coredns.io/manual/toc/ (source: github.com/coredns/coredns coremain/run.go)
# Reference accessed: 2026-05-17
# Verified: upstream coremain source registers these flags via Go's flag package.

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)-version[show version]'
  '-conf=[Corefile to load]:file:_files'
  '-dns.port=[default DNS listening port]:port:'
  '-pidfile=[write PID to file]:file:_files'
  '-plugins[list installed plugins]'
  '-quiet[suppress startup output]'
)

_arguments -s -S $arguments
