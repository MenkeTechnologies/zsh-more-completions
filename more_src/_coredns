#compdef coredns

# completions for CoreDNS DNS server

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '-conf=[Corefile to load]:file:_files'
  '-dns.port=[default port]:port'
  '-pidfile=[PID file]:file:_files'
  '-plugins[list installed plugins]'
  '-p=[default port]:port'
  '-quiet[suppress startup logging]'
  '*:file:_files'
)

_arguments -s -S $arguments
