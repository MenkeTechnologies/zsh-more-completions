#compdef cpuctl
# Documentation: https://man.netbsd.org/cpuctl.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '1:command:(list identify offline online noacpi type ucode)'
    '2:CPU number:'
    '-h[Show help]'
    '-v[Verbose output]'
)

_arguments -s -S $arguments
