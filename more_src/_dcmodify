#compdef dcmodify
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmodify.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/dcmodify.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/dcmodify.cc OFCommandLine setup + docs/man/dcmodify.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(+fc --create-file)'{+fc,--create-file}'[create file format if it does not exist]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(+ao --accept-odd-length)'{+ao,--accept-odd-length}'[accept odd length attributes (default)]' \
  '(+ae --assume-even-length)'{+ae,--assume-even-length}'[assume real length is one byte larger]' \
  '(+dc --enable-correction)'{+dc,--enable-correction}'[enable automatic data correction (default)]' \
  '(-dc --disable-correction)'{-dc,--disable-correction}'[disable automatic data correction]' \
  '(+bd --bitstream-deflated)'{+bd,--bitstream-deflated}'[expect deflated bitstream (default)]' \
  '(+bz --bitstream-zlib)'{+bz,--bitstream-zlib}'[expect deflated zlib bitstream]' \
  '--backup[backup files before modifying (default)]' \
  '(-nb --no-backup)'{-nb,--no-backup}'[do not backup files]' \
  '*'{-iff+,--process-if=}'[only perform modifications if condition holds]:condition:' \
  '*'{-i+,--insert=}'[insert or overwrite tag-path with value]:tag-path=value:' \
  '*'{-if+,--insert-from-file=}'[insert tag-path with value read from file]:tag-path=file:' \
  '(-nrc --no-reserv-check)'{-nrc,--no-reserv-check}'[do not check private reservations]' \
  '*'{-m+,--modify=}'[modify tag at position to given value]:tag-path=value:' \
  '*'{-mf+,--modify-from-file=}'[modify tag at position with value from file]:tag-path=file:' \
  '*'{-ma+,--modify-all=}'[modify all matching tags in file to value]:tag-path=value:' \
  '*'{-e+,--erase=}'[erase tag/item at position]:tag-path:' \
  '*'{-ea+,--erase-all=}'[erase all matching tags in file]:tag-path:' \
  '(-ep --erase-private)'{-ep,--erase-private}'[erase all private data from file]' \
  '(-gst --gen-stud-uid)'{-gst,--gen-stud-uid}'[generate new Study Instance UID]' \
  '(-gse --gen-ser-uid)'{-gse,--gen-ser-uid}'[generate new Series Instance UID]' \
  '(-gin --gen-inst-uid)'{-gin,--gen-inst-uid}'[generate new SOP Instance UID]' \
  '(-nmu --no-meta-uid)'{-nmu,--no-meta-uid}'[do not update metaheader UIDs if dataset UIDs change]' \
  '(-ie --ignore-errors)'{-ie,--ignore-errors}'[continue if modify error occurs]' \
  '(-imt --ignore-missing-tags)'{-imt,--ignore-missing-tags}'[treat missing tags as success when modifying or erasing]' \
  '(-iun --ignore-un-values)'{-iun,--ignore-un-values}'[do not write any values to UN VR elements]' \
  '(+F --write-file)'{+F,--write-file}'[write file format (default)]' \
  '(-F --write-dataset)'{-F,--write-dataset}'[write data set without file meta information]' \
  '(+t= --write-xfer-same)'{+t=,--write-xfer-same}'[write with same TS as input (default)]' \
  '(+te --write-xfer-little)'{+te,--write-xfer-little}'[write with explicit VR little endian TS]' \
  '(+tb --write-xfer-big)'{+tb,--write-xfer-big}'[write with explicit VR big endian TS]' \
  '(+ti --write-xfer-implicit)'{+ti,--write-xfer-implicit}'[write with implicit VR little endian TS]' \
  '(+u --enable-new-vr)'{+u,--enable-new-vr}'[enable support for new VRs (default)]' \
  '(-u --disable-new-vr)'{-u,--disable-new-vr}'[disable new VRs, convert to OB]' \
  '(+g= --group-length-recalc)'{+g=,--group-length-recalc}'[recalculate group lengths if present (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[always write with group length elements]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[always write without group length elements]' \
  '(+le --length-explicit)'{+le,--length-explicit}'[write with explicit lengths (default)]' \
  '(-le --length-undefined)'{-le,--length-undefined}'[write with undefined lengths]' \
  '(-p= --padding-retain)'{-p=,--padding-retain}'[do not change padding (default)]' \
  '(-p --padding-off)'{-p,--padding-off}'[no padding]' \
  '(+p --padding-create)'{+p+,--padding-create=}'[align file on multiple of f bytes, items on i bytes]:file-pad:' \
  '*:dcmfile-in:_files'
