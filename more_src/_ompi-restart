#compdef ompi-restart
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/ompi-restart.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ompi-restart: restart a checkpointed MPI job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-mca[MCA parameter]:param value:' \
  '--mca=[MCA parameter]:param value:' \
  '*::ompi-restart args:_files' && ret=0
return ret
