#compdef ompi-restart
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/ompi-restart.1.html
# Reference accessed: 2026-05-20
# Verified: upstream Open MPI ompi-restart(1) manpage.

# ompi-restart: restart a checkpointed MPI job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(-p --preload)'{-p,--preload}'[preload checkpoint files on remote systems]' \
  '--fork[fork off a new restarted process]' \
  '(-s --seq)'{-s+,--seq=}'[sequence number of the checkpoint]:seqnum:' \
  '(-hostfile --hostfile)'{-hostfile,--hostfile}'[specify a hostfile]:file:_files' \
  '(-machinefile --machinefile)'{-machinefile,--machinefile}'[specify a machinefile]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '*'{-mca,--mca}'[MCA parameter]:key:: :value:' \
  '*'{-gmca,--gmca}'[global MCA parameter]:key:: :value:' \
  '*::global snapshot handle:' && ret=0
return ret
