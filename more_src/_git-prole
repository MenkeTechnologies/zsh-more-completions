autoload -U is-at-least

_git-prole() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_git-prole_commands" \
"*::: :->git-prole" \
&& ret=0
    case $state in
    (git-prole)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:git-prole-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
'--default-branch=[A default branch to create a worktree for]:DEFAULT_BRANCH: ' \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::destination -- The directory to place the worktrees into:' \
&& ret=0
;;
(clone)
_arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':repository -- The repository URL to clone:' \
'::directory -- The directory to setup the worktrees in:' \
'*::clone_args -- Extra arguments to forward to `git clone`:' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'(-B --force-branch -d --detach)-b+[Create a new branch with the given name instead of checking out an existing branch]:BRANCH: ' \
'(-B --force-branch -d --detach)-c+[Create a new branch with the given name instead of checking out an existing branch]:BRANCH: ' \
'(-B --force-branch -d --detach)--branch=[Create a new branch with the given name instead of checking out an existing branch]:BRANCH: ' \
'(-B --force-branch -d --detach)--create=[Create a new branch with the given name instead of checking out an existing branch]:BRANCH: ' \
'(-b --branch -d --detach)-B+[Create a new branch with the given name, overwriting any existing branch with the same name]:FORCE_BRANCH: ' \
'(-b --branch -d --detach)-C+[Create a new branch with the given name, overwriting any existing branch with the same name]:FORCE_BRANCH: ' \
'(-b --branch -d --detach)--force-branch=[Create a new branch with the given name, overwriting any existing branch with the same name]:FORCE_BRANCH: ' \
'(-b --branch -d --detach)--force-create=[Create a new branch with the given name, overwriting any existing branch with the same name]:FORCE_BRANCH: ' \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'(-b --branch -B --force-branch)-d[Create the new worktree in detached mode, not checked out on any branch]' \
'(-b --branch -B --force-branch)--detach[Create the new worktree in detached mode, not checked out on any branch]' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::name_or_path -- The new worktree'\''s name or path:' \
'::commitish -- The commit to check out in the new worktree:' \
'*::worktree_add_args -- Extra arguments to forward to `git worktree add`:' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
":: :_git-prole__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:git-prole-config-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::output -- The location to write the configuration file. Can be `-` for stdout. Defaults to `~/.config/git-prole/config.toml`:' \
&& ret=0
;;
        esac
    ;;
esac
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(manpages)
_arguments "${_arguments_options[@]}" : \
'--log=[Log filter directives, of the form \`target\[span{field=value}\]=level\`, where all components except the level are optional]:LOG: ' \
'--config=[The location to read the configuration file from. Defaults to \`~/.config/git-prole/config.toml\`]:CONFIG: ' \
'--dry-run[If set, do not perform any actions, and instead only construct and print a plan]' \
'--dry[If set, do not perform any actions, and instead only construct and print a plan]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':out_dir -- Directory to write man pages to:' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_git-prole_commands] )) ||
_git-prole_commands() {
    local commands; commands=(
'convert:Convert a repository into a worktree checkout' \
'clone:Clone a repository into a worktree checkout' \
'add:Add a new worktree' \
'config:Initialize the configuration file' \
'completions:Generate shell completions' \
'manpages:Generate man pages' \
    )
    _describe -t commands 'git-prole commands' commands "$@"
}
(( $+functions[_git-prole__add_commands] )) ||
_git-prole__add_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole add commands' commands "$@"
}
(( $+functions[_git-prole__clone_commands] )) ||
_git-prole__clone_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole clone commands' commands "$@"
}
(( $+functions[_git-prole__completions_commands] )) ||
_git-prole__completions_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole completions commands' commands "$@"
}
(( $+functions[_git-prole__config_commands] )) ||
_git-prole__config_commands() {
    local commands; commands=(
'init:Initialize a default configuration file' \
    )
    _describe -t commands 'git-prole config commands' commands "$@"
}
(( $+functions[_git-prole__config__init_commands] )) ||
_git-prole__config__init_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole config init commands' commands "$@"
}
(( $+functions[_git-prole__convert_commands] )) ||
_git-prole__convert_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole convert commands' commands "$@"
}
(( $+functions[_git-prole__manpages_commands] )) ||
_git-prole__manpages_commands() {
    local commands; commands=()
    _describe -t commands 'git-prole manpages commands' commands "$@"
}

if [ "$funcstack[1]" = "_git-prole" ]; then
    _git-prole "$@"
else
    compdef _git-prole git-prole
fi
