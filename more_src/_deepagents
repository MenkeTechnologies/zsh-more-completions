#compdef deepagents deepagents-cli
# Documentation: https://github.com/langchain-ai/deepagents
# Reference accessed: 2026-05-22
# Verified: libs/cli/deepagents_cli/main.py deployment CLI.

# Zsh completion for deepagents - LangGraph Deep Agents deploy/dev/init CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'deepagents command' \
      'init[initialize Deep Agents project]' \
      'dev[run development server]' \
      'deploy[deploy agent to LangGraph]' && ret=0
    ;;
esac

return ret
