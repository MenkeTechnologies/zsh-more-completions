#compdef cga
# Documentation: https://www.npmjs.com/package/create-graphql-app
# Reference accessed: 2026-05-24
# Verified: npm view create-graphql-app bin (cga); npx create-graphql-app --help output.

# Zsh completion for cga - production GraphQL server bootstrap CLI

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-V --version)'{-V,--version}'[output version number]'   '--ignoreContext[do not add service to server GraphQL context]'   '(-h --help)'{-h,--help}'[output usage information]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command'       'init:Create new project'       'i:Create new project (alias)'       'resolver:Generate resolver from type file'       'r:Generate resolver from type file (alias)'       'service:Add new service to services directory'       's:Add new service (alias)'       'deploy:Deploy project to production'       'd:Deploy project (alias)' && ret=0
    ;;
  args)
    case $line[1] in
      init|i)
        _arguments -C ':project name:' && ret=0
        ;;
      resolver|r)
        _arguments -C ':path to type file:_files' ':path to resolver file:_files' && ret=0
        ;;
      service|s)
        _arguments -C '[service path]:path:_directories' && ret=0
        ;;
      deploy|d)
        _arguments -C '[project path]:path:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
