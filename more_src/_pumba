#compdef pumba

# Zsh completion for pumba - container chaos testing tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'kill:kill specified containers'
  'netem:emulate network problems'
  'pause:pause running containers'
  'stop:stop running containers'
  'rm:remove containers'
  'stress:stress test containers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--host=[daemon socket to connect to]:host' \
  '--tls[use TLS]' \
  '--tls-verify[use TLS and verify the remote]' \
  '--log-level=[set the logging level]:level:(debug info warning error fatal panic)' \
  '--json[produce log in JSON format]' \
  '--interval=[recurrence interval for chaos command]:interval' \
  '--random[randomly select target from matched containers]' \
  '--label=[filter containers by label]:label' \
  '--dry-run[skip all container commands, just log]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'pumba command' commands && ret=0
    ;;
  args)
    case $words[1] in
      kill)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--signal=[signal to send to container]:signal:(SIGKILL SIGTERM SIGSTOP SIGINT SIGHUP)' \
          '--limit=[limit number of containers to kill]:limit' \
          '*:container:' && ret=0
        ;;
      netem)
        local -a netem_commands=(
          'delay:delay egress traffic'
          'loss:add packet losses'
          'loss-state:add packet losses using state model'
          'loss-gemodel:add packet losses using Gilbert-Elliott model'
          'rate:limit egress bandwidth'
          'duplicate:duplicate egress packets'
          'corrupt:corrupt egress packets'
        )
        _describe -t netem-commands 'netem command' netem_commands && ret=0
        ;;
      pause)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--duration=[pause duration]:duration' \
          '*:container:' && ret=0
        ;;
      stop)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--time=[seconds to wait before killing]:seconds' \
          '*:container:' && ret=0
        ;;
      rm)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--force[force remove running containers]' \
          '--links[remove associated links]' \
          '--volumes[remove associated volumes]' \
          '*:container:' && ret=0
        ;;
      stress)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--duration=[stress duration]:duration' \
          '--stress-image=[stress-ng Docker image]:image' \
          '--stressors=[stress-ng stressors]:stressors' \
          '*:container:' && ret=0
        ;;
    esac
    ;;
esac

return ret
