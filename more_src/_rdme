#compdef rdme
# Documentation: https://man.archlinux.org/search?q=rdme
# Reference accessed: 2026-05-16

# Zsh completion for rdme (readmeio/rdme, oclif). Command tree from src/commands
# on the next branch; topics use a space separator per package.json oclif config.

local curcontext="$curcontext" state line ret=1
local -a top openapi1 docs1 changelog1 pages1 ref1

top=(
  'autocomplete:oclif shell autocomplete'
  'changelog:changelog commands'
  'changelogs:deprecated use changelog upload'
  'custompages:custom page commands'
  'docs:docs folder commands'
  'help:oclif help'
  'login:store ReadMe API credentials'
  'logout:clear stored credentials'
  'openapi:OpenAPI definition commands'
  'plugins:oclif plugin commands'
  'reference:API reference upload'
  'whoami:print current ReadMe user or project'
  'rage:hidden debug environment dump'
)

openapi1=(
  'convert:convert API definition format'
  'inspect:analyze OpenAPI document'
  'reduce:simplify OpenAPI spec'
  'resolve:resolve and bundle external OpenAPI references'
  'upload:push API definition to ReadMe'
  'validate:validate OpenAPI document'
)

docs1=(
  'migrate:migrate legacy docs layout'
  'upload:sync Markdown docs to ReadMe'
)

changelog1=('upload:upload changelog Markdown to ReadMe')

pages1=('upload:upload custom pages to ReadMe')

ref1=('upload:sync API reference to ReadMe')

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[verbose oclif logging]' \
  '1: :->top' \
  '*::arg:->args' && ret=0

case $state in
  (top) _describe -t commands 'rdme command' top && ret=0 ;;
  (args)
    case $line[1] in
      (openapi)
        if (( CURRENT == 3 )); then
          _describe -t commands 'rdme openapi subcommand' openapi1 && ret=0
        else
          _default && ret=0
        fi ;;
      (docs)
        if (( CURRENT == 3 )); then
          _describe -t commands 'rdme docs subcommand' docs1 && ret=0
        else
          _default && ret=0
        fi ;;
      (changelog)
        if (( CURRENT == 3 )); then
          _describe -t commands 'rdme changelog subcommand' changelog1 && ret=0
        else
          _default && ret=0
        fi ;;
      (custompages)
        if (( CURRENT == 3 )); then
          _describe -t commands 'rdme custompages subcommand' pages1 && ret=0
        else
          _default && ret=0
        fi ;;
      (reference)
        if (( CURRENT == 3 )); then
          _describe -t commands 'rdme reference subcommand' ref1 && ret=0
        else
          _default && ret=0
        fi ;;
      (*) _default && ret=0 ;;
    esac ;;
esac

return ret
