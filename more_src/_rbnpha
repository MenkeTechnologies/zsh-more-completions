#compdef rbnpha
# Physically compresses (rebins) a PHA dataset in channel-space

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[FITS PHA file to be compressed]:input file:_files' \
  'outfile=[output FITS file with compressed PHA dataset]:output file:_files' \
  'finchan=[number of channels in the compressed dataset]:channels:' \
  'cmpmode=[compression mode]:mode:(LINEAR FAINT2BRIGHT BRIGHT2LINEAR)' \
  'binfile=[ASCII file specifying binning information]:bin file:_files' \
  'fchan=[output first channel number]:channel:' \
  'chatter=[verbosity level]:level:' \
  'clobber=[overwrite pre-existing output file]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
