#compdef nativefier
# Documentation: https://github.com/nativefier/nativefier/blob/master/API.md
# Build native desktop apps from any web page

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --arch)'{-a,--arch}'=[CPU architecture to build for]:arch:(ia32 x64 armv7l arm64 universal)' \
  '(-c --conceal)'{-c,--conceal}'[package source into an asar archive]' \
  '(-e --electron-version)'{-e,--electron-version}'=[electron version to use]:version' \
  '--global-shortcuts=[define global keyboard shortcuts via JSON file]:file:_files' \
  '(-i --icon)'{-i,--icon}'=[icon file for the app]:icon:_files' \
  '(-n --name)'{-n,--name}'=[name of the app]:name' \
  '--no-overwrite[do not overwrite output directory if it exists]' \
  '(-p --platform)'{-p,--platform}'=[OS platform to build for]:platform:(mac mas linux windows)' \
  '--portable[store user data in the app folder]' \
  '--upgrade=[upgrade an app built by an older Nativefier]:app:_files' \
  '--widevine[use a Widevine-enabled Electron for DRM playback]' \
  '--always-on-top[enable always on top window]' \
  '--background-color=[set the app background color]:color' \
  '--bookmarks-menu=[create a bookmarks menu via JSON file]:file:_files' \
  '--browserwindow-options=[override Electron BrowserWindow options (JSON)]:json' \
  '--disable-context-menu[disable the right-click context menu]' \
  '--disable-dev-tools[disable developer tools]' \
  '--full-screen[always start the app full screen]' \
  '--height=[window default height in pixels]:height' \
  '--hide-window-frame[disable window frame and controls]' \
  '(-m --show-menu-bar)'{-m,--show-menu-bar}'[set menu bar visible]' \
  '--max-height=[window maximum height in pixels]:height' \
  '--max-width=[window maximum width in pixels]:width' \
  '--maximize[always start the app maximized]' \
  '--min-height=[window minimum height in pixels]:height' \
  '--min-width=[window minimum width in pixels]:width' \
  '--process-envs=[JSON of env vars set before windows open]:json' \
  '--single-instance[allow only a single instance of the app]' \
  '--tray=[allow app to stay in system tray]:tray:(true false start-in-tray)' \
  '--width=[window default width in pixels]:width' \
  '-x=[window x location in pixels from left]:x' \
  '-y=[window y location in pixels from top]:y' \
  '--zoom=[default zoom factor for the app]:zoom' \
  '--file-download-options=[JSON of file download options]:json' \
  '*--inject=[path to a CSS/JS file to be injected]:file:_files' \
  '--lang=[language or locale to render the site as]:lang' \
  '(-u --user-agent)'{-u,--user-agent}'=[set the app user agent string]:ua' \
  '(--user-agent-honest --honest)'{--user-agent-honest,--honest}'[prevent changing the user agent string]' \
  '--clear-cache[prevent preserving cache between launches]' \
  '--disk-cache-size=[max disk space for the disk cache (bytes)]:bytes' \
  '--block-external-urls[forbid navigation to non-internal URLs]' \
  '--internal-urls=[regex of URLs to consider internal]:regex' \
  '--strict-internal-urls[disable domain-based internal URL matching]' \
  '--proxy-rules=[proxy rules]:rules' \
  '--basic-auth-password=[basic http auth password]:password' \
  '--basic-auth-username=[basic http auth username]:username' \
  '--disable-gpu[disable hardware acceleration]' \
  '--enable-es3-apis[force activation of WebGL 2.0]' \
  '--ignore-gpu-blacklist[force WebGL apps on unsupported GPUs]' \
  '--ignore-certificate[ignore certificate-related errors]' \
  '--insecure[enable loading of insecure content]' \
  '--app-copyright=[set a human-readable copyright line (macOS/win)]:copyright' \
  '--app-version=[set the version of the app (macOS/win)]:version' \
  '--bounce[make the dock icon bounce on counter increase (macOS)]' \
  '--build-version=[set the build version (macOS/win)]:version' \
  '--counter[set a dock count badge from window title (macOS)]' \
  '--darwin-dark-mode-support[enable Dark Mode support (macOS)]' \
  '(-f --fast-quit)'{-f,--fast-quit}'[quit app on window close (macOS)]' \
  '--title-bar-style=[set title bar style (macOS)]:style:(hidden hiddenInset)' \
  '--win32metadata=[JSON of executable metadata (windows)]:json' \
  '--crash-reporter=[remote server URL for crash reports]:url' \
  '--verbose[enable verbose/debug logs]' \
  '--quiet[suppress all logging]' \
  '1:target URL:_urls' \
  '2:output directory:_files -/' && ret=0

return ret
