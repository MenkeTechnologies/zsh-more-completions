#compdef haiti
# Documentation: https://github.com/noraj/haiti
# Hash type identifier

_arguments -s -S \
  '--hashcat[show Hashcat mode]' \
  '--john[show John the Ripper format]' \
  '-e[show extended hash types]' \
  '--extended[show extended hash types]' \
  '--no-color[disable colored output]' \
  '--ascii-art[display ASCII art]' \
  '--short[short output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:hash:' \
  && return 0
