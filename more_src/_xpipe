#compdef xpipe
# Documentation: https://docs.xpipe.io/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Only `open` and `daemon`
# subcommands are documented; prior file's launch/beacon/list/reload
# subcommands not present in upstream docs.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'open:launch the GUI and start the daemon if inactive'
  'daemon:control the XPipe daemon'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'xpipe command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (daemon)
        _arguments \
          '1:op:(start stop status mode)' && ret=0 ;;
    esac ;;
esac

return ret
