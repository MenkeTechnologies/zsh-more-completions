#compdef xpipe
# Documentation: https://docs.xpipe.io/cli/xpipe
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'open:open a connection by name'
  'launch:launch the XPipe desktop application'
  'daemon:control the XPipe daemon'
  'beacon:interact with the XPipe beacon API'
  'list:list available connections'
  'reload:reload data sources'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'xpipe command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (daemon)
        _arguments \
          '1:op:(start stop restart status)' && ret=0 ;;
      (beacon)
        _arguments \
          '1:op:(query call subscribe)' && ret=0 ;;
    esac ;;
esac

return ret
