#compdef pcp-atop
# Documentation: https://man.archlinux.org/search?q=pcp-atop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[archive]:file:_files' \
  '-r+[raw file]:file:_files' \
  '-b+[begin time]:time:' \
  '-e+[end time]:time:' \
  '-w+[write to file]:file:_files' \
  '-P+[parsable output]:flag:' \
  '-N[hide tasks]' \
  '-y[show threads]' \
  '-V[show version]' \
  '-h+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-Z+[timezone]:tz:' \
  '-z[use archive timezone]' \
  '*:interval:' && ret=0

return ret
