#compdef pcp-atop
# Documentation: https://man7.org/linux/man-pages/man1/pcp-atop.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[show all/active processes (toggle)]' \
  '-A[sort by most busy system resource]' \
  '-B[start in bar graph mode]' \
  '-c[show command line of processes]' \
  '-C[sort by CPU consumption]' \
  '-d[show disk-related process info]' \
  '-D[sort by disk accesses]' \
  '-f[show fixed header lines (toggle)]' \
  '-F[suppress sorting of system resources (toggle)]' \
  '-g[show generic output]' \
  '-G[suppress exited processes (toggle)]' \
  '-H[hide CPU/disk categories in bar graphs]' \
  '-m[show memory-related process info]' \
  '-M[sort by resident memory consumption]' \
  '-n[show network-related process info]' \
  '-N[sort by network bandwidth]' \
  '-o[show user-defined process line]' \
  '-p[show activity per program]' \
  '-P+[parsable output for labels]:labels:' \
  '-s[show scheduling characteristics]' \
  '-u[show activity per user]' \
  '-v[show various process characteristics]' \
  '-x[suppress colors (toggle)]' \
  '-y[show individual threads (toggle)]' \
  '-Y[sort threads per process (toggle)]' \
  '-1[show counters as average per second]' \
  '-r+[read PCP archive folio]:folio:_files' \
  '-w+[write to PCP archive folio]:folio:_files' \
  '-b+[begin time YYYYMMDDhhmm[ss]]:time:' \
  '-e+[end time YYYYMMDDhhmm[ss]]:time:' \
  '-S[finish before midnight when writing]' \
  '-L+[alternate line length]:length:' \
  '-h+[host specification]:host:_hosts' \
  '--host=[host specification]:host:_hosts' \
  '-O+[time origin]:time:' \
  '--origin=[time origin]:time:' \
  '-V[show version information]' \
  '-Z[exchange spaces with underscores in parsable output]' \
  '-l[limit system resource lines]' \
  '*:interval:' && ret=0

return ret
