#compdef i3status-rs
# Documentation: https://man.archlinux.org/search?q=i3status-rs
# Reference accessed: 2026-05-16

# Zsh completion for i3status-rs (i3status-rust) - status bar generator

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--threads[number of threads to use]:thread count' \
  '1:config file:_files'
