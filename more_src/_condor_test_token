#compdef condor_test_token
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_test_token.html
# generate a SciToken for testing purposes by impersonating an issuer

local ret=1

_arguments -s -S \
  '--help[display usage information]' \
  '--issuer[specify the issuer to impersonate]:issuer-url' \
  '--scope[specify the scope claim for the token]:scopes' \
  '--subject[specify the sub claim for the token]:subject' \
  '--lifetime[specify the lifetime of the token in seconds]:lifetime' \
  '--audience[specify the aud claim for the token]:audience' \
  '--cache[specify the SciTokens cache location]:cache-location:_files -/' && ret=0

return ret
