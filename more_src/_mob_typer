#compdef mob_typer
# mob_typer — MOB-suite plasmid typing and mobility prediction

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '(-i --infile)'{-i,--infile}'[input FASTA file]:input file:_files' \
  '(-o --out_file)'{-o,--out_file}'[output results file]:output file:_files' \
  '--debug[enable debug logging]' \
  '(-d --database)'{-d,--database}'[path to MOB-suite database]:database dir:_files -/' \
  '--multi[report multiple replicon and relaxase hits]' \
  && return 0
