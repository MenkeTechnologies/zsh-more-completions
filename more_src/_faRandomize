#compdef faRandomize
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# create random fasta records with same base frequency as input

local ret=1

_arguments -s -S \
  '-seed=[seed (integer) for random number generator]:n' \
  '1:in fa:_files -g "*.(fa|fasta)"' \
  '2:randomized fa:_files' && ret=0

return ret
