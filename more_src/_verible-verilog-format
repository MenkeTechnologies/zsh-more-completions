#compdef verible-verilog-format
# Documentation: https://man.archlinux.org/search?q=verible-verilog-format
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--helpfull[show all options]' \
  '--inplace[edit file in place]' \
  '--stdin_name=[name of stdin file]:name:' \
  '--column_limit=[column limit]:cols:' \
  '--indentation_spaces=[indentation spaces]:n:' \
  '--wrap_spaces=[wrap spaces]:n:' \
  '--line_break_penalty=[line break penalty]:n:' \
  '--over_column_limit_penalty=[over column limit penalty]:n:' \
  '--lines=[line ranges to format]:ranges:' \
  '--show_largest_token_partitions=[show largest token partitions]:n:' \
  '--show_token_partition_tree[show token partition tree]' \
  '--show_inter_token_info[show inter-token info]' \
  '--show_equally_optimal_wrappings[show equally optimal wrappings]' \
  '--max_search_states=[max search states]:n:' \
  '--verify_convergence[verify convergence]' \
  '--verbose[verbose]' \
  '--verify_consistency[verify consistency]' \
  '--diff[show diff]' \
  '--check_only[do not format, just check]' \
  '--port_declarations_alignment=[port declaration alignment]:flag:(align infer preserve flush-left)' \
  '--parameter_declarations_alignment=[parameter declaration alignment]:flag:(align infer preserve flush-left)' \
  '*:file:_files -g "*.{v,sv,vh,svh}"' && ret=0

return ret
