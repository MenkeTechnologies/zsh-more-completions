#compdef orca_vpot
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# ORCA utility to compute the electrostatic potential at user-defined points

local ret=1

_arguments -s -S \
  '1:gbw file:_files -g "*.gbw"' \
  '2:density matrix file:_files -g "*.scfp"' \
  '3:coordinates file:_files' \
  '4:output file:_files' && ret=0

return ret
