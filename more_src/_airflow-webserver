#compdef airflow-webserver
# _airflow-webserver — Apache Airflow webserver (Flask-based UI + REST API; -p port, -w workers, -k worker class, -t worker timeout seconds, -H bind host, -A access log, -E error log, -l log file, -D daemonize, --pid pidfile, --debug debug-mode reloader, --ssl-cert/--ssl-key TLS material)
# upstream: https://github.com/apache/airflow
# Flags from Apache Airflow airflow/cli/commands/webserver_command.py on tip.

_airflow-webserver() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-p+[port]:port:' \
        '--port+[port]:port:' \
        '-w+[workers]:n:' \
        '--workers+[workers]:n:' \
        '-k+[worker class]:class:(sync eventlet gevent gthread tornado)' \
        '--workerclass+[worker class]:class:(sync eventlet gevent gthread tornado)' \
        '-t+[worker timeout seconds]:seconds:' \
        '--worker-timeout+[worker timeout seconds]:seconds:' \
        '-H+[bind host]:host:_hosts' \
        '--hostname+[bind host]:host:_hosts' \
        '-A+[access log]:file:_files' \
        '--access-logfile+[access log]:file:_files' \
        '-E+[error log]:file:_files' \
        '--error-logfile+[error log]:file:_files' \
        '-l+[log file]:file:_files' \
        '--log-file+[log file]:file:_files' \
        '-D[daemonize]' \
        '--daemon[daemonize]' \
        '-p+[pidfile]:file:_files' \
        '--pid+[pidfile]:file:_files' \
        '--debug[debug mode]' \
        '--ssl-cert+[TLS cert]:file:_files' \
        '--ssl-key+[TLS key]:file:_files' \
        '--access-logformat+[access log format]:format:'
}

_airflow-webserver "$@"
