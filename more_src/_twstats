#compdef twstats
# Documentation: https://github.com/DReichLab/EIG/blob/master/POPGEN/README
# EIGENSOFT twstats: Tracy-Widom statistics for eigenvalue significance

local ret=1

_arguments -s -S \
  '-t[Tracy-Widom table]:file:_files' \
  '-i[input eigenvalues file]:file:_files' \
  '-o[Tracy-Widom statistics output]:file:_files' \
  '-n[effective number of markers]:num' \
  '-m[minimum number of input eigenvalues]:num' && ret=0

return ret
