#compdef fkeytab
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fkeytab.txt
# Copy a FITS keyword value to a FITS table element

local ret=1

_arguments -s \
  "fitsfile=[FITS file containing the keyword]:file:_files" \
  "keyword=[keyword name to read]:" \
  "tblfile=[target FITS table file]:file:_files" \
  "column=[column name]:" \
  "row=[row number]:" \
  "element=[vector element number]:" \
  "exist=[require keyword to exist]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
