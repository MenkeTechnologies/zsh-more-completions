#compdef ipset
# Documentation: https://manpages.debian.org/ipset.8
# Source: netfilter — Linux kernel IP-set table manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(-! -exist)'{-\!,-exist}'[ignore errors on duplicate create/add/del]' \
    '(-o -output)'{-o+,-output}'[output format]:fmt:(plain save xml json)' \
    '(-q -quiet)'{-q,-quiet}'[suppress stdout/stderr]' \
    '(-r -resolve)'{-r,-resolve}'[enforce name lookup when listing]' \
    '(-s -sorted)'{-s,-sorted}'[sorted output when listing/saving]' \
    '(-n -name)'{-n,-name}'[list only set names]' \
    '(-t -terse)'{-t,-terse}'[list set names and headers without members]' \
    '(-f -file)'{-f+,-file}'[input/output file (instead of stdin/stdout)]:file:_files' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'create:create a set with a given type'
            'add:add an entry to a set'
            'del:delete an entry from a set'
            'test:test whether an entry is in a set'
            'destroy:destroy a set or all sets'
            'list:list header + entries of a set or all sets'
            'save:dump set(s) to stdout in restore-readable form'
            'restore:restore a saved session from stdin'
            'flush:flush all entries from a set or all sets'
            'rename:rename a set'
            'swap:swap contents of two sets (exchange names)'
            'help:print help (with TYPENAME for set-type-specific help)'
            'version:print program version'
            '-:interactive mode (read commands from stdin)'
        )
        _describe -t subcmds 'ipset command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            create)
                _arguments \
                    '1:setname:' \
                    '2:settype:(bitmap:ip bitmap:ip,mac bitmap:port hash:ip hash:mac hash:ip,mac hash:net hash:net,net hash:ip,port hash:net,port hash:ip,port,ip hash:ip,port,net hash:net,port,net hash:net,iface list:set)' \
                    '*:option:'
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac

return ret
