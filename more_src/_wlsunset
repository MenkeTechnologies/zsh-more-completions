#compdef wlsunset
# Documentation: https://man.archlinux.org/man/extra/wlsunset/wlsunset.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wlsunset - day/night gamma adjustments for Wayland

_arguments \
  '(- *)-h[show help]' \
  '-T[set high (day) temperature, default 6500]:kelvin' \
  '-t[set low (night) temperature, default 4000]:kelvin' \
  '-l[set latitude]:latitude' \
  '-L[set longitude]:longitude' \
  '-S[set manual sunrise time]:time (HH\:MM)' \
  '-s[set manual sunset time]:time (HH\:MM)' \
  '-d[set animation duration in seconds]:seconds' \
  '-g[set gamma, default 1.0]:gamma'
