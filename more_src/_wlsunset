#compdef wlsunset

# Zsh completion for wlsunset - day/night gamma adjustments for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l)'-l'[set latitude]:latitude' \
  '(-L)'-L'[set longitude]:longitude' \
  '(-t)'-t'[set low temperature (night)]:kelvin' \
  '(-T)'-T'[set high temperature (day)]:kelvin' \
  '(-S)'-S'[set manual sunrise time]:time (HH\:MM)' \
  '(-s)'-s'[set manual sunset time]:time (HH\:MM)' \
  '(-d)'-d'[set transition duration]:minutes' \
  '(-g)'-g'[set gamma]:gamma' \
  '(-G)'-G'[set output]:output'
