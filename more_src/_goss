#compdef goss

# Zsh completion for goss - server validation tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-g --gossfile)'{-g,--gossfile}'[goss file to use]:file:_files' \
  '--vars=[vars file to use]:file:_files' \
  '--vars-inline=[inline variables]:vars:' \
  '--package=[package type to use]:type:(rpm deb apk pacman)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'validate:validate system'
      'serve:serve a health endpoint'
      'render:render gossfile after importing all referenced gossfiles'
      'autoadd:auto-add resources for a subject'
      'add:add a resource to the test suite'
    )
    _describe -t commands 'goss commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      validate)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(rspecish documentation json tap nagios nagios_verbose silent)' \
          '--format-options=[extra options for format]:options:' \
          '--max-concurrent=[max number of tests to run concurrently]:num:' \
          '--no-color[disable color]' \
          '-r[retry on failure]' \
          '--retry-timeout=[timeout for retries]:duration:' \
          '--sleep=[time to sleep between retries]:duration:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(rspecish documentation json tap nagios nagios_verbose silent)' \
          '--format-options=[extra options for format]:options:' \
          '--max-concurrent=[max number of tests to run concurrently]:num:' \
          '(-l --listen-addr)'{-l,--listen-addr}'[listen address]:addr:' \
          '--endpoint=[endpoint to expose]:path:' \
          '--cache=[cache duration]:duration:' && ret=0
        ;;
      add|autoadd)
        _arguments -s -S \
          '1:resource type:(addr command dns file group http interface kernel-param mount package port process service user)' \
          '*:resource name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
