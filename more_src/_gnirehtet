#compdef gnirehtet
# Documentation: https://man.archlinux.org/search?q=gnirehtet
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install Android client APK'
  'uninstall:uninstall Android client'
  'reinstall:reinstall Android client'
  'rt:run reverse tethering once'
  'run:run install + start + relay'
  'autorun:run automatically when device connected'
  'start:start tunneling on device'
  'autostart:start automatically when device connected'
  'stop:stop tunneling on device'
  'reset:reset tunnel'
  'relay:start relay server'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnirehtet command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|uninstall|reinstall|start|autostart|stop|reset|run|autorun|rt)
        _arguments \
          '*: :->dev_dns_route'
        case $state in
          (dev_dns_route) _values 'arg' 'serial' 'dns:8.8.8.8' 'route:0.0.0.0/0' && ret=0 ;;
        esac ;;
      (relay)
        _arguments \
          '1:port:' && ret=0 ;;
    esac ;;
esac

return ret
