# Zsh completion for hledger-iadd (interactive transaction adder).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --file)'{-f+,--file=}'[path to the journal file]:file:_files -g "*.{journal,hledger}"' \
  '--date-format=[format used to parse dates]:format:' \
  '--completion-engine=[algorithm for account name completion]:engine:(fuzzy substrings)' \
  '--dump-default-config[print an example configuration file to stdout and exit]' \
  '--version[print version number and exit]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
