#compdef cromwell
# Documentation: https://cromwell.readthedocs.io/en/stable/CommandLine/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cromwell: bioinformatics workflow management system (WDL/CWL).
# Subcommands: server (no args), run (workflow_source plus per-run flags).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run Cromwell as a web server (REST, port 8000)'
  'run:execute a single workflow and print outputs as JSON'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[print Cromwell version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cromwell command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-i --inputs)'{-i+,--inputs=}'[workflow inputs file]:file:_files -g "*.json"' \
          '(-o --options)'{-o+,--options=}'[workflow options file]:file:_files -g "*.json"' \
          '(-t --type)'{-t+,--type=}'[workflow type]:type:(WDL CWL)' \
          '(-v --type-version)'{-v+,--type-version=}'[workflow type version]:version:' \
          '(-l --labels)'{-l+,--labels=}'[workflow labels file]:file:_files -g "*.json"' \
          '(-p --imports)'{-p+,--imports=}'[imports zip file]:file:_files -g "*.zip"' \
          '(-m --metadata-output)'{-m+,--metadata-output=}'[metadata output JSON path]:file:_files -g "*.json"' \
          '--workflow-root=[workflow root directory]:dir:_files -/' \
          '--help[print help]' \
          '--version[print Cromwell version]' \
          '*::workflow_source:_files -g "*.(wdl|cwl)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
