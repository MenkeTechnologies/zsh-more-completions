#compdef cromwell

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run Cromwell as a web server (REST)'
  'run:execute a single workflow and exit'
  'submit:submit a workflow to a running server'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cromwell command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-i --inputs)'{-i+,--inputs=}'[workflow inputs JSON]:file:_files -g "*.json"' \
          '(-o --options)'{-o+,--options=}'[workflow options JSON]:file:_files -g "*.json"' \
          '(-l --labels)'{-l+,--labels=}'[workflow labels JSON]:file:_files -g "*.json"' \
          '(-p --imports)'{-p+,--imports=}'[imports zip file]:file:_files -g "*.zip"' \
          '(-m --metadata-output)'{-m+,--metadata-output=}'[metadata output JSON]:file:_files -g "*.json"' \
          '--workflow-root=[workflow execution root]:dir:_files -/' \
          '*::workflow_source:_files -g "*.{wdl,cwl}"' && ret=0 ;;
      (submit)
        _arguments \
          '(-h --host)'{-h+,--host=}'[Cromwell host URL]:url:' \
          '(-i --inputs)'{-i+,--inputs=}'[inputs JSON]:file:_files -g "*.json"' \
          '(-o --options)'{-o+,--options=}'[options JSON]:file:_files -g "*.json"' \
          '(-t --type)'{-t+,--type=}'[workflow type]:type:(WDL CWL)' \
          '(-v --type-version)'{-v+,--type-version=}'[workflow type version]:version:' \
          '(-l --labels)'{-l+,--labels=}'[labels JSON]:file:_files -g "*.json"' \
          '(-p --imports)'{-p+,--imports=}'[imports zip]:file:_files -g "*.zip"' \
          '*--header=[HTTP header]:header:' \
          '*::workflow_source:_files -g "*.{wdl,cwl}"' && ret=0 ;;
    esac ;;
esac

return ret
