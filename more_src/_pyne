#compdef pyne pyne-tally pyne-cli pyne-nucname pyne-data
# _pyne — PyNE collaboration Python for Nuclear Engineering toolkit nuclide cross-section reactor analysis tools (pyne team, Python); argparse
# upstream: https://github.com/pyne/pyne

_pyne() {
    local -a sub=(
        'tally:tally subcommands'
        'nucname:nuclide name conversion'
        'data:data subcommands'
        'mesh:mesh subcommands'
        'origen:ORIGEN subcommands'
        'transport:transport subcommands'
        'spatial:spatial subcommands'
        'dagmc:DAGMC subcommands'
        'mcnp:MCNP subcommands'
        'serpent:Serpent subcommands'
        'cccc:CCCC subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '--ensdf-dir=+[ensdf dir]:dir:_files -/' \
        '--nuc-data=+[data file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pyne subcommand' sub ;;
        args)
            case $words[1] in
                nucname) _arguments '1:nucname cmd:(name id zzaaam zzzaaa zzllaaam mcnp serpent groundstate fluka cinder alara nist)' '*:nuclide:' ;;
                data) _arguments '1:data cmd:(simple_xs reaction_xs photonatomic decay atomic eaf nndc_eaf endf wimsd)' ;;
                mesh) _arguments '1:mesh cmd:(create export load convert volume)' ;;
                tally) _arguments '1:tally cmd:(create export sum write)' ;;
                mcnp) _arguments '1:mcnp cmd:(meshtal mctal volume_calc dag-postprocessor)' ;;
                serpent) _arguments '1:serpent cmd:(input output detector)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_pyne "$@"
