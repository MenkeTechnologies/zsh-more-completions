#compdef nil
# Documentation: https://man.archlinux.org/search?q=nil
# Reference accessed: 2026-05-16

# nix-community/nil — Nix language server (`nil --help`): stdio LSP with optional workspace roots.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--stdio[force stdio transport]' \
  '*:workspace roots:_files -/' && ret=0

return ret
