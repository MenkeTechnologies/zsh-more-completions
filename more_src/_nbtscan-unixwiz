#compdef nbtscan-unixwiz
# Documentation: https://man.archlinux.org/search?q=nbtscan-unixwiz
# Reference accessed: 2026-05-16

# nbtscan-unixwiz: NetBIOS name scanner
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose (full NBT names)]' \
  '-d[dump packets]' \
  '-e[format suitable for shell scripts]' \
  '-l[format suitable for lprng]' \
  '-t[response timeout (ms)]:ms:' \
  '-b[bandwidth limit (pps)]:pps:' \
  '-r[use local port 137 (root)]' \
  '-q[suppress banners and errors]' \
  '-s[separator character (default \t)]:char:' \
  '-m[count of retries]:n:' \
  '-f[targets file]:file:_files' \
  '*:targets:' && ret=0
return ret
