#compdef nbtscan-unixwiz

# nbtscan (Unixwiz variant): scan IP ranges for NetBIOS information
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose output]' \
  '-d[dump packets]' \
  '-e[format result as Excel-friendly columns]' \
  '-l[format compact line listing]' \
  '-n[lookup by IP, no name resolution]' \
  '-p[UDP port to send to]:port:' \
  '-q[suppress banners]' \
  '-r[use local port 137]' \
  '-s[output field separator]:sep:' \
  '-t[response timeout]:sec:' \
  '-w[wait time between sends]:ms:' \
  '-T[set total scan timeout]:sec:' \
  '-f[scan from file of IPs]:file:_files' \
  '*:target (IP, CIDR, hostname):' && ret=0
return ret
