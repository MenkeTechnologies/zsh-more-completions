#compdef stackctl
# _stackctl — Pat Brisbin stackctl CLI for managing AWS CloudFormation stacks lifecycle from declarative YAML specs deploy lint validate output diff capability list provisioner Haskell-based DevOps tooling (freckle team, Haskell); optparse-applicative
# upstream: https://github.com/freckle/stackctl

_stackctl() {
    local -a sub=(
        'deploy:deploy stack updates'
        'lint:lint stack spec'
        'validate:validate template'
        'output:show stack outputs'
        'logs:show stack logs'
        'diff:show diff between deployed and proposed'
        'list:list deployable specs'
        'cat:cat resolved template'
        'list-templates:list templates'
        'list-stacks:list stacks'
        'changeset:changeset operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--directory=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '--filter=+[expr]:str:' \
        '-f+[expr]:str:' \
        '--region=+[r]:str:' \
        '--profile=+[p]:str:' \
        '--no-color[no color]' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--log-format=+[fmt]:f:(plain json)' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stackctl subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments \
                    '--no-prompt[no prompt]' \
                    '--clean[clean]' \
                    '--save-change-set=+[name]:str:' \
                    '*:stack name:' ;;
                lint|validate|cat|output|diff|logs|list|changeset) _arguments '*:stack or template name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_stackctl "$@"
