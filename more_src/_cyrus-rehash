#compdef cyrus-rehash
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/rehash.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org rehash(8) reference manpage. Takes
# imapd.conf as a required positional argument, not via a flag.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-rehash: rename Cyrus spool/conf files for changed hash settings
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose: print each rename]' \
  '-n[dry-run (implies verbose)]' \
  '(-F)-f[force fulldirhash=no]' \
  '(-f)-F[force fulldirhash=yes]' \
  '(-I)-i[force hashimapspool=no]' \
  '(-i)-I[force hashimapspool=yes]' \
  '1:imapd.conf:_files' && ret=0
return ret
