#compdef keymgr knot-keymgr
# _knot-keymgr — CZ.NIC Knot keymgr (DNSSEC key/policy manager for Knot DNS authoritative server; -c config file, -C kasp database, -d set zone db dir, -t check timers, -E force unsafe key rollover, -j JSON output, -V version; once a zone is opened: list, generate, ds, dnskey, share, delete, set, import-bind, import-pem, import-pkcs11, set-published, set-active, set-retired, set-removed, policy)
# upstream: https://gitlab.nic.cz/knot/knot-dns
# Subcommands from knot-dns src/utils/keymgr/main.c on tip.

_knot-keymgr() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-C+[kasp dir]:dir:_files -/' \
        '-d+[zone db dir]:dir:_files -/' \
        '-t[check timers]' \
        '-E[force unsafe rollover]' \
        '-j[JSON output]' \
        '1: :->zone' \
        '*::cmd:->cmd'
    case $state in
        zone) _message 'zone name' ;;
        cmd) _describe -t commands 'keymgr subcommand' '(list generate ds dnskey share delete set import-bind import-pem import-pkcs11 set-published set-active set-retired set-removed policy nsec3 nsec3-salt list-signing list-keys list-policies)' ;;
    esac
}

_knot-keymgr "$@"
