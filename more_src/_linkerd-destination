#compdef linkerd-destination
# Documentation: https://man.archlinux.org/search?q=linkerd-destination
# Reference accessed: 2026-05-16

# linkerd-destination: control plane destination service
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--addr=[bind address]:addr:' \
  '--metrics-addr=[metrics addr]:addr:' \
  '--controller-namespace=[controller namespace]:ns:' \
  '--cluster-domain=[cluster domain]:domain:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--log-format=[log format]:fmt:(plain json)' \
  '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
  '--trace-collector=[trace collector addr]:addr:' \
  '--enable-h2-upgrade=[enable h2 upgrade]:bool:(true false)' \
  '--default-opaque-ports=[default opaque ports]:list:' \
  '*::linkerd-destination args:_files' && ret=0
return ret
