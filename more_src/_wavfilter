#compdef wavfilter
# Documentation: https://man.archlinux.org/search?q=wavfilter
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:filter type:(lp hp)' \
  '2:cutoff frequency:' \
  '3:input WAV:_files -g "*.wav"' \
  '4:output WAV:_files -g "*.wav"' && ret=0

return ret
