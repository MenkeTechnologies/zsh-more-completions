#compdef mongosync
# Documentation: https://www.mongodb.com/docs/mongosync/current/reference/mongosync-binary/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--acceptDisclaimer[accept disclaimer non-interactively]' \
  '--cluster0=[source cluster URI]:uri:' \
  '--cluster1=[destination cluster URI]:uri:' \
  '--config=[config YAML]:file:_files -g "*.(yaml|yml)"' \
  '--createIndexesBatchSize=[batch size for index creation]:n:' \
  '--disableMetricsLogging[disable metrics logging]' \
  '--disableTelemetry[disable telemetry]' \
  '--disableVerification[disable verification phase]' \
  '--enableCappedCollectionHandling[handle capped collections]' \
  '--hotDocIDs[track hot doc IDs]' \
  '--id=[run id]:id:' \
  '--loadLevel=[load level 1-4]:n:(1 2 3 4)' \
  '--logPath=[log directory]:dir:_files -/' \
  '--metricsLoggingFilepath=[metrics dir]:dir:_files -/' \
  '--port=[HTTP port]:port:' \
  '--verbosity=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL PANIC)' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
