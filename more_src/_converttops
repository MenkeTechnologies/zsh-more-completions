#compdef converttops
# Documentation: http://www.leptonica.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above; positional args from
# `converttops` usage output (leptonica 1.87.0).
# Syntax: converttops filein fileout [level]   (level = {1,2,3}, default 2)

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:output PS file:_files -g "*.ps"' \
  '3::PS level:(1 2 3)' && ret=0

return ret
