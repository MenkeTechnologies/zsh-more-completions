#compdef faust2jack
# Generate standalone JACK audio applications from Faust DSP code

_arguments -s -S \
  '-httpd[enable HTTP interface]' \
  '-osc[enable OSC interface]' \
  '-midi[enable MIDI interface]' \
  '-nvoices[number of polyphonic voices]:voices:' \
  '-effect[effect DSP file]:file:_files -g "*.dsp"' \
  '-soundfile[enable soundfile support]' \
  '-resample[enable resampling]' \
  '*:DSP file:_files -g "*.dsp"' \
  && return 0
