#compdef grdfilter
# Documentation: https://docs.generic-mapping-tools.org/latest/grdfilter.html
# Source: GenericMappingTools/gmt classic-mode grdfilter — filter a grid (boxcar/cosine/gaussian/median/mode/...).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[distance calc method (p/0-5: cartesian or spherical)]:method:(p 0 1 2 3 4 5)' \
    '-F+[filter type + width (b/c/g/f/o/m/p/h/l/L/u/U + modifiers +h +q)]:spec:_default' \
    '-G+[output grid file]:file:_files' \
    '-I+[output grid spacing (dx/dy)]:spacing:_default' \
    '-N+[NaN handling]:mode:(i p r)' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T[toggle gridline vs pixel registration]' \
    '*-V[verbose (stackable)]' \
    '-r[pixel registration (default gridline)]' \
    '-x+[CPU cores limit]:n:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
