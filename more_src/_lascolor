#compdef lascolor
# Documentation: https://github.com/LAStools/LAStools
# LAStools: color LAS/LAZ points using an orthophoto image

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help output]' \
  '-version[report tool version]' \
  '-gui[launch with GUI]' \
  '-demo[run in demo mode]' \
  '(-v -verbose)'{-v,-verbose}'[extra information output]' \
  '-vv[very verbose output]' \
  '-silent[output only errors/warnings]' \
  '-image+[single image file for coloring all inputs]:file:_files' \
  '-imagedir+[directory containing image files]:dir:_files -/' \
  '-imgtif[use TIFF as image format]' \
  '-imgpng[use PNG as image format]' \
  '-band+[specify band number (default 0)]:n' \
  '-dont_scale_rgb_up[keep RGB values as-is]' \
  '-scale_rgb_up[multiply RGB values by 256]' \
  '-scale_rgb_down[divide RGB values by 256]' \
  '-clamp_RGB_to_8bit[limit RGB to 8-bit range]' \
  '-zero_rgb[set uncolored points to black]' \
  '-red[copy band to red channel]' \
  '-green[copy band to green channel]' \
  '-blue[copy band to blue channel]' \
  '(-grey -gray)'{-grey,-gray}'[copy band to all RGB channels]' \
  '-nir[copy band to NIR channel]' \
  '-intensity[store in intensity field]' \
  '-rgbnir[copy 4 bands to RGBNIR fields]' \
  '-classify_as+[classify black pixels as class n]:code' \
  '-classify_not_black[classify non-black pixels]' \
  '-classify_white[classify white pixels]' \
  '-classify_not_white[classify non-white pixels]' \
  '*-i+[input file or mask]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output file suffix]:suffix' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
