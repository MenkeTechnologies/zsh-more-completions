#compdef makehmmerdb
# Documentation: http://hmmer.org/documentation.html
# HMMER: build an nhmmer binary database from a sequence file

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '--informat=[assert input sequence file format]:format:(fasta embl genbank stockholm a2m afa psiblast clustal phylip)' \
  '--bin_length=[FM index bin length (default 256)]:n' \
  '--sa_freq=[suffix array sample rate, power of 2 (default 8)]:n' \
  '--block_size=[input block size in millions of letters (default 50)]:n' \
  '*:sequence file:_files' && ret=0

return ret
