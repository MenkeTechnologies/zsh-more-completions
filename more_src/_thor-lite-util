#compdef thor-lite-util
# Documentation: https://thor-util-manual.nextron-systems.com/en/latest/
# THOR Lite Util - companion utility for THOR Lite (Nextron Systems)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(upgrade update download install encrypt report verify decrypt logconvert diagnostics)' \
  '*::arg:_files' && ret=0

return ret
