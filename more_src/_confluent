#compdef confluent

# Zsh completion for confluent - Confluent Cloud/Platform CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[CLI context]:context' \
  '(-e --environment)'{-e,--environment}'[environment ID]:environment' \
  '--cluster=[cluster ID]:cluster' \
  '--api-key=[API key]:key' \
  '--api-secret=[API secret]:secret' \
  '(-o --output)'{-o,--output}'[output format]:format:(human json yaml)' \
  '--unsafe-trace[enable unsafe trace logging]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'login:log in to Confluent'
      'logout:log out of Confluent'
      'version:show version'
      'update:update the CLI'
      'completion:generate shell completion'
      'api-key:manage API keys'
      'connect:manage connectors'
      'environment:manage environments'
      'iam:manage identity and access'
      'kafka:manage Apache Kafka'
      'ksql:manage ksqlDB'
      'schema-registry:manage Schema Registry'
      'service-quota:manage service quotas'
      'admin:manage admin settings'
    )
    _describe -t commands 'confluent command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      completion)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
      api-key)
        local -a apikey_cmds=(
          'create:create an API key'
          'delete:delete an API key'
          'describe:describe an API key'
          'list:list API keys'
          'store:store an API key locally'
          'update:update an API key'
          'use:set active API key'
        )
        _describe -t commands 'api-key subcommand' apikey_cmds && ret=0
        ;;
      connect)
        local -a connect_cmds=(
          'cluster:manage connect clusters'
          'plugin:manage connector plugins'
        )
        _describe -t commands 'connect subcommand' connect_cmds && ret=0
        ;;
      environment)
        local -a env_cmds=(
          'create:create an environment'
          'delete:delete an environment'
          'describe:describe an environment'
          'list:list environments'
          'update:update an environment'
          'use:set active environment'
        )
        _describe -t commands 'environment subcommand' env_cmds && ret=0
        ;;
      iam)
        local -a iam_cmds=(
          'rbac:manage role-based access control'
          'pool:manage identity pools'
          'provider:manage identity providers'
          'service-account:manage service accounts'
        )
        _describe -t commands 'iam subcommand' iam_cmds && ret=0
        ;;
      kafka)
        local -a kafka_cmds=(
          'cluster:manage Kafka clusters'
          'mirror:manage mirror topics'
          'link:manage cluster links'
          'topic:manage Kafka topics'
          'consumer:manage consumer groups'
          'acl:manage Kafka ACLs'
          'partition:manage topic partitions'
        )
        _describe -t commands 'kafka subcommand' kafka_cmds && ret=0
        ;;
      ksql)
        local -a ksql_cmds=(
          'cluster:manage ksqlDB clusters'
          'app:manage ksqlDB apps'
        )
        _describe -t commands 'ksql subcommand' ksql_cmds && ret=0
        ;;
      schema-registry)
        local -a sr_cmds=(
          'cluster:manage Schema Registry clusters'
          'subject:manage subjects'
          'schema:manage schemas'
          'exporter:manage schema exporters'
          'dek:manage data encryption keys'
          'kek:manage key encryption keys'
        )
        _describe -t commands 'schema-registry subcommand' sr_cmds && ret=0
        ;;
      service-quota)
        local -a sq_cmds=(
          'list:list service quotas'
        )
        _describe -t commands 'service-quota subcommand' sq_cmds && ret=0
        ;;
      admin)
        local -a admin_cmds=(
          'promo:manage promo codes'
          'payment:manage payment settings'
        )
        _describe -t commands 'admin subcommand' admin_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
