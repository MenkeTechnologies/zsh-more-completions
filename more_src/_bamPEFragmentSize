#compdef bamPEFragmentSize
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/bamPEFragmentSize.html
# deepTools: compute paired-end fragment sizes from BAM files with summary stats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --bamfiles)'{-b,--bamfiles}'[BAM files]:bam:_files -g "*.bam"' \
  '(-hist -o --histogram)'{-hist,-o,--histogram}'[output histogram image]:file:_files' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '--samplesLabel[sample labels]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '--maxFragmentLength[maximum fragment length]:length:' \
  '--logScale[plot fragment lengths on log scale]' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases]:size:' \
  '(-n --distanceBetweenBins)'{-n,--distanceBetweenBins}'[distance between bins]:n:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED file of regions to exclude]:file:_files' \
  '--table[output tab-separated table file]:file:_files' \
  '--outRawFragmentLengths[output raw fragment lengths file]:file:_files' \
  '--verbose[verbose output]' \
  '--version[show version]' && ret=0

return ret
