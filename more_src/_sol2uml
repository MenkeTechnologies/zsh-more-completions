#compdef sol2uml
# Documentation: https://github.com/naddison36/sol2uml/blob/master/README.md
# sol2uml - UML class/storage diagram generator for Solidity contracts

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable debugging output]' \
  '(-o --outputFileName)'{-o,--outputFileName}'=[output file name]:file:_files' \
  '(-f --outputFormat)'{-f,--outputFormat}'=[output format]:format:(svg png dot all)' \
  '(-n --network)'{-n,--network}'=[blockchain network]:network:' \
  '(-k --apiKey)'{-k,--apiKey}'=[block explorer API key]:key:' \
  '(-e --explorerUrl)'{-e,--explorerUrl}'=[custom explorer URL]:url:' \
  '(-bc --backColor)'{-bc,--backColor}'=[canvas background color]:color:' \
  '(-sc --shapeColor)'{-sc,--shapeColor}'=[shape color]:color:' \
  '(-fc --fillColor)'{-fc,--fillColor}'=[node fill color]:color:' \
  '(-tc --textColor)'{-tc,--textColor}'=[text color]:color:' \
  '(-b --baseContractNames)'{-b,--baseContractNames}'=[filter to base contracts]:names:' \
  '(-c --clusterFolders)'{-c,--clusterFolders}'[group contracts by source folders]' \
  '1:command:(class storage flatten diff)' \
  '*:solidity file or address:_files' && ret=0

return ret
