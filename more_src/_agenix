#compdef agenix
# _agenix — edit and rekey age-encrypted secret files for NixOS (ryantm/agenix)
# upstream: https://github.com/ryantm/agenix
# Flags from pkgs/agenix.sh.

_agenix() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-e --edit)'{-e+,--edit=}'[edit FILE using $EDITOR]:file:_files' \
        '(-r --rekey)'{-r,--rekey}'[re-encrypt secrets with specified recipients]' \
        '(-d --decrypt)'{-d+,--decrypt=}'[decrypt FILE to stdout]:file:_files' \
        '*'{-i+,--identity=}'[private SSH key to decrypt with]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
}

_agenix "$@"
