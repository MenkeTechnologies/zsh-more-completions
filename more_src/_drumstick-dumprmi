#compdef drumstick-dumprmi
# _drumstick-dumprmi — dump / extract a RIFF MIDI (.rmi) file (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/dumprmi/main.cpp (QCommandLineParser).

_drumstick-dumprmi() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-e --extract)'{-e,--extract}'[extract the embedded SMF as a .mid file]' \
        '*:RMI file:_files -g "*.rmi"'
}

_drumstick-dumprmi "$@"
