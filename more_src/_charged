_charged() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[output usage information]' \
        '(- *)'{-v,--version}'[output version number]' \
        '(-t --api-token)'{-t,--api-token}'=[API access token (required unless --cookie-file is specified; bound to API_TOKEN env var)]:token:' \
        '(-C --cookie-file)'{-C,--cookie-file}'=[generate random access token and persist to path (default: none; bound to COOKIE_FILE env var)]:path:_files' \
        '(-l --ln-path)'{-l,--ln-path}'=[path to c-lightning data directory (default ~/.lightning; bound to LN_PATH env var)]:path:_files -/' \
        '(-d --db-path)'{-d,--db-path}'=[path to sqlite3 database file (default ./sqlite.db; bound to DB_PATH env var)]:path:_files' \
        '(-w --max-wait)'{-w,--max-wait}'=[maximum time to wait for invoice long-poll updates in seconds (default 120; bound to MAX_WAIT env var)]:seconds:' \
        '(-p --port)'{-p,--port}'=[http server port (default 9112; bound to PORT env var)]:port:' \
        '(-i --host)'{-i,--host}'=[http server listen address (default 127.0.0.1; bound to HOST env var)]:host:_hosts' \
        '(-e --node-env)'{-e,--node-env}'=[nodejs environment mode (default production; bound to NODE_ENV env var)]:env:(production development test)' \
        '--allow-cors=[allow browser CORS requests from origin (default off; bound to ALLOW_CORS env var)]:origin:' \
        '--rate-proxy=[proxy URI for fetching exchange rate from Bitstamp/CoinGecko (default: proxy-from-env; bound to RATE_PROXY env var)]:uri:' \
        '--hook-proxy=[proxy URI for webhook push requests (default: proxy-from-env; bound to HOOK_PROXY env var)]:uri:' \
        '--all-proxy=[proxy URI for all http requests (default: proxy-from-env; bound to ALL_PROXY env var)]:uri:'
}

_charged "$@"
