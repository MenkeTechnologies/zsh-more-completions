#compdef gone
# _gone — terminal pomodoro timer (guillaumebreton/gone)
# upstream: https://github.com/guillaumebreton/gone
# Flags from main.go (stdlib flag).

_gone() {
    local -a args
    args=(
        '-w+[working session duration (minutes)]:minutes:'
        '-s+[short break duration (minutes)]:minutes:'
        '-l+[long break duration (minutes)]:minutes:'
        '-p+[session pattern (w=work, s=short, l=long)]:pattern:'
        '-e+[command to execute when a session ends]:cmd:'
        '-m+[color mode]:mode:(light dark)'
        '-n[enable desktop notifications]'
        '-debug[development debug mode]'
        '(- *)-h[show help]'
    )
    _arguments -s $args
}

_gone "$@"
