#compdef cxfreeze cx_Freeze
# _cxfreeze — package Python apps into executables (marcelotduarte/cx_Freeze)
# upstream: https://github.com/marcelotduarte/cx_Freeze
# Flags from cx_Freeze docs (script.html).

_cxfreeze() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--script=[python script to freeze]:file:_files -g "*.py"' \
        '--base=[base name (Console / Win32GUI / etc.)]:base:(Console Win32GUI Win32Service WinMainService)' \
        '--base-name=[deprecated alias for --base]:base:' \
        '--init-script=[init script to use]:file:_files' \
        '--target-dir=[output directory]:dir:_files -/' \
        '--target-name=[output executable name]:name:' \
        '--icon=[executable icon file]:file:_files' \
        '--manifest=[Windows manifest file]:file:_files' \
        '--shortcut-name=[Windows shortcut name]:name:' \
        '--shortcut-dir=[Windows shortcut directory]:dir:' \
        '--copyright=[copyright string]:str:' \
        '--trademarks=[trademark string]:str:' \
        '--color-code-background=[background ANSI color for console]:color:' \
        '--color-code-foreground=[foreground ANSI color for console]:color:' \
        '--uac-admin[require admin elevation (Windows)]' \
        '--uac-uiaccess[request UIAccess (Windows)]' \
        '--debug[debug build]' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '*:script:_files -g "*.py"'
}

_cxfreeze "$@"
