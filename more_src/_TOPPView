#compdef TOPPView
# Documentation: https://www.openms.org/documentation/html/TOPP_TOPPView.html
# OpenMS: GUI viewer for mass-spectrometry maps, spectra and chromatograms

local ret=1

_arguments -s -S \
  '--help[show this help]' \
  '-ini[set the INI file]:file:_files -g "*.ini"' \
  '--force[force rescan for new TOPP tools after version updates]' \
  '--skip_tool_scan[skip automatic scan for new tools]' \
  '*:file:_files -g "*.(mzML|mzXML|mzData|featureXML|consensusXML|idXML)"' && ret=0

return ret
