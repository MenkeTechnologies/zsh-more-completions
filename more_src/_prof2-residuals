#compdef prof2-residuals
# Documentation: https://professor.hepforge.org/docs.sphinx213/
# prof2-residuals - Professor2 relative residuals of interpolation vs MC runs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--pname --pfile)'{--pname,--pfile}'=[name of the params file in each run directory]:name:' \
  '--xrange=[+/- range of relative deviation to display]:range:' \
  '--nbins=[number of bins in relative residuals histograms]:N:' \
  '--no-plots[do not write histogram PDFs]' \
  '--tot-only[only make total residuals histograms, not per-observable]' \
  '--logx[use symmetric log binning for resolution around 0]' \
  '(-v --debug)'{-v,--debug}'[turn on debug messages]' \
  '(-q --quiet)'{-q,--quiet}'[turn off messages]' \
  '1:runsdir:_files -/' \
  '2:ipolfile:_files' && ret=0

return ret
