#compdef tgtimg

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --op)'{-o,--op}'+[operation]:op:(new show)' \
  '(-Y --device-type)'{-Y,--device-type}'+[device type]:type:(disk cd tape ssc)' \
  '(-t --type)'{-t,--type}'+[tape type]:type:(data clean WORM)' \
  '(-b --barcode)'{-b,--barcode}'+[barcode label]:label:' \
  '(-s --size)'{-s,--size}'+[size in MB]:mb:' \
  '(-f --file)'{-f,--file}'+[image file]:file:_files' && ret=0

return ret
