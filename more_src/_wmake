#compdef wmake
# Documentation: https://man.archlinux.org/search?q=wmake
# Reference accessed: 2026-05-16

# OpenFOAM wmake: OpenFOAM build/wrap tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-show-compile[show compile command]' \
  '-show-c[show C compiler]' \
  '-show-cxx[show C++ compiler]' \
  '-show-cflags[show C compile flags]' \
  '-show-cxxflags[show C++ compile flags]' \
  '-show-cflags-arch[show arch C compile flags]' \
  '-show-cxxflags-arch[show arch C++ compile flags]' \
  '-show-path-cxx[show C++ compiler path]' \
  '-show-path-c[show C compiler path]' \
  '-show-mpi-cxx[show MPI C++ compiler]' \
  '-show-mpi-c[show MPI C compiler]' \
  '-q[quiet make]' \
  '-k[continue after errors]' \
  '-debug[debug build]' \
  '-j[parallel make jobs]:n:' \
  '-no-recursive[no recursive build]' \
  '-update[update dependencies]' \
  '-all[build all sub-directories]' \
  '-help-full[show full help]' \
  '*::wmake target type and dir:_files' && ret=0
return ret
