#compdef steamcmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '+login[login to Steam]:username: :password: :steam guard code:' \
  '+force_install_dir[set install directory]:directory:_directories' \
  '+app_update[install or update an app]:app ID: :arguments:(validate)' \
  '+app_set_config[set app config]:app ID: :config key: :config value:' \
  '+app_info_print[print app info]:app ID:' \
  '+app_info_update[update app info cache]' \
  '+app_info_request[request app info]:app ID:' \
  '+app_license_request[request free app license]:app ID:' \
  '+app_status[show app status]:app ID:' \
  '+workshop_download_item[download workshop item]:app ID: :workshop item ID:' \
  '+workshop_status[show workshop status]:app ID:' \
  '+quit[quit steamcmd]' \
  '+exit[exit steamcmd]' \
  '+set_steam_guard_code[set Steam Guard code]:code:' \
  '+runscript[run a script file]:script file:_files' \
  '*:commands:' && ret=0

return ret
