#compdef cmake-init
# Documentation: https://github.com/friendlyanon/cmake-init
# The missing CMake project initializer

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--c[generate a C project instead of a C++ one]' \
  '(-s -e -h)-s[set up a static/shared library project]' \
  '(-s -e -h)-e[set up an executable project]' \
  '(-s -e -h)-h[set up a header-only library project]' \
  '--std=[set the language standard to use]:standard:' \
  '--no-clang-tidy[omit the clang-tidy preset from the dev preset]' \
  '--no-cppcheck[omit the cppcheck preset from the dev preset]' \
  '--overwrite[skip checks for existing files and non-empty project root]' \
  '--examples[generate examples for a library]' \
  '-p[package manager to use (conan, vcpkg)]:package manager:(conan vcpkg)' \
  '*:path:_files -/' && ret=0

return ret
