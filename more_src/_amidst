local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Minecraft world types from WorldType enum (from
# amidst.mojangapi.world.WorldType — common values)
local -a world_types=(
  'DEFAULT:standard overworld'
  'FLAT:flat world'
  'LARGE_BIOMES:large biomes preset'
  'AMPLIFIED:amplified terrain'
  'CUSTOMIZED:customized world'
  'BUFFET:buffet world'
)

# 11 options decoded source-direct from @Option
# annotations at CommandLineParameters.java:23-118.
# Single-dash names per args4j convention.
_arguments -s -S \
  '-mcpath+[location of the .minecraft directory]:directory:_files -/' \
  '(-profile)-mcjar+[location of the minecraft jar file (depends -mcjson, forbids -profile)]:jar file:_files -g "*.jar"' \
  '(-profile)-mcjson+[location of the minecraft json file (depends -mcjar, forbids -profile)]:json file:_files -g "*.json"' \
  '(-mcjar -mcjson)-profile+[name of profile to select (forbids -mcjar/-mcjson)]:profile name:' \
  '-biome-profiles+[location of the biome profile directory]:directory:_files -/' \
  '-history+[location of the seed history file]:history file:_files' \
  '-log+[location of the log file]:log file:_files' \
  '-seed+[initial seed to use]:seed string:' \
  '-world-type+[world type for the initial seed (depends -seed)]:world type:->world_types' \
  '(- *)-help[print usage information]' \
  '(- *)-version[print version]' && ret=0

case $state in
  world_types)
    _describe -t world_types 'Minecraft world type' world_types && ret=0
    ;;
esac

return ret
