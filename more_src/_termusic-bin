#compdef termusic
# _termusic-bin — Termusic terminal music player (Rust); local-file + YouTube + lyric + podcast support with Vim-style keys
# upstream: https://github.com/tramhao/termusic

_termusic-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --disable-cover)'{-c,--disable-cover}'[disable album cover]' \
        '(-d --disable-discord)'{-d,--disable-discord}'[disable Discord IPC]' \
        '(-m --max-depth)'{-m,--max-depth}'+[recursion depth]:n:' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '*:music dir or file:_files'
}

_termusic-bin "$@"
