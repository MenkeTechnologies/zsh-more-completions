#compdef sentinelsat
# Documentation: https://sentinelsat.readthedocs.io/en/stable/cli.html
# search and download Copernicus Sentinel satellite images

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --user)'{-u,--user}'=[Copernicus Open Access Hub username]:user:' \
  '(-p --password)'{-p,--password}'=[Copernicus Open Access Hub password]:password:' \
  '--url=[API URL]:url:' \
  '(-s --start)'{-s,--start}'=[start date of query]:date:' \
  '(-e --end)'{-e,--end}'=[end date of query]:date:' \
  '(-g --geometry)'{-g,--geometry}'=[search area geometry as GeoJSON file]:file:_files' \
  '*--uuid=[select by product UUID]:uuid:' \
  '*--name=[select by product name (wildcards allowed)]:name:' \
  '--sentinel=[limit to a Sentinel satellite (1/2/3/5)]:number:' \
  '--instrument=[limit to an instrument]:instrument:' \
  '--producttype=[limit to a product type]:producttype:' \
  '(-c --cloud)'{-c,--cloud}'=[max cloud cover percentage]:percent:' \
  '(-o --order-by)'{-o,--order-by}'=[comma-separated sort keywords]:keywords:' \
  '(-l --limit)'{-l,--limit}'=[max number of products]:number:' \
  '--path=[set download directory]:directory:_files -/' \
  '*'{-q,--query}'=[extra query parameter]:query:' \
  '(-f --footprints)'{-f,--footprints}'=[create geojson footprints file]:path:_files' \
  '--include-pattern=[glob pattern to filter files to download]:pattern:' \
  '--exclude-pattern=[glob pattern to exclude files from download]:pattern:' \
  '--timeout=[HTTP timeout in seconds]:seconds:' \
  '--fmt=[custom format for query result output]:format:' \
  '(-d --download)'{-d,--download}'[download all results of the query]' \
  '--fail-fast[abort on first download failure]' \
  '--gnss[query GNSS end-of-life products]' \
  '--info[display API information]' \
  '--version[show version]' \
  '--debug[print debug log messages]' && ret=0

return ret
