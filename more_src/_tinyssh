#compdef tinyssh tinysshd
# Documentation: https://man.archlinux.org/search?q=tinyssh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-l+[log level]:lvl:' \
  '-x+[crypto names]:names:' \
  '-z+[forbidden keys]:keys:' \
  '*:keydir:_files -/' && ret=0

return ret
