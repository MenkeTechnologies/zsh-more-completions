#compdef tinyssh tinysshd
# Documentation: https://github.com/janmojzis/tinyssh/blob/master/man/tinysshd.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-l+[log level]:lvl:' \
  '-x+[crypto names]:names:' \
  '-z+[forbidden keys]:keys:' \
  '*:keydir:_files -/' && ret=0

return ret
