#compdef superfile spf

# Zsh completion for superfile - TUI file manager

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --dir)'{-d,--dir}'[starting directory]:dir:_directories' \
  '--theme[theme name]:theme:' \
  '--config[config file path]:file:_files' \
  '--print-last-dir[print last visited directory on exit]' \
  '--print-config-path[print config file path]' \
  '--print-theme-path[print theme file path]' \
  '*:path:_files' && return 0
