#compdef amplitude-cli amplitude
# _amplitude-cli — Amplitude amplitude-cli CLI command-line frontend wrapping the Amplitude product analytics platform REST API managing projects events users cohorts dashboards charts notebooks experiments features insights organization data-governance taxonomy event-types properties identify-deduplication-API-key event-deletion upload-batch-events (Amplitude team, Go); cobra
# upstream: https://amplitude.com/

_amplitude-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'project:project operations'
        'event:event operations'
        'user:user operations'
        'cohort:cohort operations'
        'dashboard:dashboard operations'
        'chart:chart operations'
        'notebook:notebook operations'
        'experiment:experiment operations'
        'feature:feature flag operations'
        'taxonomy:taxonomy operations'
        'insight:insight operations'
        'upload:batch upload events'
        'export:export events'
        'identify:upload identify payloads'
        'delete:event deletion'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu)' \
        '--project-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amplitude-cli subcommand' sub ;;
        args)
            case $words[1] in
                project|event|user|cohort|dashboard|chart|notebook|experiment|feature|taxonomy|insight) _arguments '1:op:(list get create update delete enable disable launch stop)' '*:id:' ;;
                upload|export|identify) _arguments '*:file:_files -g "*.json *.csv *.gz"' ;;
            esac
            ;;
    esac
}

_amplitude-cli "$@"
