#compdef xml2bib
# _xml2bib — Chris Putnam bibutils xml2bib CLI converting MODS XML Library of Congress Metadata Object Description Schema citation records into BibTeX entries with brief or full output styles UTF-8 encoded entity translation BibTeX-specific abbreviation expansion citation-key preservation (Chris Putnam team, C); getopt
# upstream: https://sourceforge.net/projects/bibutils/

_xml2bib() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug level]:l:(0 1 2 3 4 5)' \
        '-i+[input encoding]:e:(utf8 latin1 cp1252 iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--input-encoding=+[enc]:str:' \
        '-o+[output encoding]:e:(utf8 latin1 cp1252 iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--output-encoding=+[enc]:str:' \
        '-u[input UTF-8 with BOM]' \
        '-un[input UTF-8 no BOM]' \
        '-b[brief format]' \
        '-fc[final cleanup]' \
        '-nl[no LaTeX output]' \
        '-nb[no BOM]' \
        '-w[wrap output]' \
        '-sd[output safe doctype]' \
        '-s[output single entry mode]' \
        '-c+[corporation tag]:str:' \
        '-x[strict matching]' \
        '*:xml file:_files -g "*.xml *.mods"'
}

_xml2bib "$@"
