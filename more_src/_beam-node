#compdef beam-node beam-node-wallet
# _beam-node — BEAM Development beam-node CLI for the Mimblewimble-based privacy-focused BEAM main-net node maintaining the blockchain validating shielded transactions network sync RPC API mining pool stratum (BeamMW team, C++); boost program_options
# upstream: https://github.com/BeamMW/beam

_beam-node() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--storage=+[file]:file:_files -g "*.db"' \
        '-s+[file]:file:_files -g "*.db"' \
        '--peer=+[host:port]:str:' \
        '--testnet[use testnet]' \
        '--mainnet[use mainnet]' \
        '--horizon_hi=+[N]:n:' \
        '--horizon_lo=+[N]:n:' \
        '--blockchain[do blockchain only]' \
        '--mining_threads=+[N]:n:' \
        '-m+[N]:n:' \
        '--miner_key=+[key]:str:' \
        '--key_owner=+[file]:file:_files' \
        '--treasury_path=+[file]:file:_files' \
        '--log_level=+[level]:l:(error warning info debug verbose trace)' \
        '--file_log_level=+[level]:l:(error warning info debug verbose trace)' \
        '--node_id=+[id]:str:' \
        '--pass=+[password]:str:' \
        '--api_use_http[enable HTTP API]' \
        '--stratum_port=+[port]:n:' \
        '--stratum_secrets_path=+[file]:file:_files' \
        '--config=+[file]:file:_files -g "*.cfg beam-node.cfg"' \
        '--bbs_msg_window_size=+[s]:n:' \
        '--allow_external_event[allow external events]' \
        '--standalone[standalone mode]' \
        '--cwd=+[dir]:dir:_files -/'
}

_beam-node "$@"
