#compdef condor_dagman
# Documentation: https://man.archlinux.org/search?q=condor_dagman
# Reference accessed: 2026-05-16

# condor_dagman: HTCondor DAG manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-Debug[debug level]:level:(0 1 2 3 4 5 6 7)' \
  '-Lockfile[lock file]:file:_files' \
  '-Dag[input DAG]:file:_files -g "*.dag"' \
  '-Rescue[rescue DAG]:file:_files -g "*.rescue*"' \
  '-Help[show help]' \
  '-MaxIdle[max idle jobs]:n:' \
  '-MaxJobs[max running jobs]:n:' \
  '-MaxPre[max running PRE scripts]:n:' \
  '-MaxPost[max running POST scripts]:n:' \
  '-NoEventChecks[no event checks]' \
  '-AllowLogError[allow log errors]' \
  '-DontAlwaysRunPost[do not always run POST]' \
  '-AllowVersionMismatch[allow version mismatch]' \
  '-AutoRescue[auto rescue]:bool:(0 1)' \
  '-DoRecov[do recovery]' \
  '-AlwaysRunPost[always run POST]' \
  '-WaitForDebug[wait for debugger]' \
  '-DumpRescue[dump rescue]' \
  '-Notification[notification]:level:(Always Complete Error Never)' \
  '*::condor_dagman args:_files' && ret=0
return ret
