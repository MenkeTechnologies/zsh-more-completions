#compdef condor_dagman
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_dagman.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_dagman: HTCondor DAG manager (node scheduler for HTCondor job workflows).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-Debug[debug level]:level:(0 1 2 3 4 5 6 7)' \
  '-Lockfile[lock file to prevent concurrent execution]:file:_files' \
  '-Dag[input DAG file]:file:_files -g "*.dag"' \
  '-CsdVersion[version of condor_submit_dag]:version:' \
  '-AllowVersionMismatch[allow version mismatch (not recommended)]' \
  '-Batch-Name[set JobBatchName for submitted jobs]:name:' \
  '-Dot[exit after producing DOT visualization file]' \
  '-DryRun[run without submitting jobs]' \
  '-Priority[minimum job priority]:n:' \
  '-SubmitMethod[submission method]:n:(0 1)' \
  '-UseDagDir[execute from each DAG file directory]' \
  '-AlwaysRunPost[always run POST scripts]' \
  '-DontAlwaysRunPost[do not always run POST scripts]' \
  '-suppress_notification[suppress email notification]' \
  '-dont_suppress_notification[do not suppress email notification]' \
  '-AutoRescue[automatic rescue DAG mode]:bool:(0 1)' \
  '-DoRescueFrom[start from given rescue level]:n:' \
  '-DoRecovery[run in recovery mode]' \
  '-RescueFile[rescue DAG file]:file:_files -g "*.rescue*"' \
  '-load_save[reload from save file]:file:_files' \
  '-MaxIdle[max idle jobs]:n:' \
  '-MaxJobs[max running jobs]:n:' \
  '-MaxPre[max running PRE scripts]:n:' \
  '-MaxPost[max running POST scripts]:n:' \
  '-MaxHold[max held jobs]:n:' \
  '-WaitForDebug[wait for debugger attachment]' \
  '-DumpRescue[dump rescue and exit]' \
  '-Notification[notification level]:level:(Always Complete Error Never)' \
  '*::condor_dagman args:_files' && ret=0
return ret
