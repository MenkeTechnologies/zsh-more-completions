autoload -U is-at-least

_finalfusion() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
":: :_finalfusion_commands" \
"*::: :->finalfusion" \
&& ret=0
    case $state in
    (finalfusion)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:finalfusion-command-$line[1]:"
        case $line[1] in
            (analogy)
_arguments "${_arguments_options[@]}" \
'-f+[]: :(fasttext finalfusion finalfusion_mmap word2vec text textdims)' \
'-k+[Return K nearest neighbors]' \
'-s+[Similarity measure]: :(angular cosine)' \
'--similarity=[Similarity measure]: :(angular cosine)' \
'*--include=[Specify query parts that should be allowed as answers.]: :(a b c)' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':EMBEDDINGS -- Embeddings file:_files' \
'::INPUT -- Input words:_files' \
&& ret=0
;;
(bucket-to-explicit)
_arguments "${_arguments_options[@]}" \
'-f+[File format]: :(finalfusion fasttext)' \
'--format=[File format]: :(finalfusion fasttext)' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT -- Input file:_files' \
':OUTPUT -- Output file:_files' \
&& ret=0
;;
(compute-accuracy)
_arguments "${_arguments_options[@]}" \
'--threads=[Number of threads (default: logical_cpus / 2)]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':EMBEDDINGS -- Embedding file:_files' \
'::ANALOGIES -- Analogy file:_files' \
&& ret=0
;;
(convert)
_arguments "${_arguments_options[@]}" \
'-f+[]: :(fasttext finalfusion floret text textdims word2vec)' \
'--from=[]: :(fasttext finalfusion floret text textdims word2vec)' \
'-m+[TOML metadata add to the embeddings]' \
'--metadata=[TOML metadata add to the embeddings]' \
'-t+[]: :(finalfusion text textdims word2vec)' \
'--to=[]: :(finalfusion text textdims word2vec)' \
'--lossy[do not fail on malformed UTF-8 byte sequences]' \
'-u[unnormalize embeddings (does not affect finalfusion format)]' \
'--unnormalize[unnormalize embeddings (does not affect finalfusion format)]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT -- finalfusion model:_files' \
':OUTPUT -- Output file:_files' \
&& ret=0
;;
(metadata)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT -- finalfusion model:_files' \
'::OUTPUT -- Output file:_files' \
&& ret=0
;;
(quantize)
_arguments "${_arguments_options[@]}" \
'-a+[Number of quantization attempts]' \
'--attempts=[Number of quantization attempts]' \
'-b+[Number of quantizer bits (max: 8)]' \
'--bits=[Number of quantizer bits (max: 8)]' \
'-f+[]: :(fasttext finalfusion floret text textdims word2vec)' \
'--from=[]: :(fasttext finalfusion floret text textdims word2vec)' \
'-i+[Number of iterations]' \
'--iter=[Number of iterations]' \
'-q+[]: :(gaussian_opq opq pq)' \
'--quantizer=[]: :(gaussian_opq opq pq)' \
'-s+[Number of subquantizers (default: d/2)]' \
'--subquantizers=[Number of subquantizers (default: d/2)]' \
'-t+[Number of threads (default: logical_cpus /2)]' \
'--threads=[Number of threads (default: logical_cpus /2)]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT -- finalfusion model:_files' \
':OUTPUT -- Output file:_files' \
&& ret=0
;;
(reconstruct)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT -- quantized finalfusion embeddings:_files' \
':OUTPUT -- reconstructed finalfusion embeddings:_files' \
&& ret=0
;;
(select)
_arguments "${_arguments_options[@]}" \
'-f+[Input format]: :(fasttext finalfusion finalfusion_mmap floret text textdims word2vec)' \
'-t+[Output format]: :(finalfusion text textdims word2vec)' \
'-i[Ignore words for which no embedding is available]' \
'--ignore-unknown[Ignore words for which no embedding is available]' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':INPUT_EMBEDDINGS -- Input embeddings:_files' \
':OUTPUT_EMBEDDINGS -- Output embeddings:_files' \
'::SELECT -- Words to select:_files' \
&& ret=0
;;
(similar)
_arguments "${_arguments_options[@]}" \
'-f+[]: :(fasttext finalfusion finalfusion_mmap text textdims word2vec)' \
'-k+[Return K nearest neighbors]' \
'-s+[Similarity measure]: :(angular cosine)' \
'--similarity=[Similarity measure]: :(angular cosine)' \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
':EMBEDDINGS -- Embeddings file:_files' \
'::INPUT -- Input words:_files' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
'::shell:(zsh bash fish powershell elvish)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'-h[Prints help information]' \
'--help[Prints help information]' \
'-V[Prints version information]' \
'--version[Prints version information]' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_finalfusion_commands] )) ||
_finalfusion_commands() {
    local commands; commands=(
        "analogy:Find words that fit an analogy" \
"bucket-to-explicit:Convert embeddings with bucket-vocab to explicit vocab." \
"compute-accuracy:Compute prediction accuracy on a set of analogies" \
"convert:Convert between embedding formats" \
"metadata:Extract metadata from finalfusion embeddings" \
"quantize:Quantize embedding matrices" \
"reconstruct:Reconstruct quantized embedding matrices" \
"select:Select embeddings from an embeddings file" \
"similar:Find words that are similar to a given word" \
"completions:Generate completion scripts for your shell" \
"help:Prints this message or the help of the given subcommand(s)" \
    )
    _describe -t commands 'finalfusion commands' commands "$@"
}
