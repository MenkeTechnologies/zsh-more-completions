#compdef emaint
# Documentation: https://wiki.gentoo.org/wiki/Emaint
# Gentoo system maintenance tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'all:run all maintenance checks'
      'binhost:scan and generate metadata for binary packages'
      'cleanconfmem:discard config tracker entries for uninstalled packages'
      'cleanresume:discard merge lists for interrupted merges'
      'logs:clean and manage portage logs'
      'merges:scan for failed merges and fix them'
      'movebin:perform binary package move updates'
      'moveinst:perform installed package move updates'
      'sync:synchronize repositories'
      'world:fix problems in the world file'
    )
    _describe -t commands 'emaint command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-c --check)'{-c,--check}'[check for problems]' \
      '(-f --fix)'{-f,--fix}'[fix problems]' \
      '(-P --purge)'{-P,--purge}'[remove unused entries]' \
      '--sync[sync specific repository]:repo:' \
      '--auto[sync auto-sync enabled repositories]' \
      && ret=0
    ;;
esac

return ret
