#compdef btiotest
# Documentation: https://github.com/bluez/bluez/blob/master/tools/btiotest.c
# Source: BlueZ tools/btiotest.c — generic BlueZ BtIO (L2CAP/RFCOMM/SCO/ISO) connection tester.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --channel)'{-c+,--channel=}'[RFCOMM channel]:channel:' \
    '(-p --psm)'{-p+,--psm=}'[L2CAP PSM]:psm:' \
    '(-j --cid)'{-j+,--cid=}'[L2CAP CID]:cid:' \
    '(-t --addr-type)'{-t+,--addr-type=}'[address type]:type:(0 1 2)' \
    '(-s --sco)'{-s,--sco}'[use SCO]' \
    '(-o --iso)'{-o,--iso}'[use ISO]' \
    '(-d --defer)'{-d,--defer}'[use DEFER_SETUP for incoming connections]' \
    '(-V --voice)'{-V+,--voice=}'[voice setting]:voice:(0x0060 0x0003)' \
    '(-S --sec-level)'{-S+,--sec-level=}'[security level]:level:' \
    '(-U --update-sec-level)'{-U+,--update-sec-level=}'[update security level]:level:' \
    '(-i --dev)'{-i+,--dev=}'[HCI device to use]:dev:' \
    '(-r --reject)'{-r+,--reject=}'[reject connection after N seconds]:seconds:' \
    '(-D --disconnect)'{-D+,--disconnect=}'[disconnect after N seconds]:seconds:' \
    '(-a --accept)'{-a+,--accept=}'[accept connection after N seconds]:seconds:' \
    '(-C --central -m --master)'{-C,--central}'[central role switch (incoming connections)]' \
    '(-C --central -m --master)'{-m,--master}'[deprecated alias of --central]' \
    '(-P --priority)'{-P+,--priority=}'[transmission priority (0-6, higher needs CAP_NET_ADMIN)]:prio:' \
    && ret=0

return ret
