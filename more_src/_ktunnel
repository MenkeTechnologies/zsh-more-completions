#compdef ktunnel
# Documentation: https://github.com/omrikiei/ktunnel
# Reference accessed: 2026-05-19
# Verified: upstream cmd/root.go persistent flags and cmd/expose.go
# subcommand flags. Replaced prior 2-flag stub with real subcommands
# (expose, inject, version) and verified flag set.

local curcontext="$curcontext" state line ret=1
local -a commands persistent

commands=(
  'expose:expose local ports/services to the cluster'
  'inject:inject a tunnel into an existing deployment'
  'version:print the ktunnel version'
)

persistent=(
  '(-h --help)'{-h,--help}'[help for ktunnel]'
  '(-p --port)'{-p+,--port=}'[port used to establish the tunnel]:port:'
  '(-t --tls)'{-t,--tls}'[connection uses TLS if set, else plain TCP]'
  '(-v --verbose)'{-v,--verbose}'[verbose mode]'
)

_arguments -C -s -S \
  ${persistent[@]} \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'ktunnel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (expose|inject)
        _arguments -s -S \
          ${persistent[@]} \
          '(-c --ca-file)'{-c+,--ca-file=}'[TLS CA file]:file:_files' \
          '(-s --scheme)'{-s+,--scheme=}'[scheme]:scheme:' \
          '(-o --server-host-override)'{-o+,--server-host-override=}'[server host override for TLS]:host:' \
          '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
          '--context=[Kubernetes context]:context:' \
          '(-i --server-image)'{-i+,--server-image=}'[server image to use]:image:' \
          '--cert=[TLS cert file]:file:_files' \
          '--key=[TLS key file]:file:_files' \
          '--service-type=[service type]:type:(ClusterIP NodePort LoadBalancer)' \
          '--portname=[service port name]:name:' \
          '(-r --reuse)'{-r,--reuse}'[reuse deployment/service if they exist]' \
          '(-f --force)'{-f,--force}'[delete existing deployment before creating]' \
          '(-d --deployment-only)'{-d,--deployment-only}'[create only a deployment, no service]' \
          '*'{-q+,--node-selector-tags=}'[node selector tag]:tag:' \
          '*'{-l+,--deployment-labels=}'[deployment label]:label:' \
          '*--deployment-annotations=[deployment annotation]:annotation:' \
          '*--pod-tolerations=[pod toleration]:toleration:' \
          '--server-cpu-request=[server CPU request]:millicores:' \
          '--server-cpu-limit=[server CPU limit]:millicores:' \
          '--server-memory-request=[server memory request]:MiB:' \
          '--server-memory-limit=[server memory limit]:MiB:' \
          '*:ports/target:_default' && ret=0
        ;;
      (*) _default && ret=0 ;;
    esac
    ;;
esac

return ret
