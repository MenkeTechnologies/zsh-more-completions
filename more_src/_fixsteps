#compdef fixsteps
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss16.html
# SMURF: fix DC steps in a supplied SCUBA-2 time series NDF.

local ret=1

_arguments -s -S \
  'IN=[input time series cube]:ndf:_files' \
  'OUT=[corrected output time series]:ndf:_files' \
  'CONFIG=[step-fixing config defaults]:config:_files' \
  'CONTINUE=[prompt to continue display]:flag:(TRUE FALSE)' \
  'DCFITBOX=[box size for RMS measurement]:n:' \
  'DCLIMCORR=[correlated step detection threshold]:n:' \
  'DCMAXSTEPS=[max steps per minute]:n:' \
  'DCSMOOTH=[median filter width]:n:' \
  'DCTHRESH=[SNR threshold for baseline steps]:n:' \
  'FIRST=[index of first change to display]:n:' \
  'MEANSHIFT=[apply mean-shift filter]:flag:(TRUE FALSE)' \
  'NEWSTEPS=[output file describing fixed steps]:file:_files' \
  'OLDSTEPS=[reference file for validation]:file:_files' \
  'SIZETOL=[relative tolerance for step size]:tol:' \
  'CHANGED=[output: differences found flag]:flag:' \
  'NFIXED=[output: count of steps fixed]:n:' \
  'NREJECTED=[output: count of rejected bolometers]:n:' \
  '*:ndf:_files' && ret=0

return ret
