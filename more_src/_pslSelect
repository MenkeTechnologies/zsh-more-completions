#compdef pslSelect
# UCSC kent: select records from a PSL file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-qtPairs=[file of tab-separated qName tName pairs to select]:file:_files' \
  '-qPass[pass PSLs with queries not in qtPairs file]' \
  '-queries=[file with qNames to select]:file:_files' \
  '-queryPairs=[file of qName pairs with new qName]:file:_files' \
  '-qtStart=[file of qName,tName,tStart rows]:file:_files' \
  '-qDelim=[use part of query name before this character]:char:' \
  ':input psl:_files' \
  ':output psl:_files' && ret=0

return ret
