#compdef i3

# Zsh completion for i3 - improved tiling window manager

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message and exit]' \
  '(-v --version)'{-v,--version}'[display version number and exit]' \
  '(-m --moreversion)'{-m,--moreversion}'[display versions of i3 and i3-msg (for debugging)]' \
  '(-a)-a[disable autostart]' \
  '(-c --config)'{-c,--config}'[use the provided configfile instead]:config file:_files' \
  '(-C --convert-config)'{-C,--convert-config}'[convert old config file to new format]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug output]:debug flags:' \
  '(-V --shmlog-verbose)'{-V,--shmlog-verbose}'[enable verbose shmlog]' \
  '--get-socketpath[retrieve the i3 IPC socket path from X11]' \
  '--force-xinerama[use Xinerama instead of RandR]' \
  '--disable-signalhandler[disable SIGSEGV handler]' \
  '--replace[replace the currently running window manager]'
