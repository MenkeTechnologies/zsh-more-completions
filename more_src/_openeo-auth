#compdef openeo-auth
# Documentation: https://github.com/Open-EO/openeo-python-client/blob/master/openeo/rest/auth/cli.py
# Tool to manage openEO related authentication and configuration

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[increase logging verbosity]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'paths:show paths to config/token files'
      'config-dump:dump config file'
      'config:dump config file'
      'token-dump:dump OpenID Connect refresh tokens file'
      'token-clear:remove OpenID Connect refresh tokens file'
      'add-basic:add or update config entry for basic auth'
      'add-oidc:add or update config entry for OpenID Connect'
      'oidc-auth:authenticate via OpenID Connect and store refresh token'
    )
    _describe -t commands 'openeo-auth command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      config-dump|config|token-dump)
        _arguments '--show-secrets[do not redact secrets in the dump]' && ret=0
        ;;
      token-clear)
        _arguments '(-f --force)'{-f,--force}'[remove without asking confirmation]' && ret=0
        ;;
      add-basic)
        _arguments \
          '--username=[basic auth username]:username' \
          '--no-try[do not try the credentials against the backend]' \
          '1:backend: ' && ret=0
        ;;
      add-oidc)
        _arguments \
          '--provider-id=[provider ID to use]:id' \
          '--client-id=[client ID to use]:id' \
          '--no-client-secret[do not store a client secret]' \
          '--use-default-client[use default client provided by backend]' \
          '1:backend: ' && ret=0
        ;;
      oidc-auth)
        _arguments \
          '--provider-id=[provider ID to use]:id' \
          '--flow=[OpenID Connect flow to use]:flow:(auth-code device)' \
          '--timeout=[timeout in seconds to wait for user response]:seconds' \
          '1:backend: ' && ret=0
        ;;
    esac
    ;;
esac

return ret
