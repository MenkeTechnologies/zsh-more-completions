#compdef mri_gcut
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_gcut
# FreeSurfer: graph-cut based skull stripping

local ret=1

_arguments -s -S \
  '-110[use voxels with intensity 110 as white matter mask]' \
  '-mult[intersect with an existing skull-stripped volume]:filename:_files' \
  '-T[threshold as fraction of WM intensity (default 0.40)]:value' \
  '*:volume:_files' && ret=0

return ret
