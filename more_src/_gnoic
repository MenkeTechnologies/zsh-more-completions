#compdef gnoic
# _gnoic — Karim Said gNOIc gRPC Network Operations Interface client supports OS Cert File and System services (openconfig team, Go); cobra
# upstream: https://github.com/karimra/gnoic

_gnoic() {
    local -a sub=(
        'cert:certificate subcommands'
        'file:file subcommands'
        'system:system subcommands'
        'os:OS install subcommands'
        'healthz:healthz subcommands'
        'factory-reset:factory reset RPCs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--address=+[target address]:host:_hosts' \
        '-a+[target address]:host:_hosts' \
        '--port=+[target port]:port:_ports' \
        '-p+[target port]:port:_ports' \
        '--username=+[user]:user:_users' \
        '-u+[user]:user:_users' \
        '--password=+[password]:str:' \
        '--tls-ca=+[ca cert]:file:_files' \
        '--tls-cert=+[client cert]:file:_files' \
        '--tls-key=+[client key]:file:_files' \
        '--skip-verify[skip TLS verify]' \
        '--insecure[insecure]' \
        '--gzip[use gzip encoding]' \
        '--timeout=+[duration]:str:' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--log-tls-secret[log tls secret]' \
        '--max-msg-size=+[bytes]:n:' \
        '--prometheus-address=+[addr]:str:' \
        '--print-request[print request]' \
        '--retry-timer=+[duration]:str:' \
        '--encoding=+[encoding]:e:(json json_ietf proto bytes ascii)' \
        '--format=+[output format]:f:(json json-pretty event protojson prototext yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnoic subcommand' sub ;;
        args)
            case $words[1] in
                cert) _arguments '1:cert cmd:(rotate install genCSR canGenerateCSR getCertificates revoke load loadCA generateCSR)' ;;
                file) _arguments '1:file cmd:(get put transfertoremote stat remove)' ;;
                system) _arguments '1:system cmd:(ping time switchControlProcessor reboot rebootStatus cancelReboot killProcess setPackage traceroute)' ;;
                os) _arguments '1:os cmd:(install activate verify)' ;;
                healthz) _arguments '1:healthz cmd:(get list ack artifact check)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gnoic "$@"
