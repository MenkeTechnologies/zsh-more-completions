#compdef potrace

# Zsh completion for potrace - bitmap to vector graphics converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-l,--license}'[show license]' \
  '(-b --backend)'{-b,--backend}'[output backend]:backend:(svg eps ps pdf pgm dxf geojson gimppath xfig)' \
  '-s[SVG output (shortcut for -b svg)]' \
  '-e[EPS output (shortcut for -b eps)]' \
  '-p[PS output (shortcut for -b ps)]' \
  '-g[PGM output (shortcut for -b pgm)]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '(-z --turnpolicy)'{-z,--turnpolicy}'[path decomposition policy]:policy:(black white right left minority majority random)' \
  '(-t --turdsize)'{-t,--turdsize}'[suppress speckles of up to this size]:pixels' \
  '(-a --alphamax)'{-a,--alphamax}'[corner threshold]:alpha' \
  '-n[turn off curve optimization]' \
  '(-O --opttolerance)'{-O,--opttolerance}'[curve optimization tolerance]:tolerance' \
  '(-u --unit)'{-u,--unit}'[output quantization]:unit' \
  '(-d --debug)'{-d,--debug}'[debug level]:level' \
  '(-k --blacklevel)'{-k,--blacklevel}'[threshold for bitmap decomposition]:level' \
  '(-i --invert)'{-i,--invert}'[invert the bitmap]' \
  '--opaque[make white shapes opaque]' \
  '(-C --color)'{-C,--color}'[foreground color]:color' \
  '--fillcolor=[background fill color]:color' \
  '(-x --width)'{-x,--width}'[output width]:dimension' \
  '(-y --height)'{-y,--height}'[output height]:dimension' \
  '(-W --pagewidth)'{-W,--pagewidth}'[page width]:dimension' \
  '(-H --pageheight)'{-H,--pageheight}'[page height]:dimension' \
  '(-r --resolution)'{-r,--resolution}'[output resolution]:DPI' \
  '(-S --pagesize)'{-S,--pagesize}'[page size]:size:(letter a4 a3 a5 b5 legal)' \
  '(-M --margin)'{-M,--margin}'[margin]:dimension' \
  '-L[left margin]:dimension' \
  '-R[right margin]:dimension' \
  '-T[top margin]:dimension' \
  '-B[bottom margin]:dimension' \
  '--tight[remove whitespace around output]' \
  '--flat[no layers in SVG]' \
  '--group[group paths in SVG output]' \
  '--rotate=[rotate output]:angle' \
  '--mirror=[mirror output]:axis:(x y)' \
  '--progress[show progress bar]' \
  '--longcoding[use long format in PS output]' \
  '--gamma=[gamma value for PGM backend]:gamma' \
  '*:input bitmap:_files -g "*.pbm *.pgm *.ppm *.pnm *.bmp"'
