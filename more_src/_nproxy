#compdef nproxy
# Documentation: https://doc.powerdns.com/authoritative/manpages/nproxy.1.html
# Read DNS NOTIFY queries and forward them to an inner nameserver

local ret=1

_arguments -s -S \
  '--powerdns-address[IP address of the PowerDNS server to forward to]:address:_hosts' \
  '--chroot[change root to path]:path:_files -/' \
  '--setuid[switch to numerical user ID]:uid:' \
  '--setgid[switch to numerical group ID]:gid:' \
  '--origin-address[source address for notifications]:address:_hosts' \
  '--listen-address[IP addresses to listen on]:address:_hosts' \
  '--listen-port[port to listen on]:port:_ports' \
  '(-d --daemon)'{-d,--daemon}'[set to 0 to disable background operation]:arg:(0 1)' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '*:address:_hosts' && ret=0

return ret
