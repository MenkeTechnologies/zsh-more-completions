#compdef hoarder hoarder-server
# _hoarder — MohamedBassem Hoarder self-hostable bookmark-everything app with AI tagging and full-text search (hoarder-app team, TypeScript); standard argv
# upstream: https://github.com/hoarder-app/hoarder

_hoarder() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--host=+[bind host]:host:_hosts' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '--db-url=+[db url]:str:' \
        '--meilisearch-url=+[meili url]:url:_urls' \
        '--meilisearch-key=+[meili key]:str:' \
        '--openai-api-key=+[openai key]:str:' \
        '--ollama-base-url=+[ollama url]:url:_urls' \
        '--inference-text-model=+[model]:str:' \
        '--inference-image-model=+[model]:str:' \
        '--browser-web-url=+[chrome devtools url]:url:_urls' \
        '--browser-web-socket-url=+[chrome ws url]:url:_urls' \
        '--browser-connect-on-demand[lazy browser]' \
        '--data-quotas-enabled[enable user quotas]' \
        '--public-url=+[public base url]:url:_urls' \
        '--invite-only[invite only signup]' \
        '--disable-signups[disable signups]' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--analytics[opt-in analytics]' \
        '--no-analytics[opt out analytics]'
}

_hoarder "$@"
