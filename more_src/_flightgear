#compdef flightgear fgfs

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--fg-root=[FG_ROOT directory]:dir:_files -/' \
  '--fg-scenery=[scenery path]:dir:_files -/' \
  '--fg-aircraft=[aircraft path]:dir:_files -/' \
  '--aircraft=[aircraft model]:aircraft:' \
  '--airport=[airport ICAO]:icao:' \
  '--runway=[runway]:runway:' \
  '--carrier=[carrier name]:carrier:' \
  '--carrier-position=[parking or start point]:pos:' \
  '--parking-id=[parking position]:id:' \
  '--lat=[latitude]:lat:' \
  '--lon=[longitude]:lon:' \
  '--altitude=[altitude feet]:ft:' \
  '--heading=[heading]:deg:' \
  '--ground-elev=[ground elevation]:ft:' \
  '--time-of-day=[time of day]:tod:(real dawn morning noon afternoon dusk evening midnight)' \
  '--time-match-real[real time]' \
  '--time-offset=[time offset]:hh\:mm\:ss:' \
  '--enable-fullscreen[fullscreen mode]' \
  '--disable-fullscreen[windowed mode]' \
  '--geometry=[window geometry]:WxH:' \
  '--bpp=[bits per pixel]:bpp:(16 24 32)' \
  '--fdm=[flight dynamics model]:fdm:(jsb yasim larcsim magic balloon ada external null)' \
  '--language=[interface language]:lang:' \
  '--config=[config file]:file:_files' \
  '--browser-app=[browser command]:cmd:_command_names' \
  '--vc=[VCG version]:ver:' \
  '--data=[additional data dir]:dir:_files -/' \
  '--telnet=[Telnet IO]:host:port:' \
  '--httpd=[HTTP server port]:port:' \
  '--multiplay=[multiplayer connection]:conn:' \
  '--callsign=[multiplayer callsign]:callsign:' && ret=0

return ret
