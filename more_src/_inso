#compdef inso

_inso() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-v --version)'{-v,--version}'[output the version number]'
        '(-w --workingDir)'{-w,--workingDir}'[set working directory]:directory:_files -/'
        '--verbose[show additional logs]'
        '--ci[run in CI mode]'
        '--config[path to configuration file]:file:_files'
        '--printOptions[print the loaded options]'
        '(-h --help)'{-h,--help}'[display help for command]'
    )

    subcmds=(
        'run:Execution utilities'
        'lint:Lint a document or spec'
        'export:Export data from insomnia models'
        'script:Run scripts defined in .insorc'
        'generate-docs:Generate documentation'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'inso commands' subcmds
            ;;
        args)
            case $line[1] in
                run)
                    local -a run_subcmds
                    run_subcmds=(
                        'test:Run unit test suites'
                        'collection:Run request collection'
                    )
                    _describe -t commands 'run subcommands' run_subcmds
                    ;;
                lint)
                    local -a lint_subcmds
                    lint_subcmds=(
                        'spec:Lint an API specification'
                    )
                    _describe -t commands 'lint subcommands' lint_subcmds
                    ;;
            esac
            ;;
    esac
}

_inso "$@"
