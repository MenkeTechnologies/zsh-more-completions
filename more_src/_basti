#
# yargs command completion script
#
# Installation: @@HOMEBREW_CELLAR@@/basti/1.7.2/bin/basti completion >> ~/.zshrc
#    or @@HOMEBREW_CELLAR@@/basti/1.7.2/bin/basti completion >> ~/.zprofile on OSX.
#
_basti_yargs_completions()
{
  local reply
  local si=$IFS
  IFS=$'
' reply=($(COMP_CWORD="$((CURRENT-1))" COMP_LINE="$BUFFER" COMP_POINT="$CURSOR" @@HOMEBREW_CELLAR@@/basti/1.7.2/bin/basti --get-yargs-completions "${words[@]}"))
  IFS=$si
  _describe 'values' reply
}
###-end-basti-completions-###

