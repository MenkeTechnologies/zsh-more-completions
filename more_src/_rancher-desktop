#compdef rdctl

# Zsh completion for rdctl - Rancher Desktop CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:call Rancher Desktop API endpoints'
  'extension:manage extensions'
  'factory-reset:clear all Rancher Desktop state'
  'list-settings:list current settings'
  'set:update settings'
  'shell:run an interactive shell or command'
  'shutdown:shut down Rancher Desktop'
  'snapshot:manage snapshots'
  'start:start Rancher Desktop'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  '--verbose[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'rdctl command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      set)
        _arguments \
          '--container-engine.name=[container engine]:engine:(containerd moby)' \
          '--kubernetes.enabled=[enable Kubernetes]:bool:(true false)' \
          '--kubernetes.version=[Kubernetes version]:version:' \
          '--application.path-management-strategy=[PATH strategy]:strategy:(manual rcfiles notset)' \
          '*:setting=value:'
        ;;
      snapshot)
        local -a snap_cmds=(
          'create:create a snapshot'
          'delete:delete a snapshot'
          'list:list snapshots'
          'restore:restore a snapshot'
        )
        _describe -t commands 'snapshot command' snap_cmds && ret=0
        ;;
      shell)
        _arguments '*:command:_command_names -e'
        ;;
    esac
    ;;
esac

return ret
