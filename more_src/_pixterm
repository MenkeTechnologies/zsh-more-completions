#compdef pixterm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[dithering mode]:mode:(none FloydSteinberg)' \
  '-dither[dithering mode]:mode:(none FloydSteinberg)' \
  '-s[scale to terminal size]:scale:(fit fill none)' \
  '-scale[scale to terminal size]:scale:(fit fill none)' \
  '-tc[number of terminal columns]:columns' \
  '-tr[number of terminal rows]:rows' \
  '-m[rendering mode]:mode:(256 24bit)' \
  '-matte[background matte color]:color' \
  '-filter[scaling filter]:filter:(NearestNeighbor ApproxBiLinear BiLinear CatmullRom)' \
  '-noresize[do not resize the image]' \
  '1:image file:_files' && ret=0

return ret