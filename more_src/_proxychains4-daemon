#compdef proxychains4-daemon
# Documentation: https://manpages.debian.org/trixie/proxychains4/proxychains4.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-a[Listen address]:address:'
    '-p[Listen port]:port:'
    '-d[Run as daemon]'
    '-h[Show help]'
    '*:config file:_files'
)

_arguments -s -S $arguments
