#compdef proxychains4-daemon
# Documentation: https://man.archlinux.org/search?q=proxychains4-daemon
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-a[Listen address]:address:'
    '-p[Listen port]:port:'
    '-d[Run as daemon]'
    '-h[Show help]'
    '*:config file:_files'
)

_arguments -s -S $arguments
