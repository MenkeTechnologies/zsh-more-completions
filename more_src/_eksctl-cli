#compdef eksctl
# _eksctl-cli — eksctl AWS EKS official CLI (Weaveworks + AWS, Go); create + manage Amazon EKS clusters
# upstream: https://github.com/eksctl-io/eksctl

_eksctl-cli() {
    local -a sub=(
        'anywhere:EKS Anywhere commands'
        'associate:associate IAM identities + service accounts'
        'completion:print shell completion'
        'create:create EKS resources'
        'delete:delete EKS resources'
        'disassociate:disassociate IAM identities'
        'drain:drain nodegroups'
        'enable:enable features'
        'get:get EKS resources'
        'help:show help'
        'info:print eksctl info'
        'register:register external cluster'
        'scale:scale a nodegroup'
        'set:set logging type / labels / etc'
        'unset:unset labels / etc'
        'update:update cluster resources'
        'upgrade:upgrade cluster'
        'utils:utility commands'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-C+[color]:when:(true false fabulous)' \
        '--color+[color]:when:(true false fabulous)' \
        '--dumpLogs[dump logs]' \
        '-d[dump logs]' \
        '--verbose+[verbosity]:n:' \
        '-v+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'eksctl subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments '1:create what:(addon cluster fargateprofile iamidentitymapping iamserviceaccount nodegroup pod-identity-association podidentityassociation)' '*:args:' ;;
                delete) _arguments '1:delete what:(addon cluster fargateprofile iamidentitymapping iamserviceaccount nodegroup pod-identity-association podidentityassociation)' '*:args:' ;;
                get) _arguments '1:get what:(addon cluster cluster-versions fargateprofile iamidentitymapping iamserviceaccount labels nodegroup pod-identity-association podidentityassociation)' '*:args:' ;;
                scale) _arguments '1:scale what:(nodegroup)' '*:args:' \
                    '--cluster+[cluster]:cluster:' \
                    '--name+[name]:str:' \
                    '--nodes+[nodes]:n:' \
                    '--nodes-min+[nodes min]:n:' \
                    '--nodes-max+[nodes max]:n:' ;;
                upgrade) _arguments '1:upgrade what:(addon cluster nodegroup)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_eksctl-cli "$@"
