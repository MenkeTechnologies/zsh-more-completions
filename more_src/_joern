#compdef joern joern-cli joern-parse joern-export joern-scan joern-slice joern-flow joern-vectors joern-stats
# Documentation: https://docs.joern.io/
# Sources: joern-cli/src/main/scala/io/joern/joerncli/{JoernParse,JoernExport,
#          JoernScan,JoernSlice,JoernFlow,JoernVectors}.scala (scopt configs)
# Reference accessed: 2026-05-30
# Joern — Whitespace Engineering's static code-analysis platform. CPG-based
# (Code Property Graph) — wrapper scripts for source→CPG (parse), CPG→graph
# (export), CPG querying (scan), slicing (slice), data-flow (flow), vector
# emission (vectors), and an interactive Scala REPL (`joern` itself).

local curcontext="$curcontext" state line ret=1

case $service in

  joern|joern-cli)
    # Interactive Scala REPL launcher. Bare CLI surface — most work happens
    # inside the REPL via importCode(), help.cpg, :exit etc.
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--script=[run a script file instead of opening REPL]:file:_files -g "*.(sc|scala)"' \
      '--param=[script parameter (key=value)]:param:' \
      '--import-script=[script to import before REPL starts]:file:_files -g "*.(sc|scala)"' \
      '--server[run as JSON-RPC server]' \
      '--server-host=[server host]:host:_hosts' \
      '--server-port=[server port]:port:' \
      '--nocolors[disable colored output]' \
      '*:cpg or source:_files' \
      && ret=0
    ;;

  joern-parse)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(-o --output)'{-o,--output=}'[output CPG filename]:file:_files' \
      '--language=[source language override]:lang:(c cpp java jvm javasrc go python php csharp kotlin js javascript ruby swift ghidra)' \
      '(- *)--list-languages[list available frontends and exit]' \
      '--namespaces=[comma-separated namespaces to include]:namespaces:' \
      '(--nooverlays --overlaysonly)--nooverlays[do not apply default overlays]' \
      '(--nooverlays --overlaysonly)--overlaysonly[only apply default overlays (skip parse)]' \
      '--max-num-def=[max definitions per method (data-flow calc)]:N:' \
      '1:source file or directory:_files' \
      '*:frontend args (after --):' \
      && ret=0
    ;;

  joern-export)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(-o --out)'{-o,--out=}'[output directory (created, must not exist)]:dir:_files -/' \
      '--repr=[CPG representation to export (default cpg14)]:repr:(ast cfg ddg cdg pdg cpg14 cpg all)' \
      '--format=[export format (default dot)]:fmt:(dot neo4jcsv graphml graphson)' \
      '1:input CPG (default cpg.bin):_files -g "*.bin"' \
      && ret=0
    ;;

  joern-scan)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--overwrite[overwrite existing CPG]' \
      '--store[persist graph changes from scanner]' \
      '--dump[dump available queries to default location]' \
      '--dump-to=[dump queries to specific file]:file:_files' \
      '(- *)--list-query-names[list all available query names]' \
      '--updatedb[update query database]' \
      '--dbversion=[query DB version that updatedb installs]:version:' \
      '--names=[filter queries by comma-separated names]:names:' \
      '--tags=[filter queries by comma-separated tags]:tags:' \
      '--depth=[interprocedural call depth]:N:' \
      '--language=[source language]:lang:(c cpp java jvm javasrc go python php csharp kotlin js javascript ruby swift)' \
      '(- *)--list-languages[list available languages]' \
      '1:source directory:_files -/' \
      && ret=0
    ;;

  joern-slice)
    # Subcommand: data-flow OR usages.
    _arguments -C \
      '(- *)--help[show help]' \
      '(-o --out)'{-o,--out=}'[output file (default `slices`)]:file:_files' \
      '--dummy-types[enable dummy types during CPG gen]' \
      '--file-filter=[filter slices by source filename]:filter:' \
      '--method-name-filter=[filter by method-name regex]:regex:' \
      '--method-parameter-filter=[filter by method-parameter-types regex]:regex:' \
      '--method-annotation-filter=[filter by method-annotation regex]:regex:' \
      '(-p --parallelism)'{-p,--parallelism=}'[thread-pool size]:N:' \
      '1: :->slicemode' \
      '*:: :->sliceargs' && ret=0
    case $state in
      slicemode)
        _describe -t commands 'slice mode' \
          '(data-flow:"data-dependency slices" usages:"per-symbol usage slices")' && ret=0
        ;;
      sliceargs)
        case $line[1] in
          data-flow)
            _arguments \
              '--slice-depth=[max DDG depth (default 20)]:N:' \
              '--sink-filter=[sink-code regex]:regex:' \
              '--end-at-external-method[require slice to end at external call]' \
              '*:input CPG or source:_files' \
              && ret=0
            ;;
          usages)
            _arguments \
              '--min-num-calls=[min calls per usage slice (default 1)]:N:' \
              '--exclude-operators[remove operator calls from slices]' \
              '--exclude-source[remove method source code from slices]' \
              '*:input CPG or source:_files' \
              && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  joern-flow)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--src-param=[source parameter index]:N:' \
      '--dst-param=[destination parameter index]:N:' \
      '--depth=[analysis depth (calls to expand)]:N:' \
      '--verbose[print debug information]' \
      '1:source regex:' \
      '2:destination regex:' \
      '3:input CPG (default cpg.bin):_files -g "*.bin"' \
      && ret=0
    ;;

  joern-vectors)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(-o --out)'{-o,--out=}'[output directory (created, must not exist)]:dir:_files -/' \
      '--features[provide dimension→feature map]' \
      '1:input CPG (default cpg.bin):_files -g "*.bin"' \
      && ret=0
    ;;

  joern-stats)
    # Statistics helper — flag set not exposed via scopt; covers the common
    # positional + meta only.
    _arguments -s -S \
      '(- *)--help[show help]' \
      '1:input CPG (default cpg.bin):_files -g "*.bin"' \
      && ret=0
    ;;

esac

return ret
