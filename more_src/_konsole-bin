#compdef konsole
# _konsole-bin — Konsole KDE terminal emulator (KDE community); Qt-based terminal with tabs, profiles, splits
# upstream: https://invent.kde.org/utilities/konsole

_konsole-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--profile+[profile]:profile:' \
        '--fallback-profile[disable fallback profile]' \
        '--workdir+[cwd]:dir:_files -/' \
        '--hold[hold after exit]' \
        '--noclose[hold after exit]' \
        '--new-tab[open new tab in existing window]' \
        '--tabs-from-file+[load tabs from file]:file:_files' \
        '--background-mode[run as DBus service]' \
        '--separate[force new process]' \
        '--show-menubar[show menubar]' \
        '--hide-menubar[hide menubar]' \
        '--show-tabbar[show tabbar]' \
        '--hide-tabbar[hide tabbar]' \
        '--fullscreen[fullscreen]' \
        '--notransparency[disable transparency]' \
        '--p+[set profile key=value]:str:' \
        '-e+[command]:cmd:_command_names -e' \
        '--list-profiles[list profiles]' \
        '--list-profile-properties[list profile properties]' \
        '--qwindowtitle+[window title]:title:' \
        '--qwindowicon+[window icon]:icon:' \
        '--name+[window name]:name:' \
        '*::command:_command_names -e'
}

_konsole-bin "$@"
