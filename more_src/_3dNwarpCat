#compdef 3dNwarpCat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dNwarpCat.html
# AFNI: catenate a series of warps

local ret=1

_arguments -s -S \
  '-interp[interpolation mode]:mode:(linear quintic wsinc5)' \
  '-verb[verbose output to stderr]' \
  '-prefix[output warp dataset prefix]:prefix:' \
  '-space[attach atlas space marker string]:space:' \
  '-warp1[specify first warp]:warp:_files' \
  '-warp2[specify second warp]:warp:_files' \
  '-iwarp[invert the final output warp]' \
  '-expad[pad warps by N voxels in all directions]:voxels:' \
  '*:warp:_files' && ret=0

return ret
