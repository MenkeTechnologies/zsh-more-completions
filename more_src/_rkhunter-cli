#compdef rkhunter
# Documentation: https://manpages.debian.org/bookworm/rkhunter/rkhunter.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# File is named _rkhunter-cli but binary on disk is just `rkhunter`.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[run check]' \
  '(-C --config-check)'{-C,--config-check}'[check config]' \
  '(--cs2 --color-set2)'{--cs2,--color-set2}'[use alt color set]' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '(--cronjob)--cronjob[cron job mode]' \
  '(--display-logfile)--display-logfile[display log file]' \
  '(--list)--list+[list]:l:(rootkits perl tests propfiles languages)' \
  '(--logfile)*--logfile=[log file]:file:_files' \
  '(--noappend-log)--noappend-log[no append log]' \
  '(--nocolors)--nocolors[no colors]' \
  '(--nolog)--nolog[no logging]' \
  '(--nomow --no-mail-on-warning)'{--nomow,--no-mail-on-warning}'[no mail on warn]' \
  '(--ns --nosummary)'{--ns,--nosummary}'[no summary]' \
  '(--pkgmgr)--pkgmgr=[pkg manager]:p:(NONE BSD DPKG RPM SOLARIS)' \
  '(--propupd)--propupd[update properties]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--rwo --report-warnings-only)'{--rwo,--report-warnings-only}'[warnings only]' \
  '(--sk --skip-keypress)'{--sk,--skip-keypress}'[skip keypress]' \
  '(--summary)--summary[show summary]' \
  '(--syslog)--syslog+[syslog priority]:p:' \
  '(--unlock)--unlock[unlock database]' \
  '(--update)--update[update signatures]' \
  '(--vl --verbose-logging)'{--vl,--verbose-logging}'[verbose logging]' \
  '(--versioncheck)--versioncheck[check version]' \
  '(-x --autox --auto-x)'{-x,--autox,--auto-x}'[auto X]' \
  '(--enable)--enable=[enable tests csv]:list:' \
  '(--disable)--disable=[disable tests csv]:list:' \
  '(--lang)--lang+[language]:lang:' \
  '(--bindir)--bindir+[bin dir csv]:list:' \
  '(--tmpdir)--tmpdir+[tmp dir]:dir:_files -/' \
  '(--dbdir)--dbdir+[db dir]:dir:_files -/' \
  '(--configfile)--configfile+[config file]:file:_files' \
  '(--appendlog)--appendlog[append to log]' \
  '(--debug)--debug[debug logging]' \
  '(--hash)--hash+[hash function]:fn:' \
  '(--nocf)--nocf[no config file]' \
  '(--novl --no-verbose-logging)'{--novl,--no-verbose-logging}'[no verbose log]' \
  '(--no-autox -X)'{--no-autox,-X}'[no auto X]' \
  '*: :_files' && ret=0

return ret
