#compdef grouper
# Documentation: https://github.com/leonklingele/grouper
# analyze expression groups (import, const, var, type) in Go source

local ret=1

_arguments -s -S \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-const-require-grouping[require the use of grouped global const declarations]' \
  '-const-require-single-const[require the use of a single global const declaration only]' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-flags[print analyzer flags in JSON]' \
  '-import-require-grouping[require the use of grouped global import declarations]' \
  '-import-require-single-import[require the use of a single global import declaration only]' \
  '-json[emit JSON output]' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-trace=[write trace log to file]:file:_files' \
  '-type-require-grouping[require the use of grouped global type declarations]' \
  '-type-require-single-type[require the use of a single global type declaration only]' \
  '-var-require-grouping[require the use of grouped global var declarations]' \
  '-var-require-single-var[require the use of a single global var declaration only]' \
  '*:packages:_files' && ret=0

return ret
