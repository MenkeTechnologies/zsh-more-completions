#compdef codex

# Zsh completion for codex - OpenAI Codex CLI (lightweight coding agent)

local curcontext="$curcontext" state line ret=1

_codex_commands() {
  local -a commands=(
    'exec:run a non-interactive task'
    'login:log in to OpenAI'
    'logout:log out'
    'completion:generate shell completion script'
    'mcp:interact with MCP servers'
    'help:show help'
  )
  _describe -t commands 'codex command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-m --model)'{-m,--model}'[model to use]:model' \
  '(-i --image)'{-i,--image}'[include image attachment]:file:_files' \
  '(-a --approval-mode)'{-a,--approval-mode}'[approval mode]:mode:(suggest auto-edit full-auto)' \
  '(-q --quiet)'{-q,--quiet}'[non-interactive mode]' \
  '--config[config file path]:file:_files' \
  '--provider[AI provider]:provider' \
  '--full-auto[run in full-auto mode]' \
  '--dangerously-auto-approve-everything[auto approve everything]' \
  '1: :_codex_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      exec)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-m --model)'{-m,--model}'[model to use]:model' \
          '(-q --quiet)'{-q,--quiet}'[minimize output]' \
          '*:task' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
