#compdef codex
# Documentation: https://github.com/openai/codex
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# OpenAI Codex CLI - terminal coding agent.

local curcontext="$curcontext" state line ret=1

_codex_commands() {
  local -a commands=(
    'exec:run Codex non-interactively'
    'e:alias for exec'
    'review:run a code review non-interactively'
    'resume:resume a previous interactive session'
    'fork:fork a previous interactive session'
    'login:manage login'
    'logout:remove stored credentials'
    'mcp:manage external MCP servers'
    'mcp-server:run codex as an MCP server'
    'plugin:manage codex plugins'
    'completion:generate shell completion scripts'
    'update:update codex to the latest version'
    'doctor:diagnose installation, config, auth, runtime'
    'sandbox:run commands inside the codex sandbox'
    'debug:debugging tools'
    'features:inspect feature flags'
    'apply:apply the latest diff from the agent'
    'a:alias for apply'
    'cloud:browse Codex Cloud tasks'
    'app-server:[experimental] run the app server'
    'remote-control:[experimental] manage the app-server daemon'
    'help:show help'
  )
  _describe -t commands 'codex command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[model to use]:model:' \
  '(-i --image)'{-i,--image}'[attach image(s), comma-delimited]:file:_files' \
  '(-p --profile)'{-p,--profile}'[configuration profile]:profile:' \
  '--profile-v2[use named profile (v2)]:profile:' \
  '(-c --config)'{-c,--config}'[override configuration values]:key=value:' \
  '--strict-config[error on unrecognized config fields]' \
  '*--enable=[enable a feature flag]:feature:' \
  '*--disable=[disable a feature flag]:feature:' \
  '--remote=[connect TUI to a remote app server]:addr:' \
  '--remote-auth-token-env=[env var with bearer token]:env:' \
  '--sandbox=[sandbox restriction mode]:mode:(read-only workspace-write danger-full-access)' \
  '--ask-for-approval=[approval prompt mode]:mode:(untrusted on-failure on-request never)' \
  '--dangerously-bypass-approvals-and-sandbox[bypass safety checks]' \
  '--search[enable web search]' \
  '--oss[open-source mode]' \
  '(-C --cwd)'{-C,--cwd}'[set working directory]:directory:_directories' \
  '1: :_codex_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      exec|e)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-m --model)'{-m,--model}'[model to use]:model:' \
          '*:task:' && ret=0 ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      resume|fork)
        _arguments '*:session id:' && ret=0 ;;
    esac ;;
esac

return ret
