#compdef ftpd
# _ftpd — OpenBSD ftpd (Internet FTP server; usually inetd-launched; -A anonymous only, -D standalone, -S enable statistics; supports ftpchroot(5) chroot users and PASV throttling)
# upstream: https://github.com/openbsd/src (libexec/ftpd)
# Flags from libexec/ftpd/ftpd.8 on tip.

_ftpd() {
    _arguments \
        '-4[IPv4 only (with -D)]' \
        '-6[IPv6 only (with -D)]' \
        '-A[anonymous FTP only]' \
        '-D[standalone (daemonize)]' \
        '-d[debug]' \
        '-l[log connections]' \
        '-M[disable mlsd output mode]' \
        '-n[disable anonymous FTP]' \
        '-P[show config path + exit]' \
        '-S[enable statistics logging]' \
        '-U[log session in last/wtmp]' \
        '-W[disable wtmp logging]' \
        '-m+[minimum uid permitted to log in]:uid:' \
        '-T+[maximum idle timeout (seconds)]:seconds:' \
        '-t+[default idle timeout (seconds)]:seconds:' \
        '-u+[umask]:mask:'
}

_ftpd "$@"
