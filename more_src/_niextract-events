#compdef niextract-events
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/niextract-events.html
# Extract/filter NICER events by spatial region and/or time GTI

local ret=1

_arguments -s -S \
  'filename=[input event file(s), @ for list]:filename:_files' \
  'eventsout=[output events file name]:eventsout:_files' \
  'regionfile=[spatial region file, or NONE]:regionfile:_files' \
  'timefile=[temporal GTI file, or NONE]:timefile:_files' \
  'xcolf=[X coordinate column for region filtering]:xcolf:' \
  'ycolf=[Y coordinate column for region filtering]:ycolf:' \
  'tcol=[event timestamp column]:tcol:' \
  'events=[events extension name]:events:' \
  'obsid=[replace OBS_ID keyword, or NONE]:obsid:' \
  'gtimerge=[GTI merge method OR or AND]:gtimerge:(OR AND)' \
  'fpmsel=[process FPM selection information]:fpmsel:(yes no)' \
  'gti=[GTI extension name]:gti:' \
  'minselectmb=[file size threshold for low-mem MB]:minselectmb:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'history=[write HISTORY and FILIN keywords]:history:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
