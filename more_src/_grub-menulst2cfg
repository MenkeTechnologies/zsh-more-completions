#compdef grub-menulst2cfg
# Documentation: https://www.gnu.org/software/grub/manual/grub/grub.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# grub-menulst2cfg: convert legacy GRUB menu.lst to grub.cfg
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-V[show version]' \
  '(- *)--usage[show usage]' \
  '1:menu.lst input:_files' \
  '2:grub.cfg output:_files' && ret=0
return ret
