#compdef grub-menulst2cfg
# Documentation: https://man.archlinux.org/search?q=grub-menulst2cfg
# Reference accessed: 2026-05-16

# grub-menulst2cfg: convert legacy GRUB menu.lst to grub.cfg
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-V[show version]' \
  '(- *)--usage[show usage]' \
  '1:menu.lst input:_files' \
  '2:grub.cfg output:_files' && ret=0
return ret
