#compdef lvmd
# Documentation: https://github.com/topolvm/topolvm/blob/main/docs/lvmd.md
# lvmd — TopoLVM gRPC service to manage LVM volumes on a node

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[config file path for device-class settings]:config file:_files' \
  '--container[set if LVMd runs in the container]' \
  '--spare=[spare capacity in GiB subtracted from free space reporting]:gib' && ret=0

return ret
