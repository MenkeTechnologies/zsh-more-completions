#compdef jumppad
# Documentation: https://man.archlinux.org/search?q=jumppad
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:apply Jumppad configuration (create/update resources)'
  'down:tear down all resources from configuration'
  'dev:watch and apply on changes (live development mode)'
  'init:initialize a new project'
  'check:validate configuration files'
  'status:show resource status'
  'env:show env vars set by configuration'
  'exec:execute a command inside a service'
  'output:show outputs from configuration'
  'logs:show service logs'
  'refresh:refresh remote state'
  'delete:delete a specific resource'
  'purge:purge cached resources'
  'connector:run/operate the local connector'
  'test:run blueprint tests'
  'completion:generate shell completion'
  'version:show jumppad version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-level=[log level]:level:(debug info warning error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jumppad command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (up)
        _arguments \
          '--force-update[ignore caches and re-download]' \
          '--no-browser[do not open browser]' \
          '*--var=[variable key=value]:var:' \
          '--vars-file=[variables file]:file:_files' \
          '(-v --version)'{-v+,--version=}'[Jumppad runtime version]:version:' \
          '(-y --y)'{-y,--y}'[skip confirmation prompts]' \
          '*::path_or_url:_files' && ret=0 ;;
      (down)
        _arguments \
          '(-y --y)'{-y,--y}'[skip confirmation]' && ret=0 ;;
      (dev)
        _arguments \
          '*--var=[variable key=value]:var:' \
          '--vars-file=[variables file]:file:_files' \
          '--no-browser[do not open browser]' \
          '*::path:_files -/' && ret=0 ;;
      (exec)
        _arguments \
          '*::resource_and_command:' && ret=0 ;;
      (logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '*::resource:' && ret=0 ;;
      (env)
        _arguments \
          '*::path:_files' && ret=0 ;;
      (delete)
        _arguments \
          '*::resource:' && ret=0 ;;
      (init)
        _arguments \
          '*::name:' && ret=0 ;;
      (check)
        _arguments \
          '*::path:_files' && ret=0 ;;
      (test)
        _arguments \
          '*::path:_files -/' && ret=0 ;;
      (refresh)
        _arguments \
          '*::path:_files' && ret=0 ;;
      (purge)
        _arguments \
          '(-y --y)'{-y,--y}'[skip confirmation]' && ret=0 ;;
      (output)
        _arguments \
          '*::name:' && ret=0 ;;
      (connector)
        _arguments \
          '*::sub:(run install uninstall status)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
