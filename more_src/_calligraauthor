#compdef calligraauthor

# Calligra eBook author - inherits common Qt/KDE generic options
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--help-all[show Qt+KDE options too]' \
  '(- *)--help-qt[Qt-specific options]' \
  '(- *)--help-kde[KDE-specific options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[print author info]' \
  '--license[print license info]' \
  '--print[print document and exit]:file:_files -g "*.(epub|odt|fodt|opf)"' \
  '--export-pdf[export to PDF and exit]:file:_files -g "*.(epub|odt|fodt|opf)"' \
  '--template=[start from template]:template:' \
  '--profile=[apply profile]:profile:' \
  '*:document:_files -g "*.(epub|odt|fodt|opf)"' && ret=0
return ret
