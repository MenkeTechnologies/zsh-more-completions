#compdef hugin-cli
# Documentation: https://man.archlinux.org/search?q=hugin-cli
# Reference accessed: 2026-05-16

# Hugin: panorama photo stitcher CLI wrapper (alias for hugin_executor / pto_*)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--stitching[run stitching stage]' \
  '--assistant[run assistant stage]' \
  '-t[output threads]:n:' \
  '-o[output filename / prefix]:prefix:_files' \
  '-p[user-defined output preset .pto]:preset:_files -g "*.pto"' \
  '*:panorama .pto:_files -g "*.pto"' && ret=0
return ret
