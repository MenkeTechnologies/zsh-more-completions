#compdef mkrmf
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/mkrmf.html
# Generate an RMF for Chandra imaging data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[name of an input FEF file]:file:_files' \
  'outfile=[name of output FITS RMF file]:file:_files' \
  'axis1=[axis and binning attributes for primary axis]:axis1:' \
  'axis2=[axis and binning attributes for secondary axis]:axis2:' \
  'logfile=[name of log file]:file:_files' \
  'weights=[input weights file in FITS]:file:_files' \
  'thresh=[minimum value included in output matrix]:thresh:' \
  'outfmt=[format of RMF output]:outfmt:(legacy cxc)' \
  'clobber=[overwrite existing output file]:clobber:(yes no)' \
  'verbose=[verbosity level]:verbose:(0 1 2 3 4 5)' \
  'axis3=[optional additional axis]:axis3:' \
  'axis4=[optional additional axis]:axis4:' \
  'axis5=[optional additional axis]:axis5:' && ret=0

return ret
