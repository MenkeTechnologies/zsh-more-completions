#compdef eclint
# _eclint — EditorConfig linter and fixer
# upstream: https://github.com/jedmao/eclint

_eclint() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'check:check files against EditorConfig rules'
                'fix:fix files to match EditorConfig rules'
                'infer:infer EditorConfig settings from files'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                check|fix)
                    _arguments \
                        '--indent_style=[expected indent style]:style:(tab space)' \
                        '--indent_size=[expected indent size]:size:' \
                        '--end_of_line=[expected end of line]:eol:(lf crlf cr)' \
                        '--charset=[expected charset]:charset:(utf-8 utf-8-bom utf-16be utf-16le latin1)' \
                        '--trim_trailing_whitespace=[trim trailing whitespace]:bool:(true false)' \
                        '--insert_final_newline=[insert final newline]:bool:(true false)' \
                        '--max_line_length=[maximum line length]:length:' \
                        '--block_comment_start=[block comment start]:string:' \
                        '--block_comment=[block comment prefix]:string:' \
                        '--block_comment_end=[block comment end]:string:' \
                        '*:files:_files'
                    ;;
                infer)
                    _arguments \
                        '--ini[output as INI format]' \
                        '--score[show confidence scores]' \
                        '*:files:_files'
                    ;;
            esac
            ;;
    esac
}

_eclint "$@"
