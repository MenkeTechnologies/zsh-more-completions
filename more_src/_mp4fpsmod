#compdef mp4fpsmod
# Documentation: https://github.com/nu774/mp4fpsmod/blob/master/man/mp4fpsmod.1
# MP4 timecode editor

local ret=1

_arguments -s -S \
  '-o+[specify MP4 output filename]:file:_files' \
  '*'{-p,--print}'+[output current timecodes into timecode-v2 format]:file:_files' \
  '(-r --fps)'{-t,--tcfile}'+[edit timecodes with timecode-v2 file]:file:_files' \
  '*'{-r,--fps}'+[edit timecodes with nframes:fps spec (repeatable for VFR)]:spec:' \
  '(-x --optimize)'{-x,--optimize}'[optimize timecode]' \
  '(-c --compress-dts)'{-c,--compress-dts}'[enable DTS compression]' \
  '(-d --delay)'{-d,--delay}'+[delay audio by n millisecond]:ms:' \
  '(-T --timescale)'{-T,--timescale}'+[preserve or set video track timescale]:value:(keep)' \
  '*:file:_files -g "*.mp4"' && ret=0

return ret
