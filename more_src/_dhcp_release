#compdef dhcp_release
# Documentation: https://man.archlinux.org/search?q=dhcp_release
# Reference accessed: 2026-05-16

# dhcp_release: send a DHCPRELEASE to free a v4 lease
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:interface:' \
  '2:address:' \
  '3:MAC address:' \
  '4:client-id (optional):' && ret=0
return ret
