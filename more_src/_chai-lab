#compdef chai-lab
# Documentation: https://github.com/chaidiscovery/chai-lab/blob/main/chai_lab/chai1.py
# Chai-1 biomolecular structure prediction

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(fold)' \
  '*::args:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '--output-dir=[directory for output structures]:dir:_files -/' \
      '--use-esm-embeddings[use ESM embeddings]' \
      '--use-msa-server[generate MSAs via ColabFold MMseqs2 server]' \
      '--msa-server-url=[custom ColabFold server URL]:url:' \
      '--msa-directory=[directory of precomputed MSAs]:dir:_files -/' \
      '--constraint-path=[path to restraint/constraint file]:file:_files' \
      '--use-templates-server[retrieve templates automatically]' \
      '--template-hits-path=[path to template hits file]:file:_files' \
      '--recycle-msa-subsample=[MSA subsample size per recycle]:n:' \
      '--num-trunk-recycles=[number of trunk recycles]:n:' \
      '--num-diffn-timesteps=[number of diffusion timesteps]:n:' \
      '--num-diffn-samples=[number of diffusion samples]:n:' \
      '--num-trunk-samples=[number of trunk samples]:n:' \
      '--seed=[random seed]:n:' \
      '--device=[torch device]:device:' \
      '--low-memory[enable low-memory mode]' \
      '--fasta-names-as-cif-chains[use FASTA names as CIF chain ids]' \
      '1:fasta file:_files' \
      '2:output dir:_files -/' && ret=0
    ;;
esac

return ret
