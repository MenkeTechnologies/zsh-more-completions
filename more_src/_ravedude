#compdef ravedude
# Documentation: https://github.com/Rahix/avr-hal/tree/main/ravedude
# ravedude: CLI runner to flash and monitor Rust AVR (Arduino) microcontrollers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--dump-config[print board configuration as TOML and exit]' \
  '(-c --open-console)'{-c,--open-console}'[open serial console after flashing]' \
  '(-C --console-port)'{-C,--console-port}'=[serial console port]:port:_files' \
  '(-b --baudrate)'{-b,--baudrate}'=[serial console baudrate]:baudrate' \
  '(-P --port)'{-P,--port}'=[device port]:port:_files' \
  '(-d --reset-delay)'{-d,--reset-delay}'=[delay in ms before flashing]:ms' \
  '--debug-avrdude[print the avrdude command being run]' \
  '(-o --output-mode)'{-o,--output-mode}'=[console output mode]:mode:(ascii hex dec bin)' \
  '*:binary:_files' && ret=0

return ret
