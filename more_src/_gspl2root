#compdef gspl2root
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gSplineXml2Root.cxx
# gspl2root - GENIE utility to convert XML cross-section splines to ROOT

local ret=1

_arguments -s -S \
  '-f[input XML file containing cross-section spline data]:file:_files' \
  '-p[neutrino (probe) PDG code]:pdg:' \
  '-t[target PDG code (10LZZZAAAI)]:target:' \
  '-e[energy range in GeV (single value or min,max)]:erange:' \
  '-o[output ROOT filename (default gxsec.root)]:outfile:_files' \
  '-w[write cross-section plots to PostScript file]' \
  '-l[plot energy bins in log10 scale]' \
  '-k[keep spline knot points]' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '--event-generator-list[event generator list name (default Default)]:list:' \
  '--tune[tuning configuration identifier]:tune:' \
  '*: :_files' && ret=0

return ret
