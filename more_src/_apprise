#compdef apprise

# Zsh completion for Apprise - push notifications

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-b+[notification body]:body' \
  '--body=[notification body]:body' \
  '-t+[notification title]:title' \
  '--title=[notification title]:title' \
  '-n+[notification type]:type:(info success warning failure)' \
  '--notification-type=[notification type]:type:(info success warning failure)' \
  '-i+[file attachment]:file:_files' \
  '--attach=[file attachment]:file:_files' \
  '-e[interpret escapes in body/title]' \
  '--interpret-escapes[interpret escapes in body/title]' \
  '-l[interpret body as HTML]' \
  '--interpret-links[interpret body as HTML]' \
  '-g+[tag to notify]:tag' \
  '--tag=[tag to notify]:tag' \
  '-Da+[disable asynchronous sending]' \
  '--disable-async[disable asynchronous sending]' \
  '-R[recursively load URLs from config]' \
  '--recursive[recursively load URLs from config]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-D[debug output]' \
  '--debug[debug output]' \
  '-I+[input format]:format:(text html markdown)' \
  '--input-format=[input format]:format:(text html markdown)' \
  '-c+[config file]:config:_files' \
  '--config=[config file]:config:_files' \
  '-S+[storage path]:path:_directories' \
  '--storage-path=[storage path]:path:_directories' \
  '--dry-run[perform dry run]' \
  '*:service URL' && ret=0

return ret
