#compdef create-strapi-app
# Documentation: https://www.npmjs.com/package/create-strapi-app
# Reference accessed: 2026-05-23
# Verified: npx create-strapi-app --help.

# Zsh completion for create-strapi-app - Strapi application scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--no-run[do not start the application after creation]' \
  '--use-npm[force npm instead of yarn]' \
  '--debug[display database connection error]' \
  '--quickstart[quickstart app creation]' \
  '--dbclient=[database client]:client:' \
  '--dbhost=[database host]:host:' \
  '--dbsrv=[database srv]:srv:' \
  '--dbport=[database port]:port:' \
  '--dbname=[database name]:name:' \
  '--dbusername=[database username]:username:' \
  '--dbpassword=[database password]:password:' \
  '--dbssl=[database SSL]:ssl:' \
  '--dbauth=[authentication database]:auth:' \
  '--dbfile=[sqlite database file path]:file:_files' \
  '--dbforce[overwrite database content if any]' \
  ':directory:_directories' && ret=0

return ret
