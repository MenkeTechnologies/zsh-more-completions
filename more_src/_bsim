#compdef bsim
# _bsim — Ghidra BSim database CLI for function similarity queries (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Subcommands from BSimLaunchable.java (custom dispatcher).

_bsim() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                createdatabase:'create a new BSim database'
                dropdatabase:'drop an existing BSim database'
                setmetadata:'set BSim database metadata'
                getmetadata:'print BSim database metadata'
                addexecategory:'add an executable category'
                addfunctiontag:'add a function tag'
                dropindex:'drop the similarity index'
                rebuildindex:'rebuild the similarity index'
                prewarm:'pre-warm the BSim database cache'
                generatesigs:'generate signatures for a Ghidra project'
                commitsigs:'commit signatures into the BSim database'
                generateupdates:'generate signature update set'
                commitupdates:'commit signature update set'
                delete:'delete executables from the database'
                listfuncs:'list functions stored in the database'
                listexes:'list executables stored in the database'
                getexecount:'print number of executables in the database'
                dumpsigs:'dump signatures from the database'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments '*::args:_files'
            ;;
    esac
}

_bsim "$@"
