#compdef polka
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss10.html
# POLPACK: creates Stokes vectors from a set of 2-dimensional intensity frames.

local ret=1

_arguments -s -S \
  'IN=[input 2-d intensity frames]:ndf:_files' \
  'OUT=[output intensity images]:ndf:_files' \
  'OUT_O=[O-ray output images]:ndf:_files' \
  'OUT_E=[E-ray output images]:ndf:_files' \
  'OUT_S=[output Stokes parameter cube]:ndf:_files' \
  'REFIN=[reference frame for coord system]:ndf:_files' \
  'SKYFRAMES=[sky frames to subtract]:ndf:_files' \
  'LOGFILE=[log file for messages]:file:_files' \
  'DUALBEAM=[operate in dual-beam mode]:flag:(TRUE FALSE)' \
  'POL=[treat input as polarimeter data]:flag:(TRUE FALSE)' \
  'PMODE=[type of polarization]:mode:(Linear Circular)' \
  'FITTYPE=[mapping type between images]:type:(1 2 3 4)' \
  'OEFITTYPE=[mapping type between O and E rays]:type:(1 2 3 4)' \
  'PSFSIZE=[feature width for centroiding]:n:' \
  'PERCENTILES=[scaling limit percentiles]:pct:' \
  'SKYPAR=[polynomial order for sky fitting]:n:' \
  'SKYOFF=[remove sky background]:flag:(TRUE FALSE)' \
  'VIEW=[image display mode]:view:(ZOOMED UNZOOMED)' \
  'DPI=[dots per inch for display]:n:' \
  'BADCOL=[colour for missing data]:colour:(RED BLUE GREEN CYAN MAGENTA YELLOW BLACK)' \
  'CURCOL=[colour for entered objects]:colour:(RED BLUE GREEN CYAN MAGENTA YELLOW BLACK)' \
  'REFCOL=[colour for reference objects]:colour:(RED BLUE GREEN CYAN MAGENTA YELLOW BLACK)' \
  'SELCOL=[colour for selected area]:colour:(RED BLUE GREEN CYAN MAGENTA YELLOW BLACK)' \
  'XHAIRCOL=[colour for crosshair]:colour:(RED BLUE GREEN CYAN MAGENTA YELLOW BLACK)' \
  'XHAIR=[use crosshair pointer]:flag:(TRUE FALSE)' \
  'HELPAREA=[display dynamic help]:flag:(TRUE FALSE)' \
  'STARTHELP=[display help browser on startup]:flag:(TRUE FALSE)' \
  'STATUSAREA=[show status box]:flag:(TRUE FALSE)' \
  '*:ndf:_files' && ret=0

return ret
