#compdef meson-install
# _meson-install — Meson build system meson-install CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-install() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C+[build dir]:dir:_files -/' \
        '--no-rebuild[do not rebuild before install]' \
        '--only-changed[only install changed files]' \
        '--quiet[quiet]' \
        '--destdir=+[destdir]:dir:_files -/' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--skip-subprojects=+[skip subprojects]:str:' \
        '--tags=+[tags csv]:str:' \
        '--strip[strip]' \
        '*:arg:'
}

_meson-install "$@"
