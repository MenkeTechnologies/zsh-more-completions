#compdef ctlinnd
# Documentation: man ctlinnd(8)
# Source: InterNetNews/inn frontends/ctlinnd.c — control innd news server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '-h[help]' \
    '-s[silent — no output]' \
    '-t+[timeout in seconds]:secs:_default' \
    '1:command:->cmd' \
    '*::args:_default' \
    && ret=0

case $state in
    cmd)
        local -a cmds
        cmds=(
            addhist:'add history line'
            allow:'allow remote connections'
            begin:'start newly-added site'
            cancel:'cancel message locally'
            changegroup:'change mode of group'
            checkfile:'check syntax of newsfeeds file'
            drop:'stop feeding site'
            feedinfo:'print state of feed to site'
            flush:'flush feed for site'
            flushlogs:'flush log files'
            go:'restart after pause or throttle'
            hangup:'hangup specified incoming channel'
            help:'show help'
            kill:'send signal to site process'
            logmode:'send server mode to syslog'
            lowmark:'reset active file low marks'
            mode:'print operating mode'
            name:'print name of specified channel'
            newgroup:'create new group'
            param:'change command-line parameters'
            pause:'short-term pause accepting articles'
            perl:'enable or disable Perl filtering'
            python:'enable or disable Python filtering'
            readers:'enable or disable newsreading'
            reject:'reject remote connections'
            reload:'re-read config files'
            renumber:'renumber the active file'
            renumberlow:'reset active file low marks'
            reserve:'reserve next pause or throttle'
            rmgroup:'remove named group'
            send:'send text to exploder feed'
            shutdown:'shut down server'
            stathist:'log history stats to file'
            status:'turn innd status generation on/off'
            throttle:'stop accepting articles'
            timer:'turn performance monitoring on/off'
            trace:'turn tracing on/off'
            xabort:'abort the server'
            xexec:'exec new server'
        )
        _describe -t cmds 'ctlinnd command' cmds && ret=0
        ;;
esac

return ret
