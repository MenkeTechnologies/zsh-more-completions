#compdef nixos-shell
# _nixos-shell — boot a NixOS VM from a module (Mic92/nixos-shell)
# upstream: https://github.com/Mic92/nixos-shell
# Flags from bin/nixos-shell usage().

_nixos-shell() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--flake=[flake URI#attr]:flake:' \
        '(-I --builders)'{-I+,--builders=}'[nix builders path]:path:' \
        '--show-trace[show Nix backtrace on errors]' \
        '(-K --keep-failed)'{-K,--keep-failed}'[keep failed build dirs]' \
        '(-k --keep-going)'{-k,--keep-going}'[keep going on build failure]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-vv[more verbose]' \
        '-vvv[very verbose]' \
        '-vvvv[much verbose]' \
        '-vvvvv[debug verbose]' \
        '--fallback[fall back to local build]' \
        '--repair[verify and repair store paths]' \
        '-L[print full build logs]' \
        '--refresh[refresh flake cache]' \
        '--no-net[disable network]' \
        '--impure[allow impure expressions]' \
        '--guest-system=[guest system triple]:triple:' \
        '--host-system=[host system triple]:triple:' \
        '*--option=[Nix option key value]:opt:' \
        '--build-only[build VM but do not start]' \
        '--out-link=[result symlink]:path:_files' \
        '1:nixos config file:_files -g "*.nix"'
}

_nixos-shell "$@"
