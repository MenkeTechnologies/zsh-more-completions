#compdef guetzli
# Documentation: https://man.archlinux.org/search?q=guetzli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--quality=[visual quality]:quality' \
  '--memlimit=[memory limit in MB]:MB' \
  '--nomemlimit[disable memory limit]' \
  '--verbose[print a verbose trace of encoding steps]' \
  '1:input file:_files -g "*.(png|jpg|jpeg)"' \
  '2:output file:_files -g "*.(jpg|jpeg)"' && ret=0

return ret
