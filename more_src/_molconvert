#compdef molconvert
# Documentation: https://docs.chemaxon.com/latest/molconvert_index.html
# ChemAxon Molconvert - molecule file format conversion

local ret=1

_arguments -s -S \
  '-o+[direct output to a specified file]:file:_files' \
  '-m[generate multiple output files]' \
  '-e+[input character encoding]:charset:' \
  '-f+[import format and settings]:format:' \
  '-s+[read molecule from SMILES/SMARTS/peptide string]:string:' \
  '--peptide=[read molecule from peptide string]:string:' \
  '-g[continue with next molecule on error]' \
  '-Y[remove explicit hydrogen atoms]' \
  '-I+[process molecules within index range]:range:' \
  '-U[merge input molecules and output union]' \
  '-R+[fuse fragments from file]:file:_files' \
  '-T[export molecule properties in tab-separated format]' \
  '-F[remove small fragments, retain largest]' \
  '-c+[filter by field values during SDF import]:filter:' \
  '--mol-fields-to-records[convert molecule fields to records]' \
  '-2+[calculate 2D coordinates]:options:' \
  '-3+[calculate 3D coordinates]:options:' \
  '-H3D[display 3D calculation options]' \
  '(-v -vv)-v[verbose output]' \
  '(-v -vv)-vv[very verbose with stack traces]' \
  '*:molecule file:_files' && ret=0

return ret
