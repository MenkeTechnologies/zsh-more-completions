#compdef lsar

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l[print all information for each file]' \
  '-L[print even more information for each file]' \
  '-t[print only file listing as a test]' \
  '-p+[password for encrypted archives]:password:' \
  '-e+[encoding for filenames]:encoding:' \
  '-pe+[password encoding]:encoding:' \
  '-j[output as JSON]' \
  '-ja[output as JSON array]' \
  '-nr[do not recurse into sub-archives]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:archive:_files -g "*.{zip,rar,7z,tar,gz,bz2,xz,lz,lzma,cab,iso,arj,lha,lzh,sit,sitx,cpio,rpm,deb,Z,tgz,tbz2,txz,ace}(-.)"' && ret=0

return ret
