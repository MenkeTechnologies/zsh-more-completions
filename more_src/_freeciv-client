#compdef freeciv freeciv-client freeciv-sdl freeciv-gtk3 freeciv-gtk4 freeciv-qt

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --autoconnect)'{-a,--autoconnect}'[skip connection dialog]' \
  '(-A --Announce)'{-A,--Announce}'+[announce protocol]:proto:(ipv4 ipv6 none)' \
  '(-d --debug)'{-d,--debug}'+[debug level 0-3]:level:(0 1 2 3)' \
  '(-F --Fatal)'{-F,--Fatal}'[fatal warnings]' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-M --Meta)'{-M,--Meta}'+[metaserver]:url:' \
  '(-n --name)'{-n,--name}'+[player name]:name:' \
  '(-p --port)'{-p,--port}'+[server port]:port:' \
  '(-P --Plugin)'{-P,--Plugin}'+[plugin]:name:' \
  '(-r --read)'{-r,--read}'+[load saved game]:file:_files -g "*.{sav,sav.gz,sav.bz2,sav.xz}"' \
  '(-s --server)'{-s,--server}'+[server host]:host:_hosts' \
  '(-S --Sound)'{-S,--Sound}'+[soundspec]:spec:' \
  '(-t --tiles)'{-t,--tiles}'+[tileset]:tileset:' \
  '(-u --user)'{-u,--user}'+[username]:user:' \
  '(-w --warnings)'{-w,--warnings}'[show warnings]' && ret=0

return ret
