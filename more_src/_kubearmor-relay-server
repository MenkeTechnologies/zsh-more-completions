#compdef kubearmor-relay-server
# _kubearmor-relay-server — KubeArmor telemetry/alert aggregating gRPC relay (kubearmor/kubearmor-relay-server)
# upstream: https://github.com/kubearmor/kubearmor-relay-server
# Flags from relay-server/config/config.go on tip.

_kubearmor-relay-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--gRPC=[gRPC bind port]:port:' \
        '--tlsEnabled=[enable TLS to KubeArmor service]:bool:(true false)' \
        '--tlsCertPath=[TLS cert directory]:dir:_files -/' \
        '--tlsCertProvider=[TLS cert source]:src:(self external)'
}

_kubearmor-relay-server "$@"
