#compdef russ
# Documentation: https://github.com/ckampfe/russ
# russ - TUI RSS/Atom feed reader

local ret=1
local context state state_descr line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-d --database-path)'{-d,--database-path}'[override default feed database location]:database:_files' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds
    cmds=(
      'read:read feeds in the TUI'
      'import:import feeds from an OPML file'
    )
    _describe -t commands command cmds && ret=0
    ;;
  args)
    case $line[1] in
      read)
        _arguments -s \
          '(-d --database-path)'{-d,--database-path}'[override feed database location]:database:_files' \
          '(-t --tick-rate)'{-t,--tick-rate}'[time in ms between two ticks]:ms' \
          '(-f --flash-display-duration-seconds)'{-f,--flash-display-duration-seconds}'[seconds to show flash message]:seconds' \
          '(-n --network-timeout)'{-n,--network-timeout}'[network request timeout in seconds]:seconds' \
          '(-h --help)'{-h,--help}'[print help]' && ret=0
        ;;
      import)
        _arguments -s \
          '(-d --database-path)'{-d,--database-path}'[override feed database location]:database:_files' \
          '(-o --opml-path)'{-o,--opml-path}'[path to OPML file for import]:opml:_files' \
          '(-n --network-timeout)'{-n,--network-timeout}'[network request timeout in seconds]:seconds' \
          '(-h --help)'{-h,--help}'[print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
