#compdef gridss gridss.sh
# _gridss — Daniel Cameron gridss CLI Genome Rearrangement IDentification Software Suite split-read assembly-based structural variant caller producing breakpoint-resolution VCF supporting somatic germline tumor-normal paired BAM inputs with iterative assembly-around-breakends repeat handling on Illumina short reads (Daniel Cameron team, Java); getopt
# upstream: https://github.com/PapenfussLab/gridss

_gridss() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-r+[reference fasta]:file:_files -g "*.fa *.fasta *.fna"' \
        '--reference=+[file]:file:_files -g "*.fa *.fasta *.fna"' \
        '-o+[output vcf]:file:_files -g "*.vcf *.vcf.gz"' \
        '--output=+[file]:file:_files -g "*.vcf *.vcf.gz"' \
        '-a+[assembly bam]:file:_files -g "*.bam"' \
        '--assembly=+[bam]:file:_files -g "*.bam"' \
        '-j+[jar]:file:_files -g "*.jar"' \
        '--jar=+[jar]:file:_files -g "*.jar"' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-w+[working dir]:dir:_files -/' \
        '--workingdir=+[dir]:dir:_files -/' \
        '-b+[blacklist]:file:_files -g "*.bed *.bed.gz"' \
        '--blacklist=+[file]:file:_files -g "*.bed *.bed.gz"' \
        '-c+[config file]:file:_files' \
        '--configuration=+[file]:file:_files' \
        '-s+[steps]:s:(setupreference preprocess assemble call all)' \
        '--steps=+[steps]:s:(setupreference preprocess assemble call all)' \
        '--labels=+[labels]:str:' \
        '--useproperpair[require proper pair]' \
        '--concordantreadpairdistribution=+[N]:str:' \
        '--keepTempFiles[keep temp files]' \
        '--maxcoverage=+[N]:n:' \
        '--jvmheap=+[size]:str:' \
        '--externalaligner[use external aligner]' \
        '--repeatmaskerbed=+[file]:file:_files' \
        '--otherjvmheap=+[size]:str:' \
        '--picardoptions=+[opts]:str:' \
        '*:bam files:_files -g "*.bam"'
}

_gridss "$@"
