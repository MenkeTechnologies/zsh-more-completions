#compdef kstest
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss81.html
# KAPPA: compare data sets using the Kolmogorov-Smirnov test

local ret=1

_arguments -s \
  'COMP=[NDF array component to test]:comp:(Data Error Quality Variance)' \
  'LIMIT=[confidence level for consistency]:limit' \
  'IN=[NDFs to be tested]:NDF:_files' \
  'NSAMPLE=[number of subsamples]:nsample' \
  'OUT=[output NDF for consistent data]:NDF:_files' \
  '*:NDF:_files' && ret=0

return ret
