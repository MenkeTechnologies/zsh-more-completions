#compdef mBackground
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mBackground.html
# Remove a planar background (A,B,C) from a single FITS image

local ret=1

_arguments -s -S \
  '-t[table mode: start group of parallel runs]' \
  '-d+[debugging level]:level' \
  '-n[no area images are present]' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '*:argument:_files' && ret=0

return ret
