#compdef joplin

# Zsh completion for joplin - note taking application (terminal client)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'attach:attach a file to a note'
  'batch:execute commands listed in a file'
  'cat:display the given note'
  'config:get or set a config value'
  'cp:duplicates the notes matching <note> to [notebook]'
  'done:marks a to-do as done'
  'e2ee:manage end-to-end encryption'
  'edit:edit the given note'
  'export:exports Joplin data to the given path'
  'geoloc:display a geolocation URL for the note'
  'help:display help for the given command'
  'import:imports data into Joplin'
  'ls:displays the notes in the current notebook'
  'mkbook:creates a new notebook'
  'mknote:creates a new note'
  'mktodo:creates a new to-do'
  'mv:moves the notes matching <note> to [notebook]'
  'ren:renames the given <item> (note or notebook) to <name>'
  'rmbook:deletes the given notebook'
  'rmnote:deletes the notes matching <note-pattern>'
  'search:searches for the given <pattern>'
  'server:start, stop or check the API server'
  'set:sets the property <name> of the given <note>'
  'status:displays summary about the notes and notebooks'
  'sync:synchronizes with remote storage'
  'tag:<tag-command> can be ''add'', ''remove'', ''list'' or ''notetags'''
  'todo:toggle todo state'
  'undone:marks a to-do as non-completed'
  'use:switches to [notebook] - all further operations will be on this notebook'
  'version:display version information'
)

_arguments -s -S \
  '1:command:->command' \
  '--profile[use the specified profile directory]:directory:_files -/' \
  '--env[specify environment (dev or prod)]:env:(dev prod)' \
  '--help[display help]' \
  '--stack-trace-enabled[enable stack trace]' \
  '--log-level[set log level]:level:(debug info warn error)' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'joplin command' commands && ret=0
    ;;
esac

return ret
