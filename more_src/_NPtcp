#compdef NPtcp
# Documentation: https://manpages.debian.org/buster/netpipe-tcp/NPtcp.1.en.html
# NPtcp - NetPIPE network protocol independent performance evaluator (TCP)

local ret=1

_arguments -s -S \
  '-h[receiver host name to connect to (transmitter)]:host:_hosts' \
  '-b[set send and receive TCP buffer sizes]:size' \
  '-l[lower bound for message sizes tested]:size' \
  '-u[upper bound for message sizes tested]:size' \
  '-o[output filename (default np.out)]:file:_files' \
  '-p[perturbation value for message size testing]:size' \
  '-n[number of repeats for each test]:count' \
  '-O[buffer offsets: source_offset,dest_offset]:offsets' \
  '-i[do an integrity check instead of performance]' \
  '-I[invalidate cache to remove cache effects]' \
  '-r[reset TCP sockets after every test]' \
  '-s[streaming mode: data in one direction only]' \
  '-2[bi-directional mode: both sides send/receive]' \
  '-a[asynchronous mode: prepost receives]' \
  '-B[burst mode: prepost all receives at once]' \
  '*::arg:_default' && ret=0

return ret
