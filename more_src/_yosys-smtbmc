#compdef yosys-smtbmc
# Documentation: https://github.com/YosysHQ/yosys/blob/main/backends/smt2/smtbmc.py
# Reference accessed: 2026-05-21
# Verified: upstream source (getopt + help text).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-t+[time steps]:steps:' \
  '-c[run cover analysis]' \
  '-i[run temporal induction instead of BMC]' \
  '-g[generate arbitrary satisfying trace]' \
  '-m+[top module name]:module:' \
  '-s+[SMT solver]:solver:(yices boolector cvc4 mathsat z3 dummy bitwuzla)' \
  '--final-only[check only final constraints]' \
  '--noinfo[skip additional information collection]' \
  '--noinit[omit initial conditions]' \
  '--binary[output anyconst as bit strings]' \
  '--keep-going[continue after first failure]' \
  '--check-witness[validate witness sufficiency]' \
  '--detect-loops[check state uniqueness]' \
  '--incremental[experimental incremental mode]' \
  '--track-assumes[report used assumptions]' \
  '--minimize-assumes[find minimal assumption set]' \
  '--smtc-init[write only final state to constraints]' \
  '--presat[check SAT before UNSAT]' \
  '--aig-noheader[AIGER witness lacks status lines]' \
  '--dump-all[create dump for each step]' \
  '--smtc+[constraints file]:file:_files' \
  '--cex+[CEX file]:file:_files' \
  '--aig+[AIGER files (prefix or aim:aiw)]:aiger:_files' \
  '--yw+[Yosys witness file]:file:_files -g "*.yw"' \
  '--btorwit+[BTOR witness file]:file:_files' \
  '--dump-vcd+[VCD output]:file:_files' \
  '--dump-yw+[Yosys witness output]:file:_files' \
  '--dump-vlogtb+[Verilog testbench output]:file:_files' \
  '--vlogtb-top+[testbench top entity]:name:' \
  '--dump-smtc+[constraints output]:file:_files' \
  '--smtc-top+[constraint module mapping (old[:new])]:mapping:' \
  '--assume-skipped+[skip assumptions before step]:step:' \
  '--append+[add time steps]:steps:' \
  '*:SMT2 input file:_files -g "*.smt2"' && ret=0
return ret
