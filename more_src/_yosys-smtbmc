#compdef yosys-smtbmc
# Documentation: https://man.archlinux.org/search?q=yosys-smtbmc
# Reference accessed: 2026-05-16

# Yosys yosys-smtbmc: SMT-based bounded model checker (with cover/prove)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-t[time steps to model]:n:' \
  '-c[check covers (cover assert)]' \
  '-i[induction mode for prove]' \
  '-m[unroll backwards from given step]:n:' \
  '-s[SMT solver]:solver:(z3 yices boolector cvc4 mathsat dummy)' \
  '-S[per-tick solver args]:args:' \
  '-O[per-solver options]:args:' \
  '--noprogress[disable progress output]' \
  '--unroll[unrolling mode]' \
  '--noincr[disable incremental solving]' \
  '--noprogress[no progress]' \
  '--smt2[write SMT2 to stdout]' \
  '--dump-vcd[write VCD trace]:file:_files' \
  '--dump-vlogtb[write Verilog testbench]:file:_files' \
  '--dump-smtc[write SMT constraint file]:file:_files' \
  '--smtc[read SMT constraint file]:file:_files' \
  '--seed[random seed]:n:' \
  '--final-only[only check the final state]' \
  '--noinit[do not constrain initial state]' \
  '--cex[counterexample to consider as known]:file:_files' \
  '--gentrace[generate traces]' \
  '--info[print info about the SMT2 file]' \
  '*:SMT2 input file:_files -g "*.smt2"' && ret=0
return ret
