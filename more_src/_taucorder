_taucorder() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'dream:run using local dream simulated cloud'
        'local:run using local dream (alias for dream)'
        'prod:connect to remote production Taubyte cloud'
      )
      _describe -t subcommands 'taucorder subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        dream|local)
          if (( CURRENT == 2 )); then
            local -a dreamcmds
            dreamcmds=(
              'with:connect to a specific universe'
              'use:connect to a specific universe (alias for with)'
              'list:list available universes'
              'l:list available universes (alias)'
            )
            _describe -t subcommands 'dream subcommand' dreamcmds
          fi
          ;;
      esac
      ;;
  esac
}

_taucorder "$@"
