#compdef nexfil
# Documentation: https://github.com/thewhiteh4t/nexfil
# OSINT: find profiles by username across social media sites.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-u+[specify a single username]:username:' \
  '-f+[file containing username list]:file:_files' \
  '-l+[multiple comma-separated usernames]:usernames:' \
  '-t+[timeout duration (default 10 seconds)]:seconds:' \
  '-v[print version information]' \
  '-U[check for available updates]' \
  '-pm+[proxy mode]:mode:(single file)' \
  '-proto+[proxy protocol (default http)]:proto:(http https)' \
  '-ph+[proxy hostname]:host:_hosts' \
  '-pp+[proxy port]:port:' && ret=0

return ret
