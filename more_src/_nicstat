#compdef nicstat
# Documentation: https://man.archlinux.org/search?q=nicstat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-?[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-a[show all]' \
  '-i+[interfaces csv]:list:_net_interfaces' \
  '-l[list interfaces]' \
  '-M[Mbits/s mode]' \
  '-m[summary mode]' \
  '-n[skip non-local]' \
  '-p[parsable]' \
  '-s[show extended]' \
  '-S+[stat fields csv]:list:' \
  '-t[show TCP stats]' \
  '-u[show UDP stats]' \
  '-x[extended mode]' \
  '-z[skip zero counters]' \
  '*: :' && ret=0

return ret
