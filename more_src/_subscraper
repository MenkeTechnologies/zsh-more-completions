#compdef subscraper
# Documentation: https://github.com/m8sec/subscraper
# Subdomain enumeration tool using multiple techniques.

local ret=1

_arguments -s -S \
  '-debug[enable debug logging]' \
  '-update[update config file (removes existing entries)]' \
  '-config[override default config location]:file:_files' \
  '-silent[show subdomains only in output]' \
  '(-threads -T)'{-threads,-T}'[max threads for enumeration]:threads' \
  '-t[set connection timeouts]:timeout' \
  '(-d --domain)'{-d,--domain}'[target domain input (domain, .txt, STDIN)]:domain' \
  '-ls[list SubScraper enumeration modules]' \
  '-m[execute module(s) by name or group]:modules' \
  '-module-only[execute modules only, not brute force]' \
  '-w[custom wordlist for DNS brute force]:file:_files' \
  '-ns[comma separated nameservers to use]:nameservers' \
  '(-r -resolve)'{-r,-resolve}'[resolve IP address for each subdomain]' \
  '(-c -cname)'{-c,-cname}'[perform CNAME lookup for takeover checks]' \
  '-http[probe for active HTTP services]' \
  '-http-port[HTTP ports to check, comma separated]:ports' \
  '(-nc -no-color)'{-nc,-no-color}'[disable color output]' \
  '-active[only report active subdomains with resolved IP]' \
  '-csv[create CSV output report]' \
  '-o[output file]:file:_files' && ret=0

return ret
