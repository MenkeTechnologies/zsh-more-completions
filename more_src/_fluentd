#compdef fluentd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-s+[send signal to process]:signal:(USR1 USR2 HUP TERM INT CONT STOP)' \
  '--setup=[install sample config]:directory:_directories' \
  '-c+[configuration file]:config file:_files' \
  '--config=[configuration file]:config file:_files' \
  '--check[check configuration and exit]' \
  '--dry-run[dry run mode]' \
  '-p+[add plugin directory]:plugin directory:_directories' \
  '--plugin=[add plugin directory]:plugin directory:_directories' \
  '-I+[add library path]:library path:_directories' \
  '-r+[load Ruby library]:library:' \
  '-d+[daemonize and write PID]:PID file:_files' \
  '--daemon=[daemonize and write PID]:PID file:_files' \
  '--under-supervisor[run under supervisor]' \
  '--no-supervisor[run without supervisor]' \
  '--workers=[number of workers]:count:' \
  '--user=[change user]:user:_users' \
  '--group=[change group]:group:_groups' \
  '-o+[log file path]:log file:_files' \
  '--log=[log file path]:log file:_files' \
  '--log-rotate-age=[log rotation age]:age:' \
  '--log-rotate-size=[log rotation size]:size:' \
  '--log-event-verbose[enable event verbose logging]' \
  '-i+[inline config]:config:' \
  '--inline-config=[inline config]:config:' \
  '--emit-error-log-interval=[error log interval]:seconds:' \
  '--suppress-repeated-stacktrace[suppress repeated stacktrace]' \
  '--without-source[invoke without input plugins]' \
  '--config-path=[config file path]:config file:_files' \
  '--use-v1-config[use v1 config parser]' \
  '--use-v0-config[use v0 config parser]' \
  '-v[increase verbosity (-v debug, -vv trace)]' \
  '-q[decrease verbosity (-q warn, -qq error)]' \
  '--suppress-config-dump[suppress config dump at start]' \
  '-g+[graceful shutdown timeout]:seconds:' \
  '--gemfile=[Gemfile path]:Gemfile:_files' && ret=0

return ret
