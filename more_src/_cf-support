#compdef cf-support
# Documentation: https://docs.cfengine.com/docs/3.22/reference-components-cf-support.html
# cf-support - gather system details into a tarball for CFEngine support

local ret=1

_arguments -s -S \
  '(-y --yes)'{-y,--yes}'[non-interactive use, assume no ticket and include masterfiles]' \
  '(-h --help)'{-h,--help}'[print the help message]' && ret=0

return ret
