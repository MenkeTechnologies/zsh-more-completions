#compdef salt-extend
# Documentation: https://docs.saltproject.io/en/latest/ref/cli/salt-extend.html
# salt-extend - scaffold new Salt modules, states and extensions from templates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --extension)'{-e,--extension}'+[extension type to develop]:type:(module module_unit state)' \
  '(-o --salt-directory)'{-o,--salt-directory}'+[path to the salt installation]:dir:_files -/' \
  '(-n --name)'{-n,--name}'+[module name for the new module]:name:' \
  '(-d --description)'{-d,--description}'+[description of the new extension]:description:' \
  '--no-merge[do not merge the new module into the salt source directory]' \
  '--debug[print debug messages to stdout]' && ret=0

return ret
