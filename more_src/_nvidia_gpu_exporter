#compdef nvidia_gpu_exporter
# Documentation: https://github.com/utkuozdemir/nvidia_gpu_exporter/blob/main/CONFIGURE.md
# Prometheus exporter for nvidia-smi GPU metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--web.config.file=[path to TLS/auth config file]:file:_files' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:addr' \
  '--web.telemetry-path=[path under which to expose metrics]:path' \
  '--nvidia-smi-command=[path or command for the nvidia-smi executable]:cmd' \
  '--query-field-names=[comma-separated list of query fields (AUTO to detect)]:fields' \
  '--query-field-names-exclude=[comma-separated query fields to exclude]:fields' \
  '--web.enable-pprof[enable pprof endpoints under /debug/pprof/]' \
  '--no-web.enable-pprof[disable pprof endpoints]' \
  '--log.level=[only log messages with given severity or above]:level:(debug info warn error)' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[display application version]' && ret=0

return ret
