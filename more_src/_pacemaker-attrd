#compdef pacemaker-attrd

# pacemaker-attrd: Pacemaker attribute manager daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --verbose)'{-V,--verbose}'[increase log verbosity (repeatable)]' \
  '(--features)--features[show enabled features]' \
  '*::pacemaker-attrd args:_files' && ret=0
return ret
