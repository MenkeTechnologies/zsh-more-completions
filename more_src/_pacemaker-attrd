#compdef pacemaker-attrd

# pacemaker-attrd: pacemaker attribute manager subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-\$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-attrd args:_files' && ret=0
return ret
