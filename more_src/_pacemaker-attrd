#compdef pacemaker-attrd
# Documentation: https://man.archlinux.org/search?q=pacemaker-attrd
# Reference accessed: 2026-05-16

# pacemaker-attrd: pacemaker attribute manager subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-\$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-attrd args:_files' && ret=0
return ret
