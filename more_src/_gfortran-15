#compdef gfortran-15 gfortran
# Documentation: gfortran-15 --help (GCC 15 Fortran)
# Source: GNU Fortran compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-pass-exit-codes[exit with highest error code from a phase]' \
    '(- *)--help[show help]' \
    '(- *)--target-help[target-specific options]' \
    '(- *)--help=[show specific kind of options]:kind:(common optimizers params target warnings joined separate undocumented)' \
    '(- *)--version[show version]' \
    '-dumpspecs[show built-in spec strings]' \
    '-dumpversion[show compiler version]' \
    '-dumpmachine[show target processor]' \
    '-foffload=[offload targets]:targets:' \
    '-print-search-dirs[show compiler search path]' \
    '-print-libgcc-file-name[show libgcc path]' \
    '-print-file-name=[show full path to library]:lib:' \
    '-print-prog-name=[show full path to compiler component]:prog:' \
    '-print-multiarch[show normalized GNU triplet]' \
    '-print-multi-directory[show libgcc root]' \
    '-print-multi-lib[show option/library mapping]' \
    '-print-multi-os-directory[show OS-library relative path]' \
    '-print-sysroot[show target libraries directory]' \
    '-print-sysroot-headers-suffix[show sysroot headers suffix]' \
    '-c[compile only, no link]' \
    '-S[compile only, generate assembly]' \
    '-E[preprocess only]' \
    '-o+[output file]:file:_files' \
    '-O0[no optimisation]' \
    '-O1[basic optimisation]' \
    '-O2[default optimisation]' \
    '-O3[aggressive optimisation]' \
    '-Os[optimise for size]' \
    '-Ofast[aggressive incl. unsafe math]' \
    '-Og[debug-friendly optimisation]' \
    '-g[debug info]' \
    '-Wall[enable common warnings]' \
    '-Wextra[enable extra warnings]' \
    '-pedantic[strict Fortran-standard mode]' \
    '-std=[Fortran standard]:std:(f95 f2003 f2008 f2018 f2023 gnu legacy)' \
    '-ffree-form[free-form source]' \
    '-ffixed-form[fixed-form source]' \
    '*-I+[include search directory]:dir:_files -/' \
    '*-L+[library search directory]:dir:_files -/' \
    '*-l+[library name]:lib:' \
    '*:fortran source:_files -g "*.(f|f90|f95|f03|f08|for|F|F90|F95)"' \
    && ret=0

return ret
