#compdef sh_to_modulefile
# Documentation: https://lmod.readthedocs.io/en/latest/260_sh_to_modulefile.html
# Lmod tool: convert a shell script into a Lua or TCL modulefile

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--to[output modulefile format]:format:(Lua TCL)' \
  '--output[output modulefile base name]:output name:_files' \
  '*:shell script:_files' && ret=0

return ret
