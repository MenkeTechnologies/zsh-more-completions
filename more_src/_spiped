#compdef spiped spipe
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=spiped
# Reference accessed: 2026-05-21
# Verified: upstream FreeBSD spiped(1) man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[take encrypted connections, send unencrypted]' \
  '-e[take unencrypted connections, send encrypted]' \
  '-s+[source socket address]:addr:' \
  '-t+[target socket address]:addr:' \
  '-k+[key file path]:file:_files' \
  '-b+[bind outgoing address]:addr:' \
  '-F[run in foreground]' \
  '-D[wait for DNS with retry logic before binding]' \
  '-f[fast/weak handshaking (disable Diffie-Hellman)]' \
  '-g[enforce perfect forward secrecy (reject -f)]' \
  '-j[disable transport layer keep-alives]' \
  '-n+[max concurrent connections]:n:' \
  '-o+[connection timeout (s)]:n:' \
  '-p+[pidfile path]:file:_files' \
  '-r+[re-resolve target interval (s)]:n:' \
  '-R[disable target address re-resolution]' && ret=0

return ret
