#compdef ITGDec
# Documentation: https://traffic.comics.unina.it/software/ITG/manual/
# D-ITG log decoder: parses binary log files and computes traffic metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help and exit]' \
  '-v[print standard summary to stdout]' \
  '-l+[print the decoded log in text format]:txtlog:_files' \
  '-t[interpret logfile as in text format]' \
  '-o+[print the decoded log for Octave/Matlab import]:outfile:_files' \
  '-r+[generate combined log from receiver- and sender-side logs]:sender log:_files' \
  '-d+[print average delay to file every DT milliseconds]:DT' \
  '-j+[print average jitter to file every JT milliseconds]:JT' \
  '-b+[print average bitrate to file every BT milliseconds]:BT' \
  '-p+[print average packet loss to file every PT milliseconds]:PT' \
  '-c+[print all average metrics to file every CT milliseconds]:CT' \
  '-s+[generate a separate log file for each flow adding a suffix]:suffix' \
  '-f+[consider only flows with number <= flownum]:flownum' \
  '-P[print to stdout the size of each packet]' \
  '-I[print to stdout the inter departure time between each packet pair]' \
  '1:logfile:_files' && ret=0

return ret
