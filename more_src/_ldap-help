#compdef ldap-help ldap-explain
# _ldap-help — distro-shipped LDAP CLI help wrapper (small helper that lists every ldap* / slap* tool in $PATH and prints a brief one-line summary; -l long format, -s search keyword, -V version, -h help; useful for sysadmins exploring an unfamiliar OpenLDAP install)
# upstream: distro-shipped helpers around OpenLDAP CLI tools on tip.
# Common flag shape from openldap-clients/openldap-servers packaging on tip.

_ldap-help() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-l[long format]' \
        '-s+[search keyword]:keyword:' \
        '*::tool:_command_names -e'
}

_ldap-help "$@"
