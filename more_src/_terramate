#compdef terramate

# Zsh completion for terramate - Terraform stack orchestration tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'clone:clone a stack'
  'create:create a new stack'
  'debug:debug information'
  'experimental:experimental features'
  'fmt:format Terramate files'
  'generate:generate code from stacks'
  'install-completions:install shell completions'
  'list:list stacks'
  'run:run a command in each stack'
  'script:manage and run scripts'
  'trigger:trigger stacks for change detection'
  'version:print version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-C --chdir)'{-C,--chdir}'[change working directory]:directory:_directories' \
  '(-B --git-change-base)'{-B,--git-change-base}'[git change base ref]:ref:' \
  '--tags=[filter by tags]:tags:' \
  '--no-tags=[exclude tags]:tags:' \
  '--changed[only include changed stacks]' \
  '--disable-safeguards=[disable safeguards]:safeguards:(all git none)' \
  '--log-level=[log level]:level:(trace debug info warn error fatal disabled)' \
  '--log-fmt=[log format]:format:(text json)' \
  '--log-destination=[log destination]:dest:(stderr stdout file)' \
  '--quiet[suppress output]' \
  '--verbose=[verbosity level]:level:' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '--name=[stack name]:name:' \
          '--description=[stack description]:desc:' \
          '--id=[stack ID]:id:' \
          '--after=[stacks that must run before]:stack:' \
          '--before=[stacks that must run after]:stack:' \
          '--import=[import paths]:path:_directories' \
          '--ensure-stack-ids[ensure all stacks have IDs]' \
          '--all-terraform[mark all terraform dirs as stacks]' \
          ':path:_directories' && ret=0
        ;;
      run)
        _arguments \
          '--no-recursive[do not recurse into substacks]' \
          '--dry-run[plan execution without running]' \
          '--reverse[reverse execution order]' \
          '--continue-on-error[continue on error]' \
          '--parallel=[number of parallel jobs]:jobs:' \
          '*:command:_command_names' && ret=0
        ;;
      list)
        _arguments \
          '--why[show reason for change]' \
          '--run-order[show execution order]' && ret=0
        ;;
      fmt)
        _arguments \
          '--check[check without modifying]' \
          '--detailed-exit-code[return detailed exit code]' \
          '*:file:_files' && ret=0
        ;;
      clone)
        _arguments ':source stack:_directories' ':destination:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
