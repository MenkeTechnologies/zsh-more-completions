#compdef appium-doctor git-bonsai git-recover
# Documentation: source-direct extraction from upstream
# appium/appium-doctor bin/appium-doctor.js yargs
#   .boolean(...)/.describe(...) declarations -> 7 boolean
#   flags + the documented default-fallback behavior in the
#   .check() arm (no flag = enable iOS on macOS + Android).
# agateau/git-bonsai src/cliargs.rs clap-derive CliArgs struct
#   -> 1 short+long flag pair (-l/--log).
# ethomson/git-recover top-level case-arm in the
#   `case "$1" in -a|--all)/--full)/-i|--interactive)/...`
#   loop -> 4 short+long flag pairs + positional <id> [-f
#   <filename>] sub-flag pairs.
# Reference accessed: 2026-05-30 via gh api.
# R182 — Appium environment-validation + git-tree-pruning +
# orphaned-blob-recovery pivot.  appium-doctor validates the
# Appium test environment (iOS/Android SDKs, Xcode, JDK, etc.);
# git-bonsai is the Rust TUI git-branch pruner ("tend the
# branches of your git garden"); git-recover is Edward
# Thomson's BFG-style orphaned-blob-recovery tool for
# undeleting files lost outside of git's reachable graph.

case $service in

  appium-doctor)
    # 7 yargs .boolean()/.describe() declarations decoded
    # source-direct.  Default fallback when no flag set: enable
    # --ios on macOS + --android always (from .check() arm).
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--ios[check iOS setup (default on macOS)]' \
      '--android[check Android setup (default)]' \
      '--dev[check dev setup]' \
      '--debug[show debug messages]' \
      '(--no)--yes[always respond yes to prompts]' \
      '(--yes)--no[always respond no to prompts]' \
      '--demo[run appium-doctor demo (for dev)]'
    ;;

  git-bonsai)
    # 1 clap-derive arg pair decoded source-direct from
    # src/cliargs.rs CliArgs struct.
    _arguments -s -S \
      '(-l --log)'{-l+,--log=}'[path to log file]:file:_files' \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '(-V --version)'{-V,--version}'[print version and exit]'
    ;;

  git-recover)
    # 4 top-level case-arm flags decoded source-direct from
    # the `case "$1" in -a|--all)...` loop.  Plus positional
    # <id> tokens that can be followed by -f/--filename sub-flag
    # to specify the output filename (and apply gitattributes
    # filters like CRLF conversion / Git-LFS).
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '(-a --all)'{-a,--all}'[write all orphaned blobs to cwd named by their object IDs]' \
      '(-i --interactive)'{-i,--interactive}'[interactively prompt to recover each orphaned blob]' \
      '--full[examine packfiles too (slow; default = loose objects only)]' \
      '*: <id> [-f filename] [<id> [-f filename] ...]:'
    ;;

esac
