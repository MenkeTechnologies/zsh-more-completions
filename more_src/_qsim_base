#compdef qsim_base
# Documentation: https://quantumai.google/qsim/usage
# qsim full state-vector circuit simulator

local ret=1

_arguments -s -S \
  '-c[circuit file to run]:circuit file:_files' \
  '-d[maximum time]:maxtime' \
  '-t[number of threads to use]:num threads' \
  '-f[maximum fused gate size]:max fused size' \
  '-v[verbosity level (0,1,2,3,4,5)]:verbosity' \
  '-z[set flush-to-zero and denormals-are-zeros MXCSR flags]' && ret=0

return ret
