#compdef ksysguard6 plasma-systemmonitor
# _ksysguard6 — KDE Plasma 6 ksysguard6 plasma-systemmonitor CLI Qt6 KDE system performance monitor showing live CPU memory IO network sensor curves process table per-PID resource usage tabs configurable views for the KDE Plasma desktop replacing ksysguard5 (KDE team, C++); Qt argparse
# upstream: https://invent.kde.org/plasma/plasma-systemmonitor

_ksysguard6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-p+[page id]:str:' \
        '--page=+[page]:str:' \
        '--help-all[show all options]' \
        '--help-qt[show Qt options]' \
        '--help-kde[show KDE options]' \
        '*:sensor:'
}

_ksysguard6 "$@"
