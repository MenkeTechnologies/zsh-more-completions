#compdef biscuit
# _biscuit — create/attenuate/inspect Biscuit auth tokens (biscuit-auth/biscuit-cli)
# upstream: https://github.com/biscuit-auth/biscuit-cli
# Subcommands from src/cli.rs (clap derive SubCommand).

_biscuit() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                keypair:'create and manipulate key pairs'
                inspect:'inspect a biscuit token (optionally verify signature)'
                inspect-snapshot:'inspect a biscuit snapshot'
                generate:'generate a biscuit from a private key and authority block'
                attenuate:'append a block to a biscuit token'
                generate-third-party-block-request:'generate a third-party block request'
                generate-third-party-block:'generate a third-party block'
                append-third-party-block:'append a third-party block to a token'
                seal:'seal a biscuit (no further attenuation)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                keypair)
                    _arguments \
                        '--from-private-key=[generate from given private key]:key:' \
                        '--from-file=[generate from private key file (- for stdin)]:file:_files' \
                        '--from-format=[private key input format]:format:(hex raw)' \
                        '--from-algorithm=[private key algorithm (raw input only)]:algo:(ed25519 secp256r1)' \
                        '--key-algorithm=[key algorithm for new keypair]:algo:(ed25519 secp256r1)' \
                        '--key-output-format=[public/private key output format]:format:(hex raw)' \
                        '--only-public-key[only output the public key]' \
                        '--only-private-key[only output the private key]' ;;
                generate)
                    _arguments \
                        '--root-key-id=[hint for public key selection]:id:' \
                        '--raw[output raw bytes without base64]' \
                        '--context=[context string for the authority block]:ctx:' \
                        '--add-ttl=[add TTL check (timestamp or duration)]:ttl:' \
                        '--private-key=[root private key]:key:' \
                        '--private-key-file=[root private key file]:file:_files' \
                        '*--param=[datalog parameter k=v]:kv:' \
                        '1:datalog authority file (- for stdin):_files' ;;
                attenuate)
                    _arguments \
                        '--raw-input[input is raw bytes (no base64)]' \
                        '--raw[output raw bytes]' \
                        '--add-ttl=[add TTL check]:ttl:' \
                        '--context=[context string for the new block]:ctx:' \
                        '--block-file=[block file (- for stdin)]:file:_files' \
                        '1:biscuit file:_files' ;;
                inspect|inspect-snapshot)
                    _arguments \
                        '--raw-input[input is raw bytes (no base64)]' \
                        '--public-key=[root public key (verifies signature)]:key:' \
                        '--public-key-file=[root public key file]:file:_files' \
                        '--verify-interactive[open EDITOR to enter datalog policy]' \
                        '--verify-with=[datalog file with verification policies]:file:_files' \
                        '--json[emit JSON output]' \
                        '1:biscuit file:_files' ;;
                seal)
                    _arguments \
                        '--raw-input[input is raw bytes]' \
                        '--raw[output raw bytes]' \
                        '1:biscuit file:_files' ;;
            esac
            ;;
    esac
}

_biscuit "$@"
