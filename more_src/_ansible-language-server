#compdef ansible-language-server
# Documentation: https://github.com/ansible/ansible-language-server
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Ansible Language Server — packages/ansible-language-server/src/cli.ts

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(--version)'--version'[print package version]' \
  '(--generate-docs)'--generate-docs'[write settings docs]:markdown file:_files' \
  '(--stdio)'--stdio'[language server over stdio (vscode-languageserver)]' \
  '(--node-ipc)'--node-ipc'[Node IPC transport]' \
  '(--socket)'--socket'[listen port or pipe name]' \
  '(--clientProcessId)'--clientProcessId'[embedding editor PID]' \
  '*::args:_normal' && ret=0

return ret
