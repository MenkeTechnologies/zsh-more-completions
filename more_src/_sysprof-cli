#compdef sysprof-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--aid=[instrument aid to use]:aid' \
  '--no-battery[disable battery profiling]' \
  '--no-cpu[disable CPU profiling]' \
  '--no-disk[disable disk profiling]' \
  '--no-memory[disable memory profiling]' \
  '--no-network[disable network profiling]' \
  '--duration=[duration of capture in seconds]:seconds' \
  '--power-profile=[power profile to use during capture]:profile' \
  '--env=[set environment variable]:VAR=VALUE' \
  '--pid=[attach to existing process]:pid:_pids' \
  '--command=[command to profile]:command:_command_names' \
  '1:output file:_files -g "*.syscap"' && ret=0

return ret
