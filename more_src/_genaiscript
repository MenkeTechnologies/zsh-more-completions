#compdef genaiscript
# Documentation: https://microsoft.github.io/genaiscript/reference/cli/commands/
# Reference accessed: 2026-05-21
# Verified: upstream CLI command reference at the URL above.

# Zsh completion for genaiscript - Microsoft scripting framework for LLMs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'genaiscript command' \
      'configure[set up LLM providers and GitHub Actions]' \
      'run[execute a script against files]' \
      'runs[manage previous script executions]' \
      'test[run evaluations and tests]' \
      'convert[process files through scripts]' \
      'scripts[manage script utilities]' \
      'cache[handle caching operations]' \
      'video[process video/audio files]' \
      'retrieval[RAG indexing and searching]' \
      'serve[start local web server]' \
      'mcp[launch Model Context Protocol server]' \
      'webapi[deploy REST API server]' \
      'parse[data conversion and analysis]' \
      'info[system and configuration details]' \
      'models[model management]' && ret=0
    ;;
  args)
    case $line[1] in
      configure)
        _values 'configure subcmd' llm action && ret=0
        ;;
      runs)
        _values 'runs subcmd' list && ret=0
        ;;
      test)
        _values 'test subcmd' run list view && ret=0
        ;;
      scripts)
        _values 'scripts subcmd' list create fix compile model help && ret=0
        ;;
      cache)
        _values 'cache subcmd' clear && ret=0
        ;;
      video)
        _values 'video subcmd' probe extract-audio extract-frames && ret=0
        ;;
      retrieval)
        _values 'retrieval subcmd' index vector fuzz && ret=0
        ;;
      parse)
        _values 'parse subcmd' \
          data fence pdf docx html tokens tokenize jsonl2json prompty jinja2 secrets markdown && ret=0
        ;;
      info)
        _values 'info subcmd' help system env && ret=0
        ;;
      models)
        _values 'models subcmd' list alias && ret=0
        ;;
    esac
    ;;
esac

return ret
