#compdef reproject_image
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/reproject_image.html
# Project image from one WCS to another

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[the input image(s)]:file:_files' \
  'matchfile=[the reference image]:file:_files' \
  'outfile=[the output file name]:file:_files' \
  'resolution=[number of points per side of polygon]:resolution:' \
  'method=[method for regridding the pixels]:method:(sum average)' \
  'coord_sys=[coordinate system to do the pixel mapping in]:coord_sys:(world physical)' \
  'lookupTab=[the header merging table]:file:_files' \
  'clobber=[remove output if it exists]:clobber:(yes no)' \
  'verbose=[the tool chatter level]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
