#compdef gpstop

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d=[coordinator data directory]:dir:_files -/' \
  '-B=[parallel processes]:n:' \
  '-M=[shutdown mode]:mode:(smart fast immediate)' \
  '-t=[timeout seconds]:secs:' \
  '-r[restart after shutdown]' \
  '-y[do not stop standby coordinator]' \
  '-a[do not prompt for confirmation]' \
  '-l=[log directory]:dir:_files -/' \
  '-m[stop a coordinator started in maintenance mode]' \
  '-u[reload pg_hba.conf and postgresql.conf without shutdown]' \
  '--host=[stop segments on a specific host]:host:_hosts' \
  '-v[verbose]' \
  '-q[quiet]'
