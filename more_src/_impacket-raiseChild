#compdef impacket-raiseChild
# Documentation: https://github.com/fortra/impacket/blob/master/examples/raiseChild.py
# Privilege escalation from a child domain up to its forest

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-ts[adds timestamp to every logging output]' \
  '-debug[turn DEBUG output ON]' \
  '-w=[writes the golden ticket in CCache format into the specified file]:file:_files' \
  '-target-exec=[target host for PSEXEC execution after the attack completes]:address' \
  '-targetRID=[target user RID to dump credentials; Administrator (500) by default]:rid' \
  '-hashes=[NTLM hashes, format is LMHASH:NTHASH]:hashes' \
  '-no-pass[don'\''t ask for password (useful for -k)]' \
  '-k[use Kerberos authentication from ccache file]' \
  '-aesKey=[AES key to use for Kerberos authentication (128 or 256 bits)]:hexkey' \
  '1:target (domain/username\[:password\]):' && ret=0

return ret
