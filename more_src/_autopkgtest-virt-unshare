#compdef autopkgtest-virt-unshare
# _autopkgtest-virt-unshare — unshare virtualisation backend for autopkgtest
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-virt-unshare(1) man page.

_autopkgtest-virt-unshare() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[enable debugging output]' \
        '(-a --arch)'{-a+,--arch=}'[dpkg architecture]:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '*'{-b+,--bind=}'[bind-mount OUTSIDE INSIDE]:outside-inside:' \
        '--bootstrapcmd=[alternative chroot bootstrap command]:cmd:' \
        '(-p --prefix)'{-p+,--prefix=}'[mkdtemp prefix]:prefix:' \
        '(-m --mirror)'{-m+,--mirror=}'[debootstrap mirror]:url:' \
        '(-r --release)'{-r+,--release=}'[distribution release]:release:'
}

_autopkgtest-virt-unshare "$@"
