#compdef artemis-cli

# artemis-cli: ActiveMQ Artemis broker management CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'help:show help'
  'producer:produce messages'
  'consumer:consume messages'
  'browser:browse messages'
  'address:manage addresses'
  'queue:manage queues'
  'data:data tools (export, import)'
  'transfer:transfer messages'
  'check:run a check'
  'create:create a broker instance'
  'run:run a standalone broker'
  'stop:stop a broker'
  'kill:kill a broker'
  'mask:mask a password'
  'shell:open management shell'
  'version:show version'
  'completion:emit shell completion'
  'perf-(journal,producer,consumer):perf testing helpers'
  'pwd:check broker pwd'
  'upgrade:upgrade broker instance'
  'user:manage broker users'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--silent[no console output]' \
  '--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'artemis-cli command' commands && ret=0 ;;
esac
return ret
