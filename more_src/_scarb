#compdef scarb
# Documentation: https://docs.swmansion.com/scarb
# Reference accessed: 2026-05-21
# Verified: subcommands confirmed via scarb docs (init, add, build, fmt,
# test, check, update, doc, execute, prove, verify). Other subcommands
# and global flags exist but a comprehensive published flag table is
# not available; conservative completion retained.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add dependencies to Scarb.toml'
  'build:compile current project'
  'check:analyze without producing Sierra'
  'clean:remove generated artifacts'
  'doc:generate package documentation'
  'execute:execute Cairo program'
  'fmt:format project files'
  'init:create new package in current dir'
  'new:create new package at PATH'
  'prove:produce Cairo execution proof'
  'remove:remove dependencies'
  'rm:remove dependencies (alias)'
  'run:run package scripts'
  'test:run tests'
  'update:update dependencies'
  'verify:verify Cairo execution proof'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'scarb subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (init|new)
        _arguments \
          '--name=[package name]:name:' \
          ':path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
