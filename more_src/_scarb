#compdef scarb

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add:add dependencies to Scarb.toml'
  'remove:remove dependencies'
  'rm:remove dependencies (alias)'
  'list:list available registry versions'
  'build:compile current project'
  'expand:expand macros'
  'cache:manipulate packages cache'
  'check:analyze without producing Sierra'
  'clean:remove generated artifacts'
  'completions:generate shell completions'
  'commands:list installed commands'
  'fetch:fetch dependencies from network'
  'fmt:format project files'
  'init:create new package in current dir'
  'manifest-path:print path to Scarb.toml'
  'metadata:output resolved deps'
  'new:create new package at PATH'
  'tree:display dependency tree'
  'package:assemble distributable tarball'
  'proc-macro-server:start proc macro server'
  'publish:upload package to registry'
  'lint:lint Cairo code'
  'run:run package scripts'
  'test:run tests'
  'update:update dependencies'
)

_arguments -C \
  '--manifest-path=[Scarb.toml path]:file:_files -g "*.toml"' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--json[NDJSON output]' \
  '--offline[no network]' \
  '--global-cache-dir=[cache dir]:dir:_files -/' \
  '--global-config-dir=[config dir]:dir:_files -/' \
  '--target-dir=[target dir]:dir:_files -/' \
  '--no-proc-macros[disable proc macros]' \
  '--no-prebuilt-proc-macros[disable prebuilt proc macros]' \
  '--profile=[profile name]:profile:' \
  '--release[release profile]' \
  '--dev[dev profile]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'scarb subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (completions)
        _values 'shell' 'bash' 'zsh' 'fish' 'elvish' 'powershell' && ret=0
        ;;
      (new|init)
        _arguments \
          '--name=[package name]:name:' \
          ':path:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
