#compdef cargo-equip
# _cargo-equip — bundle a Rust crate into a single .rs file for competitive programming (qryxip/cargo-equip)
# upstream: https://github.com/qryxip/cargo-equip
# Run as `cargo equip [OPTIONS]`; flags from src/lib.rs (structopt).

_cargo-equip() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    # cargo invokes this as `cargo-equip equip [opts...]`; honor both.
    _arguments -C \
        '1: :(equip)' \
        '*::equip args:->equip' && ret=0

    case $state in
        equip)
            local -a args
            args=(
                '--src=[bundle the lib/bin/example target containing PATH]:file:_files -g "*.rs"'
                '--lib[bundle the library target]'
                '--bin=[bundle the named binary target]:bin:'
                '--example=[bundle the named example target]:example:'
                '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"'
                '*--exclude=[exclude a library crate from bundling]:spec:'
                '--exclude-atcoder-crates[exclude crates available on AtCoder]'
                '--exclude-atcoder-202301-crates[exclude crates available on AtCoder 202301]'
                '--exclude-codingame-crates[exclude crates available on CodinGame]'
                '--no-license-and-copyright-notices[do not include license / copyright notices]'
                '--toolchain-for-udeps=[nightly toolchain for cargo-udeps]:toolchain:'
                '--toolchain-for-proc-macros=[toolchain for expanding procedural macros]:toolchain:'
                '--mod-path=[module path to expand libraries into (default crate::__cargo_equip)]:path:'
                '--remove=[parts of the output to remove]:parts:(docs comments)'
                '--minify=[output minification level]:level:(none libs all)'
                '--no-resolve-cfgs[do not resolve cfg(...) attributes]'
                '--no-rustfmt[do not format the output]'
                '--no-check[do not type-check the output before emitting]'
                '(-o --output)'{-o+,--output=}'[write to FILE instead of stdout]:file:_files'
                '(- *)'{-h,--help}'[show help]'
                '(- *)'{-V,--version}'[show version]'
            )
            _arguments -s -S $args && ret=0 ;;
    esac

    return ret
}

_cargo-equip "$@"
