#compdef hab
# Documentation: https://docs.chef.io/habitat/2.0/reference/habitat_cli/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bldr:commands relating to Habitat Builder'
  'cli:commands relating to Habitat runtime config'
  'config:commands relating to a Service runtime config'
  'file:commands relating to Habitat files'
  'license:license agreement management'
  'origin:commands for managing Builder origins'
  'pkg:commands for working with Habitat packages'
  'plan:commands relating to plans and app-specific configuration'
  'ring:commands relating to Habitat rings'
  'studio:Habitat Studio commands'
  'sup:the Habitat Supervisor'
  'supportbundle:create a support tarball of Supervisor data'
  'svc:commands relating to Habitat Services'
  'user:commands relating to Habitat users'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hab subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (bldr)
        _values 'bldr action' 'channel' 'job' && ret=0
        ;;
      (cli)
        _values 'cli action' 'completers' 'setup' && ret=0
        ;;
      (config)
        _values 'config action' 'apply' 'show' && ret=0
        ;;
      (file)
        _values 'file action' 'upload' && ret=0
        ;;
      (origin)
        _values 'origin action' 'create' 'delete' 'depart' 'info' 'invitations' 'key' 'rbac' 'transfer' && ret=0
        ;;
      (pkg)
        _values 'pkg action' \
          'binds' 'binlink' 'build' 'bulk-upload' 'channels' 'config' \
          'delete' 'demote' 'dependencies' 'download' 'env' 'exec' \
          'export' 'hash' 'header' 'info' 'install' 'list' 'path' \
          'promote' 'provides' 'search' 'sign' 'uninstall' 'upload' 'verify' && ret=0
        ;;
      (plan)
        _values 'plan action' 'init' 'render' && ret=0
        ;;
      (ring)
        _values 'ring action' 'key' && ret=0
        ;;
      (sup)
        _values 'sup action' 'bash' 'depart' 'restart' 'secret' 'sh' 'run' 'term' && ret=0
        ;;
      (svc)
        _values 'svc action' 'key' 'load' 'start' 'status' 'stop' 'unload' 'update' && ret=0
        ;;
      (user)
        _values 'user action' 'key' && ret=0
        ;;
    esac
    ;;
esac

return ret
