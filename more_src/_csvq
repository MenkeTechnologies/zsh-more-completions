#compdef csvq
# Documentation: https://mithrandie.github.io/csvq/reference/command.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# csvq: SQL-like query language for CSV files (mithrandie/csvq).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-r+[repository directory]:directory:_directories' \
  '--repository=[repository directory]:directory:_directories' \
  '-s+[load statements from file]:source file:_files' \
  '--source=[load statements from file]:source file:_files' \
  '-d+[input field delimiter]:delimiter' \
  '--delimiter=[input field delimiter]:delimiter' \
  '--delimiter-positions=[fixed-length field positions]:positions' \
  '--allow-uneven-fields[allow uneven field counts]' \
  '-D+[output field delimiter]:delimiter' \
  '--write-delimiter=[output field delimiter]:delimiter' \
  '--write-delimiter-positions=[fixed-length output positions]:positions' \
  '-e+[input file encoding]:encoding:(UTF8 UTF8M UTF16 UTF16BE UTF16LE UTF16BEM UTF16LEM SJIS)' \
  '--encoding=[input file encoding]:encoding:(UTF8 UTF8M UTF16 UTF16BE UTF16LE UTF16BEM UTF16LEM SJIS)' \
  '-E+[output file encoding]:encoding:(UTF8 UTF8M UTF16BE UTF16LE UTF16BEM UTF16LEM SJIS)' \
  '--write-encoding=[output file encoding]:encoding:(UTF8 UTF8M UTF16BE UTF16LE UTF16BEM UTF16LEM SJIS)' \
  '-i+[input import format]:format:(CSV TSV FIXED JSON JSONL LTSV)' \
  '--import-format=[input import format]:format:(CSV TSV FIXED JSON JSONL LTSV)' \
  '--timezone=[time-zone]:timezone' \
  '-n[treat first line as data (no header)]' \
  '--no-header[treat first line as data (no header)]' \
  '--without-null[treat empty fields as empty strings]' \
  '-f+[output format]:format:(CSV TSV FIXED JSON JSONL LTSV GFM ORG BOX TEXT)' \
  '--format=[output format]:format:(CSV TSV FIXED JSON JSONL LTSV GFM ORG BOX TEXT)' \
  '-w[write output to file]' \
  '--write-to-file[write output to file]' \
  '--out=[output file path]:output file:_files' \
  '-q[suppress logs]' \
  '--quiet[suppress logs]' \
  '--color[use ANSI colors]' \
  '--no-color[disable colors]' \
  '--strip-ending-line-break[strip trailing line break]' \
  '--pretty-print[pretty-print JSON output]' \
  '--cpu=[number of CPU cores]:cpu count' \
  '--stats[show execution time]' \
  '--wait-timeout=[lock wait timeout (seconds)]:seconds' \
  '--limit-recursion=[max recursion depth]:n' \
  '--datetime-format=[datetime format string]:format' \
  '--strict-equal[require strict type equality]' \
  '1:command or query:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'fields:show field names of a file'
      'calc:evaluate an expression for each stdin line'
      'syntax:show language syntax'
      'check-update:check for newer versions'
      'help:show command help'
    )
    _describe -t commands 'csvq command' commands
    ;;
esac

return ret
