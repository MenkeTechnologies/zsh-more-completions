#compdef csvq

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-r+[repository directory]:directory:_directories' \
  '--repository=[repository directory]:directory:_directories' \
  '-s+[source file]:source file:_files' \
  '--source=[source file]:source file:_files' \
  '-d+[delimiter]:delimiter' \
  '--delimiter=[delimiter]:delimiter' \
  '-D+[delimiter for output]:delimiter' \
  '--write-delimiter=[delimiter for output]:delimiter' \
  '-e+[file encoding]:encoding:(UTF8 SJIS)' \
  '--encoding=[file encoding]:encoding:(UTF8 SJIS)' \
  '-E+[encoding for output]:encoding:(UTF8 SJIS)' \
  '--write-encoding=[encoding for output]:encoding:(UTF8 SJIS)' \
  '--timezone=[timezone]:timezone' \
  '-n[without header line]' \
  '--no-header[without header line]' \
  '-f+[output format]:format:(TEXT CSV TSV JSON LTSV GFM ORG BOX)' \
  '--format=[output format]:format:(TEXT CSV TSV JSON LTSV GFM ORG BOX)' \
  '-w[write output to file]' \
  '--write-to-file[write output to file]' \
  '--out=[output file]:output file:_files' \
  '-q[suppress logs]' \
  '--quiet[suppress logs]' \
  '--color[use colors]' \
  '--no-color[disable colors]' \
  '--strip-ending-line-break[strip ending line break]' \
  '--cpu=[number of CPUs]:cpu count' \
  '--stats[show execution time]' \
  '1:command or query:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'fields:show fields in file'
      'calc:evaluate expression'
      'syntax:show syntax'
    )
    _describe -t commands 'csvq command' commands
    ;;
esac

return ret
