#compdef maas-cli
# Documentation: https://man.archlinux.org/search?q=maas-cli
# Reference accessed: 2026-05-16

# maas-cli: legacy MAAS CLI wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[print debug tracebacks]' \
  '*::maas-cli args:_files' && ret=0
return ret
