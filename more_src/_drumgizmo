#compdef drumgizmo
# Documentation: https://manpages.debian.org/testing/drumgizmo/drumgizmo.1.en.html
# DrumGizmo command-line drum sampler engine

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print command line help and exit]' \
  '(-v --version)'{-v,--version}'[print drumgizmo version and exit]' \
  '(-a --async_load)'{-a,--async_load}'[load kit in the background]' \
  '(-b --bleed)'{-b,--bleed}'[set and enable master bleed]:bleed' \
  '(-i --inputengine)'{-i,--inputengine}'[input engine]:engine:(dummy test jackmidi midifile)' \
  '(-I --inputparms)'{-I,--inputparms}'[parameters for the input engine]:parms' \
  '(-o --outputengine)'{-o,--outputengine}'[audio output engine]:engine:(dummy alsa jackaudio wavfile oss)' \
  '(-O --outputparms)'{-O,--outputparms}'[parameters for the output engine]:parms' \
  '(-e --endpos)'{-e,--endpos}'[number of samples to process (default -1: infinite)]:samples' \
  '(-r --no-resampling)'{-r,--no-resampling}'[disable resampling]' \
  '(-s --streaming)'{-s,--streaming}'[enable diskstreaming]' \
  '(-S --streamingparms)'{-S,--streamingparms}'[parameters for the streaming buffers]:parms' \
  '(-t --timing-humanizer)'{-t,--timing-humanizer}'[enable moving of notes in time]' \
  '(-T --timing-humanizerparms)'{-T,--timing-humanizerparms}'[timing humanizer parameters]:parms' \
  '(-l --voice-limit)'{-l,--voice-limit}'[enable voice limit]' \
  '(-L --voice-limitparms)'{-L,--voice-limitparms}'[voice limit parameters]:parms' \
  '(-p --parameters)'{-p,--parameters}'[parameters for the sample selection algorithm]:parms' \
  '*:drumkit file:_files -g "*.xml"' && ret=0

return ret
