#compdef obspy-runtests
# Documentation: https://docs.obspy.org/
# ObsPy: run the ObsPy test suite

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--no-report[skip submitting results to the report server]' \
  '--report[submit results to the report server]' \
  '--cov=[generate test coverage metrics]:package' \
  '--network[execute only network-dependent tests]' \
  '--all[run both network and non-network tests]' \
  '--keep-images[preserve test-generated images]' \
  '--pdb[enter debugger on test failures]' \
  '*:test target:' && ret=0

return ret
