#compdef pplx perplexity

_pplx() {
    local line state
    local -a commands
    commands=(
        'search:Standard web search'
        'research:Deep research mode'
        'code:Programming and debugging help'
        'academic:Scholarly and peer-reviewed sources'
        'history:View recent query history'
        'help:Show help menu'
        'chat:Start interactive chat'
        'config:Manage configuration'
    )

    _arguments -C \
        '(-m --model)'{-m,--model}'[Specify model]:model:(sonar-pro sonar-reasoning)' \
        '(-v --version)'{-v,--version}'[Display version]' \
        '(-u --usage)'{-u,--usage}'[Show token usage statistics]' \
        '(-c --citations)'{-c,--citations}'[Show source citations]' \
        '(-g --glow)'{-g,--glow}'[Use Glow-compatible formatting]' \
        '1: :->command' \
        '*:query:'

    case $state in
        command)
            _describe -t commands 'pplx command' commands
            ;;
    esac
}

_pplx "$@"
