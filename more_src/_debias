#compdef debias
# Documentation: http://www.starlink.ac.uk/docs/sun139.htx/sun139.html
# CCDPACK: Debias a list of CCD images

local ret=1

_arguments -s -S \
  'IN=[input images to be debiassed]:in:_files' \
  'OUT=[output debiassed images]:out:_files' \
  'BIAS=[bias calibration image]:bias:_files' \
  'BOUNDS=[bias strip bounds]:bounds:' \
  'RNOISE=[readout noise in ADUs]:rnoise:' \
  'ADC=[analogue-to-digital conversion factor]:adc:' \
  'MASK=[bad pixel mask]:mask:_files' \
  'BADBITS=[bad-bits mask value]:badbits:' \
  'BOXSIZE=[smoothing box size]:boxsize:' \
  'CMODE=[bias interpolation mode]:cmode:' \
  'DEFERRED=[deferred charge value]:deferred:' \
  'DIRECTION=[readout direction]:direction:(X Y)' \
  'EXPAND=[expand bias before subtraction]:expand:(TRUE FALSE)' \
  'EXTENT=[useful CCD area extent]:extent:' \
  'FIXORIGIN=[fix output NDF origin]:fixorigin:(TRUE FALSE)' \
  'FMODE=[bias fitting mode]:fmode:' \
  'GENVAR=[generate variances]:genvar:(TRUE FALSE)' \
  'GETBIAS=[subtract a bias image]:getbias:(TRUE FALSE)' \
  'GETMASK=[apply a bad pixel mask]:getmask:(TRUE FALSE)' \
  'KEEPIN=[retain input NDFs]:keepin:(TRUE FALSE)' \
  'LOGFILE=[log file name]:logfile:_files' \
  'LOGTO=[where to write log information]:logto:(TERMINAL LOGFILE BOTH NEITHER)' \
  'NSIGMA=[sigma clipping level]:nsigma:' \
  'OFFSET=[offset bias to match data]:offset:(TRUE FALSE)' \
  'PRESERVE=[preserve input data type]:preserve:(TRUE FALSE)' \
  'SATURATE=[apply saturation processing]:saturate:(TRUE FALSE)' \
  'SATURATION=[saturation value]:saturation:' \
  'SETBAD=[set saturated pixels bad]:setbad:(TRUE FALSE)' \
  'SETSAT=[flag saturated pixels]:setsat:(TRUE FALSE)' \
  'SMODE=[saturation handling mode]:smode:' \
  'TITLE=[output NDF title]:title:' \
  'USECON=[use a constant bias]:usecon:(TRUE FALSE)' \
  'USEEXT=[read parameters from NDF extension]:useext:(TRUE FALSE)' \
  'USESET=[use Set header grouping]:useset:(TRUE FALSE)' \
  'WMODE=[bias strip combination mode]:wmode:' \
  'ZERO=[zero the mean output level]:zero:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
