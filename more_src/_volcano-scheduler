#compdef volcano-scheduler vc-scheduler
# _volcano-scheduler — Volcano batch scheduler (PodGroup-aware gang scheduler for HPC/AI workloads)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/scheduler/app/options/options.go on tip.

_volcano-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[k8s API server address (overrides kubeconfig)]:url:_urls' \
        '--kubeconfig=[kubeconfig file path]:file:_files' \
        '--ca-cert-file=[x509 CA cert for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--lock-object-namespace=[leader-election lock object namespace]:ns:' \
        '--scheduler-conf=[absolute path to scheduler configuration file]:file:_files' \
        '--schedule-period=[period between each scheduling cycle]:dur:' \
        '--resync-period=[default informer resync period]:dur:' \
        '--default-queue=[default queue name for jobs]:name:' \
        '--version[show version and exit]' \
        '--listen-address=[HTTP request listen address]:addr:' \
        '--healthz-address=[health check server listen address]:addr:' \
        '--priority-class[enable PriorityClass support]' \
        '--kube-api-qps=[QPS to k8s apiserver]:n:' \
        '--kube-api-burst=[burst to k8s apiserver]:n:' \
        '--plugins-dir=[directory of custom scheduler plugins to load]:dir:_files -/' \
        '--csi-storage[enable CSI storage]' \
        '--enable-healthz[enable health check endpoint]' \
        '--enable-metrics[enable metrics endpoint]' \
        '--enable-pprof[enable pprof endpoint]' \
        '--cache-dumper[enable cache dumper]' \
        '--cache-dump-dir=[dir for cache dump JSON files]:dir:_files -/' \
        '--gate-removal-worker-num=[async workers for scheduling-gate removal]:n:' \
        '--resource-sync-timeout=[wait timeout for initial resource sync]:dur:' \
        '--disable-default-scheduler-config[do not fall back to default config when provided one is invalid]' \
        '--scheduler-sharding-mode=[node sharding mode]:mode:(none hard soft)' \
        '--scheduler-sharding-name=[shard name for this scheduler]:name:' \
        '--log-flush-frequency=[max seconds between log flushes]:dur:'
}

_volcano-scheduler "$@"
