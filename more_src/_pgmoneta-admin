#compdef pgmoneta-admin
# _pgmoneta-admin — manage pgmoneta users/master-key (pgmoneta/pgmoneta)
# upstream: https://github.com/pgmoneta/pgmoneta
# Flags from src/admin.c (getopt_long via cli_option table).

_pgmoneta-admin() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-U --user)'{-U+,--user=}'[username]:user:' \
        '(-P --password)'{-P+,--password=}'[password]:pass:' \
        '(-f --file)'{-f+,--file=}'[users file]:file:_files' \
        '(-g --generate)'{-g,--generate}'[generate password]' \
        '(-l --length)'{-l+,--length=}'[generated password length]:n:' \
        '(-F --format)'{-F+,--format=}'[file format]:fmt:(plaintext md5 scram-sha-256)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'master-key:generate/update master key'
                'user:user-management commands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                user) _arguments '1:subcommand:(add edit del ls)' ;;
            esac
            ;;
    esac
}

_pgmoneta-admin "$@"
