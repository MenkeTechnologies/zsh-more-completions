#compdef cargo-build-sbf cargo-build-bpf cargo-test-sbf cargo-test-bpf

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '--sbf-out-dir=[output directory for SBF program]:directory:_directories' \
  '--sbf-sdk=[path to Solana SBF SDK]:directory:_directories' \
  '--arch=[target architecture]:arch:(sbfv1 sbfv2)' \
  '--dump[dump ELF details after build]' \
  '--features=[features to activate]:features' \
  '--no-default-features[disable default features]' \
  '--generate-child-script-on-failure[generate failure script]' \
  '--tools-version=[platform tools version]:version' \
  '--workspace[build all workspace members]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-p+[specific package]:package' \
  '--package=[specific package]:package' \
  '*:extra cargo arguments' && ret=0

return ret
