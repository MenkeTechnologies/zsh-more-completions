#compdef kail

# Zsh completion for kail (Kubernetes log tailer)

_arguments -s -S \
  '(-l --label)'{-l,--label}'[label selector]:label:' \
  '(-p --pod)'{-p,--pod}'[pod name]:pod:' \
  '(-c --container)'{-c,--container}'[container name]:container:' \
  '(-n --ns)'{-n,--ns}'[namespace]:namespace:' \
  '--svc[service name]:service:' \
  '--rc[replication controller]:rc:' \
  '--rs[replica set]:rs:' \
  '--ds[daemon set]:ds:' \
  '-d[deployment name]:deployment:' \
  '--deploy[deployment name]:deployment:' \
  '--sts[stateful set]:sts:' \
  '--job[job name]:job:' \
  '--node[node name]:node:' \
  '--ing[ingress name]:ingress:' \
  '--context[kubernetes context]:context:' \
  '--current-ns[use current namespace]' \
  '--ignore[patterns to ignore]:pattern:' \
  '--since[show logs since duration]:duration:' \
  '--output[output format]:format:(default json zero)' \
  '--log-file[log file]:file:_files' \
  '--log-level[log level]:level:(debug info warn error)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
