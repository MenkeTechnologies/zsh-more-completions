#compdef gq graphqurl
# Documentation: https://github.com/hasura/graphqurl
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --query)'{-q,--query}'=[GraphQL query string]:query:' \
  '*'{-H,--header}'+[request header name\:value]:header:' \
  '*--variable+[query variable key=value]:pair:' \
  '--variablesJSON=[variables as JSON string]:json:' \
  '--queryFile=[read query from file]:file:_files' \
  '--operationName=[operation name in query file]:name:' \
  '--variablesFile=[read variables from JSON file]:file:_files' \
  '-l[single-line unformatted output]' \
  '--single-line[single-line unformatted output]' \
  '--introspect[introspect schema]' \
  '--format=[introspection output format]:format:(json graphql)' \
  '1:endpoint url: _default'
