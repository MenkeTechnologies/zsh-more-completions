#compdef cobaya-grid-extract
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: extract files matching extensions from a grid

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--normalize_names[replace actual name tags with normalized names]' \
  '*--tag_replacements=[XX YY replaces name XX with YY]:replacement' \
  '1:grid directory:_files -/' \
  '2:target directory:_files -/' \
  '*:file extension:' && ret=0

return ret
