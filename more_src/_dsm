#compdef dsm
# Documentation: https://man.archlinux.org/search?q=dsm
# Reference accessed: 2026-05-16
# Source: cargo binstall dsm@1.0.2
# Probed via: completions zsh
# Repository: https://github.com/Yakiyo/dsm

autoload -U is-at-least

_dsm() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'-V[Print version information]' \
'--version[Print version information]' \
'--no-colors[Disable colors in output]' \
":: :_dsm_commands" \
"*::: :->dsm" \
&& ret=0
    case $state in
    (dsm)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dsm-command-$line[1]:"
        case $line[1] in
            (install)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':version -- The version to install:' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':version -- The version to uninstall:' \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-s[Remain silent if the current version is the same as the one to be used]' \
'--silent-if-unchanged[Remain silent if the current version is the same as the one to be used]' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':version -- The version to use:' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
&& ret=0
;;
(env)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':shell -- The shell syntax to use:(bash zsh fish powershell)' \
&& ret=0
;;
(current)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
&& ret=0
;;
(alias)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':version:' \
':name:' \
&& ret=0
;;
(unalias)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':alias:' \
&& ret=0
;;
(self)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--no-colors[Disable colors in output]' \
':shell:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'--arch=[The architecture to use. Defaults to the system arch]:ARCH:(arm arm64 x64 ia32)' \
'--dsm-dir=[Dsm directory. Defaults to `~/.dsm`]:DSM_DIR: ' \
'--no-colors[Disable colors in output]' \
'*::subcommand -- The subcommand whose help message to display:' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_dsm_commands] )) ||
_dsm_commands() {
    local commands; commands=(
'install:Install a specific version of the Dart SDK' \
'uninstall:Uninstall a specific version of the Dart SDK' \
'use:Change Dart SDK version' \
'list:List all installed versions' \
'ls:List all installed versions' \
'env:Print required environment variables for dsm' \
'current:Prints the current version in use' \
'alias:Create an alias to an existing version' \
'unalias:Create an alias to an existing version' \
'self:Check for new versions of the app' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'dsm commands' commands "$@"
}
(( $+functions[_dsm__alias_commands] )) ||
_dsm__alias_commands() {
    local commands; commands=()
    _describe -t commands 'dsm alias commands' commands "$@"
}
(( $+functions[_dsm__completions_commands] )) ||
_dsm__completions_commands() {
