#compdef pdnsd
# _pdnsd — Paul Rombouts pdnsd CLI proxy DNS server with permanent caching designed for nomadic systems mobile networks slow uplink-aware DNS-cache disk-persistent positive negative TTL configurable upstream-resolver-rotation IPv4 IPv6 EDNS DNSSEC validating-resolver query routing (Paul Rombouts team, C); getopt
# upstream: https://github.com/erikkay/pdnsd

_pdnsd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[daemonize]' \
        '--daemon[daemonize]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config-file=+[file]:file:_files -g "*.conf"' \
        '-s+[cache dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '-p+[pid file]:file:_files' \
        '--pid-file=+[file]:file:_files' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-g+[group]:_groups' \
        '--group=+[group]:_groups' \
        '-q[no warnings]' \
        '--quiet[no warnings]' \
        '-mxg[no ipv6]' \
        '-mxog[no ipv4]' \
        '-v+[verbosity]:l:(0 1 2 3 4 5)' \
        '-r+[run as]:str:' \
        '-G[grab connect-port for dnsproxy]' \
        '-t+[check config and exit]:str:' \
        '-S+[init source]:str:' \
        '*::'
}

_pdnsd "$@"
