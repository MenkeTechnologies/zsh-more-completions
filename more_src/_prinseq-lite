#compdef prinseq-lite prinseq-lite.pl
# Documentation: https://github.com/uwb-linux/prinseq
# filter, reformat and trim FASTA/FASTQ sequence data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-fastq[input FASTQ file]:fastq:_files' \
  '-fasta[input FASTA file]:fasta:_files' \
  '-out_format[output format]:format:(1 2 3 4 5)' \
  '-out_good[output file prefix for good sequences]:prefix:' \
  '-out_bad[output file prefix for bad sequences]:prefix:' \
  '-trim_left[remove bases from left side]:n:' \
  '-trim_right[remove bases from right side]:n:' \
  '-trim_left_p[remove percentage of bases from left]:pct:' \
  '-trim_right_p[remove percentage of bases from right]:pct:' \
  '-trim_qual_left[trim left until quality threshold]:qual:' \
  '-trim_qual_right[trim right until quality threshold]:qual:' \
  '-trim_tail_left[remove trailing low-quality from left]:n:' \
  '-trim_tail_right[remove trailing low-quality from right]:n:' \
  '-trim_ns_left[remove Ns from left end]:n:' \
  '-trim_ns_right[remove Ns from right end]:n:' \
  '-trim_to_len[trim sequences to specific length]:len:' \
  '-min_len[filter sequences below minimum length]:len:' \
  '-max_len[filter sequences above maximum length]:len:' \
  '-range_len[keep sequences within length range]:range:' \
  '-min_qual_score[filter below minimum quality score]:score:' \
  '-max_qual_score[filter above maximum quality score]:score:' \
  '-min_qual_mean[filter below mean quality threshold]:mean:' \
  '-max_qual_mean[filter above mean quality threshold]:mean:' \
  '-min_gc[filter below GC percentage]:gc:' \
  '-max_gc[filter above GC percentage]:gc:' \
  '-range_gc[keep sequences within GC range]:range:' \
  '-ns_max_p[maximum N percentage allowed]:pct:' \
  '-ns_max_n[maximum N count allowed]:n:' \
  '-noniupac[remove non-IUPAC characters]' \
  '-lc_method[low-complexity filter method]:method:(dust entropy)' \
  '-derep[remove duplicate sequences]:type:' \
  '-seq_id[custom sequence identifiers]:id:' \
  '-seq_case[adjust letter case]:case:(upper lower)' \
  '-dna_rna[convert between DNA/RNA]:type:(dna rna)' && ret=0

return ret
