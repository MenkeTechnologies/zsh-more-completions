#compdef automap
# Documentation: https://github.com/pyrocko/pyrocko/blob/master/src/apps/automap.py
# pyrocko: create a simple map with topography

local ret=1

_arguments -s -S \
  '--width=[width of output image]:width' \
  '--height=[height of output image]:height' \
  '--topo-resolution-min=[minimum topography resolution]:res' \
  '--topo-resolution-max=[maximum topography resolution]:res' \
  '--no-grid[do not show grid lines]' \
  '--no-topo[do not show topography]' \
  '--no-cities[do not show cities]' \
  '--no-illuminate[deactivate artificial illumination of topography]' \
  '--illuminate-factor-land=[factor for artificial illumination of land]:factor' \
  '--illuminate-factor-ocean=[factor for artificial illumination of ocean]:factor' \
  '--theme=[select color theme]:theme:(topo soft)' \
  '--download-etopo1[download full ETOPO1 topography dataset]' \
  '--download-srtmgl3[download full SRTMGL3 topography dataset]' \
  '--make-decimated-topo[pre-make all decimated topography datasets]' \
  '--stations=[load station coordinates from file]:file:_files' \
  '--events=[load event coordinates from file]:file:_files' \
  '--debug[print debugging information to stderr]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:arg' && ret=0

return ret
