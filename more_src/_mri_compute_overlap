#compdef mri_compute_overlap
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_compute_overlap
# Compute label overlap (Dice) between two segmentation volumes

local ret=1

_arguments -s -S \
  '-a[compute overlap of all labels]' \
  '-s[show label name for segmentation]' \
  '-l[filename to write results to]:fname:_files' \
  '-h[print help]' \
  '*:volume:_files' && ret=0

return ret
