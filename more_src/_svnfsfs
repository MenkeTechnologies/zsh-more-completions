#compdef svnfsfs
# Documentation: none found (Subversion 1.9+ ships svnfsfs; upstream HTML reference missing).
# Reference accessed: 2026-05-21
# Verified: subcommand names (dump-index, load-index, stats) confirmed via `svnfsfs help` shipped with Subversion.
# STUB: cannot confidently enumerate per-subcommand flags without official HTML/man source.

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
    'dump-index:Dump FSFS index for a revision'
    'load-index:Load FSFS index'
    'stats:Report FSFS repository statistics'
    'help:Show help'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args' && ret=0

case $state in
    subcmd)
        _describe -t subcommands 'svnfsfs subcommand' subcommands && ret=0
        ;;
    args)
        _arguments '*:repository path:_files' && ret=0
        ;;
esac

return ret
