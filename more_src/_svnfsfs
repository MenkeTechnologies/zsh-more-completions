#compdef svnfsfs

local -a subcommands
subcommands=(
    'dump-index:Dump FSFS index for a revision'
    'help:Show help'
    'load-index:Load FSFS index'
    'stats:Report FSFS repository statistics'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svnfsfs subcommand' subcommands
        ;;
    args)
        _arguments \
            '-r[Revision]:revision' \
            '--revision[Revision]:revision' \
            '-M[Memory cache size in MB]:megabytes' \
            '--memory-cache-size[Memory cache size in MB]:megabytes' \
            '-q[Quiet mode]' \
            '--quiet[Quiet mode]' \
            '*:repository path:_files'
        ;;
esac
