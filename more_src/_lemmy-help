#compdef lemmy-help

# Lemmy markdown generator — LemmyHelp rust CLI used for Lemmy docs (`lemmy-help --help`).

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-i,--input}"=[Rust source root]:dir:_files -/" \
  {-o,--output}"=[Markdown output]:file:_files" \
  '--crate=[crate name filter]:crate' && ret=0

return ret
