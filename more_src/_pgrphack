#compdef pgrphack
# _pgrphack — daemontools-encore pgrphack (run a child in its own process group via setpgid; insulates a daemontools-managed service from terminal-signal propagation)
# upstream: https://github.com/schmonz/daemontools-encore
# Source: pgrphack.8 on tip; positional only.

_pgrphack() {
    _arguments '*::child:_command_names -e'
}

_pgrphack "$@"
