#compdef tcatest

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'write:write records'
  'read:read records'
  'remove:remove records'
  'rcat:concatenated record write'
  'misc:miscellaneous tests'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tcatest subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '1:database name:_files' \
      '2::record number:' && ret=0
    ;;
esac

return ret
