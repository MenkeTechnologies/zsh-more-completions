#compdef cave

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:perform package configuration'
  'contents:list contents of an installed package'
  'display-resolution:display a resolution'
  'dump-cave-formats-conf:dump format conf'
  'execute-resolution:execute a resolution'
  'find-candidates:find candidate packages'
  'fix-cache:fix the cache'
  'fix-linkage:fix broken linkage'
  'generate-metadata:generate metadata cache'
  'graph-jobs:produce a graphviz graph of jobs'
  'has-version:check if version available'
  'help:show help'
  'import:import a package'
  'info:show environment info'
  'manage-search-index:manage search index'
  'match:check a spec matches'
  'mirror:fetch package source files'
  'owner:find package owning a path'
  'perform:perform an action (low-level)'
  'print-best-version:print best version'
  'print-categories:print category names'
  'print-checksum:print SHA256/etc checksum'
  'print-checksum-algorithms:print supported checksum algorithms'
  'print-commands:print available commands'
  'print-dependent-ids:print dependent IDs'
  'print-environment-metadata:print environment metadata'
  'print-id-actions:print actions for an ID'
  'print-id-contents:print contents of an installed ID'
  'print-id-environment-variable:print env var for an ID'
  'print-id-executables:print executables of an installed ID'
  'print-id-masks:print masks affecting an ID'
  'print-id-metadata:print metadata of an ID'
  'print-id-size:print size of an installed ID'
  'print-ids:print package IDs'
  'print-owners:print owners of a path'
  'print-packages:print package names'
  'print-repositories:print repositories'
  'print-repository-formats:print repository formats'
  'print-repository-keys:print repository keys'
  'print-repository-metadata:print repository metadata'
  'print-resolution-required-confirmations:print required confirmations'
  'print-set:print packages in a set'
  'print-sets:print available sets'
  'print-spec:print parsed spec'
  'print-sync-protocols:print supported sync protocols'
  'print-unmanaged-files:print unmanaged files'
  'print-unused-distfiles:print unused distfiles'
  'purge:remove unused packages'
  'report:report errors'
  'resolve:resolve dependencies'
  'resume:resume a previous resolution'
  'search:search for packages'
  'show:show information about a package'
  'size-of-download:report download size of resolution'
  'sync:sync repositories'
  'sync-protocol-options:show sync protocol options'
  'uninstall:uninstall packages'
  'update-world:update the world set'
  'verify:verify installed packages'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-E+[environment]:env:' \
  '--log-level=[log level]:level:(debug qa warning silent)' \
  '--no-colour[disable colour]' \
  '--colour[force colour]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cave command' commands && ret=0 ;;
esac

return ret
