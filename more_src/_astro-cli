#compdef astro
# _astro-cli — Astro multi-framework SSG/SSR CLI (Fred K. Schott, The Astro Technology Company); islands-architecture web framework
# upstream: https://github.com/withastro/astro

_astro-cli() {
    local -a sub=(
        'dev:run dev server'
        'build:build production'
        'preview:preview built site'
        'sync:generate content-collection types'
        'add:add an integration'
        'remove:remove an integration'
        'check:run type/content/diagnostic checks'
        'docs:open Astro docs'
        'info:print env info'
        'login:login to Astro Studio'
        'logout:logout'
        'link:link Astro Studio db'
        'create-key:create encryption key'
        'preferences:manage CLI preferences'
        'telemetry:telemetry opt-in/out'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'astro subcommand' sub ;;
        args)
            case $words[1] in
                dev|preview) _arguments \
                    '--host+[host]:host:_hosts' \
                    '--port+[port]:port:' \
                    '--open[open browser]' \
                    '--config+[config file]:file:_files' \
                    '--root+[project root]:dir:_files -/' \
                    '--mode+[runtime mode]:mode:(development production test)' ;;
                build) _arguments \
                    '--config+[config file]:file:_files' \
                    '--root+[project root]:dir:_files -/' \
                    '--mode+[runtime mode]:mode:(development production test)' \
                    '--devOutput[allow dev output]' ;;
                check) _arguments \
                    '--watch[watch and re-check]' \
                    '--config+[config file]:file:_files' \
                    '--root+[project root]:dir:_files -/' \
                    '--tsconfig+[tsconfig]:file:_files' \
                    '--noSync[skip sync]' \
                    '--minimumFailingSeverity+[threshold]:lvl:(error warning hint)' \
                    '--minimumSeverity+[threshold]:lvl:(error warning hint)' \
                    '--preserveWatchOutput[preserve watch output]' ;;
                add|remove) _arguments '*:integration:(react preact vue svelte solid lit alpinejs mdx tailwind tailwindcss vercel netlify cloudflare node deno markdoc partytown sitemap robotstxt prefetch image)' ;;
                sync) _arguments '--config+[config file]:file:_files' ;;
                telemetry) _arguments '1:action:(enable disable status)' ;;
            esac
            ;;
    esac
}

_astro-cli "$@"
