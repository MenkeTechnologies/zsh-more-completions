#compdef CollectMultipleMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectMultipleMetrics
# Picard: run multiple metrics-collection modules in a single pass over a BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[base name for output files]:basename:' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--METRIC_ACCUMULATION_LEVEL=[level at which to accumulate metrics]:level:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '--FILE_EXTENSION=[file extension appended to metric output files]:ext:' \
  '*--PROGRAM=[metrics program to apply]:program:(CollectAlignmentSummaryMetrics CollectInsertSizeMetrics QualityScoreDistribution MeanQualityByCycle CollectBaseDistributionByCycle CollectGcBiasMetrics RnaSeqMetrics CollectSequencingArtifactMetrics CollectQualityYieldMetrics)' \
  '--INTERVALS=[optional interval restriction list]:interval_list:_files -g "*.interval_list"' \
  '--DB_SNP=[dbSNP file for polymorphism regions]:vcf:_files -g "*.(vcf|vcf.gz)"' \
  '--INCLUDE_UNPAIRED=[include unpaired reads in artifact metrics]:bool:(true false)' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
