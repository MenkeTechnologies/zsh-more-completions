#compdef check_http
# Documentation: https://www.monitoring-plugins.org/doc/man/check_http.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Nagios monitoring-plugins: HTTP/HTTPS server probe with content and SSL checks

_arguments -s \
  '(-H --hostname)'{-H,--hostname}'=[host name]:host:_hosts' \
  '(-I --IP-address)'{-I,--IP-address}'=[IP address]:addr:' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '(-4 --use-ipv4)'{-4,--use-ipv4}'[use IPv4]' \
  '(-6 --use-ipv6)'{-6,--use-ipv6}'[use IPv6]' \
  '(-S --ssl)'{-S,--ssl}'=[use SSL/TLS, optional version]:version:' \
  '--sni[use SNI]' \
  '(-C --certificate)'{-C,--certificate}'=[cert age check]:days:' \
  '(-J --client-cert)'{-J,--client-cert}'=[client cert]:file:_files' \
  '(-K --private-key)'{-K,--private-key}'=[private key]:file:_files' \
  '--continue-after-certificate[continue after cert check]' \
  '(-e --expect)'{-e,--expect}'=[expected status]:status:' \
  '(-d --header-string)'{-d,--header-string}'=[header substring]:str:' \
  '(-s --string)'{-s,--string}'=[content substring]:str:' \
  '(-u --url)'{-u,--url}'=[URL]:url:' \
  '(-P --post)'{-P,--post}'=[POST data]:data:' \
  '(-j --method)'{-j,--method}'=[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS CONNECT TRACE PATCH PROPFIND)' \
  '(-N --no-body)'{-N,--no-body}'[do not wait for body]' \
  '(-M --max-age)'{-M,--max-age}'=[max age]:duration:' \
  '(-T --content-type)'{-T,--content-type}'=[content type]:type:' \
  '(-l --linespan)'{-l,--linespan}'[allow regex span lines]' \
  '(-r --regex)'{-r,--regex}'=[regex]:regex:' \
  '(-R --eregi)'{-R,--eregi}'=[case insensitive regex]:regex:' \
  '--invert-regex[invert regex match]' \
  '(-a --authorization)'{-a,--authorization}'=[user:pass]:cred:' \
  '(-b --proxy-authorization)'{-b,--proxy-authorization}'=[proxy user:pass]:cred:' \
  '(-A --useragent)'{-A,--useragent}'=[user agent]:ua:' \
  '*'{-k,--header}'=[extra header]:header:' \
  '(-L --link)'{-L,--link}'[link to graph in output]' \
  '(-f --onredirect)'{-f,--onredirect}'=[on redirect]:action:(ok warning critical follow sticky stickyport)' \
  '--max-redirs=[max redirects]:n:' \
  '(-m --pagesize)'{-m,--pagesize}'=[min:max bytes]:range:' \
  '(-t --timeout)'{-t,--timeout}'=[timeout]:s:' \
  '(-E --extended-perfdata)'{-E,--extended-perfdata}'[extended perf data]' \
  '(-B --show-body)'{-B,--show-body}'[show body in output]' \
  '--state-regex=[state regex]:regex:' \
  '--extra-opts=[extra opts]:section:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --warning)'{-w,--warning}'=[warning threshold]:threshold:' \
  '(-c --critical)'{-c,--critical}'=[critical threshold]:threshold:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
