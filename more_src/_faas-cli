#compdef faas-cli

_faas-cli_commands() {
  local -a commands=(
    'build:Build OpenFaaS function containers'
    'deploy:Deploy OpenFaaS functions'
    'push:Push OpenFaaS function containers'
    'remove:Remove deployed OpenFaaS functions'
    'invoke:Invoke an OpenFaaS function'
    'list:List OpenFaaS functions'
    'login:Log in to an OpenFaaS gateway'
    'logout:Log out from an OpenFaaS gateway'
    'new:Create a new function from a template'
    'up:Build, push and deploy in one command'
    'store:Browse and deploy functions from the store'
    'secret:Manage secrets'
    'logs:Fetch function logs'
    'describe:Describe an OpenFaaS function'
    'auth:Obtain a token for authentication'
    'template:Manage templates'
    'namespace:Manage namespaces'
    'registry-login:Generate registry auth file'
    'version:Display version information'
    'help:Show help'
  )
  _describe -t commands 'faas-cli command' commands
}

_faas-cli() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-g --gateway)'{-g,--gateway}'[Gateway URL]:url:' \
    '--tls-no-verify[Disable TLS verification]' \
    '--token[Authentication token]:token:' \
    '1:command:_faas-cli_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        build|push|deploy|up)
          _arguments \
            '(-f --yaml)'{-f,--yaml}'[YAML file for function definition]:file:_files -g "*.y(a|)ml"' \
            '--filter[Wildcard to match function names]:filter:' \
            '--tag[Override image tag]:tag:(latest sha branch-sha describe)' \
            '--no-cache[Do not use Docker cache]' \
            '--parallel[Build in parallel]:count:' \
            '--build-arg[Set a build arg]:arg:' \
            '--handler[Directory with handler]:dir:_directories' \
            '--image[Docker image name]:image:' \
            '--lang[Programming language template]:lang:' \
            '--name[Name of the function]:name:' \
            '--regex[Regex to match function names]:regex:'
          ;;
        invoke)
          _arguments \
            '(-f --yaml)'{-f,--yaml}'[YAML file]:file:_files -g "*.y(a|)ml"' \
            '--content-type[Content type]:type:' \
            '--async[Invoke asynchronously]' \
            '--query[Query string parameters]:params:' \
            '--header[HTTP headers]:header:' \
            '1:function name:'
          ;;
        new)
          _arguments \
            '--lang[Programming language template]:lang:' \
            '--list[List available templates]' \
            '--prefix[Docker image prefix]:prefix:' \
            '--gateway[Gateway URL]:url:' \
            '--handler[Handler directory]:dir:_directories' \
            '--append[Append to existing YAML file]:file:_files' \
            '1:function name:'
          ;;
        login)
          _arguments \
            '(-u --username)'{-u,--username}'[Username]:user:' \
            '(-p --password)'{-p,--password}'[Password]:pass:' \
            '--password-stdin[Read password from stdin]' \
            '(-g --gateway)'{-g,--gateway}'[Gateway URL]:url:'
          ;;
        store)
          local -a subcommands=(
            'list:List store functions'
            'deploy:Deploy a store function'
            'inspect:Inspect a store function'
          )
          _describe -t subcommands 'store subcommand' subcommands
          ;;
        template)
          local -a subcommands=(
            'pull:Pull templates'
            'store:Browse template store'
          )
          _describe -t subcommands 'template subcommand' subcommands
          ;;
        secret)
          local -a subcommands=(
            'create:Create a secret'
            'list:List secrets'
            'remove:Remove a secret'
            'update:Update a secret'
          )
          _describe -t subcommands 'secret subcommand' subcommands
          ;;
        list|remove)
          _arguments \
            '(-f --yaml)'{-f,--yaml}'[YAML file]:file:_files -g "*.y(a|)ml"' \
            '(-n --namespace)'{-n,--namespace}'[Namespace]:namespace:'
          ;;
      esac
      ;;
  esac
}

_faas-cli "$@"
