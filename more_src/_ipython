#compdef ipython ipython3
# Documentation: IPython source IPython/terminal/ipapp.py + IPython core docs
# Source: IPython — interactive Python shell.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'profile:create / list / locate profiles'
    'locate:print IPython directory or profile path'
    'history:trim / clear / list history'
    'kernel:run an IPython kernel'
    'install-nbextension:install a Jupyter notebook extension'
)

_arguments -s -C \
    '-i[force interactive after running script]' \
    '-c+[execute string then exit]:cmd:' \
    '-m+[run module as a script]:module:' \
    '--pylab=[pylab GUI matplotlib backend]:backend:(auto gtk gtk3 inline notebook nbagg ipympl osx qt qt4 qt5 qt6 tk wx)' \
    '--matplotlib=[matplotlib GUI backend]:backend:(auto gtk gtk3 inline notebook nbagg ipympl osx qt qt4 qt5 qt6 tk wx)' \
    '(--banner --no-banner)--banner[show startup banner]' \
    '(--banner --no-banner)--no-banner[hide startup banner]' \
    '(--confirm-exit --no-confirm-exit)--confirm-exit[prompt on exit]' \
    '(--confirm-exit --no-confirm-exit)--no-confirm-exit[no exit prompt]' \
    '(--tip --no-tip)--tip[show tips at startup]' \
    '(--tip --no-tip)--no-tip[no startup tips]' \
    '(--term-title --no-term-title)--term-title[set terminal title]' \
    '(--term-title --no-term-title)--no-term-title[no terminal title]' \
    '--term-title-format=[terminal title format]:fmt:' \
    '(--autoedit-syntax --no-autoedit-syntax)--autoedit-syntax[auto-launch editor on SyntaxError]' \
    '(--autoedit-syntax --no-autoedit-syntax)--no-autoedit-syntax[disable autoedit]' \
    '(--simple-prompt --no-simple-prompt)--simple-prompt[plain text prompts (e.g. for emacs)]' \
    '(--simple-prompt --no-simple-prompt)--no-simple-prompt[disable plain prompts]' \
    '--classic[classic >>> prompt mode]' \
    '--quick[skip startup files]' \
    '--pdb[automatic post-mortem debugging]' \
    '--autoindent[enable auto-indent]' \
    '--no-autoindent[disable auto-indent]' \
    '--automagic[allow magic without %]' \
    '--no-automagic[require %magic]' \
    '--autocall=[autocall mode (0=off, 1=smart, 2=full)]:mode:(0 1 2)' \
    '--colors=[color scheme]:scheme:(NoColor Neutral LightBG Linux)' \
    '--xmode=[exception mode]:mode:(Plain Context Verbose Minimal)' \
    '--logfile=[log file path]:file:_files' \
    '--logappend=[append-only log file]:file:_files' \
    '--profile=[profile to use]:profile:' \
    '--profile-dir=[explicit profile directory]:dir:_files -/' \
    '--ipython-dir=[IPython home directory]:dir:_files -/' \
    '--ClassName=*[set configurable trait (Class.attr=value)]:Class.attr=value:' \
    '(- *)--help[show help and exit]' \
    '(- *)--help-all[show full help and exit]' \
    '(- *)--version[show version and exit]' \
    '1: :->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        _alternative \
            'verbs:subcommand:_describe -t ipython-verbs "ipython subcommand" verbs' \
            'files:script:_files -g "*.{py,ipy,ipynb}"' \
            && ret=0
        ;;
    args)
        _files && ret=0
        ;;
esac

return ret
