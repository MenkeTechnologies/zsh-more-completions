#compdef linkcheck

# Zsh completion for linkcheck - dead link checker

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output except errors]' \
  '--version[show version]' \
  '(-r --recursive)'{-r,--recursive}'[recursively check links]' \
  '--max-depth=[maximum recursion depth]:depth' \
  '--timeout=[request timeout in seconds]:seconds' \
  '--retry=[number of retries for failed requests]:count' \
  '--delay=[delay between requests in milliseconds]:ms' \
  '--concurrency=[number of concurrent requests]:number' \
  '--user-agent=[custom user agent string]:agent' \
  '--accept=[comma-separated list of accepted status codes]:codes' \
  '--exclude=[regex pattern for URLs to exclude]:pattern' \
  '--include=[regex pattern for URLs to include]:pattern' \
  '--skip-tls-verification[skip TLS certificate verification]' \
  '--no-color[disable colored output]' \
  '--json[output results as JSON]' \
  '--markdown[check links in markdown files]' \
  '--html[check links in HTML files]' \
  '(-o --output)'{-o,--output}'=[write results to file]:file:_files' \
  '--config=[path to config file]:file:_files' \
  '*:file or URL:_files' \
  && return 0
