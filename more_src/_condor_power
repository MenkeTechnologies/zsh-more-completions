#compdef condor_power
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_power.html
# send a Wake On LAN power-on packet to a machine

local ret=1

_arguments -s -S \
  '-h[print usage information and exit]' \
  '-d[enable debugging messages]' \
  '-i[read a ClassAd piped in through standard input]' \
  '-m[specify the MAC address]:MACaddress' \
  '-s[specify the subnet as an IPv4 address mask]:subnet' && ret=0

return ret
