#compdef pass
# _pass — passwordstore.org pass (UNIX password manager: one GPG-encrypted file per password, optional git store; subcommands init/insert/edit/generate/rm/mv/cp/show/grep/find/git/help/version; -c copies to clipboard for 45s, -m multiline, -f force, --no-symbols for generate)
# upstream: https://git.zx2c4.com/password-store
# Subcommands from password-store src/password-store.sh on tip.

_pass() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'pass command' \
                '(init ls show find search grep insert edit generate rm mv cp git otp help version)'
            ;;
        args)
            case $line[1] in
                generate) _arguments \
                    '-n[no symbols]' \
                    '--no-symbols[no symbols]' \
                    '-c[copy to clipboard]' \
                    '--clip[copy to clipboard]' \
                    '-f[force overwrite]' \
                    '--force[force overwrite]' \
                    '-i[in-place: replace first line only]' \
                    '--in-place[in-place]' \
                    '1:pass name:' '2:length:' ;;
                insert) _arguments \
                    '-e[no echo]' \
                    '-m[multiline]' \
                    '-f[force overwrite]' \
                    '1:pass name:' ;;
                show) _arguments \
                    '-c[copy to clipboard]' \
                    '--clip[copy to clipboard]' \
                    '-q[qr code]' \
                    '--qrcode[qr code]' \
                    '1:pass name:' ;;
                mv|cp) _arguments \
                    '-f[force overwrite]' \
                    '1:source:' '2:dest:' ;;
                rm) _arguments \
                    '-r[recursive]' \
                    '-f[force]' \
                    '1:pass name:' ;;
                edit) _arguments '1:pass name:' ;;
                find|search) _arguments '*:term:' ;;
                init) _arguments '-p+[subfolder path]:path:' '*:gpg-id:' ;;
                git) _arguments '*:git args:' ;;
                otp) _describe -t commands 'otp subcommand' '(code insert append uri validate)' ;;
            esac
            ;;
    esac
}

_pass "$@"
