#compdef suamp
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suamp.c
# output amp, phase, real or imag trace from

local ret=1

_arguments -s -S \
  'mode=[mode]:mode:' \
  'jack=[jack]:jack:' \
  'unwrap=[unwrap]:unwrap:' \
  'trend=[trend]:trend:' \
  'zeromean=[zeromean]:zeromean:' \
  'smooth=[smooth]:smooth:' \
  'r=[r]:r:' \
  'op=[op]:op:' \
  '*:file:_files' && ret=0

return ret
