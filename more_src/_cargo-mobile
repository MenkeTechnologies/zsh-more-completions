#compdef cargo-mobile cargo-mobile2

# Zsh completion for cargo-mobile - scaffold Rust mobile applications

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generate a new mobile project'
  'open:open project in the default IDE'
  'update:update the cargo-mobile template'
  'android:android specific commands'
  'ios:iOS specific commands'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--non-interactive[skip interactive prompts]' \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '--color[when to use colored output]:color:(auto always never)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'cargo-mobile command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments \
          '--open[open in IDE after init]' \
          '--template-pack[template pack to use]:pack:' && ret=0
        ;;
      android)
        local -a android_commands=(
          'open:open in Android Studio'
          'check:check for issues without building'
          'build:build APK'
          'run:build and run on device'
          'st:stacktrace'
          'list:list devices'
        )
        _describe -t android-commands 'android command' android_commands
        ;;
      ios)
        local -a ios_commands=(
          'open:open in Xcode'
          'check:check for issues without building'
          'build:build the app'
          'archive:archive the app'
          'run:build and run on device or simulator'
          'pod:run CocoaPods'
          'list:list devices'
        )
        _describe -t ios-commands 'ios command' ios_commands
        ;;
    esac
    ;;
esac

return ret
