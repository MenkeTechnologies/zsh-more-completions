#compdef fixelconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelconvert.html
# Source: MRtrix3/mrtrix3 cmd/fixelconvert.cpp — convert between old/new fixel storage formats (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-name+[name for the value field (default "value", no extension)]:string:_default' \
    '-nii[output index/directions/data as NIfTI instead of .mif]' \
    '-out_size[also output the size field from old format]' \
    '-template+[existing fixel directory in new format to conform to]:dir:_files -/' \
    '-value+[file to import to the value field in old format]:file:_files' \
    '-in_size+[file to import for the size field in old format]:file:_files' \
    '1:fixel_in:_files' \
    '2:fixel_out:_files' \
    && ret=0

return ret
