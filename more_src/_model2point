#compdef model2point
# Documentation: https://bio3d.colorado.edu/imod/doc/man/model2point.html
# Convert model file to point file

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-input -inp -InputFile)'{-input,-inp,-InputFile}'[Input model file. If this option is not entered, the first...]:file:_files' \
  '(-output -ou -OutputFile)'{-output,-ou,-OutputFile}'[Output text file for points. If this option is not entered,...]:file:_files' \
  '(-float -fl -FloatingPoint)'{-float,-fl,-FloatingPoint}'[Output model coordinates as floating point; otherwise the...]' \
  '(-integer -int -IntegerOutput)'{-integer,-int,-IntegerOutput}'[Output model coordinates by taking the nearest integer...]' \
  '(-scaled -sc -ScaledCoordinates)'{-scaled,-sc,-ScaledCoordinates}'[Output coordinates in the model coordinate system, scaled...]' \
  '(-object -ob -ObjectAndContour)'{-object,-ob,-ObjectAndContour}'[Output object and contour numbers for each point (numbered...]' \
  '(-contour -c -Contour)'{-contour,-c,-Contour}'[Output contour number for each point (numbered from 1)]' \
  '(-zero -ze -NumberedFromZero)'{-zero,-ze,-NumberedFromZero}'[Output object and contour numbers starting from 0 instead...]' \
  '(-zcoord -zc -ZCoordinatesFromZero)'{-zcoord,-zc,-ZCoordinatesFromZero}'[Output Z coordinates that are 0 instead of -0.5 at the...]' \
  '(-sizes -si -PointSizes)'{-sizes,-si,-PointSizes}'[Output the point sizes for individual points, placing them...]' \
  '(-times -t -TimesForContours)'{-times,-t,-TimesForContours}'[Output a time index for each contour, on the first line for...]' \
  '(-values -v -ValuesInLastColumn)'{-values,-v,-ValuesInLastColumn}'[Enter 1 to output general point values as the last number on]:value' \
  '(-fill -fi -FillValue)'{-fill,-fi,-FillValue}'[Value to output when contour/point has no stored value...]:value' \
  '(-mesh -m -MeshVertexCoordinates)'{-mesh,-m,-MeshVertexCoordinates}'[Output mesh vertex coordinates instead of contours points;...]:value' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
