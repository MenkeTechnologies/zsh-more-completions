#compdef ttx
# _ttx — Just van Rossum fonttools ttx CLI for converting between TrueType/OpenType TTF/OTF binary fonts and ttx XML textual format with per-table dump and round-trip compilation (fonttools team, Python); argparse
# upstream: https://github.com/fonttools/fonttools

_ttx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[output dir]:dir:_files -/' \
        '-o+[output file]:file:_files -g "*.ttx *.ttf *.otf *.woff *.woff2"' \
        '-f[overwrite]' \
        '-l[list table info]' \
        '-t+[table tag]:t:(BASE CBDT CBLC CFF CFF2 COLR CPAL DSIG EBDT EBLC EBSC FFTM GDEF GPOS GSUB GVAR HVAR JSTF LTSH MATH MERG META MVAR OS/2 PCLT POST SING STAT SVG TSI0 TSI1 TSI2 TSI3 TSI5 TSIB TSID TSIJ TSIP TSIS TSIV VDMX VORG VVAR ankr avar bdat bhed bloc bsln cmap cvar cvt fdsc feat fpgm fvar gasp glyf gvar hdmx head hhea hmtx kern kerx lcar loca ltag maxp meta mort morx name opbd post prep prop sbix trak vhea vmtx)' \
        '-x+[exclude table tag]:str:' \
        '-s[split tables]' \
        '-g[split per glyph]' \
        '-i[ignore decompile errors]' \
        '-z+[bitmap glyph dir]:dir:_files -/' \
        '-y+[font number]:n:' \
        '-m+[merge file]:file:_files -g "*.ttx"' \
        '-b[disable recalculation of bounding boxes]' \
        '-e[don'\''t ignore decompilation errors]' \
        '--unicodedata=+[file]:file:_files' \
        '--newline=+[n]:n:(LF CR CRLF)' \
        '--no-recalc-timestamp[no recalc timestamp]' \
        '--flavor=+[f]:f:(woff woff2)' \
        '--with-zopfli[use zopfli]' \
        '*:font file:_files -g "*.ttf *.otf *.woff *.woff2 *.ttx *.ttc *.otc"'
}

_ttx "$@"
