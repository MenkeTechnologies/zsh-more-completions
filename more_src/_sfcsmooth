#compdef sfcsmooth
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mcsmooth.c
# Madagascar: multi-dimensional triangle smoothing for complex data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  '*rect=[smoothing radius on the n-th axis]:radius' \
  '*diff=[differentiation on the n-th axis]:flag:(y n)' \
  '*box=[box (rather than triangle) on the n-th axis]:flag:(y n)' \
  'repeat=[repeat filtering several times]:count' \
  'adj=[run in the adjoint mode]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
