#compdef daprd
# Documentation: https://man.archlinux.org/search?q=daprd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--app-id=[application identifier]:id:' \
  '--app-port=[application port]:port:' \
  '--app-protocol=[app protocol]:proto:(http grpc h2c https grpcs)' \
  '--app-channel-address=[app host or IP]:host:_hosts' \
  '--app-max-concurrency=[max concurrent app calls]:n:' \
  '--app-ssl[use HTTPS for app channel]' \
  '--allowed-origins=[allowed CORS origins]:list:' \
  '--config=[Dapr config file]:file:_files -g "*.yaml *.yml"' \
  '--components-path=[components dir]:dir:_files -/' \
  '--resources-path=[resources dir]:dir:_files -/' \
  '--control-plane-address=[Dapr control plane addr]:addr:' \
  '--dapr-grpc-port=[Dapr gRPC port]:port:' \
  '--dapr-http-port=[Dapr HTTP port]:port:' \
  '--dapr-internal-grpc-port=[internal gRPC port]:port:' \
  '--dapr-internal-grpc-listen-address=[internal gRPC listen addr]:addr:' \
  '--dapr-listen-addresses=[Dapr listen addresses csv]:list:' \
  '--dapr-public-port=[Dapr public port]:port:' \
  '--dapr-public-listen-address=[Dapr public listen addr]:addr:' \
  '--dapr-block-shutdown-duration=[block shutdown dur]:dur:' \
  '--dapr-block-shutdown-seconds=[block shutdown secs]:secs:' \
  '--dapr-graceful-shutdown-seconds=[graceful shutdown secs]:secs:' \
  '--dapr-http-max-request-size=[max request MB]:mb:' \
  '--dapr-http-read-buffer-size=[read buffer KB]:kb:' \
  '--enable-mtls[enable mTLS]' \
  '--enable-app-health-check[enable app health check]' \
  '--app-health-check-path=[health check path]:path:' \
  '--app-health-probe-interval=[probe interval]:secs:' \
  '--app-health-probe-timeout=[probe timeout ms]:ms:' \
  '--app-health-threshold=[unhealthy threshold]:n:' \
  '--enable-metrics[enable metrics]' \
  '--metrics-port=[metrics port]:port:' \
  '--enable-profiling[enable profiling]' \
  '--profile-port=[profile port]:port:' \
  '--enable-api-logging[enable API logging]' \
  '--log-level=[log level]:lvl:(debug info warn error fatal)' \
  '--log-as-json[JSON log output]' \
  '--mode=[mode]:m:(standalone kubernetes)' \
  '--placement-host-address=[placement service addr]:addr:' \
  '--scheduler-host-address=[scheduler service addr]:addr:' \
  '--sentry-address=[sentry service addr]:addr:' \
  '--trust-anchors=[trust anchors PEM]:pem:' \
  '--trust-domain=[trust domain]:domain:' \
  '--cert-chain=[cert chain]:cert:' \
  '--cert-key=[cert key]:key:' \
  '--unix-domain-socket=[unix domain socket dir]:dir:_files -/' \
  '--enabled-features=[features csv]:list:' \
  '--disable-builtin-k8s-secret-store[disable k8s secret store]' \
  '*--proto-only=[proto types csv]:list:' \
  '*--*' && ret=0

return ret
