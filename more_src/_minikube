#compdef minikube

# Zsh completion for minikube (local Kubernetes)

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'addons:Enable or disable a minikube addon'
  'cache:Manage cache for images'
  'completion:Generate command completion'
  'config:Modify persistent configuration values'
  'cp:Copy the specified file into minikube'
  'dashboard:Access the Kubernetes dashboard'
  'delete:Deletes a local Kubernetes cluster'
  'docker-env:Configure environment to use minikubes Docker daemon'
  'image:Manage images'
  'ip:Retrieves the IP address of the specified node'
  'kubectl:Run a kubectl binary matching the cluster version'
  'license:Outputs the licenses of dependencies'
  'logs:Returns logs to debug a local Kubernetes cluster'
  'mount:Mounts the specified directory into minikube'
  'node:Add, remove, or list additional nodes'
  'options:Show a list of global command-line options'
  'pause:Pause Kubernetes'
  'podman-env:Configure environment to use minikubes Podman service'
  'profile:Get or list the current profiles'
  'service:Returns a URL to connect to a service'
  'ssh:Log into the minikube environment via SSH'
  'ssh-host:Retrieve the ssh host key of the specified node'
  'ssh-key:Retrieve the ssh identity key path of the specified node'
  'start:Starts a local Kubernetes cluster'
  'status:Gets the status of a local Kubernetes cluster'
  'stop:Stops a running local Kubernetes cluster'
  'tunnel:Connect to LoadBalancer services'
  'unpause:Unpause Kubernetes'
  'update-check:Print current and latest version number'
  'update-context:Update kubeconfig in case of IP or port change'
  'version:Print the version of minikube'
)

_arguments -C \
  '--add_dir_header[If true, adds the file directory to header of log messages]' \
  '--alsologtostderr[Log to standard error as well as files]' \
  {-b,--bootstrapper}'=[The name of the cluster bootstrapper]:bootstrapper:(kubeadm)' \
  {-h,--help}'[Help for minikube]' \
  '--log_backtrace_at=[Log a stack trace at specified file\:N]:location:' \
  '--log_dir=[Write log files in this directory]:dir:_directories' \
  '--log_file=[Write to this log file]:file:_files' \
  '--logtostderr[Log to standard error]' \
  {-p,--profile}'=[The name of the minikube VM being used]:profile:' \
  '--stderrthreshold=[Logs at or above this threshold go to stderr]:threshold:' \
  '--user=[Specifies the user executing the operation]:user:' \
  {-v,--v}'=[Number for log level verbosity]:level:' \
  '--vmodule=[Comma-separated list of pattern=N settings]:settings:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'minikube command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      start)
        _arguments \
          '--addons=[Enable addons]:addons:' \
          '--apiserver-ips=[A set of apiserver IP addresses]:ips:' \
          '--apiserver-name=[The authoritative apiserver hostname]:name:' \
          '--apiserver-names=[A set of apiserver names]:names:' \
          '--apiserver-port=[The apiserver listening port]:port:' \
          '--auto-update-drivers[Auto-update drivers]' \
          '--base-image=[The base image to use for docker/podman drivers]:image:' \
          '--cache-images[Cache images from the container runtime]' \
          '--cni=[CNI plug-in to use]:cni:(auto bridge calico cilium flannel kindnet)' \
          '--container-runtime=[The container runtime to use]:runtime:(docker cri-o containerd)' \
          '--cpus=[Number of CPUs allocated to Kubernetes]:cpus:' \
          '--cri-socket=[The cri socket path to be used]:socket:' \
          '--delete-on-failure[Delete the cluster if start fails]' \
          '--disable-driver-mounts[Disables the filesystem mounts provided by the hypervisor]' \
          '--disk-size=[Disk size allocated to the minikube VM]:size:' \
          '--dns-domain=[The cluster DNS domain name]:domain:' \
          '--dns-proxy[Enable DNS proxy]' \
          '--docker-env=[Environment variables to pass to the Docker daemon]:env:' \
          '--docker-opt=[Specify arbitrary flags to the Docker daemon]:opt:' \
          '--download-only[Download without starting the cluster]' \
          '--driver=[Driver to use]:driver:(virtualbox vmwarefusion hyperv vmware docker podman ssh none)' \
          '--dry-run[Dry run mode]' \
          '--embed-certs[Embed certs in kubeconfig]' \
          '--enable-default-cni[DEPRECATED: Use --cni=bridge instead]' \
          '--extra-config=[A set of key=value pairs for Kubernetes components]:config:' \
          '--extra-disks=[Number of extra disks]:count:' \
          '--feature-gates=[A set of key=value pairs for Kubernetes feature gates]:gates:' \
          '--force[Force start even if safety checks fail]' \
          '--force-systemd[Use systemd cgroup manager]' \
          '--gpus=[Allow containers to use NVIDIA GPUs]:gpus:(all nvidia)' \
          '--ha[Create a highly available cluster with multiple control plane nodes]' \
          '--host-dns-resolver[Enable host DNS resolver]' \
          '--host-only-cidr=[The CIDR to be used for the host only network]:cidr:' \
          '--host-only-nic-type=[NIC type for host only network]:type:' \
          '--hyperkit-vpnkit-sock=[Location of the VPNKit socket]:path:_files' \
          '--hyperkit-vsock-ports=[Ports for guest to host vsock]:ports:' \
          '--hyperv-external-adapter=[External adapter on which external switch will be created]:adapter:' \
          '--hyperv-use-external-switch[Use external switch]' \
          '--hyperv-virtual-switch=[The name of the Hyper-V virtual switch]:switch:' \
          '--image-mirror-country=[Country code of image mirror]:country:' \
          '--image-repository=[Alternative image repository]:repo:' \
          '--insecure-registry=[Insecure Docker registries to pass to the Docker daemon]:registry:' \
          '--install-addons[Install default addons]' \
          '--interactive[Allow user prompts for more information]' \
          '--iso-url=[Locations to fetch the minikube ISO from]:url:' \
          '--keep-context[Keep the existing kubectl context]' \
          '--kubernetes-version=[The Kubernetes version]:version:' \
          '--kvm-gpu[Enable GPU passthrough in KVM]' \
          '--kvm-hidden[Hide KVM hypervisor from the guest]' \
          '--kvm-network=[The KVM default network name]:network:' \
          '--kvm-numa-count=[Number of NUMA nodes]:count:' \
          '--kvm-qemu-uri=[The KVM QEMU connection URI]:uri:' \
          '--listen-address=[IP address to use]:address:' \
          '--memory=[Amount of RAM allocated]:memory:' \
          '--mount[Start the mount daemon]' \
          '--mount-9p-version=[Mount 9p version]:version:(9p2000 9p2000.u 9p2000.L)' \
          '--mount-gid=[Mount GID]:gid:' \
          '--mount-ip=[Mount IP]:ip:' \
          '--mount-msize=[Mount msize]:msize:' \
          '--mount-options=[Mount options]:options:' \
          '--mount-port=[Mount port]:port:' \
          '--mount-string=[Mount spec host-path:vm-path]:spec:' \
          '--mount-type=[Mount access type]:type:(9p)' \
          '--mount-uid=[Mount UID]:uid:' \
          '--namespace=[The namespace used for the minikube addons]:namespace:' \
          '--nat-nic-type=[NIC type for NAT network]:type:' \
          '--native-ssh[Use native SSH instead of emulated (requires openssh)]' \
          '--network=[Network to run minikube with]:network:' \
          '--network-plugin=[DEPRECATED: Use --cni]:plugin:' \
          '--nfs-share=[Local folders to share via NFS]:dirs:' \
          '--nfs-shares-root=[Where to root the NFS shares]:root:' \
          '--no-kubernetes[Do not start Kubernetes]' \
          '--no-vtx-check[Disable VTX check]' \
          {-n,--nodes}'=[Number of nodes to spin up]:count:' \
          {-o,--output}'=[Output format]:format:(text json)' \
          '--ports=[Ports to expose for docker and podman driver]:ports:' \
          '--preload[Preload the container runtime images]' \
          '--registry-mirror=[Registry mirrors to pass to Docker daemon]:mirrors:' \
          '--service-cluster-ip-range=[The CIDR to be used for service cluster IPs]:cidr:' \
          '--socket-vmnet-client-path=[Path to socket vmnet client]:path:_files' \
          '--socket-vmnet-path=[Path to socket vmnet binary]:path:_files' \
          '--ssh-ip-address=[IP address for SSH]:ip:' \
          '--ssh-key=[SSH key for SSH driver]:key:_files' \
          '--ssh-port=[SSH port for SSH driver]:port:' \
          '--ssh-user=[SSH user for SSH driver]:user:' \
          '--static-ip=[Set a static IP for the minikube cluster]:ip:' \
          '--subnet=[Subnet to be used on kic cluster]:subnet:' \
          '--trace=[Send trace events to a specified endpoint]:endpoint:' \
          '--uuid=[UUID for the minikube cluster]:uuid:' \
          '--vm[Use a VM driver]' \
          '--vm-driver=[DEPRECATED: Use --driver]:driver:' \
          '--wait=[Comma-separated components to verify and wait for]:components:' \
          '--wait-timeout=[Max time to wait per Kubernetes/system pod]:duration:' && ret=0
        ;;
      stop)
        _arguments \
          '--all[Stop all running profiles]' \
          '--cancel-scheduled[Cancel any scheduled stop]' \
          '--keep-context-active[Keep context active after stop]' \
          '--schedule=[Schedule stop]:duration:' \
          {-o,--output}'=[Output format]:format:(text json)' && ret=0
        ;;
      delete)
        _arguments \
          '--all[Delete all profiles]' \
          '--purge[Delete all config data and caches]' \
          {-o,--output}'=[Output format]:format:(text json)' && ret=0
        ;;
      status)
        _arguments \
          {-o,--output}'=[Output format]:format:(text json short)' \
          {-n,--node}'=[Node name]:node:' \
          '--watch=[Continuously watch status]:interval:' && ret=0
        ;;
      dashboard)
        _arguments \
          '--port=[Expose dashboard on this port]:port:' \
          '--url[Display dashboard URL instead of opening browser]' && ret=0
        ;;
      service)
        _arguments \
          '--all[Forward all services in a namespace]' \
          '--https[Open service URL with HTTPS]' \
          '--interval=[Polling interval in seconds]:interval:' \
          {-n,--namespace}'=[The service namespace]:namespace:' \
          '--url[Display the service URL]' \
          '--wait=[Wait timeout in seconds]:timeout:' \
          '1:service:' && ret=0
        ;;
      addons)
        local -a addon_cmds
        addon_cmds=(
          'configure:Configure an addon'
          'disable:Disable an addon'
          'enable:Enable an addon'
          'images:List addon images'
          'list:List all available addons'
          'open:Open an addon in the browser'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t addon_cmds 'addons subcommand' addon_cmds && ret=0 ;;
        esac
        ;;
      node)
        local -a node_cmds
        node_cmds=(
          'add:Add a node to the given cluster'
          'delete:Delete a node from a cluster'
          'list:List nodes'
          'start:Start a node'
          'stop:Stop a node'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t node_cmds 'node subcommand' node_cmds && ret=0 ;;
        esac
        ;;
      image)
        local -a image_cmds
        image_cmds=(
          'build:Build a container image'
          'list:List images'
          'load:Load an image into minikube'
          'ls:List images'
          'pull:Pull images'
          'push:Push images'
          'rm:Remove one or more images'
          'save:Save an image from minikube'
          'tag:Tag images'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t image_cmds 'image subcommand' image_cmds && ret=0 ;;
        esac
        ;;
      ssh)
        _arguments \
          {-n,--node}'=[The node to SSH into]:node:' \
          '--native-ssh[Use native SSH]' \
          '*:command:' && ret=0
        ;;
      tunnel)
        _arguments \
          '--bind-address=[Tunnel bind address]:address:' \
          {-c,--cleanup}'[Call with cleanup to remove old tunnels]' && ret=0
        ;;
      logs)
        _arguments \
          '--audit[Show only Kubernetes audit logs]' \
          '--file=[Logs file path]:file:_files' \
          {-f,--follow}'[Follow log output]' \
          '--last-start-only[Show only logs from the last start]' \
          '--length=[Number of lines to show]:length:' \
          {-n,--node}'=[The node to get logs from]:node:' \
          '--problems[Show only problems]' && ret=0
        ;;
      mount)
        _arguments \
          '--9p-version=[9p version]:version:(9p2000 9p2000.u 9p2000.L)' \
          '--gid=[GID]:gid:' \
          '--ip=[IP to bind]:ip:' \
          '--kill[Kill the mount process]' \
          '--mode=[File permissions]:mode:' \
          '--msize=[Mount msize]:msize:' \
          '--options=[Mount options]:options:' \
          '--port=[Mount port]:port:' \
          '--type=[Mount type]:type:(9p)' \
          '--uid=[UID]:uid:' \
          '1:mount spec (host\:vm):' && ret=0
        ;;
      config)
        local -a config_cmds
        config_cmds=(
          'defaults:Lists all valid default values for PROPERTY_NAME'
          'get:Gets the value of PROPERTY_NAME'
          'set:Sets a value in the minikube config file'
          'unset:Unsets a value in the minikube config file'
          'view:Display values currently set in the minikube config file'
        )
        _arguments -C \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t config_cmds 'config subcommand' config_cmds && ret=0 ;;
        esac
        ;;
      profile)
        local -a profile_cmds
        profile_cmds=(
          'list:List all profiles'
        )
        _arguments -C \
          '1:subcommand or profile name:->subcmd' \
          '*::arg:->subargs' && ret=0
        case "$state" in
          subcmd) _describe -t profile_cmds 'profile subcommand' profile_cmds && ret=0 ;;
        esac
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
