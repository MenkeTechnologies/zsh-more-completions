#compdef bash-snippets
# Documentation: https://man.archlinux.org/search?q=bash-snippets
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '--help[Show help]'
    '-u[Update bash-snippets]'
    '--update[Update bash-snippets]'
    '-v[Show version]'
    '--version[Show version]'
    '1:tool:(cheat cloudup crypt cryptocurrency currency geo movies newton qrify short stocks taste todo transfer weather ytview)'
)

_arguments -s -S $arguments
