#compdef roslyn-language-server Microsoft.CodeAnalysis.LanguageServer
# Documentation: https://github.com/dotnet/vscode-csharp
# roslyn-language-server - Microsoft Roslyn C# language server

local ret=1

_arguments -s -S \
  '--stdio[communicate over standard input/output]' \
  '--logLevel=[set the minimum log level]:level:(Trace Debug Information Warning Error Critical None)' \
  '--extensionLogDirectory=[directory to write extension logs]:dir:_files -/' \
  '*--extension=[path to a Roslyn extension dll]:file:_files -g "*.dll"' \
  '--razorSourceGenerator=[path to the Razor source generator dll]:file:_files -g "*.dll"' \
  '--razorDesignTimePath=[path to Razor design-time targets]:file:_files' \
  '--starredCompletionComponentPath=[path to starred suggestions components]:dir:_files -/' \
  '--devKitDependencyPath=[path to Dev Kit dependencies]:file:_files' \
  '--sessionId=[unique session identifier]:id' \
  '--telemetryLevel=[telemetry level]:level' && ret=0

return ret
