#compdef osu_multi_lat
# Documentation: https://github.com/forresti/osu-micro-benchmarks/blob/master/README
# OSU MPI point-to-point latency micro-benchmark

local ret=1

_arguments -s \
  '-m[set minimum and maximum message length (e.g. 2:128)]:size:' \
  '-i[number of iterations per message length]:count:' \
  '-x[number of warmup iterations to skip]:count:' \
  '-d[accelerator device type for buffers]:type:(cuda openacc managed)' \
  '-M[maximum per-process memory consumption in bytes]:bytes:' \
  '-h[display help message]' && ret=0

return ret
