#compdef hexyl
# _hexyl — David Peter (sharkdp) hexyl (colorful Rust hexdump that renders byte categories with distinct colors + character panel)
# upstream: https://github.com/sharkdp/hexyl
# Flags from src/main.rs on tip (clap-derive).

_hexyl() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-n --length --bytes -c -l)'{-n+,--length=,--bytes=,-c+,-l+}'[number of bytes to read]:n:' \
        '(-s --skip)'{-s+,--skip=}'[skip bytes from the beginning]:n:' \
        '--block-size=[block size for size suffixes (e.g. k, M)]:size:' \
        '(-v --no-squeezing)'{-v,--no-squeezing}'[show all lines (do not collapse repeats with *)]' \
        '--color=[when to use color]:when:(always auto never force)' \
        '--border=[border style]:style:(unicode ascii none)' \
        '(-p --plain)'{-p,--plain}'[--no-characters + --no-position + --border=none + --color=never]' \
        '--no-characters[hide the character panel]' \
        '(-C --characters)'{-C,--characters}'[show the character panel (default)]' \
        '--character-table=[character mapping table]:table:(default ascii codepage-437)' \
        '--color-scheme=[character color scheme]:scheme:(default ibm-vga)' \
        '(-P --no-position)'{-P,--no-position}'[hide the position panel]' \
        '(-o --display-offset)'{-o+,--display-offset=}'[start position display offset]:n:' \
        '--panels=[number of hex panels (auto = max for terminal width)]:n:' \
        '(-g --group-size --groupsize)'{-g+,--group-size=,--groupsize=}'[bytes per group]:size:(1 2 4 8)' \
        '--endianness=[group byte order]:fmt:(big little)' \
        '(-e)-e[alias for --endianness=little]' \
        '(-b --base)'{-b+,--base=}'[byte base]:base:(binary octal decimal hexadecimal)' \
        '--terminal-width=[force terminal width]:cols:' \
        '--print-color-table[print color legend and exit]' \
        '(-i --include)'{-i,--include}'[C include-file output style (xxd -i)]' \
        '--completion=[emit shell completion]:shell:(bash zsh fish elvish powershell)' \
        '1:file:_files'
}

_hexyl "$@"
