#compdef rtabmap-reprocess
# Documentation: https://github.com/introlab/rtabmap/blob/master/tools/Reprocess/main.cpp
# Reprocess an RTAB-Map database with new parameters

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-r[use database stamps as input rate]' \
  '-skip[skip frames after each processed frame]:n' \
  '-c[configuration file overwriting database parameters]:ini:_files -g "*.ini"' \
  '-default[use default parameters instead of database parameters]' \
  '-params_last[use last database parameters instead of first]' \
  '-odom[recompute odometry]' \
  '-odom_input_guess[forward input odometry as guess when recomputing]' \
  '-odom_lin_var[override computed odometry linear covariance]:v' \
  '-odom_ang_var[override computed odometry angular covariance]:v' \
  '-start[start from node ID]:id' \
  '-stop[last node to process]:id' \
  '-start_s[start from map session ID]:id' \
  '-stop_s[last map session to process]:id' \
  '-stop_loop[stop after first loop closure detected]' \
  '-a[append mode: reprocess next databases on top of first]' \
  '-cam[camera index to stream]:idx' \
  '-cam_tf[override camera local transform]:transform' \
  '-cam_tf_lens_offset[Y-axis offset before optical rotation]:v' \
  '-nolandmark[ignore landmarks from input database]' \
  '-nopriors[ignore priors from input database]' \
  '-noimu[ignore IMU from input database]' \
  '-pub_loops[republish loop closures from input database]' \
  '-pub_inter_as_normal[republish intermediate nodes as normal]' \
  '-loc_null[reset localization pose between sessions]' \
  '-gt[use original graph as ground truth]' \
  '-g2[assemble 2D occupancy grid to map.pgm]' \
  '-g3[assemble 3D cloud to map.pcd]' \
  '-o2[assemble OctoMap 2D projection to octomap.pgm]' \
  '-o3[assemble OctoMap 3D cloud to octomap.pcd]' \
  '-db[save 2D occupancy grid in database]' \
  '-p[save odometry and localization poses g2o]' \
  '-scan_from_depth[generate scans from depth images]' \
  '-scan_downsample[downsample input scans]:n' \
  '-scan_range_min[filter scans with minimum range in m]:m' \
  '-scan_range_max[filter scans with maximum range in m]:m' \
  '-scan_voxel_size[voxel filter for input scans in m]:m' \
  '-scan_normal_k[compute scan normals k-neighbors]:k' \
  '-scan_normal_radius[compute scan normals radius-neighbors]:r' \
  '*:database:_files -g "*.db"' && ret=0

return ret
