#compdef ROI2dataset
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/ROI2dataset.html
# AFNI/SUMA transform ROI files into a node dataset

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help message]' \
  '-prefix[output dataset name prefix]:prefix:' \
  '-keep_separate[one column per ROI value]' \
  '-nodelist[1D files of node indices in traversal order]:nl:_files' \
  '-nodelist.nodups[node list without duplicate node entries]:nl:_files' \
  '-nodelist_with_ROIval[add ROI values as second column]' \
  '-input[input ROI files (must be last)]:roi:_files' \
  '-label_dset[output labeled NIML dataset for SUMA]:dsetname:' \
  '-of[output format]:format:(ni_bi ni_as 1D)' \
  '-dom_par_id[filter ROIs by domain parent idcode]:id:' \
  '-pad_to_node[full dataset from node 0 to max index]:max_index:' \
  '-pad_label[label value for nodes not in any ROI]:label:' \
  '*:roi:_files' && ret=0

return ret
