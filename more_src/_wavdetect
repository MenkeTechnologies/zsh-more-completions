#compdef wavdetect
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/wavdetect.html
# Mexican-Hat Wavelet source detection (wtransform+wrecon)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image file]:file:_files' \
  'outfile=[file name of output source list]:file:_files' \
  'scellfile=[image showing the source cells]:file:_files' \
  'imagefile=[output reconstructed source image]:file:_files' \
  'defnbkgfile=[default normalized background]:file:_files' \
  'scales=[the wavelet radii, in pixels]:scales:' \
  'regfile=[file for ASCII region output]:file:_files' \
  'clobber=[existing output files will be overwritten]:clobber:(yes no)' \
  'ellsigma=[size, in sigmas, of elliptical source regions]:ellsigma:' \
  'interdir=[directory for intermediate results]:dir:_files -/' \
  'bkginput=[pre-determined background input image]:file:_files' \
  'bkgerrinput=[use background error in file bkginput[2]]:bkgerrinput:(yes no)' \
  'outputinfix=[unique string to embed in output file names]:outputinfix:' \
  'sigthresh=[threshold for a pixel belonging to a source]:sigthresh:' \
  'bkgsigthresh=[significance threshold for cleansing data]:bkgsigthresh:' \
  'falsesrc=[number of false sources allowed per scale]:falsesrc:' \
  'sigcalfile=[data file for the false-source algorithm]:file:_files' \
  'exptime=[time of the exposure, in seconds]:exptime:' \
  'expfile=[exposure file]:file:_files' \
  'expthresh=[relative exposure threshold]:expthresh:' \
  'bkgtime=[livetime of predetermined background]:bkgtime:' \
  'maxiter=[maximum number of cleansing iterations per scale pair]:maxiter:' \
  'iterstop=[stop iterating below this cleansed-pixels ratio]:iterstop:' \
  'psffile=[table of PSF size data]:file:_files' \
  'log=[create wavdetect.log file]:log:(yes no)' \
  'verbose=[level of log output]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
