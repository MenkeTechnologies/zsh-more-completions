#compdef kfilt
# Documentation: https://github.com/ryane/kfilt
# Filter Kubernetes resources from a stream of manifests

local ret=1

_arguments -s -S \
  '*'{-i,--include}'=[include resources matching key=value]:selector' \
  '*'{-x,--exclude}'=[exclude resources matching key=value]:selector' \
  '*'{-k,--kind}'=[include by kind]:kind' \
  '*'{-K,--exclude-kind}'=[exclude by kind]:kind' \
  '*'{-n,--name}'=[include by name]:name' \
  '*'{-N,--exclude-name}'=[exclude by name]:name' \
  '*'{-l,--labels}'=[include by label selector]:labels' \
  '*'{-L,--exclude-labels}'=[exclude by label selector]:labels' \
  '(-f --filename)'{-f,--filename}'=[read manifests from a file or URL]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
