#compdef kubetest2-noop
# _kubetest2-noop — kubetest2 deployer for existing clusters (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from kubetest2-noop/deployer/deployer.go (gpflag).

_kubetest2-noop() {
    _arguments \
        '--build[build kubernetes]' \
        '--up[provision the test cluster (no-op)]' \
        '--down[tear down the test cluster (no-op)]' \
        '--test=[tester to run after deployer up]:tester:(ginkgo exec node clusterloader2)' \
        '--kubeconfig=[existing kubeconfig path]:file:_files' \
        '*::tester args:_normal'
}

_kubetest2-noop "$@"
