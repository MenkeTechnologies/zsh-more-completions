#compdef glsa-check
# Gentoo Linux Security Advisory checker

local ret=1

_arguments -s -S \
  '-l[list all GLSAs]' \
  '-d[dump GLSA details]:GLSA id:' \
  '-t[test if system is affected]:GLSA id:' \
  '-p[pretend to fix]:GLSA id:' \
  '-f[fix the GLSA]:GLSA id:' \
  '-i[inject GLSA into applied set]:GLSA id:' \
  '-n[list only new GLSAs]' \
  '-e[list affected GLSAs]' \
  '-c[use CPIO archive]' \
  '-v[verbose output]' \
  '-q[quiet mode]' \
  '-m[send mail notification]' \
  '--nocolor[disable color output]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:GLSA id:' && ret=0

return ret
