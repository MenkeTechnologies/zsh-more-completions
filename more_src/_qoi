#compdef qoi qoiconv qoibench
# _qoi — Dominic Szablewski Quite OK Image QOI codec qoiconv qoibench reference tools for the QOI lossless image format (phoboslab team, C); getopt
# upstream: https://github.com/phoboslab/qoi

_qoi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.qoi *.png *.bmp *.tga *.jpg *.jpeg"' \
        '-o+[output file]:file:_files -g "*.qoi *.png *.bmp *.tga"' \
        '-n+[N iterations]:n:' \
        '-q[quick test]' \
        '-w[warmup]' \
        '--encode[encode only]' \
        '--decode[decode only]' \
        '*:input output:_files -g "*.qoi *.png *.bmp *.tga *.jpg *.jpeg"'
}

_qoi "$@"
