#compdef 3dDTtoDWI
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDTtoDWI.html
# AFNI: compute diffusion-weighted images from a diffusion tensor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-prefix[output dataset prefix]:pname:_files' \
  '-automask[create mask from input]' \
  '-datum[output data type]:type:(byte short float)' \
  '-scale_out_1000[scale output by 1000]' \
  '*:dataset:_files' && ret=0

return ret
