#compdef kafka-mirror-maker kafka-mirror-maker-2

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--consumer.config=[consumer config file]:file:_files -g "*.properties"' \
  '--producer.config=[producer config file]:file:_files -g "*.properties"' \
  '--num.streams=[number of consumer threads]:n:' \
  '--whitelist=[topic whitelist regex]:regex:' \
  '--include=[topic include regex]:regex:' \
  '--blacklist=[topic blacklist regex (deprecated)]:regex:' \
  '--exclude=[topic exclude regex]:regex:' \
  '--abort.on.send.failure=[abort on send failure]:flag:(true false)' \
  '--message.handler=[message handler class]:class:' \
  '--message.handler.args=[message handler args]:args:' \
  '--rebalance.listener=[rebalance listener class]:class:' \
  '--rebalance.listener.args=[rebalance listener args]:args:' \
  '--offset.commit.interval.ms=[offset commit interval ms]:ms:' \
  '--new.consumer[use new consumer (default)]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
