#compdef accio
# _accio — Cihat Gündüz Accio Swift dependency manager CLI (Cihat Gündüz / Flinesoft, Swift); custom argparse (deprecated in favor of SwiftPM)
# upstream: https://github.com/JamitLabs/Accio

_accio() {
    local -a sub=(
        'init:scaffold Accio project'
        'install:install dependencies'
        'update:update dependencies'
        'set-shared-cache:set shared cache path'
        'unset-shared-cache:unset shared cache'
        'clear-cache:clear cache'
        'clean:clean build artifacts'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--project=+[xcodeproj]:file:_files -g "*.xcodeproj"' \
        '-p+[xcodeproj]:file:_files -g "*.xcodeproj"' \
        '--target=+[target]:list:' \
        '-t+[target]:list:' \
        '--workspace=+[workspace]:file:_files -g "*.xcworkspace"' \
        '-w+[workspace]:file:_files -g "*.xcworkspace"' \
        '--cache=+[cache type]:t:(local shared)' \
        '-c+[cache type]:t:(local shared)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'accio subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--no-xcconfig[no xcconfig]' ;;
                set-shared-cache) _arguments \
                    '*:cache-path:_files -/' ;;
            esac
            ;;
    esac
}

_accio "$@"
