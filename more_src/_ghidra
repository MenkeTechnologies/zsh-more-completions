#compdef ghidraRun analyzeHeadless

# Zsh completion for Ghidra headless analyzer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:project location:_files -/' \
  '2:project name' \
  '-import[Import files into project]:*:files:_files' \
  '-process[Process files already in project]:file name' \
  '-postScript[Run script after analysis]:script:_files -g "*.{java,py}"' \
  '-preScript[Run script before analysis]:script:_files -g "*.{java,py}"' \
  '-scriptPath[Additional script search path]:path:_files -/' \
  '-propertiesPath[User properties directory]:path:_files -/' \
  '-recursive[Process input directories recursively]' \
  '-readOnly[Do not save changes]' \
  '-deleteProject[Delete the project when done]' \
  '-noanalysis[Do not run auto-analysis]' \
  '-analysisTimeoutPerFile=[Timeout per file in seconds]:seconds' \
  '-keystore=[Path to the PKI keystore]:keystore:_files' \
  '-connect=[Connect to Ghidra Server]:server URL' \
  '-p[Ghidra Server user password]' \
  '-commit=[Commit message]:message' \
  '-okToDelete[OK to delete existing project files]' \
  '-max-cpu=[Maximum CPU cores to use]:cores' \
  '-loader=[Specify the loader to use]:loader' \
  '-language=[Specify the language ID]:language id' \
  '-compiler=[Specify the compiler spec ID]:compiler id' \
  '-processor=[Specify the processor]:processor' \
  '-cspec=[Specify the compiler spec]:spec' \
  '-log+[Log file]:file:_files' \
  '-scriptlog+[Script log file]:file:_files' \
  '-overwrite[Overwrite existing files in project]' && ret=0

return ret
