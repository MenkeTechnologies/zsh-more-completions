#compdef lade
# Documentation: https://man.archlinux.org/search?q=lade
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-v)*-v[increase log verbosity]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      inject:'inject secrets then run command'
      user:'show or set per-user secret mapping user'
      install:'install shell hooks'
      upgrade:'self-upgrade lade binary'
      hook:'agent hook (stdin JSON)'
      on:'enable shell integration'
      off:'disable shell integration'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
