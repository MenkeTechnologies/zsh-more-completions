#compdef gz-fuel
# Documentation: https://gazebosim.org/docs
# Gazebo Fuel resource management tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--force-version=[specify library version]:version' \
  '--versions[show available versions]' \
  '(-c --config)'{-c,--config}'=[path to configuration file]:file:_files' \
  '--header=[add HTTP authentication header]:header' \
  '(-u --url)'{-u,--url}'=[server URL or full resource URL]:url' \
  '(-t --type)'{-t,--type}'=[resource type]:type:(model world)' \
  '(-o --owner)'{-o,--owner}'=[resource owner name]:owner' \
  '(-m --model)'{-m,--model}'=[model directory path]:path:_files -/' \
  '(-p --private)'{-p,--private}'[mark resource as private]' \
  '(-b --public)'{-b,--public}'[mark resource as public]' \
  '(-r --raw)'{-r,--raw}'[machine-readable output format]' \
  '(-j --jobs)'{-j,--jobs}'=[parallel download count, max 16]:count' \
  '(-v --verbose)'{-v,--verbose}'=[console output verbosity 0-4]:level:(0 1 2 3 4)' \
  '--config2pbtxt=[convert model config to metadata format]:file:_files' \
  '--pbtxt2config=[convert metadata format to model config]:file:_files' \
  '--onlymodels[update only models]' \
  '--onlyworlds[update only worlds]' \
  '1:command:(download upload delete list edit meta configure update)' \
  '*::args:_default' && ret=0

return ret
