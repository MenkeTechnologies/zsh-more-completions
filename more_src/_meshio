#compdef meshio
# Documentation: https://github.com/nschloe/meshio
# I/O for many mesh formats: convert, inspect, compress and recode mesh files

local ret=1
local -a formats
formats=(
  abaqus ansys avsucd cgns dolfin-xml exodus flac3d gmsh h5m mdpa medit med
  nastran netgen neuroglancer obj off permas ply stl tecplot tetgen su2 ugrid
  vtk vtu wkt xdmf
)

local -a subcmds
subcmds=(
  'convert:convert between mesh formats'
  'info:print mesh info (points, cells, data)'
  'compress:compress a mesh file in place'
  'decompress:decompress a mesh file in place'
  'binary:convert a mesh file to its binary variant'
  'ascii:convert a mesh file to its ASCII variant'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'meshio command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      convert)
        _arguments \
          '(-i --input-format)'{-i,--input-format}'[input file format]:format:('"$formats"')' \
          '(-o --output-format)'{-o,--output-format}'[output file format]:format:('"$formats"')' \
          '(-a --ascii)'{-a,--ascii}'[write in ASCII format variant]' \
          '(-f --float-format)'{-f,--float-format}'[float format used in output ASCII files]:format:' \
          '(-s --sets-to-int-data)'{-s,--sets-to-int-data}'[convert sets to integer data if possible]' \
          '(-d --int-data-to-sets)'{-d,--int-data-to-sets}'[convert integer data to sets if possible]' \
          '1:infile:_files' \
          '2:outfile:_files' && ret=0
        ;;
      compress)
        _arguments \
          '(-i --input-format)'{-i,--input-format}'[input file format]:format:('"$formats"')' \
          '(-max --max)'{-max,--max}'[maximum compression]' \
          '1:infile:_files' && ret=0
        ;;
      info|decompress|binary|ascii)
        _arguments \
          '(-i --input-format)'{-i,--input-format}'[input file format]:format:('"$formats"')' \
          '1:infile:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
