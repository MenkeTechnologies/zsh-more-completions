#compdef cluster-proportional-vertical-autoscaler cpvpa
# _cluster-proportional-vertical-autoscaler — Cluster Proportional Vertical Autoscaler
# upstream: https://github.com/kubernetes-sigs/cluster-proportional-vertical-autoscaler
# Flags from cmd/cpvpa/options/options.go on tip.

_cluster-proportional-vertical-autoscaler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--target=[target to scale (deployment/*)]:spec:' \
        '--namespace=[target namespace]:ns:' \
        '--default-config=[fallback config (JSON)]:json:' \
        '--config-file=[config file (JSON, overrides default-config)]:file:_files' \
        '--poll-period-seconds=[poll period (s)]:s:' \
        '--kubeconfig=[kubeconfig file (out-of-cluster)]:file:_files' \
        '--version=[print version and exit]:bool:(true false)' \
        '--dry-run=[compute updates without applying]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_cluster-proportional-vertical-autoscaler "$@"
