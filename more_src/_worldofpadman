#compdef worldofpadman
# Documentation: https://github.com/PadWorld-Entertainment/wop_engine
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: World of Padman runs on the ioquake3 engine (id Tech 3); the
# universal id Tech 3 convention is +cmd Cbuf parsing. No flag-style options.

local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
