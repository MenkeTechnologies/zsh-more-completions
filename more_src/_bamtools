#compdef bamtools
# bamtools — toolkit for working with BAM alignment files

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'convert:convert BAM to other formats'
  'count:count number of alignments'
  'coverage:print coverage statistics'
  'filter:filter BAM file by properties'
  'header:print BAM header'
  'index:generate BAM index'
  'merge:merge multiple BAM files'
  'random:select random alignments'
  'resolve:resolve paired-end reads'
  'revert:revert BAM to original state'
  'sort:sort BAM file'
  'split:split BAM file by tag'
  'stats:print general alignment statistics'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'bamtools subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      convert)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-format+[output format]:format:(bed fasta fastq json pileup sam yaml)' \
          '-region+[genomic region]:region:' && ret=0
        ;;
      count)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-region+[genomic region]:region:' && ret=0
        ;;
      coverage)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' && ret=0
        ;;
      filter)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-script+[filter script JSON]:script file:_files -g "*.json(-.)"' \
          '-region+[genomic region]:region:' && ret=0
        ;;
      header)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' && ret=0
        ;;
      index)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-bti[create BAM Tool Index instead of standard]' && ret=0
        ;;
      merge)
        _arguments \
          '*-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-list+[file listing BAM files]:list file:_files' \
          '-region+[genomic region]:region:' && ret=0
        ;;
      random)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-count+[number of alignments]:count:' \
          '-region+[genomic region]:region:' && ret=0
        ;;
      sort)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-byname[sort by name instead of position]' \
          '-n+[max records per temp file]:count:' \
          '-mem+[max memory in MB]:megabytes:' && ret=0
        ;;
      split)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-refPrefix+[custom prefix for reference split]:prefix:' \
          '-mapped[split mapped/unmapped]' \
          '-paired[split paired/single-end]' \
          '-reference[split by reference]' \
          '-tag+[split by tag]:tag:' && ret=0
        ;;
      stats)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-insert[show insert size summary]' && ret=0
        ;;
      resolve)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-stats+[stats file]:stats file:_files' \
          '-makeStats[generate stats file]' \
          '-markPairs[mark pairs]' \
          '-twoPass[two-pass algorithm]' && ret=0
        ;;
      revert)
        _arguments \
          '-in+[input BAM file]:BAM file:_files -g "*.bam(-.)"' \
          '-out+[output file]:output file:_files' \
          '-keepDuplicate[keep duplicate flag]' \
          '-keepQualities[keep original qualities]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
