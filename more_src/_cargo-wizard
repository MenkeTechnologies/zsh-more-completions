#compdef cargo-wizard
# Documentation: https://github.com/Kobzol/cargo-wizard
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Interactive Cargo profile templates: `cargo install cargo-wizard`. Subcommand: apply.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--colors=[console color policy]:policy:(auto always never)' \
  '--nightly=-[include nightly-only rustc settings]:mode:(auto on off)' \
  '1: :_cargo_wizard_cmds' \
  '*:: :->args' && ret=0

_cargo_wizard_cmds() {
  local -a cmd=( 'apply:apply a predefined template to a profile' )
  _describe -t commands 'cargo wizard command' cmd
}

case $state in
  args)
    case $words[1] in
      apply)
        _arguments -s -S \
          '1:template:(fast-compile fast-runtime min-size)' \
          '2:profile:(dev release bench test)' \
          '--manifest-path=[explicit Cargo.toml]:file:_files -g "*.toml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
