#compdef cargo-wizard
# Documentation: https://man.archlinux.org/search?q=cargo-wizard
# Reference accessed: 2026-05-16

# https://github.com/kobzol/cargo-wizard — interactive Cargo profile templates (`cargo install cargo-wizard`)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--colors=[color policy]:policy:(auto always never)' \
  '--nightly=-[include nightly-only rustc settings]:mode:(auto on off)' \
  '1: :_cargo_wizard_cmds' \
  '*:: :->args' && ret=0

_cargo_wizard_cmds() {
  local -a cmd=( 'apply:apply a bundled profile template' )
  _describe -t commands 'cargo wizard command' cmd
}

case $state in
  args)
    case $words[1] in
      apply)
        _arguments -s -S \
          '1:template:_default' \
          '2:profile:_default' \
          '--manifest-path=[explicit Cargo.toml]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
