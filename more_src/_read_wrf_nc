#compdef read_wrf_nc
# WRF utility to read and inspect WRF netCDF output files

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-att[print global attributes]' \
  '-m[list available fields with min/max values]' \
  '-M[list fields with min/max at level z]:level:' \
  '-s[list fields with sample value from domain center]' \
  '-S[sample value at specific point x y z]:x:' \
  '-t[apply options to time range]:t1:' \
  '-times[print only file times]' \
  '-ts[generate time series output]' \
  '-lev[create time series for level z]:level:' \
  '-rot[rotate winds to Earth coordinates]' \
  '-diag[show diagnostics (temperature, pressure, height)]' \
  '-v[print field information]:var:' \
  '-V[print field info and dump full field]:var:' \
  '-w[write full field to file VAR.out]:var:' \
  '-EditData[modify specific field in output file]:var:' \
  '*:wrf netcdf file:_files -g "*.nc"' && ret=0

return ret
