#compdef ipa-adtrust-install
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-adtrust-install.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-adtrust-install.1.

# ipa-adtrust-install: install Active Directory trust support
local curcontext="$curcontext" ret=1
_arguments -C \
  '--netbios-name=[NetBIOS name for IPA domain]:name:' \
  '--add-sids[add SIDs to existing users and groups]' \
  '--add-agents[add IPA masters as trusted-forest user info servers]' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' \
  '--rid-base=[first RID value of local domain]:n:' \
  '--secondary-rid-base=[start of secondary RID range]:n:' \
  '(-A --admin-name)'{-A,--admin-name=}'[admin user name (default admin)]:name:' \
  '(-a --admin-password)'{-a,--admin-password=}'[admin password]:password:' \
  '--enable-compat[enable Schema Compatibility plugin for trusted users]' && ret=0
return ret
