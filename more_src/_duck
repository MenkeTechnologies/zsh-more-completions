#compdef duck

# iterate-ch/cyberduck cli TerminalOptionsBuilder.java; Homebrew: Formula/d/duck.rb

local ret=1
_arguments -s \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[show version]' \
  '(--upload)'--upload='[upload file to URL]:url file:_default' \
  '(-d --download)'{-d,--download=}'[download URL to local path]:url local:_files' \
  '(--copy)'--copy='[server-to-server copy]:src dst:_default' \
  '(--move)'--move='[rename remote path]:url file:_default' \
  '(-l --list)'{-l+,--list=}'[list remote URL]:url:' \
  '(-L --longlist)'{-L+,--longlist=}'[long list remote URL]:url:' \
  '(-D --delete)'{-D+,--delete=}'[delete remote URL]:url:' \
  '(-c --mkdir)'{-c+,--mkdir=}'[mkdir remote URL]:url:' \
  '(--synchronize)'--synchronize='[sync remote to local directory]:url dir:_files -/' \
  '(--edit)'--edit='[edit remote file URL]:url:' \
  '(--purge)'--purge='[purge CDN URL]:url:' \
  '(-u --username)'{-u+,--username=}'[username or access key]:user:' \
  '(-p --password)'{-p+,--password=}'[password / secret]:password:' \
  '--anonymous[no login]' \
  '(--profile)'--profile='[connection profile]:profile:' \
  '(-i --identity)'{-i+,--identity=}'[private key file]:key:_files' \
  '(1)--chmod=[octal mode for upload]:mode:' \
  '(1)--application=[external editor]:app:_files' \
  '(1)--region=[bucket location]:region:' \
  '(-P --preserve)'{-P,--preserve}'[preserve metadata on transfer]' \
  '(-r --retry)'{-r+,--retry=}'[retry count]:count:' \
  '--udt[use UDT when applicable]' \
  '(--parallel)'--parallel='[parallel connections]:n:' \
  '(--throttle)'--throttle='[bytes per second limit]:bps:' \
  '--nochecksum[skip checksum verify]' \
  '--nokeychain[do not store passwords in keychain]' \
  '(--vault)'--vault='[unlock vault path]:vault:_files -/' \
  '(-e --existing)'{-e+,--existing=}'[existing file transfer action]:action:' \
  '(-v --verbose)'{-v,--verbose}'[print transcript]' \
  '--debug[debug log]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress]' \
  '(-y --assumeyes)'{-y,--assumeyes}'[assume yes]' && ret=0
return ret
