#compdef qcachegrind
# _qcachegrind — QCachegrind pure-Qt callgrind viewer; same UI as KCachegrind without KDE deps
# upstream: https://kcachegrind.github.io

_qcachegrind() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '--display+[X display]:display:' \
        '*:callgrind file:_files -g "*.out*"'
}

_qcachegrind "$@"
