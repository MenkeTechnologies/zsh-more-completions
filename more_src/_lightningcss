#compdef lightningcss

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--minify[enable minification]' \
  '--nesting[enable CSS nesting]' \
  '--custom-media[enable custom media queries]' \
  '--bundle[bundle @import rules]' \
  '--targets=[browser targets]:targets' \
  '--browserslist[use browserslist for targets]' \
  '-o+[output file]:output file:_files' \
  '--output-file=[output file]:output file:_files' \
  '--sourcemap[generate source map]' \
  '--input-source-map=[input source map]:file:_files' \
  '--css-modules[enable CSS modules]' \
  '--css-modules-pattern=[CSS modules naming pattern]:pattern' \
  '--css-modules-dashed-idents[dash CSS modules identifiers]' \
  '--analyze-dependencies[output dependency list as JSON]' \
  '--error-recovery[attempt to recover from parse errors]' \
  '*:input file:_files -g "*.css"' && ret=0

return ret
