#compdef chiaki
# Documentation: https://man.archlinux.org/search?q=chiaki
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'discover:discover PlayStation consoles on the network'
  'wakeup:wake up a console'
  'register:register a new console'
  'stream:start streaming session'
  'list-controllers:list connected controllers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--log-level=[log level]:level:(trace debug info warning error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chiaki command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (discover)
        _arguments \
          '-h[host filter]:host:_hosts' \
          '--broadcast[scan broadcast]' \
          '--timeout=[scan timeout sec]:sec:' && ret=0 ;;
      (wakeup)
        _arguments \
          '-h[host]:host:_hosts' \
          '--registkey=[registration key]:key:' \
          '--ps5[target is PS5]' \
          '--ps4[target is PS4]' && ret=0 ;;
      (register)
        _arguments \
          '-h[host]:host:_hosts' \
          '--pin=[8-digit PIN]:pin:' \
          '--account-id=[PSN account ID]:id:' && ret=0 ;;
      (stream)
        _arguments \
          '-h[host]:host:_hosts' \
          '--resolution=[resolution]:res:(360p 540p 720p 1080p)' \
          '--fps=[frame rate]:fps:(30 60)' \
          '--codec=[video codec]:codec:(h264 h265 hevc)' \
          '--bitrate=[bitrate kbps]:kbps:' \
          '--audio-out=[audio output device]:dev:' && ret=0 ;;
    esac ;;
esac

return ret
