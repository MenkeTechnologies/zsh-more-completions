#compdef chiaki-cli chiaki
# Documentation: https://github.com/thenets/chiaki/tree/master/cli/src
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (cli/src/main.c, discover.c, wakeup.c).

# chiaki-cli supports only `discover` and `wakeup` subcommands.
local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'discover:send a discovery request to a PlayStation console'
  'wakeup:send a wakeup packet to a console'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chiaki-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (discover)
        _arguments \
          '(-h --host)'{-h,--host}'=[host to send discovery request to]:host:_hosts' && ret=0 ;;
      (wakeup)
        _arguments \
          '(-h --host)'{-h,--host}'=[host to send wakeup packet to]:host:_hosts' \
          '(-r --registkey)'{-r,--registkey}'=[Remote Play registration key (plaintext)]:key:' \
          '(-4 --ps4)'{-4,--ps4}'[target is PlayStation 4]' \
          '(-5 --ps5)'{-5,--ps5}'[target is PlayStation 5 (default)]' && ret=0 ;;
    esac ;;
esac

return ret
