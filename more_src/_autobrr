#compdef autobrr
# Documentation: https://github.com/autobrr/autobrr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for autobrr (pflag)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--config[path to configuration directory]:dir:_directories' \
  '--pgo[internal pprof output path]:file:_files' \
  '(-h --help)'{-h,--help}'[show usage]' && ret=0

return ret
