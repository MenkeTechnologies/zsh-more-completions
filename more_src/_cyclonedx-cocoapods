#compdef cyclonedx-cocoapods
# Documentation: https://github.com/CycloneDX/cyclonedx-cocoapods
# cyclonedx-cocoapods: generate CycloneDX SBOM from CocoaPods projects

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--verbose[display verbose debugging output]' \
  '--no-verbose[disable verbose debugging output]' \
  '(-p --path)'{-p,--path}'[directory path for CocoaPods project]:dir:_files -/' \
  '(-o --output)'{-o,--output}'[output file location (.json triggers JSON format)]:file:_files' \
  '--bom-version[generated BOM version]:version:' \
  '(-x --exclude-test-targets)'{-x,--exclude-test-targets}'[remove Podfile targets containing test in name]' \
  '--shortened-strings[truncate author, publisher and purl fields]:length:' \
  '(-n --name)'{-n,--name}'[component name]:name:' \
  '(-v --version)'{-v,--version}'[component version]:version:' \
  '(-t --type)'{-t,--type}'[component type]:type:(application framework library container operating-system device firmware file)' \
  '(-g --group)'{-g,--group}'[component group]:group:' \
  '(-s --source)'{-s,--source}'[version control system URL]:url:' \
  '(-b --build)'{-b,--build}'[build URL]:url:' \
  '--manufacturer-name[manufacturer name]:name:' \
  '--manufacturer-url[manufacturer URL]:url:' \
  '--manufacturer-contact-name[contact person name]:name:' \
  '--manufacturer-email[contact email]:email:' \
  '--manufacturer-phone[contact phone number]:phone:' && ret=0

return ret
