#compdef cdh-oneshot
# _cdh-oneshot — Confidential Data Hub one-shot CLI (runs CDH in-process and performs a single op: UnsealSecret/UnwrapKey/GetResource/SecureMount/PullImage)
# upstream: https://github.com/confidential-containers/guest-components
# Subcommands + flags from confidential-data-hub/hub/src/bin/cdh-oneshot.rs Cli on tip (clap).

_cdh-oneshot() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --config)'{-c,--config}'=[path to the CDH config file]:file:_files' \
        '(-r --retry)'{-r,--retry}'=[retry attempts]:n:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                unseal-secret:'unseal a sealed secret (envelope or vault)'
                unwrap-key:'unwrap an OCI image encryption key from an AnnotationPacket'
                get-resource:'fetch a confidential resource from the KBS'
                secure-mount:'mount a Storage object via the CDH secure-mount provider'
                pull-image:'pull an image and store it as an OCI bundle'
            )
            _describe -t commands 'cdh-oneshot subcommand' subs
            ;;
        args)
            case $line[1] in
                unseal-secret)
                    _arguments \
                        '(-s --secret-path)'{-s,--secret-path}'=[file containing the sealed secret]:file:_files'
                    ;;
                unwrap-key)
                    _arguments \
                        '(-a --annotation-path)'{-a,--annotation-path}'=[file containing the AnnotationPacket]:file:_files'
                    ;;
                get-resource)
                    _arguments \
                        '(-r --resource-uri)'{-r,--resource-uri}'=[KBS Resource URI]:uri:'
                    ;;
                secure-mount)
                    _arguments \
                        '(-s --storage-path)'{-s,--storage-path}'=[file containing the Storage object]:file:_files'
                    ;;
                pull-image)
                    _arguments \
                        '(-i --image-url)'{-i,--image-url}'=[image reference to pull]:ref:' \
                        '(-b --bundle-path)'{-b,--bundle-path}'=[path to store the bundle]:dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_cdh-oneshot "$@"
