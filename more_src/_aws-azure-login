#compdef aws-azure-login
# _aws-azure-login — log in to AWS via Azure AD SAML (aws-azure-login/aws-azure-login)
# upstream: https://github.com/aws-azure-login/aws-azure-login
# Flags from src/index.ts (commander).

_aws-azure-login() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --profile)'{-p+,--profile=}'[AWS profile name]:profile:' \
        '(-a --all-profiles)'{-a,--all-profiles}'[run for all configured profiles]' \
        '(-f --force-refresh)'{-f,--force-refresh}'[force credential refresh]' \
        '(-c --configure)'{-c,--configure}'[configure the profile]' \
        '(-m --mode)'{-m+,--mode=}'[login mode]:mode:(cli gui debug)' \
        '--no-sandbox[disable Puppeteer sandbox]' \
        '--no-prompt[do not prompt for input]' \
        '--enable-chrome-network-service[enable Chromium Network Service]' \
        '--no-verify-ssl[disable SSL peer verification for AWS]' \
        '--enable-chrome-seamless-sso[enable Azure AD seamless SSO]' \
        '--no-disable-extensions[allow Chromium extensions]' \
        '--disable-gpu[pass --disable-gpu to Chromium]'
}

_aws-azure-login "$@"
