#compdef tdspool
# Documentation: https://man.archlinux.org/search?q=tdspool
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-l+[log file]:file:_files' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '1:pool name:' && ret=0

return ret
