#compdef wasm2wat

# Zsh completion for wasm2wat - translate WebAssembly binary to text format

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-v,--verbose}'[verbose output]' \
  {-o,--output}'[output file]:output file:_files' \
  '--fold-exprs[fold expressions in output]' \
  '--inline-exports[inline exports in output]' \
  '--inline-imports[inline imports in output]' \
  '--no-debug-names[ignore debug names in binary]' \
  '--generate-names[generate names for unnamed items]' \
  '--enable-exceptions[enable exceptions extension]' \
  '--enable-mutable-globals[enable mutable globals extension]' \
  '--enable-saturating-float-to-int[enable saturating float-to-int extension]' \
  '--enable-sign-extension[enable sign extension extension]' \
  '--enable-simd[enable SIMD extension]' \
  '--enable-threads[enable threads extension]' \
  '--enable-multi-value[enable multi-value extension]' \
  '--enable-tail-call[enable tail call extension]' \
  '--enable-bulk-memory[enable bulk memory extension]' \
  '--enable-reference-types[enable reference types extension]' \
  '--enable-annotations[enable annotations extension]' \
  '--enable-gc[enable GC extension]' \
  '--enable-memory64[enable memory64 extension]' \
  '--enable-multi-memory[enable multi-memory extension]' \
  '--enable-all[enable all extensions]' \
  '1:wasm file:_files -g "*.wasm"'
