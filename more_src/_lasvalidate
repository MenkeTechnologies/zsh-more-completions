#compdef lasvalidate
# Documentation: https://github.com/LAStools/LAStools
# LAStools: validate LAS/LAZ files against the ASPRS LAS specification

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-version[report tool version]' \
  '-gui[launch with GUI]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output with extra information]' \
  '-vv[very verbose output]' \
  '-silent[output only errors/warnings]' \
  '-quiet[suppress all output]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue despite errors]' \
  '-report_per_file[separate validation report per input file]' \
  '-tile_size+[check if header bounding box exceeds tile size]:n' \
  '-no_CRS_fail[treat CRS validation errors as warnings]' \
  '-halt_on_errors[stop processing on first error]' \
  '*-i+[input file or file mask]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-lof+[use input list from file]:file:_files' \
  '-subdir[enable recursive subdirectory search]' \
  '-unique[remove duplicate files from list]' \
  '-stdin[pipe input from stdin]' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output file suffix]:suffix' \
  '-ocsv[output as CSV]' \
  '-oxml[output as XML]' \
  '-otxt[output as text]' \
  '-ojs[output as JSON]' \
  '-stdout[pipe output to stdout]' \
  '-cores+[process multiple files on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
