#compdef ninja

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--quiet[quiet output]' \
  '-C+[change to directory before doing anything]:dir:_files -/' \
  '-f+[input build file]:file:_files -g "*.ninja"' \
  '-j+[parallel jobs]:n:' \
  '-k+[keep going after N failures]:n:' \
  '-l+[do not start new jobs if load is above N]:load:' \
  '-n[dry run]' \
  '*-d+[debug mode]:mode:(stats explain keepdepfile keeprsp list)' \
  '-t+[run a subtool]:tool:(browse clean cleandead commands compdb compdb-targets deps graph inputs missingdeps multi-inputs query recompact restat rules targets list)' \
  '*-w+[warning flag]:flag:(phonycycle=err phonycycle=warn list)' \
  '*:target:'
