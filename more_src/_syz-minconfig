#compdef syz-minconfig
# _syz-minconfig — minimize a kernel config that still triggers a crash (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-minconfig/minconfig.go (flag).

_syz-minconfig() {
    _arguments \
        '-sourcedir=[kernel sources directory]:dir:_files -/' \
        '-base=[baseline config]:file:_files' \
        '-full=[full config]:file:_files' \
        '-configs=[comma-separated configs for the crash predicate]:list:' \
        '-arch=[kernel architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)'
}

_syz-minconfig "$@"
