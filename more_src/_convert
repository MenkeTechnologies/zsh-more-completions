#compdef convert
# Documentation: https://imagemagick.org/script/convert.php
# Source: ImageMagick — legacy `convert` CLI (modern alias of `magick convert`).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-resize[resize the image]:geometry:' \
    '-crop[crop the image]:geometry:' \
    '-rotate[apply Paeth rotation]:degrees:' \
    '-flip[flip image vertically]' \
    '-flop[flop image horizontally]' \
    '-quality[JPEG/MIFF/PNG compression level]:n:' \
    '-compress[image compression type]:type:(None BZip Fax Group4 JPEG JPEG2000 Lossless LZW RLE Zip)' \
    '-density[horizontal+vertical density (dpi)]:density:' \
    '-format[output formatted image characteristics]:format:' \
    '-filter[resize filter]:filter:(Point Box Triangle Hermite Hanning Hamming Blackman Gaussian Quadratic Cubic Catrom Mitchell Lanczos Bessel Sinc)' \
    '-gravity[text placement]:gravity:(NorthWest North NorthEast West Center East SouthWest South SouthEast)' \
    '-strip[strip profiles and comments]' \
    '-auto-orient[auto-orient via EXIF]' \
    '-extent[set image size]:geometry:' \
    '-trim[trim image edges]' \
    '-negate[replace each pixel with complementary color]' \
    '-despeckle[reduce speckles]' \
    '-sharpen[sharpen the image]:radiusxsigma:' \
    '-blur[blur the image]:radiusxsigma:' \
    '-gamma[gamma correction]:value:' \
    '-level[adjust contrast (black/white[,gamma])]:value:' \
    '-modulate[brightness,saturation,hue]:b,s,h:' \
    '-monochrome[transform to black and white]' \
    '-colorspace[colorspace]:space:(RGB sRGB CMYK Gray HSV HSL Lab YCbCr XYZ)' \
    '-background[background color]:color:' \
    '-fill[paint color]:color:' \
    '-stroke[stroke color]:color:' \
    '-pointsize[font point size]:pt:' \
    '-font[font]:font:' \
    '-annotate[annotate image]:geometry text:' \
    '-channel[image channel]:channel:(R G B A K All Default)' \
    '-alpha[on / off / set / opaque / transparent / etc]:mode:(activate deactivate set on off opaque transparent extract copy shape remove)' \
    '-thumbnail[create thumbnail]:geometry:' \
    '-append[append images vertically]' \
    '+append[append images horizontally]' \
    '*:image file:_files' \
    && ret=0

return ret
