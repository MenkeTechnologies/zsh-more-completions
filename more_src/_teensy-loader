#compdef teensy-loader teensy_loader_cli
# Documentation: https://man.archlinux.org/search?q=teensy-loader
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '--mcu=+[mcu]:mcu:(TEENSY2 TEENSY2PP TEENSY30 TEENSY31 TEENSY32 TEENSY35 TEENSY36 TEENSY40 TEENSY41 TEENSYLC at90usb162 atmega32u4 at90usb646 at90usb1286)' \
  '-w[wait for device]' \
  '-r[reset device]' \
  '-s[soft reboot]' \
  '-n[skip reboot]' \
  '-b[boot only, no program]' \
  '-v[verbose]' \
  '*:hex file:_files -g "*.hex"' && ret=0

return ret
