#compdef teensy-loader teensy_loader_cli
# Documentation: https://www.pjrc.com/teensy/loader_cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated -h/-V flags (teensy_loader_cli has no
# documented help/version short options); kept only --mcu and the documented
# -w/-r/-s/-n/-b/-v flags. MCU list pulled from upstream documentation.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--mcu=[target MCU]:mcu:(TEENSY41 TEENSY40 TEENSY36 TEENSY35 TEENSY32 TEENSY31 TEENSY30 TEENSYLC TEENSY2PP TEENSY2 imxrt1062 mk66fx1m0 mk64fx512 mk20dx256 mk20dx128 mkl26z64 at90usb1286 atmega32u4 at90usb646 at90usb162)' \
  '-w[wait for device to appear]' \
  '-r[use hard reboot if device not online]' \
  '-s[use soft reboot if device not online (Teensy3.x only)]' \
  '-n[no reboot after programming]' \
  '-b[boot only, do not program]' \
  '-v[verbose output]' \
  '*:hex file:_files -g "*.hex"' && ret=0

return ret
