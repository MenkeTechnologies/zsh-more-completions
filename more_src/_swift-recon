#compdef swift-recon

# swift-recon: collect cluster-wide metrics from object/account/container servers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--suppress=[suppress storage policies (comma list)]:list:' \
  '-a[get async pending stats]' \
  '--async[get async pending stats]' \
  '--auditor[get auditor stats]' \
  '--updater[get updater stats]' \
  '--expirer[get expirer stats]' \
  '-r[get replication stats]' \
  '--replication[get replication stats]' \
  '-u[get unmounted device stats]' \
  '--unmounted[get unmounted device stats]' \
  '-d[get diskusage stats]' \
  '--diskusage[get diskusage stats]' \
  '-l[get load stats]' \
  '--loadstats[get load stats]' \
  '-T[get time sync stats]' \
  '--time[get time sync stats]' \
  '-q[get quarantined stats]' \
  '--quarantined[get quarantined stats]' \
  '-R[get socket stats]' \
  '--socket[get socket stats]' \
  '-D[get drive audit stats]' \
  '--driveaudit[get drive audit stats]' \
  '-i[get version stats]' \
  '--version[get version stats]' \
  '--all[get all stats]' \
  '-z[mount zone]:zone:' \
  '--zone=[mount zone]:zone:' \
  '--swiftdir=[swift dir]:dir:_files -/' \
  '--server-type=[server type]:type:(account container object)' \
  '-t[timeout]:seconds:' \
  '--timeout=[timeout]:seconds:' \
  '*::swift-recon args:_files' && ret=0
return ret
