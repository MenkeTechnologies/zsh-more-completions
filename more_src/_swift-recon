#compdef swift-recon
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/cli/recon.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[print verbose information]' \
  '--suppress[suppress most connection related errors]' \
  '(-a --async)'{-a,--async}'[get async pending stats]' \
  '(-r --replication)'{-r,--replication}'[get replication stats]' \
  '(-R --reconstruction)'{-R,--reconstruction}'[get reconstruction stats]' \
  '--auditor[get auditor stats]' \
  '--updater[get updater stats]' \
  '--expirer[get expirer stats]' \
  '--sharding[get sharding stats]' \
  '(-u --unmounted)'{-u,--unmounted}'[check cluster for unmounted devices]' \
  '(-d --diskusage)'{-d,--diskusage}'[get disk usage stats]' \
  '--human-readable[format disk usage with human-readable suffix]' \
  '(-l --loadstats)'{-l,--loadstats}'[get cluster load average stats]' \
  '(-q --quarantined)'{-q,--quarantined}'[get cluster quarantine stats]' \
  '--validate-servers[validate servers on the ring]' \
  '--md5[compare ring md5sum against local copy]' \
  '--sockstat[get cluster socket usage stats]' \
  '--driveaudit[get drive audit error stats]' \
  '(-T --time)'{-T,--time}'[check time synchronization]' \
  '--jitter=[maximal allowed time jitter]:seconds:' \
  '--swift-versions[check swift versions]' \
  '--top=[show top COUNT entries in rank order]:count:' \
  '--lowest=[show lowest COUNT entries in rank order]:count:' \
  '--all[perform all checks]' \
  '--region=[only query servers in specified region]:region:' \
  '(-z --zone)'{-z+,--zone=}'[only query servers in specified zone]:zone:' \
  '(-t --timeout)'{-t+,--timeout=}'[time to wait for a response from a server]:seconds:' \
  '--swiftdir=[swift configuration directory]:dir:_files -/' \
  '(-p --policy)'{-p+,--policy=}'[filter object servers by storage policy]:policy:' \
  '*:server type:(account container object)' && ret=0
return ret
