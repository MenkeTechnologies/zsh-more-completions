#compdef box86
# Documentation: https://github.com/ptitSeb/box86/blob/master/src/main.c
# Reference accessed: 2026-05-16
# Verified: src/main.c argv parse loop (lines 1371-1395). box86 is primarily
# env-driven via BOX86_* variables; CLI surface is minimal.

# box86: x86 (32-bit) Linux binary translator on ARM
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show box86 version and exit]' \
  '(-f --flags)'{-f,--flags}'[show supported CPU flags and exit]' \
  '*:x86 ELF binary:_files' && ret=0
return ret
