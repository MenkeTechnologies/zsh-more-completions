#compdef create-icebreaker
# Documentation: https://www.npmjs.com/package/create-icebreaker
# Reference accessed: 2026-05-23
# Verified: npm view create-icebreaker bin; npm readme Flags section.

# Zsh completion for create-icebreaker - icebreaker monorepo template scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--templates=[comma-separated template keys to keep]:templates:(tsdown vue-lib vue-hono hono-server vitepress cli)'   '--force[overwrite a non-empty target directory]'   ':project directory:_directories' && ret=0

return ret
