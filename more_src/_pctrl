#compdef pctrl
# Documentation: https://man.archlinux.org/search?q=pctrl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'spawn:spawn processes'
  'kill:kill processes by job ID'
  'status:show process status'
  'list:list jobs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pctrl subcommand' subcommands && ret=0
    ;;
esac

return ret
