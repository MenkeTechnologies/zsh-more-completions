#compdef pctrl
# Documentation: https://github.com/openpmix/openpmix
# Reference accessed: 2026-05-20
# Verified: upstream help-pctrl.txt shipped with PMIx (PMIx job control tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose debug output]' \
  '--pmixmca[set MCA parameter value]:param:' \
  '--uri[server URI or file containing it]:uri:' \
  '--namespace[namespace of target daemon]:namespace:' \
  '--nspace[namespace of target daemon]:namespace:' \
  '--pid[PID of target daemon]:pid:' \
  '--system-server-first[prefer system server]' \
  '--system-server-only[connect only to system server]' \
  '--tmpdir[session directory root]:dir:_files -/' \
  '--wait-to-connect[delay before connecting]:seconds:' \
  '--num-connect-retries[max connection retries]:n:' \
  '--request-id[string identifier for request]:id:' \
  '--pause[pause specified processes]' \
  '--resume[resume paused processes]' \
  '--cancel[cancel request by ID]:id:' \
  '--kill[force terminate processes]' \
  '--terminate[politely terminate processes]' \
  '--signal[send signal to processes]:signal:' \
  '--restart[restart from checkpoint ID]:id:' \
  '--checkpoint[checkpoint with assigned ID]:id:' \
  '--pset[define new pset by name]:name:' \
  '--targets[comma-delimited target processes]:targets:' && ret=0

return ret
