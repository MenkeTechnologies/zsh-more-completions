#compdef tai64n
# _tai64n — daemontools tai64n (prepend each input line with a 12-byte TAI64N timestamp; standard log-line annotator that pairs with multilog and svlogd)
# upstream: https://github.com/schmonz/daemontools-encore
# Source: tai64n.8 on tip; no flags.

_tai64n() {
    _arguments '(- *)-h[show help]'
}

_tai64n "$@"
