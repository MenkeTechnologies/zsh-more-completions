#compdef sortmerna
# Documentation: https://sortmerna.readthedocs.io/en/latest/manual4.0.html
# SortMeRNA - filter and align rRNA reads against reference databases

local ret=1

_arguments -s \
  '(-h)-h[print help information]' \
  '--version[print SortMeRNA version number]' \
  '*-ref[reference file (FASTA), use multiple times]:ref:_files' \
  '*-reads[raw reads file (FASTA/FASTQ/.GZ), use twice for paired]:reads:_files' \
  '-aligned[aligned reads file prefix dir/pfx]:prefix:_files' \
  '-other[non-aligned reads file prefix dir/pfx]:prefix:_files' \
  '-fastx[output aligned reads into FASTA/FASTQ file]' \
  '-sam[output SAM alignment for aligned reads]' \
  '-SQ[add SQ tags to the SAM file]' \
  '-blast[output alignments in Blast-like formats]:format' \
  '-num_alignments[report first INT alignments per read]:int' \
  '-no-best[disable best alignments search]' \
  '-min_lis[search only alignments with LIS of at least N seeds (default 2)]:int' \
  '-print_all_reads[output null alignment strings for non-aligned reads]' \
  '-paired[flag single file as interleaved paired reads]' \
  '-paired_in[flag paired reads aligned when either aligns]' \
  '-paired_out[flag paired reads non-aligned when either is non-aligned]' \
  '-out2[output paired reads into separate files]' \
  '-sout[separate paired and singleton aligned reads]' \
  '-match[SW score for a match (default 2)]:int' \
  '-mismatch[SW penalty for a mismatch (default -3)]:int' \
  '-gap_open[SW penalty for introducing a gap (default 5)]:int' \
  '-gap_ext[SW penalty for extending a gap (default 2)]:int' \
  '-N[SW penalty for ambiguous letters scored as mismatch]:int' \
  '-F[search only the forward strand]' \
  '-R[search only the reverse-complementary strand]' \
  '-e[E-value threshold (default 1)]:evalue' \
  '-v[verbose output when building the index]' \
  '-id[%id similarity threshold (default 0.97)]:float' \
  '-coverage[%query coverage threshold (default 0.97)]:float' \
  '-de_novo_otu[output FASTA file with de novo reads]' \
  '-otu_map[output OTU map for QIIME make_otu_table.py]' \
  '-passes[three seed-placement intervals L,L/2,3]:intervals' \
  '-edges[nucleotides to add to each read edge (default 4)]:num' \
  '-num_seeds[number of seeds matched before searching LIS (default 2)]:int' \
  '-full_search[search all 0-error and 1-error seed matches]' \
  '-pid[add pid to output file names]' \
  '-a[DEPRECATED number of processing threads (use -threads)]:int' \
  '-threads[number of processing threads to use (default 2)]:int' \
  '-thpp[number of post-processing read:process threads (1:1)]:ratio' \
  '-threp[number of report read:process threads (1:1)]:ratio' \
  '-workdir[workspace directory]:dir:_files -/' \
  '-kvdb[directory for key-value database]:dir:_files -/' \
  '-idx-dir[directory for storing reference index]:dir:_files -/' \
  '-readb[storage for pre-processed reads]:dir:_files -/' \
  '-tmpdir[directory for temporary index-build files]:dir:_files -/' \
  '-interval[index every Nth L-mer (default 1)]:int' \
  '-m[memory in Mbytes for building the index (default 3072)]:mb' \
  '-L[indexing seed length (default 18)]:int' \
  '-max_pos[max positions stored per unique L-mer (default 1000)]:int' \
  '-readfeed[method of accessing reads]:type:(0 1)' \
  '-zip-out[control output compression]:flag:(1 0 -1 true false yes no)' \
  '-index[build reference database index]:flag:(0 1)' \
  '-task[processing task]:task:(0 1 2 3 4 5)' \
  '-dbg-level[debug verbosity level (0-2)]:level:(0 1 2)' \
  '-cmd[launch an interactive session]' \
  '*:file:_files' && ret=0

return ret
