#compdef tpm2_create tpm2_createprimary tpm2_load tpm2_loadexternal tpm2_evictcontrol tpm2_flushcontext
# Documentation: source-direct extraction from upstream
# tpm2-software/tpm2-tools.  Per-tool `struct option topts[]`
# table decoded source-direct from each tools/tpm2_<name>.c.
# Shared common options ($tpm2_common helper array) re-extracted
# source-direct from lib/tpm2_options.c's long_options[] +
# common_short_opts = "T:h::vVQZz" — see R193 HARVEST_LOG entry
# for the full extraction note.
# Reference accessed: 2026-05-30 via gh api.
# tpm2-software tpm2-tools R194 — follow-up to R193's hunt-skip
# on the remaining ~74 tpm2_* binaries.  This round covers the
# key creation/loading family: tpm2_create (TPM2_Create for
# child keys under a parent), tpm2_createprimary (TPM2_
# CreatePrimary for primary keys directly under a hierarchy),
# tpm2_load (TPM2_Load a key into the TPM session), tpm2_load-
# external (TPM2_LoadExternal a key from outside the TPM),
# tpm2_evictcontrol (TPM2_EvictControl to persist/un-persist a
# key in NV storage), tpm2_flushcontext (TPM2_FlushContext to
# evict transient contexts).  Sister tools to R193's tpm2_
# getrandom/getcap/pcrread/hash/nvread/nvwrite already in the
# corpus.

local -a tpm2_common=(
  '(-T --tcti)'{-T+,--tcti=}'[TCTI library + options (e.g. "device:/dev/tpmrm0" or "swtpm:port=2321")]:tcti:'
  '(-h --help)'{-h-,--help=-}'[print help (optional arg = topic)]::topic:'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '(-V --verbose)'{-V,--verbose}'[verbose mode]'
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode]'
  '(-Z --enable-errata)'{-Z,--enable-errata}'[enable TPM2 errata workarounds]'
  '(-z --pwd-session)'{-z,--pwd-session}'[use password-authorized session]'
)

# 4-entry TPM2 hierarchy enum (owner|endorsement|platform|null)
# + 4 single-letter aliases (o|e|p|n) - see R193 HARVEST_LOG.
local -a tpm2_hierarchy=(owner endorsement platform null o e p n)
local -a tpm2_hashalgs=(sha1 sha256 sha384 sha512 sm3_256)
# Common TPM2 key algorithm strings.
local -a tpm2_keyalgs=(rsa rsa1024 rsa2048 rsa3072 rsa4096
                      ecc ecc_nist_p192 ecc_nist_p224 ecc_nist_p256
                      ecc_nist_p384 ecc_nist_p521 ecc_sm2_p256
                      ecc_bn_p256 ecc_bn_p638
                      aes aes128 aes192 aes256
                      keyedhash xor null)

case $service in

  tpm2_create)
    # Create a child key under an existing parent key.
    _arguments -s -S \
      $tpm2_common \
      '(-P --parent-auth)'{-P+,--parent-auth=}'[parent key authorization]:auth:' \
      '(-p --key-auth)'{-p+,--key-auth=}'[new key authorization]:auth:' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm]:alg:($tpm2_hashalgs)' \
      '(-G --key-algorithm)'{-G+,--key-algorithm=}'[key algorithm]:alg:($tpm2_keyalgs)' \
      '(-a --attributes)'{-a+,--attributes=}'[object attributes bitmask (sign,decrypt,fixedtpm,fixedparent,...)]:attrs:' \
      '(-i --sealing-input)'{-i+,--sealing-input=}'[input data file to seal into the new key]:file:_files' \
      '(-L --policy)'{-L+,--policy=}'[authorization policy digest file]:file:_files' \
      '(-u --public)'{-u+,--public=}'[output public-key file]:file:_files' \
      '(-r --private)'{-r+,--private=}'[output private-key file]:file:_files' \
      '(-C --parent-context)'{-C+,--parent-context=}'[parent key context (handle or context file)]:parent:' \
      '(-c --key-context)'{-c+,--key-context=}'[output key context file]:file:_files' \
      '--creation-data=[output creation-data file]:file:_files' \
      '--template-data=[output template-data file (for off-line attestation)]:file:_files' \
      '(-t --creation-ticket)'{-t+,--creation-ticket=}'[output creation-ticket file]:file:_files' \
      '(-d --creation-hash)'{-d+,--creation-hash=}'[output creation-hash file]:file:_files' \
      '(-q --outside-info)'{-q+,--outside-info=}'[outside-info data file (for creation-data binding)]:file:_files' \
      '(-l --pcr-list)'{-l+,--pcr-list=}'[PCR list for creation-data digest (e.g. sha256:0,1,2)]:pcr-list:' \
      '--cphash=[output command-parameter hash for off-line audit]:file:_files' \
      '--rphash=[output response-parameter hash for off-line audit]:file:_files' \
      '(-S --session)'{-S+,--session=}'[authorization session context file]:file:_files' \
      '(-f --format)'{-f+,--format=}'[output format for --public]:format:(tss pem der)' \
      '(-o --output)'{-o+,--output=}'[output file for --format output]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush created child key after operation]'
    ;;

  tpm2_createprimary)
    # Create a primary key directly under a hierarchy.
    _arguments -s -S \
      $tpm2_common \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[hierarchy under which to create the primary]:hierarchy:($tpm2_hierarchy)' \
      '(-P --hierarchy-auth)'{-P+,--hierarchy-auth=}'[hierarchy authorization]:auth:' \
      '(-p --key-auth)'{-p+,--key-auth=}'[new key authorization]:auth:' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm]:alg:($tpm2_hashalgs)' \
      '(-G --key-algorithm)'{-G+,--key-algorithm=}'[key algorithm]:alg:($tpm2_keyalgs)' \
      '(-c --key-context)'{-c+,--key-context=}'[output key context file]:file:_files' \
      '(-L --policy)'{-L+,--policy=}'[authorization policy digest file]:file:_files' \
      '(-a --attributes)'{-a+,--attributes=}'[object attributes bitmask]:attrs:' \
      '(-u --unique-data)'{-u+,--unique-data=}'[unique-data file for deterministic primary derivation]:file:_files' \
      '--creation-data=[output creation-data file]:file:_files' \
      '--template-data=[output template-data file (for off-line attestation)]:file:_files' \
      '(-t --creation-ticket)'{-t+,--creation-ticket=}'[output creation-ticket file]:file:_files' \
      '(-d --creation-hash)'{-d+,--creation-hash=}'[output creation-hash file]:file:_files' \
      '(-q --outside-info)'{-q+,--outside-info=}'[outside-info data file]:file:_files' \
      '(-l --pcr-list)'{-l+,--pcr-list=}'[PCR list for creation-data digest]:pcr-list:' \
      '--cphash=[output command-parameter hash]:file:_files' \
      '(-f --format)'{-f+,--format=}'[output format for --output]:format:(tss pem der)' \
      '(-o --output)'{-o+,--output=}'[output public-key file]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush created primary after operation]'
    ;;

  tpm2_load)
    # Load a previously-created child key into the TPM session.
    _arguments -s -S \
      $tpm2_common \
      '(-P --auth)'{-P+,--auth=}'[parent key authorization]:auth:' \
      '(-u --public)'{-u+,--public=}'[input public-key file]:file:_files' \
      '(-r --private)'{-r+,--private=}'[input private-key file]:file:_files' \
      '(-n --name)'{-n+,--name=}'[output name file]:file:_files' \
      '(-c --key-context)'{-c+,--key-context=}'[output key context file]:file:_files' \
      '(-C --parent-context)'{-C+,--parent-context=}'[parent key context (handle or context file)]:parent:' \
      '--cphash=[output command-parameter hash]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush loaded key after operation]'
    ;;

  tpm2_loadexternal)
    # Load a key whose private/public material is external to
    # the TPM (e.g. from an OpenSSL keyfile).
    _arguments -s -S \
      $tpm2_common \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[hierarchy to load under (null|owner|platform|endorsement)]:hierarchy:($tpm2_hierarchy)' \
      '(-u --public)'{-u+,--public=}'[input public-key file (TSS or PEM)]:file:_files' \
      '(-r --private)'{-r+,--private=}'[input private-key file (TSS or PEM)]:file:_files' \
      '(-c --key-context)'{-c+,--key-context=}'[output key context file]:file:_files' \
      '(-a --attributes)'{-a+,--attributes=}'[object attributes bitmask]:attrs:' \
      '(-L --policy)'{-L+,--policy=}'[authorization policy digest file]:file:_files' \
      '(-p --auth)'{-p+,--auth=}'[key authorization]:auth:' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm]:alg:($tpm2_hashalgs)' \
      '(-G --key-algorithm)'{-G+,--key-algorithm=}'[key algorithm]:alg:($tpm2_keyalgs)' \
      '(-n --name)'{-n+,--name=}'[output name file]:file:_files' \
      '--passin=[passphrase for input PEM/DER file (pass: env: file: fd:)]:passin:' \
      '--cphash=[output command-parameter hash]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush loaded key after operation]' \
      '(-e --rsa_exponent_zero)'{-e,--rsa_exponent_zero}'[force RSA exponent = 0 (use TPM default 65537)]'
    ;;

  tpm2_evictcontrol)
    # Persist or evict a key in TPM NV storage (TPM2_EvictControl).
    _arguments -s -S \
      $tpm2_common \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[hierarchy (owner|platform)]:hierarchy:(owner platform o p)' \
      '(-P --auth)'{-P+,--auth=}'[hierarchy authorization]:auth:' \
      '(-c --object-context)'{-c+,--object-context=}'[object context (handle or context file) to persist/evict]:object:' \
      '(-o --output)'{-o+,--output=}'[output persistent-handle file]:file:_files' \
      '--cphash=[output command-parameter hash]:file:_files' \
      ':persistent handle (hex 0x8100xxxx) — omit to use next available:'
    ;;

  tpm2_flushcontext)
    # Flush a transient or session context out of the TPM.
    _arguments -s -S \
      $tpm2_common \
      '(-t --transient-object)'{-t,--transient-object}'[flush all transient-object contexts]' \
      '(-l --loaded-session)'{-l,--loaded-session}'[flush all loaded-session contexts]' \
      '(-s --saved-session)'{-s,--saved-session}'[flush all saved-session contexts]' \
      '--cphash=[output command-parameter hash]:file:_files' \
      ':context handle (hex or context file) — omit when using -t/-l/-s sweep flags:'
    ;;

esac
