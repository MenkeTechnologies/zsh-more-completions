#compdef quickenv
# Documentation: https://codeberg.org/untitaker/quickenv
# quickenv: an unintrusive environment manager (direnv alternative using shims)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1:command:(reload vars shim unshim exec which help)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      shim|unshim|which)
        _command_names -e && ret=0
        ;;
      exec)
        _command_names -e && ret=0
        ;;
    esac
    ;;
esac

return ret
