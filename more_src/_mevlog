_mevlog() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--color=[color output mode]:mode:(auto always never)' \
        '--format=[output format]:format:(json json-pretty csv table)' \
        '1: :_mevlog_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                query|q)
                    _arguments \
                        '(-b --blocks)'{-b,--blocks}'=[block range (e.g. 22030800\:22030900)]:range:' \
                        '--latest-offset=[get N-offset latest block]:n:' \
                        '--max-range=[maximum allowed range size]:n:' \
                        '--batch-size=[fetch batch size (default 100)]:n:' \
                        '--sql=[custom read-only SQL against local txs DB]:sql:' \
                        '--evm-trace[capture EVM trace]' \
                        '--evm-calls[capture call sequence]' \
                        '--evm-ops[capture opcode-level operations]' \
                        '--evm-state-diff[capture state diff]' \
                        '--rpc-url=[RPC URL override]:url:' \
                        '--chain-id=[chain id override]:id:' && ret=0 ;;
                update-db|chains|chain-info|debug-available|ens-resolve|ens-lookup|mcp|seed-db|tui)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mevlog_commands] )) ||
_mevlog_commands() {
    local -a commands
    commands=(
        'query:query txs within a block range'
        'q:query (alias)'
        'update-db:update signatures database from Sourcify'
        'chains:list all available chains from ChainList'
        'chain-info:show detailed chain information'
        'debug-available:check if RPC supports debug tracing'
        'ens-resolve:resolve an ENS name to an address'
        'ens-lookup:reverse-resolve an address to an ENS name'
        'mcp:start MCP server (feature mcp)'
        'seed-db:[Dev] seed signatures DB (feature seed-db)'
        'tui:run TUI (feature tui)'
    )
    _describe -t commands 'mevlog command' commands
}

_mevlog "$@"
