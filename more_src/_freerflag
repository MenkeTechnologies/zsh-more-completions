#compdef freerflag
# freerflag — assign a free-R flag column to reflection data (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output MTZ]:file:_files -g "*.mtz"' \
  'FREERFRAC[fraction flagged as free]:frac:' \
  'SEED[seed RNG with current time]' \
  'COMPLETE[extend existing free-R flags]:opt:' \
  'UNIQUE[complete list of allowed reflections]' \
  'RESOL[maximum resolution]:dmax:' \
  'OBL[twin obliquity angle]:deg:' \
  'NOSYM[disable symmetry considerations]' \
  'NOTWIN[exclude twin laws]' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
