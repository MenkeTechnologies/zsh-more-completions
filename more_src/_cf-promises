#compdef cf-promises
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-promises.html
# Source: cfengine/core cf-promises/cf-promises.c — verify CFEngine policy syntax.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w --workdir)'{-w+,--workdir=}'[override work directory]:dir:_directories' \
    '--eval-functions[evaluate functions during syntax checking]' \
    '--show-classes[show discovered classes]' \
    '--show-vars[show discovered variables]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-b --bundlesequence)'{-b+,--bundlesequence=}'[bundlesequence to verify]:bundles:_default' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-n --dry-run)'{-n,--dry-run}'[dry-run, no changes]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-f --file)'{-f+,--file=}'[alternative input file]:file:_files' \
    '(-D --define)'{-D+,--define=}'[define classes at startup]:classes:_default' \
    '(-N --negate)'{-N+,--negate=}'[undefine classes at startup]:classes:_default' \
    '(-I --inform)'{-I,--inform}'[print basic info about system changes]' \
    '(-x --diagnostic)'{-x,--diagnostic}'[internal diagnostics (devs)]' \
    '(-p --policy-output-format)'{-p+,--policy-output-format=}'[parsed policy output format]:format:(none cf json cf-full json-full)' \
    '(-s --syntax-description)'{-s,--syntax-description}'[describe syntax elements]' \
    '(-c --full-check)'{-c,--full-check}'[full policy integrity checks]' \
    '(-W --warn)'{-W+,--warn=}'[enable warnings or convert to errors]:warns:_default' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '(-T --tag-release)'{-T+,--tag-release=}'[tag directory with validation+release id]:dir:_directories' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps]' \
    '--ignore-preferred-augments[skip def_preferred.json]' \
    '*--log-modules=[detailed debug logging for module]:module:_default' \
    && ret=0

return ret
