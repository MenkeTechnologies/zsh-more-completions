#compdef mfsgettrashtime
# Documentation: https://linux.die.net/man/1/mfsgettrashtime
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mfsgettrashtime: show trashtime for files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '-r[recursive]' \
  '-n[numeric output]' \
  '-H[1024-based human readable]' \
  '-h[1000-based human readable]' \
  '-k[in KB]' \
  '-m[in MB]' \
  '-g[in GB]' \
  '-v[verbose]' \
  '*:file/dir:_files' && ret=0
return ret
