#compdef gocsv

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'autoincrement:add auto-incrementing column'
      'behead:remove header row'
      'cap:add header row'
      'clean:clean CSV formatting'
      'delimiter:change delimiter'
      'describe:describe columns'
      'dimensions:show number of rows and columns'
      'filter:filter rows'
      'head:show first N rows'
      'headers:show column headers'
      'join:join two CSVs'
      'ncol:print number of columns'
      'nrow:print number of rows'
      'rename:rename columns'
      'replace:replace values'
      'sample:random sample of rows'
      'select:select columns'
      'sort:sort rows'
      'split:split into multiple files'
      'sql:run SQL query against CSV'
      'stack:stack multiple CSVs'
      'stats:calculate column statistics'
      'tail:show last N rows'
      'top:show most frequent values'
      'transpose:transpose rows and columns'
      'tsv:convert to TSV'
      'unique:remove duplicate rows'
      'view:pretty print CSV'
      'xlsx:convert Excel to CSV'
    )
    _describe -t commands 'gocsv command' commands && ret=0
    ;;
esac

return ret
