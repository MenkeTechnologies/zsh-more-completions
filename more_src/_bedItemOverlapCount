#compdef bedItemOverlapCount
# Documentation: https://github.com/ucscGenomeBrowser/kent/blob/master/src/hg/bedItemOverlapCount/bedItemOverlapCount.c
# count number of times a base is overlapped by the items in a bed file; output is bedGraph 4 to stdout

local ret=1

_arguments -s -S \
  '-zero[add blocks with zero count]' \
  '-bed12[expect bed12 and count based on blocks]' \
  '-max[if counts per base overflows set to max instead of exiting]' \
  '-outBounds[output min/max to stderr]' \
  '-chromSize=[read chrom sizes from file instead of database]:size file:_files' \
  '-host=[mysql host used to get chrom sizes]:hostname:_hosts' \
  '-user=[mysql user]:username:' \
  '-password=[mysql password]:password:' \
  '*:database / bed:_files' && ret=0

return ret
