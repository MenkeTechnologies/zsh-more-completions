#compdef chopper
# Documentation: https://github.com/wdecoster/chopper
# rust tool for quality/length filtering and trimming of long reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-q --quality)'{-q,--quality}'[minimum Phred average quality score]:quality:' \
  '--maxqual[maximum Phred average quality score]:quality:' \
  '(-l --minlength)'{-l,--minlength}'[minimum read length]:length:' \
  '--maxlength[maximum read length]:length:' \
  '--mingc[minimum GC content]:gc:' \
  '--maxgc[maximum GC content]:gc:' \
  '(-c --contam)'{-c,--contam}'[filter contaminants against a fasta]:fasta:_files' \
  '--trim-approach[trimming strategy]:approach:(fixed-crop trim-by-quality best-read-segment split-by-low-quality)' \
  '--cutoff[minimum quality score threshold for trimming]:cutoff:' \
  '--split-window[consecutive low-quality bases required to split]:window:' \
  '--headcrop[trim N bases from the start of each read]:n:' \
  '--tailcrop[trim N bases from the end of each read]:n:' \
  '(-t --threads)'{-t,--threads}'[use N parallel threads]:threads:' \
  '(-i --input)'{-i,--input}'[input filename, stdin if unspecified]:input:_files' \
  '--inverse[output the opposite of the normal results]' && ret=0

return ret
