#compdef code_saturne
# Documentation: https://www.code-saturne.org/documentation/8.0/doxygen/src/cs_ug_run_computation.html
# code_saturne general-purpose CFD solver command launcher

local ret=1
local -a cmds
cmds=(
  'run:run a calculation'
  'submit:submit a calculation to a batch system'
  'create:create study and case directories'
  'info:display version and system information'
  'gui:launch the graphical user interface'
  'compile:compile user-defined functions'
  'bdump:query and dump checkpoint file contents'
  'bdiff:compare two checkpoint files'
  'studymanager:manage parametric studies'
)

if (( CURRENT == 2 )); then
  _describe -t commands 'code_saturne command' cmds && ret=0
  return ret
fi

case $words[2] in
  run|submit)
    _arguments -s \
      '(-h --help)'{-h,--help}'[show help]' \
      '--stage[execute only the data staging step]' \
      '--initialize[prepare execution but do not start]' \
      '--compute[run the computation step]' \
      '--finalize[run the finalization step]' \
      '(-p --param)'{-p,--param}'=[parameter (setup XML) file]:param file:_files -g "*.xml"' \
      '--case=[case directory]:case:_files -/' \
      '--id=[run identifier under RESU]:id:' \
      '--id-prefix=[prefix for run id]:prefix:' \
      '--id-suffix=[suffix for run id]:suffix:' \
      '--suggest-id[print a suggested run id and exit]' \
      '(-n --nprocs)'{-n,--nprocs}'=[number of MPI ranks]:nprocs:' \
      '--nthreads=[number of OpenMP threads per rank]:n:' \
      '--coupling=[coupling parameters file]:file:_files' \
      '--dest=[top run directory destination]:dir:_files -/' \
      '--force[force overwrite of existing run directory]' && ret=0
    ;;
  create)
    _arguments -s \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-s --study)'{-s,--study}'=[study directory name]:study:' \
      '(-c --case)'{-c,--case}'=[case directory name (repeatable)]:case:' \
      '--copy-from=[copy case from existing directory]:dir:_files -/' \
      '--copy-ref[copy reference user files and examples]' \
      '--noref[do not copy reference user files]' \
      '*:directory:_files -/' && ret=0
    ;;
  info)
    _arguments -s \
      '(-h --help)'{-h,--help}'[show help]' \
      '--version[print version number]' \
      '--modules[list available modules]' \
      '(-g --guide)'{-g,--guide}'=[open a documentation guide]:guide:(user theory developer studymanager)' && ret=0
    ;;
  *)
    _arguments '(-h --help)'{-h,--help}'[show help]' '*:arg:_files' && ret=0
    ;;
esac

return ret
