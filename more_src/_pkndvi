#compdef pkndvi
# Documentation: https://pktools.nongnu.org/html/pkndvi.html
# calculate normalized difference vegetation index

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[input image file]:file:_files' \
  '(-o --output)'{-o,--output}'[output image file containing ndvi]:file:_files' \
  '(-b --band)'{-b,--band}'[Bands to be used for vegetation index (see rule option)]:value:' \
  '*:file:_files' && ret=0

return ret
