#compdef ani-cli ani-cli-ru
# Documentation: https://github.com/pystardust/ani-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-c --continue)'{-c,--continue}'[continue from history]' \
  '(-d --download)'{-d,--download}'[download instead of playing]' \
  '(-D --delete)'{-D,--delete}'[delete history]' \
  '(-l --logview)'{-l,--logview}'[show logs]' \
  '(-s --syncplay)'{-s,--syncplay}'[use Syncplay]' \
  '(-S --select-nth)'{-S,--select-nth}'[select nth entry]' \
  '(-q --quality)'{-q,--quality}'[video quality]:quality:' \
  '(-v --vlc)'{-v,--vlc}'[use VLC]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-e --episode -r --range)'{-e,--episode,-r,--range}'[episodes or range]:range:' \
  '--dub[play dubbed version]' \
  '--rofi[use rofi for menu]' \
  '--dmenu[use dmenu for menu]' \
  '--skip[use ani-skip for intro]' \
  '--no-detach[do not detach player]' \
  '--exit-after-play[exit after playback]' \
  '--skip-title=[ani-skip query title]:title:' \
  '(-N --nextep-countdown)'{-N,--nextep-countdown}'[countdown to next episode]' \
  '(-U --update)'{-U,--update}'[update script]' \
  '*::query: _default'
