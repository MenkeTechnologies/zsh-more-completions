#compdef sarif
# Documentation: https://man.archlinux.org/search?q=sarif
# Reference accessed: 2026-05-16

# Zsh completion for sarif

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*:: :_files' && ret=0

return ret
