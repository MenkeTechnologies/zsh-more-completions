#compdef msp430-gdb msp430-elf-gdb
# _msp430-gdb — Texas Instruments msp430-elf-gdb CLI for the TI MSP430 bare-metal cross-debugger supporting target remote MSP-FET FET-Pro430 mspdebug Spy-Bi-Wire JTAG flash load TUI semihosting (TI team, C); getopt
# upstream: https://www.ti.com/tool/MSP430-GCC-OPENSOURCE

_msp430-gdb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--batch[exit after command file]' \
        '--batch-silent[batch silent]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--silent[silent]' \
        '-nh[no history]' \
        '-nx[no init files]' \
        '-n[no init files]' \
        '-c+[corefile]:file:_files' \
        '-p+[pid]:n:_pids' \
        '-x+[script file]:file:_files -g "*.gdb *.py"' \
        '--command=+[script file]:file:_files -g "*.gdb *.py"' \
        '-eval-command=+[cmd]:str:' \
        '-ex+[cmd]:str:' \
        '-tui[use TUI]' \
        '--interpreter=+[i]:i:(console mi mi2 mi3 cli tui)' \
        '-i+[i]:i:(console mi mi2 mi3 cli tui)' \
        '--directory=+[dir]:dir:_files -/' \
        '--cd=+[dir]:dir:_files -/' \
        '--baud=+[baud]:n:' \
        '-b+[baud]:n:' \
        '--symbols=+[file]:file:_files' \
        '-s+[file]:file:_files' \
        '--write[allow target write]' \
        '*:executable:_files'
}

_msp430-gdb "$@"
