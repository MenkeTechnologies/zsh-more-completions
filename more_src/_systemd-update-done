#compdef systemd-update-done
# _systemd-update-done (systemd marker tool that writes /etc/.updated and /var/.updated stamps after the boot-time update procedure has finished; reads no config and takes no positional arguments — invoked once during boot by systemd-update-done.service)
# upstream: https://github.com/systemd/systemd (src/update-done)
# Argument shape from systemd src/update-done/update-done.c on tip.

_systemd-update-done() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-update-done "$@"
