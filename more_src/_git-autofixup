#compdef git-autofixup

# Zsh completion for git-autofixup - create fixup commits for staged changes

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-h --hierarchical-search)'{-h,--hierarchical-search}'[use upstream search strategy]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-s --strict)'{-s,--strict}'=[set strictness level]:level:(0 1 2)' \
  '(-e --exit-code)'{-e,--exit-code}'[use meaningful exit codes]' \
  '--target=[target ref for fixup commits]:ref:__git_references' \
  '1:upstream revision:__git_references'

# Helper for git references if available
(( $+functions[__git_references] )) || __git_references() {
  _alternative \
    'branches:branch:compadd $(git branch --format="%(refname:short)" 2>/dev/null)' \
    'tags:tag:compadd $(git tag -l 2>/dev/null)' \
    'commits:recent commit:compadd $(git log --oneline -20 --format="%h" 2>/dev/null)'
}
