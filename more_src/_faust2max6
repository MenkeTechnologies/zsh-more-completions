#compdef faust2max6
# Documentation: https://faustdoc.grame.fr/manual/tools/
# Reference accessed: 2026-06-21
# Verified: flags parsed by the faust2max6 script in grame-cncm/faust tools/faust2appls.

local ret=1

_arguments -s -S \
  '(-help -h)'{-help,-h}'[show help]' \
  '-opt+[optimize for cpu]:cpu:(native generic)' \
  '-native[optimize for the host cpu]' \
  '-single[use single precision floats]' \
  '-nvoices+[number of polyphonic voices]:n:' \
  '-effect+[global output effect dsp]:file:_files -g "*.dsp"' \
  '-midi[add MIDI control]' \
  '-osc[add OSC control]' \
  '-soundfile[add soundfile resources]' \
  '-soundfile-dynamic[add dynamic soundfile resources]' \
  '-mc[multichannel mode]' \
  '-us+[up-sampling factor]:n:' \
  '-ds+[down-sampling factor]:n:' \
  '-filter+[resampling filter type]:type:' \
  '-nopatch[do not generate the Max patch]' \
  '-nopost[do not post-process]' \
  '-universal[build a universal binary]' \
  '-A+[architecture include path]:dir:_files -/' \
  '*:dsp file:_files -g "*.dsp"' && ret=0

return ret
