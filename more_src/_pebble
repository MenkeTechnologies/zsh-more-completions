#compdef pebble

# Zsh completion for Pebble - ACME test server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-config+[config file]:file:_files' \
  '-strict[enable strict mode]' \
  '-dnsserver+[DNS server address]:address' \
  '-httpport+[HTTP challenge port]:port' \
  '-httpsport+[HTTPS listen port]:port' \
  '-tlsport+[TLS-ALPN challenge port]:port' \
  '-managementport+[management interface port]:port' \
  '-ocspresponder+[OCSP responder URL]:url' \
  '-challenge+[challenge type to use]:challenge:(http-01 dns-01 tls-alpn-01)' \
  && ret=0

return ret
