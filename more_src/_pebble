#compdef pebble
# Documentation: https://github.com/letsencrypt/pebble/blob/main/cmd/pebble/main.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-config[Pebble configuration file]:file:_files' \
  '-strict[enable strict mode]' \
  '-dnsserver[custom DNS server address]:address:' \
  '-version[show version]' \
  && ret=0

return ret
