#compdef gh-copilot

_gh_copilot_commands() {
  local -a commands=(
    'suggest:suggest a command'
    'explain:explain a command'
    'alias:configure shell aliases for Copilot CLI'
  )
  _describe 'command' commands
}

_gh_copilot() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '-h[display help]' \
    '--help[display help]' \
    '-v[display version]' \
    '--version[display version]' \
    '1:command:_gh_copilot_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        suggest)
          _arguments \
            '-t[target shell type]:type:(shell gh git)' \
            '*:query'
          ;;
        explain)
          _arguments '*:command to explain'
          ;;
        alias)
          _arguments \
            '1:shell:(bash zsh powershell)'
          ;;
      esac
      ;;
  esac
}

_gh_copilot "$@"
