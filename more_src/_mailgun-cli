#compdef mailgun mailgun-cli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'send:send a message'
  'mailing-list:mailing list commands'
  'event:event commands'
  'route:route commands'
  'webhook:webhook commands'
  'domain:domain commands'
  'stat:statistics'
  'tag:tag commands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--api-key=[API key]:k:' \
  '*-k+[API key]:k:' \
  '*--domain=[domain]:d:' \
  '*-d+[domain]:d:' \
  '*--region=[region]:r:(us eu)' \
  '*--api-base=[API base URL]:url:' \
  '*--debug[debug]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mailgun command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (send)
        _arguments \
          '*--from=[from]:addr:' \
          '*--to=[to]:addr:' \
          '*--cc=[cc]:addr:' \
          '*--bcc=[bcc]:addr:' \
          '*--subject=[subject]:s:' \
          '*--text=[text body]:t:' \
          '*--html=[html body]:h:' \
          '*--template=[template]:t:' \
          '*--tag=[tag]:t:' \
          '*--attachment=[attachment]:file:_files' \
          '*--dkim=[DKIM]:b:(yes no)' \
          '*--testmode[test mode]' \
          '*--tracking=[tracking]:b:(yes no)' \
          '*--scheduled-at=[scheduled at]:t:' \
          '*: :' && ret=0 ;;
      (mailing-list)
        _arguments \
          '1:subcommand:(create list members add-member remove-member delete)' \
          '*: :' && ret=0 ;;
      (event)
        _arguments \
          '1:subcommand:(list)' \
          '*: :' && ret=0 ;;
      (route)
        _arguments \
          '1:subcommand:(create list update delete)' \
          '*: :' && ret=0 ;;
      (domain)
        _arguments \
          '1:subcommand:(create list update delete verify)' \
          '*: :' && ret=0 ;;
      (webhook)
        _arguments \
          '1:subcommand:(create list update delete)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
