#compdef ufw-cli ufw-frontend
# _ufw-cli — ufw / Ubuntu Uncomplicated Firewall command-line wrapper (idempotent rule manager on top of iptables/nftables; subcommands: enable, disable, reload, default, allow, deny, reject, limit, delete, insert, route, status (numbered|verbose), show (raw|builtins|before-rules|user-rules|after-rules|logging-rules|listening|added), logging on|off|low|medium|high|full, reset; --force skip prompts, --dry-run print without applying)
# upstream: https://launchpad.net/ufw
# Subcommands from ufw src/parser.py on tip.

_ufw-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--force[skip prompts]' \
        '--dry-run[print without applying]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ufw command' '(enable disable reload default allow deny reject limit delete insert route status show logging reset version help)' ;;
        args)
            case $line[1] in
                default) _describe -t commands 'default value' '(deny allow reject)' ;;
                logging) _describe -t commands 'logging level' '(on off low medium high full)' ;;
                status) _describe -t commands 'status format' '(numbered verbose)' ;;
                show) _describe -t commands 'show target' '(raw builtins before-rules user-rules after-rules logging-rules listening added)' ;;
                route) _describe -t commands 'route action' '(allow deny reject limit delete status show)' ;;
            esac
            ;;
    esac
}

_ufw-cli "$@"
