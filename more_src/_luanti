#compdef luanti
# Documentation: https://docs.luanti.org/luanti/command-line/
# Reference accessed: 2026-05-16

# Luanti: open-source voxel game engine (renamed from Minetest)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--address=[connect to address]:host:_hosts' \
  '--port=[port]:port:' \
  '--name=[player name]:name:' \
  '--password=[password]:pass:' \
  '--password-file=[password file]:file:_files' \
  '--server[run as server]' \
  '--world=[world directory]:dir:_files -/' \
  '--worldname=[world name]:name:' \
  '--gameid=[game id]:game:' \
  '--config=[config file]:file:_files' \
  '--info[info messages]' \
  '--verbose[verbose]' \
  '--trace[trace messages]' \
  '--logfile=[log file]:file:_files' \
  '--quiet[print only errors]' \
  '--color=[colorize output]:val:(always never auto)' \
  '--migrate=[migrate map backend]:backend:(sqlite3 leveldb redis postgresql files dummy)' \
  '--migrate-players=[migrate player backend]:backend:' \
  '--migrate-auth=[migrate auth backend]:backend:' \
  '--migrate-mod-storage=[migrate mod storage backend]:backend:' \
  '--terminal[use terminal interface]' \
  '--map-dir=[map directory]:dir:_files -/' \
  '--go[start game immediately]' \
  '--gameid-test=[run engine tests for game]:game:' \
  '--run-unittests[run unit tests]' \
  '--run-benchmarks[run benchmarks]' \
  '--test-module=[run test module]:module:' \
  '--recompress[recompress data]' \
  '--random-input[stress test input]' \
  '*::minetest args:_files' && ret=0
return ret
