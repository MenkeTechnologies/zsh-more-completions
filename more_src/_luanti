#compdef luanti
# Documentation: https://github.com/luanti-org/luanti/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: extracted set_allowed_options() in main.cpp (35 named options)

# Luanti (formerly Minetest): open-source voxel game engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help and quit]' \
  '(- *)--version[show version and quit]' \
  '--config=[config file]:file:_files' \
  '--port=[set network port]:port:' \
  '--run-unittests[run unit tests and quit]' \
  '--run-tests[run all tests and quit]' \
  '--run-benchmarks[run benchmarks and quit]' \
  '--test-module=[run a specific test module]:module:' \
  '--map-dir=[map directory]:dir:_files -/' \
  '--world=[world directory or name]:world:' \
  '--worldname=[world by name]:name:' \
  '--worldlist=[world list strategy]:strategy:' \
  '--quiet[print only errors]' \
  '--color=[colorize output]:val:(always never auto)' \
  '--log-timestamp=[log timestamp format]:fmt:' \
  '--info[print info messages]' \
  '--verbose[print verbose messages]' \
  '--trace[enable trace logging]' \
  '--debugger[attach to a debugger]' \
  '--logfile=[log file]:file:_files' \
  '--gameid=[set/list game ids (use "list")]:game:' \
  '--migrate=[migrate map backend to another]:backend:' \
  '--migrate-players=[migrate player backend to another]:backend:' \
  '--migrate-auth=[migrate auth backend to another]:backend:' \
  '--migrate-mod-storage=[migrate mod-storage backend]:backend:' \
  '--terminal[interactive terminal in dedicated server mode]' \
  '--recompress[recompress map blocks and quit]' \
  '--address=[host or IP to connect to as client]:host:_hosts' \
  '--random-input[fuzz with random input events]' \
  '--server[run as dedicated server]' \
  '--name=[set player name]:name:' \
  '--password=[set client password]:pass:' \
  '--password-file=[file containing client password]:file:_files' \
  '--console[open a console window (Windows)]' \
  '--go[skip the main menu and start immediately]' \
  '*::extra args:_files' && ret=0
return ret
