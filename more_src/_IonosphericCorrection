#compdef IonosphericCorrection
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/s1tbx-op-insar/src/main/java/org/esa/s1tbx/insar/gpf/IonosphericCorrectionOp.java
# ESA SNAP gpt IonosphericCorrection operator - correct ionospheric phase in interferograms

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-Psigma=[standard deviation for Gaussian filter]:sigma' \
  '-PcoherenceThreshold=[coherence threshold]:threshold' \
  '-PminCoherence=[minimum coherence for output mask]:coherence' \
  '*:graph xml:_files' && ret=0

return ret
