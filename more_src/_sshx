#compdef sshx

# Zsh completion for sshx - Terminal sharing over the web

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --shell)'{-s,--shell}'[shell command to use]:shell command' \
  '(-n --name)'{-n,--name}'[session name]:name' \
  '--server=[server address]:server address' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '*:command to run'
