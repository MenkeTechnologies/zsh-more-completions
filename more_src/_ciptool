#compdef ciptool
# _ciptool — BlueZ ciptool (Common ISDN Profile (CIP) helper; subcommands: show currently-connected sessions, search nearby CIP-capable peers, connect <BD_ADDR> <PSM>, release <BD_ADDR>; -i hciX source device, -h help)
# upstream: https://github.com/bluez/bluez (tools/ciptool.c)
# Flags from bluez tools/ciptool.c on tip.

_ciptool() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX source]:device:' \
        '1:command:(show search connect release)' \
        '*:argument:'
}

_ciptool "$@"
