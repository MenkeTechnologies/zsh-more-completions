#compdef fbserv
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=fbserv&sektion=1
# BRL-CAD framebuffer server

local ret=1

_arguments -s \
  '-s[square framebuffer size in pixels]:size' \
  '-w[framebuffer width]:width' \
  '-n[framebuffer height]:height' \
  '-p[port number]:port' \
  '-F[framebuffer device to use]:device' \
  '-v[verbose output]' \
  '*::args:_default' && ret=0

return ret
