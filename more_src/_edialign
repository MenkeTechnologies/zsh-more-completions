#compdef edialign

# EMBOSS edialign: local multiple alignment using DIALIGN method
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[unaligned sequence(s)]:sequence USA:_files' \
  '-nucmode=[nucleotide weighting mode]:mode:(0 1 2 3 4)' \
  '-overlapweights[use overlap weights]' \
  '-strict[strict alignment - report only similar regions]' \
  '-thresholdscore=[threshold T for diagonal scoring]:score:' \
  '-anchorfile=[anchor file (alignment positions to fix)]:file:_files' \
  '-translation[align as translated proteins]' \
  '-translationtable=[NCBI genetic code]:code:(0 1 2 3 4 5 6 9 10 11 12 13 14 15 16 21 22 23)' \
  '-iterations=[number of iterations]:n:' \
  '-noiterations[skip iterative refinement]' \
  '-outseq=[output alignment file]:file:_files' \
  '-outfile=[diagonals output file]:file:_files' \
  '-mask[mask sequences with low-scoring residues]' \
  '*:sequence USA:_files' && ret=0
return ret
