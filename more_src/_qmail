#compdef qmail
# Documentation: https://man.archlinux.org/search?q=qmail
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start qmail'
  'stop:stop qmail'
  'restart:restart qmail'
  'reload:reload config'
  'status:show status'
  'pause:pause queue'
  'cont:continue queue'
  'flush:flush queue'
  'queue:show queue stats'
  'doqueue:run queue'
  'stat:queue stats'
  'cdb:rebuild cdb files'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'qmail command' commands && ret=0 ;;
esac

return ret
