#compdef balena

# Zsh completion for balena (balena CLI for IoT fleet management)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Login to balena'
  'logout:Logout from balena'
  'whoami:Display account information'
  'app:Manage applications (deprecated, use fleets)'
  'fleet:Manage fleets'
  'device:Manage devices'
  'devices:List all devices'
  'env:Manage device/fleet environment variables'
  'keys:List SSH keys'
  'key:Manage SSH keys'
  'logs:Show device logs'
  'push:Start a build and deploy to a fleet or local device'
  'ssh:SSH into a device'
  'tunnel:Create a network tunnel'
  'build:Build a container image'
  'deploy:Deploy a container image'
  'join:Move a device to a fleet'
  'leave:Remove a device from a fleet'
  'local:Local device operations'
  'note:Set device note'
  'os:Manage OS images'
  'config:Manage device/fleet configuration'
  'preload:Preload an OS image with a release'
  'release:Manage releases'
  'scan:Scan for local balenaOS devices'
  'settings:Print current settings'
  'support:Access support'
  'tag:Manage device/fleet tags'
  'util:Utility commands'
  'version:Display version'
)

_arguments -s -S -C \
  '--help[Print help]' \
  '--version[Print version]' \
  '--debug[Print additional debug info]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'balena command' commands && ret=0
    ;;
  args)
    case $words[1] in
      push)
        _arguments -s -S \
          '--fleet=[Fleet name or slug]:fleet' \
          '--device=[Device UUID for local push]:uuid' \
          '(-s --source)'{-s,--source}'=[Source directory]:dir:_files -/' \
          '--emulated[Build for emulated architecture]' \
          '--dockerfile=[Path to Dockerfile]:file:_files' \
          '--nocache[Do not use build cache]' \
          '--nolive[Disable livepush]' \
          '--detached[Run build in background]' \
          '--release-tag=[Set release tags]:tag' \
          ':fleet or device' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '--port=[SSH port]:port' \
          '--noproxy[Do not use proxy]' \
          '-s+[Service to connect to]:service' \
          '--service=[Service to connect to]:service' \
          ':device UUID or IP' && ret=0
        ;;
      logs)
        _arguments -s -S \
          '--tail[Continuously stream output]' \
          '-s+[Service filter]:service' \
          '--service=[Service filter]:service' \
          '--system[Show system logs]' \
          ':device UUID' && ret=0
        ;;
      devices)
        _arguments -s -S \
          '--fleet=[Filter by fleet]:fleet' \
          '--json[Output in JSON]' && ret=0
        ;;
      fleet)
        local -a fleet_cmds=(
          'create:Create a fleet'
          'list:List fleets'
          'rm:Remove a fleet'
          'rename:Rename a fleet'
          'restart:Restart fleet services'
          'purge:Purge data from all devices'
        )
        _describe -t fleet_cmds 'fleet subcommand' fleet_cmds && ret=0
        ;;
      env)
        local -a env_cmds=(
          'add:Add environment variable'
          'rename:Rename environment variable'
          'rm:Remove environment variable'
          'list:List environment variables'
        )
        _describe -t env_cmds 'env subcommand' env_cmds && ret=0
        ;;
      login)
        _arguments -s -S \
          '--web[Login via web authorization]' \
          '--token=[Login with an auth token]:token' \
          '--credentials[Login with email/password]' \
          '--email=[Account email]:email' \
          '--password=[Account password]:password' && ret=0
        ;;
    esac
    ;;
esac

return ret
