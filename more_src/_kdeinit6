#compdef kdeinit6
# Documentation: https://manpages.debian.org/testing/kinit/kdeinit5.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream kdeinit5(8) manpage (kinit; kdeinit6 shares the
# same launcher option set). SYNOPSIS:
#   kdeinit5 [--help] [[--no-fork]|[--no-kded]|[--suicide]] [[+programs]|[programs]]

# kdeinit6: KDE Frameworks 6 process launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help about options]' \
  '--no-fork[do not exit until all executed programs end]' \
  '--no-kded[do not start kded]' \
  '--suicide[terminate when no KDE applications are left running]' \
  '*:program:_command_names' && ret=0
return ret
