# kdeinit6: KDE Frameworks 6 process launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--no-fork[do not fork into background]' \
  '--no-kded[do not start kded6]' \
  '--suicide[exit after a few seconds (testing)]' && ret=0
return ret
