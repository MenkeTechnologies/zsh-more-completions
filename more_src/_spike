#compdef spike riscv-isa-sim
# Documentation: https://man.archlinux.org/search?q=spike
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-d[interactive debug mode]' \
  '-g[track committed instructions for spike-history]' \
  '-l[generate a log of execution]' \
  '-p+[number of harts]:n:' \
  '-m+[memory size in MiB]:mb:' \
  '-s[do not auto-init system]' \
  '-H[start halted, allowing host to attach]' \
  '--isa=[RISC-V ISA string]:isa:(RV32IMAFDC RV64IMAFDC RV32IMAFDCV RV64IMAFDCV RV32GC RV64GC)' \
  '--priv=[supported privilege modes]:p:(M MU MSU)' \
  '--varch=[vector arch string]:varch:' \
  '--pc=[start address hex]:hex:' \
  '--hartids=[hart IDs csv]:list:' \
  '--ic=[I-cache S:W:B]:cache:' \
  '--dc=[D-cache S:W:B]:cache:' \
  '--l2=[L2 cache S:W:B]:cache:' \
  '--big-endian[big endian]' \
  '--device=[plugin spec name,addr,args]:dev:' \
  '--rbb-port=[remote bitbang port]:port:' \
  '--initrd=[initrd image]:file:_files' \
  '--bootargs=[boot args]:args:' \
  '--real-time-clint[use real time CLINT]' \
  '--triggers=[trigger module]:n:' \
  '--dm-progsize=[debug module program size]:n:' \
  '--dm-sba=[debug module SBA support]:n:' \
  '--dm-auth[enable debug module auth]' \
  '--dmi-rti=[DMI run-test idle cycles]:n:' \
  '--dm-abstract-rti=[DM abstract RTI]:n:' \
  '--dm-no-hasel[no hasel field]' \
  '--dm-no-abstract-csr[no CSR access]' \
  '--dm-no-halt-groups[no halt groups]' \
  '--dm-no-impebreak[no impebreak]' \
  '--blocksz=[max snoop bytes per check]:n:' \
  '--dump-dts[dump device tree spec]' \
  '--dtb=[device tree blob]:file:_files' \
  '--kernel=[kernel image]:file:_files' \
  '--log-cache-miss[log cache misses]' \
  '--log-commits[log committed instructions]' \
  '--log=[log to file]:file:_files' \
  '--abstract-rti=[abstract command RTI]:n:' \
  '--extension=[extension lib]:lib:' \
  '*:elf or bin:_files' && ret=0

return ret
