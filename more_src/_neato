#compdef neato
# Documentation: graphviz.org/doc/info/command.html
# Source: GraphViz neato — spring-model graph layout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a formats
formats=(
    bmp canon cgimage cmap cmapx cmapx_np dot dot_json eps exr fig
    gd gd2 gif gv icns ico imap imap_np ismap jp2 jpe jpeg jpg
    json json0 kitty kittyz pct pdf pic pict plain plain-ext png pov
    ps ps2 psd sgi svg svg_inline svgz tga tif tiff tk vrml
    vt wbmp webp xdot xdot1.2 xdot1.4 xdot_json
)

_arguments -s \
    "-T+[output format]:format:(${formats[@]})" \
    '-o+[output file]:file:_files' \
    '-O[auto-generate filename from input + -T]' \
    '*-G-[graph attribute]:name[=value]:' \
    '*-N-[default node attribute]:name[=value]:' \
    '*-E-[default edge attribute]:name[=value]:' \
    '*-A-[attributes for graph/nodes/edges (v13.1+)]:name[=value]:' \
    '-K+[override layout engine]:engine:(dot neato twopi circo fdp sfdp osage patchwork)' \
    '-n+[use existing positions (1=interp, 2=verbatim)]:n:(1 2)' \
    '-s+[input scale (default 72)]:scale:' \
    '-y[invert y-axis]' \
    '(- *)-V[show version]' \
    '-v[verbose]' \
    '(- *)-?[show help]' \
    '-q[suppress warnings]' \
    '-P[generate plugin configuration graph]' \
    '*-l+[include device-specific library text]:library:_files' \
    '-x[prune isolated nodes]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
