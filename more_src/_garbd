#compdef garbd
# Documentation: https://galeracluster.com/library/documentation/arbitrator.html
# Galera arbitrator daemon for an even-numbered Galera cluster

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-d --daemon)'{-d,--daemon}'[become daemon]' \
  '(-a --address)'{-a,--address}'+[group address in Galera format]:address:' \
  '(-g --group)'{-g,--group}'+[group name]:group:' \
  '(-l --log)'{-l,--log}'+[path to log file]:path:_files' \
  '(-c --cfg)'{-c,--cfg}'+[path to configuration file]:path:_files' \
  '(-o --options)'{-o,--options}'+[GCS/GCOMM option list]:options:' \
  '--sst=[SST request string to trigger state dump]:request:' \
  '--donor=[SST donor name for state dump]:donor:' && ret=0

return ret
