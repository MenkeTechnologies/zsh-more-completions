#compdef irrecord
# Documentation: https://manpages.debian.org/bookworm/lirc/irrecord.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm irrecord(1) manpage OPTIONS section.

# irrecord: record LIRC configuration files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --analyse)'{-a,--analyse}'[analyse raw_codes config]' \
  '(-u --update)'{-u,--update}'[add buttons to existing config]' \
  '(-f --force)'{-f,--force}'[force raw mode]' \
  '(-n --disable-namespace)'{-n,--disable-namespace}'[disable namespace checks]' \
  '(-l --list-namespace)'{-l,--list-namespace}'[list valid button names]' \
  '(-H --driver)'{-H,--driver=}'[driver to use]:driver:' \
  '(-d --device)'{-d,--device=}'[device to read from]:device:_files' \
  '(-U --plugindir)'{-U,--plugindir=}'[plugin directory]:dir:_files -/' \
  '(-k --keep-root)'{-k,--keep-root}'[do not drop root privileges]' \
  '(-A --driver-options)'{-A,--driver-options=}'[driver options]:key\:value:' \
  '(-D --loglevel)'{-D,--loglevel=}'[log level]:level:(error warning info notice debug trace trace1 trace2)' \
  '(-O --options-file)'{-O,--options-file=}'[default options file]:file:_files' \
  '*:output config:_files' && ret=0
return ret
