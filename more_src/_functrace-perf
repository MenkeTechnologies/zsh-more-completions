#compdef functrace-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/functrace.8
# trace kernel function calls matching specified wildcards (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-H[include column headers]' \
  '-p+[trace when this PID is on-CPU]:pid:_pids' \
  '-L+[trace when this thread is on-CPU]:tid' \
  '*:kernel function name:' && ret=0

return ret
