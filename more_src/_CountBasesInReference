#compdef CountBasesInReference
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/fasta/CountBasesInReference.java
# Count the numbers of each base in a reference file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--reference -R)'{--reference,-R}'=[reference sequence file]:value:_files' \
  '(--output -O)'{--output,-O}'=[output file for results]:value:_files' \
  '*:argument:_files' && ret=0

return ret
