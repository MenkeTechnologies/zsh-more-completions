#compdef atlas
# _atlas — Ariga Atlas CLI (manage database schemas as code: declarative schema, versioned migrations, drift detection)
# upstream: https://github.com/ariga/atlas
# Subcommands from cmd/atlas/internal/cmdapi/{cmdapi,schema,migrate}.go on tip (cobra); ATLAS_NO_UPDATE_NOTIFIER env var silences the update check.

_atlas() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                schema:'declarative database schema management (apply/clean/diff/fmt/inspect/lint/push)'
                migrate:'versioned database migration management (apply/diff/hash/import/lint/new/set/status/validate/push/checkpoint/rebase)'
                license:'display license information'
                version:'print Atlas CLI version'
            )
            _describe -t commands 'atlas subcommand' subs
            ;;
        args)
            case $line[1] in
                schema)
                    _arguments \
                        '1: :(apply clean diff fmt inspect lint push)'
                    ;;
                migrate)
                    _arguments \
                        '1: :(apply diff hash import lint new set status validate push checkpoint rebase down)'
                    ;;
            esac
            ;;
    esac
}

_atlas "$@"
