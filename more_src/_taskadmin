#compdef taskadmin

local -a arguments

arguments=(
    '-h[Show help message]'
    '--help[Show help message]'
    '-v[Verbose output]'
    '--verbose[Verbose output]'
    '-p[Process ID]:process id'
    '--pid=[Process ID]:process id'
    '-k[Kill task]'
    '--kill[Kill task]'
    '-s[Suspend task]'
    '--suspend[Suspend task]'
    '-r[Resume task]'
    '--resume[Resume task]'
    '-l[List tasks]'
    '--list[List tasks]'
    '*:process id'
)

_arguments -s -S $arguments
