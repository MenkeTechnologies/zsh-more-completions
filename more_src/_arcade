#compdef arcade arcade-mcp
# Documentation: https://github.com/ArcadeAI/arcade-ai
# Reference accessed: 2026-05-23
# Verified: arcade_cli/main.py Typer commands (arcade-ai PyPI).

# Zsh completion for arcade - Arcade MCP servers and AI tools CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'arcade command' \
      'login[log in to Arcade]' \
      'logout[log out of Arcade]' \
      'whoami[login status and active context]' \
      'new[create new server package directory]' \
      'mcp[run MCP servers with different transports]' \
      'show[show installed tools or tool details]' \
      'evals[run tool calling evaluations]' \
      'configure[configure Arcade client settings]' \
      'connect[connect Arcade client]' \
      'deploy[deploy tool server to Arcade Cloud]' \
      'update[check for and install CLI updates]' \
      'upgrade[upgrade Arcade CLI]' \
      'dashboard[open Arcade Dashboard in browser]' \
      'org[manage organizations]' \
      'project[manage projects]' && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--dir[tools directory path]:directory:_files -/' \
          '1:server name:' && ret=0
        ;;
      mcp)
        _arguments \
          '1:transport:(stdio http)' \
          '--host[bind host]:host:' \
          '--port[bind port]:port:' \
          '--discover-installed[discover installed arcade tool packages]' \
          '--show-packages[show loaded packages during discovery]' \
          '--reload[auto-reload on code changes]' \
          '--debug[verbose logging]' \
          '--otel-enable[send logs to OpenTelemetry]' \
          '--env-file[environment file]:file:_files' \
          '--name[server name]:name:' \
          '--version[server version]:version:' \
          '--cwd[working directory]:directory:_files -/' && ret=0
        ;;
      show)
        _arguments \
          '(-T --server)'{-T+,--server=}'[server to show tools of]:server:' \
          '(-t --tool)'{-t+,--tool=}'[tool to show details for]:tool:' && ret=0
        ;;
    esac
    ;;
esac

return ret
