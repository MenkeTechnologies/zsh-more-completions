#compdef wavegain
# Documentation: https://github.com/MestreLion/wavegain
# Replaygain functionality for WAV audio files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-a --album)'{-a,--album}'[use Album gain setting]' \
  '(-r --radio)'{-r,--radio}'[use Radio/Single Track gain (default)]' \
  '(-q --adc)'{-q,--adc}'[apply Album-based DC Offset correction]' \
  '(-p --no_offset)'{-p,--no_offset}'[disable DC Offset correction]' \
  '(-c --calculate)'{-c,--calculate}'[calculate gain without applying (default)]' \
  '(-x --scale)'{-x,--scale}'[output scale values to stdout]' \
  '(-y --apply)'{-y,--apply}'[calculate and apply gain adjustments]' \
  '(-s --fast)'{-s,--fast}'[fast calculation]' \
  '(-w --write)'{-w,--write}'[write gain chunk to Wave Header]' \
  '--force[reprocess files with existing gain chunks]' \
  '--undo-gain[reverse previously applied gain]' \
  '(-o --stdout)'{-o,--stdout}'[write output file to stdout]' \
  '(-z --recursive)'{-z,--recursive}'[search recursively; treat folders as albums]' \
  '(-n --noclip)'{-n,--noclip}'[disable clipping prevention]' \
  '(-d --dither)'{-d,--dither}'[apply dithering]:type:(0 1 2 3 4)' \
  '(-t --limiter)'{-t,--limiter}'[apply 6dB hard limiter]' \
  '(-g --gain)'{-g,--gain}'[manual gain adjustment in dB (-20.0 to +12.0)]:dB' \
  '(-l --log)'{-l,--log}'[write log file (default WGLog.txt)]' \
  '(-f --logfile)'{-f,--logfile}'[specify custom log filename]:logfile:_files' \
  '(-b --bits)'{-b,--bits}'[set output sample format]:format:(1 2 3 4 5 6)' \
  '*:WAV file:_files -g "*.(wav|WAV|aif|aiff|AIF|AIFF)"' && ret=0

return ret
