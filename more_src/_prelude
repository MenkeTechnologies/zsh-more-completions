#compdef prelude
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/registration/fugue.html
# FSL PRELUDE: phase region expanding labeller for unwrapping discrete estimates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[input complex phase volume]:complex:_files' \
  '-a[input absolute/magnitude volume]:abs:_files' \
  '-p[input raw phase volume]:phase:_files' \
  '-u[output unwrapped phase volume]:unwrap:_files' \
  '-m[input mask volume]:mask:_files' \
  '-o[output raw phase]:rawphase:_files' \
  '-n[number of phase partitions for labeling]:num:' \
  '-t[intensity threshold for masking]:thresh:' \
  '-s[do all processing in 2D (slice at a time)]' \
  '--labelslices[2D labeling with 3D unwrapping]' \
  '-f[force 3D processing even for 2D acquisitions]' \
  '--removeramps[remove phase ramps during unwrapping]' \
  '--savemask=[save mask volume]:mask:_files' \
  '-v[verbose output]' \
  '*:image:_files' && ret=0

return ret
