#compdef netlify ntl

# Zsh completion for Netlify CLI

_netlify-cli() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'build:build on your local machine'
    'deploy:create a new deploy from a local folder'
    'dev:local development server'
    'env:control environment variables'
    'functions:manage Netlify functions'
    'init:configure continuous deployment'
    'link:link a local repo to an existing Netlify site'
    'login:login to your Netlify account'
    'logout:logout of your Netlify account'
    'open:open settings for a site'
    'sites:handle site operations'
    'status:print status info'
    'switch:switch active Netlify account'
    'unlink:unlink a local folder from a Netlify site'
    'watch:watch for site deploy to finish'
    'lm:handle Netlify Large Media'
    'addons:manage Netlify Add-ons'
    'api:make API requests'
    'blobs:manage Netlify Blobs'
    'completion:generate shell completion script'
    'recipes:run a recipe'
    'serve:build the site for production and serve locally'
    'integration:manage Netlify integrations'
    'logs:stream logs'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'netlify command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        deploy)
          _arguments -s -S \
            '(-d --dir)'{-d,--dir}'[specify a folder to deploy]:directory:_files -/' \
            '(-f --functions)'{-f,--functions}'[specify a functions folder]:directory:_files -/' \
            '(-p --prod)'{-p,--prod}'[deploy to production]' \
            '--prodIfUnlocked[deploy to production if unlocked]' \
            '--alias=[alias for the deployment]:alias:' \
            '--branch=[branch to deploy]:branch:' \
            '--open[open site after deploy]' \
            '(-m --message)'{-m,--message}'[deploy message]:message:' \
            '(-s --site)'{-s,--site}'[site to deploy to]:site ID:' \
            '--auth=[Netlify auth token]:token:' \
            '--timeout=[deploy timeout in seconds]:seconds:' \
            '--trigger[trigger a new build on the remote]' \
            '--build[run build command before deploying]' \
            '--json[output as JSON]' \
            '--skip-functions-cache[skip the functions cache]' \
            && ret=0
          ;;
        dev)
          _arguments -s -S \
            '(-c --command)'{-c,--command}'[command to run]:command:' \
            '(-p --port)'{-p,--port}'[port of Netlify dev]:port:' \
            '--targetPort=[port of target dev server]:port:' \
            '--framework=[web framework]:framework:' \
            '(-d --dir)'{-d,--dir}'[dir with static files]:directory:_files -/' \
            '(-f --functions)'{-f,--functions}'[functions directory]:directory:_files -/' \
            '--functionsPort=[port for functions]:port:' \
            '-o[open the site in the browser]' \
            '--offline[disables any features that require network access]' \
            '-l[run in live mode]' \
            '--live[run in live mode]' \
            '-e[specify an edge-functions directory]:directory:_files -/' \
            '--edgeFunctions=[specify an edge-functions directory]:directory:_files -/' \
            && ret=0
          ;;
        env)
          _arguments -s -S \
            '1:subcommand:(get set unset import list clone)' \
            '*:: :->env_args' \
            && ret=0
          ;;
        functions)
          _arguments -s -S \
            '1:subcommand:(build create invoke list serve)' \
            '*:: :->func_args' \
            && ret=0
          ;;
        sites)
          _arguments -s -S \
            '1:subcommand:(create delete list)' \
            '*:: :->site_args' \
            && ret=0
          ;;
        open)
          _arguments -s -S \
            '1:target:(admin site)' \
            '--site=[site ID]:site ID:' \
            && ret=0
          ;;
        link)
          _arguments -s -S \
            '--id=[site ID]:site ID:' \
            '--name=[site name]:site name:' \
            '--gitRemoteName=[name of git remote]:remote:' \
            && ret=0
          ;;
        login)
          _arguments -s -S \
            '--new[force new login]' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--context=[build context]:context:(production deploy-preview branch-deploy dev)' \
            '--dry[dry run]' \
            '--offline[build offline]' \
            && ret=0
          ;;
        logs)
          _arguments -s -S \
            '1:subcommand:(deploy function)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--auth=[Netlify auth token]:token:' \
            '--json[output as JSON]' \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_netlify-cli "$@"
