#compdef cloudprober
# Documentation: https://man.archlinux.org/search?q=cloudprober
# Reference accessed: 2026-05-16

# Zsh completion for cloudprober v0.14.x (flag package)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-config_file[probe configuration proto file]:file:_files -g "*.cfg"' \
  '-surfacers_config_file[surfacers configuration file]:file:_files' \
  '-test_instance_name[instance name for config interpolation]:name' \
  '-version[print version and exit]' \
  '-buildinfo[print build info and exit]' \
  '-stop_time[grace period before exit on signals]:duration' \
  '-cpuprof[write CPU profile to file]:file:_files' \
  '-memprof[write heap profile to file]:file:_files' \
  '-configtest[dry-run config parse]' \
  '-dumpconfig[dump processed config to stdout]' \
  '-dumpconfig_fmt[dump format]:format:(textpb json yaml)' \
  '-run_once[run probes once and exit]' \
  '-run_once_probe_names[comma-separated probe names]:names' \
  '-run_once_output_format[run-once output format]:format:(text json)' \
  '-run_once_output_indent[indent string for run-once JSON]:indent' \
  '*::args:{ _message "cloudprober flags" }' && ret=0

return ret
