#compdef pdb_delinsertion
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Deletes insertion codes (optionally for given residues), e.g. -A9,B12

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residues to deinsert, e.g. -A9,B12]:residues' \
  '*:PDB file:_files' && ret=0

return ret
