#compdef cordless
# Documentation: https://github.com/Bios-Marcel/cordless
# cordless - terminal Discord client

local ret=1

_arguments -s -S \
  '-version[show the version instead of starting cordless]' \
  '-shortcut-dialog[shows the shortcuts dialog instead of launching cordless]' \
  '-config-dir=[sets the configuration directory]:dir:_files -/' \
  '-script-dir=[sets the script directory]:dir:_files -/' \
  '-config-file=[sets exact path of the configuration file]:file:_files' \
  '-account=[defines which account cordless tries to load]:account' \
  '-log=[defines what file we log to]:file:_files' && ret=0

return ret
