#compdef yandex-disk

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:initial setup and authorization'
  'start:start the daemon'
  'stop:stop the daemon'
  'status:show synchronization status'
  'sync:synchronize specified folder'
  'token:get or refresh authorization token'
  'publish:publish a file or folder'
  'unpublish:unpublish a file or folder'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '(-c --config)'{-c,--config}'=[path to configuration file]:config file:_files' \
  '(-d --dir)'{-d,--dir}'=[path to sync directory]:sync dir:_files -/' \
  '--auth=[path to auth file]:auth file:_files' \
  '--proxy=[set proxy]:proxy URL:' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'yandex-disk command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--no-daemon[do not daemonize]' \
          '(-d --dir)'{-d,--dir}'=[path to sync directory]:sync dir:_files -/' \
          '--exclude-dirs=[comma-separated list of directories to exclude]:dirs:' \
          '--read-only[do not upload local changes]' \
          '--overwrite[overwrite local files with server versions]' \
          && ret=0
        ;;
      (status)
        _arguments \
          '--output=[output format]:format:(auto json)' \
          && ret=0
        ;;
      (sync)
        _arguments \
          '1:folder to sync:_files -/' \
          && ret=0
        ;;
      (token)
        _arguments \
          '(-p --password)'{-p,--password}'=[account password]:password:' \
          && ret=0
        ;;
      (publish|unpublish)
        _arguments \
          '1:file or folder:_files' \
          && ret=0
        ;;
      (setup)
        _arguments \
          '--no-start[do not start daemon after setup]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
