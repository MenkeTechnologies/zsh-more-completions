#compdef vboxsdl VBoxSDL

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--startvm=+[VM name or uuid]:vm:' \
  '--separate[separate config]' \
  '--hda=+[hard disk]:file:_files' \
  '--fda=+[floppy disk]:file:_files' \
  '--cdrom=+[cdrom file]:file:_files -g "*.iso"' \
  '--boot=+[boot device]:dev:(a c d n)' \
  '--memory=+[memory in MB]:mb:' \
  '--vram=+[video memory MB]:mb:' \
  '--fullscreen[fullscreen mode]' \
  '--fullscreenresize[fullscreen resize]' \
  '--fixedmode=+[fixed mode WxH]:mode:' \
  '--nofstoggle[no fullscreen toggle]' \
  '--noresize[no resize]' \
  '--nohostkey[no hostkey grab]' \
  '--nohostkeys=+[disabled hostkeys]:keys:' \
  '--nograbonclick[no grab on click]' \
  '--detecthostkey[detect host key]' \
  '--hostkey=+[host key]:key:' \
  '--termacpi[term ACPI shutdown]' \
  '--vrdp=+[port range]:port:' \
  '--discardstate[discard state on exit]' \
  '--settingspw=+[settings password]:pw:' \
  '--settingspwfile=+[settings password file]:file:_files' \
  '*::option:' && ret=0

return ret
