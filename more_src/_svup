#compdef svup
# _svup — daemontools-encore svup (verify that supervise(8) is running and has actually started the named service — including the log child when present; exit 0 if up, 100 if not)
# upstream: https://github.com/schmonz/daemontools-encore
# Flags from svup.8.in on tip; honors $SUPERVISEDIR.

_svup() {
    _arguments \
        '(-L -l)-L[only check the log process, not the service itself]' \
        '(-L -l)-l[skip the log-process check]' \
        '1:service:_files -/'
}

_svup "$@"
