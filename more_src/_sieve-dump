#compdef sieve-dump
# _sieve-dump — dump a compiled Sieve binary back to source (dovecot/pigeonhole)
# upstream: https://github.com/dovecot/pigeonhole
# Flags from src/sieve-tools/sieve-dump.c (getopt).

_sieve-dump() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-c+[Dovecot config file]:file:_files'
        '-D[enable Sieve debug output]'
        '*-P+[load this Sieve plugin]:plugin:'
        '-x+[extra Sieve extensions to enable]:extensions:'
        '1:sieve binary (.svbin):_files -g "*.svbin"'
        '2:output file (default stdout):_files'
    )
    _arguments -s $args
}

_sieve-dump "$@"
