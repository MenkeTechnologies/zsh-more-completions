#compdef critical
# =============================================================================
# critical — Critical-path CSS extractor + inliner.  Reads an HTML page,
#            renders it in headless Chromium (via penthouse + puppeteer),
#            detects which CSS rules are USED by elements visible in the
#            initial viewport ("above the fold"), inlines those rules in
#            a <style> tag in the page <head>, and asynchronously
#            defer-loads the rest of the stylesheet via preload + onload
#            link rel="preload" pattern.  Originally an Addy Osmani
#            Google Chrome team performance-optimization project; today
#            the canonical NPM library for critical-path-CSS extraction,
#            used by Static-Site-Generators (Eleventy, Gatsby, Nuxt),
#            CI build steps for marketing sites, and PageSpeed-driven
#            optimization workflows.  Reduces Largest-Contentful-Paint
#            time by ~30-60% on typical content-heavy sites.
#
# Author:  Addy Osmani (addyosmani — Google Chrome team performance
#          engineer; author of "Learning JavaScript Design Patterns",
#          "Image Optimization" O'Reilly books; prolific OSS author
#          behind react-tabs, paseo, todomvc, yeoman generator-yeoman,
#          and dozens of Critical-CSS-adjacent performance tools)
# Source:  https://github.com/addyosmani/critical
# CLI:     cli.js (uses sindresorhus/meow)
# Library: sindresorhus/meow
#          ("CLI app helper" — Sindre Sorhus's idiomatic JS / TS CLI
#           library built on minimist + yargs-parser with a uniquely
#           HELP-TEXT-AS-CONFIG design)
# License: Apache-2.0
# Status:  Stable — 10215+ stars on addyosmani/critical; recommended by
#          Google PageSpeed Insights documentation; integrated as the
#          critical-path CSS step in many SSG build pipelines.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 36
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 36TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 35 to 36 documented libraries (sindresorhus/meow via critical).  New
# leaderboard: Rust=36, Go=36, TypeScript-Node=36 (THREE-WAY TIE AT 36
# RESTORED — top group rejoined for the third time in this round-sequence).
# Taxonomy now spans 255 cross-language CLI library variants across 61
# documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS sindresorhus/meow AND WHY IS IT A DISTINCT 36TH TS-NODE CLI LIBRARY?
#
# sindresorhus/meow (https://github.com/sindresorhus/meow, 3708+ stars) is
# **Sindre Sorhus's "CLI app helper"** — the canonical "small, opinionated
# CLI library for tiny Sindre-Sorhus-style utilities" used by hundreds of
# his own npm packages (np, np-init, gulp-changed, image-min-cli, etc.)
# plus thousands of community CLIs.  Sindre is the most prolific OSS
# author in the JS ecosystem with 1,800+ npm packages and 100B+ monthly
# downloads aggregate; meow is the parser he uses for virtually all of
# his "single-purpose Unix-y" command-line tools.
#
# meow is DISTINCT from every documented TS-Node CLI library on FIVE
# specific axes:
#
#   1. HELP-TEXT-AS-PRIMARY-INPUT (NOT JUST OUTPUT) — meow's killer
#      design choice: the FIRST ARGUMENT TO meow() IS THE HELP TEXT,
#      not a schema:
#         const cli = meow(`
#           Usage
#             $ critical <input> [<option>]
#
#           Options
#             --base, -b      Your base directory
#             --css, -c       Your CSS Files (optional)
#             --width, -w     Viewport width
#             --height, -h    Viewport height
#             --inline, -i    Generate HTML with inlined critical-path CSS
#         `, {
#             importMeta: import.meta,
#             flags: { ... },  // typed flag schema (SECONDARY)
#         });
#      The help text is the **PRIMARY USER-FACING SPECIFICATION** of the
#      CLI surface; the typed `flags` schema is SECONDARY (just for
#      runtime parsing).  Compare:
#        commander:     help text is GENERATED from .option() calls
#        yargs:         help text is GENERATED from .command(spec).demand()
#        oclif:         help text is GENERATED from class-attribute decorators
#        cac (R508):    help text is GENERATED from .option() chains
#        clack/prompts: no argv parser, no help text
#        @stricli/core: help text is GENERATED
#        brocli R500:   help text is GENERATED
#        gunshi R504:   help text is GENERATED + i18n
#        docopt (port): help text IS the schema (similar to meow but
#                        STRICTER — docopt parses help text into a
#                        grammar; meow uses help text DECORATIVELY +
#                        separate schema)
#        meow:          help text is AUTHOR-WRITTEN; flag schema is
#                        AUTHOR-WRITTEN; the two coexist independently.
#                        meow displays the help text VERBATIM on -h.
#      **First documented TS-Node CLI library to make the help text
#      the PRIMARY public artifact + a separate typed schema for
#      parsing — author writes BOTH, library doesn't auto-generate
#      either from the other.**
#
#   2. TYPED `flags` SCHEMA WITH RICH OPTION-OBJECT FORMAT — meow's
#      `flags` field is a flat object mapping flag-name to option-spec:
#         flags: {
#             base: {
#                 type: "string",
#                 shortFlag: "b",
#             },
#             css: {
#                 type: "string",
#                 shortFlag: "c",
#                 isMultiple: true,         // can be specified multiple times
#             },
#             width: {
#                 type: "number",
#                 shortFlag: "w",
#             },
#             extract: {
#                 type: "boolean",
#                 shortFlag: "e",
#                 default: false,
#             },
#             dimensions: {
#                 type: "string",
#                 isMultiple: true,
#                 choices: ["mobile", "tablet", "desktop"],
#             },
#         }
#      Compare:
#        commander:     `.option("-e, --extract", "...")` — string DSL
#        yargs:         `.option("extract", { alias: "e", type: "boolean" })`
#                        — option-object SIMILAR to meow but on a fluent
#                        chain
#        oclif:         `Flags.boolean({char: "e"})` — class-attribute
#        meow:          `extract: {type: "boolean", shortFlag: "e"}` —
#                        FLAT object key-value, no chaining
#      The flat object format is **the simplest possible option-spec
#      surface for declarative TS/JS CLIs**.  No methods, no closures,
#      no class decorators — just a plain object.
#
#   3. AUTOMATIC -v/--version FROM package.json — meow reads
#      `package.json` (via `importMeta` ESM lookup or `pkg` legacy
#      option) and AUTO-GENERATES `--version` / `-v` handlers:
#         const cli = meow(helpText, {
#             importMeta: import.meta,
#             flags: { ... },
#             // version: optional override; otherwise auto-from-pkg
#         });
#         // $ critical --version
#         // → reads version from caller's package.json
#      Compare:
#        commander:     `.version()` must be called explicitly
#        yargs:         `.version()` reads from package.json if no arg
#        oclif:         class attribute or framework convention
#        cac:           `cli.version(versionStr)` explicit
#        meow:          AUTOMATIC version-from-package.json — caller
#                        doesn't write any version code.
#      Reflects Sindre's hyper-aggressive "remove all boilerplate" CLI
#      philosophy.
#
#   4. ESM-FIRST DESIGN (importMeta + import.meta) — meow 9.x+ is
#      ESM-ONLY; the parser receives `importMeta: import.meta` to
#      locate the caller's package.json:
#         import meow from "meow";
#         const cli = meow(`...help...`, {
#             importMeta: import.meta,    // ESM-only path lookup
#             flags: { ... },
#         });
#      Compare:
#        commander:     dual-format (CJS + ESM exports)
#        yargs:         dual-format
#        oclif:         dual-format
#        cac:           dual-format
#        clack/prompts: ESM-only (similar to meow)
#        meow:          ESM-ONLY since v10 — caller must use
#                        import.meta to bridge ESM/CJS resolution
#                        for package.json detection.
#      Reflects Sindre's leadership in pushing the JS ecosystem to
#      ESM-only — meow was one of the EARLIEST popular npm packages
#      to drop CJS support, a controversial-at-the-time call that
#      proved correct as Node ESM matured.
#
#   5. AUTO-CAMELIZE OF KEBAB-CASE FLAGS — meow automatically converts
#      kebab-case flag names to camelCase in the parsed result:
#         flags: {
#             "user-agent": { type: "string", shortFlag: "ua" },
#             "ignore-inlined-styles": { type: "boolean", default: false },
#         }
#         // $ critical --user-agent='Custom' --ignore-inlined-styles
#         // → cli.flags.userAgent      === 'Custom'
#         // → cli.flags.ignoreInlinedStyles === true
#      The kebab-case `user-agent` becomes camelCase `userAgent` in
#      `cli.flags`.  Compare:
#        commander:     does NOT auto-camelize; access via cli.opts()["user-agent"]
#        yargs:         auto-camelize (similar to meow)
#        oclif:         auto-camelize via Flags.string()
#        meow:          AUTO-CAMELIZE in both flag NAMES (in flags
#                        schema can use "user-agent" or "userAgent") and
#                        ACCESSORS (cli.flags.userAgent).
#      Critical-CSS author Addy Osmani uses this in his flag definitions
#      (e.g. `inlineImages`, `assetPaths`, `userAgent`) to make the CLI
#      surface readable as both `--inline-images` AND `--inlineImages`.
#
# Bonus: meow has **EXPLICIT `input` POSITIONAL ARGS** accessible as
# `cli.input` (array of strings) — separate from `cli.flags` (object).
# This is the classic Unix CLI separation: positional args vs flags,
# accessible as TWO DIFFERENT FIELDS on the meow result.
#
# THE sindresorhus/meow API SURFACE (verbatim from upstream README)
#
#   import meow from "meow";
#
#   const cli = meow(`
#       Usage
#         $ foo <input>
#
#       Options
#         --rainbow, -r  Include a rainbow
#         --unicorn, -u  Show a unicorn
#
#       Examples
#         $ foo unicorns --rainbow
#         🌈 unicorns
#   `, {
#       importMeta: import.meta,
#       flags: {
#           rainbow: {
#               type: "boolean",
#               shortFlag: "r",
#           },
#           unicorn: {
#               type: "boolean",
#               shortFlag: "u",
#               default: false,
#               isRequired: false,
#           },
#       },
#   });
#
#   console.log(cli.input);   // ['unicorns']
#   console.log(cli.flags);   // { rainbow: true, unicorn: false }
#   console.log(cli.pkg);     // package.json contents (auto-loaded)
#   console.log(cli.help);    // the help text passed to meow()
#   console.log(cli.version); // version from package.json
#   cli.showHelp();           // print help text + exit(2)
#   cli.showVersion();        // print version + exit(0)
#
# Option-spec fields:
#   type           string | boolean | number
#   shortFlag      single-letter short alias
#   default        default value if flag absent
#   isMultiple     accept the flag multiple times (returns array)
#   isRequired     fail if flag is missing
#   choices        array of allowed values
#   aliases        long-name aliases (in addition to canonical name)
#
# Top-level options to meow():
#   importMeta     import.meta (ESM-only — required since v10)
#   flags          option-spec record
#   description    overrides package.json description in help
#   version        overrides package.json version
#   help           overrides the help text passed as first arg
#   allowUnknownFlags    if true, don't error on unknown flags
#   booleanDefault       global default for boolean flags (true|false|undefined)
#   pkg            package.json object (legacy; superseded by importMeta)
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander           — chained .command().option().action() parser
#   * yargs               — chained .command(spec).demand().argv parser
#   * oclif               — file-based + class-per-command framework
#   * citty (UnJS)        — defineCommand({meta, args, run}) parser
#   * cac (R508)          — zero-dep single-file 4-API parser
#   * minimist            — pure parser, no command abstraction
#   * sade                — chained lightweight parser
#   * arg (Vercel)        — pure parser
#   * mri (lukeed)        — minimist replacement, lighter
#   * yargs-parser        — parsing kernel under yargs
#   * arg-parser          — typed plain object schema
#   * cleye R472          — string-command map + typed flags
#   * clipanion           — class-based with attribute decorators
#   * gluegun             — extension-plugin architecture
#   * stricli R484        — Bloomberg complex CLI framework
#   * type-flag           — low-level typed flag primitive
#   * tinyargs            — egoist's parser + Option class
#   * breadc              — modern minimal TS framework
#   * clerc R496          — plugin-driven typed chained API
#   * brocli R500         — factory-fn + method-chain + plain object
#   * command-line-args   — 75lb's three-stage parser
#   * cliffy (Deno-first) — chained + Promise-returning .parse()
#   * gunshi R504         — universal-runtime + i18n + 3 renderers
#   * @clack/prompts R512 — INTERACTIVE-TUI-PROMPT library
#   * meow (THIS)         — HELP-TEXT-AS-PRIMARY-INPUT + flat-object
#                            flags schema + auto-version-from-package.json
#                            + ESM-only + auto-camelize kebab-case
#                            (Sindre Sorhus's CLI app helper)
#
# meow occupies a UNIQUE NICHE — the **HELP-TEXT-FIRST TS-Node CLI
# library**.  Where every other parser AUTO-GENERATES help text from a
# schema, meow inverts the relationship: the author writes the help
# text AS the canonical user-facing artifact, and the flags schema is
# a separate, more-machine-readable companion.  This is the OPPOSITE
# of docopt's "help text IS the spec" — meow uses BOTH the help text
# AND a separate schema, each authored explicitly by the developer.
#
# REAL-WORLD sindresorhus/meow USERS:
#
#   * addyosmani/critical (THIS, 10215*) — Critical-path CSS extractor
#       and inliner from Addy Osmani / Google Chrome team
#   * mifi/editly (5425*) — Slick, declarative command line video
#       editing & API
#   * refinedev/refine:codemod (34816*) — refine React Framework's
#       codemod CLI for migrating refine projects across versions
#   * ueberdosis/hocuspocus (2345*) — Yjs CRDT WebSocket backend
#       (uses meow in packages/cli)
#   * serwist/serwist (1424*) — Service Workers Swiss Army knife
#       (uses meow in packages/cli/src/bin.ts)
#   * prismicio/slice-machine (304*) — Prismic CMS tooling
#   * itgalaxy/generate-robotstxt — robots.txt generator
#   * textlint/create-textlint-rule — textlint scaffolder
#   * Hundreds of Sindre's own packages:
#       - np (npm publish)
#       - np-init
#       - gulp-changed
#       - imagemin-cli
#       - sort-package-json
#       - is-online-cli
#       - dot-prop-cli
#       - chalk-cli
#       - emoji-regex-cli
#       - ...and ~50+ more single-purpose Unix-y utilities
#
# meow's adoption pattern: **THE CANONICAL choice for small Unix-y
# JS/TS CLI utilities** by Sindre Sorhus and the loose community of
# JS-utility-author "Sindre-likes".  When a tool does ONE THING and
# needs to be a small npm package with minimal dependencies and
# Sindre-style aesthetic (terse README, explicit help text, ESM-only,
# single-author maintained), meow is the default.  Where cac (R508)
# competes for "zero-dep small CLI" niche, meow is the choice when
# you want the HELP-TEXT-FIRST authoring style + Sindre-ecosystem
# integration.
#
# -----------------------------------------------------------------------------
# CRITICAL'S CLI SURFACE (verbatim from cli.js meow help text + flags)
# -----------------------------------------------------------------------------
#
# USAGE:
#   critical <input> [<options>]
#
# Positional:
#   <input>                          HTML file or URL to process
#
# Options:
#   -b, --base <DIR>                 Your base directory
#   -c, --css <FILE>                 Your CSS files (REPEATABLE — multiple
#                                     stylesheets)
#   -w, --width <PX>                 Viewport width
#   -h, --height <PX>                Viewport height
#   -i, --inline                     Generate HTML with inlined critical-
#                                     path CSS
#   -e, --extract                    Extract inlined styles from referenced
#                                     stylesheets (default: false)
#
#       --inlineImages               Inline images as data URIs in the
#                                     critical CSS
#       --dimensions <WxH>           Pass viewport dimensions
#                                     (e.g. --dimensions 1300x900 — REPEATABLE)
#       --ignore <REGEX|TYPE|SEL>    RegExp / @type / selector to ignore
#                                     when extracting critical rules
#       --ignore-[OPTION]            Pass option to postcss-discard
#                                     (see github.com/cssnano/cssnano)
#       --ignoreInlinedStyles        Ignore already-inlined stylesheets
#                                     (default: false)
#       --include <REGEX|TYPE|SEL>   RegExp / @type / selector to FORCE-
#                                     include in critical CSS
#       --include-[OPTION]           Pass option to inline-critical
#                                     (see github.com/addyosmani/inline-critical)
#       --assetPaths <PATHS>         Directories / URLs where the inliner
#                                     should start looking for assets
#       --user <USER>                RFC2617 basic-auth user (for fetching
#                                     remote HTML/CSS)
#       --pass <PASSWORD>            RFC2617 basic-auth password
#       --penthouse-[OPTION]         Pass option through to penthouse
#                                     (the underlying critical-CSS extractor)
#                                     (see github.com/pocketjoso/penthouse)
#   --ua, --userAgent <UA>           User-Agent header to send when
#                                     fetching remote HTML/CSS
#       --strict                     Throw on CSS parsing errors / missing
#                                     CSS (default: false)
#       --version                    Print version and exit
#
# Note: critical uses `group-args` alongside meow to recognize the
# `--ignore-*`, `--include-*`, and `--penthouse-*` flag-groups as
# pass-through configurations to the underlying postcss-discard /
# inline-critical / penthouse libraries.  meow itself sees the bare
# flag names (e.g. `--ignore-message-bus`) and `group-args`
# post-processes them into nested objects (e.g. `{ ignore: { messageBus: true } }`).
#
# Typical usage:
#   $ critical index.html --base . --css styles.css --width 1300 --height 900 -i
#   $ critical index.html -c style.css -i -e > optimized.html
#   $ critical https://example.com/ --base out/ --inline --extract
#   $ critical index.html --dimensions 320x568 --dimensions 1366x768 -i
#   $ critical index.html --user admin --pass secret --ua "MyBot/1.0"
#
# Output:
#   By default, writes the optimized HTML to stdout (redirect to a file).
#   With --inline + --extract, writes back to the input file in place
#   (with backup).  With --base set, all relative URLs in the HTML are
#   resolved relative to that directory.
#
# Companion tools by Addy Osmani:
#   inline-critical                  Inline the critical CSS into an
#                                     HTML file's <style> tag
#   penthouse                        The underlying critical-CSS extractor
#                                     (separate npm package; critical wraps
#                                     it with the CLI + inlining + caching)
#   critters                         Lighter-weight critical-CSS extractor
#                                     by Google Chrome team (now part of
#                                     Vite under preact org)
#
# =============================================================================

_critical() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-b --base)'{-b,--base}'[base directory]:dir:_directories' \
        '*'{-c,--css}'[CSS file (repeatable)]:file:_files -g "*.css"' \
        '(-w --width)'{-w,--width}'[viewport width in pixels]:width:' \
        '(-h --height)'{-h,--height}'[viewport height in pixels]:height:' \
        '(-i --inline)'{-i,--inline}'[generate HTML with inlined critical-path CSS]' \
        '(-e --extract)'{-e,--extract}'[extract inlined styles from referenced stylesheets]' \
        '--inlineImages[inline images as data URIs]' \
        '*--dimensions[viewport dimensions WxH (repeatable)]:dimensions:' \
        '--ignore[regex/type/selector to ignore]:pattern:' \
        '--ignoreInlinedStyles[ignore already-inlined stylesheets]' \
        '--include[regex/type/selector to force-include]:pattern:' \
        '--assetPaths[directories/URLs to look for assets]:paths:' \
        '--user[basic-auth user]:user:' \
        '--pass[basic-auth password]:password:' \
        '(--ua --userAgent)'{--ua,--userAgent}'[User-Agent header]:ua:' \
        '--strict[throw on CSS parsing errors / missing CSS]' \
        '--version[print version and exit]' \
        '*: :_files -g "*.(html|htm)"' && ret=0

    return ret
}

_critical "$@"
