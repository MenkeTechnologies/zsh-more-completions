#compdef nbdev_docs
# Documentation: https://nbdev.fast.ai/api/quarto.html
# nbdev_docs: create Quarto docs and README.md for an nbdev project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--path=[path to notebooks directory]:path:_files -/' \
  '--n_workers=[number of workers]:n:' && ret=0

return ret
