#compdef gnome-five-or-more five-or-more
# Documentation: https://man.archlinux.org/search?q=gnome-five-or-more
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--display=+[X display]:disp:' && ret=0

return ret
