#compdef theHarvester theharvester

# Zsh completion for theHarvester - OSINT tool for gathering information about a target

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --domain)'{-d,--domain}'[domain to search]:domain:' \
  '(-l --limit)'{-l,--limit}'[limit the number of search results (default 500)]:limit:' \
  '(-S --start)'{-S,--start}'[start with result number X]:start:' \
  '(-p --proxies)'{-p,--proxies}'[use proxies for requests]' \
  '(-s --shodan)'{-s,--shodan}'[use Shodan to query discovered hosts]' \
  '--screenshot[take screenshots of resolved domains]:output directory:_files -/' \
  '(-v --virtual-host)'{-v,--virtual-host}'[verify host name via DNS resolution and search for virtual hosts]' \
  '(-e --dns-server)'{-e,--dns-server}'[DNS server to use for lookups]:server:' \
  '(-r --dns-resolve)'{-r,--dns-resolve}'[perform DNS resolution on all discovered hosts]' \
  '(-n --dns-lookup)'{-n,--dns-lookup}'[enable DNS server lookup]' \
  '(-c --dns-brute)'{-c,--dns-brute}'[perform a DNS brute force on the domain]' \
  '(-f --filename)'{-f,--filename}'[save the results to an XML and HTML file]:filename:_files' \
  '(-b --source)'{-b,--source}'[sources to use]:source:(anubis baidu bing bingapi bufferoverun censys certspotter crtsh dnsdumpster duckduckgo fullhunt github-code google hackertarget hunter intelx linkedin netcraft onyphe otx pentesttools projectdiscovery qwant rapiddns rocketreach securitytrails shodan spyse sublist3r threatcrowd threatminer trello twitter urlscan virustotal yahoo)'
