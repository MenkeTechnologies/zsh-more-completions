#compdef create-red-app
# Documentation: https://www.npmjs.com/package/create-red-app
# Reference accessed: 2026-05-24
# Verified: npm view create-red-app bin; npx create-red-app --help output.

# Zsh completion for create-red-app - licensed RED project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--license=[license key]:key:'   '--version=[pin release version]:version:'   '--api-url=[license API base URL]:url:'   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show CLI version]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command'       'versions:list available releases'       'info:show release details'       'download:download and extract a release'       ':scaffold project (default):' && ret=0
    ;;
  args)
    case $line[1] in
      info|download)
        _arguments -C ':release version:' && ret=0
        ;;
      *)
        _arguments -C ':project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
