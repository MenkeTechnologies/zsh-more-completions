#compdef hkexpand
# Expand a compressed ASCA Housekeeping data table into a full sized table

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input compressed format HK table]:input file:_files' \
  'outfile=[output expanded FITS table]:output file:_files' \
  'param=[list of housekeeping parameter names to include]:params:' \
  'dtime=[time interval for writing parameter values]:interval:' \
  'name=[column name with housekeeping parameter names]:column:' \
  'value=[column name with housekeeping parameter values]:column:' \
  'time=[column name with housekeeping parameter time stamp]:column:' \
  'tnull=[TNULL keyword value for undefined values]:tnull:' \
  'outtype=[output data type]:type:(F E R D B S I A)' \
  'constdiv=[write only at regular intervals]:flag:(yes no)' \
  'copyall=[copy all file extensions]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
