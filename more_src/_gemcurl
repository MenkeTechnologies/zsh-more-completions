#compdef gemcurl
# _gemcurl — gemcurl curl-like Gemini fetcher; one-shot gemini:// request with TLS SNI + client cert
# upstream: https://git.sr.ht/~julienxx/gemcurl

_gemcurl() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-H --header)'{-H,--header}'[print response header]' \
        '(-i --include)'{-i,--include}'[include header in output]' \
        '(-k --insecure)'{-k,--insecure}'[skip TLS verify]' \
        '(-c --cert)'{-c,--cert}'+[client cert]:file:_files' \
        '(-K --key)'{-K,--key}'+[client key]:file:_files' \
        '--connect-timeout+[timeout sec]:n:' \
        '*:gemini URL:_urls'
}

_gemcurl "$@"
