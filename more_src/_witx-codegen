#compdef witx-codegen
# Documentation: https://github.com/jedisct1/witx-codegen
# witx-codegen: WITX code and documentation generator for AssemblyScript, Zig, Rust and more

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-H --skip-header)'{-H,--skip-header}'[omit header generation]' \
  '(-I --skip-imports)'{-I,--skip-imports}'[disregard imported types and functions]' \
  '(-m --module-name)'{-m,--module-name}'=[alternative module name instead of reading from the WITX file]:name:' \
  '(-o --output)'{-o,--output}'=[output destination (or - for stdout)]:file:_files' \
  '(-t --output-type)'{-t,--output-type}'=[select output format]:type:(assemblyscript zig rust overview markdown)' \
  '*:witx files:_files' && ret=0

return ret
