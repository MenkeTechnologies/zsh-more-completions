#compdef teqc
# Documentation: https://www.unavco.org/software/data-processing/teqc/tutorial/tutorial.html
# UNAVCO translation, editing, and quality check of GNSS data

local ret=1

_arguments -s \
  '+qc[enable quality checking mode]' \
  '+s[generate short report segment]' \
  '+l[generate long report segment]' \
  '(+plot -plot)+plot[create plot files]' \
  '(+plot -plot)-plot[suppress plot files]' \
  '+ion[output ionospheric delay observable]' \
  '+iod[output derivative of ionospheric delay]' \
  '+mp[output MP1 and MP2 observables]' \
  '+sn[output signal-to-noise for L1/L2]' \
  '+tec[convert ionospheric data to TEC format]' \
  '-nav[RINEX navigation file(s)]:file:_files' \
  '+nav[output navigation file]:file:_files' \
  '+obs[output observation file]:file:_files' \
  '-config[configuration file]:file:_files' \
  '+out[redirect stdout to file]:file:_files' \
  '+err[redirect stderr to file]:file:_files' \
  '++out[append stdout to file]:file:_files' \
  '++err[append stderr to file]:file:_files' \
  '(+binex -binex)+binex[output BINEX format]' \
  '(+binex -binex)-binex[input BINEX format]' \
  '-tr[Trimble receiver format]:fmt' \
  '-ash[Ashtech receiver format]:fmt' \
  '-leica[Leica receiver format]:fmt' \
  '-topcon[Topcon receiver format]:fmt' \
  '-javad[Javad receiver format]:fmt' \
  '-aoa[TurboRogue/Benchmark receiver format]:fmt' \
  '-O.mo[set monument name]:name' \
  '-O.obs[specify observable types]:types' \
  '-O.px[approximate position (WGS84 cartesian)]:pos' \
  '-O.pe[antenna topocentric correction]:pe' \
  '+O.c[append comment]:comment' \
  '-O.dec[decimate observation epochs]:interval' \
  '-N.s[set satellite system]:system' \
  '+N.c[append navigation comment]:comment' \
  '-M.mo[set monument name (MET)]:name' \
  '-M.obs[specify meteorological observables]:types' \
  '-st[specify start time]:time' \
  '-e[specify end time]:time' \
  '+d[time delta from start]:delta' \
  '-d[time delta from end]:delta' \
  '-hole[time window holes file]:file:_files' \
  '-tbin[enable time binning for output files]:bin' \
  '-ast[set aligned start time for binning]:time' \
  '+v[verification mode (suppress stdout)]' \
  '-week[specify GPS week]:week' \
  '-warn[suppress warning messages]' \
  '-phc[delete post-header comments]' \
  '-delim[change delimiter character]:char' \
  '+relax[relaxed compliance checking]' \
  '+diag[diagnostic output]' \
  '++config[display all configuration options]' \
  '+config[display modified options only]' \
  '+help[display usage information]' \
  '+version[display program version]' \
  '*:input file:_files' && ret=0

return ret
