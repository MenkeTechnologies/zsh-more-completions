#compdef otbcli_VectorDataReprojection
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VectorDataReprojection.html
# Orfeo ToolBox: reproject vector data using image or user-defined projection

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in.vd[input vector data to reproject]:vector:_files' \
  '-in.kwl[optional input image for vector metadata]:image:_files' \
  '-out.vd[output reprojected vector data]:output:_files' \
  '-out.proj[output projection choice]:proj:(image user)' \
  '-out.proj.image.in[image whose metadata provides projection]:image:_files' \
  '-out.proj.user.map[map projection to use]:map:(utm lambert2 lambert93 wgs epsg)' \
  '-out.proj.user.map.utm.zone[UTM zone number 1-60]:zone:' \
  '-out.proj.user.map.utm.northhem[image is in northern hemisphere]:bool:(true false)' \
  '-out.proj.user.map.epsg.code[EPSG code of map projection]:code:' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '*::arg:_files' && ret=0

return ret
