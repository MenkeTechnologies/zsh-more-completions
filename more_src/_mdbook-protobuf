#compdef mdbook-protobuf
# _mdbook-protobuf — mdBook preprocessor rendering Protocol Buffers definitions (zakhenry/mdbook-protobuf)
# upstream: https://github.com/zakhenry/mdbook-protobuf
# Subcommands from src/main.rs (clap App).

_mdbook-protobuf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
                'install:install required asset files and update config'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments ':renderer:(html epub markdown latex)' ;;
                install)  _arguments ':book root dir:_files -/' ;;
            esac
            ;;
    esac
}

_mdbook-protobuf "$@"
