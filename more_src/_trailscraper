#compdef trailscraper

# Zsh completion for trailscraper CloudTrail log tool

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--since[ISO8601 start time]:time' \
  '--until[ISO8601 end time]:time' \
  '--accounts[comma-separated account IDs]:ids' \
  '--regions[comma-separated regions]:regions' \
  '--filter-expression[JMESPath predicate]:expr' \
  '--output-file[write YAML to path]:file:_files' \
  '--output-format[serializer]:format:(yaml json)' \
  '*::args:{ _message "trailscraper args" }' && ret=0

return ret
