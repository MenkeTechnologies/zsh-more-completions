#compdef agentstack
# Documentation: https://github.com/agentstack-ai/AgentStack
# Reference accessed: 2026-05-22
# Verified: agentstack/main.py argparse subcommands.

# Zsh completion for agentstack - build and run AI agent applications

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[project directory]:directory:_directories' \
  '--debug[verbose error output]' \
  '--no-git[disable automatic git commits]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agentstack command' \
      'init[initialize agent project]' \
      'run[run your agent]' \
      'generate[generate agents or tasks]' \
      'tools[manage tools]' \
      'export[export project as template]' \
      'undo[undo last project change]' \
      'update[check for CLI updates]' \
      'login[authenticate with agentstack.sh]' \
      'docs[open documentation]' \
      'quickstart[open quickstart guide]' \
      'templates[view templates]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '(-w --wizard)'{-w,--wizard}'[interactive setup wizard]' \
          '(-t --template)'{-t,--template}'[agent template]:template:' \
          '(-f --framework)'{-f,--framework}'[framework]:framework:' \
          '1:slug name:' && ret=0
        ;;
      run)
        _arguments \
          '(-f --function)'{-f,--function}'[function in main.py]:function:' \
          '*:input override:' && ret=0
        ;;
      generate)
        case $line[2] in
          agent)
            _arguments \
              '(-r --role)'{-r,--role}'[agent role]:role:' \
              '(-g --goal)'{-g,--goal}'[agent goal]:goal:' \
              '(-b --backstory)'{-b,--backstory}'[agent backstory]:text:' \
              '(-l --llm)'{-l,--llm}'[LLM model]:model:' \
              '--position[stack position]:position:' \
              '1:agent name:' && ret=0
            ;;
          task)
            _arguments \
              '(-d --description)'{-d,--description}'[task description]:text:' \
              '(-e --expected_output)'{-e,--expected_output}'[expected output]:text:' \
              '(-a --agent)'{-a,--agent}'[assigned agent]:agent:' \
              '--position[stack position]:position:' \
              '1:task name:' && ret=0
            ;;
          *)
            _values 'generate target' agent task && ret=0
            ;;
        esac
        ;;
      tools)
        case $line[2] in
          list) ret=0 ;;
          add)
            _arguments \
              '(-a --agents)'{-a,--agents}'[agents comma-separated]:agents:' \
              '--agent[agent name]:agent:' \
              '1:tool name:' && ret=0
            ;;
          new)
            _arguments \
              '--agents[agents comma-separated]:agents:' \
              '--agent[agent name]:agent:' \
              '1:tool name:' && ret=0
            ;;
          remove)
            _arguments '1:tool name:' && ret=0
            ;;
          *)
            _values 'tools command' list add new remove && ret=0
            ;;
        esac
        ;;
      export)
        _arguments '1:filename:' && ret=0
        ;;
      docs|quickstart|templates|login|undo|update)
        ret=0
        ;;
    esac
    ;;
esac

return ret
