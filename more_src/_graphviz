#compdef dot neato fdp sfdp circo twopi osage patchwork

# Zsh completion for Graphviz layout engines

_arguments -s -S \
  '-T+[set output format]:format:(svg png pdf ps eps gif jpg jpeg bmp tiff webp json json0 dot xdot plain canon)' \
  '-K+[set layout engine]:engine:(dot neato fdp sfdp circo twopi osage patchwork)' \
  '-o+[set output file]:output file:_files' \
  '-G+[set graph attribute]:name=value:' \
  '-N+[set default node attribute]:name=value:' \
  '-E+[set default edge attribute]:name=value:' \
  '-l+[use external library]:library file:_files' \
  '-q+[set message suppression level]:level:(0 1 2)' \
  '-s+[set scale]:scale:' \
  '-y[invert y coordinate in output]' \
  '-n+[set no-layout mode]:level:(1 2)' \
  '-x[reduce graph]' \
  '-Lg[do not use grid]' \
  '-LO[use old attractive force]' \
  '-Ln+[set max iterations]:iterations:' \
  '-LC+[set overlap expansion factor]:factor:' \
  '-LT+[set temperature]:temperature:' \
  '-Gstart=[set random seed]:seed:' \
  '-Goverlap=[set overlap handling]:mode:(true false scale scalexy compress vpsc voronoi prism ortho orthoxy orthoyx portho pvoronoi)' \
  '-Gsplines=[set edge routing]:mode:(true false none line polyline curved ortho compound)' \
  '-Grankdir=[set rank direction]:direction:(TB BT LR RL)' \
  '-V[print version]' \
  '-v[verbose mode]' \
  '-?[show usage]' \
  '*:input file:_files -g "*.{dot,gv}"'
