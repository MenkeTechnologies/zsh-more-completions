#compdef dhcpcd-cli
# _dhcpcd-cli — Roy Marples dhcpcd DHCP/IPv6RA/staticIP daemon CLI alias (NetworkConfiguration team, C); custom argparse
# upstream: https://github.com/NetworkConfiguration/dhcpcd

_dhcpcd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[background]' \
        '--background[background]' \
        '-c+[script file]:file:_files' \
        '--script=+[script file]:file:_files' \
        '-d[debug logging]' \
        '--debug[debug logging]' \
        '-e+[var=val]:str:' \
        '--env=+[var=val]:str:' \
        '-f+[config file]:file:_files -g "dhcpcd.conf"' \
        '--config=+[config file]:file:_files -g "dhcpcd.conf"' \
        '-g[reconfigure interface]' \
        '--reconfigure[reconfigure interface]' \
        '-i+[vendor class id]:str:' \
        '--vendorclassid=+[vendor class id]:str:' \
        '-j+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-k[release lease]' \
        '--release[release lease]' \
        '-l+[fallback delay]:n:' \
        '--leasetime=+[time]:n:' \
        '-m+[metric]:n:' \
        '--metric=+[metric]:n:' \
        '-n[rebind]' \
        '--rebind[rebind]' \
        '-o+[require option]:str:' \
        '--option=+[require option]:str:' \
        '-p[persistent]' \
        '--persistent[persistent]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[static ip]:str:' \
        '--request=+[static ip]:str:' \
        '-s+[ip address]:str:' \
        '--inform=+[ip address]:str:' \
        '-t+[timeout]:n:' \
        '--timeout=+[timeout]:n:' \
        '-u+[user class]:str:' \
        '--userclass=+[user class]:str:' \
        '-v+[option]:str:' \
        '--vendor=+[option]:str:' \
        '-w[wait for lease]' \
        '--waitip[wait for lease]' \
        '-x[stop daemon]' \
        '--exit[stop daemon]' \
        '-z+[deny interface]:_net_interfaces' \
        '--denyinterfaces=+[deny interface]:_net_interfaces' \
        '-A[allow IPv4]' \
        '--noarp[no ARP]' \
        '-B[no background]' \
        '-C+[no hook script]:str:' \
        '--nohook=+[no hook script]:str:' \
        '-D[client id]' \
        '--clientid[client id]' \
        '-E[lastlease]' \
        '--lastlease[lastlease]' \
        '-F+[FQDN]:f:(none ptr both disable)' \
        '--fqdn=+[FQDN]:f:(none ptr both disable)' \
        '-G[no gateway]' \
        '--nogateway[no gateway]' \
        '-H[xidhwaddr]' \
        '--xidhwaddr[xidhwaddr]' \
        '-I+[clientid]:str:' \
        '--clientid=+[clientid]:str:' \
        '-J[broadcast]' \
        '--broadcast[broadcast]' \
        '-K[no link]' \
        '--nolink[no link]' \
        '-L[no IPv4LL]' \
        '--noipv4ll[no IPv4LL]' \
        '-M[noinitial]' \
        '--master[master]' \
        '-N[renew]' \
        '--renew[renew]' \
        '-P+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '-Q+[option as integer]:str:' \
        '--require=+[option as integer]:str:' \
        '-R[abandon]' \
        '--abandon[abandon]' \
        '-S+[static var=val]:str:' \
        '--static=+[static var=val]:str:' \
        '-T[test]' \
        '--test[test]' \
        '-U[duid]' \
        '--dumplease[dump lease]' \
        '-X+[exclude]:str:' \
        '--exclude=+[exclude]:str:' \
        '-Y[noup]' \
        '--noup[noup]' \
        '-Z[disabled]' \
        '--disabled[disabled]' \
        '*:interface:_net_interfaces'
}

_dhcpcd-cli "$@"
