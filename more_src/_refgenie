#compdef refgenie
# Documentation: https://refgenie.org/refgenie/usage/
# refgenie - reference genome asset manager

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--silent[silence logging]' \
  '--verbosity=[set logging level]:level' \
  '--logdev[expand logging message format]' \
  '1:subcommand:(init list listr pull build seek seekr add remove getseq tag id subscribe unsubscribe alias compare upgrade populate populater)' \
  '*::args:_files' && ret=0

return ret
