#compdef zerodha-cli zerodha
# _zerodha-cli — Zerodha zerodha-cli CLI command-line frontend wrapping the Zerodha Indian retail stock broker REST WebSocket API Kite Connect 3 managing orders trades positions portfolio holdings funds GTT margin instruments market quote ohlc ltp historical-data charts dividends corporate-actions postback (Zerodha team, Go); cobra
# upstream: https://kite.trade/

_zerodha-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'portfolio:portfolio operations'
        'holding:holding operations'
        'funds:funds operations'
        'gtt:GTT operations'
        'margin:margin operations'
        'instrument:instrument operations'
        'quote:quote operations'
        'ohlc:OHLC data'
        'ltp:LTP last traded price'
        'historical:historical data'
        'charts:charts'
        'mutual-fund:mutual fund operations'
        'sip:SIP operations'
        'postback:postback management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--request-token=+[token]:str:' \
        '--user-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '--api-version=+[v]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zerodha-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel modify exit history)' \
                    '--variety=+[v]:v:(regular co iceberg amo auction)' \
                    '--exchange=+[e]:e:(NSE BSE NFO BFO CDS MCX)' \
                    '--tradingsymbol=+[ticker]:str:' \
                    '--transaction-type=+[t]:t:(BUY SELL)' \
                    '--order-type=+[t]:t:(MARKET LIMIT SL SL-M)' \
                    '--quantity=+[N]:n:' \
                    '--price=+[N]:str:' \
                    '--product=+[p]:p:(CNC MIS NRML CO MTF)' \
                    '*:order id:' ;;
                position|portfolio|holding|funds|gtt|margin|trade|instrument|mutual-fund|sip|postback) _arguments '1:op:(list get create update delete cancel)' '*:id:' ;;
                quote|ohlc|ltp|historical|charts) _arguments \
                    '--instrument=+[token]:str:' \
                    '--interval=+[i]:i:(minute 3minute 5minute 10minute 15minute 30minute 60minute day)' \
                    '--from=+[YYYY-MM-DD]:str:' \
                    '--to=+[YYYY-MM-DD]:str:' ;;
            esac
            ;;
    esac
}

_zerodha-cli "$@"
