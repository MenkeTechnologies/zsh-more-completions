#compdef kudu

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'cluster:cluster operations (health, rebalance)'
  'diagnose:parse diagnostic logs for stack traces and metrics'
  'fs:interact with local Kudu filesystem'
  'hms:Hive Metastore integration management'
  'local_replica:work with tablet replicas on local filesystem'
  'master:operate on Kudu Master servers'
  'pbc:handle protobuf container files'
  'perf:performance testing (load gen, scanning)'
  'remote_replica:manage tablet replicas on remote tservers'
  'table:create and modify tables'
  'tablet:tablet-level operations'
  'tserver:control Tablet Server instances'
  'test:testing utilities'
  'txn:inspect transaction state'
  'wal:examine write-ahead logs'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kudu subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cluster)
        _values 'cluster action' \
          'ksck' 'rebalance' 'check_quiescing_state' && ret=0
        ;;
      (master)
        _values 'master action' \
          'add' 'authz_cache' 'dump_memtrackers' 'get_flags' 'list' \
          'remove' 'run' 'set_flag' 'status' 'timestamp' 'unsafe_rebuild' \
          'unsafe_change_config' && ret=0
        ;;
      (tserver)
        _values 'tserver action' \
          'dump_memtrackers' 'get_flags' 'list' 'quiesce' 'set_flag' \
          'state' 'status' 'timestamp' 'unsafe_change_config' && ret=0
        ;;
      (table)
        _values 'table action' \
          'add_column' 'add_range_partition' 'change_owner' 'change_extra_config' \
          'column_remove_default' 'column_set_block_size' 'column_set_compression' \
          'column_set_default' 'column_set_encoding' 'copy' 'create' 'delete_column' \
          'describe' 'drop_range_partition' 'list' 'locate_row' 'recall' \
          'rename_column' 'rename_table' 'scan' 'set_extra_configs' \
          'set_limit' 'set_replication_factor' 'statistics' && ret=0
        ;;
      (tablet)
        _values 'tablet action' \
          'add_replica' 'change_replica_type' 'leader_step_down' 'list' \
          'move_replica' 'unsafe_replace_tablet' 'unsafe_change_config' && ret=0
        ;;
      (perf)
        _values 'perf action' \
          'loadgen' 'tablet_scan' 'table_scan' && ret=0
        ;;
      (fs)
        _values 'fs action' \
          'check' 'dump' 'format' 'list' 'update_dirs' && ret=0
        ;;
      (local_replica)
        _values 'local_replica action' \
          'cmeta' 'copy_from_local' 'copy_from_remote' 'data_size' 'delete' \
          'dump' 'list' 'tmeta' && ret=0
        ;;
      (remote_replica)
        _values 'remote_replica action' \
          'check' 'copy' 'delete' 'dump' 'list' 'unsafe_change_config' && ret=0
        ;;
      (wal)
        _values 'wal action' 'dump' && ret=0
        ;;
      (pbc)
        _values 'pbc action' 'dump' && ret=0
        ;;
      (hms)
        _values 'hms action' 'check' 'downgrade' 'fix' 'precheck' 'list_notifications' && ret=0
        ;;
      (txn)
        _values 'txn action' 'list_active' 'list' 'kill' 'finalize_commit' && ret=0
        ;;
      (diagnose)
        _values 'diagnose action' 'parse_metrics' 'parse_stacks' && ret=0
        ;;
    esac
    ;;
esac

return ret
