#compdef rust-size
# Documentation: https://github.com/rust-embedded/cargo-binutils
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# cargo-binutils wrapper invoking llvm-size.

# rust-size: cargo-binutils wrapper for llvm-size
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-A[Berkeley output (default)]' \
  '-B[BSD output]' \
  '--format=[output format]:format:(berkeley sysv)' \
  '*:object file:_files' && ret=0
return ret
