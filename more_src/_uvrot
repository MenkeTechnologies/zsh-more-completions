#compdef uvrot
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvrot.html
# Rotate uv coordinates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'out=[out keyword]:out:' \
  'select=[select keyword]:select:' \
  'angle=[angle keyword]:angle:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
