#compdef zypper2
# _zypper2 — SUSE openSUSE Zypper zypper2 CLI command-line frontend wrapping the Zypper open-source command-line package manager for openSUSE Leap SLES Linux based on libzypp ZYpp library written in C++ originally Novell SUSE now openSUSE/SUSE rich command-line interface to ZYpp uses libsolv for fast dependency resolution help shell repos rr addrepo removerepo modifyrepo refresh services addservice removeservice modifyservice install remove install-new-recommends in rm verify update up patch list-patches patches list-updates dist-upgrade dup search what-provides info if patch-info pattern-info source-install si build-deps-install patch-check pchk locks ll cleanlocks (SUSE openSUSE team Novell, C++); custom argparse
# upstream: https://en.opensuse.org/Portal:Zypper

_zypper2() {
    local -a sub=(
        'help:show help'
        'shell:open zypper shell'
        'repos:list repos'
        'lr:list repos (alias)'
        'addrepo:add a repo'
        'ar:add a repo (alias)'
        'removerepo:remove a repo'
        'rr:remove a repo (alias)'
        'renamerepo:rename a repo'
        'nr:rename repo (alias)'
        'modifyrepo:modify a repo'
        'mr:modify a repo (alias)'
        'refresh:refresh repos'
        'ref:refresh (alias)'
        'clean:clean cache'
        'cc:clean cache (alias)'
        'services:list services'
        'ls:list services (alias)'
        'addservice:add a service'
        'as:add a service (alias)'
        'removeservice:remove a service'
        'rs:remove a service (alias)'
        'modifyservice:modify a service'
        'ms:modify a service (alias)'
        'refresh-services:refresh services'
        'refs:refresh services (alias)'
        'install:install packages'
        'in:install (alias)'
        'remove:remove packages'
        'rm:remove (alias)'
        'verify:verify dependencies'
        've:verify (alias)'
        'source-install:install source packages'
        'si:source install (alias)'
        'install-new-recommends:install new recommended'
        'inr:install new recommended (alias)'
        'update:update packages'
        'up:update (alias)'
        'list-updates:list available updates'
        'lu:list updates (alias)'
        'patch:install needed patches'
        'list-patches:list patches'
        'lp:list patches (alias)'
        'dist-upgrade:dist upgrade'
        'dup:dist upgrade (alias)'
        'patch-check:check for patches'
        'pchk:patch check (alias)'
        'search:search packages'
        'se:search (alias)'
        'info:show package info'
        'if:info (alias)'
        'patch-info:show patch info'
        'pattern-info:show pattern info'
        'product-info:show product info'
        'packages:list packages'
        'pa:list packages (alias)'
        'patterns:list patterns'
        'pt:list patterns (alias)'
        'products:list products'
        'pd:list products (alias)'
        'what-provides:list what-provides'
        'wp:what-provides (alias)'
        'addlock:add lock'
        'al:add lock (alias)'
        'removelock:remove lock'
        'rl:remove lock (alias)'
        'locks:list locks'
        'll:list locks (alias)'
        'cleanlocks:clean locks'
        'cl:clean locks (alias)'
        'targetos:show target os'
        'tos:target os (alias)'
        'versioncmp:compare versions'
        'vcmp:version compare (alias)'
        'licenses:list licenses'
        'lic:licenses (alias)'
        'download:download packages'
        'source-download:download source'
        'needs-rebooting:check needs reboot'
        'ps:list processes using deleted'
        'purge-kernels:purge old kernels'
        'subcommand:list subcommands'
        'system-architecture:show arch'
        'console-output:console output'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '-n[non-interactive]' \
        '--non-interactive[non interactive]' \
        '--non-interactive-include-reboot-patches[non-interactive include reboot]' \
        '--xmlout[XML output]' \
        '-x[XML output]' \
        '-c+[config file]:file:_files -g "zypper.conf *.conf"' \
        '--config=+[file]:file:_files -g "zypper.conf *.conf"' \
        '--no-cd[no CD/DVD repos]' \
        '--no-refresh[no refresh]' \
        '--no-confirm[no confirmation]' \
        '-y[no confirmation]' \
        '--terse[terse output]' \
        '-t+[type]:t:(package patch pattern product srcpackage)' \
        '--type=+[t]:t:(package patch pattern product srcpackage)' \
        '-r+[repo]:str:' \
        '*-r+[repo]:str:' \
        '--repo=+[name]:str:' \
        '--from=+[repo]:str:' \
        '--reposd-dir=+[dir]:dir:_files -/' \
        '-D+[reposd-dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '-C+[cache-dir]:dir:_files -/' \
        '--raw-cache-dir=+[dir]:dir:_files -/' \
        '--solv-cache-dir=+[dir]:dir:_files -/' \
        '--pkg-cache-dir=+[dir]:dir:_files -/' \
        '--gpg-auto-import-keys[auto-import keys]' \
        '--ignore-unknown[ignore unknown]' \
        '-i[ignore unknown]' \
        '-l[auto-agree-with-licenses]' \
        '--auto-agree-with-licenses[auto agree licenses]' \
        '--auto-agree-with-product-licenses[auto agree product licenses]' \
        '--debug-solver[debug solver]' \
        '--no-recommends[no recommends]' \
        '--recommends[recommends]' \
        '--allow-vendor-change[allow vendor change]' \
        '--no-allow-vendor-change[no allow vendor change]' \
        '--allow-arch-change[allow arch change]' \
        '--allow-name-change[allow name change]' \
        '--allow-downgrade[allow downgrade]' \
        '--no-allow-downgrade[no allow downgrade]' \
        '--force[force]' \
        '-f[force]' \
        '--force-resolution[force resolution]' \
        '--no-force-resolution[no force resolution]' \
        '--replacefiles[replace files]' \
        '--dry-run[dry run]' \
        '--details[show details]' \
        '--download=+[m]:m:(only in-advance in-heaps as-needed)' \
        '--download-only[download only]' \
        '-d[download only]' \
        '--download-in-advance[download in advance]' \
        '--download-in-heaps[download in heaps]' \
        '--download-as-needed[download as needed]' \
        '--root=+[dir]:dir:_files -/' \
        '-R+[root]:dir:_files -/' \
        '--installroot=+[dir]:dir:_files -/' \
        '--disable-system-resolvables[disable system resolvables]' \
        '--plus-repo=+[uri]:str:' \
        '*--plus-repo=+[uri]:str:' \
        '--plus-content=+[tag]:str:' \
        '*--plus-content=+[tag]:str:' \
        '--disable-repositories[disable repos]' \
        '--no-cd[no CD]' \
        '--no-remote[no remote]' \
        '--releasever=+[v]:str:' \
        '--userdata=+[s]:str:' \
        '-i[case-insensitive]' \
        '-u[uninstalled only]' \
        '--uninstalled-only[uninstalled only]' \
        '--installed-only[installed only]' \
        '-r[repo]' \
        '-s[search]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zypper subcommand' sub ;;
        args)
            case $words[1] in
                install|in|remove|rm|info|if|source-install|si|verify|ve|download|search|se|what-provides|wp|update|up|patch|patches|locks|ll|addlock|al|removelock|rl) _arguments '*:package:' ;;
                addrepo|ar|removerepo|rr|renamerepo|nr|modifyrepo|mr|refresh|ref) _arguments '*:repo:' ;;
            esac
            ;;
    esac
}

_zypper2 "$@"
