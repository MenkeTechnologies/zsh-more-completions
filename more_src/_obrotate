#compdef obrotate
# obrotate — rotate a bond in a molecular structure

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  ':SMARTS pattern:' \
  ':input file:_files -g "*.{sdf,mol,mol2,pdb,xyz,smi,cml}"' \
  ':atom1 index:' \
  ':atom2 index:' \
  ':atom3 index:' \
  ':atom4 index:' \
  ':angle (degrees):'
