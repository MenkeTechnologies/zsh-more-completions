#compdef ConvertToJpg
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ConvertToJpg.cxx — convert a 2D image to JPEG (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:infile.nii:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:out.jpg:_files -g "*.{jpg,jpeg}"' \
    && ret=0

return ret
