#compdef dgsh-conc
# Documentation: https://www.spinellis.gr/sw/dgsh/dgsh-conc.html
# dgsh-conc - directed graph shell input/output concentrator

local ret=1

_arguments -s -S \
  '(-o)-i[input concentrator: multiple inputs to single output]' \
  '(-i)-o[output concentrator: multiple outputs to single input]' \
  '*:program:_command_names -e' && ret=0

return ret
