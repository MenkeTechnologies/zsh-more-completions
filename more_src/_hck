#compdef hck

# Zsh completion for hck - fast cut replacement

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --delimiter)'{-d,--delimiter}'[field delimiter]:delimiter:' \
  '(-f --fields)'{-f,--fields}'[field ranges to select]:ranges:' \
  '(-D --output-delimiter)'{-D,--output-delimiter}'[output delimiter]:delimiter:' \
  '--no-mmap[do not use memory-mapped I/O]' \
  '(-z --try-decompress)'{-z,--try-decompress}'[try to decompress input]' \
  '(-e --regex-delimiter)'{-e,--regex-delimiter}'[use regex as delimiter]:regex:' \
  '(-E --exclude)'{-E,--exclude}'[exclude matching fields]' \
  '--header[use first line as header]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0

return ret
