#compdef gpgtar
# Documentation: gpgtar --help on gpgtar (GnuPG) 2.5.20
# Source: GnuPG gpgtar — encrypt or sign files into an archive (tar + gpg wrapper).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)--create[create an archive]' \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)--extract[extract an archive]' \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)'{-e,--encrypt}'[create an encrypted archive]' \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)'{-d,--decrypt}'[extract an encrypted archive]' \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)'{-s,--sign}'[create a signed archive]' \
    '(--create --extract -e --encrypt -d --decrypt -s --sign -t --list-archive)'{-t,--list-archive}'[list an archive]' \
    '(-c --symmetric)'{-c,--symmetric}'[symmetric encryption]' \
    '*'{-r,--recipient=}'[encrypt for USER-ID]:user-id:' \
    '*'{-u,--local-user=}'[USER-ID to sign or decrypt]:user-id:' \
    '(-o --output)'{-o,--output=}'[write output to FILE]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[somewhat more quiet]' \
    '--skip-crypto[skip crypto processing]' \
    '--dry-run[do not make any changes]' \
    '(-C --directory)'{-C,--directory=}'[change to DIRECTORY first]:dir:_files -/' \
    '(-T --files-from)'{-T,--files-from=}'[read names to create from FILE]:file:_files' \
    '--null[-T reads NUL-terminated names]' \
    '--gpg=[gpg program path]:pgm:_files' \
    '*--gpg-args=[extra args passed to gpg]:args:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:file or directory:_files' \
    && ret=0

return ret
