#compdef flit-core
# Documentation: https://man.archlinux.org/search?q=flit-core
# Reference accessed: 2026-05-16

# flit_core: minimal build backend for flit pyproject.toml builds
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'build-sdist:build sdist'
  'build-wheel:build wheel'
  'prepare-metadata:prepare metadata'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'flit-core command' commands && ret=0 ;;
esac
return ret
