#compdef sk

# Zsh completion for skim (sk) - Fuzzy finder

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-e,--exact}'[enable exact match]' \
  '--algo[fuzzy matching algorithm]:algo:(skim_v1 skim_v2 clangd)' \
  {-i,--case}'[case insensitive match]' \
  '+i[case sensitive match]' \
  '--regex[start in regex mode]' \
  '-n[comma-separated list of field index expressions for limiting search scope]:field:' \
  {-d,--delimiter}'[field delimiter regex]:delimiter:' \
  '--tac[reverse the order of input]' \
  '--no-sort[do not sort the result]' \
  '--tiebreak[comma-separated tiebreak criteria]:criteria:' \
  {-m,--multi}'[enable multi-select]' \
  '--no-multi[disable multi-select]' \
  '--bind[custom key bindings]:bindings:' \
  '--color[color scheme]:scheme:' \
  '--no-hscroll[disable horizontal scroll]' \
  '--height[display below the cursor with given height]:height:' \
  '--min-height[minimum height when --height is given in percent]:height:' \
  '--layout[choose layout]:layout:(default reverse reverse-list)' \
  '--reverse[equivalent to --layout=reverse]' \
  '--margin[screen margin]:margin:' \
  '--inline-info[display info inline]' \
  '--prompt[input prompt]:prompt:' \
  '--cmd-prompt[command mode prompt]:prompt:' \
  '--header[sticky header]:header:' \
  '--header-lines[number of header lines]:lines:' \
  '--ansi[enable ANSI color processing]' \
  '--tabstop[tab stop]:spaces:' \
  {-c,--cmd}'[command to invoke dynamically]:command:_command_names' \
  {-I,--replstr}'[replace string in command]:string:' \
  '--interactive[start in interactive mode]' \
  {-p,--preview}'[command for preview]:command:' \
  '--preview-window[preview window layout]:layout:' \
  {-q,--query}'[start the finder with the given query]:query:' \
  '--cmd-query[start the command mode query]:query:' \
  '--expect[comma-separated list of keys]:keys:' \
  '--read0[read input delimited by null characters]' \
  '--print0[print output delimited by null characters]' \
  {-f,--filter}'[filter mode]:query:' \
  '--select-1[select automatically when there is only one match]' \
  '--exit-0[exit immediately when there is no match]' \
  '--no-mouse[disable mouse]' \
  '--no-clear[do not clear finder on exit]' \
  && return 0
