#compdef litmus

_litmus_commands() {
  local -a commands=(
    'agent:manage Litmus agents'
    'chaos-experiment:manage chaos experiments'
    'completion:generate shell completion'
    'config:manage Litmus config'
    'connect:connect to a Litmus server'
    'create:create Litmus resources'
    'delete:delete Litmus resources'
    'describe:describe Litmus resources'
    'disconnect:disconnect from Litmus server'
    'get:get Litmus resources'
    'help:help about any command'
    'list:list Litmus resources'
    'run:run a chaos experiment'
    'version:print version'
  )
  _describe 'command' commands
}

_litmus() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '-h[display help]' \
    '--help[display help]' \
    '--config[config file]:file:_files' \
    '--kubeconfig[kubeconfig file]:file:_files' \
    '-n[namespace]:namespace' \
    '--namespace[namespace]:namespace' \
    '1:command:_litmus_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        connect)
          _arguments \
            '--endpoint[Litmus server endpoint]:url' \
            '--username[username]:user' \
            '--password[password]:pass'
          ;;
        create)
          _arguments '1:resource:(chaos-experiment chaos-scenario)'
          ;;
        get|describe|delete)
          _arguments '1:resource:(chaos-experiment chaos-scenario agent)'
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_litmus "$@"
