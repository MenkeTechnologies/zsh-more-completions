#compdef linkerd-proxy-init
# Documentation: https://github.com/linkerd/linkerd2-proxy-init/blob/main/proxy-init/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: linkerd/linkerd2-proxy-init proxy-init/cmd/root.go PersistentFlags.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --incoming-proxy-port/--outgoing-proxy-port short forms wrong;
# missing real flags --netns, --use-wait-flag, --timeout-close-wait-secs,
# --iptables-mode, --ipv6, --proxy-gid.

# linkerd-proxy-init: configures iptables rules in the pod network namespace
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --incoming-proxy-port)'{-p,--incoming-proxy-port}'=[inbound proxy port]:port:' \
  '(-o --outgoing-proxy-port)'{-o,--outgoing-proxy-port}'=[outbound proxy port]:port:' \
  '(-u --proxy-uid)'{-u,--proxy-uid}'=[proxy user UID]:n:' \
  '(-g --proxy-gid)'{-g,--proxy-gid}'=[proxy group GID]:n:' \
  '(-r --ports-to-redirect)'{-r,--ports-to-redirect}'=[inbound ports to redirect]:list:' \
  '--inbound-ports-to-ignore=[inbound ports to ignore]:list:' \
  '--outbound-ports-to-ignore=[outbound ports to ignore]:list:' \
  '--subnets-to-ignore=[subnets to ignore]:list:' \
  '--simulate[simulate (do not apply)]' \
  '--netns=[network namespace to enter]:netns:' \
  '(-w --use-wait-flag)'{-w,--use-wait-flag}'[use iptables -w flag]' \
  '--timeout-close-wait-secs=[iptables wait close-wait timeout (seconds)]:n:' \
  '--log-format=[log format]:fmt:(plain json)' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--iptables-mode=[iptables mode (legacy or nft)]:mode:(legacy nft)' \
  '--ipv6=[enable IPv6 (default true)]:bool:(true false)' \
  '--firewall-bin-path=[iptables bin path]:file:_files' \
  '--firewall-save-bin-path=[iptables-save bin path]:file:_files' && ret=0
return ret
