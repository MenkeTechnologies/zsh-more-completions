#compdef linkerd-proxy-init

# linkerd-proxy-init: configures iptables rules in the pod network namespace
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--incoming-proxy-port=[inbound proxy port]:port:' \
  '--outgoing-proxy-port=[outbound proxy port]:port:' \
  '--proxy-uid=[proxy user UID]:n:' \
  '--ports-to-redirect=[inbound ports to redirect]:list:' \
  '--inbound-ports-to-ignore=[inbound ports to ignore]:list:' \
  '--outbound-ports-to-ignore=[outbound ports to ignore]:list:' \
  '--subnets-to-ignore=[subnets to ignore]:list:' \
  '--simulate[simulate (do not apply)]' \
  '--log-format=[log format]:fmt:(plain json)' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--firewall-bin-path=[iptables bin path]:file:_files' \
  '--firewall-save-bin-path=[iptables-save bin path]:file:_files' \
  '*::linkerd-proxy-init args:_files' && ret=0
return ret
