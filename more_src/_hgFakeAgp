#compdef hgFakeAgp
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: create a fake AGP file by looking for gaps in a fasta sequence

local ret=1

_arguments -s -S \
  '-minContigGap=[minimum size for a gap between contigs (default 25)]:n' \
  '-minScaffoldGap=[minimum size for a gap between scaffolds (default 50000)]:n' \
  '-singleContigs[preserve contig name without index when sequence has no gaps]' \
  '1:input fasta:_files' \
  '2:output agp:_files' && ret=0

return ret
