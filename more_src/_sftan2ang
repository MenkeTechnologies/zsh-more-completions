#compdef sftan2ang
# Documentation: https://github.com/ahay/src/blob/master/system/seismic/Mtan2ang.c
# Madagascar: tangent to angle transformation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'na=[number of angles]:count' \
  'da=[angle increment]:value' \
  'a0=[starting angle]:value' \
  'extend=[temporary extension]:samples' \
  'top=[enable velocity-based processing]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
