#compdef wsclean-mp
# Documentation: https://wsclean.readthedocs.io/en/latest/distributed_imaging.html
# MPI-distributed WSClean; shares all wsclean options plus MPI-specific channel distribution.

local ret=1

_arguments -s -S \
  '-channel-to-node[map output channels to specific nodes, e.g. 0,0,1,2]:mapping:' \
  '-no-work-on-master[do not let the master node perform gridding work]' \
  '-compound-tasks[send facets from the same channel to the same node]' \
  '-channels-out[number of output channels]:count:' \
  '-j[number of threads per MPI process]:threads:' \
  '-parallel-gridding[number of parallel gridding tasks]:count:' \
  '-size[image size in pixels]:width: :height:' \
  '-scale[pixel scale, e.g. 1asec]:scale:' \
  '-name[output filename prefix]:name:' \
  '*:measurement set:_files -/' && ret=0

return ret
