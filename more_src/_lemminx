#compdef lemminx
# Documentation: https://man.archlinux.org/search?q=lemminx
# Reference accessed: 2026-05-16

# Zsh completion for LemMinX (Eclipse XML Language Server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--stdio[use stdio transport]' \
  '--port=[use TCP transport on port]:port:' \
  '--hostname=[hostname for TCP transport]:hostname:_hosts' && ret=0

return ret
