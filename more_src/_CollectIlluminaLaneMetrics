#compdef CollectIlluminaLaneMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectIlluminaLaneMetrics
# Picard: collect per-lane tile metrics from an Illumina run directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '--RUN_DIRECTORY=[Illumina run directory to generate lane metrics for]:dir:_files -/' \
  '--OUTPUT_DIRECTORY=[directory to which the output file is written]:dir:_files -/' \
  {-O=,--OUTPUT_PREFIX=}'[prefix prepended to the output file name]:prefix:' \
  {-RS=,--READ_STRUCTURE=}'[cluster logical structure (e.g. 25T8B25T)]:structure:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:directory:_files -/' && ret=0

return ret
