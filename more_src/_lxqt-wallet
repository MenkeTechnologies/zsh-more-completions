#compdef lxqt-wallet
# Documentation: https://github.com/lxqt/lxqt_wallet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxqt_wallet ships as a C++ library (frontend to KWallet/libsecret/etc),
# not a top-level CLI. Some downstream packaging installs an lxqt-wallet binary
# that only exposes built-in help and version.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
