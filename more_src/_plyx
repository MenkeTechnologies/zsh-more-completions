#compdef plyx
# Source: cargo binstall plyx@0.2.2
# Probed via: completions zsh
# Repository: https://github.com/TheRedDeveloper/plyx

autoload -U is-at-least

_plyx() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_plyx_commands" \
"*::: :->plyx" \
&& ret=0
    case $state in
    (plyx)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:plyx-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::args -- What to add (e.g. "shader-pipeline", "font comic sans"). If omitted, opens interactive mode:_default' \
&& ret=0
;;
(skill)
_arguments "${_arguments_options[@]}" : \
'--install[Install skill into ~/.claude/skills/ply-engine/SKILL.md]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(apk)
_arguments "${_arguments_options[@]}" : \
'--native[Use local NDK instead of Docker]' \
'--install[Install APK via adb after building]' \
'--auto[Non-interactive CI mode]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(web)
_arguments "${_arguments_options[@]}" : \
'--auto[Non-interactive CI mode]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ios)
_arguments "${_arguments_options[@]}" : \
'--device[Build for a real device instead of the simulator]' \
'--actions[Generate a GitHub Actions workflow for iOS CI builds]' \
'--auto[Non-interactive CI mode]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--install[Automatically install completions into your shell config]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_plyx_commands] )) ||
_plyx_commands() {
    local commands; commands=(
'init:Scaffold a new ply-engine project' \
'add:Add features or fonts to an existing project' \
'skill:Print the bundled Ply skill text, or install it into ~/.claude/skills' \
'apk:Build an Android APK' \
'web:Build for web (WASM)' \
'ios:Build for iOS (simulator or device)' \
'completions:Generate shell completions' \
    )
    _describe -t commands 'plyx commands' commands "$@"
}
(( $+functions[_plyx__add_commands] )) ||
_plyx__add_commands() {
    local commands; commands=()
    _describe -t commands 'plyx add commands' commands "$@"
}
(( $+functions[_plyx__apk_commands] )) ||
_plyx__apk_commands() {
    local commands; commands=()
    _describe -t commands 'plyx apk commands' commands "$@"
}
(( $+functions[_plyx__completions_commands] )) ||
_plyx__completions_commands() {
    local commands; commands=()
    _describe -t commands 'plyx completions commands' commands "$@"
}
(( $+functions[_plyx__init_commands] )) ||
_plyx__init_commands() {
    local commands; commands=()
    _describe -t commands 'plyx init commands' commands "$@"
}
(( $+functions[_plyx__ios_commands] )) ||
_plyx__ios_commands() {
    local commands; commands=()
    _describe -t commands 'plyx ios commands' commands "$@"
}
(( $+functions[_plyx__skill_commands] )) ||
_plyx__skill_commands() {
    local commands; commands=()
    _describe -t commands 'plyx skill commands' commands "$@"
}
(( $+functions[_plyx__web_commands] )) ||
_plyx__web_commands() {
    local commands; commands=()
    _describe -t commands 'plyx web commands' commands "$@"
}

if [ "$funcstack[1]" = "_plyx" ]; then
    _plyx "$@"
else
    compdef _plyx plyx
fi
