#compdef sukill
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/sukill.c
# SUKILL - zero out traces

local ret=1

_arguments -s -S \
  'key=[header name to select traces to kill]:k:' \
  'a=[header value identifying traces to kill]:a:' \
  'min=[first trace to kill (one-based)]:m:' \
  'count=[number of traces to kill]:c:' \
  '*:SU file:_files' && ret=0

return ret
