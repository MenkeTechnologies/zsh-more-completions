#compdef architect-cli
# Documentation: https://github.com/architect-team/architect-cli
# Reference accessed: 2026-05-23
# Verified: architect CLI reference (see also _architect).

# Zsh completion for architect-cli - Architect cloud development CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'autocomplete:autocomplete install instructions'
  'cluster:cluster operations'
  'clusters:manage clusters'
  'component:manage components'
  'components:list components'
  'config:CLI config'
  'deploy:deploy component'
  'destroy:destroy deployment'
  'dev:start local dev environment'
  'doctor:debugging info'
  'environment:manage environments'
  'environments:list environments'
  'envs:alias for environments'
  'exec:exec command in container'
  'help:show help'
  'init:initialize architect.yml'
  'link:link local component'
  'login:login to Architect Cloud'
  'logout:logout'
  'logs:show resource logs'
  'platform:manage platforms'
  'platforms:list platforms'
  'plats:alias for platforms'
  'push:push component'
  'register:register component'
  'scale:scale service'
  'secrets:manage secrets'
  'task:exec task'
  'unlink:unlink component'
  'unregister:unregister component'
  'update:update CLI'
  'whoami:show logged-in user'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'architect command' commands && ret=0
    ;;
esac

return ret
