#compdef tcode

# EMBOSS tcode: identify coding regions with Fickett TESTCODE statistic
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-window=[window size]:n:' \
  '-step=[window step size]:n:' \
  '-datafile=[Fickett statistic data file]:file:_files' \
  '-plot[plot result as graph]' \
  '-graph=[graph format]:fmt:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:DNA sequence:_files' && ret=0

return ret
