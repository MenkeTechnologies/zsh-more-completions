#compdef osh ysh oils oils-for-unix
# Documentation: https://man.archlinux.org/search?q=osh
# Reference accessed: 2026-05-16

# Zsh completion for Oils shell (OSH and YSH)
# https://oils.pub

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[execute command string]:command:' \
  '-i[force interactive mode]' \
  '-n[parse-only mode]' \
  '-O[set shell option]:option:' \
  '+O[unset shell option]:option:' \
  '--debug-file=[redirect debug logs]:file:_files' \
  '--xtrace-to-debug-file[send xtrace to debug file]' \
  '--help[display help]' \
  '--version[display version]' \
  '*:script:_files' && ret=0

return ret
