#compdef imgpkg vendir
# Documentation: https://github.com/carvel-dev/imgpkg
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (imgpkg)
    local -a commands
    commands=(
      'copy:copy bundle/image to dest'
      'describe:describe a bundle'
      'pull:pull bundle/image'
      'push:push bundle/image'
      'tag:tag commands'
      'completion:generate completion'
      'help:show help'
      'version:show version'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(--version)--version[show version]' \
      '*--no-color[no color]' \
      '*--debug[debug]' \
      '*--registry-ca-cert-path=[registry CA cert]:file:_files' \
      '*--registry-username=[registry user]:u:_users' \
      '*--registry-password=[registry pass]:p:' \
      '*--registry-token=[registry token]:t:' \
      '*--registry-anon[anon]' \
      '*--registry-azure-cr-config=[azure CR config]:file:_files' \
      '*--registry-response-header-timeout=[response timeout]:t:' \
      '*--registry-retry-count=[retry count]:n:' \
      '*--registry-verify-certs=[verify certs]:b:(true false)' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'imgpkg command' commands && ret=0 ;;
      (args)
        case $line[1] in
          (push)
            _arguments \
              '(-b --bundle)'{-b+,--bundle=}'[bundle]:b:' \
              '(-i --image)'{-i+,--image=}'[image]:i:' \
              '(-f --file)*'{-f+,--file=}'[file/dir]:file:_files' \
              '*--file-exclusion=[exclude file]:f:' \
              '--lock-output=[lock output]:file:_files' \
              '--use-default-image-tags[default image tags]' \
              '*: :' && ret=0 ;;
          (pull)
            _arguments \
              '(-b --bundle)'{-b+,--bundle=}'[bundle]:b:' \
              '(-i --image)'{-i+,--image=}'[image]:i:' \
              '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
              '--lock=[lock file]:file:_files' \
              '*: :' && ret=0 ;;
          (copy)
            _arguments \
              '(-b --bundle)'{-b+,--bundle=}'[src bundle]:b:' \
              '(-i --image)'{-i+,--image=}'[src image]:i:' \
              '--repo-based-tags[repo based tags]' \
              '--to-tar=[to tar file]:file:_files' \
              '--from-tar=[from tar file]:file:_files' \
              '--to-repo=[dest repo]:r:' \
              '--lock=[lock file]:file:_files' \
              '--lock-output=[lock output]:file:_files' \
              '--concurrency=[concurrency]:n:' \
              '--include-non-distributable-layers[include nondist]' \
              '*: :' && ret=0 ;;
          (describe)
            _arguments \
              '(-b --bundle)'{-b+,--bundle=}'[bundle]:b:' \
              '(-o --output-type)'{-o+,--output-type=}'[output]:o:(text yaml)' \
              '*: :' && ret=0 ;;
          (tag)
            _arguments '1:subcommand:(list resolve)' '*: :' && ret=0 ;;
          (completion)
            _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
          (*) _files ;;
        esac ;;
    esac ;;
  (vendir)
    local -a vc
    vc=(
      'sync:sync directories'
      'init:initialize vendir.yml'
      'completion:generate completion'
      'help:show help'
      'version:show version'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*--no-color[no color]' \
      '*--debug[debug]' \
      '*--column=[columns csv]:list:' \
      '*--json[JSON output]' \
      '1: :->vc' \
      '*::arg:->vargs' && ret=0
    case $state in
      (vc) _describe -t cmds 'vendir command' vc && ret=0 ;;
      (vargs)
        case $line[1] in
          (sync)
            _arguments \
              '(-d --directory)*'{-d+,--directory=}'[directory]:dir:_files -/' \
              '(-f --file)*'{-f+,--file=}'[vendir file]:file:_files' \
              '--locked[use lock]' \
              '--lock-file=[lock file]:file:_files' \
              '--chdir=[chdir]:dir:_files -/' \
              '--allow-all-symlink-destinations[allow all symlinks]' \
              '*--symlink-allow=[allow symlink]:dir:_files -/' \
              '*: :' && ret=0 ;;
          (completion)
            _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
          (*) _files ;;
        esac ;;
    esac ;;
esac

return ret
