#compdef appoptics appoptics-cli
# _appoptics — SolarWinds AppOptics appoptics-cli CLI command-line frontend to the SolarWinds AppOptics application performance monitoring APM REST API ingesting custom metrics events spans alerts annotations for distributed traces query agents host-checks dashboards integration with downstream alert-routing notifications (SolarWinds team, JavaScript); commander
# upstream: https://www.solarwinds.com/appoptics/

_appoptics() {
    local -a sub=(
        'auth:authenticate'
        'measurements:post measurements'
        'events:post events'
        'spans:post spans'
        'annotations:post annotations'
        'alerts:alert management'
        'dashboards:dashboard management'
        'snapshots:snapshot management'
        'metrics:metric management'
        'hosts:host inventory'
        'tags:tag management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appoptics subcommand' sub ;;
        args)
            case $words[1] in
                measurements|events|spans|annotations) _arguments '*:file:_files -g "*.json"' ;;
                alerts|dashboards|metrics|hosts|tags|snapshots) _arguments '1:op:(list show create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_appoptics "$@"
