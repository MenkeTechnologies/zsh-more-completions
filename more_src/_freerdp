#compdef freerdp xfreerdp xfreerdp3 wlfreerdp sdl-freerdp sdl-freerdp3
# Documentation: https://manpages.debian.org/bookworm/freerdp2-x11/xfreerdp.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--list-monitors[list monitors and exit]' \
  '(- *)--kbd-list[list keyboard layouts]' \
  '/v:[server (host:port)]:host:_hosts' \
  '/u:[username]:user:' \
  '/d:[domain]:domain:' \
  '/p:[password]:password:' \
  '/from-stdin[read password from stdin]' \
  '/w:[screen width]:width:' \
  '/h:[screen height]:height:' \
  '/size:[screen size WxH or percent]:size:' \
  '/f[fullscreen]' \
  '/multimon[multi-monitor]' \
  '/monitors:[monitor index list]:monitors:' \
  '/bpp:[color depth]:bpp:(8 15 16 24 30 32)' \
  '/gdi:[GDI backend]:backend:(sw hw)' \
  '/network:[network type]:type:(modem broadband-low broadband-high wan lan autodetect)' \
  '/sound:[enable audio with sub-options]:opts:' \
  '/microphone:[enable microphone redirection with sub-options]:opts:' \
  '+clipboard[enable clipboard redirection]' \
  '/app:[remote app program]:program:' \
  '/app-cmd:[remote app command line]:cmd:' \
  '/g:[gateway server]:gw:' \
  '/gu:[gateway username]:user:' \
  '/gp:[gateway password]:pass:' \
  '/gd:[gateway domain]:domain:' \
  '/cert:[certificate options]:opts:' \
  '/tls-seclevel:[TLS security level]:level:(0 1 2 3 4 5)' \
  '/sec:[security protocol]:protocol:(rdp tls nla ext)' \
  '/log-level:[logging level]:level:(OFF FATAL ERROR WARN INFO DEBUG TRACE)' \
  '/log-filters:[per-tag log levels]:filters:' \
  '/rfx[enable RemoteFX]' \
  '/nsc[enable NSCodec]' \
  '/gfx:[enable RDP8 GFX pipeline]:opts:' \
  '+gfx-progressive[enable progressive GFX]' \
  '+gfx-small-cache[GFX small cache mode]' \
  '+gfx-thin-client[GFX thin client mode]' \
  '/drive:[mount drive name,path]:drive:' \
  '*::passthrough:' && ret=0

return ret
