#compdef gardenctl

_gardenctl_commands() {
  local -a commands=(
    'config:Manage gardenctl configuration'
    'get:Get resources'
    'ls:List resources'
    'target:Set or show targeting scope'
    'ssh:SSH to a node or pod'
    'kubectl:Run kubectl on targeted cluster'
    'ka:kubectl alias'
    'completion:Generate shell completion'
    'provider:Cloud provider operations'
    'version:Print version'
    'help:Show help'
    'resolve:Resolve targeting to show current state'
    'rc:Register completion'
    'env:Print environment variables for targeted cluster'
  )
  _describe -t commands 'gardenctl command' commands
}

_gardenctl() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
    '--config[Config file]:file:_files' \
    '1:command:_gardenctl_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        target)
          _arguments \
            '--garden[Target a garden]:garden:' \
            '--project[Target a project]:project:' \
            '--seed[Target a seed]:seed:' \
            '--shoot[Target a shoot]:shoot:' \
            '--namespace[Target a namespace]:namespace:' \
            '--control-plane[Target the control plane]' \
            '--unset[Unset the current target]'
          ;;
        get)
          local -a resources=(
            'garden:Get garden details'
            'project:Get project details'
            'seed:Get seed details'
            'shoot:Get shoot details'
            'secrets:Get secrets'
          )
          _describe -t resources 'resource' resources
          ;;
        ls)
          local -a resources=(
            'gardens:List gardens'
            'projects:List projects'
            'seeds:List seeds'
            'shoots:List shoots'
            'issues:List issues'
          )
          _describe -t resources 'resource' resources
          ;;
        ssh)
          _arguments \
            '--interactive[Interactive mode]' \
            '--node[Node name]:node:' \
            '--cidr[CIDR range for bastion]:cidr:' \
            '1:target:'
          ;;
        config)
          local -a subcommands=(
            'view:View configuration'
            'set-garden:Set garden configuration'
            'delete-garden:Delete garden configuration'
          )
          _describe -t subcommands 'config subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_gardenctl "$@"
