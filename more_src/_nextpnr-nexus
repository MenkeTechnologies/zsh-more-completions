#compdef nextpnr-nexus
# _nextpnr-nexus — YosysHQ nextpnr-nexus CLI place-and-route portable open-source FPGA P&R tool targeting Lattice Nexus family LIFCL CrossLink-NX Certus-NX chips packed JSON netlist from Yosys producing config text for ecpprog flash (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/nextpnr

_nextpnr-nexus() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '--json=+[json netlist]:file:_files -g "*.json"' \
        '--pdc=+[pdc constraints]:file:_files -g "*.pdc"' \
        '--fasm=+[fasm output]:file:_files -g "*.fasm"' \
        '--write=+[json output]:file:_files -g "*.json"' \
        '--device=+[d]:d:(LIFCL-17-9BG196C LIFCL-17-7UWG72C LIFCL-40-9BG400CES LIFCL-40-9BG256C LIFCL-40-8MG289C LIFCL-40-7BG121C LFCPNX-100-9LFG672C)' \
        '--family=+[f]:f:(LIFCL LFCPNX LFD2NX)' \
        '--freq=+[MHz]:n:' \
        '--seed=+[seed]:n:' \
        '--placer=+[p]:p:(heap sa)' \
        '--router=+[r]:r:(router1 router2)' \
        '--no-route[skip routing]' \
        '--no-place[skip placement]' \
        '--no-pack[skip packing]' \
        '--placer-heap-alpha=+[alpha]:n:' \
        '--placer-heap-beta=+[beta]:n:' \
        '--threads=+[N]:n:' \
        '--gui[gui mode]' \
        '--report=+[file]:file:_files -g "*.json"' \
        '--detailed-timing-report[detailed timing report]' \
        '--no-tmdriv[disable timing-driven]' \
        '--ignore-loops[ignore combinational loops]' \
        '--randomize-seed[randomize seed]' \
        '*:json file:_files -g "*.json"'
}

_nextpnr-nexus "$@"
