#compdef whysynth
# Documentation: https://man.archlinux.org/search?q=whysynth
# Reference accessed: 2026-05-16

# WhySynth: subtractive DSSI software synthesizer plugin
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '*:WhySynth .so DSSI plugin:_files -g "*.so"' && ret=0
return ret
