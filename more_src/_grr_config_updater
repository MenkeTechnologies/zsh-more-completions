#compdef grr_config_updater
# Documentation: https://manpages.debian.org/testing/grr-server/grr_config_updater.1
# GRR Rapid Response server configuration updater

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '--verbose[turn on verbose logging]' \
  '--debug[break in debugger on unhandled exception]' \
  '--config=[primary configuration file]:file:_files' \
  '--secondary_configs=[secondary config files]:files:_files' \
  '--config_help[print config help]' \
  '--context=[config contexts]:context' \
  '--plugins=[additional plugin files]:files:_files' \
  '--disallow_missing_config_definitions[error on undefined config options]' \
  '(-p --parameter)'{-p,--parameter}'=[global config override]:param' \
  '--list_storage[list storage subsystems]' \
  '--share_dir=[directory containing grr data]:directory:_directories' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'grr_config_updater command' \
      'generate_keys[generate crypto keys]' \
      'repack_clients[repack client binaries]' \
      'initialize[setup a new GRR install]' \
      'set_var[set a config variable]' \
      'update_user[update user settings]' \
      'add_user[add a new user]' \
      'delete_user[delete a user account]' \
      'show_user[show or list users]' \
      'upload_raw[upload a raw file to aff4 path]' \
      'upload_artifact[upload a json artifact file]' \
      'upload_python[sign and upload a python hack]' \
      'upload_exe[sign and upload an executable]' \
      'sign_component[authenticode sign the component]' \
      'upload_component[sign and upload a client component]' \
      'upload_components[sign and upload all components]' && ret=0
    ;;
esac

return ret
