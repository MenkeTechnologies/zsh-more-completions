#compdef opentelemetry-collector otelcol
# Documentation: https://github.com/open-telemetry/opentelemetry-collector/blob/main/otelcol/flags.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# opentelemetry-collector: OpenTelemetry Collector
local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'components:list available components'
  'validate:validate the configuration'
  'featuregate:display feature gates information'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--config=[location of config file/URI (may repeat)]:uri:_files' \
  '*--set=[set config property (e.g. processors.batch.timeout=2s)]:kv:' \
  '--feature-gates=[enable/disable feature gates]:gates:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'otelcol subcommand' subcommands && ret=0 ;;
esac
return ret
