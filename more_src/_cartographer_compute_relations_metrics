#compdef cartographer_compute_relations_metrics
# Documentation: https://github.com/cartographer-project/cartographer/blob/master/cartographer/ground_truth/compute_relations_metrics_main.cc
# Compute relation metrics against ground truth for a Cartographer pose graph

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-pose_graph_filename=[proto stream file containing the pose graph to assess]:file:_files -g "*.pbstream"' \
  '-relations_filename=[relations file containing the ground truth]:file:_files' \
  '-read_text_file_with_unix_timestamps[read relations text files with unix timestamps]' \
  '-write_relation_metrics[export relation metrics as CSV]' && ret=0

return ret
