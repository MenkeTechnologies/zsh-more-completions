#compdef qmrestore
# _qmrestore — Proxmox Server Solutions qmrestore restore Proxmox VE QEMU VM backup archives (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=qemu-server.git

_qmrestore() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--bwlimit=+[bandwidth limit kbps]:n:' \
        '--force[force overwrite existing VM]' \
        '--live-restore[live restore from PBS]' \
        '--pool=+[resource pool]:str:' \
        '--storage=+[target storage]:str:' \
        '--unique[generate unique properties]' \
        '--start[start VM after restore]' \
        '--workers=+[N]:n:' \
        '1:archive:_files -g "*.vma *.vma.lzo *.vma.gz *.vma.zst *.tar *.tar.lzo *.tar.gz *.tar.zst"' \
        '2:VM id:'
}

_qmrestore "$@"
