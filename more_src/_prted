#compdef prted
# Documentation: https://docs.prrte.org/en/latest/manpages/prted.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above plus local `prted --help` output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[enable typical debug options]' \
  '--debug[top-level PRTE debug switch]' \
  '--bootstrap[bootstrap PRTE daemon]' \
  '--gmca=[global MCA parameter]:param:' \
  '--hetero-nodes[indicate cluster has heterogeneous nodes]' \
  '--set-sid[direct daemon to separate session]' \
  '--system-server[start daemon as system server]' \
  '--tree-spawn[spawn daemons in tree pattern]' && ret=0

return ret
