#compdef cargo-wasix
# Documentation: https://github.com/wasix-org/cargo-wasix
# cargo-wasix - Cargo wrapper for building and running WebAssembly wasi(x)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '--release[build the optimized wasix artifact]' \
  '1:command:(build run test bench check fix download-toolchain version self)' \
  '*::args:_files' && ret=0

return ret
