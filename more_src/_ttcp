#compdef ttcp
# Documentation: https://linux.die.net/man/1/ttcp
# ttcp - test TCP/UDP performance

local ret=1

_arguments -s -S \
  '-t[transmit mode]' \
  '-r[receive mode]' \
  '-u[use UDP instead of TCP]' \
  '-s[source/sink data pattern instead of stdin/stdout]' \
  '-l[length of buffers in bytes (default 8192)]:length' \
  '-b[set size of socket buffer]:size' \
  '-n[number of source buffers transmitted (default 2048)]:numbufs' \
  '-p[port number to send to or listen on (default 2000)]:port' \
  '-D[do not buffer TCP data (TCP_NODELAY)]' \
  '-B[output only complete blocks when receiving]' \
  '-A[align start of buffers to this modulus (default 16384)]:align' \
  '-O[align start of buffers to this offset (default 0)]:offset' \
  '-f[throughput rate format (k/K/m/M/g/G)]:format:(k K m M g G)' \
  '-T[touch the data as read to measure cache effects]' \
  '-v[verbose: print more statistics]' \
  '-d[debug: set the SO_DEBUG socket option]' \
  '*::host:_hosts' && ret=0

return ret
