#compdef connect-standalone connect-standalone.sh
# Documentation: https://github.com/apache/kafka/blob/trunk/bin/connect-standalone.sh
# Reference accessed: 2026-05-17
# Verified: upstream Apache Kafka script at the URL above. Supports -daemon
# and forwards -name/-loggingdir through to kafka-run-class.sh.

local -a arguments

arguments=(
    '-daemon[Run as daemon]'
    '-name[Connector name]:name'
    '-loggingdir[Logging directory]:dir:_directories'
    '*:properties file:_files -g "*.properties"'
)

_arguments -s -S $arguments
