#compdef connect-standalone connect-standalone.sh
# Documentation: https://man.archlinux.org/search?q=connect-standalone
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-daemon[Run as daemon]'
    '-name[Connector name]:name'
    '-loggingdir[Logging directory]:dir:_directories'
    '*:properties file:_files -g "*.properties"'
)

_arguments -s -S $arguments
