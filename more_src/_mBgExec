#compdef mBgExec
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mBgExec.html
# Apply background corrections to a set of reprojected images

local ret=1

_arguments -s -S \
  '-p+[directory containing projected images]:projdir:_files -/' \
  '-s+[write output to status file]:statusfile:_files' \
  '-d[enable debugging]' \
  '-n[no area images are present]' \
  '1:images table:_files -g "*.tbl"' \
  '2:corrections table:_files -g "*.tbl"' \
  '3:corrected-output directory:_files -/' && ret=0

return ret
