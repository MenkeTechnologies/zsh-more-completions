#compdef kgateway-sds sds
# _kgateway-sds — kgateway Envoy SDS server sidecar (serves Istio-mTLS cert rotations into a co-located Envoy via the SDS protocol)
# upstream: https://github.com/kgateway-dev/kgateway
# Source: cmd/sds/main.go + pkg/sds/run.go on tip; no CLI flags — env vars SDS_SERVER_ADDRESS, SDS_CLIENT, POD_NAME, POD_NAMESPACE, ISTIO_MTLS_SDS_ENABLED, ISTIO_CERT_DIR, ISTIO_SERVER_CERT, ISTIO_VALIDATION_CONTEXT drive runtime behaviour.

_kgateway-sds() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_kgateway-sds "$@"
