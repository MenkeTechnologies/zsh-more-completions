#compdef ghostfolio
# _ghostfolio — Thomas Kaul Ghostfolio open-source self-hosted wealth management and portfolio tracking platform (ghostfolio team, NestJS/Node.js); standard argv
# upstream: https://github.com/ghostfolio/ghostfolio

_ghostfolio() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.env *.json"' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--host=+[bind host]:host:_hosts' \
        '--database-url=+[postgres url]:str:' \
        '--redis-host=+[redis host]:host:_hosts' \
        '--redis-port=+[redis port]:port:_ports' \
        '--redis-password=+[redis password]:str:' \
        '--redis-db=+[redis db]:n:' \
        '--access-token-salt=+[salt]:str:' \
        '--jwt-secret-key=+[jwt secret]:str:' \
        '--api-key-coingecko-demo=+[key]:str:' \
        '--api-key-coingecko-pro=+[key]:str:' \
        '--api-key-financial-modeling-prep=+[key]:str:' \
        '--api-key-rapid-api=+[key]:str:' \
        '--enable-feature-fear-and-greed-index[fear/greed index]' \
        '--enable-feature-import[CSV import]' \
        '--enable-feature-read-only-mode[read only]' \
        '--enable-feature-statistics[stats]' \
        '--enable-feature-subscription[subscriptions]' \
        '--enable-feature-system-message[system message]' \
        '--data-source-import-batch-size=+[N]:n:' \
        '--data-gathering-cron-stock-split=+[cron]:str:' \
        '--root-url=+[root URL]:url:_urls' \
        '--cache-quotes-ttl=+[seconds]:n:' \
        '--cache-statistics-ttl=+[seconds]:n:' \
        '--log-level=+[level]:l:(verbose debug log warn error)' \
        '--cors-allowed-origin=+[origin]:str:'
}

_ghostfolio "$@"
