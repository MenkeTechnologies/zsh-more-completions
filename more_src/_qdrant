#compdef qdrant
# Documentation: https://man.archlinux.org/search?q=qdrant
# Reference accessed: 2026-05-16

_arguments -s \
  '--bootstrap=[bootstrap URI]:uri:' \
  '--uri=[node URI]:uri:' \
  '(-f --force-snapshot)'{-f,--force-snapshot}'[force snapshot recovery]' \
  '*--snapshot=[collection snapshot path:name]:snapshot:' \
  '*--collection-snapshot=[collection snapshot path:name]:snapshot:' \
  '--storage-snapshot=[storage snapshot path]:file:_files' \
  '--config-path=[config file]:file:_files -g "*.(yaml|yml|json)"' \
  '--disable-telemetry[disable telemetry]' \
  '--stacktrace[print stacktrace on panic]' \
  '--reinit[reinitialize node]' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]'
