#compdef spamd
# Documentation: https://man.archlinux.org/search?q=spamd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(-P --pidfile)'{-P,--pidfile}'+[pid file]:file:_files' \
  '(-c --create-prefs)'{-c,--create-prefs}'[create user prefs]' \
  '(-i --listen)'{-i,--listen}'+[listen address]:addr:' \
  '(-p --port)'{-p,--port}'+[listen port]:port:' \
  '(-A --allowed-ips)'{-A,--allowed-ips}'+[allowed clients]:ips:' \
  '(-u --username)'{-u,--username}'+[run as user]:user:_users' \
  '(-g --groupname)'{-g,--groupname}'+[run as group]:group:_groups' \
  '(-q --sql-config)'{-q,--sql-config}'[use SQL config]' \
  '(-Q --setuid-with-sql)'{-Q,--setuid-with-sql}'[setuid with SQL]' \
  '(-x --nouser-config)'{-x,--nouser-config}'[no user config]' \
  '(-D --debug)'{-D,--debug}'+[debug area]:area:' \
  '(-v --vpopmail)'{-v,--vpopmail}'[use vpopmail]' \
  '(-s --syslog)'{-s,--syslog}'+[log facility]:facility:' \
  '(-L --local)'{-L,--local}'[no network tests]' \
  '(--max-children)--max-children=+[max children]:n:' \
  '(--min-children)--min-children=+[min children]:n:' \
  '(--max-conn-per-child)--max-conn-per-child=+[max conns]:n:' \
  '(--timeout-child)--timeout-child=+[child timeout]:sec:' \
  '(--timeout-tcp)--timeout-tcp=+[tcp timeout]:sec:' \
  '(--socketpath)--socketpath=+[socket path]:file:_files' \
  '(--socketowner)--socketowner=+[socket owner]:user:_users' \
  '(--socketgroup)--socketgroup=+[socket group]:group:_groups' \
  '(--socketmode)--socketmode=+[socket mode]:mode:' \
  '(--pre-fork)--pre-fork[pre-fork mode]' && ret=0

return ret
