#compdef secretlint

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--secretlintrc=[config file]:config file:_files' \
  '--secretlintignore=[ignore file]:ignore file:_files' \
  '--format=[output format]:format:(stylish json unix table mask-result)' \
  '--output=[output file]:output file:_files' \
  '--no-color[disable color output]' \
  '--color[enable color output]' \
  '--debug[enable debug mode]' \
  '--locale=[locale for messages]:locale' \
  '--maskSecrets[mask detected secrets in output]' \
  '--no-maskSecrets[do not mask detected secrets]' \
  '*:file or directory:_files' && ret=0

return ret
