#compdef lastpass-cli2 lpass2
# _lastpass-cli2 — LogMeIn LastPass lastpass-cli2 CLI command-line frontend wrapping the LastPass community-driven LastPass open-source command line interface for the LastPass password manager written in C provides access to LastPass functionality through C library and CLI Linux macOS BSD Windows-WSL lpass login logout passwd ls show add edit generate duplicate rm mv share export import status logout sync sync edit-by-id sync-blocking interactive non-interactive search show-all custom field copy hide click clipboard color (LastPass community team Bob Beck Adam Glasgall Andrew Connolly, C); custom argparse
# upstream: https://github.com/lastpass/lastpass-cli

_lastpass-cli2() {
    local -a sub=(
        'login:authenticate'
        'logout:log out'
        'passwd:change vault password'
        'ls:list accounts'
        'show:show account details'
        'add:add a new account'
        'edit:edit an account'
        'generate:generate a password'
        'duplicate:duplicate an account'
        'rm:remove an account'
        'mv:move an account'
        'share:share operations'
        'sync:sync vault'
        'export:export vault'
        'import:import vault'
        'status:show status'
        'completion:completion helpers'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--user=+[user]:_users' \
        '--trust[trust this device]' \
        '--plaintext-key[plaintext key]' \
        '--force[force]' \
        '--non-interactive[no prompts]' \
        '--color=+[c]:c:(auto always never)' \
        '--password=+[password]:str:' \
        '--username=+[user]:_users' \
        '--url=+[url]:str:' \
        '--note=+[text]:str:' \
        '--notes=+[text]:str:' \
        '--field=+[name]:str:' \
        '--name=+[name]:str:' \
        '--app-name=+[name]:str:' \
        '-x[non-interactive editor]' \
        '--xml[XML output]' \
        '--id=+[id]:str:' \
        '--last=+[last name]:str:' \
        '--first=+[first name]:str:' \
        '--clip[copy to clipboard]' \
        '--all[show all info]' \
        '-c[copy to clipboard]' \
        '-l+[length]:n:' \
        '--length=+[N]:n:' \
        '--no-symbols[no symbols]' \
        '--sync=+[mode]:m:(auto now no)' \
        '--background[background sync]' \
        '--fields=+[fields]:str:' \
        '--format=+[fmt]:f:(csv)' \
        '--sharekey=+[key]:str:' \
        '--read-only=+[v]:v:(yes no)' \
        '--hide-passwords=+[v]:v:(yes no)' \
        '--admin=+[v]:v:(yes no)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lpass subcommand' sub ;;
        args)
            case $words[1] in
                show|edit|rm|duplicate|mv) _arguments '*:account:' ;;
                share) _arguments '1:op:(list ls add rm mv create userls useradd userdel limit)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_lastpass-cli2 "$@"
