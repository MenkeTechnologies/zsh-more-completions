#compdef wcsslide
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss210.html
# KAPPA: applies a translational shift to the WCS of an NDF

local ret=1

_arguments -s \
  'NDF=[NDF to be translated]:ndf:_files -g "*.sdf"' \
  'STYPE=[type of shift]:type:(Absolute Relative)' \
  'ABS=[absolute shift per WCS axis]:shift' \
  'FID=[fiducial point position]:point' \
  'OBJ=[standard object position]:point' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
