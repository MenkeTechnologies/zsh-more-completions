#compdef esplinemap
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/esplinemap/node4.html
# XMM-Newton SAS: derive spline background maps from non-source regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--boxlistset=[name of eboxdetect source list]:file:_files' \
  '--imageset=[names of input EPIC fits images]:file:_files' \
  '--bkgimageset=[name of output spline background map]:file:_files' \
  '--fitmethod=[fitting approach]:method:(spline model smooth)' \
  '--expimageset=[name of input exposure map]:file:_files' \
  '--expimageset2=[second exposure map for fitmethod=model]:file:_files' \
  '--detmaskset=[name of input detection mask]:file:_files' \
  '--scut=[source cut-out flux level (counts/arcsec^2)]:flux:' \
  '--idband=[band identifier from source list]:band:' \
  '--mlmin=[minimum detection likelihood for exclusion]:like:' \
  '--nsplinenodes=[number of spline nodes]:nodes:' \
  '--excesssigma=[threshold for excess sigmas wrt spline fit]:sigma:' \
  '--nfitrun=[number of iterations for excess removal]:n:' \
  '--withdetmask=[enable detection mask usage]:flag:(yes no)' \
  '--withexpimage=[enable exposure map usage]:flag:(yes no)' \
  '--withexpimage2=[second exposure map for model fitting]:flag:(yes no)' \
  '--snrmin=[minimum signal-to-noise for adaptive smoothing]:snr:' \
  '--smoothsigma=[minimum width of Gaussian smoothing kernel]:sigma:' \
  '--withcheese=[output source-masked photon image]:flag:(yes no)' \
  '--cheeseimageset=[name of cheesed image]:file:_files' \
  '--withcheesemask=[output mask image]:flag:(yes no)' \
  '--cheesemaskset=[name of cheese mask image]:file:_files' \
  '--withootset=[calculate background from OOT events]:flag:(yes no)' \
  '--ooteventset=[photon event table for background]:file:_files' \
  '--pimin=[lower PI channel limit]:ev:' \
  '--pimax=[upper PI channel limit]:ev:' \
  '*:file:_files' && ret=0

return ret
