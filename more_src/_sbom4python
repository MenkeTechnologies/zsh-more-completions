#compdef sbom4python
# Documentation: https://pypi.org/project/sbom4python/
# generate an SBOM for a Python module and its dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --module)'{-m,--module}'=[Python module to scan]:module:' \
  '(-r --requirement)'{-r,--requirement}'=[requirements file]:file:_files' \
  '--system[scan installed system packages]' \
  '--exclude-license[exclude license data]' \
  '--include-file[include file data]' \
  '--include-service[include service data]' \
  '--use-pip[use pip to resolve dependencies]' \
  '--python=[path to python interpreter]:file:_files' \
  '-d[show debug information]' \
  '--sbom=[SBOM type]:type:(spdx cyclonedx)' \
  '--format=[output format]:format:(tag json yaml)' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-g --graph)'{-g,--graph}'=[graph output file]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
