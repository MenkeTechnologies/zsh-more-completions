#compdef hk
# Documentation: https://hk.jdx.dev/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# jdx/hk: git hook manager and project linting tool

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run hooks for a git event'
  'check:run check linters'
  'fix:run fix linters'
  'install:install git hooks in the repo'
  'uninstall:remove installed git hooks'
  'init:initialize a new hk configuration'
  'config:manage hk configuration'
  'migrate:migrate from another hook manager'
  'validate:validate hk configuration'
  'builtins:list built-in linters and utilities'
  'util:utility helpers'
  'cache:manage hk cache'
  'completion:generate shell completion script'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase log verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-s --slow)'{-s,--slow}'[run slow linters]' \
  '--jobs=[parallel job count]:n:' \
  '--profile=[hk profile]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hk command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
