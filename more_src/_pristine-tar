#compdef pristine-tar
# Regenerate pristine upstream tarballs from VCS and delta

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'checkout:reconstruct a pristine tarball'
      'commit:store a pristine tarball delta in VCS'
      'list:list tarballs stored in VCS'
      'verify:verify a tarball against stored delta'
    )
    _describe -t commands 'pristine-tar command' commands && ret=0
    ;;
  args)
    _arguments '*:file:_files' && ret=0
    ;;
esac

return ret
