#compdef wxmaxima

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --open)'{-o,--open}'+[open file]:file:_files -g "*.{wxm,wxmx,mac}"' \
  '(-f --batch)'{-f,--batch}'+[batch evaluate file]:file:_files -g "*.{wxm,wxmx,mac}"' \
  '(-e --eval)'{-e,--eval}'+[evaluate expression]:expr:' \
  '(-l --logtostderr)'{-l,--logtostderr}'[log to stderr]' \
  '(-x --no-startup-file)'{-x,--no-startup-file}'[skip startup file]' \
  '(-X --extra-args)'{-X,--extra-args}'+[extra maxima args]:args:' \
  '(-p --pipe)'{-p,--pipe}'[read input from stdin]' \
  '(-m --maxima)'{-m,--maxima}'+[path to maxima binary]:file:_files' \
  '--logtostdout[log to stdout]' \
  '*:file:_files' && ret=0

return ret
