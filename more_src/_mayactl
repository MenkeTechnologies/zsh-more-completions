#compdef mayactl
# Documentation: https://openebs.io/docs/3.2.x/deprecated/mayactl
# OpenEBS command line tool for volumes and pools

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--volname=[volume name]:volume' \
  '--poolname=[storage pool name]:pool' \
  '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace' \
  '1:command:(volume pool snapshot version help)' \
  '*::arg:_default' && ret=0

return ret
