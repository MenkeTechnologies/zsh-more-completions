#compdef memory-qos
# _memory-qos — containers/nri-plugins NRI plugin that programs memory.high / memory.min per-container based on QoS annotations
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/plugins/memory-qos/main.go on tip.

_memory-qos() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--name=[plugin name to register to NRI]:name:' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--config=[configuration file]:file:_files' \
        '-v[verbose output]' \
        '-vv[very verbose output]'
}

_memory-qos "$@"
