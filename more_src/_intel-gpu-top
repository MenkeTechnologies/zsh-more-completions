#compdef intel_gpu_top intel-gpu-top
# Documentation: https://man.archlinux.org/search?q=intel_gpu_top
# Reference accessed: 2026-05-16

# Zsh completion for intel_gpu_top (Intel GPU utilization monitor)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s+[Refresh period in milliseconds]:period' \
  '-l[List all available GPUs]' \
  '-L[Print engine info and exit]' \
  '-o+[Output to file]:file:_files' \
  '-p+[Specify PID to monitor]:pid:_pids' \
  '-J[Output in JSON format]' \
  '-d+[Specify device to use]:device:_files -W /dev/dri' \
  '-h[Print help]' && ret=0

return ret
