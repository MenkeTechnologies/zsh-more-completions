#compdef zxbasic

# ZX BASIC: Boriel's compiler for Sinclair ZX Spectrum BASIC (Python)
# Documentation: https://zxbasic.readthedocs.io/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-d[debug level]:n:' \
  '--debug=[debug level]:n:' \
  '-O[optimization level]:n:(0 1 2 3)' \
  '--optimize=[optimization level]:n:(0 1 2 3)' \
  '-o[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-S[stop at assembly]' \
  '--asm[stop at assembly]' \
  '-A[stop at assembly]' \
  '-T[output to TZX]' \
  '--tzx[output to TZX]' \
  '-t[output to TAP]' \
  '--tap[output to TAP]' \
  '-B[BASIC output]' \
  '--basic[BASIC output]' \
  '-a[no autostart]' \
  '--autorun[autorun BASIC]' \
  '-N[no header]' \
  '--no-header[no header]' \
  '-Z[debug Z80]' \
  '--zxnext[ZX Next mode]' \
  '-M[Memory map]:file:_files' \
  '--mmap=[Memory map]:file:_files' \
  '-X[explicit type]' \
  '-I[include path]:dir:_files -/' \
  '--include-path=[include path]:dir:_files -/' \
  '-D[define symbol]:symbol=value:' \
  '--define=[define symbol]:symbol=value:' \
  '-H[hide ones]' \
  '--heap-size=[heap size]:bytes:' \
  '--stack-size=[stack size]:bytes:' \
  '*:source file:_files -g "*.(bas|zxb)"' && ret=0
return ret
