#compdef CheckIlluminaDirectory
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CheckIlluminaDirectory
# Picard: verify the completeness of an Illumina basecalls output directory

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-B=,--BASECALLS_DIR=}'[the basecalls output directory]:dir:_files -/' \
  '*'{-L=,--LANES=}'[lane number(s) to check]:int:' \
  {-RS=,--READ_STRUCTURE=}'[cluster logical structure (e.g. 25T8B25T)]:structure:' \
  '*'{-DT=,--DATA_TYPES=}'[data types to check for each tile/cycle]:type:(Position BaseCalls QualityScores PF Barcodes)' \
  {-F=,--FAKE_FILES=}'[create fake versions of the missing files]:bool:(true false)' \
  {-X=,--LINK_LOCS=}'[create symlinks to the loc file for X Ten tiles]:bool:(true false)' \
  '*'{-T=,--TILE_NUMBERS=}'[tile number(s) to check]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:directory:_files -/' && ret=0

return ret
