#compdef ngmlr
# Documentation: https://github.com/philres/ngmlr
# Long-read mapper designed to align PacBio or Oxford Nanopore reads to a reference genome

local ret=1

_arguments -s -S \
  '(-r --reference)'{-r,--reference}'[path to the reference genome (FASTA/Q, can be gzipped)]:reference:_files' \
  '(-q --query)'{-q,--query}'[path to the read file (FASTA/Q)]:query:_files' \
  '(-o --output)'{-o,--output}'[path to output file]:output:_files' \
  '--skip-write[do not write reference index to disk]' \
  '--bam-fix[report reads with more than 64k CIGAR operations as unmapped]' \
  '--rg-id[adds RG:Z:<string> to all alignments in SAM/BAM]:string:' \
  '--rg-sm[RG header sample]:string:' \
  '--rg-lb[RG header library]:string:' \
  '--rg-pl[RG header platform]:string:' \
  '--rg-ds[RG header description]:string:' \
  '--rg-dt[RG header date]:string:' \
  '--rg-pu[RG header platform unit]:string:' \
  '--rg-pi[RG header predicted insert size]:string:' \
  '--rg-pg[RG header programs]:string:' \
  '--rg-cn[RG header sequencing center]:string:' \
  '--rg-fo[RG header flow order]:string:' \
  '--rg-ks[RG header key sequence]:string:' \
  '(-t --threads)'{-t,--threads}'[number of threads]:int:' \
  '(-x --presets)'{-x,--presets}'[parameter presets for different sequencing technologies]:preset:(pacbio ont)' \
  '(-i --min-identity)'{-i,--min-identity}'[alignments with identity lower than threshold discarded]:0-1:' \
  '(-R --min-residues)'{-R,--min-residues}'[alignments with fewer residues discarded]:int/float:' \
  '--no-smallinv[do not detect small inversions]' \
  '--no-lowqualitysplit[split alignments with poor quality]' \
  '--verbose[debug output]' \
  '--no-progress[do not print progress info while mapping]' \
  '--match[match scoring parameter]:value:' \
  '--mismatch[mismatch scoring parameter]:value:' \
  '--gap-open[gap open scoring parameter]:value:' \
  '--gap-extend-max[max gap extend scoring parameter]:value:' \
  '--gap-extend-min[min gap extend scoring parameter]:value:' \
  '--gap-decay[gap decay scoring parameter]:value:' \
  '(-k --kmer-length)'{-k,--kmer-length}'[k-mer length in bases]:10-15:' \
  '--kmer-skip[number of k-mers to skip when building the lookup table]:int:' \
  '--bin-size[sets the size of the grid used during alignment]:int:' \
  '--max-segments[max number of segments allowed for a read per kb]:int:' \
  '--subread-length[length of fragments reads are split into]:int:' \
  '--subread-corridor[length of corridor sub-reads are aligned with]:int:' \
  '*:file:_files' && ret=0

return ret
