#compdef harbor
# Documentation: https://man.archlinux.org/search?q=harbor
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:log in to a Harbor registry'
  'logout:log out of a Harbor registry'
  'project:manage projects'
  'repo:manage repositories'
  'artifact:manage artifacts'
  'label:manage labels'
  'tag:manage tags'
  'quota:manage quotas'
  'webhook:manage webhook policies'
  'robot:manage robot accounts'
  'user:manage users'
  'registry:manage external registries'
  'replication:manage replication policies'
  'config:manage Harbor CLI configuration'
  'cve-allowlist:manage system CVE allowlist'
  'health:show Harbor components health'
  'preheat:manage preheat provider instances'
  'info:show Harbor system info'
  'scanner:manage scanners'
  'schedule:schedule jobs in Harbor'
  'context:switch between Harbor contexts'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[path to config file]:file:_files -g "*.yaml"' \
  '--output-format=[output format]:format:(json yaml table wide)' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'harbor command' commands && ret=0 ;;
  (args)
    local -a crud_subs=(
      'list:list resources'
      'create:create a resource'
      'delete:delete a resource'
      'get:get/view a resource'
      'update:update a resource'
    )
    case $line[1] in
      (project|repo|artifact|label|tag|quota|webhook|robot|user|registry|replication|cve-allowlist|preheat|scanner|schedule)
        _describe -t crudcmds 'subcommand' crud_subs && ret=0 ;;
      (config)
        local -a config_subs=(
          'set:set a configuration value'
          'get:get a configuration value'
          'list:list all configuration values'
          'delete:delete a configuration value'
        )
        _describe -t cfgcmds 'config subcommand' config_subs && ret=0 ;;
      (login)
        _arguments \
          '--name=[context name]:name:' \
          '-u+[username]:username:' \
          '-p+[password]:password:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
