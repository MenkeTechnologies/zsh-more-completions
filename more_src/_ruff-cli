#compdef ruff

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:run linter on files'
  'rule:explain a rule (or list rules)'
  'config:list all configuration options'
  'linter:list all linters'
  'clean:clear caches'
  'format:run formatter'
  'server:run language server'
  'analyze:analyze import graphs'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --silent)'{-s,--silent}'[silent]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-n --no-cache)'{-n,--no-cache}'[no cache]' \
  '*--isolated[ignore config]' \
  '*--config=[config option override]:cfg:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ruff command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '(--fix)--fix[apply autofixes]' \
          '(--unsafe-fixes)--unsafe-fixes[apply unsafe fixes]' \
          '(--no-fix)--no-fix[no autofix]' \
          '(--show-fixes)--show-fixes[show applied fixes]' \
          '(--diff)--diff[show diff]' \
          '(--watch -w)*'{-w,--watch}'[watch mode]' \
          '(--add-noqa)--add-noqa[add noqa]' \
          '(-e --exit-zero)'{-e,--exit-zero}'[exit 0 even on errors]' \
          '(--exit-non-zero-on-fix)--exit-non-zero-on-fix[exit non-zero on fix]' \
          '(--fix-only)--fix-only[only apply fixes]' \
          '(--ignore-noqa)--ignore-noqa[ignore noqa]' \
          '(--output-format)--output-format=[format]:fmt:(text concise full json json-lines junit grouped github gitlab pylint rdjson azure sarif)' \
          '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files' \
          '(--target-version)--target-version=[Python version]:v:(py37 py38 py39 py310 py311 py312 py313 py314)' \
          '(--preview)--preview[preview mode]' \
          '(--no-preview)--no-preview[no preview]' \
          '(--extension)*--extension=[extension]:ext:' \
          '(--select)*--select=[select codes csv]:list:' \
          '(--extend-select)*--extend-select=[extend select csv]:list:' \
          '(--ignore)*--ignore=[ignore csv]:list:' \
          '(--extend-ignore)*--extend-ignore=[extend ignore csv]:list:' \
          '(--per-file-ignores)*--per-file-ignores=[per file ignores]:s:' \
          '(--fixable)*--fixable=[fixable codes csv]:list:' \
          '(--unfixable)*--unfixable=[unfixable csv]:list:' \
          '(--exclude)*--exclude=[exclude paths csv]:list:' \
          '(--extend-exclude)*--extend-exclude=[extend exclude csv]:list:' \
          '(--respect-gitignore)--respect-gitignore[respect gitignore]' \
          '(--no-respect-gitignore)--no-respect-gitignore[no respect gitignore]' \
          '(--force-exclude)--force-exclude[force exclude]' \
          '(--no-force-exclude)--no-force-exclude[no force exclude]' \
          '(--statistics)--statistics[print statistics]' \
          '(--show-files)--show-files[show files only]' \
          '(--show-settings)--show-settings[show settings]' \
          '(--stdin-filename)--stdin-filename=[stdin filename]:file:_files' \
          '(--cache-dir)--cache-dir=[cache dir]:dir:_files -/' \
          '*: :_files -g "*.py *.pyi *.ipynb"' && ret=0 ;;
      (format)
        _arguments \
          '(--check)--check[check formatting]' \
          '(--diff)--diff[show diff]' \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          '(--target-version)--target-version=[Python version]:v:' \
          '(--preview)--preview[preview]' \
          '(--no-preview)--no-preview[no preview]' \
          '(--exclude)*--exclude=[exclude paths csv]:list:' \
          '(--respect-gitignore)--respect-gitignore[respect gitignore]' \
          '(--stdin-filename)--stdin-filename=[stdin filename]:file:_files' \
          '*: :_files -g "*.py *.pyi *.ipynb"' && ret=0 ;;
      (rule)
        _arguments \
          '(--all)--all[show all rules]' \
          '(--output-format)--output-format=[format]:fmt:(text json)' \
          '*:rule:' && ret=0 ;;
      (config)
        _arguments '*: :' && ret=0 ;;
      (clean)
        _arguments '*: :' && ret=0 ;;
      (server)
        _arguments '--preview[preview]' '*: :' && ret=0 ;;
      (analyze)
        _arguments '1:subcommand:(graph)' '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
