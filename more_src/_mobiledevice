#compdef mobiledevice
# Documentation: https://github.com/imkira/mobiledevice
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mobiledevice - iOS device management CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:display the help screen'
  'version:show program version'
  'list_devices:list UDIDs of connected devices'
  'list_device_props:list all property names for a device'
  'get_device_prop:display a specific device property value'
  'list_apps:list installed applications'
  'list_app_props:list properties for an app'
  'get_app_prop:display an application property value'
  'install_app:install an .app folder to the device'
  'uninstall_app:remove an app by bundle ID'
  'tunnel:forward TCP connections between Mac and device'
  'get_bundle_id:extract bundle id from an .app folder'
)

_arguments -C \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'mobiledevice command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (version)
        _arguments '-r[include revision identifier]' && ret=0
        ;;
      (list_devices)
        _arguments \
          '-t+[timeout in ms]:timeout:' \
          '-n+[limit number of results]:count:' && ret=0
        ;;
      (list_device_props|get_device_prop|list_apps|list_app_props|get_app_prop|install_app|uninstall_app|tunnel)
        _arguments \
          '-u+[filter by device UDID]:udid:' \
          '-t+[timeout in ms]:timeout:' \
          '*:: :_files' && ret=0
        ;;
      (get_bundle_id)
        _arguments '*:app folder:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
