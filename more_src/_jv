#compdef jv
# jv - JSON Schema validator CLI (Go)
#
# Upstream: https://github.com/santhosh-tekuri/jsonschema  (1232+ stars, Apache-2.0)
# Author:   Santhosh Kumar Tekuri (@santhosh-tekuri)
# Library:  github.com/santhosh-tekuri/jsonschema/v6 (canonical Go JSON Schema validator)
# Flags:    spf13/pflag (POSIX-style long/short flag parser)
#
# Source-direct extraction from cmd/jv/main.go `flag.BoolP / StringP / IntP`
# definitions: https://github.com/santhosh-tekuri/jsonschema/blob/master/cmd/jv/main.go
#
# Drafts: 4 | 6 | 7 | 2019 | 2020   (default 2020 when $schema is missing)
# Output: simple | alt | flag | basic | detailed   (default simple)

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_jv_drafts() {
    local -a d
    d=(
        '4:JSON Schema Draft 4'
        '6:JSON Schema Draft 6'
        '7:JSON Schema Draft 7'
        '2019:JSON Schema 2019-09'
        '2020:JSON Schema 2020-12 (default)'
    )
    _describe -t drafts 'draft version' d
}

_jv_outputs() {
    local -a o
    o=(
        'simple:human-readable simple (default)'
        'alt:alternative simple report'
        'flag:single boolean output (RFC: 2020-12 flag output)'
        'basic:flat list of validation errors (RFC: 2020-12 basic output)'
        'detailed:hierarchical / detailed report (RFC: 2020-12 detailed output)'
    )
    _describe -t outputs 'output format' o
}

_arguments -C \
    '(- *)'{-h,--help}'[print help information and exit]' \
    '(- *)'{-v,--version}'[print build / module version info and exit]' \
    '(-q --quiet)'{-q,--quiet}'[do not print validation errors]' \
    '(-d --draft)'{-d,--draft}'+[draft version used when $schema is missing (4|6|7|2019|2020)]:draft:_jv_drafts' \
    '(-o --output)'{-o,--output}'+[output format]:format:_jv_outputs' \
    '(-f --assert-format)'{-f,--assert-format}'[enable format assertions (only with draft >= 2019)]' \
    '(-c --assert-content)'{-c,--assert-content}'[enable content assertions (only with draft >= 7)]' \
    '(-k --insecure)'{-k,--insecure}'[use insecure TLS connection]' \
    '--cacert=[PEM file with one or more CA certificates for peer verification]:pem file:_files -g "*.(pem|crt|cer|ca-bundle)"' \
    '*'{-m,--map}'+[mount URL prefix to local dir (syntax: url_prefix=/path/to/dir; repeatable)]:URL=/path:' \
    '1:SCHEMA:_files -g "*.(json|yaml|yml)"' \
    '*:INSTANCE:_files -g "*.(json|yaml|yml)"' \
    && ret=0

return ret
