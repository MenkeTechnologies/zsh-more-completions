#compdef cffsubr
# Documentation: https://github.com/adobe-type-tools/cffsubr
# Standalone CFF subroutinizer based on the AFDKO tx tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-o --output-file -i --inplace)'{-o,--output-file}'=[path to output file (default: stdout)]:file:_files' \
  '(-o --output-file -i --inplace)'{-i,--inplace}'[overwrite the input file]' \
  '(-f --cff-version)'{-f,--cff-version}'=[output CFF table format version]:version:(1 2)' \
  '(-N --no-glyph-names)'{-N,--no-glyph-names}'[drop postscript glyph names when converting CFF to CFF2]' \
  '(-d --desubroutinize)'{-d,--desubroutinize}'[remove all subroutines instead of subroutinizing]' \
  '1:input font:_files -g "*.(otf|ttf|OTF|TTF)"' && ret=0

return ret
