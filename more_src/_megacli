#compdef megacli MegaCli MegaCli64

# LSI MegaCLI: command-line tool for LSI MegaRAID controllers
local curcontext="$curcontext" ret=1
_arguments -C \
  '-AdpAllInfo[print full controller info]:adp:' \
  '-AdpCount[print number of controllers]' \
  '-AdpGetTime[get adapter time]:adp:' \
  '-AdpSetTime[set adapter time]:adp:' \
  '-AdpEventLog[print event log]:adp:' \
  '-LDInfo[logical drive info]:LD:' \
  '-PDList[physical drive list]:adp:' \
  '-PDInfo[physical drive info]:slot:' \
  '-CfgAllFreeSpace[show all free space]:adp:' \
  '-CfgLdAdd[add new logical drive]:cfg:' \
  '-CfgLdDel[delete logical drive]:LD:' \
  '-LDPDInfo[LD/PD mapping info]:adp:' \
  '-BbuMfgData[battery backup manufacturing data]:adp:' \
  '-FwTermLog[firmware termination log]:adp:' \
  '-AdpFwFlash[flash firmware]:adp file:_files' \
  '-h[show help]' \
  '-NoLog[no log file output]' \
  '*::MegaCLI args:_files' && ret=0
return ret
