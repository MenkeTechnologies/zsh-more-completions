#compdef megacli MegaCli MegaCli64
# Documentation: https://man.archlinux.org/search?q=megacli
# Reference accessed: 2026-05-16

# MegaCli: LSI MegaRAID CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-v[show version]' \
  '-AdpAllInfo[show adapter info]' \
  '-AdpCount[count adapters]' \
  '-AdpGetTime[get adapter time]' \
  '-AdpSetTime[set adapter time]' \
  '-AdpPR[adapter patrol-read settings]' \
  '-AdpBbuCmd[BBU commands]' \
  '-AdpEventLog[event log]' \
  '-PDList[physical drive list]' \
  '-PDInfo[PD detail info]' \
  '-PDOnline[bring PD online]' \
  '-PDOffline[take PD offline]' \
  '-PDMakeGood[mark unconfigured-good]' \
  '-PDHSP[hot spare set/remove]' \
  '-PDLocate[locate PD]' \
  '-PDClear[clear PD]' \
  '-LDInfo[logical drive info]' \
  '-LDGetProp[LD properties]' \
  '-LDSetProp[set LD properties]' \
  '-CfgLdAdd[add new LD]' \
  '-CfgLdDel[delete LD]' \
  '-CfgEachDskRaid0[create RAID0 per disk]' \
  '-CfgClr[clear configuration]' \
  '-CfgForeign[foreign config ops]' \
  '-PhyInfo[show PHY info]' \
  '-Pdgetmissing[show missing PDs]' \
  '-Pdgetcommissingdisks[get missing disks]' \
  '-Pdgetcommreplacing[get replacing disks]' \
  '-EncInfo[enclosure info]' \
  '-FwTermLog[firmware termlog]' \
  '-aALL[apply to all adapters]' \
  '-a[adapter number]:n:' \
  '*::MegaCli args:_files' && ret=0
return ret
