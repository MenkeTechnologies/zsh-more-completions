#compdef gbp

# Zsh completion for gbp (git-buildpackage - Debian packaging tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'buildpackage:build a Debian package from a git repository'
  'clone:clone a Debian package git repository'
  'config:query configuration values'
  'create-remote-repo:create a remote repository'
  'dch:generate Debian changelog entries from git commits'
  'export-orig:export orig tarball from git'
  'import-dsc:import a Debian source package into git'
  'import-orig:import a new upstream tarball into git'
  'import-ref:import from a git reference'
  'pq:manage quilt patches on a patch queue branch'
  'pristine-tar:manage pristine-tar data'
  'pull:pull updates from remote repository'
  'push:push changes to remote repository'
  'rpm-ch:generate RPM changelog entries'
  'tag:create a packaging tag'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--color[use colored output]:when:(on auto off)' \
  '--color-scheme[color scheme]:scheme' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gbp command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (buildpackage)
        _arguments -s -S \
          '--git-ignore-new[build with uncommitted changes]' \
          '--git-tag[create a tag after successful build]' \
          '--git-sign-tags[sign tags with GPG]' \
          '--git-builder[specify build command]:command' \
          '--git-cleaner[specify clean command]:command' \
          '--git-upstream-branch[upstream branch]:branch' \
          '--git-debian-branch[Debian branch]:branch' \
          '--git-export-dir[export directory]:directory:_files -/' \
          '--git-tarball-dir[tarball directory]:directory:_files -/' \
          '--git-no-pristine-tar[do not use pristine-tar]' \
          '--git-pristine-tar[use pristine-tar]' \
          '--git-pristine-tar-commit[commit tarball to pristine-tar]' \
          '--git-force-create[force creation of orig tarball]' \
          '--git-verbose[be verbose]' && ret=0
        ;;
      (clone)
        _arguments -s -S \
          '--all[track all branches]' \
          '--debian-branch[Debian branch to track]:branch' \
          '--upstream-branch[upstream branch to track]:branch' \
          '--pristine-tar[track pristine-tar branch]' \
          '--depth[shallow clone depth]:depth' \
          '1:repository URL' \
          '2:directory:_files -/' && ret=0
        ;;
      (dch)
        _arguments -s -S \
          '--auto[guess next version]' \
          '--new-version[specify new version]:version' \
          '--release[mark changelog as released]' \
          '--snapshot[create snapshot entry]' \
          '--since[changelog since commit]:commit' \
          '--distribution[set distribution]:distribution' \
          '--urgency[set urgency]:urgency:(low medium high emergency critical)' \
          '--full[include full commit messages]' && ret=0
        ;;
      (import-orig)
        _arguments -s -S \
          '--upstream-version[upstream version]:version' \
          '--upstream-branch[upstream branch]:branch' \
          '--debian-branch[Debian branch]:branch' \
          '--merge[merge to Debian branch]' \
          '--no-merge[do not merge]' \
          '--pristine-tar[use pristine-tar]' \
          '--filter[filter files]:pattern' \
          '--sign-tags[sign tags]' \
          '1:tarball or directory:_files' && ret=0
        ;;
      (import-dsc)
        _arguments -s -S \
          '--pristine-tar[use pristine-tar]' \
          '--sign-tags[sign tags]' \
          '1:dsc file:_files -g "*.dsc(N)"' && ret=0
        ;;
      (pq)
        local -a pq_cmds=(
          'import:import patches to patch queue branch'
          'export:export patches from patch queue branch'
          'rebase:rebase patch queue branch'
          'drop:drop patch queue branch'
          'apply:apply a patch'
          'switch:switch between patch queue and packaging branch'
        )
        _arguments '1:pq subcommand:->pq_sub' && ret=0
        case $state in
          (pq_sub) _describe -t commands 'pq subcommand' pq_cmds && ret=0 ;;
        esac
        ;;
      (tag)
        _arguments -s -S \
          '--sign-tags[sign tags]' \
          '--debian-branch[Debian branch]:branch' \
          '--debian-tag[tag format]:format' \
          '--retag[re-tag if tag exists]' && ret=0
        ;;
      (pull|push)
        _arguments -s -S \
          '--debian-branch[Debian branch]:branch' \
          '--upstream-branch[upstream branch]:branch' \
          '--pristine-tar[include pristine-tar branch]' \
          '1:remote:_git_remotes' && ret=0
        ;;
      (config)
        _arguments -s -S \
          '1:config key' && ret=0
        ;;
    esac
    ;;
esac

return ret
