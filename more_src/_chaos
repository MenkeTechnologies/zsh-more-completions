#compdef chaos

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[target domain]:domain:' \
  '-key[Chaos API key]:key:' \
  '-o[output file]:file:_files' \
  '-count[show subdomain count only]' \
  '-json[output in JSON format]' \
  '-silent[silent mode]' \
  '-v[verbose output]' \
  '-up[upload subdomains]' \
  '-f[file with subdomains to upload]:file:_files' \
  '-update[update chaos to latest version]' \
  '-disable-update-check[disable automatic update check]' \
  && ret=0

return ret
