#compdef chaos
# Documentation: https://github.com/projectdiscovery/chaos-client
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# projectdiscovery/chaos-client - ProjectDiscovery Chaos subdomain dataset CLI (binary: chaos)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-version[show version]' \
  '-d[target domain]:domain:' \
  '-dL[file containing domains]:file:_files' \
  '-key[ProjectDiscovery PDCP API key]:key:' \
  '-o[output file]:file:_files' \
  '-count[show subdomain count only]' \
  '-json[output in JSON format]' \
  '-silent[silent mode]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-up[upload subdomains]' \
  '-f[file with subdomains to upload]:file:_files' \
  '-update[update chaos to latest version]' \
  '(-duc -disable-update-check)'{-duc,-disable-update-check}'[disable automatic update check]' \
  && ret=0

return ret
