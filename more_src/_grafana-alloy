#compdef alloy grafana-alloy

# Zsh completion for Grafana Alloy - OpenTelemetry collector distribution

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run Alloy'
      'fmt:format Alloy configuration files'
      'tools:developer tools'
      'convert:convert configuration from other formats'
      'completion:generate shell completion'
    )
    _describe -t commands 'alloy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config.file=[configuration file]:file:_files' \
          '--server.http.listen-addr=[HTTP listen address]:address' \
          '--cluster.enabled[enable cluster mode]' \
          '--storage.path=[storage directory]:directory:_directories' \
          '--stability.level=[minimum stability level]:level:(experimental public-preview generally-available)' \
          '*:config file:_files' \
          && ret=0
        ;;
      fmt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--write[write formatted output back to files]' \
          '*:config file:_files' \
          && ret=0
        ;;
      tools)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:tool command' \
          && ret=0
        ;;
      convert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-format=[source format]:format:(prometheus promtail static otelcol)' \
          '--output=[output file]:file:_files' \
          '--bypass-errors[bypass conversion errors]' \
          '--extra-args=[additional arguments]:args' \
          '--report=[report file]:file:_files' \
          '*:input file:_files' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
