# kolourpaint: KDE simple paint application
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--mimetypes[list all readable image MIME types]' \
  '--new[start with new image of WxH size]:size:' \
  '*:image file:_files' && ret=0
return ret
