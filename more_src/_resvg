#compdef resvg

# Zsh completion for resvg (SVG rendering tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-w --width)'{-w,--width}'[set output image width]:width in pixels' \
  '(-h --height)'{-h,--height}'[set output image height]:height in pixels' \
  '(-z --zoom)'{-z,--zoom}'[set zoom factor]:zoom factor' \
  '--dpi[set DPI for output]:DPI:(72 96 150 200 300)' \
  '--background[set background color]:color' \
  '--languages[set preferred languages]:language list' \
  '--shape-rendering[set shape rendering mode]:mode:(optimizeSpeed crispEdges geometricPrecision)' \
  '--text-rendering[set text rendering mode]:mode:(optimizeSpeed optimizeLegibility geometricPrecision)' \
  '--image-rendering[set image rendering mode]:mode:(optimizeQuality optimizeSpeed)' \
  '--resources-dir[path for relative image paths]:directory:_files -/' \
  '--font-family[set default font family]:font family' \
  '--font-size[set default font size]:size' \
  '--serif-family[set serif font family]:font family' \
  '--sans-serif-family[set sans-serif font family]:font family' \
  '--cursive-family[set cursive font family]:font family' \
  '--fantasy-family[set fantasy font family]:font family' \
  '--monospace-family[set monospace font family]:font family' \
  '*--use-font-file[load a specific font file]:font file:_files' \
  '*--use-fonts-dir[load fonts from a directory]:directory:_files -/' \
  '--skip-system-fonts[do not load system fonts]' \
  '--list-fonts[list all available fonts]' \
  '--query-all[print bounding boxes of all elements with IDs]' \
  '--export-id[render only element with specified ID]:element ID' \
  '--export-area-page[use page area for export-id]' \
  '--perf[print rendering time]' \
  '--quiet[suppress warnings]' \
  '--dump-svg[print preprocessed SVG to stdout]' \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:input SVG file:_files -g "*.svg(|.gz)(|z)(N)"' \
  '2:output file:_files -g "*.(png|pdf|svg)(N)"' && ret=0

return ret
