#compdef orbcat
# _orbcat — orbuculum project orbcat CLI text consumer client connecting to orbuculum daemon stream channels filtering by ITM stimulus port printing decoded printf style trace messages with timestamp formatting for live ARM Cortex-M firmware debug (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbcat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-c+[channel,format]:str:' \
        '-C[print cycle count]' \
        '-g+[trigger]:str:' \
        '-n[no buffering]' \
        '-t+[hostname:port]:host:port:' \
        '-s+[server]:host:' \
        '-T[TPIU framing]' \
        '-w+[output file]:file:_files' \
        '-e[exclude empty]' \
        '-x+[exclude channel mask]:n:' \
        '*:format spec:'
}

_orbcat "$@"
