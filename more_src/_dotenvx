#compdef dotenvx

local -a subcommands
subcommands=(
  'run:Inject env vars and run a command'
  'get:Get an env var value'
  'set:Set an env var value'
  'encrypt:Encrypt .env files'
  'decrypt:Decrypt .env files'
  'genexample:Generate .env.example'
  'gitignore:Add .env to .gitignore'
  'keypair:Print public/private keys'
  'ls:List .env files'
  'precommit:Precommit hook to prevent .env leaks'
  'pro:Dotenvx Pro features'
  'ext:Extensions'
  'help:Show help'
)

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-l --log-level)'{-l,--log-level}'[Log level]:level:(error warn info verbose debug silly)' \
  '(-q --quiet)'{-q,--quiet}'[Suppress output]' \
  '1:command:_describe -t commands command subcommands' \
  '*::arg:->args' && return 0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '--overload[Override existing env vars]' \
          '--convention=[Load convention]:convention:(nextjs)' \
          '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
          '(-d --debug)'{-d,--debug}'[Debug output]' \
          '--:[Command separator]:' \
          '*:command:_command_names'
        ;;
      get)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '--overload[Override existing env vars]' \
          '--convention=[Load convention]:convention:(nextjs)' \
          '--all[Get all env vars]' \
          '--pretty-print[Pretty print JSON]' \
          '1:key:'
        ;;
      set)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '(-c --encrypt)'{-c,--encrypt}'[Encrypt value]' \
          '--plain[Store as plain text]' \
          '1:key:' \
          '2:value:'
        ;;
      encrypt)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '--stdout[Output to stdout]' \
          '-k[Encryption key]:key:'
        ;;
      decrypt)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '--stdout[Output to stdout]' \
          '-k[Decryption key]:key:'
        ;;
      keypair)
        _arguments \
          '(-f --env-file)'{-f,--env-file}'[Path to .env file]:file:_files' \
          '--format=[Output format]:format:(shell json)'
        ;;
    esac
    ;;
esac
