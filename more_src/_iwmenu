    _arguments -s \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-l --launcher -m --menu)'{-l+,--launcher=}'[launcher to use (REQUIRED)]:launcher:(fuzzel rofi dmenu bemenu custom)' \
        '--launcher-command=[custom launcher command (REQUIRED when --launcher=custom)]:command:' \
        '(-i --icon)'{-i+,--icon=}'[icon set]:icon:(font xdg)' \
        '(-s --spaces)'{-s+,--spaces=}'[spaces between icon and text (default 1)]:n:' \
        '--interactive[stay in menus after actions]'
}

_iwmenu "$@"
