#compdef condor_hold
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_hold.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_hold: place a HTCondor job on hold.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-long[display result ClassAd]' \
  '-totals[display success/failure totals]' \
  '-debug[debug]' \
  '-name[schedd name]:name:' \
  '-pool[pool]:pool:' \
  '-addr[address (sinful string)]:sinful:' \
  '-reason[hold reason text]:reason:' \
  '-subcode[hold subcode]:n:' \
  '-all[hold all jobs of user]' \
  '-constraint[constraint expression]:expr:' \
  '*:jobid:' && ret=0
return ret
