#compdef intake
# Documentation: https://intake.readthedocs.io/en/stable/tools.html
# Intake data catalog command-line tools

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(list describe discover exists get cache config)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      list)
        _arguments '(-h --help)'{-h,--help}'[show help]' '--full[show details for each catalog entry]' '1:uri:_files' && ret=0
        ;;
      describe|discover|exists|get)
        _arguments '(-h --help)'{-h,--help}'[show help]' '1:uri:_files' '2:name:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
