#compdef chisel
# Documentation: https://github.com/jpillora/chisel
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above (chisel server/client flag tables).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run chisel server'
  'client:run chisel client'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chisel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--host=[network host to bind]:host:_hosts' \
          '(--port -p)'{--port=,-p+}'[port to listen on]:port:' \
          '--key=[seed for generating ECDSA key pair]:key string:' \
          '--keepalive=[keepalive interval]:duration:' \
          '--backend=[HTTP server to proxy normal requests to]:url:' \
          '--socks5[enable internal SOCKS5 proxy access]' \
          '--reverse[allow clients to specify reverse port forwarding]' \
          '--auth=[inline credentials user:pass]:auth:' \
          '--authfile=[users.json authentication file]:file:_files' \
          '--tls-key=[TLS private key]:file:_files' \
          '--tls-cert=[TLS certificate]:file:_files' \
          '--tls-ca=[TLS CA certificate]:file:_files' \
          '--tls-domain=[TLS domain for automatic certificate]:domain:' \
          '--pid[enable PID file in tmp directory]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
          '(- *)--help[show help]' && ret=0 ;;
      (client)
        _arguments \
          '--fingerprint=[server fingerprint for verification]:fp:' \
          '--auth=[credentials user:pass]:auth:' \
          '--keepalive=[keepalive interval]:duration:' \
          '--max-retry-count=[maximum number of retries]:n:' \
          '--max-retry-interval=[maximum retry interval]:duration:' \
          '--proxy=[HTTP CONNECT or SOCKS5 proxy]:url:' \
          '--header=[custom HTTP header key:value]:h:' \
          '--hostname=[override Host header]:host:' \
          '--sni=[override SNI hostname]:host:' \
          '--tls-ca=[TLS CA certificate]:file:_files' \
          '--tls-cert=[client TLS certificate]:file:_files' \
          '--tls-key=[client TLS private key]:file:_files' \
          '--tls-skip-verify[skip TLS verification]' \
          '--pid[enable PID file]' \
          '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
          '(- *)--help[show help]' \
          '1:server URL:' \
          '*:remote spec (local\:remote):' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
