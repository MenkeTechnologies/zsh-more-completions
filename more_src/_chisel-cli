#compdef chisel
# Documentation: https://man.archlinux.org/search?q=chisel
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run chisel server'
  'client:run chisel client'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'chisel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--port=[port]:port:' \
          '-p+[port]:port:' \
          '--keepalive=[keepalive]:t:' \
          '--backend=[default backend]:url:' \
          '--socks5[enable SOCKS5]' \
          '--reverse[allow reverse port forwarding]' \
          '--auth=[auth user:pass]:auth:' \
          '--authfile=[auth file JSON]:file:_files' \
          '--key=[fingerprint key]:k:' \
          '--keygen=[keygen output]:file:_files' \
          '--keepalive=[keepalive interval]:t:' \
          '--proxy=[upstream proxy URL]:url:' \
          '--tls-key=[TLS key]:file:_files' \
          '--tls-cert=[TLS cert]:file:_files' \
          '--tls-ca=[TLS CA]:file:_files' \
          '--tls-domain=[TLS domain]:d:' \
          '--pid[print pid]' \
          '-v[verbose]' \
          '*: :' && ret=0 ;;
      (client)
        _arguments \
          '--fingerprint=[server fingerprint]:fp:' \
          '--auth=[user:pass]:auth:' \
          '--keepalive=[keepalive]:t:' \
          '--max-retry-count=[max retry]:n:' \
          '--max-retry-interval=[max retry interval]:t:' \
          '--proxy=[upstream proxy]:url:' \
          '--header=[HTTP header]:h:' \
          '--hostname=[hostname]:h:' \
          '--sni=[SNI]:s:' \
          '--tls-ca=[CA cert]:file:_files' \
          '--tls-cert=[client cert]:file:_files' \
          '--tls-key=[client key]:file:_files' \
          '--tls-skip-verify[skip TLS verify]' \
          '--pid[print pid]' \
          '-v[verbose]' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
