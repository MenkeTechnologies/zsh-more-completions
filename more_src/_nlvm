#compdef nlvm
# Documentation: https://github.com/arnetheduck/nlvm
# nlvm - LLVM-based backend for the Nim compiler

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--os=[target operating system]:os:' \
  '--cpu=[target CPU architecture]:cpu:(amd64 i386 arm arm64 wasm32 riscv64)' \
  '--gc=[garbage collector]:gc:(refc markAndSweep boehm go none arc orc)' \
  '--nlvm.triple=[use a specific target triple]:triple:' \
  '--passl:[pass arguments to the linker]:linker arg:' \
  '--passc:[pass arguments to the compiler]:compiler arg:' \
  '1:command:(c compile r run)' \
  '*:file:_files -g "*.nim"' && ret=0

return ret
