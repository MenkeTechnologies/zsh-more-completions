#compdef stethoscope
# Documentation: upstream monetdb_stethoscope/stethoscope.py at
# github.com/njnes/monetdb-stethoscope
# Reference accessed: 2026-05-30 via gh api inspection of every
# parser.add_argument call.
# MonetDB stethoscope R67 — MonetDB profiler-stream interaction CLI.
# Single-binary Python argparse CLI (pip install monetdb-stethoscope
# installs entry point `stethoscope`).
# NOTE: removed from MonetDB main repo; separate PyPI package.

local -a _formatters _transformers _log_levels _pipelines
_formatters=( json json_pretty line )
_transformers=( statement mask dummy identity prereqs obfuscate )
_log_levels=( debug info warning error critical )
_pipelines=( raw )

_arguments -s -S \
  '(-d --database)'{-d,--database}'=[database name]:database:' \
  '(-I --input)'{-I,--input}'=[read profiler events from file]:file:_files' \
  '(-m --minimal)'{-m,--minimal}'[request minimal profiler stream]' \
  '(-i --include-keys)*'{-i,--include-keys}'=[only include these keys]:keys:' \
  '(-e --exclude-keys)*'{-e,--exclude-keys}'=[exclude these keys]:keys:' \
  '(-l --pipeline)'{-l,--pipeline}'=[parser pipeline]:pipeline:($_pipelines)' \
  '(-F --formatter)'{-F,--formatter}'=[output formatter]:formatter:($_formatters)' \
  '(-t --transformer)*'{-t,--transformer}'=[transformer (repeatable)]:transformer:($_transformers)' \
  '(-o --output)'{-o,--output}'=[output stream (default stdout)]:output:' \
  '(-u --username)'{-u,--username}'=[username (default monetdb)]:user:_users' \
  '(-H --hostname)'{-H,--hostname}'=[hostname (default localhost)]:host:_hosts' \
  '(-P --password)'{-P,--password}'=[password (default monetdb)]:password:' \
  '(-p --port)'{-p,--port}'=[server port (default 50000)]:port:' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-L --log-level)'{-L,--log-level}'=[log level]:level:($_log_levels)' \
  '(-C --no-console)'{-C,--no-console}'[disable console logging]' \
  '(-O --log-file)'{-O,--log-file}'=[log file]:file:_files' \
  '(-U --flush)'{-U,--flush}'[flush output buffer after every event]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(- *)'{-h,--help}'[show help]'
