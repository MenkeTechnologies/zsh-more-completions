#compdef audit-ci

# Zsh completion for audit-ci - continuous integration audit tool for npm/yarn/pnpm

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help information]'
  '--version[show audit-ci version]'
  '(-l --low)'{-l,--low}'[fail on low vulnerabilities]'
  '(-m --moderate)'{-m,--moderate}'[fail on moderate vulnerabilities]'
  '(-h --high)'{-h,--high}'[fail on high vulnerabilities]'
  '(-c --critical)'{-c,--critical}'[fail on critical vulnerabilities]'
  '(-p --package-manager)'{-p,--package-manager}'[package manager]:manager:(auto npm yarn pnpm)'
  '(-a --allowlist)'{-a,--allowlist}'[advisories, cves, paths, or modules to allowlist]:entries:'
  '(-r --report)'{-r,--report}'[print auditor report]'
  '(-o --output-format)'{-o,--output-format}'[report output format]:format:(text json)'
  '--summary[print audit summary]'
  '--report-type[report type]:type:(important summary full)'
  '--retry-count[retry count for network requests]:n:'
  '--show-found-vulnerabilities[show found vulnerabilities even if allowlisted]'
  '--show-not-found[show allowlisted entries that were not found]'
  '--directory[working directory]:dir:_files -/'
  '--extra-args[extra args forwarded to the audit command]:args:'
  '--registry[package registry URL]:url:'
  '--pass-enoaudit[pass if audit command errors]'
  '--config[path to config file]:file:_files -g "*.(json|jsonc)"'
  '--skip-dev[skip development dependencies]'
)

_arguments -s $arguments
