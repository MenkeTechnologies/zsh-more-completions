#compdef xrec
# Documentation: https://man.archlinux.org/search?q=xrec
# Reference accessed: 2026-05-16

# xrec: simple X11 screen recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-o[output file]:file:_files' \
  '-d[X display]:display:' \
  '-r[framerate]:fps:' \
  '-s[scale factor]:scale:' \
  '*::xrec args:_files' && ret=0
return ret
