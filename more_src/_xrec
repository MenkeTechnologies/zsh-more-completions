#compdef xrec
# Documentation: https://github.com/Happy-Ferret/x11-recorder
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrec: X11 screen recorder (PNG screenshots and GIF capture).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[display usage information]' \
  '(- *)'{-V,--version}'[show version number]' \
  {-d,--delay}'+[delay before recording starts (seconds)]:seconds:' \
  {-r,--rate}'+[capture frame rate (milliseconds, default 700)]:ms:' \
  {-c,--count}'+[total frames to capture (default 15)]:n:' \
  {-q,--quality}'+[GIF compression level (default 10)]:n:' \
  {-m,--measure}'[measure screen region and exit]' \
  {-o,--output}'+[output directory]:dir:_directories' \
  {-p,--pointer}'[include mouse cursor in capture]' \
  {-f,--fullscreen}'[record entire screen]' \
  {-s,--screenshot}'[capture static PNG image]' \
  '*:file:_files' && ret=0
return ret
