#compdef acra-translator
# _acra-translator — Acra lightweight encryption translation server (cossacklabs/acra)
# upstream: https://github.com/cossacklabs/acra
# Flags from cmd/acra-translator/acra-translator.go (flag).

_acra-translator() {
    _arguments \
        '(- *)-h[show help]' \
        '-logging_format=[log format]:fmt:(plaintext json CEF)' \
        '-incoming_connection_http_string=[HTTP listen URL]:url:' \
        '-incoming_connection_grpc_string=[gRPC listen URL]:url:' \
        '-keys_dir=[directory containing keys]:dir:_files -/' \
        '-keystore_cache_on_start_enable=[load all keys on start]:bool:(true false)' \
        '-keystore_cache_size=[in-memory key LRU cache size]:n:' \
        '-poison_detect_enable[enable poison record detection]' \
        '-poison_shutdown_enable[shutdown on poison-record detect]' \
        '-poison_run_script_file=[script to run on poison]:file:_files' \
        '-incoming_connection_close_timeout=[stop-signal connection-close timeout (s)]:secs:' \
        '-incoming_connection_prometheus_metrics_string=[Prometheus metrics URL]:url:' \
        '-token_db=[BoltDB token DB file]:file:_files' \
        '-tls_identifier_extractor_type=[TLS cert client-id extractor]:type:(distinguished_name serial_number)' \
        '-acratranslator_client_id_from_connection_enable[derive clientID from TLS connection]' \
        '-audit_log_enable[enable audit logging]' \
        '-v[log INFO/WARN/ERROR to stderr]' \
        '-d[log everything to stderr]' \
        '-log_to_console=[log to stderr]:bool:(true false)' \
        '-log_to_file=[log file path]:file:_files'
}

_acra-translator "$@"
