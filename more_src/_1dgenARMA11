#compdef 1dgenARMA11
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dgenARMA11.html
# Generate an ARMA(1,1) time series for simulation studies

local ret=1

_arguments -s -S \
  '-num[length of the time series vector to generate]:N' \
  '-len[length of the time series vector to generate]:N' \
  '-nvec[number of time series vectors to generate (default 1)]:M' \
  '-a[ARMA(1,1) parameter a]:a' \
  '-b[ARMA(1,1) parameter b directly]:b' \
  '-lam[ARMA(1,1) parameter b indirectly]:lam' \
  '-sig[standard deviation of results (default 1)]:ss' \
  '-norm[normalize so sum of squares equals 1]' \
  '-seed[set random number seed]:dd' \
  '-CORcut[correlation cutoff threshold (default 0.00010)]:cc' \
  '-arma31[use restricted ARMA(3,1) model]:a' \
  '-arma51[use restricted ARMA(5,1) model with two frequencies]:a' && ret=0

return ret
