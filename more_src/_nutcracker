#compdef nutcracker
# Documentation: https://github.com/twitter/twemproxy/blob/master/README.md
# Twemproxy — fast, lightweight proxy for memcached and redis

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-t --test-conf)'{-t,--test-conf}'[test configuration for syntax errors and exit]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as a daemon]' \
  '(-D --describe-stats)'{-D,--describe-stats}'[print stats description and exit]' \
  '(-v --verbose)'{-v,--verbose=}'[set logging level (0-11)]:level:' \
  '(-o --output)'{-o,--output=}'[set logging file]:file:_files' \
  '(-c --conf-file)'{-c,--conf-file=}'[set configuration file]:file:_files -g "*.(yml|yaml)"' \
  '(-s --stats-port)'{-s,--stats-port=}'[set stats monitoring port]:port:' \
  '(-a --stats-addr)'{-a,--stats-addr=}'[set stats monitoring ip]:addr:' \
  '(-i --stats-interval)'{-i,--stats-interval=}'[set stats aggregation interval in msec]:msec:' \
  '(-p --pid-file)'{-p,--pid-file=}'[set pid file]:file:_files' \
  '(-m --mbuf-size)'{-m,--mbuf-size=}'[set size of mbuf chunk in bytes]:bytes:' && ret=0

return ret
