#compdef kubecm
# Documentation: https://github.com/sunny0826/kubecm/tree/master/cmd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_kubecm_commands() {
  local -a commands=(
    'add:Add kubeconfig from file'
    'alias:Generate alias for switch context'
    'clear:Clear lapsed context, cluster and user'
    'cloud:Manage kubeconfig from cloud'
    'completion:Generate shell completion'
    'create:Create new kubeconfig'
    'delete:Delete the specified context'
    'list:List all contexts'
    'merge:Merge kubeconfig files'
    'namespace:Switch or change namespace'
    'rename:Rename the contexts of kubeconfig'
    'switch:Switch kube context interactively'
    'export:Export the specified context'
    'version:Print version info'
    'help:Show help'
  )
  _describe -t commands 'kubecm command' commands
}

_kubecm() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--config=[path of kubeconfig]:file:_files' \
    '--create[create a new kubeconfig file if not exists]' \
    '(-s --silence-table)'{-s,--silence-table}'[enable/disable output of context table]' \
    '(-m --mac-notify)'{-m,--mac-notify}'[display Mac notification banner]' \
    '(-u --ui-size)'{-u+,--ui-size=}'[number of list items to show in menu at once]:n' \
    '1:command:_kubecm_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        add)
          _arguments \
            '(-f --file)'{-f+,--file=}'[path to merge kubeconfig files]:file:_files' \
            '(-c --cover)'{-c,--cover}'[overwrite local kubeconfig files]' \
            '*--context=[specify the context to be added]:context:' \
            '--context-prefix=[add a prefix before context name]:prefix:' \
            '--context-name=[override context name when adding kubeconfig context]:name:' \
            '*--context-template=[attributes used for composing the context name]:template:' \
            '--select-context[select the context to be added in interactive mode]' \
            '--insecure-skip-tls-verify[do not check server certificate validity]'
          ;;
        merge)
          _arguments \
            '(-f --folder)'{-f+,--folder=}'[KubeConfig folder]:dir:_directories' \
            '(-y --assumeyes)'{-y,--assumeyes}'[skip interactive file overwrite confirmation]' \
            '*--context=[specify the context to be merged]:context:' \
            '--context-prefix=[add a prefix before context name]:prefix:' \
            '*--context-template=[attributes used for composing the context name]:template:' \
            '--select-context[select the context to be merged in interactive mode]' \
            '*:kubeconfig files:_files'
          ;;
        export)
          _arguments \
            '(-f --file)'{-f+,--file=}'[path to export kubeconfig files]:file:_files' \
            '*:context name:'
          ;;
        rename)
          _arguments \
            '1:context name:'
          ;;
        switch|namespace|delete)
          _arguments \
            '1:context name:'
          ;;
        cloud)
          _arguments \
            '--provider=[public cloud]:provider:' \
            '--cluster_id=[kubernetes cluster id]:id:' \
            '--region_id=[cloud region id]:region:' \
            '--aws_profile=[AWS profile name]:profile:' \
            '1:subcommand:(add list)'
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kubecm "$@"
