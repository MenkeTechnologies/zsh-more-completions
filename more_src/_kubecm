#compdef kubecm

_kubecm_commands() {
  local -a commands=(
    'add:Add kubeconfig from file'
    'completion:Generate shell completion'
    'create:Create new kubeconfig'
    'delete:Delete a context'
    'list:List all contexts'
    'merge:Merge kubeconfig files'
    'namespace:Switch namespace'
    'rename:Rename a context'
    'switch:Switch to a context'
    'alias:Manage context aliases'
    'cloud:Manage cloud kubeconfigs'
    'export:Export a context to file'
    'clear:Clear kubeconfig'
    'version:Print version'
    'help:Show help'
  )
  _describe -t commands 'kubecm command' commands
}

_kubecm() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--config[Kubeconfig file]:file:_files' \
    '1:command:_kubecm_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        add)
          _arguments \
            '(-f --file)'{-f,--file}'[Kubeconfig file to add]:file:_files' \
            '(-n --name)'{-n,--name}'[Context name override]:name:' \
            '--context[Specific context to add]:context:' \
            '-c[Cover existing context]'
          ;;
        delete)
          _arguments \
            '1:context name:'
          ;;
        merge)
          _arguments \
            '(-f --folder)'{-f,--folder}'[Folder containing kubeconfigs]:dir:_directories' \
            '*:kubeconfig files:_files'
          ;;
        rename)
          _arguments \
            '1:old name:' \
            '2:new name:'
          ;;
        switch)
          _arguments \
            '1:context name:'
          ;;
        namespace)
          _arguments \
            '1:namespace:'
          ;;
        export)
          _arguments \
            '(-f --file)'{-f,--file}'[Output file]:file:_files' \
            '1:context name:'
          ;;
        cloud)
          local -a subcommands=(
            'add:Add cloud kubeconfig'
            'list:List cloud providers'
          )
          _describe -t subcommands 'cloud subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_kubecm "$@"
