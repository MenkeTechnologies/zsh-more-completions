#compdef zitadel

_zitadel_commands() {
    local -a commands
    commands=(
        'start:Start ZITADEL'
        'start-from-init:Initialize and start ZITADEL'
        'start-from-setup:Setup and start ZITADEL'
        'init:Initialize ZITADEL'
        'setup:Setup ZITADEL'
        'mirror:Mirror data from one database to another'
        'key:Manage encryption keys'
        'admin:Admin commands'
        'completion:Generate shell completion'
        'help:Help about any command'
    )
    _describe -t commands 'zitadel command' commands
}

_zitadel() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--config[Path to config file]:file:_files' \
        '--masterkey[Master key for encryption]:key:' \
        '--tlsMode[TLS mode]:mode:(disabled external)' \
        '--externalDomain[External domain]:domain:' \
        '--externalPort[External port]:port:' \
        '--externalSecure[Use HTTPS for external communication]' \
        '1:command:_zitadel_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                start|start-from-init|start-from-setup)
                    _arguments \
                        '--config[Config file path]:file:_files' \
                        '--masterkey[Master key]:key:' \
                        '--tlsMode[TLS mode]:mode:(disabled external)' \
                        '--externalDomain[External domain]:domain:' \
                        '--externalPort[External port]:port:' \
                        '--externalSecure[Use HTTPS]' \
                        '--port[Listening port]:port:' \
                        '--database.cockroach.host.address[CockroachDB host]:host:_hosts' \
                        '--database.cockroach.host.port[CockroachDB port]:port:' \
                        '--database.cockroach.database[CockroachDB database]:database:' \
                        '--database.cockroach.user.username[CockroachDB user]:user:' \
                        '--database.cockroach.user.password[CockroachDB password]:password:' \
                        '--database.cockroach.user.ssl.mode[SSL mode]:mode:(disable require verify-ca verify-full)' \
                        '--database.postgres.host.address[PostgreSQL host]:host:_hosts' \
                        '--database.postgres.host.port[PostgreSQL port]:port:' \
                        '--database.postgres.database[PostgreSQL database]:database:' \
                        '--database.postgres.user.username[PostgreSQL user]:user:' \
                        '--database.postgres.user.password[PostgreSQL password]:password:' \
                        '--database.postgres.user.ssl.mode[SSL mode]:mode:(disable require verify-ca verify-full)'
                    ;;
                init)
                    _arguments \
                        '--config[Config file path]:file:_files' \
                        '--steps[Path to steps config]:file:_files'
                    ;;
                setup)
                    _arguments \
                        '--config[Config file path]:file:_files' \
                        '--masterkey[Master key]:key:' \
                        '--init-projections[Initialize projections]'
                    ;;
                mirror)
                    _arguments \
                        '--config[Config file path]:file:_files' \
                        '--source[Source config]:file:_files' \
                        '--destination[Destination config]:file:_files' \
                        '1:action:(auth eventstore projections system verify)'
                    ;;
                key)
                    _arguments \
                        '1:action:(generate)' \
                        '--masterkey[Master key]:key:'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_zitadel "$@"
