#compdef mutt-wizard mw
# Documentation: https://github.com/LukeSmithxyz/mutt-wizard
# Reference accessed: 2026-05-16
# Verified: upstream README + mw POSIX shell source. Binary is `mw`.
# Removed from prior file: fabricated -h/--help/-V/--version (mw uses
# only short opts) and bogus man.archlinux.org search URL.

# mutt-wizard (mw): mutt account configuration helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[add a new email account]:email:' \
  '-l[list existing accounts]' \
  '-d[choose an account to delete]' \
  '-D[delete account without confirmation]:email:' \
  '-t[toggle automatic mailsync every N minutes]:minutes:' \
  '-T[toggle mailsync with default 10 minute interval]' \
  '-r[reorder account shortcut numbers]' \
  '-u[IMAP/SMTP username]:user:' \
  '-n[user real name]:name:' \
  '-i[IMAP server]:host:' \
  '-I[IMAP port]:port:' \
  '-s[SMTP server]:host:' \
  '-S[SMTP port]:port:' \
  '-m[max messages to sync per folder]:n:' \
  '-x[account password (insecure, prompts otherwise)]:password:' \
  '-f[force account creation despite errors]' \
  '-o[offline mode (no online verification)]' \
  '-p[use plain auth]' && ret=0
return ret
