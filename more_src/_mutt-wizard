#compdef mutt-wizard mw
# Documentation: https://github.com/LukeSmithxyz/mutt-wizard/blob/master/bin/mw
# Reference accessed: 2026-05-19
# Verified: upstream bin/mw getopts string in the POSIX shell source.
# Binary is `mw`.

# mutt-wizard (mw): mutt account configuration helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[add a new email account]:email:' \
  '-l[list existing accounts]' \
  '-d[choose an account to delete]' \
  '-D[delete account without confirmation]:email:' \
  '-y[sync mail for account by name]:account:' \
  '-Y[sync mail for all accounts]' \
  '-t[toggle automatic mailsync every N minutes]:minutes:' \
  '-T[toggle mailsync with default 10 minute interval]' \
  '-r[reorder account shortcut numbers]' \
  '-u[IMAP/POP username]:user:' \
  '-n[user real name]:name:' \
  '-i[IMAP/POP server]:host:' \
  '-I[IMAP/POP server port]:port:' \
  '-s[SMTP server]:host:' \
  '-S[SMTP server port]:port:' \
  '-m[max messages to sync per folder]:n:' \
  '-x[account password (insecure; prompts otherwise)]:password:' \
  '-P[pass-store prefix for the password file]:prefix:' \
  '-X[also delete local mail when removing account]' \
  '-f[force account creation despite errors]' \
  '-o[offline mode (no online verification)]' \
  '-p[configure POP server instead of IMAP]' \
  '-h[show help]' && ret=0
return ret
