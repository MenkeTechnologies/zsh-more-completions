# ============================================================================
#  _vuls — vuls: agent-less vulnerability scanner for Linux,
#          FreeBSD, Container, WordPress, programming-language
#          libraries (future-architect/vuls)
#
#  Source-direct extraction from
#    https://github.com/future-architect/vuls/blob/master/cmd/vuls/main.go
#    https://github.com/future-architect/vuls/blob/master/subcmds/{scan,report,tui,discover,history,configtest,server}.go
#    https://github.com/google/subcommands (the google/subcommands
#    library — Google's Go subcommand framework)
#
#  Maintained by Future-Architect Inc. (Japanese sec engineering
#  firm) — original author Kota Kanbe (kotakanbe).  12,167 GH
#  stars.  vuls is an AGENT-LESS vulnerability scanner: connects
#  to target servers over SSH, inventories installed packages
#  (DEB/RPM/APK/pkg/FreeBSD ports/composer/gem/pip/npm/cargo/etc.),
#  then cross-references the installed-version-set against NVD/
#  OVAL/JVN/RedHatErrata/UbuntuUSN/DebianDSA/AlpineSecDB CVE
#  databases to report missing security patches.  Supports
#  CONTAINER scanning (Docker/LXD), WORDPRESS scanning (WP core +
#  plugins + themes), and programming-language LIBRARY scanning
#  (npm/pip/gem/composer/cargo/yarn lockfiles).  Output formats:
#  TUI (terminal UI), JSON, CSV, CycloneDX SBOM (JSON+XML), one-
#  email, one-line-text, full-text, list.  Long-running web-app
#  mode (`vuls server`) exposes a localhost:5515 HTTP API for
#  CI/CD integration.  Sister tools: trivy (in corpus via _trivy
#  — Aqua Security's container/IaC vuln scanner; vuls INTEGRATES
#  WITH trivy's vulnerability database via --trivy-cachedb-dir),
#  grype (Anchore's vuln scanner — in corpus via _grype), snyk
#  (in corpus via _snyk + STOCK Node.js dev community), syft
#  (Anchore SBOM generator — in corpus via _syft), oss-review-
#  toolkit (ORT — in corpus via _ort), clamav (in corpus + STOCK),
#  nessus (Tenable commercial scanner), openvas (in corpus + STOCK
#  Kali).
#
#  CLI library taxonomy update: 14th Go CLI library — Google's
#  **subcommands** (google/subcommands).  Go ecosystem now has 14
#  documented CLI libraries — TYING WITH RUST at the top of the
#  cross-language taxonomy ahead of TypeScript-Node (13).  🎉 Go
#  RE-TIES with Rust at 14.
#
#  google/subcommands (789 GH stars) is GOOGLE'S OFFICIAL Go
#  subcommand framework — designed for tools that need
#  GIT/SVN/HG-style subcommand dispatch (`tool subcmd [flags]
#  [args]`) without the heavy cobra/urfave-cli ceremony.  Used
#  internally at GOOGLE for many Google Cloud / Borg / Bazel-
#  adjacent tools and many open-source Google projects.  Used by
#  future-architect/vuls (12,167 stars), google/gvisor (Google's
#  application kernel — runsc uses subcommands; gvisor 16,000+
#  stars), google/kf (Cloud Foundry on Kubernetes 405 stars),
#  drone/go-convert (Drone CI pipeline converter), kayac/bqin
#  (KAYAC BigQuery ingestion CLI), 1f349/jasmine (Jasmine multi-
#  user OAuth2 server), Xe/site (Xe Iaso's site CLI), kuenishi/
#  baccounts, donatj/pullaway (Pushover CLI), mprimi/nasefa,
#  multifacet/kalium (gVisor variant), and many other Go binaries
#  that prefer Google's idiomatic Command interface over cobra's
#  Command struct.
#
#  google/subcommands API:
#    import (
#      "context"
#      "flag"
#      "github.com/google/subcommands"
#    )
#
#    // Each subcommand implements the Command interface:
#    type ScanCmd struct {
#      configPath string
#      timeoutSec int
#      // ... fields for flag values
#    }
#
#    // Name() returns the subcommand name (used in dispatch)
#    func (*ScanCmd) Name() string     { return "scan" }
#
#    // Synopsis() returns a one-line description
#    func (*ScanCmd) Synopsis() string { return "Scan target server" }
#
#    // Usage() returns multi-line usage help
#    func (*ScanCmd) Usage() string {
#      return `scan [flags] [server...]
#
#    Scan target server(s) for vulnerabilities.
#    `
#    }
#
#    // SetFlags is called by subcommands to register flags into
#    // the subcommand's FlagSet (uses stdlib flag package!)
#    func (p *ScanCmd) SetFlags(f *flag.FlagSet) {
#      f.StringVar(&p.configPath, "config", "/etc/vuls/config.toml",
#                  "Config file path")
#      f.IntVar(&p.timeoutSec, "timeout", 300, "Timeout (sec)")
#      f.BoolVar(&p.debug, "debug", false, "Debug mode")
#    }
#
#    // Execute is the subcommand's main entry point
#    func (p *ScanCmd) Execute(ctx context.Context,
#                              f *flag.FlagSet,
#                              args ...any) subcommands.ExitStatus {
#      // ... do scan work
#      return subcommands.ExitSuccess
#    }
#
#    func main() {
#      subcommands.Register(subcommands.HelpCommand(), "")
#      subcommands.Register(subcommands.FlagsCommand(), "")
#      subcommands.Register(subcommands.CommandsCommand(), "")
#      subcommands.Register(&ScanCmd{}, "")
#      subcommands.Register(&ReportCmd{}, "")
#      flag.Parse()  // parse top-level flags
#      ctx := context.Background()
#      os.Exit(int(subcommands.Execute(ctx)))
#    }
#
#  google/subcommands distinctive features:
#    - COMMAND INTERFACE: subcommands implement
#      `Name() / Synopsis() / Usage() / SetFlags(*flag.FlagSet) /
#      Execute(ctx, *flag.FlagSet, ...any) ExitStatus` — 5
#      methods, no struct config
#    - STDLIB flag PACKAGE FOR FLAG REGISTRATION — SetFlags
#      receives a `*flag.FlagSet` from the Go standard library,
#      which means EVERY FLAG TYPE FROM stdlib flag works
#      automatically: BoolVar/StringVar/IntVar/Int64Var/UintVar/
#      Float64Var/DurationVar/Func/Var. NO new flag-registration
#      API to learn.  CONTRAST: cobra brings spf13/pflag (its own
#      flag system); kong brings struct tags; flaggy brings
#      package-level setters.
#    - GROUPING via `subcommands.Register(cmd, group)` — the
#      `group` string parameter clusters subcommands under named
#      headings in the auto-generated "commands" output (empty
#      string is the default unnamed group)
#    - BUILT-IN HELP/FLAGS/COMMANDS subcommands:
#      * `subcommands.HelpCommand()` — `tool help` and `tool help
#        SUBCMD` for per-subcommand usage
#      * `subcommands.FlagsCommand()` — `tool flags` and `tool
#        flags SUBCMD` for per-subcommand flag listing
#      * `subcommands.CommandsCommand()` — `tool commands` lists
#        all registered subcommands
#    - ExitStatus ENUM — `subcommands.ExitSuccess` (0),
#      `ExitFailure` (1), `ExitUsageError` (2) — Execute returns
#      one of these for os.Exit
#    - INTERFACE-BASED DISPATCH — Execute() is called on the
#      matched Command via interface method call; no struct
#      Run/RunE fields, no func-pointer chains.  CONTRAST: cobra's
#      RunE func field on Command struct, kong's Run(ctx) error
#      method, urfave/cli's Action func field
#    - GLOBAL REGISTRY via package-level `Register(cmd, group)` —
#      single global subcommand registry per process (unlike
#      cobra's rootCmd.AddCommand tree which can be assembled at
#      any depth)
#    - NO POSITIONAL parsing helpers — `Execute(ctx, f, args...)`
#      receives positionals as `f.Args()` from the FlagSet; caller
#      does any further positional parsing manually
#    - NO automatic --version (caller handles via top-level
#      flag.Bool before subcommands.Execute, as vuls does:
#      `var v = flag.Bool("v", false, "Show version"); flag.Parse();
#      if *v { print version; exit }`)
#    - NO env-var fallback (subcommands focuses ONLY on
#      subcommand dispatch; pair with peterbourgon/ff if you need
#      env+config-file merge)
#    - NO type-coerced parsing beyond stdlib flag's built-in types
#    - INSPIRED BY GOOGLE'S INTERNAL go/src/cmd-style subcommand
#      pattern (similar to `go test`, `go build`, `go fmt`, etc.
#      which use a similar Command interface internally to Go's
#      own tool); package extracted from internal Google tools
#      and open-sourced
#  Distinct from R237 Go spf13/cobra (subcommand-TREE with Command
#  STRUCTS having Run/RunE func fields + rootCmd.AddCommand(child)
#  tree assembly — Hugo/Kubernetes/Docker), R237 Go spf13/pflag
#  (POSIX-flag-compat replacement for stdlib flag — used INSIDE
#  cobra), R237 Go urfave/cli (action-callback framework — Docker
#  pre-cobra, restic), R237 Go alecthomas/kingpin (chained-builder
#  fluent API — Prometheus), R237 Go jessevdk/go-flags (struct-tag
#  based — Helm earlier), R237 Go mitchellh/cli (HashiCorp
#  Terraform), R262 Go stdlib `flag` (POSIX-INCOMPATIBLE single-
#  dash — gofmt/go test; google/subcommands USES stdlib flag for
#  flag registration internally), R363 Go peterbourgon/ff
#  (functional-options 3-way config flag/env/file merge), R367 Go
#  akamensky/argparse (Python-argparse-style port), R408 Go
#  pborman/getopt (POSIX-getopt(3) faithful BSD/C-style — oklog/
#  ulid), R411 Go integrii/flaggy (package-level functional-
#  builder — joanbono/Gurp + jesseduffield/lazydocker), R414 Go
#  alecthomas/kong (modern struct-tag — charmbracelet/freeze + gum
#  + mtg).  Go documented libraries so far: stdlib flag, pflag,
#  cobra, urfave-cli, kingpin, jessevdk/go-flags, mitchellh/cli,
#  ff, akamensky/argparse, pborman/getopt, flaggy, kong, google/
#  subcommands (this round)... that's 14.  google/subcommands's
#  distinguishing feature vs ALL other Go libs: subcommands is the
#  ONLY one that PURELY HANDLES SUBCOMMAND DISPATCH (5-method
#  Command interface) while DELEGATING flag registration entirely
#  to stdlib flag.FlagSet — every other lib (cobra/kong/urfave/
#  kingpin/flaggy) wraps stdlib flag in its own flag API.  google/
#  subcommands's approach: COMMAND-INTERFACE SUBCOMMAND DISPATCH
#  with `subcommands.Register(cmd, group)` global registry + 5-
#  method `Name()/Synopsis()/Usage()/SetFlags(*flag.FlagSet)/
#  Execute(ctx, f, args...) ExitStatus` interface + STDLIB flag
#  for flag registration (BoolVar/StringVar/IntVar/etc.) + built-
#  in `HelpCommand()`/`FlagsCommand()`/`CommandsCommand()` meta-
#  subcommands + group string parameter for subcommand clustering
#  + `ExitStatus` enum (Success/Failure/UsageError) + NO POSIX-
#  long-flag (inherits stdlib flag's single-dash long-flag style)
#  + NO automatic --version + NO env-var fallback (compose with
#  peterbourgon/ff for that) — corpus's **first documented pure-
#  subcommand-dispatch Go CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 156; Go ecosystem now
#  has 14 documented CLI libraries — TYING WITH RUST at the top
#  of the cross-language taxonomy ahead of TypeScript-Node (13).
#
#  Surface (verbatim from `cmd/vuls/main.go` subcommands.Register
#  calls + `subcmds/*.go` SetFlags):
#
#  Top-level:
#    vuls [options] <subcommand>
#
#  Top-level flag:
#    -v                             Show version (handled BEFORE
#                                   subcommand dispatch by
#                                   flag.Parse() in main)
#
#  Subcommands:
#    help [SUBCMD]                  Show help (auto from subcommands.
#                                   HelpCommand)
#    flags [SUBCMD]                 List flags for a subcommand
#    commands                       List all registered subcommands
#    discover <CIDR-RANGE>          Discover SSH-reachable hosts in
#                                   a CIDR range (prints
#                                   bootstrap config)
#    tui                            Launch terminal UI for browsing
#                                   scan results
#    scan [HOST...]                 Scan target server(s) for
#                                   vulnerabilities (the CORE
#                                   workflow — connects over SSH
#                                   and inventories packages)
#    history                        Display scan history
#    report                         Generate vulnerability report
#                                   from prior scan results (does
#                                   NOT re-scan; reads from
#                                   results-dir)
#    configtest                     Test config file + SSH
#                                   connectivity to all hosts
#                                   defined in config.toml
#    server                         Run as long-running HTTP API
#                                   server (default port 5515)
#                                   for CI/CD integration
#
#  Common flags (most subcommands accept these):
#    -config FILE                   Path to TOML config file
#                                   (default: /etc/vuls/config.toml)
#    -results-dir DIR               Path to results directory
#    -log-dir DIR                   Path to log directory
#    -log-to-file                   Output log to file
#    -debug                         Debug mode (verbose logging)
#    -quiet                         Quiet mode (no stdout output)
#    -debug-sql                     SQL debug mode (verbose DB
#                                   query logging)
#    -http-proxy URL                HTTP proxy URL
#    -vvv                           ssh -vvv (very verbose SSH
#                                   debug — for SSH connection
#                                   troubleshooting)
#    -no-progress                   Suppress progress bar
#
#  vuls scan specific flags:
#    -cachedb-path FILE             Path to cache DB file
#    -timeout SEC                   Per-host timeout (default: 300)
#    -timeout-scan SEC              Scan timeout (default: 7200)
#    -pipe                          Use stdin via PIPE
#    -ips                           Retrieve IPS information
#
#  vuls report specific flags:
#    -lang LANG                     Report language [en|ja]
#                                   (default: en)
#    -confidence-over N             Confidence threshold for
#                                   reporting (default: 80)
#    -refresh-cve                   Refresh CVE database before
#                                   generating report
#    -diff                          Show diff vs previous scan
#    -diff-plus                     Show only NEW CVEs vs previous
#    -diff-minus                    Show only RESOLVED CVEs vs
#                                   previous
#    -ignore-unscored-cves          Ignore CVEs without CVSS score
#    -ignore-unfixed                Ignore unfixed CVEs (those
#                                   with no upstream patch yet)
#    -format-json                   Output report as JSON
#    -format-csv                    Output report as CSV
#    -format-one-email              Output as single-email format
#    -format-one-line-text          One-line text format
#    -format-list                   Display as list format
#    -format-full-text              Full text format
#    -format-cyclonedx-json         CycloneDX SBOM JSON format
#    -format-cyclonedx-xml          CycloneDX SBOM XML format
#
#  vuls tui specific flags:
#    -trivy-cachedb-dir DIR         Trivy cache DB directory (vuls
#                                   integrates with Trivy's CVE DB)
#    -trivy-db-repository LIST      Comma-separated list of Trivy
#                                   DB repositories
#    -trivy-java-db-repository LIST Trivy Java DB Repositories
#                                   (comma-separated)
#    -trivy-skip-java-db-update     Skip Trivy Java DB update
#
#  vuls server specific flags:
#    -listen ADDR                   Listen address (default:
#                                   localhost:5515)
#    -to-localfile                  Write report to local file
#                                   (instead of HTTP response)
#
#  Examples:
#    vuls -v                                            # Print version
#    vuls help                                          # List subcommands
#    vuls help scan                                     # Per-subcommand help
#    vuls flags scan                                    # List scan's flags
#    vuls configtest                                    # Test config + SSH
#    vuls discover 192.168.1.0/24                       # Discover hosts in CIDR
#    vuls scan -config /etc/vuls/config.toml            # Scan all hosts in config
#    vuls scan -config c.toml server1 server2           # Scan specific hosts
#    vuls scan -timeout 600 -ips                        # Longer timeout + IPS info
#    vuls report -lang ja -format-json > report.json    # JSON report in Japanese
#    vuls report -diff-plus                             # Only NEW CVEs vs last
#    vuls report -format-cyclonedx-json > sbom.json     # CycloneDX SBOM
#    vuls tui                                           # Terminal UI
#    vuls server -listen 0.0.0.0:5515                   # Run as HTTP API server
#    vuls history                                       # Past scan history
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also google/subcommands users):
#    - kf (IN CORPUS via _kf — Google Cloud Foundry on K8s 405
#      stars; google/subcommands user; already documented)
#    - gvisor's runsc (IN CORPUS via _runsc — Google application
#      kernel; uses google/subcommands; previously documented)
#    - go-convert (drone/go-convert 16 stars — Drone CI pipeline
#      converter; too niche)
#    - bqin (kayac/bqin 4 stars — too niche)
#    - jasmine (1f349/jasmine — multi-user OAuth2 server; FUTURE)
#    - baccounts (kuenishi/baccounts — FUTURE)
#    - pullaway (donatj/pullaway 1 star Pushover CLI — too niche)
# ============================================================================

_vuls() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '-v[show version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'help:show help (with optional subcommand)'
        'flags:list flags for a subcommand'
        'commands:list all registered subcommands'
        'discover:discover SSH-reachable hosts in a CIDR range'
        'tui:launch terminal UI for browsing scan results'
        'scan:scan target server(s) for vulnerabilities'
        'history:display scan history'
        'report:generate vulnerability report from prior scan results'
        'configtest:test config file + SSH connectivity'
        'server:run as long-running HTTP API server'
      )
      _describe -t subcommands 'vuls subcommand' subcmds
      ;;
    args)
      local -a common_flags
      common_flags=(
        '-config[path to TOML config file]:file:_files -g "*.toml"'
        '-results-dir[path to results directory]:dir:_directories'
        '-log-dir[path to log directory]:dir:_directories'
        '-log-to-file[output log to file]'
        '-debug[debug mode]'
        '-quiet[quiet mode (no stdout output)]'
        '-debug-sql[SQL debug mode]'
        '-http-proxy[HTTP proxy URL]:url:'
        '-vvv[ssh -vvv (very verbose SSH debug)]'
        '-no-progress[suppress progress bar]'
      )

      case "${words[1]}" in
        scan)
          _arguments -s -S "${common_flags[@]}" \
            '-cachedb-path[path to cache DB file]:file:_files' \
            '-timeout[per-host timeout (sec)]:seconds:' \
            '-timeout-scan[scan timeout (sec)]:seconds:' \
            '-pipe[use stdin via PIPE]' \
            '-ips[retrieve IPS information]' \
            '*:host:_hosts'
          ;;
        report)
          _arguments -s -S "${common_flags[@]}" \
            '-lang[report language]:lang:(en ja)' \
            '-confidence-over[confidence threshold]:n:' \
            '-refresh-cve[refresh CVE database before report]' \
            '-diff[show diff vs previous scan]' \
            '-diff-plus[show only NEW CVEs vs previous]' \
            '-diff-minus[show only RESOLVED CVEs vs previous]' \
            '-ignore-unscored-cves[ignore CVEs without CVSS score]' \
            '-ignore-unfixed[ignore unfixed CVEs]' \
            '-format-json[JSON format]' \
            '-format-csv[CSV format]' \
            '-format-one-email[one-email format]' \
            '-format-one-line-text[one-line text format]' \
            '-format-list[list format]' \
            '-format-full-text[full text format]' \
            '-format-cyclonedx-json[CycloneDX SBOM JSON format]' \
            '-format-cyclonedx-xml[CycloneDX SBOM XML format]'
          ;;
        tui)
          _arguments -s -S "${common_flags[@]}" \
            '-trivy-cachedb-dir[Trivy cache DB directory]:dir:_directories' \
            '-trivy-db-repository[comma-separated Trivy DB repositories]:repos:' \
            '-trivy-java-db-repository[Trivy Java DB Repositories]:repos:' \
            '-trivy-skip-java-db-update[skip Trivy Java DB update]'
          ;;
        server)
          _arguments -s -S "${common_flags[@]}" \
            '-listen[listen address]:addr:' \
            '-to-localfile[write report to localfile]' \
            '-confidence-over[confidence threshold]:n:' \
            '-ignore-unscored-cves[ignore CVEs without CVSS]' \
            '-ignore-unfixed[ignore unfixed CVEs]' \
            '-lang[language]:lang:(en ja)'
          ;;
        configtest)
          _arguments -s -S \
            '-config[path to config file]:file:_files -g "*.toml"' \
            '-log-dir[path to log directory]:dir:_directories' \
            '-log-to-file[output log to file]' \
            '-debug[debug mode]' \
            '-timeout[timeout (sec)]:seconds:' \
            '-http-proxy[HTTP proxy URL]:url:' \
            '-vvv[ssh -vvv]'
          ;;
        history)
          _arguments -s -S \
            '-debug-sql[SQL debug mode]' \
            '-results-dir[path to results directory]:dir:_directories'
          ;;
        discover)
          _arguments -s -S \
            '*:cidr-range:'
          ;;
        help|flags)
          local -a sub2
          sub2=(
            'discover' 'tui' 'scan' 'history' 'report' 'configtest' 'server'
          )
          _describe -t subcommands 'subcommand' sub2
          ;;
      esac
      ;;
  esac
}

_vuls "$@"
