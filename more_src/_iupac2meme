#compdef iupac2meme
# Documentation: https://meme-suite.org/meme/doc/iupac2meme.html
# MEME Suite: convert IUPAC consensus sequences to MEME motif format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-numseqs[assumed number of sequences used to build the motif]:count:' \
  '-bg[background frequencies file]:file:_files' \
  '-pseudo[pseudocount added to the motif counts]:count:' \
  '-named[expect a name before each consensus sequence]' \
  '-nosort[do not change the order of the motifs]' \
  '*:consensus sequence:' && ret=0

return ret
