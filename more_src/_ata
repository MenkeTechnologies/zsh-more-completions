#compdef ata
# Documentation: https://github.com/transformrs/ata
# Reference accessed: 2026-05-17
# Verified: transformrs/ata ("Ask the Terminal Anything"). NOTE: upstream
# renamed the binary to `trf` — `ata` is the historical name. Keeping
# this completion for users with the older binary on PATH.
# Removed from prior file: bogus man.archlinux.org search URL;
# malformed -m+,--model= form (zsh _arguments cannot mix that syntax).

# ata: Ask the Terminal Anything (legacy name for `trf`)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --model)'{-m+,--model=}'[provider model string]:model:' \
  '*::prompt:_default' && ret=0
return ret
