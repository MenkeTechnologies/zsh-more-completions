#compdef ata
# Documentation: https://man.archlinux.org/search?q=ata
# Reference accessed: 2026-05-16

# transformrs/ata — terminal LLM assistant (clap)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '-m+,--model=[provider model string]:model:' \
  '*::prompt:_default' && ret=0
return ret
