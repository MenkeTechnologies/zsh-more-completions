#compdef fitsurface
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss60.html
# KAPPA: fit a polynomial or bi-cubic spline surface to two-dimensional data

local ret=1

_arguments -s \
  'COSYS=[coordinate system for the fit]:cosys:(World Data)' \
  'FITTYPE=[type of fitting function]:fittype:(Polynomial Spline)' \
  'KNOTS=[number of interior knots for spline]:knots' \
  'NDF=[input NDF with the 2D array]:NDF:_files' \
  'NXPAR=[number of fitting parameters in x]:nxpar' \
  'NYPAR=[number of fitting parameters in y]:nypar' \
  'OVERWRITE=[replace existing surface-fit extension]:overwrite:(TRUE FALSE)' \
  'VARIANCE=[use variance to weight the data]:variance:(TRUE FALSE)' \
  'XMAX=[maximum x coordinate for the fit]:xmax' \
  'XMIN=[minimum x coordinate for the fit]:xmin' \
  'YMAX=[maximum y coordinate for the fit]:ymax' \
  'YMIN=[minimum y coordinate for the fit]:ymin' \
  '*:NDF:_files' && ret=0

return ret
