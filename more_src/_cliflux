#compdef cliflux
# _cliflux — terminal UI for Miniflux RSS reader (spencerwi/cliflux)
# upstream: https://github.com/spencerwi/cliflux
# Flags from src/main.rs.

_cliflux() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--init[write default config file and exit]' \
        '(- *)--check-config[print resolved config and exit]'
}

_cliflux "$@"
