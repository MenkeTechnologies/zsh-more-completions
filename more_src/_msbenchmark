#compdef msbenchmark
# Documentation: https://proteowizard.sourceforge.io/tools/tools_base.html
# ProteoWizard: benchmark reading of mass-spec data files

local ret=1

_arguments -s -S \
  '*--filter[apply a spectrum list filter]:filter:' \
  '--acceptZeroLengthSpectra[accept zero-length spectra]' \
  '--ignoreZeroIntensityPoints[ignore zero-intensity points]' \
  '--combineIonMobilitySpectra[combine ion-mobility spectra]' \
  '--simAsSpectra[read SIM as spectra]' \
  '--srmAsSpectra[read SRM as spectra]' \
  '--loop[loop the benchmark]' \
  '--singleThreaded[run single-threaded]' \
  '--reverse[iterate in reverse order]' \
  '--help[show help]' \
  '1:mode:(spectra chromatograms rampadapter ramp)' \
  '2:detail:(full-data full-metadata fast-metadata instant-metadata)' \
  '3:data file:_files' && ret=0

return ret
