#compdef mksquashfs
# Documentation: https://github.com/plougher/squashfs-tools/blob/master/Documentation/4.7.6/USAGE-MKSQUASHFS
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show help summary]' \
  '(- *)-help-all[show complete help documentation]' \
  '-help-option+[help on matching options]:regex' \
  '-help-section+[help on specific section]:section' \
  '-help-comp+[compressor-specific help]:compressor' \
  '1:source directory:_files -/' \
  '2:destination file:_files' \
  '-comp+[set compression algorithm]:algorithm:(gzip lzma lzo lz4 xz zstd)' \
  '-b+[set data block size]:block size' \
  '-no-compression[disable all compression]' \
  '-tar[read uncompressed tar from stdin]' \
  '-tarstyle[retain full source paths]' \
  '-cpiostyle[read file paths from stdin]' \
  '-cpiostyle0[like cpiostyle but null-terminated]' \
  '-reproducible[build reproducible filesystem]' \
  '-not-reproducible[build non-reproducible filesystem]' \
  '-mkfs-time=[set filesystem creation time]:time' \
  '-root-time=[set root directory timestamp]:time' \
  '-inode-time=[set all inode timestamps]:time' \
  '-info[print files as they are compressed]' \
  '-info-file+[log compression progress to file]:file:_files' \
  '-no-progress[do not display progress bar]' \
  '-progress[display progress bar]' \
  '-percentage[display progress as percentage]' \
  '-no-exports[do not make filesystem exportable via NFS]' \
  '-exports[make filesystem exportable via NFS]' \
  '-no-sparse[do not detect sparse files]' \
  '-no-xattrs[do not store extended attributes]' \
  '-xattrs[store extended attributes]' \
  '*-xattrs-exclude+[remove matching xattrs]:regex' \
  '*-xattrs-include+[keep only matching xattrs]:regex' \
  '*-xattrs-add+[add xattr to files]:name=value' \
  '-noI[do not compress inode table]' \
  '-noId[do not compress uid/gid table]' \
  '-noD[do not compress data blocks]' \
  '-noF[do not compress fragment blocks]' \
  '-noX[do not compress extended attributes]' \
  '-no-fragments[do not use fragments]' \
  '-tailends[pack file tail ends into fragments]' \
  '-no-duplicates[do not perform duplicate checking]' \
  '-no-hardlinks[store duplicates instead of hardlinking]' \
  '-all-root[make all files owned by root]' \
  '-root-uid+[set root directory uid]:uid' \
  '-root-gid+[set root directory gid]:gid' \
  '-root-mode+[set root directory permissions]:mode' \
  '-root-becomes+[rename original root on append]:name' \
  '-default-uid+[set default directory uid]:uid' \
  '-default-gid+[set default directory gid]:gid' \
  '-force-uid+[force all files to be owned by uid]:uid' \
  '-force-gid+[force all files to be owned by gid]:gid' \
  '-uid-gid-offset+[offset all uid/gids]:offset' \
  '-force-file-mode+[set all file permissions]:mode' \
  '-force-dir-mode+[set all directory permissions]:mode' \
  '*-p+[specify pseudo file definition]:pseudo definition' \
  '-pf+[read pseudo file definitions from file]:file:_files' \
  '-pd+[default pseudo directory]:def' \
  '-sort+[read sort order from file]:sort file:_files' \
  '-ef+[read exclude patterns from file]:exclude file:_files' \
  '-wildcards[allow extended shell wildcards in exclude dirs]' \
  '-regex[allow POSIX regular expressions in exclude dirs]' \
  '-processors+[set number of compression threads]:number' \
  '-small-readers+[number of small file reader threads]:n' \
  '-block-readers+[number of block file reader threads]:n' \
  '-single-reader[use sequential file reading]' \
  '-throttle+[reduce read speed by percentage]:percent' \
  '-mem+[set memory limit]:size' \
  '-quiet[suppress non-error output]' \
  '-one-file-system[do not cross filesystem boundaries]' \
  '-keep-as-directory[keep source directory as a subdirectory]' \
  '-noappend[do not append to existing filesystem]' \
  '-nopad[do not pad filesystem to 4K multiple]' \
  '-recover+[recover from failed append]:recovery file:_files' \
  '-no-recovery[disable recovery file creation]' \
  '*-action+[execute action on matching files]:action definition' \
  '*-e[exclude files]:exclude pattern' \
  && ret=0

return ret
