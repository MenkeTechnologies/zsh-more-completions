#compdef beszel
# Documentation: https://github.com/henrygd/beszel/blob/main/internal/cmd/hub/hub.go
# Reference accessed: 2026-05-27
# Verified: upstream internal/cmd/hub/hub.go custom subcommands plus inherited PocketBase commands

# Zsh completion for the Beszel hub server.
# Hub is a PocketBase application with two custom subcommands wired in
# (update, health). Standard PocketBase subcommands (serve, migrate,
# superuser, etc.) are inherited from pocketbase.NewWithConfig().

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'serve:start the web server (PocketBase)'
  'migrate:execute database migrations (PocketBase)'
  'superuser:manage superuser accounts (PocketBase)'
  'update:update beszel to the latest version'
  'health:check health of running hub'
  'help:print usage information'
)

_arguments -C \
  '(- *)'{-h,--help}'[print usage information]' \
  '--version[print version information]' \
  '--dir=[path to the data directory]:directory:_files -/' \
  '--encryptionEnv=[env var name holding the database encryption key]:envvar:' \
  '--dev[enable dev mode (verbose logs)]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'beszel subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '--http=[TCP address for the HTTP server]:address:' \
          '--https=[TCP address for the HTTPS server]:address:' \
          '--origins=[CORS allowed domain origins]:origins:' \
          '*::domain:' && ret=0
        ;;
      update)
        _arguments \
          '--china-mirrors[use gh.beszel.dev mirror instead of GitHub]' && ret=0
        ;;
      health)
        _arguments \
          '--url=[base URL of the hub to probe]:url:' && ret=0
        ;;
      superuser)
        local -a superuser_sub
        superuser_sub=(
          'create:create a new superuser account'
          'update:update an existing superuser password'
          'delete:delete a superuser account'
          'upsert:create or update a superuser account'
          'otp:generate a one-time password for a superuser'
          'ips:manage the superuser IP allowlist'
        )
        _describe -t commands 'superuser subcommand' superuser_sub && ret=0
        ;;
      migrate)
        local -a migrate_sub
        migrate_sub=(
          'up:apply pending migrations'
          'down:revert the last applied migrations'
          'create:create a new blank migration file'
          'collections:create a snapshot migration of all collections'
          'history-sync:reset the migration history to match the local files'
        )
        _describe -t commands 'migrate subcommand' migrate_sub && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
