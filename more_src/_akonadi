#compdef akonadi akonadictl
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/akonadictl.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu focal akonadictl(1) manpage. The control binary is
# `akonadictl`, not bare `akonadi`. This completion accepts the alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# akonadi/akonadictl: KDE PIM data storage server control
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'start:start Akonadi server and processes'
  'stop:stop Akonadi server cleanly'
  'restart:restart Akonadi server'
  'status:show status overview'
  'vacuum:vacuum internal storage (slow!)'
  'fsck:check and fix internal storage consistency'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--instance=[Akonadi instance namespace]:instance:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'akonadictl command' commands && ret=0 ;;
esac
return ret
