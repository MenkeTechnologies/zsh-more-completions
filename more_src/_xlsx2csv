#compdef xlsx2csv
# Documentation: https://github.com/dilshod/xlsx2csv
# Reference accessed: 2026-05-21
# Verified: upstream README usage section.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[export all sheets]' \
  '(-c --outputencoding)'{-c,--outputencoding}'=[encoding of output CSV (Python 3 only)]:encoding:' \
  '(-s --sheet)'{-s,--sheet}'=[sheet number to convert, 0 for all]:sheet id:' \
  '(-n --sheetname)'{-n,--sheetname}'=[sheet name to convert]:sheet name:' \
  '(-d --delimiter)'{-d,--delimiter}'=[column delimiter in CSV (tab or x09 for tab)]:delimiter:' \
  '(-l --lineterminator)'{-l,--lineterminator}'=[line terminator (\n \r\n or \r)]:terminator:' \
  '(-f --dateformat)'{-f,--dateformat}'=[override date/time format]:format:' \
  '--floatformat=[override float format]:format:' \
  '(-i --ignoreempty)'{-i,--ignoreempty}'[skip empty lines]' \
  '(-e --escape)'{-e,--escape}'[escape \\r\\n\\t characters]' \
  '(-p --sheetdelimiter)'{-p,--sheetdelimiter}'=[sheet delimiter between sheets]:delimiter:' \
  '(-q --quoting)'{-q,--quoting}'=[field quoting]:style:(none minimal nonnumeric all)' \
  '--hyperlinks[include hyperlinks]' \
  '(-I --include_sheet_pattern)'{-I,--include_sheet_pattern}'=[include sheets matching pattern (with -a)]:pattern:' \
  '(-E --exclude_sheet_pattern)'{-E,--exclude_sheet_pattern}'=[exclude sheets matching pattern (with -a)]:pattern:' \
  '(-m --merge-cells)'{-m,--merge-cells}'[merge cells]' \
  '1:input xlsx file:_files -g "*.xlsx"' \
  '2::output csv file:_files -g "*.csv"' && ret=0

return ret
