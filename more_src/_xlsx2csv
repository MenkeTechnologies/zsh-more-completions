#compdef xlsx2csv
# Documentation: https://man.archlinux.org/search?q=xlsx2csv
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --delimiter)'{-d,--delimiter}'=[delimiter]:delimiter:' \
  '(-s --sheet)'{-s,--sheet}'=[sheet number or name]:sheet:' \
  '(-a --all)'{-a,--all}'[export all sheets]' \
  '(-p --sheetdelimiter)'{-p,--sheetdelimiter}'=[sheet delimiter]:delimiter:' \
  '(-n --sheetname)'{-n,--sheetname}'[prepend sheet name to output]' \
  '(-f --dateformat)'{-f,--dateformat}'=[date format]:format:' \
  '(-t --timeformat)'{-t,--timeformat}'=[time format]:format:' \
  '(-F --floatformat)'{-F,--floatformat}'=[float format]:format:' \
  '(-q --quoting)'{-q,--quoting}'=[quoting style]:style:(minimal all nonnumeric none)' \
  '--no-header[skip header row]' \
  '--hyperlinks[include hyperlinks]' \
  '(-I --include-sheet-pattern)'{-I,--include-sheet-pattern}'=[include sheets matching pattern]:pattern:' \
  '(-E --exclude-sheet-pattern)'{-E,--exclude-sheet-pattern}'=[exclude sheets matching pattern]:pattern:' \
  '--merge-cells[merge cells]' \
  '--skip-empty-lines[skip empty lines]' \
  '(-e --escape)'{-e,--escape}'=[escape character]:char:' \
  '(-l --lineterminator)'{-l,--lineterminator}'=[line terminator]:terminator:' \
  '--ignoreempty[ignore empty cells]' \
  '1:input xlsx file:_files -g "*.xlsx"' \
  '2::output csv file:_files -g "*.csv"' && ret=0

return ret
