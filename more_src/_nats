#compdef nats

# Zsh completion for nats (NATS CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'account:manage accounts'
  'auth:manage authentication and authorization'
  'bench:benchmark NATS'
  'cheat:view cheat sheets'
  'consumer:manage JetStream consumers'
  'context:manage nats configuration contexts'
  'errors:show NATS error codes'
  'events:show server events'
  'governor:manage concurrency governors'
  'kv:manage KV stores'
  'latency:perform latency testing'
  'object:manage Object Stores'
  'pub:publish a message'
  'reply:reply to requests'
  'request:send a request'
  'rtt:compute round trip time'
  'server:manage NATS servers'
  'stream:manage JetStream streams'
  'sub:subscribe to a subject'
)

_arguments -s -S \
  '(-s --server)'{-s,--server}'[NATS server URL]:url:' \
  '--user[username]:user:' \
  '--password[password]:password:' \
  '--creds[user credentials file]:file:_files' \
  '--nkey[user nkey seed file]:file:_files' \
  '--tlscert[TLS client certificate]:file:_files' \
  '--tlskey[TLS client key]:file:_files' \
  '--tlsca[TLS CA certificate]:file:_files' \
  '--timeout[connection timeout]:timeout:' \
  '--context[configuration context]:context:' \
  '--js-api-prefix[JetStream API prefix]:prefix:' \
  '--js-domain[JetStream domain]:domain:' \
  '--inbox-prefix[custom inbox prefix]:prefix:' \
  '--trace[enable protocol trace]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nats command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (pub)
        _arguments \
          '(-H --header)'{-H,--header}'[add a header]:key\:value:' \
          '--count[publish N messages]:count:' \
          '--reply[set reply subject]:subject:' \
          '--sleep[sleep between messages]:duration:' \
          '1:subject:' '2:message:' && ret=0
        ;;
      (sub)
        _arguments \
          '--queue[queue group name]:group:' \
          '--raw[show raw data]' \
          '--count[receive N messages and exit]:count:' \
          '--dump[dump messages to directory]:dir:_files -/' \
          '1:subject:' && ret=0
        ;;
      (request)
        _arguments \
          '(-H --header)'{-H,--header}'[add a header]:key\:value:' \
          '--count[send N requests]:count:' \
          '--timeout[request timeout]:timeout:' \
          '--raw[show raw data]' \
          '1:subject:' '2:body:' && ret=0
        ;;
      (stream)
        local -a stream_cmds=(
          'add:create a stream'
          'copy:copy a stream'
          'edit:edit a stream'
          'find:find a stream for a subject'
          'get:get a specific message'
          'info:show stream info'
          'ls:list streams'
          'purge:purge a stream'
          'rm:remove a stream'
          'report:report on stream status'
          'seal:seal a stream'
          'view:view messages in a stream'
        )
        _arguments '1:stream command:((${(j: :)${stream_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (consumer)
        local -a consumer_cmds=(
          'add:create a consumer'
          'copy:copy a consumer'
          'edit:edit a consumer'
          'info:show consumer info'
          'ls:list consumers'
          'next:get next message'
          'rm:remove a consumer'
          'report:report on consumers'
          'sub:subscribe through a consumer'
        )
        _arguments '1:consumer command:((${(j: :)${consumer_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (kv)
        local -a kv_cmds=(
          'add:add a KV store'
          'compact:compact a KV store'
          'del:delete a key'
          'get:get a value'
          'history:show key history'
          'ls:list keys or stores'
          'purge:purge a key'
          'put:put a value'
          'rm:remove a KV store'
          'status:show KV store status'
          'watch:watch for changes'
        )
        _arguments '1:kv command:((${(j: :)${kv_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
      (context)
        local -a ctx_cmds=(
          'edit:edit a context'
          'ls:list contexts'
          'rm:remove a context'
          'save:save a context'
          'select:select a context'
          'show:show a context'
          'validate:validate a context'
        )
        _arguments '1:context command:((${(j: :)${ctx_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
