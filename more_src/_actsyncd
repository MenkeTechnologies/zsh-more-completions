#compdef actsyncd
# Documentation: man actsyncd(8)
# Source: InterNetNews/inn backends/actsyncd.in — daemon driver for actsync (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-x -r)-x[deprecated, ignored]' \
    '(-x -r)-r[deprecated, ignored]' \
    '1:config file:_files' \
    '2::debug level:_default' \
    '3::debug output format:_default' \
    && ret=0

return ret
