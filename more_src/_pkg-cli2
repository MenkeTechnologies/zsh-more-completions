#compdef pkg-cli2 pkg2
# _pkg-cli2 — FreeBSD Project pkg-cli2 CLI command-line frontend wrapping the pkg the next-generation replacement for the FreeBSD pkg_install pkg_add pkg_create pkg_info pkg_delete utilities open-source written in C originally Baptiste Daroussin Jonathan Yardley now FreeBSD Project the package manager for FreeBSD DragonFlyBSD HardenedBSD pkg pkgng install delete remove search info list register lock unlock update upgrade rquery audit annotate add fetch which clean check repo bootstrap stats backup remote help unlock register repositories audit (FreeBSD Baptiste Daroussin Jonathan Yardley, C); custom argparse
# upstream: https://www.freebsd.org/cgi/man.cgi?pkg(8)

_pkg-cli2() {
    local -a sub=(
        'install:install packages'
        'remove:remove packages'
        'delete:delete packages'
        'search:search for packages'
        'info:display package info'
        'add:install from file'
        'fetch:fetch packages'
        'audit:audit installed packages'
        'autoremove:remove orphan packages'
        'annotate:annotate packages'
        'backup:backup local DB'
        'bootstrap:bootstrap pkg'
        'check:check installed packages'
        'clean:clean cache'
        'config:display config'
        'create:create binary package'
        'help:show help'
        'lock:lock packages'
        'unlock:unlock packages'
        'plugins:list plugins'
        'query:query database'
        'register:register a package'
        'repo:create a repo'
        'repositories:list repos'
        'rquery:query remote DB'
        'set:modify info on installed package'
        'shell:open SQLite shell'
        'shlib:show binaries linking lib'
        'stats:show stats'
        'triggers:trigger pkg'
        'update:update remote DB'
        'updating:show updating notices'
        'upgrade:upgrade packages'
        'version:show version compare'
        'which:show package providing file'
        'cleanup:cleanup'
        'alias:list/run alias'
        'audit-utils:audit utilities'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-l[show short URL]' \
        '--list[list]' \
        '-N[non-installed]' \
        '-N[just print package name]' \
        '-c+[chroot]:dir:_files -/' \
        '--chroot=+[dir]:dir:_files -/' \
        '-r+[root]:dir:_files -/' \
        '--rootdir=+[dir]:dir:_files -/' \
        '-C+[config file]:file:_files -g "pkg.conf *.conf"' \
        '--config=+[file]:file:_files -g "pkg.conf *.conf"' \
        '-R+[repo conf dir]:dir:_files -/' \
        '--repo-conf-dir=+[dir]:dir:_files -/' \
        '-j+[jail]:str:' \
        '--jail=+[name]:str:' \
        '-o+[option]:str:' \
        '*-o+[option]:str:' \
        '--option=+[opt]:str:' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-y[no confirm]' \
        '--yes[no confirm]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-f[force]' \
        '--force[force]' \
        '-r+[repo]:str:' \
        '--repository=+[name]:str:' \
        '-U[no update]' \
        '--no-repo-update[no repo update]' \
        '-A[automatic]' \
        '-M[manual]' \
        '-a[all]' \
        '--all[all]' \
        '-x[regex]' \
        '--regex[regex]' \
        '-g[glob]' \
        '--glob[glob]' \
        '-i[case-insensitive]' \
        '-D[show dependent]' \
        '-d[show deps]' \
        '-r[recursive]' \
        '-e[exact]' \
        '-l[list files]' \
        '-s[show size]' \
        '-p[show prefix]' \
        '-O[show by origin]' \
        '-G[origin glob]' \
        '-X[XML output]' \
        '-S+[search by]:s:(Comment Description Maintainer Name Origin Pkg-name Description Comment Maintainer Origin Pkg-name)' \
        '--search-by=+[s]:s:(Comment Description Maintainer Name Origin Pkg-name)' \
        '-L+[label]:str:' \
        '--label=+[name]:str:' \
        '--show-dependency-name=+[n]:str:' \
        '-I[case-insensitive]' \
        '-Q+[query]:str:' \
        '--query=+[q]:str:' \
        '-F[force update]' \
        '-N[no install scripts]' \
        '--no-scripts[no scripts]' \
        '--accept-licenses[accept licenses]' \
        '--regex-flag=+[flag]:str:' \
        '--repo-conf-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pkg subcommand' sub ;;
        args) _arguments '*:package:' ;;
    esac
}

_pkg-cli2 "$@"
