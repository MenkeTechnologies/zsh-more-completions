#compdef 7z 7za 7zr
# Documentation: https://manpages.debian.org/7z.1
# Source: 7-Zip — high-ratio archiver (7za is the standalone; 7zr handles only 7z format).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'a:add files to archive'
            'b:benchmark'
            'd:delete files from archive'
            'e:extract files (without directory names)'
            'h:calculate hash values'
            'l:list archive contents'
            't:test archive integrity'
            'u:update files in archive'
            'x:extract files with full paths'
            'rn:rename files in archive'
            'i:show information about supported formats'
        )
        _describe -t subcmds '7z command' subcmds && ret=0
        ;;
    args)
        _arguments \
            '-y[assume Yes on all queries]' \
            '-bd[disable progress indicator]' \
            '-p[set password]:password:' \
            '-mx0[no compression (store only)]' \
            '-mx1[fastest compression]' \
            '-mx3[fast compression]' \
            '-mx5[normal compression]' \
            '-mx7[maximum compression]' \
            '-mx9[ultra compression]' \
            '-mhe=on[encrypt headers (7z format)]' \
            '-ms=on[solid archive]' \
            '-ms=off[non-solid archive]' \
            '-m0=[compression method]:method:(LZMA LZMA2 PPMd BZip2 Deflate Deflate64 Copy)' \
            '-t[archive type]:type:(7z zip gzip bzip2 tar xz wim swfc rar arj cab chm cpio cramfs deb dmg fat hfs iso lzh lzma mbr mslz nsis ntfs ppmd qcow rpm split squashfs udf vdi vhd vmdk xar z 001)' \
            '-an[disable archive_name field]' \
            '*-i[include filenames]:filter:' \
            '*-x[exclude filenames]:filter:' \
            '-bb=-[output log level]:level:(0 1 2 3)' \
            '-bs[output stream]:spec:' \
            '-sdel[delete source files after compression]' \
            '-snh[store hard links]' \
            '-snl[store symbolic links]' \
            '-stl[set timestamp of archive from latest file]' \
            '-spd[disable wildcard matching for file names]' \
            '-spe[eliminate duplication of root folder for extract]' \
            '-spf[use fully qualified file paths]' \
            '-sse[stop archive if rename failed]' \
            '-ssp[do not change last access time]' \
            '-ssw[compress files open for writing]' \
            '-r[recurse subdirectories]' \
            '-w[set working directory]:dir:_directories' \
            '*:archive then files:_files' \
            && ret=0
        ;;
esac

return ret
