#compdef unshadow ssh2john keepass2john 7z2john bitcoin2john pdf2john keychain2john keystore2john bitwarden2john htdigest2john monero2john
# Documentation: https://github.com/openwall/john (bleeding-jumbo branch)
#                — sources read directly from src/*.c and run/*.py / run/*.pl
# Reference accessed: 2026-05-30
# John the Ripper companion utilities — the *2john + unshadow helper
# family. Each tool reads an input file (or two, for unshadow) and writes
# a JtR-compatible hash to stdout. Companion to existing _john + _zip2john
# coverage. Surfaces verified by reading the upstream source for each tool
# rather than the (unreliable) Debian dyn-redirect manpages.

local curcontext="$curcontext" state line ret=1

case $service in

  unshadow)
    # src/unshadow.c — strict 2-positional form:
    #   unshadow PASSWORD-FILE SHADOW-FILE
    _arguments -s -S \
      '1:passwd file:_files' \
      '2:shadow file:_files' \
      && ret=0
    ;;

  ssh2john)
    # run/ssh2john.py — 1+ private key files, no flags.
    # Accepts RSA / DSA / EC / OpenSSH key formats.
    _arguments -s -S \
      '*:RSA/DSA/EC/OpenSSH private key file:_files' \
      && ret=0
    ;;

  keepass2john)
    # src/keepass2john.c — optional -k keyfile + 1+ .kdbx databases.
    _arguments -s -S \
      '-k+[optional keyfile]:keyfile:_files' \
      '*:KeePass database file:_files -g "*.kdbx"' \
      && ret=0
    ;;

  7z2john)
    # run/7z2john.pl — single flag --skip-sensitive-data-warning,
    # 1+ 7-Zip files.
    _arguments -s -S \
      '--skip-sensitive-data-warning[suppress sensitive-data warning]' \
      '*:7-Zip archive file:_files -g "*.(7z|cb7)"' \
      && ret=0
    ;;

  bitcoin2john)
    # run/bitcoin2john.py — 1+ wallet .dat files, no flags.
    # Supports Bitcoin / Litecoin / PRiVCY wallets.
    _arguments -s -S \
      '*:Bitcoin/Litecoin/PRiVCY wallet file:_files -g "*.dat"' \
      && ret=0
    ;;

  pdf2john)
    # run/pdf2john.pl — wrapper around ExifTool; canonical usage is just
    # 1+ PDF input files (the wrapper exposes ExifTool's flag surface
    # but that is not part of the documented contract).
    _arguments -s -S \
      '*:PDF file:_files -g "*.pdf"' \
      && ret=0
    ;;

  keychain2john)
    # run/keychain2john.py — 1+ macOS keychain files, no flags.
    _arguments -s -S \
      '*:macOS keychain file:_files -g "*.keychain*"' \
      && ret=0
    ;;

  keystore2john)
    # run/keystore2john.py — 1+ .keystore or .jks files, no flags.
    _arguments -s -S \
      '*:Java KeyStore file:_files -g "*.(keystore|jks)"' \
      && ret=0
    ;;

  bitwarden2john)
    # run/bitwarden2john.py — 1+ files/paths, no flags.
    # Accepts storage.js (Firefox), bitwarden_preferences.xml (Android),
    # or a Chrome LevelDB directory path.
    _arguments -s -S \
      '*:Bitwarden vault file or LevelDB dir:_files' \
      && ret=0
    ;;

  htdigest2john)
    # run/htdigest2john.py — 1+ Apache htdigest files, no flags.
    _arguments -s -S \
      '*:htdigest file:_files' \
      && ret=0
    ;;

  monero2john)
    # run/monero2john.py — 1+ Monero wallet .keys files, no flags.
    _arguments -s -S \
      '*:Monero .keys file:_files -g "*.keys"' \
      && ret=0
    ;;

esac

return ret
