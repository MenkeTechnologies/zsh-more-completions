#compdef lerna-cli2 lerna2
# _lerna-cli2 — Nrwl Lerna lerna-cli2 CLI command-line frontend wrapping the Lerna fast modern build system for managing and publishing multiple JavaScript TypeScript packages from the same repository originally by Sebastian McKenzie now Nrwl now Nx open-source written in TypeScript Node monorepo tool publish version add bootstrap clean changed create diff exec import info init list ls publish run watch link run-script create-pr add-caching repair info help completion (Nrwl Lerna team Sebastian McKenzie, TypeScript); commander
# upstream: https://lerna.js.org/

_lerna-cli2() {
    local -a sub=(
        'add:add a dep to packages'
        'add-caching:enable Nx caching'
        'bootstrap:install deps and link'
        'changed:list changed packages'
        'clean:remove node_modules'
        'completion:generate shell completion'
        'create:create a new package'
        'diff:diff packages'
        'exec:exec a command'
        'help:show help'
        'import:import external package'
        'info:show env info'
        'init:initialize Lerna repo'
        'link:symlink local packages'
        'list:list packages'
        'ls:list packages (alias)'
        'publish:publish packages'
        'repair:auto repair'
        'run:run a script'
        'version:bump versions'
        'watch:watch packages'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--loglevel=+[l]:l:(silly verbose info success warn error silent)' \
        '--concurrency=+[N]:n:' \
        '--no-progress[no progress]' \
        '--reject-cycles[reject cycles]' \
        '--include-dependencies[include deps]' \
        '--include-dependents[include dependents]' \
        '--no-sort[no sort]' \
        '--stream[stream output]' \
        '--parallel[parallel]' \
        '--ci[CI mode]' \
        '--no-git-tag-version[no git tag]' \
        '--no-push[no push]' \
        '--push[push to remote]' \
        '--git-remote=+[name]:str:' \
        '--git-tag-version[git tag version]' \
        '--message=+[text]:str:' \
        '-m+[message]:str:' \
        '--sign[sign git commit]' \
        '--sign-git-commit[sign git commit]' \
        '--sign-git-tag[sign git tag]' \
        '--exact[exact version]' \
        '--allow-branch=+[glob]:str:' \
        '*--allow-branch=+[glob]:str:' \
        '--changelog-preset=+[name]:str:' \
        '--conventional-commits[conventional commits]' \
        '--conventional-graduate=+[v]:str:' \
        '--conventional-prerelease=+[v]:str:' \
        '--conventional-bump-prerelease[conv bump prerelease]' \
        '--bump=+[b]:b:(patch minor major premajor preminor prepatch prerelease)' \
        '--exact-publish[exact publish]' \
        '--legacy-auth=+[token]:str:' \
        '--no-private[no private]' \
        '--otp=+[code]:str:' \
        '--preid=+[id]:str:' \
        '--registry=+[url]:str:' \
        '--tag-version-prefix=+[prefix]:str:' \
        '--no-commit-hooks[no commit hooks]' \
        '--no-changelog[no changelog]' \
        '--commit-hooks[commit hooks]' \
        '--changelog[changelog]' \
        '--canary[canary release]' \
        '--dist-tag=+[name]:str:' \
        '--scope=+[glob]:str:' \
        '*--scope=+[glob]:str:' \
        '--ignore=+[glob]:str:' \
        '*--ignore=+[glob]:str:' \
        '--since=+[ref]:str:' \
        '--include-merged-tags[include merged tags]' \
        '--force-publish=+[names]:str:' \
        '--no-private[no private]' \
        '--no-verify-access[no verify access]' \
        '--graph-type=+[t]:t:(all dependencies)' \
        '--toposort[topological sort]' \
        '--json[JSON output]' \
        '--ndjson[NDJSON output]' \
        '--all[all packages]' \
        '-a[all]' \
        '--long[long info]' \
        '-l[long]' \
        '--no-bail[no bail]' \
        '--bail[bail on error]' \
        '--dev[dev dependency]' \
        '-D[dev dep]' \
        '--peer[peer dependency]' \
        '-P[peer dep]' \
        '--exact[exact version]' \
        '-E[exact]' \
        '--registry=+[url]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lerna subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments '*:script:' ;;
                exec) _arguments '*:cmd:_command_names' ;;
                add) _arguments '*:package:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                create) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_lerna-cli2 "$@"
