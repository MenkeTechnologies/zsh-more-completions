#compdef cairo-run
# Documentation: https://github.com/starkware-libs/cairo/tree/main/crates/bin/cairo-run
# Source: starkware-libs/cairo crates/bin/cairo-run/src/main.rs — compile and run a Cairo program.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-s --single-file)'{-s,--single-file}'[treat path as a single file]' \
    '--allow-warnings[allow compilation to succeed with warnings]' \
    '--available-gas=[amount of provided gas]:n:_default' \
    '--print-full-memory[print the full memory]' \
    '--run-profiler[run the profiler]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:path:_files' \
    && ret=0

return ret
