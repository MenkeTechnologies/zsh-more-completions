#compdef stem
# Python Tor network controller and descriptor CLI

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--tor-path[path to tor binary]:path:_files' \
  '--control-port[tor control port]:port:' \
  '--control-socket[tor control socket]:socket:_files' \
  && return 0
