#compdef regions-dump
# _regions-dump — TiKV PD region metadata exporter
# upstream: https://github.com/tikv/pd
# Flags from tools/regions-dump/main.go on tip.

_regions-dump() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-cluster-id=[cluster ID (must match TiKV)]:n:' \
        '-endpoints=[etcd endpoints (csv of URLs)]:csv:' \
        '-start-id=[ID of the first region]:n:' \
        '-end-id=[ID of the last region]:n:' \
        '-file=[dump file path]:file:_files' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files'
}

_regions-dump "$@"
