#compdef nsqadmin
# Documentation: https://nsq.io/components/nsqadmin.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-acl-http-header=[HTTP header to check for authenticated admin users]:header:'
  '*-admin-user=[admin user (repeatable)]:user:'
  '-allow-config-from-cidr=[CIDR for allowed /config sources]:cidr:'
  '-base-path=[URL base path]:path:'
  '-config=[path to config file]:file:_files'
  '-graphite-url=[graphite HTTP address]:url:'
  '-http-address=[address to listen on]:address:'
  '-http-client-connect-timeout=[HTTP client connect timeout]:duration:'
  '-http-client-request-timeout=[HTTP client request timeout]:duration:'
  '-http-client-tls-cert=[HTTP client TLS cert]:file:_files'
  '-http-client-tls-insecure-skip-verify[skip TLS verification for HTTP client]'
  '-http-client-tls-key=[HTTP client TLS key]:file:_files'
  '-http-client-tls-root-ca-file=[HTTP client TLS root CA file]:file:_files'
  '-log-level=[log level]:level:(debug info warn error fatal)'
  '-log-prefix=[log message prefix]:prefix:'
  '*-lookupd-http-address=[address of lookupd HTTP (repeatable)]:address:'
  '-notification-http-endpoint=[HTTP endpoint for action notifications]:url:'
  '*-nsqd-http-address=[address of nsqd HTTP (repeatable)]:address:'
  '-proxy-graphite[proxy graphite requests]'
  '-statsd-counter-format=[statsd counter format]:format:'
  '-statsd-gauge-format=[statsd gauge format]:format:'
  '-statsd-interval=[statsd push interval]:duration:'
  '-statsd-prefix=[statsd prefix]:prefix:'
  '-verbose[deprecated; use -log-level]'
  '-version[print version string]'
)

_arguments -s -S $arguments
