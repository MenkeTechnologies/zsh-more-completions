#compdef connect-mirror-maker connect-mirror-maker.sh
# Documentation: https://github.com/apache/kafka/blob/trunk/bin/connect-mirror-maker.sh
# Reference accessed: 2026-05-17
# Verified: upstream Apache Kafka script at the URL above. Supports -daemon,
# --clusters, and forwards -name/-loggingdir through to kafka-run-class.sh.

local -a arguments

arguments=(
    '-daemon[Run as daemon]'
    '-name[Connector name]:name'
    '-loggingdir[Logging directory]:dir:_directories'
    '--clusters[Cluster aliases]:clusters'
    '*:properties file:_files -g "*.properties"'
)

_arguments -s -S $arguments
