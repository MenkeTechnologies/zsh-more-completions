#compdef gmid

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[specify configuration file]:config file:_files' \
  '-D+[define macro]:macro=value:' \
  '-f[do not daemonize, stay in foreground]' \
  '-h[display help message]' \
  '-n[check configuration syntax and exit]' \
  '-P+[create PID file]:pid file:_files' \
  '-T[test configuration and report errors]' \
  '-v[verbose logging]' \
  '-V[display version information]' \
  && ret=0

return ret
