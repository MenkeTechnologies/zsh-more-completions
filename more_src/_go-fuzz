#compdef go-fuzz go-fuzz-build
# Documentation: source-direct extraction from upstream
# dvyukov/go-fuzz `go-fuzz/main.go` + `go-fuzz-build/main.go`
# Go `flag.<Type>(name, default, usage)` declarations at the top
# of each main.go.
# Reference accessed: 2026-05-30 via gh api.
# dvyukov go-fuzz R160a — 2-stem multi-binary harvest of the
# go-fuzz fuzzer pair: `go-fuzz-build` instruments + builds the
# fuzz target binary, then `go-fuzz` orchestrates the fuzzing
# loop (coordinator/worker) against that binary.  Sister to the
# heavily-covered fuzzing family (afl-fuzz/afl-cc/afl-tmin/
# afl-showmap/afl-analyze/honggfuzz/sancov) in the corpus.

case $service in

  go-fuzz)
    _arguments -s -S \
      '-workdir=[directory with persistent work data (default .)]:dir:_files -/' \
      '-procs=[parallelism level (default NumCPU)]:n:' \
      '-timeout=[test timeout in seconds (default 10)]:sec:' \
      '-minimize=[time limit for input minimization (default 1m)]:duration:' \
      '-coordinator=[coordinator mode (value = coordinator address)]:addr:' \
      '-worker=[worker mode (value = coordinator address)]:addr:' \
      '-connectiontimeout=[worker connect-to-coordinator timeout (default 1m)]:duration:' \
      '-bin=[test binary built with go-fuzz-build]:bin:_files' \
      '-func=[function to fuzz]:func:' \
      '-dumpcover[dump coverage profile into workdir]' \
      '-dup[collect duplicate crashers]' \
      '-testoutput[print test-binary stdout (debug only)]' \
      '-covercounters=[use coverage hit counters (default true)]:bool:(true false)' \
      '-sonar=[use sonar hints (default true)]:bool:(true false)' \
      '-v=[verbosity level]:n:' \
      '-http=[HTTP server listen address (coordinator only)]:addr:'
    ;;

  go-fuzz-build)
    _arguments -s -S \
      '-tags=[space-separated build tags to consider satisfied]:tags:' \
      '-o=[output file]:file:_files' \
      '-func=[preferred entry function]:func:' \
      '-work[do not remove working directory]' \
      '-race[enable the race detector]' \
      '-cpuprofile[generate CPU profile in cpu.pprof]' \
      '-libfuzzer[output static archive for use with libFuzzer]' \
      '-x[print the commands if build fails]' \
      '-preserve=[comma-separated import paths NOT to instrument]:paths:' \
      '-go=[path to the go command (default "go")]:cmd:_command_names -e' \
      '*:package:'
    ;;

esac
