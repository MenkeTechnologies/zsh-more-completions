#compdef nixglhost
# Documentation: https://github.com/numtide/nix-gl-host
# expose the host OpenGL/CUDA drivers to a Nix-built program

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --driver-directory)'{-d,--driver-directory}'[explicit driver libraries directory]:dir:_files -/' \
  '(-p --print-ld-library-path)'{-p,--print-ld-library-path}'[print the LD_LIBRARY_PATH and exit]' \
  '*:::command:_command_names -e' && ret=0

return ret
