#compdef depcruise-baseline
# _depcruise-baseline — record dependency-cruiser baseline violations (sverweij/dependency-cruiser)
# upstream: https://github.com/sverweij/dependency-cruiser
# Flags from bin/depcruise-baseline.mjs (parseArgs).

_depcruise-baseline() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[rules config file]:file:_files -g "*.(js|cjs|mjs|json)"' \
        '(-f --output-to)'{-f+,--output-to=}'[baseline output JSON file]:file:_files -g "*.json"' \
        '*:file or directory:_files'
}

_depcruise-baseline "$@"
