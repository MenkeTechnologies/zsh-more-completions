#compdef tikv-controller-manager
# _tikv-controller-manager — TiKV Operator controller manager
# upstream: https://github.com/tikv/tikv-operator
# Flags from cmd/tikv-controller-manager/app/app.go on tip.

_tikv-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--workers=[concurrent worker count]:n:' \
        '--auto-failover=[enable auto-failover]:bool:(true false)' \
        '--pd-discovery-image=[PD discovery image]:image:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_tikv-controller-manager "$@"
