#compdef gp2c-dbg
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/gp2c-dbg.1.html
# PARI/GP to C debugger driver (passes options through to gp2c)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[output version information and exit]' \
  '-o+[place output in file]:output file:_files' \
  '-p+[prefix user-defined symbols to avoid conflict]:prefix:' \
  '-s+[add suffix to GP install names of functions]:suffix:' \
  '-g[generate automatic garbage collection code]' \
  '-i+[set indentation level to N spaces]:spaces:' \
  '-W[output warning about types and global variable usage]' \
  '-C[generate range checking code]' \
  '-L[generate #line directives for better C compiler messages]' \
  '-S[assume strict declarations for functions]' \
  '-f[dump information about functions to stderr]' \
  '-l[output the list of functions known to the compiler]' \
  '-t[output the table of types known to the compiler]' \
  '-d[increase debugging level]' \
  '-y[switch parser to debug mode]' \
  '-T[output syntactic tree in treetool format]' \
  '-G[generate GP code in place of C code]' \
  '-V[do not clean up variables]' \
  '*:GP or C file:_files -g "*.(gp|c)"' && ret=0

return ret
