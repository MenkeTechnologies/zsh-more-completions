#compdef memray

# Zsh completion for memray - Python memory profiler

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run a Python script and track memory allocations'
  'flamegraph:generate a flame graph from a capture file'
  'table:generate a table report from a capture file'
  'tree:generate a tree report from a capture file'
  'stats:generate high-level stats from a capture file'
  'summary:generate a summary report from a capture file'
  'transform:transform a capture file to another format'
  'parse:debug a capture file'
  'attach:attach to a running process'
  'detach:detach from a process being tracked'
  'live:run a script with a live TUI'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'memray command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for capture data]:file:_files' \
          '--live[show a live TUI during tracking]' \
          '--live-remote[enable live mode with remote connection]' \
          '--live-port=[port for live TUI]:port' \
          '--native[track native C/C++ stack frames]' \
          '--follow-fork[follow child processes after fork]' \
          '--trace-python-allocators[record allocations from Python allocators]' \
          '-q[suppress memray output during tracking]' \
          '--force[overwrite existing output file]' \
          '--aggregate[aggregate results on the fly]' \
          '-c[program string to run]:command string' \
          '-m[run library module as a script]:module' \
          '*:script:_files -g "*.py"' && ret=0
        ;;
      (flamegraph)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for HTML]:file:_files' \
          '--leaks[show only memory leaks]' \
          '--split-threads[generate one flame graph per thread]' \
          '--temporary-allocation-threshold=[threshold for temporary allocations]:count' \
          '--temporary-allocations[show only temporary allocations]' \
          '--inverted[invert flame graph]' \
          '--force[overwrite existing output file]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (table)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for HTML]:file:_files' \
          '--leaks[show only memory leaks]' \
          '--temporary-allocation-threshold=[threshold for temporary allocations]:count' \
          '--temporary-allocations[show only temporary allocations]' \
          '--force[overwrite existing output file]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (tree)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for HTML]:file:_files' \
          '--leaks[show only memory leaks]' \
          '--temporary-allocation-threshold=[threshold for temporary allocations]:count' \
          '--temporary-allocations[show only temporary allocations]' \
          '--biggest-allocs=[number of biggest allocations to show]:count' \
          '--force[overwrite existing output file]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (stats)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (summary)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for HTML]:file:_files' \
          '--force[overwrite existing output file]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (attach)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file for capture data]:file:_files' \
          '--native[track native C/C++ stack frames]' \
          '--trace-python-allocators[record allocations from Python allocators]' \
          '--aggregate[aggregate results on the fly]' \
          '--force[overwrite existing output file]' \
          '1:process ID:_pids' && ret=0
        ;;
      (detach)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:process ID:_pids' && ret=0
        ;;
      (live)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--native[track native C/C++ stack frames]' \
          '--follow-fork[follow child processes after fork]' \
          '--trace-python-allocators[record allocations from Python allocators]' \
          '-c[program string to run]:command string' \
          '-m[run library module as a script]:module' \
          '*:script:_files -g "*.py"' && ret=0
        ;;
      (transform)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output file]:file:_files' \
          '--format=[output format]:format:(csv)' \
          '--force[overwrite existing output file]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
      (parse)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:capture file:_files -g "*.bin"' && ret=0
        ;;
    esac
    ;;
esac

return ret
