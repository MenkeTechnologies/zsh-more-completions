#compdef cpufreq-set
# Documentation: https://manpages.debian.org/bookworm/cpufrequtils/cpufreq-set.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Linux cpufrequtils cpufreq-set CPU frequency scaling setter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --cpu)'{-c,--cpu}'[specify CPU number]:cpu number:' \
  '(-d --min)'{-d,--min}'[set minimum CPU frequency]:frequency:' \
  '(-u --max)'{-u,--max}'[set maximum CPU frequency]:frequency:' \
  '(-g --governor)'{-g,--governor}'[set cpufreq governor]:governor:(performance powersave userspace ondemand conservative schedutil)' \
  '(-f --freq)'{-f,--freq}'[set specific CPU frequency]:frequency:' \
  '(-r --related)'{-r,--related}'[also set frequency for related CPUs]'
