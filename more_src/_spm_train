#compdef spm_train
# Documentation: https://github.com/google/sentencepiece/blob/master/doc/options.md
# SentencePiece unsupervised tokenizer trainer

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--input=[comma-separated list of input text files]:files:_files' \
  '--input_format=[input format]:format:(text tsv)' \
  '--model_prefix=[output model prefix]:prefix' \
  '--model_type=[tokenization algorithm]:type:(unigram bpe word char)' \
  '--vocab_size=[desired vocabulary size]:size' \
  '--accept_language=[ISO language codes metadata]:langs' \
  '--num_threads=[number of training threads]:n' \
  '--random_seed=[random number generator seed]:seed' \
  '--minloglevel=[logging verbosity level]:level' \
  '--character_coverage=[character coverage ratio]:ratio' \
  '--input_sentence_size=[max sentences to load]:n' \
  '--shuffle_input_sentence=[randomize sentence sampling]:bool:(true false)' \
  '--hard_vocab_limit=[enforce exact vocabulary size]:bool:(true false)' \
  '--train_extremely_large_corpus=[use 64-bit indices for massive corpora]:bool:(true false)' \
  '*:input file:_files' && ret=0

return ret
