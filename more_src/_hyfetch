#compdef hyfetch

# Zsh completion for HyFetch - neofetch with pride flags

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[color mode]:mode:(8bit 24bit)' \
  '--color=[color mode]:mode:(8bit 24bit)' \
  '-C+[config file]:config:_files' \
  '--config=[config file]:config:_files' \
  '-p+[pride flag preset]:preset:(rainbow transgender nonbinary agender queer bisexual asexual pansexual lesbian gay-men aroace aromantic genderfluid genderqueer polysexual omnisexual demisexual)' \
  '--preset=[pride flag preset]:preset:(rainbow transgender nonbinary agender queer bisexual asexual pansexual lesbian gay-men aroace aromantic genderfluid genderqueer polysexual omnisexual demisexual)' \
  '-m+[color mode]:mode:(rgb ansi 256 none)' \
  '--mode=[color mode]:mode:(rgb ansi 256 none)' \
  '-b+[backend to use]:backend:(neofetch fastfetch)' \
  '--backend=[backend to use]:backend:(neofetch fastfetch)' \
  '--c-overlay[use color overlay]' \
  '--c-set-l=[set lightness]:lightness' \
  '--distro=[override distro detection]:distro' \
  '--ascii-file=[custom ascii art file]:file:_files' \
  '--args=[pass arguments to backend]:args' \
  '--june[show June pride month special]' && ret=0

return ret
