#compdef rz-diff rzdiff
# Documentation: https://man.archlinux.org/search?q=rz-diff
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A[compare virtual<>physical addresses]' \
  '-a+[architecture plugin]:arch:(x86 arm arm64 mips ppc sparc avr msp430 8051 m68k riscv)' \
  '-b+[register size]:bits:(16 32 64)' \
  '-B[run aaa analysis on load]' \
  '-C[disable colored output]' \
  '-d+[edit-distance algorithm]:algo:(myers leven ssdeep)' \
  '*-e+[set evaluable config k=v]:setting:' \
  '-H[hexadecimal visual mode]' \
  '-i[use CLI arguments instead of files (with -d)]' \
  '-j[JSON output]' \
  '-q[minimal output]' \
  '-0+[input for file0 (with -t command)]:cmd:' \
  '-1+[input for file1 (with -t command)]:cmd:' \
  '-S+[terminal size for visual mode]:size (e.g. 120x40):' \
  '-t+[compare by type]:type:(bytes lines functions classes command entries fields graphs imports libraries sections strings symbols)' \
  '-T[show timestamp information]' \
  '-v[verbose output]' \
  '*::file:_files' && ret=0

return ret
