#compdef moonlight moonlight-qt Moonlight
# Documentation: https://github.com/moonlight-stream/moonlight-qt
# Reference accessed: 2026-05-27
# Verified: upstream app/cli/commandlineparser.cpp (GlobalCommandLineParser,
# StreamCommandLineParser, ListCommandLineParser, PairCommandLineParser,
# QuitCommandLineParser) in moonlight-stream/moonlight-qt

local curcontext="$curcontext" state line ret=1

local -a _moon_subcommands
_moon_subcommands=(
  'stream:start streaming an app on a host'
  'list:list the available apps on a host'
  'pair:pair with the specified host'
  'quit:quit the currently running app on the host'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'moonlight action' _moon_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      stream)
        _arguments \
          '--720[1280x720 resolution]' \
          '--1080[1920x1080 resolution]' \
          '--1440[2560x1440 resolution]' \
          '--4K[3840x2160 resolution]' \
          '--resolution=[custom <width>x<height> resolution]:wxh:' \
          '--vsync[enable V-Sync]' \
          '--no-vsync[disable V-Sync]' \
          '--fps=[frames per second (10-480)]:fps:' \
          '--bitrate=[bitrate in Kbps (500-500000)]:kbps:' \
          '--packet-size=[video packet size (>=1024)]:bytes:' \
          '--display-mode=[display mode]:mode:(fullscreen windowed borderless)' \
          '--audio-config=[audio config]:cfg:(stereo 5.1-surround 7.1-surround)' \
          '--multi-controller[enable multiple controller support]' \
          '--no-multi-controller[disable multiple controller support]' \
          '--quit-after[quit app after session]' \
          '--no-quit-after[do not quit app after session]' \
          '--absolute-mouse[remote desktop optimized mouse]' \
          '--no-absolute-mouse[disable absolute mouse]' \
          '--mouse-buttons-swap[swap left and right mouse buttons]' \
          '--no-mouse-buttons-swap[do not swap mouse buttons]' \
          '--touchscreen-trackpad[touchscreen in trackpad mode]' \
          '--no-touchscreen-trackpad[do not use trackpad mode]' \
          '--game-optimization[enable game optimizations]' \
          '--no-game-optimization[disable game optimizations]' \
          '--audio-on-host[play audio on host PC]' \
          '--no-audio-on-host[do not play audio on host PC]' \
          '--frame-pacing[enable frame pacing]' \
          '--no-frame-pacing[disable frame pacing]' \
          '--mute-on-focus-loss[mute audio when window loses focus]' \
          '--no-mute-on-focus-loss[do not mute on focus loss]' \
          '--background-gamepad[allow background gamepad input]' \
          '--no-background-gamepad[disable background gamepad input]' \
          '--reverse-scroll-direction[invert scroll direction]' \
          '--no-reverse-scroll-direction[normal scroll direction]' \
          '--swap-gamepad-buttons[swap A/B and X/Y (Nintendo-style)]' \
          '--no-swap-gamepad-buttons[standard gamepad button layout]' \
          '--keep-awake[prevent display sleep while streaming]' \
          '--no-keep-awake[allow display sleep]' \
          '--performance-overlay[show performance overlay]' \
          '--no-performance-overlay[hide performance overlay]' \
          '--hdr[enable HDR streaming]' \
          '--no-hdr[disable HDR streaming]' \
          '--yuv444[YUV 4:4:4 sampling if supported]' \
          '--no-yuv444[disable YUV 4:4:4]' \
          '--capture-system-keys=[capture system key combos]:mode:(never fullscreen always)' \
          '--video-codec=[video codec]:codec:(auto H.264 HEVC AV1)' \
          '--video-decoder=[video decoder]:decoder:(auto software hardware)' \
          '--help[show stream help]' \
          '--version[show version]' \
          '1:host:_hosts' \
          '2:app:' && ret=0
        ;;
      list)
        _arguments \
          '--csv[print as CSV with additional info]' \
          '--verbose[display additional info]' \
          '--help[show list help]' \
          '--version[show version]' \
          '1:host:_hosts' && ret=0
        ;;
      pair)
        _arguments \
          '--pin=[predefined 4-digit pairing PIN]:pin:' \
          '--help[show pair help]' \
          '--version[show version]' \
          '1:host:_hosts' && ret=0
        ;;
      quit)
        _arguments \
          '--help[show quit help]' \
          '--version[show version]' \
          '1:host:_hosts' && ret=0
        ;;
      *)
        _arguments '*::arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
