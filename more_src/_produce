#compdef produce
# _produce — fastlane produce iOS App Store Connect app creator (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_produce() {
    local -a sub=(
        'create:create app on App Store Connect'
        'group:create app group'
        'associate_group:associate app with group'
        'cloud_container:create iCloud container'
        'associate_cloud_container:associate iCloud container'
        'enable_services:enable services'
        'disable_services:disable services'
        'merchant:create merchant id'
        'associate_merchant:associate merchant id'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--username=+[apple ID username]:str:_users' \
        '-u+[apple ID username]:str:_users' \
        '--app-identifier=+[app identifier]:str:' \
        '-a+[app identifier]:str:' \
        '--bundle-identifier-suffix=+[bundle id suffix]:str:' \
        '-x+[bundle id suffix]:str:' \
        '--app-name=+[app name]:str:' \
        '-q+[app name]:str:' \
        '--app-version=+[app version]:str:' \
        '-z+[app version]:str:' \
        '--sku=+[sku]:str:' \
        '-y+[sku]:str:' \
        '--platform=+[platform]:p:(ios osx tvos)' \
        '-j+[platform]:p:(ios osx tvos)' \
        '--platforms=+[platforms]:list:' \
        '-J+[platforms]:list:' \
        '--language=+[language]:lang:' \
        '-m+[language]:lang:' \
        '--company-name=+[company name]:str:' \
        '-c+[company name]:str:' \
        '--itc-team-id=+[itc team id]:str:' \
        '-k+[itc team id]:str:' \
        '--itc-team-name=+[itc team name]:str:' \
        '-p+[itc team name]:str:' \
        '--team-id=+[team id]:str:' \
        '-b+[team id]:str:' \
        '--team-name=+[team name]:str:' \
        '-l+[team name]:str:' \
        '--skip-itc=+[skip iTunes Connect]:b:(true false)' \
        '-i+[skip iTunes Connect]:b:(true false)' \
        '--itc-users=+[itc users]:list:' \
        '--enabled-features=+[enabled features]:str:' \
        '-e+[enabled features]:str:' \
        '--enable-services=+[enable services]:str:' \
        '-s+[enable services]:str:' \
        '--skip-devcenter=+[skip dev center]:b:(true false)' \
        '-d+[skip dev center]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'produce subcommand' sub ;;
    esac
}

_produce "$@"
