#compdef gimlet

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'environment:manage environments'
  'release:manage releases'
  'artifact:manage artifacts'
  'gitops:GitOps operations'
  'manifest:manage Kubernetes manifests'
  'chart:manage Helm charts'
  'seal:seal secrets'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--server[Gimlet server URL]:url:' \
  '--token[API token]:token:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'gimlet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      manifest)
        _arguments -s -S \
          '1:action:(create template configure lint)' \
          '-f[manifest file]:file:_files -g "*.yaml(|.yml)"' \
          '-o[output file]:file:_files' \
          '--env[environment]:env:' \
          '--app[application]:app:' \
          '--help[show help]' && ret=0
        ;;
      release)
        _arguments -s -S \
          '1:action:(make list status track)' \
          '--env[environment]:env:' \
          '--app[application]:app:' \
          '--artifact[artifact ID]:id:' \
          '--help[show help]' && ret=0
        ;;
      seal)
        _arguments -s -S \
          '-f[manifest file]:file:_files' \
          '-o[output file]:file:_files' \
          '--env[environment]:env:' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
