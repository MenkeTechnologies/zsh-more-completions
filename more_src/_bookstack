#compdef bookstack
# _bookstack — Dan Brown BookStack open-source self-hosted documentation platform artisan CLI (BookStackApp team, PHP/Laravel); symfony console
# upstream: https://github.com/BookStackApp/BookStack

_bookstack() {
    local -a sub=(
        'list:list commands'
        'help:show help for command'
        'about:show framework info'
        'serve:start dev server'
        'tinker:php shell'
        'cache:clear:clear cache'
        'config:cache:cache config'
        'config:clear:clear config cache'
        'route:list:list routes'
        'view:cache:cache views'
        'view:clear:clear view cache'
        'migrate:run migrations'
        'migrate:rollback:rollback migrations'
        'migrate:install:install migrations'
        'migrate:reset:reset migrations'
        'migrate:fresh:wipe and migrate'
        'storage:link:link storage'
        'bookstack:assign-role:assign role to user'
        'bookstack:backup:backup BookStack content'
        'bookstack:cleanup-images:clean unused images'
        'bookstack:cleanup-revisions:cleanup revisions'
        'bookstack:clear-activity:clear activity log'
        'bookstack:clear-views:clear view counts'
        'bookstack:copy-shelf-permissions:copy shelf permissions'
        'bookstack:create-admin:create admin user'
        'bookstack:delete-users:delete users'
        'bookstack:hard-delete-pages:hard delete pages'
        'bookstack:purge-revisions:purge revisions'
        'bookstack:regenerate-references:rebuild references'
        'bookstack:regenerate-search:rebuild search index'
        'bookstack:rotate-app-key:rotate APP_KEY'
        'bookstack:update-url:rewrite URLs'
        'bookstack:reset-mfa:reset MFA'
        'queue:work:process queued jobs'
        'queue:listen:listen to queue'
        'queue:restart:restart workers'
        'schedule:run:run scheduled tasks'
        'passport:install:install oauth keys'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--env=+[environment]:str:' \
        '--no-interaction[no interactive prompts]' \
        '-n[no interactive prompts]' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '--quiet[no output]' \
        '-q[no output]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[debug verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bookstack subcommand' sub ;;
    esac
}

_bookstack "$@"
