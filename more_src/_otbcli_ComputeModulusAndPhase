#compdef otbcli_ComputeModulusAndPhase
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ComputeModulusAndPhase.html
# Orfeo ToolBox: compute modulus and phase of a complex SAR image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input complex or 2-band image]:image:_files' \
  '-modulus[output modulus image]:output:_files' \
  '-phase[output phase image]:output:_files' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
