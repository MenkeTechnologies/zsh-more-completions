#compdef usvg

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--dpi=[set DPI]:dpi' \
  '--languages=[set a comma-separated list of languages]:languages' \
  '--shape-rendering=[set shape rendering mode]:mode:(auto optimizeSpeed crispEdges geometricPrecision)' \
  '--text-rendering=[set text rendering mode]:mode:(auto optimizeSpeed optimizeLegibility geometricPrecision)' \
  '--image-rendering=[set image rendering mode]:mode:(auto optimizeQuality optimizeSpeed)' \
  '--resources-dir=[directory with fonts and images]:directory:_directories' \
  '--font-family=[set the default font family]:family' \
  '--font-size=[set the default font size]:size' \
  '--serif-family=[set the serif font family]:family' \
  '--sans-serif-family=[set the sans-serif font family]:family' \
  '--monospace-family=[set the monospace font family]:family' \
  '--cursive-family=[set the cursive font family]:family' \
  '--fantasy-family=[set the fantasy font family]:family' \
  '--skip-system-fonts[skip loading system fonts]' \
  '--font-file=[load a specific font file]:file:_files' \
  '--font-dir=[load fonts from a directory]:directory:_directories' \
  '--indent=[set XML indent]:indent:(none 1 2 3 4 tabs)' \
  '--id-prefix=[add a prefix to all IDs]:prefix' \
  '-c[write output to stdout]' \
  '--quiet[suppress warnings]' \
  '1:input SVG:_files -g "*.svg"' \
  '2:output SVG:_files -g "*.svg"' && ret=0

return ret
