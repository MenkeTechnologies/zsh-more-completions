#compdef callgraph
# _callgraph — Go x/tools call graph generator (Alan Donovan); print Go call graph using rta/pta/cha/static
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/callgraph

_callgraph() {
    _arguments \
        '-algo+[algorithm]:algo:(static cha rta vta pta)' \
        '-format+[output format]:fmt:(digraph graphviz)' \
        '-test[include tests]' \
        '-tags+[build tags]:tags:' \
        '-ptalog+[pta log file]:file:_files' \
        '*:packages:'
}

_callgraph "$@"
