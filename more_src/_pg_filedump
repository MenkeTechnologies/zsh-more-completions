#compdef pg_filedump
# Documentation: https://man.archlinux.org/search?q=pg_filedump
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-a[print absolute block offsets]' \
  '-b[print bytes]' \
  '-d[dump formatted block content]' \
  '-D+[interpret as type list]:types:' \
  '-f[print full data]' \
  '-h[show heap info only]' \
  '-i[item dump]' \
  '-k[verify block checksums]' \
  '-l+[lower-bound block]:n:' \
  '-m[interpret as multi-xact members]' \
  '-N[use file as control file]' \
  '-o[output format]' \
  '-r+[range]:n:' \
  '-R+[range start]:start:' \
  '-S+[blocksize bytes]:bytes:' \
  '-s+[start segment]:n:' \
  '-t[do not dump TOAST tables]' \
  '-T+[token print]:t:' \
  '-u+[upper-bound block]:n:' \
  '-w+[output as wal segment]:flag:' \
  '-x[interpret as B-tree index]' \
  '-X+[xlog]:flag:' \
  '-y[as SP-GiST]' \
  '-z[verify checksums]' \
  '*:file:_files' && ret=0

return ret
