#compdef cpp
# Documentation: cpp --help (Darwin C preprocessor — driver maps to clang -E)
# Source: cpp — driver for the C preprocessor (Apple toolchain forwards to clang -E).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-D-[define preprocessor macro]:NAME[=VALUE]:' \
    '*-U-[undefine preprocessor macro]:NAME:' \
    '*-I-[add include directory]:dir:_files -/' \
    '*-iquote-[add quote-include directory]:dir:_files -/' \
    '*-isystem-[add system-include directory]:dir:_files -/' \
    '*-idirafter-[add include directory after system]:dir:_files -/' \
    '*-include-[force-include file before main input]:file:_files' \
    '*-imacros-[include macros from file]:file:_files' \
    '-nostdinc[skip standard include path]' \
    '-nostdinc++[skip C++ standard include path]' \
    '-undef[do not predefine builtin macros]' \
    '-C[keep comments in output]' \
    '-CC[keep comments inside macros]' \
    '-P[do not emit linemarkers]' \
    '-traditional-cpp[emulate K&R preprocessor]' \
    '-E[run only the preprocessor]' \
    '-M[generate make dependency rule]' \
    '-MM[like -M but skip system headers]' \
    '-MD[like -M but include compile]' \
    '-MMD[like -MM but include compile]' \
    '-MF+[dependency output file]:file:_files' \
    '-MT+[target name for dependency rule]:target:' \
    '-MP[add phony target for each dependency]' \
    '-MQ+[quote-escaped target name]:target:' \
    '-o+[output file]:file:_files' \
    '-v[verbose]' \
    '-x+[input language]:lang:(c c-header c++ c++-header objective-c objective-c++ assembler)' \
    '-fsyntax-only[only check syntax]' \
    '-fno-show-column[hide column numbers]' \
    '--version[show version]' \
    '*:source file:_files -g "*.{c,cc,cpp,cxx,m,mm,h,hh,hpp,hxx,S,s}"' \
    && ret=0

return ret
