#compdef cmctl

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--context=[kubernetes context]:context' \
  '-n+[kubernetes namespace]:namespace' \
  '--namespace=[kubernetes namespace]:namespace' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'approve:approve a CertificateRequest'
      'check:check cert-manager components'
      'convert:convert cert-manager resources'
      'create:create cert-manager resources'
      'deny:deny a CertificateRequest'
      'experimental:experimental features'
      'inspect:inspect cert-manager resources'
      'renew:renew certificates'
      'status:get cert-manager status'
      'upgrade:upgrade cert-manager'
      'version:show version'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      check)
        _arguments \
          'api:check API compatibility' && ret=0
        ;;
      renew)
        _arguments \
          '--all[renew all certificates in namespace]' \
          '-l+[label selector]:selector' \
          '--label-selector=[label selector]:selector' \
          '*:certificate name' && ret=0
        ;;
      status)
        _arguments \
          '1:subcommand:(certificate)' \
          '*:name' && ret=0
        ;;
      inspect)
        _arguments \
          '1:subcommand:(secret)' \
          '*:name' && ret=0
        ;;
    esac
    ;;
esac

return ret
