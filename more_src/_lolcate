#compdef lolcate
# lolcate — fast system-wide file finder (Rust locate replacement)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'create:create a new database'
  'info:show database information'
  'lookup:search for files (default)'
  'update:update database'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--db=[database name]:name:' \
  '--all[search all databases]' \
  '(-b --basename)'{-b,--basename}'[match only the basename]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive search]' \
  '--type=[filter by type]:type:(f d l)' \
  '--color=[color output]:when:(auto always never)' \
  '1:command or pattern:->cmd_or_pattern' \
  '*:: :->args' \
  && ret=0

case $state in
  (cmd_or_pattern)
    _alternative \
      'commands:command:_describe -t commands "lolcate command" subcommands' \
      'patterns:pattern:' \
      && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:database name:' \
          && ret=0
        ;;
      (update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[update all databases]' \
          '*:database name:' \
          && ret=0
        ;;
      (info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[show info for all databases]' \
          '*:database name:' \
          && ret=0
        ;;
      (lookup|*)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--db=[database name]:name:' \
          '--all[search all databases]' \
          '(-b --basename)'{-b,--basename}'[match only basename]' \
          '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive]' \
          '--type=[filter by type]:type:(f d l)' \
          '*:pattern:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
