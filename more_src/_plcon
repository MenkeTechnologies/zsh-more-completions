#compdef plcon
# Documentation: https://www.swi-prolog.org/man/cmdline.html
# plcon - SWI-Prolog command-line console executable (Windows)

local ret=1

_arguments -s \
  '--help[summarize primary command-line options]' \
  '--version[print version and architecture]' \
  '--arch[print architecture identifier]' \
  '--abi-version[print binary compatibility key]' \
  '--dump-runtime-variables=-[output shell-compatible variable settings]:format' \
  '*-D+[set a Prolog flag before initialization]:flag' \
  '-f+[set initialization file (none to skip)]:file:_files' \
  '-s+[load script file after initialization]:file:_files' \
  '-l+[load file, skipping initialization directives]:file:_files' \
  '-x+[boot from a custom saved state]:bootfile:_files' \
  '-F+[select startup script from home directory]:script' \
  '*-p+[define a file search path alias]:alias=path' \
  '*-g+[execute goal before entering top level]:goal' \
  '-t+[set interactive top-level goal]:goal' \
  '-c[compile files to an intermediate state]:*:file:_files' \
  '-o+[output file for compilation]:output:_files' \
  '-b+[bootstrap compilation init file]:initfile:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '-O[enable optimized compilation]' \
  '--no-debug[disable debugging]' \
  '--no-signals[inhibit signal handling]' \
  '--no-threads[disable threading]' \
  '--no-packs[skip extension packages]' \
  '--no-pce[disable GUI subsystem]' \
  '--no-tty[disable terminal control]' \
  '--debug-on-interrupt[enable debugger on Control-C]' \
  '--traditional[disable version 7+ extensions]' \
  '--stack-limit=-[set combined stack size limit]:size' \
  '--table-space=-[limit memoization table space]:size' \
  '--shared-table-space=-[limit shared table space]:size' \
  '--home=-[set installation directory]:dir:_files -/' \
  '--pldoc=-[start documentation server]:port' \
  '--on-error=-[configure error handling style]:style' \
  '--on-warning=-[configure warning handling style]:style' \
  '*:file:_files' && ret=0

return ret
