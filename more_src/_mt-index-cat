#compdef mt-index-cat
# Documentation: https://github.com/grafana/metrictank
# Retrieve a metrictank index and dump it in the requested format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-addr=[graphite/metrictank address]:url' \
  '-bt-total-partitions=[total number of partitions when using bigtable]:n' \
  '-from=[generate vegeta requests from now minus this duration]:from' \
  '-limit=[show only this many metrics, 0 to disable]:n' \
  '-max-stale=[exclude series not seen for this time]:dur' \
  '-min-stale=[exclude series seen within this time]:dur' \
  '-org=[show only metrics with this OrgID]:n' \
  '-partitions=[comma-separated partition list or * for all]:partitions' \
  '-prefix=[show only metrics with this prefix]:prefix' \
  '-regex=[show only metrics matching this regex]:regex' \
  '-substr=[show only metrics with this substring]:substr' \
  '-suffix=[show only metrics with this suffix]:suffix' \
  '-tags=[tag filter]:filter:(none some valid invalid)' \
  '-verbose[print stats to stderr]' && ret=0

return ret
