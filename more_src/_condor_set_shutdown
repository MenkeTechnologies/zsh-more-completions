#compdef condor_set_shutdown
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_set_shutdown.html
# set a program to run at the next condor_master shutdown

local ret=1

_arguments -s -S \
  '-help[display usage information]' \
  '-version[display version information]' \
  '-exec[select the program the master should exec on next shutdown]:name' \
  '-debug[send debugging information to stderr]' \
  '-pool[specify a pool by central manager host name and optional port]:hostname:_hosts' \
  '-name[send the command to the named host]:hostname:_hosts' \
  '-addr[send the command to the master at the given address]:address' \
  '-constraint[apply only to machines matching the ClassAd expression]:expression' \
  '-all[send the command to all machines in the pool]' && ret=0

return ret
