#compdef slack-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize CLI with token'
  'chat:send/update/delete messages'
  'file:upload and manage files'
  'presence:set presence'
  'reminder:manage reminders'
  'snooze:DND snooze'
  'status:edit your user status'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'slack-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (chat)
        _values 'chat action' send update delete && ret=0
        ;;
      (file)
        _values 'file action' upload list info delete && ret=0
        ;;
      (presence)
        _values 'presence action' active away && ret=0
        ;;
      (reminder)
        _values 'reminder action' add complete delete info list && ret=0
        ;;
      (snooze)
        _values 'snooze action' start info end && ret=0
        ;;
      (status)
        _values 'status action' edit clear && ret=0
        ;;
    esac
    ;;
esac

return ret
