#compdef craftctl
# _craftctl — craft-parts lifecycle helper for scriptlets (canonical/craft-parts)
# upstream: https://github.com/canonical/craft-parts
# Subcommands from craft-parts how-to docs.

_craftctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'default:execute the default behavior of the current step'
                'set:set a project variable (key=value)'
                'get:get a project variable value'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                set) _arguments '*:key=value:(version=  grade=  source-commit=  source-tag=  source-branch=)' ;;
                get) _arguments '1:key:(version grade source-commit source-tag source-branch)' ;;
            esac
            ;;
    esac
}

_craftctl "$@"
