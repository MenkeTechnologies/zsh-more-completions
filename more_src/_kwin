#compdef kwin kwin_x11 kwin_wayland
# Documentation: https://man.archlinux.org/search?q=kwin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all help options]' \
  '--help-qt[show Qt-specific help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--replace[replace running window manager]' \
  '--no-kactivities[disable activities support]' \
  '--no-lockscreen[disable lock screen (Wayland)]' \
  '--no-global-shortcuts[disable global shortcuts]' \
  '--xwayland[start Xwayland server]' \
  '--no-xwayland[do not start Xwayland]' \
  '--inputmethod=[input method to use]:im:' \
  '--socket=[Wayland display socket name]:name:' \
  '--width=[output width]:n:' \
  '--height=[output height]:n:' \
  '--scale=[output scale]:n:' \
  '--output-count=[number of outputs]:n:' \
  '--drm[use DRM backend]' \
  '--virtual[use virtual backend]' \
  '--wayland[use Wayland backend]' \
  '--x11-display=[X11 display]:disp:' \
  '--wayland-display=[Wayland display]:disp:' \
  '--exit-with-session=[exit when session ends]:sess:' \
  '--lockscreen[force lock screen]' \
  '--locked[start with screen locked]' \
  '--platform=[Qt platform]:plat:(xcb wayland eglfs minimal)' \
  '--remote-debugging-port=[debug port]:port:' \
  '*:program:_command_names' && ret=0

return ret
