#compdef snakemake

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --snakefile)'{-s,--snakefile}'[Snakefile path]:file:_files' \
  '--configfile[config file]:file:_files' \
  '(-c --cores --jobs -j)'{-c,--cores,--jobs,-j}'[number of cores]:cores' \
  '(-n --dryrun --dry-run)'{-n,--dryrun,--dry-run}'[dry run]' \
  '(-p --printshellcmds)'{-p,--printshellcmds}'[print shell commands]' \
  '(-f --force)'{-f,--force}'[force execution of target rules]' \
  '(-F --forceall)'{-F,--forceall}'[force execution of all rules]' \
  '(-R --forcerun)'{-R,--forcerun}'[force rerun of given rules]:rules' \
  '(-t --touch)'{-t,--touch}'[touch output files]' \
  '(-k --keep-going)'{-k,--keep-going}'[keep going on errors]' \
  '--rerun-incomplete[rerun incomplete jobs]' \
  '--rerun-triggers[rerun triggers]:triggers:(mtime params input software code)' \
  '--profile[workflow profile]:profile:_directories' \
  '--cluster[cluster submission command]:command' \
  '--cluster-config[cluster config file]:file:_files' \
  '--drmaa[use DRMAA for cluster jobs]:args' \
  '(-d --directory)'{-d,--directory}'[working directory]:directory:_directories' \
  '--config[set config values]:values' \
  '--use-conda[use conda environments]' \
  '--use-singularity[use singularity containers]' \
  '--use-envmodules[use environment modules]' \
  '--conda-frontend[conda frontend]:frontend:(conda mamba)' \
  '--conda-prefix[conda environment prefix]:directory:_directories' \
  '--singularity-prefix[singularity image prefix]:directory:_directories' \
  '--singularity-args[singularity arguments]:args' \
  '--list[list available rules]' \
  '--list-target-rules[list target rules]' \
  '--dag[print DAG in dot format]' \
  '--rulegraph[print rule graph in dot format]' \
  '--filegraph[print file graph in dot format]' \
  '--summary[print summary]' \
  '--detailed-summary[print detailed summary]' \
  '--archive[archive workflow]:file:_files' \
  '--cleanup-metadata[clean up metadata]:files:_files' \
  '--reason[print reason for execution]' \
  '--stats[write stats to file]:file:_files' \
  '--nocolor[disable color output]' \
  '--quiet[reduce output]:modes' \
  '--verbose[verbose output]' \
  '--lint[lint workflow]:mode:(text json)' \
  '(-T --retries --restart-times)'{-T,--retries,--restart-times}'[number of retries]:retries' \
  '--attempt[current attempt number]:attempt' \
  '(-w --latency-wait --output-wait)'{-w,--latency-wait,--output-wait}'[wait for output files]:seconds' \
  '--notemp[ignore temp flag]' \
  '--keep-incomplete[keep incomplete output files]' \
  '--shadow-prefix[shadow directory prefix]:directory:_directories' \
  '--scheduler[scheduler type]:type:(ilp greedy)' \
  '--wms-monitor[WMS monitor URL]:url' \
  '--wms-monitor-arg[WMS monitor arguments]:args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:target' && ret=0
return ret
