#compdef snakemake

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --snakefile)'{-s,--snakefile}'[path to Snakefile]:file:_files -g "Snakefile*"' \
  '(-j --cores --jobs)'{-j,--cores,--jobs}'[number of cores]:cores' \
  '(-n --dryrun --dry-run)'{-n,--dryrun,--dry-run}'[dry run]' \
  '(-p --printshellcmds)'{-p,--printshellcmds}'[print shell commands]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]:type:(all progress rules)' \
  '(-f --force)'{-f,--force}'[force execution]' \
  '(-F --forceall)'{-F,--forceall}'[force all rules]' \
  '--forcerun=[force specific rules]:rules' \
  '(-R --prioritize)'{-R,--prioritize}'[prioritize rules]:rules' \
  '--until=[run until specific rules]:rules' \
  '--omit-from=[omit rules]:rules' \
  '(-r --reason)'{-r,--reason}'[print reason for execution]' \
  '(-t --touch)'{-t,--touch}'[touch output files]' \
  '--keep-going[keep going on errors]' \
  '-k[keep going on errors]' \
  '(-l --list)'{-l,--list}'[list available rules]' \
  '--list-target-rules[list target rules]' \
  '(-D --delete-all-output)'{-D,--delete-all-output}'[delete all output files]' \
  '--delete-temp-output[delete temp files]' \
  '-d[working directory]:directory:_directories' \
  '--directory=[working directory]:directory:_directories' \
  '--configfile=[config file]:file:_files -g "*.{yaml,yml,json}"' \
  '--config[set config values]:key=value' \
  '--use-conda[use conda environments]' \
  '--use-singularity[use Singularity containers]' \
  '--use-envmodules[use environment modules]' \
  '--conda-prefix=[conda environment prefix]:directory:_directories' \
  '--singularity-prefix=[Singularity image prefix]:directory:_directories' \
  '--conda-frontend=[conda frontend]:frontend:(conda mamba)' \
  '--profile=[workflow profile]:profile:_directories' \
  '--cluster=[cluster submission command]:command' \
  '--cluster-status=[cluster status command]:command' \
  '--drmaa=[DRMAA args]:args' \
  '--executor=[workflow executor]:executor:(local dryrun touch cluster slurm)' \
  '--latency-wait=[wait time for output files]:seconds' \
  '-w[wait time for output files]:seconds' \
  '--rerun-incomplete[rerun incomplete jobs]' \
  '--rerun-triggers=[rerun triggers]:triggers:(mtime params input software code)' \
  '--shadow-prefix=[shadow directory]:directory:_directories' \
  '--report=[create HTML report]:file:_files' \
  '--report-stylesheet=[report stylesheet]:file:_files -g "*.css"' \
  '-S[summary of output files]' \
  '--summary[summary of output files]' \
  '--detailed-summary[detailed summary]' \
  '--archive=[archive workflow]:file:_files -g "*.tar.gz"' \
  '--cleanup-metadata=[clean up metadata]:files:_files' \
  '--lint=[lint mode]:mode:(text json)' \
  '--generate-unit-tests=[generate unit tests]:directory:_directories' \
  '--export-cwl=[export as CWL]:file:_files' \
  '--dag[print DAG in dot format]' \
  '--rulegraph[print rule graph in dot format]' \
  '--filegraph[print file graph in dot format]' \
  '--unlock[unlock working directory]' \
  '--cleanup-shadow[clean up shadow directories]' \
  '--wrapper-prefix=[wrapper prefix]:prefix' \
  '--default-remote-prefix=[default remote prefix]:prefix' \
  '--default-remote-provider=[default remote provider]:provider:(S3 GS FTP HTTP SFTP)' \
  '--no-hooks[do not invoke onstart/onsuccess/onerror hooks]' \
  '--notemp[do not remove temp files]' \
  '--keep-incomplete[keep incomplete output files]' \
  '--keep-target-files[do not adjust creation time]' \
  '--allowed-rules=[only allow specific rules]:rules' \
  '--local-cores=[cores for local rules]:cores' \
  '--max-threads=[max threads per rule]:threads' \
  '--resources=[set resources]:resources' \
  '--set-threads=[set threads for rules]:rule=threads' \
  '--set-resources=[set resources for rules]:rule\:resource=value' \
  '--max-jobs-per-second=[max jobs per second]:rate' \
  '--max-status-checks-per-second=[max status checks per second]:rate' \
  '--retries=[number of retries]:retries' \
  '--attempt=[set attempt number]:attempt' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '*:targets' && ret=0

return ret
