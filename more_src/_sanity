#compdef sanity
# Documentation: https://www.sanity.io/docs/cli-reference
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Sanity CLI

_sanity() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize a new Sanity Studio, project and/or app'
    'dev:start a local development server with live reloading'
    'build:build Sanity Studio into a static bundle'
    'deploy:deploy Sanity Studio or application to Sanity hosting'
    'undeploy:remove deployed Sanity Studio/App from Sanity hosting'
    'preview:start a local server to preview a production build'
    'datasets:manage datasets'
    'documents:manage documents in a dataset'
    'graphql:manage GraphQL APIs'
    'schemas:manage and validate schemas'
    'exec:run a script in the context of the project'
    'cors:manage CORS origins'
    'hooks:manage webhooks'
    'login:log in to Sanity'
    'logout:log out of the current session'
    'manage:open project settings in your browser'
    'debug:print diagnostic info for troubleshooting'
    'doctor:run diagnostics on the project'
    'install:install dependencies for the Sanity Studio project'
    'typegen:generate TypeScript types from schema and GROQ'
    'codemod:run codebase modification scripts'
    'learn:open Sanity Learn in your browser'
    'help:display help'
    'versions:show installed Sanity versions'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sanity command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        init)
          _arguments -s -S \
            '--project=[project ID]:project ID:' \
            '--dataset=[dataset name]:dataset:' \
            '--output-path=[output directory]:directory:_files -/' \
            '--template=[project template]:template:' \
            '--visibility=[dataset visibility]:visibility:(public private)' \
            '--typescript[use TypeScript]' \
            '--coupon=[coupon code]:coupon:' \
            '--create-project=[create new project]:project name:' \
            '-y[use default values]' \
            '--yes[use default values]' \
            && ret=0
          ;;
        dev)
          _arguments -s -S \
            '--port=[port number]:port:' \
            '--host=[hostname]:hostname:_hosts' \
            && ret=0
          ;;
        build)
          _arguments -s -S \
            '--output-dir=[output directory]:directory:_files -/' \
            '--source-maps[generate source maps]' \
            '--no-minify[do not minify output]' \
            '-y[skip confirmation]' \
            && ret=0
          ;;
        deploy)
          _arguments -s -S \
            '--source-maps[include source maps]' \
            '--no-build[skip build step]' \
            && ret=0
          ;;
        datasets)
          _arguments -s -S \
            '1:subcommand:(create delete export import list copy visibility)' \
            && ret=0
          ;;
        documents)
          _arguments -s -S \
            '1:subcommand:(create delete get query)' \
            && ret=0
          ;;
        graphql)
          _arguments -s -S \
            '1:subcommand:(deploy list undeploy)' \
            '--dataset=[dataset name]:dataset:' \
            '--tag=[API tag]:tag:' \
            '--generation=[generation]:generation:(gen1 gen2 gen3)' \
            '--playground[enable playground]' \
            '--non-null-document-fields[make document fields non-null]' \
            && ret=0
          ;;
        cors)
          _arguments -s -S \
            '1:subcommand:(add delete list)' \
            && ret=0
          ;;
        typegen)
          _arguments -s -S \
            '--enforce-required-fields[enforce required fields]' \
            && ret=0
          ;;
        exec)
          _arguments -s -S \
            '--with-user-token[include user token in context]' \
            '--mock-browser-env[mock browser environment]' \
            '1:script file:_files -g "*.{js,ts,mjs}"' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--debug[enable debug output]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_sanity "$@"
