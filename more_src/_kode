#compdef kode kwa kd
# Documentation: https://github.com/shareAI-lab/kode
# Reference accessed: 2026-05-22
# Verified: src/entrypoints/cli/runCli.tsx Commander program.

# Zsh completion for kode / kwa / kd - AI terminal coding assistant

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--cwd[working directory]:directory:_directories' \
  '(-d --debug)'{-d,--debug}'[debug mode with optional filter]:filter:' \
  '--debug-verbose[verbose debug terminal output]' \
  '--verbose[override verbose from config]' \
  '(-p --print)'{-p,--print}'[non-interactive print mode]' \
  '(-c --continue)'{-c,--continue}'[continue most recent conversation]' \
  '(-r --resume)'{-r,--resume}'[resume conversation by ID]:id:' \
  '--model[model id]:model:' \
  '--provider[provider name]:provider:' \
  '--permission-mode[permission mode]:mode:' \
  '--max-turns[maximum agent turns]:turns:' \
  '--system-prompt[system prompt]:text:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'kode command' \
      'config[manage configuration]' \
      'agents[manage agents]' \
      'plugin[manage plugins]' \
      'skills[manage skills]' \
      'approved-tools[manage approved tools]' \
      'mcp[manage MCP servers]' \
      'doctor[run diagnostics]' \
      'update[update kode]' \
      'log[view logs]' \
      'resume[resume conversation]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _values 'config action' get set remove list && ret=0
        ;;
      agents)
        _values 'agents action' validate && ret=0
        ;;
      mcp)
        _values 'mcp action' \
          serve add-sse add-http add-ws add remove list add-json && ret=0
        ;;
      approved-tools)
        _values 'approved-tools action' list remove && ret=0
        ;;
      *)
        _arguments '*:prompt:' && ret=0
        ;;
    esac
    ;;
esac

return ret
