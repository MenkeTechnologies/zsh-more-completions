#compdef pgxc_ctl
# Documentation: https://github.com/koichi-szk/PGXC-Tools/blob/master/pgxc_ctl/manual.txt
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pgxc_ctl: Postgres-XL/XC cluster control tool
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --configuration)'{-c,--configuration}'[configuration file]:file:_files' \
  '--debug[enable debug mode]' \
  '-f[read commands from file]:file:_files' \
  '--silent[suppress verbose output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '--with-log[enable operation logging]' \
  '--without-log[disable operation logging]' \
  '*::pgxc_ctl command:(prepare init add remove start stop monitor failover unregister kill clean show register Createdb Createuser Cleanup)' && ret=0

return ret
