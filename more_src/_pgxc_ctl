#compdef pgxc_ctl

# pgxc_ctl: Postgres-XL control tool (legacy XC/XL cluster)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[config file]:file:_files' \
  '--conf=[config file]:file:_files' \
  '-d[install dir]:dir:_files -/' \
  '--installdir=[install dir]:dir:_files -/' \
  '-l[log dir]:dir:_files -/' \
  '--logdir=[log dir]:dir:_files -/' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '-s[script file to execute]:file:_files' \
  '--silent[silent]' \
  '*::pgxc_ctl command:(prepare init add remove start stop monitor failover unregister kill clean show register Createdb Createuser Cleanup)' && ret=0
return ret
