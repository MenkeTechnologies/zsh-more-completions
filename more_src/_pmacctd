#compdef pmacctd

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-f[config file]:file:_files' \
  '-a[list primitives]' \
  '-c[primitives]:primitive:' \
  '-D[daemonize]' \
  '-N[disable promiscuous]' \
  '-z[non-root execution]' \
  '-n[networks file]:file:_files' \
  '-t[ports file]:file:_files' \
  '-P[plugin]:plugin:(memory print mysql pgsql sqlite3 amqp kafka nfprobe sfprobe)' \
  '-d[debug]' \
  '-i[interface]:iface:_net_interfaces' \
  '-I[savefile]:file:_files' \
  '-S[syslog facility]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-F[pid file]:file:_files' \
  '-w[wait for interface]' \
  '-Z[seconds]:s:' \
  '-W[sleep at EOF]' \
  '-Y[replays]:n:' \
  '-R[renormalize sampled data]' \
  '-L[snaplen]:n:' \
  '-u[numeric protocols]' \
  '-T[dry run target]:target:(config setup)' \
  '-p[memory socket]:socket:' \
  '-b[memory buckets]:n:' \
  '-m[memory pools]:n:' \
  '-s[memory pool size]:n:' \
  '-r[print refresh]:s:' \
  '-O[print output format]:fmt:(formatted csv json avro)' \
  '-o[print output file]:file:_files' \
  '-M[print markers]' \
  '-A[print append]' \
  '-E[print separator]:char:'
