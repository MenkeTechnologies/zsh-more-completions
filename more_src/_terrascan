#compdef terrascan

# Zsh completion for terrascan (IaC security scanner)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize terrascan'
  'scan:scan IaC files for violations'
  'server:run terrascan as an API server'
  'version:show terrascan version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --log-level)'{-l,--log-level}'[log level]:level:(debug info warn error panic fatal)' \
  '--log-type[log output type]:type:(console json)' \
  '(-o --output)'{-o,--output}'[output format]:format:(human json yaml xml junit-xml sarif github-sarif)' \
  '--config-path[config file]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'terrascan command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (scan)
        _arguments \
          '(-d --iac-dir)'{-d,--iac-dir}'[IaC directory]:dir:_files -/' \
          '(-f --iac-file)'{-f,--iac-file}'[IaC file]:file:_files' \
          '(-i --iac-type)'{-i,--iac-type}'[IaC type]:type:(arm cft docker helm k8s kustomize terraform tfplan)' \
          '--iac-version[IaC version]:version:' \
          '(-p --policy-path)'{-p,--policy-path}'[policy path]:path:_files -/' \
          '(-t --policy-type)'{-t,--policy-type}'[policy type]:type:(all aws azure gcp github k8s)' \
          '--remote-type[remote type]:type:(git s3 gcs http terraform-registry)' \
          '--remote-url[remote URL]:url:_urls' \
          '--severity[minimum severity]:severity:(HIGH MEDIUM LOW)' \
          '--skip-rules[rules to skip]:rules:' \
          '--scan-rules[specific rules to scan]:rules:' \
          '--non-recursive[do not scan subdirectories]' \
          '--use-colors[use colors]:when:(auto always never)' \
          '--find-vulnerabilities[scan for vulnerabilities]' \
          '--show-passed[show passed rules]' \
          '--verbose[verbose output]' && ret=0
        ;;
      (server)
        _arguments \
          '--port[server port]:port:' \
          '--cert-path[TLS cert path]:file:_files' \
          '--key-path[TLS key path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
