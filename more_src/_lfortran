#compdef lfortran
# Documentation: https://man.archlinux.org/search?q=lfortran
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-v[verbose output]' \
  '(-c)-c[compile only, no link]' \
  '-S[stop after assembly]' \
  '-E[stop after preprocess]' \
  '-O0[no optimization]' \
  '-O1[level 1 optimization]' \
  '-O2[level 2 optimization]' \
  '-O3[level 3 optimization]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-I)*-I+[include directory]:dir:_files -/' \
  '(-J)*-J+[module directory]:dir:_files -/' \
  '*-L+[library directory]:dir:_files -/' \
  '*-l+[link library]:lib:' \
  '*-D+[define macro]:macro:' \
  '*-U+[undefine macro]:macro:' \
  '--show-llvm[show LLVM IR]' \
  '--show-asm[show ASM]' \
  '--show-cpp[show preprocessed]' \
  '--show-asr[show ASR]' \
  '--show-ast[show AST]' \
  '--show-tokens[show tokens]' \
  '--show-c[show C output]' \
  '--show-fortran[show Fortran output]' \
  '--show-julia[show Julia output]' \
  '--show-wat[show WAT output]' \
  '--with-intrinsic-mods[include intrinsic mods]' \
  '--get-rtl-header-dir[print rtl header dir]' \
  '--get-rtl-dir[print rtl dir]' \
  '--rtlib=[runtime library]:lib:' \
  '--target=[target triple]:t:' \
  '--platform=[platform]:p:' \
  '--cpu=[CPU]:cpu:' \
  '--print-rtl-dir[print rtl dir]' \
  '--print-rtl-header-dir[print rtl header dir]' \
  '--workdir=[work dir]:dir:_files -/' \
  '--implicit-typing[allow implicit typing]' \
  '--implicit-interface[allow implicit interface]' \
  '--allow-implicit-pointers[allow implicit ptrs]' \
  '--legacy-array-sections[legacy array sections]' \
  '--print-leading-space[print leading space]' \
  '--no-format[do not format error messages]' \
  '--openmp[enable OpenMP]' \
  '--no-color[disable colors]' \
  '--time-report[print timing breakdown]' \
  '--verbose[verbose]' \
  '--fast[fast mode]' \
  '--symtab-only[only symtab]' \
  '--debug[debug build]' \
  '--no-warnings[suppress warnings]' \
  '--noisy[noisy debug]' \
  '--separate-compilation[separate compilation]' \
  '--lookup-name=[lookup name]:name:' \
  '--lookup-pos=[lookup position]:pos:' \
  '--continue-compilation[continue on error]' \
  '--module-tree-format[module tree format]' \
  '--no-prescan[no prescan]' \
  '--realloc-lhs[realloc on assignment]' \
  '--llvm-ir[output LLVM IR]' \
  '--bytecode[output bytecode]' \
  '--cumulative[cumulative timing]' \
  '*: :_files -g "*.f90 *.f95 *.f03 *.f08 *.F90 *.F95 *.F03 *.F08 *.f *.F"' && ret=0

return ret
