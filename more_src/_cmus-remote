#compdef cmus-remote

# Zsh completion for cmus-remote - cmus remote control

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--server=[connect to specified server]:server address:' \
  '--passwd=[password for server]:password:' \
  '-p[start playing]' \
  '-u[toggle pause]' \
  '-s[stop playback]' \
  '-n[next track]' \
  '-r[previous track]' \
  '-f[seek forward 5 seconds]' \
  '-b[seek backward 5 seconds]' \
  '-k[seek to absolute position]:position (seconds):' \
  '-v[set volume]:volume (+-N or N):' \
  '-l[get library playlist]' \
  '-P[pause playback]' \
  '-U[unpause playback]' \
  '-Q[get player status]' \
  '-S[toggle shuffle]' \
  '-R[toggle repeat]' \
  '-C[send raw command to cmus]:command:' \
  '-q[add to play queue]:file:_files' \
  '-c[clear play queue]' \
  '-e[append file to library]:file:_files' \
  '*:file:_files' && ret=0

return ret
