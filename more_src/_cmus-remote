#compdef cmus-remote
# Documentation: https://man.archlinux.org/man/cmus-remote.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cmus-remote - cmus remote control

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--server=[connect to specified socket]:socket:' \
  '--passwd=[password for TCP/IP connections]:password:' \
  '(-p --play)'{-p,--play}'[begin playback]' \
  '(-u --pause)'{-u,--pause}'[toggle pause state]' \
  '(-U --pause-playback)'{-U,--pause-playback}'[pause if currently playing]' \
  '(-s --stop)'{-s,--stop}'[stop playback]' \
  '(-n --next)'{-n,--next}'[advance to next track]' \
  '(-r --prev)'{-r,--prev}'[go to previous track]' \
  '(-R --repeat)'{-R,--repeat}'[toggle repeat mode]' \
  '(-S --shuffle)'{-S,--shuffle}'[toggle shuffle mode]' \
  '(-v --volume)'{-v,--volume}'[adjust volume level]:volume (+-N or N):' \
  '(-k --seek)'{-k,--seek}'[jump to position in track]:position:' \
  '(-f --file)'{-f,--file}'[play specified file]:file:_files' \
  '(-l --library)'{-l,--library}'[target library instead of playlist]' \
  '(-P --playlist)'{-P,--playlist}'[target playlist (default)]' \
  '(-q --queue)'{-q,--queue}'[target play queue]' \
  '(-c --clear)'{-c,--clear}'[clear specified view]' \
  '(-C --raw)'{-C,--raw}'[treat arguments as raw commands]' \
  '-Q[retrieve player status information]' \
  '*:file:_files' && ret=0

return ret
