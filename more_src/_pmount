#compdef pmount

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-r[mount read-only]' \
  '-w[mount read-write]' \
  '-s[mount synchronously]' \
  '-A[mount noatime]' \
  '-e[mount with specified encoding]:encoding:' \
  '-c[set character set]:charset:' \
  '-u[set umask]:umask:' \
  '-d[use specific dmcrypt mapping]:name:' \
  '-p[passphrase file]:file:_files' \
  '-t[filesystem type]:type:(auto ext2 ext3 ext4 ntfs vfat exfat xfs btrfs)' \
  '-l[label-based mount point]' \
  '--noatime[mount noatime]' \
  '--exec[mount with exec]' \
  '--noexec[mount with noexec]' \
  '--nosuid[mount with nosuid]' \
  '--nodev[mount with nodev]' \
  '1:device:_files -g "/dev/*(-%)" -W /' \
  '2:mount point:_files -/' && ret=0

return ret
