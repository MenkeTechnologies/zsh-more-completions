#compdef kafka-cluster

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--cluster-id[Get the cluster ID]'
    '--unregister[Unregister a broker]'
    '--id[Broker ID to unregister]:id:'
)

_arguments -s -S $arguments
