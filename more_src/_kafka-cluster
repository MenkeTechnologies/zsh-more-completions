#compdef kafka-cluster
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/ClusterTool.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cluster-id:get and display the cluster ID'
  'list-endpoints:list endpoints'
  'unregister:unregister a broker'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kafka-cluster command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cluster-id|list-endpoints)
        _arguments \
          '--bootstrap-server[Server to connect to]:host\:port:' \
          '--bootstrap-controller[Controller to connect to]:host\:port:' \
          '--command-config[Admin Client config property file]:file:_files' \
          '--include-fenced-brokers[include fenced brokers (list-endpoints)]' && ret=0 ;;
      (unregister)
        _arguments \
          '--bootstrap-server[Server to connect to]:host\:port:' \
          '--bootstrap-controller[Controller to connect to]:host\:port:' \
          '--command-config[Admin Client config property file]:file:_files' \
          '--id[Broker ID to unregister]:id:' && ret=0 ;;
    esac ;;
esac

return ret
