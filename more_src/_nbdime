#compdef nbdime

# Zsh completion for nbdime - Jupyter notebook diff and merge

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'diff:compute diff of two notebooks'
  'merge:merge two notebooks with a common base'
  'diff-web:show diff in a web browser'
  'merge-web:show merge in a web browser'
  'show:show a single notebook in a readable format'
  'config-git:configure git integration'
  'extensions:install/uninstall Jupyter extensions'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nbdime command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (diff)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --sources)'{-s,--sources}'[process source cells]' \
          '(-o --outputs)'{-o,--outputs}'[process output cells]' \
          '(-a --attachments)'{-a,--attachments}'[process attachments]' \
          '(-m --metadata)'{-m,--metadata}'[process metadata]' \
          '(-d --details)'{-d,--details}'[process details]' \
          '--no-color[disable color output]' \
          '--color-words[color changed words]' \
          '--out=[output file]:file:_files' \
          '1:base notebook:_files -g "*.ipynb"' \
          '2:remote notebook:_files -g "*.ipynb"' && ret=0
        ;;
      (merge)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --sources)'{-s,--sources}'[process source cells]' \
          '(-o --outputs)'{-o,--outputs}'[process output cells]' \
          '(-a --attachments)'{-a,--attachments}'[process attachments]' \
          '(-m --metadata)'{-m,--metadata}'[process metadata]' \
          '--out=[output file]:file:_files' \
          '--no-color[disable color output]' \
          '1:base notebook:_files -g "*.ipynb"' \
          '2:local notebook:_files -g "*.ipynb"' \
          '3:remote notebook:_files -g "*.ipynb"' && ret=0
        ;;
      (diff-web)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--port=[port to listen on]:port' \
          '--ip=[IP address to listen on]:ip address' \
          '--browser=[browser to use]:browser' \
          '--no-browser[do not open a browser]' \
          '--base-url=[base URL for the server]:url' \
          '1:base notebook:_files -g "*.ipynb"' \
          '2:remote notebook:_files -g "*.ipynb"' && ret=0
        ;;
      (merge-web)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--port=[port to listen on]:port' \
          '--ip=[IP address to listen on]:ip address' \
          '--browser=[browser to use]:browser' \
          '--no-browser[do not open a browser]' \
          '--base-url=[base URL for the server]:url' \
          '--out=[output file]:file:_files' \
          '1:base notebook:_files -g "*.ipynb"' \
          '2:local notebook:_files -g "*.ipynb"' \
          '3:remote notebook:_files -g "*.ipynb"' && ret=0
        ;;
      (show)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --sources)'{-s,--sources}'[show source cells]' \
          '(-o --outputs)'{-o,--outputs}'[show output cells]' \
          '(-a --attachments)'{-a,--attachments}'[show attachments]' \
          '(-m --metadata)'{-m,--metadata}'[show metadata]' \
          '1:notebook:_files -g "*.ipynb"' && ret=0
        ;;
      (config-git)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--enable[enable git integration]' \
          '--disable[disable git integration]' \
          '--global[configure at global level]' \
          '--system[configure at system level]' && ret=0
        ;;
      (extensions)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--enable[enable extensions]' \
          '--disable[disable extensions]' && ret=0
        ;;
    esac
    ;;
esac

return ret
