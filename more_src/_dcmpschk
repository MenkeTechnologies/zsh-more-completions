#compdef dcmpschk
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmpschk.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmpschk.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmpschk.cc OFCommandLine setup + dcmpstat/docs/dcmpschk.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(--validate-std --validate-related --validate-relaxed)--validate-std[GSPS images must belong to the same SOP class (default)]' \
  '(--validate-std --validate-related --validate-relaxed)--validate-related[GSPS images may belong to related for-presentation/for-processing SOP class]' \
  '(--validate-std --validate-related --validate-relaxed)--validate-relaxed[GSPS images may be any SOP class]' \
  '*:dcmfile-in:_files'
