#compdef json2parquet
# Documentation: https://man.archlinux.org/search?q=json2parquet
# Reference accessed: 2026-05-16

# Zsh completion for json2parquet (domoritz/arrow-tools).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --schema-file)'{-s,--schema-file=}'[Arrow schema JSON file]:file:_files' \
  '--max-read-records=[rows used for schema inference]:count:' \
  '(-c --compression)'{-c,--compression=}'[parquet compression]:compression:(uncompressed snappy gzip lzo brotli lz4 zstd lz4_raw)' \
  '(-e --encoding)'{-e,--encoding=}'[column encoding]:encoding:(plain plain_dictionary rle rle_dictionary delta_binary_packed delta_length_byte_array delta_byte_array byte_stream_split)' \
  '--data-page-size-limit=[data page size limit]:bytes:' \
  '--dictionary-page-size-limit=[dictionary page size limit]:bytes:' \
  '--write-batch-size=[write batch size]:rows:' \
  '--max-row-group-size=[max row group size]:size:' \
  '--created-by=[parquet created-by metadata]:string:' \
  '--dictionary[enable dictionary encoding]' \
  '(--statistics)'--statistics='[statistics granularity]:stats:(none chunk page)' \
  '(-p --print-schema)'{-p,--print-schema}'[print schema to stderr]' \
  '(-n --dry)'{-n,--dry}'[only print schema]' \
  '1:input JSON file:_files' \
  '2:output parquet file:_files'
