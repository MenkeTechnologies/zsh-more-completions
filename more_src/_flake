#compdef flake nix-flake nix-flakes
# _flake — Nix flake nix flake subcommand wrapper CLI alias (NixOS Foundation / Eelco Dolstra, C++); custom argparse
# upstream: https://github.com/NixOS/nix

_flake() {
    local -a sub=(
        'archive:bundle flake into archive'
        'check:run flake checks'
        'clone:clone flake'
        'info:show flake info (deprecated alias for metadata)'
        'init:create flake.nix from template'
        'lock:update lockfile'
        'metadata:show flake metadata'
        'new:create new flake from template'
        'prefetch:fetch flake input'
        'show:show outputs of flake'
        'update:update inputs in lockfile'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--update-input=+[update input]:list:' \
        '--override-input=+[override input]:str:' \
        '--no-update-lock-file[no update lock file]' \
        '--no-write-lock-file[no write lock file]' \
        '--inputs-from=+[inputs from flake]:str:' \
        '--no-registries[no registries]' \
        '--commit-lock-file[commit lock file]' \
        '--recreate-lock-file[recreate lock file]' \
        '--extra-experimental-features=+[extra experimental features]:list:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flake subcommand' sub ;;
        args)
            case $words[1] in
                init|new) _arguments \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '*:dest:_files -/' ;;
                check) _arguments \
                    '--no-build[no build]' \
                    '*:flake:' ;;
                update|lock|metadata|info|show|prefetch|archive|clone) _arguments '*:flake-ref:' ;;
            esac
            ;;
    esac
}

_flake "$@"
