#compdef haskdogs
# Documentation: https://github.com/sergei-mironov/haskdogs
# Recursive hasktags-based TAGS generator for a Haskell project and its nearest deps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help text]' \
  '--version[show version number]' \
  '(-d --dir-list)'{-d,--dir-list}'=[file containing directory list to process]:file:_files' \
  '(-f --file-list)'{-f,--file-list}'=[file containing Haskell sources to process]:file:_files' \
  '(-i --input)'{-i,--input}'=[single Haskell file to process]:file:_files' \
  '--hasktags-args=[arguments to pass to hasktags]:opts' \
  '--stack-args=[arguments to pass to stack]:opts' \
  '--ghc-pkg-args=[arguments to pass to ghc-pkg]:opts' \
  '--use-stack=[execute ghc-pkg via stack]:arg:(ON OFF AUTO)' \
  '--deps-dir=[directory to place the dependencies of the project]:path:_files -/' \
  "--raw[don't execute hasktags, print list of files to tag on STDOUT]" \
  '(-q --quiet)'{-q,--quiet}"[don't print verbose messages]" \
  '*:hasktags option:' && ret=0

return ret
