#compdef nuxt

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start development server'
  'build:build for production'
  'generate:generate static site'
  'preview:preview production build'
  'prepare:prepare for development'
  'start:start production server'
  'analyze:analyze production bundle'
  'typecheck:run type checking'
  'info:show project information'
  'init:initialize a new project'
  'add:add a template or module'
  'module:manage Nuxt modules'
  'upgrade:upgrade Nuxt'
  'cleanup:clean generated files'
  'devtools:enable or disable devtools'
  'test:run tests'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--cwd=[working directory]:directory:_directories' \
  '--log-level=[log level]:level:(silent info verbose)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nuxt command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (dev)
        _arguments \
          '--open[open browser on startup]' \
          '--no-clear[do not clear console]' \
          '--port=[server port]:port' \
          '--host=[server host]:host' \
          '--https[enable HTTPS]' \
          '--ssl-cert=[SSL certificate]:file:_files' \
          '--ssl-key=[SSL key]:file:_files' \
          '--dotenv=[path to .env file]:file:_files' \
          '--no-fork[do not fork child process]' \
          '*:root directory:_directories' && ret=0
        ;;
      (build)
        _arguments \
          '--prerender[prerender routes]' \
          '--dotenv=[path to .env file]:file:_files' \
          '*:root directory:_directories' && ret=0
        ;;
      (generate)
        _arguments \
          '--dotenv=[path to .env file]:file:_files' \
          '*:root directory:_directories' && ret=0
        ;;
      (preview)
        _arguments \
          '--port=[server port]:port' \
          '--host=[server host]:host' \
          '--dotenv=[path to .env file]:file:_files' \
          '*:root directory:_directories' && ret=0
        ;;
      (init)
        _arguments \
          '--template=[template name]:template' \
          '--package-manager=[package manager]:pm:(npm yarn pnpm bun)' \
          '--git-init[initialize git repository]' \
          '--no-install[skip dependency installation]' \
          '--force[overwrite existing files]' \
          '1:project name' && ret=0
        ;;
      (add)
        local -a add_types=(
          'module:add a Nuxt module'
          'plugin:add a plugin template'
          'composable:add a composable'
          'middleware:add a middleware'
          'api:add an API route'
          'page:add a page'
          'layout:add a layout'
          'component:add a component'
        )
        _arguments \
          '1:template type:_describe -t types "type" add_types' \
          '2:name' && ret=0
        ;;
      (upgrade)
        _arguments \
          '--force[force upgrade]' && ret=0
        ;;
      (analyze)
        _arguments \
          '--name=[analysis name]:name' \
          '*:root directory:_directories' && ret=0
        ;;
      (devtools)
        _arguments '1:state:(enable disable)' && ret=0
        ;;
    esac
    ;;
esac

return ret
