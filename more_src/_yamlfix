# Zsh completion for yamlfix - YAML auto-fixer

_arguments -s -S \
  '*'{-v,--verbose}'[enable verbose logging]' \
  '--check[check if files need fixing without writing]' \
  '*'{-c+,--config-file=}'[path to a custom configuration file]:config file:_files' \
  '--env-prefix=[environment variable prefix (default YAMLFIX)]:prefix:' \
  '*'{-e+,--exclude=}'[glob pattern to ignore]:pattern:' \
  '*'{-i+,--include=}'[glob pattern to include]:pattern:' \
  '--version[show version]' \
  '*:files:_files -g "*.(yml|yaml)"'
