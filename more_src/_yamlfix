#compdef yamlfix
# Documentation: https://man.archlinux.org/search?q=yamlfix
# Reference accessed: 2026-05-16

# Zsh completion for yamlfix - YAML auto-fixer

_arguments -s -S \
  '--check[check only, do not fix files]' \
  '--config-file=[path to configuration file]:config file:_files' \
  '--env-prefix=[environment variable prefix]:prefix:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:files:_files -g "*.{yml,yaml}"'
