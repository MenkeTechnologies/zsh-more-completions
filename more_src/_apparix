#compdef apparix
# Documentation: https://github.com/micans/apparix
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for apparix
# Upstream: File system navigation via bookmarking directories
# Conservative fallback — run `apparix --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
