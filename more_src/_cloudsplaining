#compdef cloudsplaining
# Documentation: https://github.com/salesforce/cloudsplaining
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cloudsplaining - AWS IAM security assessment

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'download:download IAM authorization details'
      'scan:scan IAM authorization details'
      'scan-policy-file:evaluate an individual IAM policy file'
      'scan-multi-account:scan multiple AWS accounts'
      'create-exclusions-file:create an exclusions file template'
      'create-multi-account-config-file:create multi-account configuration template'
    )
    _describe -t commands 'cloudsplaining command' commands && ret=0
    ;;
  args)
    case $line[1] in
      download)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--profile=[AWS profile]:profile' \
          '--output=[output file]:file:_files' \
          '--include-non-default-policy-versions[include all policy versions]' && ret=0
        ;;
      create-exclusions-file)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--output=[output file]:file:_files' && ret=0
        ;;
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--input-file=[input authorization details file]:file:_files' \
          '--exclusions-file=[exclusions config file]:file:_files -g "*.{yml,yaml}"' \
          '--output=[output directory]:directory:_directories' \
          '--skip-open-report[skip opening the report]' \
          '--severity=[minimum severity level]:severity:(INFORMATIONAL LOW MEDIUM HIGH CRITICAL)' && ret=0
        ;;
      scan-policy-file)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--input-file=[policy file]:file:_files' \
          '--exclusions-file=[exclusions config file]:file:_files -g "*.{yml,yaml}"' && ret=0
        ;;
      scan-multi-account)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[multi-account configuration file]:file:_files' \
          '--profile=[AWS profile]:profile' \
          '--role-name=[IAM role to assume in target accounts]:role' \
          '--output-bucket=[S3 bucket for results]:bucket' \
          '--output-directory=[local directory for results]:directory:_directories' && ret=0
        ;;
      create-multi-account-config-file)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
