#compdef cloudsplaining

# Zsh completion for cloudsplaining - AWS IAM security assessment

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'download:download IAM authorization details'
      'create-exclusions-file:create an exclusions file template'
      'scan:scan IAM authorization details'
      'create-report:create an HTML report'
    )
    _describe -t commands 'cloudsplaining command' commands && ret=0
    ;;
  args)
    case $line[1] in
      download)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--profile=[AWS profile]:profile' \
          '--output=[output file]:file:_files' \
          '--include-non-default-policy-sizes[include non-default policy sizes]' \
          '--skip-open-report[skip opening the report]' && ret=0
        ;;
      create-exclusions-file)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--output=[output file]:file:_files' && ret=0
        ;;
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--input-file=[input authorization details file]:file:_files' \
          '--exclusions-file=[exclusions config file]:file:_files -g "*.{yml,yaml}"' \
          '--output=[output directory]:directory:_directories' \
          '--skip-open-report[skip opening the report]' \
          '--severity=[minimum severity level]:severity:(INFORMATIONAL LOW MEDIUM HIGH CRITICAL)' && ret=0
        ;;
      create-report)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--input-file=[input scan results file]:file:_files' \
          '--output=[output directory]:directory:_directories' \
          '--skip-open-report[skip opening the report]' && ret=0
        ;;
    esac
    ;;
esac

return ret
