#compdef temporalite

# Zsh completion for temporalite - all-in-one Temporal dev server

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start the Temporal server'
    )
    _describe -t commands 'temporalite command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start)
        _arguments -s -S \
          '--ephemeral[use in-memory storage]' \
          '--db-filename=[database file path]:database file:_files' \
          '*'{-n,--namespace}'[default namespace to register]:namespace' \
          '(-p --port)'{-p,--port}'[frontend port]:port' \
          '--metrics-port=[metrics port]:port' \
          '--ui-port=[UI port]:port' \
          '--headless[disable the UI]' \
          '--ip=[IP address to bind]:ip address' \
          '--log-format=[log format]:format:(json pretty)' \
          '--log-level=[log level]:level:(debug info warn error fatal)' \
          '*--pragma=[SQLite pragma]:pragma' \
          '*--sqlite-pragma=[SQLite pragma]:pragma' \
          '*--dynamic-config-value=[dynamic config value]:value' && ret=0
        ;;
    esac
    ;;
esac

return ret
