local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# GpuMode enum values from FromStr impl at
# cli_options.rs:24-29
local -a gpu_modes=(
  'drm:DRM-based GPU virtualization'
  'venus:Venus Vulkan-over-virtio'
  'software:software rendering (no GPU passthrough)'
)
local -a emulators=(
  'box:Box86/64 x86 emulator (fallback)'
  'fex:FEX x86 emulator (default if available)'
)

# 16 named options + 2 positionals decoded
# source-direct from cli_options.rs options()
# function combinator chain.
_arguments -s -S \
  '(- *)'{-h,--help}'[display bpaf auto-generated help]' \
  '(-c --cpu-list)'{-c+,--cpu-list=}'[CPU list to bind microVM to (e.g. 0,5,8-11)]:CPU list:' \
  '*'{-e+,--env=}'[environment variable (KEY=VALUE or KEY to inherit)]:env var:' \
  '--emu=[which emulator to use]:emulator:->emulators' \
  '--mem=[RAM in MiB (default: 80% of total)]:MiB:' \
  '--vram=[Video RAM in MiB (default: 50% of total)]:MiB:' \
  '*'{-f+,--fex-image=}'[FEX rootfs erofs image (repeatable)]:erofs file:_files -g "*.erofs"' \
  '(-m --merged-rootfs)'{-m,--merged-rootfs}'[use merged rootfs for FEX (experimental)]' \
  '--passt-socket=[connect to existing passt socket]:passt socket:_files' \
  '*--passt-args=[extra passt arguments (shell-quoted)]:passt args:' \
  '(-i --interactive)'{-i,--interactive}'[attach to command stdin/out]' \
  '(-t --tty)'{-t,--tty}'[allocate a tty for the command]' \
  '--privileged[run command as root inside the VM]' \
  '--gpu-mode=[GPU virtualization method]:mode:->gpu_modes' \
  '*'{-p+,--publish=}'[publish guest port(s) to host (podman/docker syntax)]:[IP:][HOST_PORT]:GUEST_PORT[/PROTO]:' \
  '*'{-x+,--execute-pre=}'[pre-init command as root in VM (repeatable)]:command:' \
  '*'{-X+,--user-execute-pre=}'[pre-init command as user in VM (repeatable)]:command:' \
  '1:command to execute in VM:_command_names -e' \
  '*::command args:_normal' && ret=0

case $state in
  gpu_modes)
    _describe -t gpu_modes 'GPU virtualization mode' gpu_modes && ret=0
    ;;
  emulators)
    _describe -t emulators 'x86 emulator' emulators && ret=0
    ;;
esac

return ret
