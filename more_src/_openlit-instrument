#compdef openlit-instrument
# Documentation: https://github.com/openlit/openlit
# Reference accessed: 2026-05-23
# Verified: openlit-instrument --help (openlit PyPI console script).

# Zsh completion for openlit-instrument - OpenLIT OpenTelemetry auto-instrumentation wrapper

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--environment[deployment environment]:env:' \
  '--application_name[application name]:name:' \
  '--service_name[service name]:name:' \
  '--otlp_endpoint[OTLP endpoint]:url:' \
  '--otlp_headers[OTLP headers]:headers:' \
  '--disable_batch[disable batch span export]' \
  '--capture_message_content[capture message content in spans]' \
  '--disabled_instrumentors[disabled instrumentors]:list:' \
  '--controller_mode[controller mode]:mode:' \
  '--disable_metrics[disable metrics]' \
  '--disable_events[disable events]' \
  '--pricing_json[pricing JSON path]:file:_files' \
  '--collect_gpu_stats[collect GPU stats]' \
  '--collect_system_metrics[collect system metrics]' \
  '--capture_db_parameters[capture DB query parameters]' \
  '--evals_logs_export[export eval logs]' \
  '--max_content_length[max captured content length]:n:' \
  '--custom_span_attributes[custom span attributes]:attrs:' \
  '--custom_metrics_attributes[custom metrics attributes]:attrs:' \
  '--version[show version]' \
  '1:command:command:' \
  '*:command args:' && ret=0

return ret
