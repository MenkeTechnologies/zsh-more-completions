#compdef bootchart systemd-bootchart
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-r --rel)'{-r,--rel}'[use relative timestamps]' \
  '(-f --freq)'{-f,--freq=}'[sampling frequency in Hz]:frequency (Hz)' \
  '(-n --samples)'{-n,--samples=}'[number of samples to record]:samples' \
  '(-x --scale-x)'{-x,--scale-x=}'[horizontal scale factor]:scale' \
  '(-y --scale-y)'{-y,--scale-y=}'[vertical scale factor]:scale' \
  '(-p --pss)'{-p,--pss}'[show PSS (proportional set size)]' \
  '(-e --entropy)'{-e,--entropy}'[show entropy]' \
  '(-o --output)'{-o,--output=}'[output directory]:directory:_directories' \
  '(-i --init)'{-i,--init=}'[init binary to use]:init binary:_files' \
  '--no-filter[disable process filtering]' \
  '(-C --cmdline)'{-C,--cmdline}'[show full command lines]' \
  '(-c --control-group)'{-c,--control-group}'[show control groups]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' && ret=0
return ret
