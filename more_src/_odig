#compdef odig
# Documentation: https://github.com/dbuenzli/odig/blob/master/src/odig_main.ml
# Reference accessed: 2026-05-27
# Verified: upstream src/odig_main.ml cmdliner term definitions (dbuenzli/odig)

# Zsh completion for odig (OCaml package documentation browser)

local curcontext="$curcontext" state line ret=1

local -a _odig_subcommands
_odig_subcommands=(
  'browse:open package metadata URIs (homepage/issues/online-doc) in your browser'
  'cache:operate on the odig cache (clear/path/trim)'
  'changes:output package change log files'
  'conf:output odig configuration'
  'doc:show odoc API documentation and manuals'
  'info:output package metadata fields'
  'license:output package license files'
  'log:output odoc build log'
  'odoc:generate odoc API documentation and manuals'
  'odoc-theme:list and set the theme used by odoc documentation'
  'pkg:list packages known to odig'
  'readme:output package readme files'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version]' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '--doc-dir=[documentation directory]:dir:_files -/' \
  '--lib-dir=[library directory]:dir:_files -/' \
  '--share-dir=[share directory]:dir:_files -/' \
  '--odoc-theme=[theme to use for odoc documentation]:theme:' \
  '(-j --jobs)'{-j+,--jobs=}'[number of concurrent jobs]:n:' \
  '--color=[colorize the output]:when:(auto always never)' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'odig subcommand' _odig_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      browse)
        _arguments \
          '--background[show URL but keep terminal focused]' \
          '--browser=[browser command]:cmd:_command_names -e' \
          '--prefix[run browser command as a prefix]' \
          '1:field:(homepage issues online-doc)' \
          '*:pkg:' && ret=0
        ;;
      cache)
        local -a _odig_cache_sub
        _odig_cache_sub=(
          'clear:clear the cache'
          'path:output cache directory path'
          'trim:trim cache without affecting generated docs'
        )
        _describe -t commands 'odig cache' _odig_cache_sub && ret=0
        ;;
      doc)
        _arguments \
          '--background[show URL but keep terminal focused]' \
          '--browser=[browser command]:cmd:_command_names -e' \
          '(-u --update)'{-u,--update}'[update docs that are out of date]' \
          '(-n --no-update)'{-n,--no-update}'[never try to update the docs]' \
          '(-t --output-path)'{-t,--output-path}'[output file paths on stdout instead of opening]' \
          '*:pkg:' && ret=0
        ;;
      info)
        _arguments \
          '(-e --keep-empty)'{-e,--keep-empty}'[keep empty fields in output]' \
          '--no-pager[do not pipe output through pager]' \
          '(-s --short)'{-s,--short}'[short output details]' \
          '(-l --long)'{-l,--long}'[long output details]' \
          '1:field:' \
          '*:pkg:' && ret=0
        ;;
      odoc)
        _arguments \
          '--index-title=[title of the package list page]:title:' \
          '--index-intro=[mld file for the introduction text]:file:_files' \
          '--index-toc=[mld file for the table of contents]:file:_files' \
          '--no-pkg-deps[do not include dependencies in the result]' \
          '--no-tag-index[do not generate the tag index]' \
          '*:pkg:' && ret=0
        ;;
      odoc-theme)
        local -a _odig_theme_sub
        _odig_theme_sub=(
          'get:get the theme used on documentation generation'
          'list:list available themes (default)'
          'path:output theme directory'
          'set:set theme used on documentation generation'
        )
        _describe -t commands 'odig odoc-theme' _odig_theme_sub && ret=0
        ;;
      log)
        _arguments \
          '--no-pager[do not pipe output through pager]' \
          '--format=[log output format]:fmt:(short normal long trace-event)' \
          '(-s --short)'{-s,--short}'[short output details]' \
          '(-l --long)'{-l,--long}'[long output details]' && ret=0
        ;;
      pkg)
        _arguments \
          '--no-pager[do not pipe output through pager]' \
          '(-s --short)'{-s,--short}'[short output details]' \
          '(-l --long)'{-l,--long}'[long output details]' \
          '*:pkg:' && ret=0
        ;;
      changes|readme|license)
        _arguments \
          '--no-pager[do not pipe output through pager]' \
          '*:pkg:' && ret=0
        ;;
      conf)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
