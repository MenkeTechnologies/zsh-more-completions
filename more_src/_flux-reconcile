#compdef flux-reconcile
# Documentation: https://fluxcd.io/flux/cmd/flux_reconcile/
# FluxCD reconcile: trigger resource synchronization

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--cluster=[name of the kubeconfig cluster to use]:cluster:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(helmrelease image kustomization receiver source)' && ret=0

return ret
