#compdef timedatectl-cli
# _timedatectl-cli — systemd timedatectl control the system time and date CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_timedatectl-cli() {
    local -a sub=(
        'status:show current settings'
        'show:show properties'
        'set-time:set current time'
        'set-timezone:set timezone'
        'list-timezones:list timezones'
        'set-local-rtc:set if RTC is in local time'
        'set-ntp:enable/disable NTP'
        'show-timesync:show timesync info'
        'timesync-status:show timesync status'
        'ntp-servers:set NTP servers'
        'revert:revert NTP servers'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-ask-password[no ask password]' \
        '--adjust-system-clock[adjust system clock]' \
        '--monitor[monitor mode]' \
        '-p+[property]:str:' \
        '--property=+[property]:str:' \
        '-a[all]' \
        '--all[all]' \
        '--value[value only]' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'timedatectl subcommand' sub ;;
    esac
}

_timedatectl-cli "$@"
