#compdef lockbook
# Documentation: https://github.com/lockbook/cli-rs
# Reference accessed: 2026-05-19
# Verified: upstream cli-rs intercepts `complete <shell> <idx> [input]` at parser.rs:124.
function _lockbook {
    comp_output=$( lockbook complete zsh "$(($CURRENT - 1))" "${words[*]}" )
    eval ${comp_output}
}

