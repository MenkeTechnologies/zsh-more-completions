#compdef dar_manager
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/dar_manager.1.html
# dar_manager - compiles several archives contents in a database to ease file restoration

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[show software version]' \
  '(-C --create)'{-C,--create}'[create an empty database]:database:_files' \
  '(-B --base)'{-B,--base}'[database to read or modify]:database:_files' \
  '(-A --add)'{-A,--add}'[add an archive to the database]:archive basename:_files' \
  '(-9 --min-digits)'{-9,--min-digits}'[minimum digits for slice numbers]:number' \
  '(-l --list)'{-l,--list}'[display information about archives in the database]' \
  '(-D --delete)'{-D,--delete}'[remove archive(s) from the database]:archive number(s)' \
  '(-b --basename)'{-b,--basename}'[rename an archive basename]:number,name' \
  '(-p --path)'{-p,--path}'[change an archive location]:number,path' \
  '(-o --options)'{-o,--options}'[options to pass to dar during restoration]:dar options' \
  '(-d --dar)'{-d,--dar}'[set the path to the dar executable]::dar path:_files' \
  '(-r --restore)'{-r,--restore}'[restore files in their latest recorded status]:*:files' \
  '(-w --when)'{-w,--when}'[restore files before the given date]:date' \
  '(-e --extra)'{-e,--extra}'[pass extra options to dar without modifying database]:options' \
  '(-u --used)'{-u,--used}'[list files for which given archive has the most recent version]:archive number' \
  '(-f --file)'{-f,--file}'[display which archive contains a given file]:filename:_files' \
  '(-s --stats)'{-s,--stats}'[show count of recent files per archive]' \
  '(-m --move)'{-m,--move}'[change archive order in the database]:number number' \
  '(-c --check)'{-c,--check}'[verify database consistency]' \
  '(-N --ignore-options-in-base)'{-N,--ignore-options-in-base}'[ignore stored options during restoration]' \
  '(-k --ignore-when-removed)'{-k,--ignore-when-removed}'[restore files marked as removed]' \
  '(-ai --alter)'{-ai,--alter=ignore-order}'[suppress chronological ordering warnings]' \
  '(-@ --batch)'{-@,--batch}'[process multiple operations from a file]:batch file:_files' \
  '(-z --compression)'{-z,--compression}'[set database compression method]:algorithm[\:level]' \
  '-Q[suppress stderr output when not on a terminal]' \
  '(-v --verbose)'{-v,--verbose}'[display additional operational information]' \
  '*:file:_files' && ret=0

return ret
