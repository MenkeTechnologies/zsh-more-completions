#compdef rbac-lookup
# Documentation: https://man.archlinux.org/search?q=rbac-lookup
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-n --namespace)'{-n,--namespace}'=[Namespace]:namespace:' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[Kubeconfig path]:file:_files' \
  '(-u --user)'{-u,--user}'[Show bindings for user subject]' \
  '(-g --group)'{-g,--group}'[Show bindings for group subject]' \
  '(-s --serviceaccount)'{-s,--serviceaccount}'=[Service account name.serviceaccount.namespace]:sa:' \
  '*::args: _default'
