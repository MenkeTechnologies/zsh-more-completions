#compdef pico2wave
# _pico2wave — convert text to WAV using SVOX Pico TTS (naggety/picotts)
# upstream: https://github.com/naggety/picotts
# Flags from pico/bin/pico2wave.c (popt).

_pico2wave() {
    _arguments \
        '(- *)'{-\?,--help}'[show help]' \
        '--usage[show short usage]' \
        '(-w --wave)'{-w+,--wave=}'[write output to WAV file]:file:_files -g "*.wav"' \
        '(-l --lang)'{-l+,--lang=}'[voice language]:lang:(en-US en-GB de-DE es-ES fr-FR it-IT)' \
        '*:text:'
}

_pico2wave "$@"
