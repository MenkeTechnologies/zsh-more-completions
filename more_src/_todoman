#compdef todoman

# completions for todoman todo manager CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  '--colour=[color mode]:mode:(always auto never)' \
  '--porcelain[machine-readable output]' \
  '--humanize[humanize dates and times]' \
  {-c+,--config=}'[configuration file]:file:_files' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'cancel:cancel a todo'
      'copy:copy a todo to another list'
      'delete:delete a todo'
      'done:mark a todo as done'
      'edit:edit a todo'
      'flush:delete completed todos'
      'list:list todos'
      'move:move a todo to another list'
      'new:create a new todo'
      'show:show a single todo'
    )
    _describe -t commands 'todoman command' commands && ret=0
    ;;
esac

return ret
