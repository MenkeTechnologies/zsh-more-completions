#compdef JLinkSWOViewer
# Documentation: https://kb.segger.com/J-Link_SWO_Viewer
# SEGGER J-Link SWO Viewer — capture SWO/ITM printf and trace output via J-Link

local ret=1

_arguments -s -S \
  '-cpufreq[current CPU speed in Hz]:hz:' \
  '-device[target device for CPU frequency auto detection]:device:' \
  '-itmmask[set of stimulus ports to display]:mask:' \
  '-itmport[stimulus port to display]:port:' \
  '-outputfile[file to print SWO Viewer output to]:file:_files' \
  '-jlinkscriptfile[J-Link script file to use]:file:_files' \
  '-swoattach[start in SWO attach mode (requires -swofreq)]' \
  '-swofreq[SWO sampling frequency]:hz:' \
  '-usb[connect via USB serial number or nickname]:sn:' \
  '-ip[select IP as host interface]:host:' && ret=0

return ret
