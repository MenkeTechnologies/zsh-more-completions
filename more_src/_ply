#compdef ply
# Documentation: https://github.com/wkz/ply (src/ply/ply.c getopt_long)
# Reference accessed: 2026-05-29
# ply — lightweight dynamic tracer for Linux: compiles dtrace/awk-style scripts to BPF.
# Only depends on libc at runtime. C-like syntax with kprobe/kretprobe/tracepoint actions.
# Multi-arch: x86_64, aarch64, arm, loongarch, mips, riscv32/64, powerpc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print usage message and exit]' \
  '(- *)'{-v,--version}'[print version information]' \
  '(-c --command)'{-c,--command=}'[run COMMAND in a shell, exit upon completion]:command:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-e --dry-run)'{-e,--dry-run}'[exit after compiling (no BPF load)]' \
  '(-k --keep-going)'{-k,--keep-going}'[keep going in face of trace buffer overruns]' \
  '(-S --dump)'{-S,--dump}'[show generated BPF]' \
  '(-T --self-test)'{-T,--self-test}'[run self-test]' \
  '(-u --unbuffer)'{-u,--unbuffer}'[always turn off buffering of stdout/stderr]' \
  '1:script (e.g. "kretprobe\:vfs_read { @[\"size\"] = quantize(retval); }"):' \
  && ret=0

return ret
