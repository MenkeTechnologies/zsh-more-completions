#compdef gatel
# Documentation: https://man.archlinux.org/search?q=gatel
# Reference accessed: 2026-05-16
# Source: cargo binstall gatel@0.1.2
# Probed via: completions zsh
# Repository: https://github.com/salvo-rs/gatel

autoload -U is-at-least

_gatel() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_gatel_commands" \
"*::: :->gatel" \
&& ret=0
    case $state in
    (gatel)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gatel-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the KDL configuration file]:CONFIG:_default' \
'--config=[Path to the KDL configuration file]:CONFIG:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the KDL configuration file]:CONFIG:_default' \
'--config=[Path to the KDL configuration file]:CONFIG:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(reload)
_arguments "${_arguments_options[@]}" : \
'-c+[Path to the KDL configuration file (used to discover admin address)]:CONFIG:_default' \
'--config=[Path to the KDL configuration file (used to discover admin address)]:CONFIG:_default' \
'-a+[Admin API address (overrides address from config file)]:ADDRESS:_default' \
'--address=[Admin API address (overrides address from config file)]:ADDRESS:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
'-p+[Listen port]:PORT:_default' \
'--port=[Listen port]:PORT:_default' \
'-l+[Listen address]:LISTEN:_default' \
'--listen=[Listen address]:LISTEN:_default' \
'-b[Enable directory browsing]' \
'--browse[Enable directory browsing]' \
'-h[Print help]' \
'--help[Print help]' \
'::root -- Directory to serve:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(man-page)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_gatel__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gatel-help-command-$line[1]:"
        case $line[1] in
            (run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(reload)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(serve)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(man-page)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_gatel_commands] )) ||
_gatel_commands() {
    local commands; commands=(
'run:Run the proxy server' \
'validate:Validate a configuration file without starting the server' \
'reload:Reload the running server'\''s configuration via the admin API' \
'serve:Quickly serve static files (development helper)' \
'completions:Generate shell completions' \
'man-page:Generate man page' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gatel commands' commands "$@"
}
(( $+functions[_gatel__completions_commands] )) ||
_gatel__completions_commands() {
    local commands; commands=()
    _describe -t commands 'gatel completions commands' commands "$@"
}
