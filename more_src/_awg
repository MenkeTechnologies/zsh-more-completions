#compdef awg awg-quick
# Documentation: https://github.com/amnezia-vpn/amneziawg-tools
# Reference accessed: 2026-05-17
# Verified: amnezia-vpn/amneziawg-tools — drop-in WireGuard fork
# with same subcommands (show, showconf, set, setconf, addconf,
# syncconf, genkey, pubkey, genpsk) plus AmneziaWG obfuscation
# parameters on `set` (jc, jmin, jmax, s1, s2, h1-h4, i1-i5).
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'show:show config and runtime info'
  'showconf:print interface config'
  'set:modify interface config'
  'setconf:replace interface config'
  'addconf:append config'
  'syncconf:apply diff only'
  'genkey:generate private key'
  'genpsk:generate preshared key'
  'pubkey:derive public key from stdin'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'awg subcommand' subcommands && ret=0
    ;;
esac

return ret
