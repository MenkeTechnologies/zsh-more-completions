#compdef last-train
# Documentation: https://gitlab.com/mcfrith/last/-/raw/main/doc/last-train.rst
# Find the rates of insertion, deletion, and substitutions between two sets of sequences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show a help message, with default option values, and exit]' \
  '(-v --verbose)'{-v,--verbose}'[show more details of intermediate steps]' \
  '--revsym[force the substitution scores to have reverse-complement symmetry]' \
  '--matsym[force the substitution scores to have directional symmetry]' \
  '--gapsym[force the insertion costs to equal the deletion costs]' \
  '--fixmat=[fix substitution probabilities to BLOSUM or PAM matrices]:name:' \
  '--pid=[ignore similar segments with more than PID% identity]:pid:' \
  '--postmask=[control masking of lowercase sequence alignments]:number:' \
  '--sample-number=[use N randomly-chosen chunks of the query sequences]:n:' \
  '--sample-length=[use randomly-chosen chunks of length L]:l:' \
  '--scale=[output scores in units of 1/S bits]:s:' \
  '--codon[do training for DNA query sequences versus protein reference sequences]' \
  '-r+[initial match score]:score:' \
  '-q+[initial mismatch cost]:cost:' \
  '-p+[initial match/mismatch score matrix]:name:' \
  '-a+[initial gap existence cost]:cost:' \
  '-b+[initial gap extension cost]:cost:' \
  '-A+[initial insertion existence cost]:cost:' \
  '-B+[initial insertion extension cost]:cost:' \
  '-F+[initial frameshift probabilities (codon mode only)]:list:' \
  '-D+[query letters per random alignment]:length:' \
  '-E+[maximum expected alignments per square giga]:eg2:' \
  '-s+[which query strand to use: 0=reverse, 1=forward, 2=both]:number:' \
  '-S+[specify substitution score matrix use for reverse strands]:number:' \
  '-C+[discard low-scoring gapless alignments before extension]:count:' \
  '-T+[type of alignment: 0=local, 1=overlap]:number:' \
  '-R+[lowercase and simple-sequence options]:digits:' \
  '-m+[maximum number of initial matches per query position]:count:' \
  '-k+[look for initial matches only at every STEP-th position]:step:' \
  '-P+[number of parallel threads]:count:' \
  '-X+[how to score matches/mismatches involving N or X]:number:' \
  '-Q+[how to read the query sequences]:name:' \
  '*:database and query:_files' && ret=0

return ret
