#compdef migrate

# Zsh completion for migrate (golang-migrate database migration CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-version[Print version]' \
  '-source=[Location of migration files]:url' \
  '-path=[Shorthand for -source=file://path]:path:_directories' \
  '-database=[Database connection URL]:url' \
  '-prefetch=[Number of migrations to load in advance]:n' \
  '-lock-timeout=[Lock timeout in seconds]:seconds' \
  '-verbose[Enable verbose logging]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:Create a set of timestamped up/down migration files'
      'goto:Migrate to a specific version'
      'up:Apply all or N up migrations'
      'down:Apply all or N down migrations'
      'drop:Drop everything inside the database'
      'force:Set version but do not run migration'
      'version:Print current migration version'
    )
    _describe -t commands 'migrate command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '-ext=[File extension]:ext' \
          '-dir=[Directory to create migration files in]:dir:_directories' \
          '-seq[Use sequential numbering instead of timestamps]' \
          '-digits=[Number of digits for sequential numbering]:digits' \
          '-format=[Timestamp format]:format' \
          '1:migration name' && ret=0
        ;;
      goto)
        _arguments -s -S \
          '1:version' && ret=0
        ;;
      up)
        _arguments -s -S \
          '1::number of migrations' && ret=0
        ;;
      down)
        _arguments -s -S \
          '-all[Apply all down migrations]' \
          '1::number of migrations' && ret=0
        ;;
      drop)
        _arguments -s -S \
          '-f[Skip confirmation prompt]' && ret=0
        ;;
      force)
        _arguments -s -S \
          '1:version' && ret=0
        ;;
    esac
    ;;
esac

return ret
