#compdef karma2ppm
# Documentation: https://www.atnf.csiro.au/computing/software/karma/user-manual/node13.html
# Karma tool to convert a Karma image or cube into one or more PPM files

local ret=1

_arguments -s \
  'cmapfile=[colourmap file to apply]:file:_files' \
  'converter=[NetPBM converter to pipe output through]:converter' \
  'extension=[filename extension for output files]:extension' \
  'out_width=[output image width in pixels]:width' \
  'out_height=[output image height in pixels]:height' \
  '*:file:_files' && ret=0

return ret
