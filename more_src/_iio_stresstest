#compdef iio_stresstest
# _iio_stresstest — multi-thread IIO buffer capture stress test (analogdevicesinc/libiio)
# upstream: https://github.com/analogdevicesinc/libiio
# Flags from utils/iio_stresstest.c (getopt_long).

_iio_stresstest() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-u --uri)'{-u+,--uri=}'[IIO context URI]:uri:' \
        '(-b --buffer-size)'{-b+,--buffer-size=}'[capture buffer size]:n:' \
        '(-d --duration)'{-d+,--duration=}'[seconds between stopping all threads]:secs:' \
        '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
        '*'{-v,--verbose}'[verbose (repeatable: -v, -vv, -vvv)]' \
        ':IIO device:' \
        '*:channel:'
}

_iio_stresstest "$@"
