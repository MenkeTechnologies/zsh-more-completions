#compdef mosquitto_rr
# Documentation: https://mosquitto.org/man/mosquitto_rr-1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mosquitto_rr: MQTT request/response client. Flags from upstream man page.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show usage information]' \
  '(-h --host)'{-h+,--host=}'[broker host]:host:_hosts' \
  '--unix=[local unix domain socket path]:socket:_files' \
  '(-p --port)'{-p+,--port=}'[broker port]:port' \
  '(-L --url)'{-L+,--url=}'[connection URL]:url' \
  '-A+[bind outgoing connection to local address]:address' \
  '--nodelay[disable TCP Nagle algorithm]' \
  '-S[use SRV lookups]' \
  '--ws[use MQTT over WebSockets]' \
  '--proxy=[SOCKS5 proxy URL]:url' \
  '(-u --username)'{-u+,--username=}'[broker authentication username]:user:_users' \
  '(-P --pw)'{-P+,--pw=}'[broker authentication password]:password' \
  '--latency[measure request/response latency]' \
  '-o+[config file path]:file:_files' \
  '-W+[message processing timeout (seconds)]:seconds' \
  '(-c --disable-clean-session)'{-c,--disable-clean-session}'[persistent client mode]' \
  '*'{-D+,--property=}'[set MQTT v5 property]:property' \
  '(-i --id)'{-i+,--id=}'[client identifier]:id' \
  '(-I --id-prefix)'{-I+,--id-prefix=}'[client ID prefix]:prefix' \
  '(-k --keepalive)'{-k+,--keepalive=}'[keepalive interval (seconds)]:seconds' \
  '(-q --qos)'{-q+,--qos=}'[quality of service level]:qos:(0 1 2)' \
  '--retain-handling=[retain message handling]:mode:(0 1 2)' \
  '(-V --protocol-version)'{-V+,--protocol-version=}'[MQTT protocol version]:version:(mqttv31 mqttv311 mqttv5)' \
  '-x+[session expiry interval]:seconds' \
  '--will-topic=[will message topic]:topic' \
  '--will-payload=[will message content]:payload' \
  '--will-qos=[will message QoS]:qos:(0 1 2)' \
  '--will-retain[retain will message]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '-N[suppress end-of-line character]' \
  '--pretty[formatted JSON output]' \
  '--quiet[suppress runtime errors]' \
  '-R[hide retained messages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output format]' \
  '-F+[custom output format string]:format' \
  '(-f --file)'{-f+,--file=}'[message from file]:file:_files' \
  '(-m --message)'{-m+,--message=}'[message from command line]:message' \
  '(-n --null-message)'{-n,--null-message}'[zero-length message]' \
  '(-s --stdin-file)'{-s,--stdin-file}'[message from stdin]' \
  '(-t --topic)'{-t+,--topic=}'[request message topic]:topic' \
  '-e+[response subscription topic]:topic' \
  '--no-tls[disable TLS encryption]' \
  '--cafile=[CA certificate file]:file:_files' \
  '--capath=[CA certificates directory]:dir:_directories' \
  '--cert=[client certificate file]:file:_files' \
  '--key=[client private key file]:file:_files' \
  '--ciphers=[TLS cipher list]:ciphers' \
  '--insecure[disable hostname verification]' \
  '--keyform=[private key format]:format:(pem engine)' \
  '--tls-alpn=[TLS ALPN protocol]:name' \
  '--tls-engine=[OpenSSL engine ID]:engine' \
  '--tls-engine-kpass-sha1=[engine password SHA1]:hash' \
  '--tls-keylog=[TLS keylog file]:file:_files' \
  '--tls-use-os-certs[use OS-provided certificates]' \
  '--tls-version=[TLS protocol version]:version:(tlsv1.2 tlsv1.3)' \
  '--psk=[pre-shared key (hexadecimal)]:key' \
  '--psk-identity=[PSK client identity]:identity' && ret=0

return ret
