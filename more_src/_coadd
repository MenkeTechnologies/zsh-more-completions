#compdef coadd
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/coadd.1 — co-add images for astrometry.net (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-w+[output WCS file (default: input file)]:file:_files -g "*.{wcs,fits,fit}"' \
    '-e+[FITS extension for WCS (default 0)]:n:_default' \
    '-o+[output image file]:file:_files' \
    '-O+[Lanczos order (default 3)]:n:_default' \
    '-p+[image plane (default 0)]:n:_default' \
    '-N[use nearest-neighbour resampling]' \
    '-s+[smooth (sigma) before resampling]:n:_default' \
    '-D[divide each image by its weight image]' \
    '-v[verbose]' \
    '*:image ext weight ext wcs ext:_default' \
    && ret=0

return ret
