#compdef slapauth
# _slapauth — OpenLDAP slapauth (offline test of SASL identity mapping rules expressed in slapd.conf authz-regexp / authz-policy clauses; -F config dir, -f slapd.conf, -m authzID type (auth|proxy), -O override mech, -R realm, -X authzID, -U mech specific username, -d debug, -v verbose, -V version; positional argument is the authentication DN)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapauth)
# Flags from OpenLDAP servers/slapd/slapauth.c on tip.

_slapauth() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-m+[authzID type]:type:(auth proxy)' \
        '-O+[override mech]:mech:' \
        '-R+[realm]:realm:' \
        '-X+[authzID]:authzid:' \
        '-U+[username]:user:_users' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '1::DN:'
}

_slapauth "$@"
