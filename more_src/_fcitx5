#compdef fcitx5

# Zsh completion for fcitx5 - input method framework

_arguments -s -S \
  '-d[run as daemon]' \
  '-D[do not run as daemon]' \
  '-s+[override the log level]:level:(0 1 2 3 4 5)' \
  '-u+[override addon UI]:ui:' \
  '--enable[enable addons, separated by comma]:addons:' \
  '--disable[disable addons, separated by comma]:addons:' \
  '--verbose[set verbose logging domain]:domain:' \
  '-r[restart]' \
  '-v[show version information and quit]' \
  '-h[show help and quit]'
