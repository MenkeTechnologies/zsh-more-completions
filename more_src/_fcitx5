#compdef fcitx5
# Documentation: https://github.com/fcitx/fcitx5
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fcitx5 - input method framework

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and quit]' \
  '(- *)'{-v,--version}'[show version information and quit]' \
  '-d[run as daemon]' \
  '-D[run in foreground (default)]' \
  '-s+[delay startup by N seconds]:seconds:' \
  {-u+,--ui=}'[select UI addon]:ui addon:' \
  '--enable=[enable addons, comma-separated]:addons:' \
  '--disable=[disable addons, comma-separated]:addons:' \
  '--verbose=[set logging rule (category=level)]:rule:' \
  {-k,--keep}'[keep running when display disconnects]' \
  {-r,--replace}'[replace existing instance]' \
  {-o+,--option=}'[pass options to addons]:name=opts:'
