#compdef crio
# _crio — CRI-O OCI-compliant Kubernetes Container Runtime Interface daemon
# upstream: https://github.com/cri-o/cri-o
# Top-level flags from internal/criocli/criocli.go on tip (urfave/cli/v2); subcommands from internal/criocli/{check,config,publish,status,version,wipe,completion}.go.

_crio() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--config=[crio.conf path]:file:_files' \
        '--config-dir=[crio.conf.d drop-in directory]:dir:_files -/' \
        '--root=[graph root directory]:dir:_files -/' \
        '--runroot=[runtime root directory]:dir:_files -/' \
        '--imagestore=[alternate image store directory]:dir:_files -/' \
        '--storage-driver=[storage graph driver]:driver:(overlay vfs btrfs aufs zfs)' \
        '*--storage-opt=[storage driver option]:opt:' \
        '--listen=[Unix socket path for CRI gRPC]:socket:_files' \
        '--stream-address=[address for streaming server]:addr:' \
        '--stream-port=[port for streaming server]:port:' \
        '--conmon=[conmon binary]:file:_files' \
        '--conmon-cgroup=[cgroup for conmon]:cgroup:' \
        '--log=[log file]:file:_files' \
        '--log-format=[log format]:fmt:(text json)' \
        '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
        '--log-filter=[log filter regex]:regex:' \
        '--log-dir=[directory for container logs]:dir:_files -/' \
        '--log-size-max=[max container log size]:bytes:' \
        '--log-journald=[mirror container logs to journald]:bool:(true false)' \
        '--pause-command=[command run by the pause image]:cmd:' \
        '--pause-image=[pause container image]:image:' \
        '--pause-image-auth-file=[auth file for pause image pull]:file:_files' \
        '--separate-pull-cgroup=[separate cgroup for image pulls]:cgroup:' \
        '--global-auth-file=[global registry auth file]:file:_files' \
        '--namespaced-auth-dir=[per-namespace auth dir]:dir:_files -/' \
        '--signature-policy=[signature policy file]:file:_files' \
        '--signature-policy-dir=[signature policy drop-in dir]:dir:_files -/' \
        '*--insecure-registry=[allow insecure registry]:host:' \
        '--default-transport=[default image transport]:transport:(docker oci dir tarball)' \
        '--decryption-keys-path=[directory containing image decryption keys]:dir:_files -/' \
        '*--additional-artifact-stores=[extra OCI artifact stores]:dir:_files -/' \
        '--default-runtime=[name of default runtime in --runtimes]:name:' \
        '*--runtimes=[runtime handler spec]:spec:' \
        '--seccomp-profile=[default seccomp profile]:file:_files' \
        '--privileged-seccomp-profile=[seccomp profile for privileged pods]:file:_files' \
        '--apparmor-profile=[default AppArmor profile]:profile:' \
        '--blockio-config-file=[blockio class config file]:file:_files' \
        '--blockio-reload[reload blockio classes on signal]' \
        '--irqbalance-config-file=[irqbalance config file]:file:_files' \
        '--rdt-config-file=[Intel RDT config file]:file:_files' \
        '--selinux=[enable SELinux support]:bool:(true false)' \
        '--cgroup-manager=[cgroup manager]:mgr:(systemd cgroupfs)' \
        '--pids-limit=[default pids limit per container]:n:' \
        '--cni-default-network=[default CNI network name]:name:' \
        '--cni-config-dir=[CNI conf directory]:dir:_files -/' \
        '*--cni-plugin-dir=[CNI plugin search path]:dir:_files -/' \
        '--image-volumes=[image volume handling]:mode:(mkdir bind ignore)' \
        '*--hooks-dir=[OCI runtime hooks directory]:dir:_files -/' \
        '--default-mounts-file=[default mounts list file]:file:_files' \
        '*--default-capabilities=[default Linux capabilities]:cap:' \
        '--add-inheritable-capabilities[add inheritable capabilities]' \
        '*--default-sysctls=[default sysctl]:kv:' \
        '*--default-ulimits=[default ulimit]:spec:' \
        '--profile[enable pprof profiling]' \
        '--profile-cpu=[CPU profile output]:file:_files' \
        '--profile-mem=[memory profile output]:file:_files' \
        '--profile-port=[pprof HTTP server port]:port:' \
        '--enable-profile-unix-socket[serve pprof over Unix socket]' \
        '--enable-metrics[enable Prometheus metrics]' \
        '--metrics-host=[metrics bind host]:host:' \
        '--metrics-port=[metrics HTTP port]:port:' \
        '--metrics-socket=[metrics Unix socket path]:socket:_files' \
        '--metrics-cert=[metrics TLS certificate]:file:_files' \
        '--metrics-key=[metrics TLS private key]:file:_files' \
        '*--metrics-collectors=[metrics collector to enable]:collector:' \
        '--enable-tracing[enable OpenTelemetry tracing]' \
        '--tracing-sampling-rate-per-million=[OTel sampling rate per million]:n:' \
        '--tracing-endpoint=[OTel collector endpoint]:url:' \
        '--enable-nri[enable Node Resource Interface]' \
        '--nri-listen=[NRI Unix socket path]:socket:_files' \
        '--nri-plugin-dir=[NRI plugin directory]:dir:_files -/' \
        '--nri-plugin-config-dir=[NRI plugin config directory]:dir:_files -/' \
        '--read-only[read-only rootfs]' \
        '--bind-mount-prefix=[prefix for host bind mounts]:dir:_files -/' \
        '--uid-mappings=[UID mappings spec]:spec:' \
        '--gid-mappings=[GID mappings spec]:spec:' \
        '*--allowed-devices=[device path allowed by default]:dev:' \
        '*--additional-devices=[device mounted by default]:dev:' \
        '*--cdi-spec-dirs=[CDI specification directory]:dir:_files -/' \
        '*--conmon-env=[env var passed to conmon]:kv:' \
        '*--default-env=[env var added to every container]:kv:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                check:'verify storage consistency and clean up orphans'
                config:'print the current config in TOML'
                publish:'publish the JSON event stream over gRPC'
                status:'CRI-O status / inspect (containers, info, config)'
                version:'print client and server version'
                wipe:'wipe internal storage / containers on upgrade'
                complete:'generate shell completion scripts'
                completion:'generate shell completion scripts'
            )
            _describe -t commands 'crio subcommand' subs
            ;;
    esac
}

_crio "$@"
