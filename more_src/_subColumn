#compdef subColumn
# UCSC kent: substitute one column in a tab-separated file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-list[column is a comma-separated list, substitute all elements]' \
  '-miss=[print misses to this file instead of aborting]:file:_files' \
  '-skipMiss[skip missing ids instead of outputting them]' \
  ':column:' \
  ':in tab:_files' \
  ':sub tab:_files' \
  ':out tab:_files' && ret=0

return ret
