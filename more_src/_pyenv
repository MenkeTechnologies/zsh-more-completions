#compdef pyenv

# Zsh completion for pyenv - Simple Python Version Management

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'commands:List all available pyenv commands'
  'exec:Run an executable with the selected Python version'
  'global:Set or show the global Python version(s)'
  'help:Display help for a command'
  'hooks:List hook scripts for a given pyenv command'
  'init:Configure the shell environment for pyenv'
  'install:Install a Python version using python-build'
  'latest:Print the latest installed or known version with the given prefix'
  'local:Set or show the local application-specific Python version(s)'
  'prefix:Display prefixes for Python versions'
  'rehash:Rehash pyenv shims (run after installing executables)'
  'root:Display the root directory where versions and shims are kept'
  'shell:Set or show the shell-specific Python version'
  'shims:List existing pyenv shims'
  'uninstall:Uninstall a specific Python version'
  'update:Update pyenv using HomeBrew or git'
  'version:Show the current Python version(s) and its origin'
  'version-file:Detect the file that sets the current pyenv version'
  'version-name:Show the current Python version'
  'version-origin:Explain how the current Python version is set'
  'versions:List all Python versions available to pyenv'
  'whence:List all Python versions that contain the given executable'
  'which:Display the full path to an executable'
)

_arguments -s -S \
  '--version[display the version of pyenv]' \
  '-h[display help]' \
  '--help[display help]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments \
          '(-l --list)'{-l,--list}'[list available versions]' \
          '-f[install even if the version appears to be installed already]' \
          '--force[install even if the version appears to be installed already]' \
          '-s[skip if the version appears to be installed already]' \
          '--skip-existing[skip if the version appears to be installed already]' \
          '-v[verbose: print compilation status to stdout]' \
          '--verbose[verbose: print compilation status to stdout]' \
          '-p[apply a patch from stdin before building]' \
          '--patch[apply a patch from stdin before building]' \
          '-g[build a debug version]' \
          '--debug[build a debug version]' \
          ':version:' && ret=0
        ;;
      uninstall)
        _arguments \
          '-f[attempt to remove the specified version without prompting for confirmation]' \
          '--force[attempt to remove without prompting]' \
          ':version:($(_pyenv_installed_versions 2>/dev/null))' && ret=0
        ;;
      global|local|shell)
        _arguments '*:version:(system $(_pyenv_installed_versions 2>/dev/null))' && ret=0
        ;;
    esac
    ;;
esac

_pyenv_installed_versions() {
  pyenv versions --bare 2>/dev/null
}

return ret
