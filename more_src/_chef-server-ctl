#compdef chef-server-ctl
# Documentation: https://docs.chef.io/server/ctl_chef_server/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (chef-server docs-chef-io/content/server/ctl_chef_server.md).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'hup:reload config'
  'int:send interrupt to services'
  'kill:forcefully terminate services'
  'once:run once without daemonizing'
  'restart:restart all services'
  'service-list:show configured services'
  'start:start all services'
  'status:show running status'
  'stop:halt all services'
  'tail:stream service logs'
  'term:gracefully terminate'
  'user-create:create user'
  'user-delete:delete user'
  'user-edit:edit user'
  'user-list:list users'
  'user-show:show user'
  'password:change password'
  'grant-server-admin-permissions:grant server-admin role'
  'remove-server-admin-permissions:revoke server-admin role'
  'list-server-admins:list server admins'
  'org-create:create organization'
  'org-delete:delete organization'
  'org-list:list organizations'
  'org-show:show organization'
  'org-user-add:add user to org'
  'org-user-remove:remove user from org'
  'add-client-key:add client key'
  'add-user-key:add user key'
  'delete-client-key:delete client key'
  'delete-user-key:delete user key'
  'list-client-keys:list client keys'
  'list-user-keys:list user keys'
  'backup:backup server'
  'restore:restore from archive'
  'maintenance:toggle maintenance mode'
  'reindex:reindex search'
  'psql:open psql session'
  'set-secret:set credential secret'
  'remove-secret:remove credential secret'
  'show-secret:show credential secret'
  'set-db-superuser-password:set DB superuser password'
  'set-actions-password:set actions password'
  'oc-id-show-app:show OC ID app'
  'require-credential-rotation:require credential rotation'
  'rotate-all-credentials:rotate all credentials'
  'rotate-credentials:rotate credentials for service'
  'rotate-shared-secrets:rotate shared secrets'
  'show-service-credentials:show service credentials'
  'cleanup-bifrost:cleanup bifrost'
  'install:install component'
  'uninstall:uninstall component'
  'upgrade:upgrade'
  'rebuild-migration-state:rebuild migration state'
  'cleanse:cleanse server'
  'gather-logs:gather diagnostic logs'
  'help:show help'
  'notice:show notice'
  'show-config:show config'
  'reconfigure:reconfigure'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'chef-server-ctl subcommand' subcommands && ret=0
    ;;
esac

return ret
