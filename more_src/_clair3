#compdef run_clair3.sh clair3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--bam_fn[input BAM file]:file:_files -g "*.bam"' \
  '--ref_fn[reference FASTA]:file:_files -g "*.fa(|sta)(|.gz)"' \
  '--output[output directory]:directory:_directories' \
  '--threads[number of threads]:threads:' \
  '--platform[sequencing platform]:platform:(ont hifi ilmn)' \
  '--model_path[model directory]:directory:_directories' \
  '--bed_fn[BED file for calling region]:file:_files -g "*.bed"' \
  '--vcf_fn[VCF file for genotyping]:file:_files -g "*.vcf(|.gz)"' \
  '--ctg_name[contig name]:contig:' \
  '--sample_name[sample name]:name:' \
  '--qual[QUAL filter threshold]:value:' \
  '--snp_min_af[minimum SNP allele frequency]:af:' \
  '--indel_min_af[minimum indel allele frequency]:af:' \
  '--var_pct_full[variant percentage full alignment]:pct:' \
  '--pileup_only[only use pileup calling]' \
  '--gvcf[enable GVCF output]' \
  '--include_all_ctgs[include all contigs]' \
  '--no_phasing_for_fa[disable phasing for full alignment]' \
  '--enable_phasing[enable phasing with whatshap]' \
  '--remove_intermediate_dir[clean up intermediate files]' \
  '(-h --help)'{-h,--help}'[show help]' \
  && ret=0

return ret
