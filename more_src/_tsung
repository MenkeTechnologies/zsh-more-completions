#compdef tsung
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/tsung.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Verified against tsung(1) manpage. tsung uses single-dash short flags only;
# previous --long alternatives (--file, --log, --id, --stats, --monitor,
# --package, --exclude, --dumptraffic, --listen, --warm-time, --help) were
# fabricated. Flags -X, -L, -w take arguments per manpage but with different
# meanings than the previous completion (paths/lifetime/delay, not
# patterns/ports/seconds).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-f+[configuration file]:file:_files -g "*.xml"' \
  '-l+[log directory]:directory:_files -/' \
  '-m+[monitoring log file name]:file:' \
  '-r+[alternative command to ssh for remote nodes]:command' \
  '-i+[set controller id]:id:' \
  '-F[use long names (FQDN) for erlang nodes]' \
  '-s[enable erlang smp on client nodes]' \
  '-p+[maximum erlang processes per vm]:processes' \
  '*-X+[add erlang load path]:directory:_files -/' \
  '-L+[SSL session lifetime in seconds]:seconds' \
  '-w+[warmup delay in seconds]:seconds' \
  '-v[show version]' \
  '-n[disable web GUI]' \
  '-k[keep web GUI and controller alive after test completion]' \
  '-6[use IPv6 for internal communications]' \
  '-h[show usage]' \
  '1:command:->commands' && ret=0

case $state in
  (commands)
    local -a commands=(
      'start:start tsung'
      'stop:stop tsung'
      'debug:start in debug mode'
      'status:show tsung status'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
