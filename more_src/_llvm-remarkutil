#compdef llvm-remarkutil
# _llvm-remarkutil — LLVM remark file utility (LLVM project, C++); inspect/convert optimization remark files
# upstream: https://github.com/llvm/llvm-project

_llvm-remarkutil() {
    local -a sub=(
        'bitstream2yaml:bitstream remarks to YAML'
        'yaml2bitstream:YAML remarks to bitstream'
        'instruction-count:instruction count'
        'annotation-count:annotation count'
        'count:remark count'
        'size-diff:remark size diff'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llvm-remarkutil subcommand' sub ;;
        args)
            case $words[1] in
                bitstream2yaml|yaml2bitstream) _arguments \
                    '-o+[output]:file:_files' \
                    '*:file:_files' ;;
                instruction-count|annotation-count|count) _arguments \
                    '--parser=+[parser]:p:(yaml bitstream)' \
                    '--use-debug-loc[use debug loc]' \
                    '--annotation-type=+[annotation type]:t:' \
                    '-o+[output]:file:_files' \
                    '*:file:_files' ;;
                size-diff) _arguments \
                    '--parser=+[parser]:p:(yaml bitstream)' \
                    '--report-style=+[style]:s:(human json)' \
                    '--pretty[pretty]' \
                    '-o+[output]:file:_files' \
                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_llvm-remarkutil "$@"
