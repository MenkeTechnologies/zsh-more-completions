#compdef create-mvp-app
# Documentation: https://www.npmjs.com/package/create-mvp-app
# Reference accessed: 2026-05-23
# Verified: npm view create-mvp-app bin; dist/index.js commander options.

# Zsh completion for create-mvp-app - Next.js MVP starter with auth and database options

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[skip prompts and use defaults]' \
  '(-d --debug)'{-d,--debug}'[show detailed logs and command output]' \
  '--no-auth[skip authentication setup]' \
  '--no-db[skip database setup]' \
  '--no-ui[skip Shadcn UI components]' \
  '--no-blocks[skip Shadcn Blocks]' \
  '--no-tests[skip testing setup]' \
  '--no-git[skip git initialization]' \
  '--clerk-key=[Clerk publishable key]:key:' \
  '--clerk-secret=[Clerk secret key]:secret:' \
  '--supabase-url=[Supabase project URL]:url:' \
  '--supabase-key=[Supabase anon key]:key:' \
  '--open[open project in VS Code after creation]' \
  ':project name:' && ret=0

return ret
