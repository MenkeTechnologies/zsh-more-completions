#compdef cuffmerge
# Documentation: http://cole-trapnell-lab.github.io/cufflinks/cuffmerge/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Cuffmerge: merge Cufflinks assemblies into a consensus GTF
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[help]' \
  '-o[output directory]:dir:_files -/' \
  '-g[reference GTF (guide)]:file:_files -g "*.gtf"' \
  '-p[threads]:n:' \
  '-s[FASTA reference]:file:_files -g "*.(fa|fasta)"' \
  '--min-isoform-fraction=[min isoform fraction]:val:' \
  '--keep-tmp[keep intermediate files]' \
  '*:assembly list file:_files' && ret=0
return ret
