#compdef palindrome
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/palindrome.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS palindrome: find inverted repeats (palindromes) in DNA sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s) to search]:DNA USA:_files' \
  '-minpallen=[minimum palindrome length]:length:' \
  '-maxpallen=[maximum palindrome length]:length:' \
  '-gaplimit=[maximum gap between repeats]:length:' \
  '-nummismatches=[allowed mismatches]:n:' \
  '-overlap[allow overlapping palindromes]' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
