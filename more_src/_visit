#compdef visit
# Documentation: https://visit-sphinx-github-user-manual.readthedocs.io/en/v3.2.0/gui_manual/StartupOptions/index.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# VisIt: parallel visualisation and analysis tool (LLNL)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-fullhelp[show full help]' \
  '-version[show version]' \
  '-cli[command-line interface mode]' \
  '-gui[GUI mode (default)]' \
  '-nowin[no window mode]' \
  '-engine[run as parallel engine]' \
  '-mdserver[run as metadata server]' \
  '-vcl[run as visit component launcher]' \
  '-o[open file at startup]:file:_files' \
  '-s[execute Python script]:file:_files -g "*.py"' \
  '-sessionfile[load session file]:file:_files -g "*.session"' \
  '-debug=[debug level 1-5]:n:(1 2 3 4 5)' \
  '-clobber[overwrite existing files]' \
  '-output[output filename]:file:_files' \
  '-format[output format]:format:(png jpeg ppm tiff rgb postscript bmp)' \
  '-geometry[window geometry WxH+X+Y]:geom:' \
  '-parallel[force parallel mode]' \
  '-np[number of processors]:n:' \
  '-nn[number of nodes]:n:' \
  '-l[launch method]:method:(srun mpirun aprun openmpi slurm)' \
  '-machinefile[hostfile]:file:_files' \
  '-noconfig[do not load configuration]' \
  '-host[host machine for engine]:host:' \
  '-dir[VisIt installation directory]:dir:_files -/' \
  '-add-plugin-dir[additional plugin directory]:dir:_files -/' \
  '*:file:_files' && ret=0
return ret
