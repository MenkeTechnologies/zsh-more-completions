#compdef create-mobile-surfaces
# Documentation: https://www.npmjs.com/package/create-mobile-surfaces
# Reference accessed: 2026-05-24
# Verified: npm view create-mobile-surfaces bin; npm readme Scripted flags table.

# Zsh completion for create-mobile-surfaces - Expo iOS widget surfaces scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--name=[project slug; required with --yes]:name:' \
  '--scheme=[URL scheme]:scheme:' \
  '--bundle-id=[iOS bundle id; required with --yes]:id:' \
  '--team-id=[Apple Team ID]:id:' \
  '--home-widget[include home-screen widget surface]' \
  '--no-home-widget[skip home-screen widget surface]' \
  '--control-widget[include iOS 18 control widget]' \
  '--no-control-widget[skip control widget surface]' \
  '--install[run pnpm install and expo prebuild]' \
  '--no-install[skip install and prebuild]' \
  '--new-arch[force Expo New Architecture on]' \
  '--no-new-arch[force Expo New Architecture off]' \
  '(-y --yes)'{-y,--yes}'[non-interactive mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
