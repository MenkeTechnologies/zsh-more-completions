#compdef addspec
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/addspec.html
# Add multiple PHA spectra and optionally build combined response and background

local ret=1

_arguments -s -S \
  'infil=[ASCII file listing PHA datasets to combine]:infil:_files' \
  'outfil=[root name for output files]:outfil:_files' \
  'qaddrmf=[construct combined response matrix]:qaddrmf:(yes no)' \
  'qsubback=[construct combined background PHA]:qsubback:(yes no)' \
  'qaddpha=[add the PHA datasets]:qaddpha:(yes no)' \
  'units=[algebra units C counts or R rate]:units:(C R)' \
  'bexpscale=[background scaling factor]:bexpscale:' \
  'properr=[propagate errors]:properr:(yes no)' \
  'errmeth=[error prescription method]:errmeth:(Gauss POISS-0 POISS-1 POISS-2 POISS-3)' \
  'chatter=[verbosity level]:chatter:' \
  'schatter=[spawned task verbosity]:schatter:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
