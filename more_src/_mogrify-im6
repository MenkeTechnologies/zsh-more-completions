#compdef mogrify-im6
# Documentation: https://imagemagick.org/script/mogrify.php
# ImageMagick 6 in-place image transformer (resize, convert, annotate in place)

local ret=1

_arguments -s \
  '-format[output format / file suffix]:type' \
  '-path[write images to this path on disk]:path:_files -/' \
  '-resize[resize the image]:geometry' \
  '-scale[scale the image]:geometry' \
  '-quality[JPEG/MIFF/PNG compression level]:value' \
  '-rotate[apply Paeth rotation to the image]:degrees' \
  '-strip[strip image of all profiles and comments]' \
  '-flip[flip image in the vertical direction]' \
  '-flop[flop image in the horizontal direction]' \
  '-crop[crop the image]:geometry' \
  '-border[add a coloured border]:geometry' \
  '-blur[reduce noise and detail]:geometry' \
  '-sharpen[enhance image sharpness]:geometry' \
  '-gravity[control text placement]:type' \
  '-annotate[add text to images]:geometry' \
  '-density[adjust image resolution]:geometry' \
  '-monitor[monitor progress]' \
  '*:image file:_files' && ret=0

return ret
