#compdef swww-daemon
# Documentation: https://github.com/LGFae/swww
# Reference accessed: 2026-05-21
# Verified: upstream daemon source (daemon/src/main.rs).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--format=[pixel format]:format:(argb abgr rgb bgr)' \
  '--namespace=[wayland socket namespace]:namespace:' \
  '--no-cache[do not cache images]' \
  '--quiet[reduce logging to errors only]' && ret=0

return ret
