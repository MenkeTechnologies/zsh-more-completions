#compdef swww-daemon
# Documentation: https://man.archlinux.org/search?q=swww-daemon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--format[pixel format]:format:(xrgb bgr)' \
  '--no-cache[do not cache images]' \
  '--quiet[suppress logging]' && ret=0

return ret
