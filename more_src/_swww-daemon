#compdef swww-daemon
# Documentation: https://man.archlinux.org/man/extra/swww/swww-daemon.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--format[pixel format]:format:(xrgb bgr)' \
  '--no-cache[do not cache images]' \
  '--quiet[suppress logging]' && ret=0

return ret
