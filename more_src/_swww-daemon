#compdef swww-daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--format[pixel format]:format:(xrgb bgr)' \
  '--no-cache[do not cache images]' \
  '--quiet[suppress logging]' && ret=0

return ret
