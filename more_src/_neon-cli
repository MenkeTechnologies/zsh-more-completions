#compdef neon-cli neonctl
# _neon-cli — Neon Tech neon-cli CLI command-line frontend wrapping the Neon CLI command-line interface for the Neon serverless Postgres platform with database branching open-source written in TypeScript Node Neon serverless Postgres branching scale-to-zero developer experience auth login logout completion projects branches roles operations connection-string databases ip-allow create delete update get list export environments connection database create branch restore reset rollback rebase prod-branch read replicas (Neon Tech team Nikita Shamgunov Heikki Linnakangas Stas Kelvich, TypeScript); commander
# upstream: https://neon.tech/

_neon-cli() {
    local -a sub=(
        'auth:authenticate'
        'branches:branch operations'
        'completion:generate shell completion'
        'connection-string:get connection string'
        'cs:short for connection-string'
        'databases:database operations'
        'help:show help'
        'ip-allow:IP allow list ops'
        'login:authenticate'
        'logout:revoke session'
        'me:show current user'
        'operations:list operations'
        'orgs:organization operations'
        'projects:project operations'
        'roles:role operations'
        'set-context:set CLI context'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-host=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--context-file=+[file]:file:_files' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--output=+[fmt]:f:(json yaml table)' \
        '-o+[output]:f:(json yaml table)' \
        '--color[force color]' \
        '--no-color[no color]' \
        '--project-id=+[id]:str:' \
        '--project=+[id]:str:' \
        '--branch-id=+[id]:str:' \
        '--branch=+[id]:str:' \
        '--database=+[name]:str:' \
        '--database-id=+[id]:str:' \
        '--role=+[name]:str:' \
        '--name=+[name]:str:' \
        '--id=+[id]:str:' \
        '--parent=+[branch]:str:' \
        '--parent-lsn=+[lsn]:str:' \
        '--parent-timestamp=+[ts]:str:' \
        '--read-only[read only]' \
        '--prepared[prepared statements]' \
        '--pooled[pooled]' \
        '--cu=+[N]:str:' \
        '--suspend-timeout=+[sec]:n:' \
        '--protected[protected]' \
        '--non-default[non-default]' \
        '--annotation=+[k=v]:str:' \
        '*--annotation=+[k=v]:str:' \
        '--type=+[t]:str:' \
        '--region-id=+[id]:str:' \
        '--pg-version=+[v]:str:' \
        '--owner-name=+[name]:str:' \
        '--cidr=+[cidr]:str:' \
        '--description=+[text]:str:' \
        '--ips=+[list]:str:' \
        '--source=+[s]:str:' \
        '--primary[primary]' \
        '--default[default]' \
        '--preserve-under-name=+[name]:str:' \
        '--restore-from=+[branch]:str:' \
        '--restore-from-source=+[id]:str:' \
        '--restore-from-timestamp=+[ts]:str:' \
        '--restore-from-lsn=+[lsn]:str:' \
        '--into-new-name=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'neon subcommand' sub ;;
        args)
            case $words[1] in
                projects|branches|databases|roles|orgs|ip-allow) _arguments '1:op:(list get create update delete restore reset rollback set-default set-primary upsert)' '*:id:' ;;
                operations) _arguments '1:op:(list)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_neon-cli "$@"
