#compdef cbimport
# Documentation: https://docs.couchbase.com/server/current/tools/cbimport.html
# Couchbase import tool for loading JSON/CSV data into a cluster

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show cbimport suite version]' \
  '(-c --cluster)'{-c,--cluster}'+[hostname of a node in the cluster]:url:_hosts' \
  '(-u --username)'{-u,--username}'+[cluster username]:username:' \
  '(-p --password)'{-p,--password}'+[cluster password]:password:' \
  '(-b --bucket)'{-b,--bucket}'+[destination bucket]:bucket:' \
  '(-d --dataset)'{-d,--dataset}'+[URI of the dataset to load]:uri:_files' \
  '(-f --format)'{-f,--format}'+[data format]:format:(lines list sample)' \
  '(-g --generate-key)'{-g,--generate-key}'+[key expression for generating document keys]:expr:' \
  '(-t --threads)'{-t,--threads}'+[number of concurrent clients]:num:' \
  '(-e --errors-log)'{-e,--errors-log}'+[log file for unloadable documents]:path:_files' \
  '(-l --log-file)'{-l,--log-file}'+[debug log file]:path:_files' \
  '(-v --verbose)'{-v,--verbose}'[output logging to stdout]' \
  '--field-delimiter=[field reference character]:char:' \
  '--generator-delimiter=[generator reference character]:char:' \
  '--ignore-fields=[comma-separated fields to exclude]:fields:' \
  '--scope-collection-exp=[route docs to scope/collection]:expression:' \
  '--limit-docs=[stop loading after N documents]:num:' \
  '--skip-docs=[skip initial N documents]:num:' \
  '--cacert=[CA certificate for SSL verification]:path:_files' \
  '--no-ssl-verify[skip SSL verification]' \
  '--client-cert=[client certificate for mTLS]:path:_files' \
  '--client-key=[client private key for mTLS]:path:_files' \
  '*:command:(json csv)' && ret=0

return ret
