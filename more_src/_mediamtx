#compdef mediamtx
# _mediamtx — RTSP/RTMP/HLS/WebRTC/SRT/MoQ media server and proxy (bluenviron/mediamtx)
# upstream: https://github.com/bluenviron/mediamtx
# CLI from internal/core/core.go (alecthomas/kong); rest of config lives in mediamtx.yml.

_mediamtx() {
    local -a args
    args=(
        '--version[print version and exit]'
        '--check-version[check whether a new version is available and exit]'
        '--upgrade[upgrade the executable to the latest version]'
        '(- *)'{-h,--help}'[show help]'
        ':config file path (default mediamtx.yml):_files -g "*.(yml|yaml)"'
    )
    _arguments -s -S $args
}

_mediamtx "$@"
