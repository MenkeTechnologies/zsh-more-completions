#compdef doit

# Zsh completion for doit - Python task automation tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run tasks'
  'clean:clean action / remove targets'
  'list:list available tasks'
  'info:show task metadata'
  'forget:clear successful run status from DB'
  'strace:use strace to list file access from a task'
  'help:show help'
  'tabcompletion:generate shell tab completion'
  'dumpdb:dump the dependency database'
  'auto:automatically re-execute tasks on file changes'
  'resetdep:recompute and save the state of file dependencies'
)

local -a global_opts=(
  '(-f --file)'{-f,--file}'[load task from file]:file:_files -g "*.py"'
  '(-d --dir)'{-d,--dir}'[set path to be used as cwd]:directory:_files -/'
  '--seek-file[seek dodo file on parent directories]'
  '--backend[select dependency file backend]:backend:(dbm json sqlite3)'
  '--db-file[file used to save successful runs]:file:_files'
  '--check_file_uptodate[choose the method to check if files have been modified]:method:(md5 timestamp)'
  '--codec_cls[codec class to encode/decode data stored in the backend]:class:'
)

_arguments -s -S \
  "${global_opts[@]}" \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'doit command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      run)
        _arguments -s -S \
          "${global_opts[@]}" \
          '(-n --process)'{-n,--process}'[number of sub-processes]:count:' \
          '--pdb[start debugger on task failure]' \
          '(-s --single)'{-s,--single}'[execute only specified tasks ignoring dependencies]' \
          '(-v --verbosity)'{-v,--verbosity}'[verbosity level]:level:(0 1 2)' \
          '--always-execute[always execute tasks even if up-to-date]' \
          '--continue[continue executing tasks even after a failure]' \
          '--reporter[choose output reporter]:reporter:(console executed-only json zero error-only)' \
          '--output-file[write reporter output to file]:file:_files' \
          '--parallel-type[type of parallelism]:type:(process thread)' \
          '*:task:' && ret=0
        ;;
      clean)
        _arguments -s -S \
          "${global_opts[@]}" \
          '(-c --clean-dep)'{-c,--clean-dep}'[clean task dependencies too]' \
          '--dry-run[print actions without executing them]' \
          '*:task:' && ret=0
        ;;
      list)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--all[list include all sub-tasks from dodo file]' \
          '--quiet[print just task name without docstring]' \
          '--status[print task status (uptodate, run, error)]' \
          '--private[include private tasks (starting with _)]' \
          '--deps[print file dependencies]' \
          '--template[display entries with a custom template]:template:' \
          '(-s --sort)'{-s,--sort}'[sort order for listing]:order:(definition name)' \
          '*:task:' && ret=0
        ;;
      info)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--no-status[do not print task status]' \
          '1:task:' && ret=0
        ;;
      auto)
        _arguments -s -S \
          "${global_opts[@]}" \
          '--loop_callback[custom callback for auto loop]:callback:' \
          '*:task:' && ret=0
        ;;
      forget)
        _arguments -s -S \
          "${global_opts[@]}" \
          '*:task:' && ret=0
        ;;
      strace|help|tabcompletion|dumpdb|resetdep)
        _arguments -s -S \
          "${global_opts[@]}" \
          '*:task:' && ret=0
        ;;
    esac
    ;;
esac

return ret
