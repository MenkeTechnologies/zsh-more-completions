#compdef lld ld.lld ld64.lld lld-link wasm-ld

# Zsh completion for lld - LLVM linker

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-v[display version information]' \
  '-o[output file]:output file:_files' \
  '*-L[library search path]:directory:_directories' \
  '*-l[link library]:library name' \
  '-r[create relocatable output]' \
  '-shared[create shared library]' \
  '-static[do not link against shared libraries]' \
  '-pie[create position-independent executable]' \
  '-no-pie[do not create position-independent executable]' \
  '(-e --entry)'{-e,--entry}'[entry point symbol]:symbol' \
  '*-rpath[add runtime library search path]:path:_directories' \
  '--sysroot=[system root]:directory:_directories' \
  '*-z[linker keyword]:keyword:(now lazy relro norelro text notext defs nodefs execstack noexecstack origin global initfirst interpose loadfltr nodefaultlib nodelete nodlopen nodump combreloc nocombreloc separate-code noseparate-code keep-text-section-prefix)' \
  '--gc-sections[remove unused sections]' \
  '--no-gc-sections[do not remove unused sections]' \
  '--print-gc-sections[print removed unused sections]' \
  '-Map[write map file]:map file:_files' \
  '--version-script=[version script]:file:_files' \
  '--dynamic-linker=[dynamic linker path]:linker:_files' \
  '(-h --soname)'{-h,--soname}'[set shared object name]:name' \
  '--whole-archive[include all objects from archives]' \
  '--no-whole-archive[use default archive handling]' \
  '--as-needed[only link libraries needed by undefined symbols]' \
  '--no-as-needed[always link listed libraries]' \
  '-O[optimization level]:level:(0 1 2)' \
  '--threads=[number of threads to use]:count' \
  '--no-threads[do not use threads]' \
  '(-s --strip-all)'{-s,--strip-all}'[strip all symbols]' \
  '(-S --strip-debug)'{-S,--strip-debug}'[strip debug symbols]' \
  '--compress-debug-sections=[compress debug sections]:format:(none zlib zstd)' \
  '--reproduce=[create tar for reproducing linking]:tar file:_files' \
  '--icf=[identical code folding]:mode:(all safe none)' \
  '--thinlto-cache-dir=[ThinLTO cache directory]:directory:_directories' \
  '--thinlto-cache-policy=[ThinLTO cache policy]:policy' \
  '--lto-O[LTO optimization level]:level:(0 1 2 3)' \
  '--color-diagnostics=[color diagnostics]:mode:(auto always never)' \
  '--error-limit=[maximum number of errors]:count' \
  '--fatal-warnings[treat warnings as errors]' \
  '--no-fatal-warnings[do not treat warnings as errors]' \
  '--no-undefined[report unresolved symbols]' \
  '(-u --undefined)'{-u,--undefined}'[force symbol to be undefined]:symbol' \
  '--wrap=[wrap symbol]:symbol' \
  '(-V)'-V'[display version information and exit]' \
  '*:files:_files'
