#compdef inlets
# Documentation: https://github.com/inlets/inlets
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'client:inlets client (exit-node tunnel)'
      'server:inlets server'
      'version:print version'
    )
    _describe -t commands 'inlets command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--license-file=[license file]:file:_files' \
      '--tcp-ports=[ports to forward]:ports' \
      '--token=[auth token]:token' \
      '--url=[server websocket URL]:url' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
