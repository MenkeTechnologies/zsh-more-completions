#compdef process-user-data
# _process-user-data — Confidential Containers PodVM userdata processor (fetches cloud-init data and writes agent config files)
# upstream: https://github.com/confidential-containers/cloud-api-adaptor
# Subcommands + flags from src/cloud-api-adaptor/cmd/process-user-data/main.go on tip (cobra).

_process-user-data() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'provision-files':'provision required files based on user data'
            )
            _describe -t commands 'process-user-data subcommand' subs
            ;;
        args)
            case $line[1] in
                'provision-files')
                    _arguments \
                        '(-t --user-data-fetch-timeout)'{-t,--user-data-fetch-timeout}'=[timeout (s) for fetching user data]:s:'
                    ;;
            esac
            ;;
    esac
}

_process-user-data "$@"
