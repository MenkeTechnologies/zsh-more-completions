#compdef a2x3
# Documentation: https://www.asciidoc3.org/a2x3/
# Convert AsciiDoc3 text files to other file formats

local ret=1

_arguments -s -S \
  '*'{-a+,--attribute=}'[set asciidoc3 attribute value]:attribute' \
  '--asciidoc-opts=[additional asciidoc3 options]:opts' \
  '--conf-file=[load configuration file]:file:_files' \
  '(-D --destination-dir)'{-D+,--destination-dir=}'[output directory]:dir:_files -/' \
  '(-d --doctype)'{-d+,--doctype=}'[DocBook document type]:doctype:(article manpage book)' \
  '(-b --backend)'{-b+,--backend=}'[name of an installed backend plugin]:backend' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(chunked docbook dvi epub htmlhelp manpage pdf ps tex text xhtml)' \
  '(-h --help)'{-h,--help}'[print command-line syntax and program options]' \
  '--icons[use admonition or navigation icon images in output documents]' \
  '--icons-dir=[path containing admonition and navigation icons]:path:_files -/' \
  '(-k --keep-artifacts)'{-k,--keep-artifacts}'[do not delete temporary build files]' \
  '--lynx[use lynx when generating text formatted output]' \
  '(-L --no-xmllint)'{-L,--no-xmllint}'[do not check asciidoc3 output with xmllint]' \
  '--epubcheck[check EPUB output with epubcheck]' \
  '(-n --dry-run)'{-n,--dry-run}'[print what would have been done without doing it]' \
  '*'{-r+,--resource=}'[specify a resource]:resource' \
  '(-m --resource-manifest)'{-m+,--resource-manifest=}'[file with a list of resources]:file:_files' \
  '--stylesheet=[space delimited list of CSS stylesheet file names]:stylesheet' \
  '(-v --verbose)'{-v,--verbose}'[print operational details to stderr]' \
  '--version[print program version to stdout]' \
  '--xsltproc-opts=[additional xsltproc options]:opts' \
  '--xsl-file=[override the built-in XSL stylesheet]:file:_files' \
  '--fop[use FOP to generate PDFs]' \
  '--fop-opts=[additional fop options]:opts' \
  '--dblatex-opts=[additional dblatex options]:opts' \
  '--backend-opts=[options for the backend plugin]:opts' \
  '*:file:_files' && ret=0

return ret
