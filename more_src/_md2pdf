#compdef md2pdf

# https://github.com/solworktech/md2pdf — Typer/click style CLI (see `md2pdf --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '(-o --output)'{-o,--output}'=-[PDF path]:file:_files' \
  '--css=-[extra stylesheet]:file:_files' \
  '--theme=-[built-in theme]:theme:' \
  '*:markdown file:_files -g "*.(md|markdown)"'
