#compdef omf
# Documentation: https://man.archlinux.org/search?q=omf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install one or more packages or themes'
  'list:list installed packages and themes'
  'update:update OMF core and packages'
  'remove:remove a package'
  'theme:change theme'
  'reload:reload the current fish shell'
  'new:scaffold a new package or theme'
  'search:search for packages and themes'
  'repositories:manage installed repositories (alias: repo)'
  'doctor:check for problems with the OMF install'
  'destroy:uninstall OMF entirely'
  'channel:set OMF release channel'
  'cd:cd to the OMF directory'
  'version:show OMF version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'omf command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (channel)
        _arguments '*::channel:(stable dev)' && ret=0 ;;
      (search)
        _arguments \
          '--packages[search only packages]' \
          '--themes[search only themes]' \
          '*::query:' && ret=0 ;;
      (new)
        _arguments '*::kind_name:(theme plugin pkg)' && ret=0 ;;
      (repositories|repo)
        _arguments '*::sub:(add remove ls list update)' && ret=0 ;;
      (theme)
        _arguments '*::theme:' && ret=0 ;;
    esac ;;
esac

return ret
