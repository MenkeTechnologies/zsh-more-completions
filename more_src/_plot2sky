#compdef plot2sky
# Documentation: https://www.star.bris.ac.uk/~mbt/stilts/sun256/plot2sky-usage.html
# STILTS: draw a plot on celestial sky axes

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'xpix=[output image X size in pixels]:int:' \
  'ypix=[output image Y size in pixels]:int:' \
  'insets=[padding around plotting area]:insets:' \
  'omode=[output mode]:mode:(swing out cgi discard auto)' \
  'out=[output file location]:out:_files' \
  'ofmt=[output graphics format]:fmt:' \
  'storage=[data storage policy]:storage:(simple memory disk policy cache basic-cache persistent parallel)' \
  'legend=[display legend]:legend:(true false null)' \
  'clon=[central longitude in decimal degrees]:double:' \
  'clat=[central latitude in decimal degrees]:double:' \
  'radius=[plot field of view radius in degrees]:double:' \
  'projection=[sky projection type]:projection:(sin aitoff aitoff0 car car0)' \
  '*:arg:' && ret=0

return ret
