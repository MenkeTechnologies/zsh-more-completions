#compdef nequip-train
# Documentation: https://nequip.readthedocs.io/en/latest/guide/getting-started/workflow.html
# NequIP: train an equivariant neural network interatomic potential (Hydra)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-cp[config path: directory containing config files]:dir:_files -/' \
  '-cn[config name: specific config file name]:name:_files' \
  '--config-path=[config directory]:dir:_files -/' \
  '--config-name=[config file name]:name:_files' \
  '*:override:_default' && ret=0

return ret
