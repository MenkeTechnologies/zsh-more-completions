#compdef nebula-importer
# Documentation: https://docs.nebula-graph.io/3.2.0/nebula-importer/use-importer/
# NebulaGraph Importer - import CSV data into NebulaGraph from a YAML config

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[path to the YAML configuration file]:config:_files' \
  '(-v --version)'{-v,--version}'[print version information]' && ret=0

return ret
