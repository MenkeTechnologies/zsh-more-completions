#compdef systemctl-tui
# Documentation: https://github.com/rgwood/systemctl-tui/blob/main/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream clap definitions in systemctl-tui src/main.rs.
# Removed: --tick-rate (no such flag), --user (use --scope user instead).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --scope)'{-s,--scope}'=[scope of services to display]:scope:(global user all)' \
  '--no-log[disable file logging]' \
  '(-l --limit-units)'{-l,--limit-units}'=[limit view to unit-file glob(s)]:glob:' \
  '1::subcommand:(show-logs-path)' && ret=0

return ret
