#compdef systemctl-tui
# Documentation: https://man.archlinux.org/search?q=systemctl-tui
# Reference accessed: 2026-05-16

# Zsh completion for systemctl-tui (terminal UI for systemd)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tick-rate=[set tick rate in milliseconds]:rate:' \
  '--user[show user units instead of system units]' && ret=0

return ret
