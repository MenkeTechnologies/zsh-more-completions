#compdef aststatistics
# aststatistics — compute statistics on datasets

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-Z --tilesize)'{-Z,--tilesize}'[regular tile size on each dimension]:sizes' \
  '(-M --numchannels)'{-M,--numchannels}'[number of channels in each dimension]:channels' \
  '(-F --remainderfrac)'{-F,--remainderfrac}'[fraction of remainder to merge with tiles]:fraction' \
  '--interpnumngb[number of neighbors for interpolation]:number' \
  '--interpmetric[metric for nearest neighbor interpolation]:metric:(radial manhattan)' \
  '--interponlyblank[only interpolate over blank tiles]' \
  '(-c --column)'{-c,--column}'[column number or search string]:column' \
  '(-g --greaterequal)'{-g,--greaterequal}'[only use values greater or equal]:value' \
  '(-l --lessthan)'{-l,--lessthan}'[only use values less than]:value' \
  '(-Q --qrange)'{-Q,--qrange}'[quantile range (one or two values)]:quantiles' \
  '(-i --interpolate)'{-i,--interpolate}'[interpolate over blank tiles to fill them]' \
  '--number[print number of non-blank elements]' \
  '--minimum[print minimum value]' \
  '--maximum[print maximum value]' \
  '--sum[print sum of values]' \
  '(-m --mean)'{-m,--mean}'[print mean]' \
  '(-d --std)'{-d,--std}'[print standard deviation]' \
  '--mad[print median absolute deviation]' \
  '(-E --median)'{-E,--median}'[print median]' \
  '(-u --quantile)'{-u,--quantile}'[print quantile value]:quantile' \
  '--quantfunc[print quantile function value]:value' \
  '--quantofmean[print quantile of the mean]' \
  '(-O --mode)'{-O,--mode}'[print mode]' \
  '--modequant[print mode quantile]' \
  '--modesym[print mode symmetricity]' \
  '--modesymvalue[print value at mode symmetricity]' \
  '--sigclip-number[number of elements after sigma clipping]' \
  '--sigclip-median[sigma-clipped median]' \
  '--sigclip-mean[sigma-clipped mean]' \
  '--sigclip-std[sigma-clipped standard deviation]' \
  '--sigclip-mad[sigma-clipped median absolute deviation]' \
  '--madclip-number[number of elements after MAD clipping]' \
  '--madclip-median[MAD-clipped median]' \
  '--madclip-mean[MAD-clipped mean]' \
  '--madclip-std[MAD-clipped standard deviation]' \
  '--madclip-mad[MAD-clipped median absolute deviation]' \
  '--concentration[concentration index]:fractions' \
  '(-A --asciihist)'{-A,--asciihist}'[print an ASCII histogram]' \
  '--asciicfp[print an ASCII cumulative frequency plot]' \
  '(-H --histogram)'{-H,--histogram}'[save histogram in output]' \
  '(-C --cumulative)'{-C,--cumulative}'[save cumulative frequency plot in output]' \
  '--histogram2d[2D histogram output]:format:(table image)' \
  '--mirror[histogram and CFP of mirror distribution]:value' \
  '(-t --ontile)'{-t,--ontile}'[single values on separate tiles]' \
  '(-y --sky)'{-y,--sky}'[find sky and STD over the tessellation]' \
  '(-s --sigmaclip)'{-s,--sigmaclip}'[overall sigma clipping]' \
  '--madclip[overall MAD clipping]' \
  '(-R --contour)'{-R,--contour}'[contour levels in PGFPlots format]:levels' \
  '(-k --kernel)'{-k,--kernel}'[kernel file for convolution]:file:_files' \
  '--khdu[HDU of kernel image]:HDU' \
  '--mirrordist[max distance to find mode (error multiplier)]:distance' \
  '--meanmedqdiff[max mode and median quantile diff per tile]:diff' \
  '(-a --outliernumngb)'{-a,--outliernumngb}'[neighboring tiles for outlier detection]:number' \
  '--outliersclip[sigma-clip params for outlier detection]:multiple,tolerance' \
  '--outliersigma[multiple of sigma to define outliers]:multiple' \
  '--sclipparams[sigma-clip multiple and tolerance/number]:multiple,tolerance' \
  '--mclipparams[MAD-clip multiple and tolerance/number]:multiple,tolerance' \
  '--smoothwidth[flat kernel width to smooth interpolated sky]:width' \
  '--checksky[store sky estimation steps in file]' \
  '--checkskynointerp[like --checksky but stop at interpolation]' \
  '--ignoreblankintiles[do not write blanks in tiled output]' \
  '--numbins[number of bins in histogram or CFP]:number' \
  '--numbins2[number of bins in 2D histogram second dim]:number' \
  '--numasciibins[number of bins in ASCII histogram or CFP]:number' \
  '--asciiheight[height of ASCII histogram or CFP plots]:height' \
  '(-n --normalize)'{-n,--normalize}'[set sum of all bins to 1]' \
  '--maxbinone[scale so maximum bin has value of one]' \
  '--manualbinrange[set min/max of bins manually]' \
  '--onebinstart[shift bins so one starts on this value]:value' \
  '--greaterequal2[upper range of 2nd dim in 2D histograms]:value' \
  '--lessthan2[lower range of 2nd dim in 2D histograms]:value' \
  '--onebinstart2[like --onebinstart for 2D histogram]:value' \
  '(-f --fit)'{-f,--fit}'[type of fitting]:type:(linear polynomial robust)' \
  '--fitweight[input weight type]:type:(std var inv-variance)' \
  '(-p --fitmaxpower)'{-p,--fitmaxpower}'[maximum power in polynomial fit]:power' \
  '--fitrobust[robust function name to use]:function' \
  '--fitestimate[estimate fitted function]:source' \
  '--fitestimatehdu[HDU containing fitestimate values]:HDU' \
  '--fitestimatecol[column containing fitestimate values]:column' \
  '*:input data:_files'
