#compdef ntpdate-utils

# ntpdate-utils: distro wrapper around ntpdate (one-shot NTP time sync)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-4[use IPv4]' \
  '-6[use IPv6]' \
  '-a[authentication key]:key:' \
  '-B[burst mode]' \
  '-b[force basic step]' \
  '-d[debug (no clock change)]' \
  '-e[authdelay]:seconds:' \
  '-k[keyfile]:file:_files' \
  '-o[NTP version]:version:(1 2 3 4)' \
  '-p[number of samples]:n:' \
  '-q[query only, do not set]' \
  '-s[log via syslog]' \
  '-t[timeout per request]:seconds:' \
  '-u[do not bind to privileged port]' \
  '*:NTP server:_hosts' && ret=0
return ret
