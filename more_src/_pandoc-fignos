#compdef pandoc-fignos
# Documentation: https://github.com/tomduck/pandoc-fignos
# pandoc-fignos: a Pandoc filter for numbering figures and figure references

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version and exit]' \
  '--pandocversion=[the pandoc version]:version:' \
  '1:format:' && ret=0

return ret
