#compdef sumo-kgen
# Documentation: https://smtg-bham.github.io/sumo/sumo-kgen.html
# sumo high-symmetry k-point path generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --poscar)'{-p,--poscar}'[input structure file]:file:_files' \
  '(-c --code)'{-c,--code}'[electronic structure code]:code:(vasp)' \
  '(-d --directory)'{-d,--directory}'[output directory for generated files]:dir:_files -/' \
  '(-s --split)'{-s,--split}'[number of k-points to include per file]:n:' \
  '(-f --folders)'{-f,--folders}'[create folders and copy in necessary files]' \
  '(-y --hybrid)'{-y,--hybrid}'[append k-points to IBZKPT file with zero weight]' \
  '--symprec=[tolerance for finding symmetry]:tol:' \
  '--spg=[space group number or symbol]:spg:' \
  '--density=[k-point density along high-symmetry path]:density:' \
  '--seekpath[use seekpath for high-symmetry path generation]' \
  '--pymatgen[use pymatgen for high-symmetry path generation]' \
  '--latimer-munro[use Latimer & Munro method for path generation]' \
  '--cartesian[use cartesian k-point coordinates]' \
  '--kpoints=[specify a list of kpoints]:kpoints:' \
  '--labels=[specify the labels for kpoints]:labels:' \
  '--phonon[write k-points as phonon band structure path]' && ret=0

return ret
