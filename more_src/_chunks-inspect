#compdef chunks-inspect
# _chunks-inspect — inspect Loki chunk files (grafana/loki)
# upstream: https://github.com/grafana/loki
# Flags from cmd/chunks-inspect/main.go (flag.Bool).

_chunks-inspect() {
    _arguments \
        '-b[print block details]' \
        '-l[print log lines]' \
        '-s[store blocks using input filename + block index]' \
        '*:chunk file:_files'
}

_chunks-inspect "$@"
