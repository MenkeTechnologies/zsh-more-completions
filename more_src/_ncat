#compdef ncat
# Documentation: ncat --help on Ncat 7.99
# Source: Nmap Project Ncat — feature-rich nc replacement (SSL, proxies, brokering).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-4 -6 -U --unixsock)-4[IPv4 only]' \
    '(-4 -6 -U --unixsock)-6[IPv6 only]' \
    '(-4 -6 -U --unixsock)'{-U,--unixsock}'[Unix domain sockets only]' \
    '(-C --crlf)'{-C,--crlf}'[CRLF as EOL sequence]' \
    '(-c --sh-exec)'{-c,--sh-exec=}'[execute command via /bin/sh]:cmd:' \
    '(-e --exec)'{-e,--exec=}'[execute command directly]:cmd:_command_names -e' \
    '--lua-exec=[execute Lua script]:script:_files -g "*.lua"' \
    '-g+[loose source routing hops]:hop1,hop2,...:' \
    '-G+[loose source routing hop pointer]:n:' \
    '(-m --max-conns)'{-m,--max-conns=}'[max simultaneous connections]:n:' \
    '(- *)'{-h,--help}'[display help]' \
    '(-d --delay)'{-d,--delay=}'[delay between read/writes]:time:' \
    '(-o --output)'{-o,--output=}'[dump session data to file]:file:_files' \
    '(-x --hex-dump)'{-x,--hex-dump=}'[dump session as hex to file]:file:_files' \
    '(-i --idle-timeout)'{-i,--idle-timeout=}'[idle read/write timeout]:time:' \
    '(-p --source-port)'{-p,--source-port=}'[source port]:port:_ports' \
    '(-s --source)'{-s,--source=}'[source address]:addr:_hosts' \
    '(-l --listen)'{-l,--listen}'[bind+listen for connections]' \
    '(-k --keep-open)'{-k,--keep-open}'[accept multiple connections in listen mode]' \
    '(-n --nodns)'{-n,--nodns}'[no DNS resolution]' \
    '(-t --telnet)'{-t,--telnet}'[answer Telnet negotiations]' \
    '(-u --udp --sctp)'{-u,--udp}'[UDP instead of TCP]' \
    '(-u --udp --sctp)--sctp[SCTP instead of TCP]' \
    '*'{-v,--verbose}'[verbose (stackable)]' \
    '(-w --wait)'{-w,--wait=}'[connect timeout]:time:' \
    '-z[zero-IO mode; report status only]' \
    '--append-output[append rather than clobber output files]' \
    '--send-only[only send; quit on EOF]' \
    '--recv-only[only receive; never send]' \
    '--no-shutdown[half-duplex after stdin EOF]' \
    '-q+[wait N seconds after stdin EOF then quit]:time:' \
    '--allow=[allow hosts]:hosts:' \
    '--allowfile=[allowed-hosts file]:file:_files' \
    '--deny=[deny hosts]:hosts:' \
    '--denyfile=[denied-hosts file]:file:_files' \
    '--broker[connection-brokering mode]' \
    '--chat[chat server]' \
    '--proxy=[proxy host\:port]:addr\:port:' \
    '--proxy-type=[proxy type]:type:(http socks4 socks5)' \
    '--proxy-auth=[proxy authentication]:user\:pass:' \
    '--proxy-dns=[where to resolve proxy destination]:type:(local remote both none)' \
    '--ssl[connect/listen with SSL]' \
    '--ssl-cert=[SSL cert (PEM) for listening]:file:_files' \
    '--ssl-key=[SSL private key (PEM)]:file:_files' \
    '--ssl-verify[verify cert trust + domain]' \
    '--ssl-trustfile=[PEM trust file]:file:_files' \
    '--ssl-ciphers=[SSL cipher list]:ciphers:' \
    '--ssl-servername=[SNI server name]:name:' \
    '--ssl-alpn=[ALPN protocol list]:list:' \
    '(- *)--version[display version]' \
    '1:hostname:_hosts' \
    '2:port:_ports' \
    && ret=0

return ret
