#compdef weaver
# Documentation: https://github.com/ServiceWeaver/weaver
# Reference accessed: 2026-05-21
# Verified: upstream cmd/weaver/main.go subcommand registration.

# Service Weaver CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:run Service Weaver code generator'
  'version:show installed weaver version'
  'single:single-process deployment commands'
  'multi:multi-process local deployment commands'
  'ssh:multi-machine deployment via SSH'
  'gke:Google Kubernetes Engine deployment'
  'gke-local:simulated GKE deployment'
  'kube:Kubernetes deployment (generic)'
  'callgraph:generate component callgraph (mermaid)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'weaver command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (single|multi)
        _values 'subcommand' deploy status dashboard profile logs && ret=0 ;;
      (ssh|gke|gke-local|kube)
        _values 'subcommand' deploy status dashboard logs && ret=0 ;;
      (*)
        _files && ret=0 ;;
    esac ;;
esac

return ret
