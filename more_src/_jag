#compdef jag
# Documentation: https://man.archlinux.org/search?q=jag
# Reference accessed: 2026-05-16

# Zsh completion for jag ESP32 live reload (toitlang/jaguar, cobra)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      scan container ping run compile simulate decode setup flash firmware monitor watch port toit pkg config version
    )
    _describe -t commands 'jag command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
