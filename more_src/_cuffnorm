#compdef cuffnorm
# Documentation: http://cole-trapnell-lab.github.io/cufflinks/cuffnorm/index.html
# Cuffnorm: normalize a set of samples to similar scales

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output-dir)'{-o,--output-dir=}'[output directory]:dir:_files -/' \
  '(-L --labels)'{-L,--labels=}'[comma-separated sample labels]:labels:' \
  '(-p --num-threads)'{-p,--num-threads=}'[number of threads]:n:' \
  '--total-hits-norm[count all fragments in FPKM denominator]' \
  '--compatible-hits-norm[count only reference-compatible fragments]' \
  '--library-type=[sequencing protocol library type]:type:(ff-firststrand ff-secondstrand ff-unstranded fr-unstranded fr-firststrand fr-secondstrand transfrags)' \
  '--library-norm-method=[library normalization method]:method:(classic-fpkm geometric quartile)' \
  '--output-format=[output file format]:format:(cuffdiff simple-table)' \
  '(-v --verbose)'{-v,--verbose}'[verbose status output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]' \
  '--no-update-check[disable version check]' \
  '*:GTF and SAM/BAM files:_files' && ret=0

return ret
