#compdef bta2dpd
# Documentation: man bta2dpd(8)
# Source: netbsd/src usr.sbin/bta2dpd — Bluetooth A2DP audio daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[SBC bit allocation method]:allocation:(0 S L)' \
    '-B+[maximum bitpool value]:bitpool:_default' \
    '-b+[SBC encoding blocks (default 16)]:blocks:(0 4 8 12 16)' \
    '-D[run in background]' \
    '-d+[local device address (BDADDR or name)]:device:_default' \
    '-e+[SBC encoding bands (default 8)]:bands:(0 4 8)' \
    '-f+[channel mode (default stereo)]:channel mode:(0 m 2 j s)' \
    '-I[initiate Discover command for pairing]' \
    '-K[register as audio sink]' \
    '-M+[MTU (default 672)]:mtu:_default' \
    '-m+[L2CAP link mode]:mode:(auth encrypt secure)' \
    '-n[do not close connection on EOF]' \
    '-p+[L2CAP PSM for audio sink (default 25)]:psm:_default' \
    '-r+[input frequency (default 44100)]:rate:(0 16000 32000 44100 48000)' \
    '-t[test mode (decode stdin/stdout)]' \
    '-V+[volume shift (1 or 2 bits)]:volume:(1 2)' \
    '-v[verbose output]' \
    '-a+[remote device address (BDADDR or name)]:address:_default' \
    '*:audio file:_files' \
    && ret=0

return ret
