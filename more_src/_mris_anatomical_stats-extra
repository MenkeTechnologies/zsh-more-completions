#compdef mris_anatomical_stats-extra
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_anatomical_stats
# FreeSurfer: compute anatomical statistics for cortical surface labels

local ret=1

_arguments -s -S \
  '-i[only consider thicknesses in range]:low thresh:hi thresh' \
  '-l[limit calculations to specified label]:label file:_files' \
  '-t[use specified file for thickness statistics]:thickness file:_files' \
  '-a[compute properties per label in annotation file]:annotation file:_files' \
  '-b[enable tabular output format]' \
  '-f[table output to tablefile]:tablefile:_files' \
  '-log[write stats to log file]:logfile:_files' \
  '-nsmooth[smooth thicknessmap N iterations]:number' \
  '-c[output annotation colortable to text file]:ctab file:_files' \
  '-noglobal[do not compute global brain stats]' \
  '-th3[compute vertex-wise volume via tetrahedra]' \
  '*:argument:_files' && ret=0

return ret
