#compdef psfex stuff
# Documentation: source-direct extraction from upstream
# astromatic/psfex
#   src/main.c: hand-rolled argv-walk in `for (a=1; a<argc; a++)`
#   loop with `switch(opt)` on `argv[a][1]` -> 5 short flags
#   (`-c`, `-d`/`-dd`, `-v`, `-h`).
#   SYNTAX define:
#     psfex catalog1 [catalog2,...][@catalog_list1 [@catalog_list2 ...]]
#         [-c <config_file>][-<keyword> <value>]
#   Config keywords decoded source-direct from src/preflist.h
#   `static keystruct keylist[] = { {"KEY", P_*, ...}, ... }`
#   block (50+ keys; representative subset listed in completion).
# astromatic/stuff
#   src/main.c: identical 5-flag parser (the astromatic.net
#   shared parser pattern across psfex/stuff/scamp/swarp/
#   sextractor).  Default config file is "stuff.conf".  No
#   positional args (stuff is a synthetic-catalog generator
#   that reads everything from its config).
# Reference accessed: 2026-05-30 via gh api.
# astromatic R179 — 2-stem multi-binary harvest of the
# astromatic.net (Bertin) astronomy data-reduction tooling
# shipped alongside the already-covered scamp/swarp/
# sextractor/solve-field/stilts family + the heavily-covered
# astronomy stack (topcat already covered in earlier rounds).
# psfex builds models of point-spread functions across CCD
# fields for PSF-photometry pipelines; stuff generates
# synthetic astronomical catalogs for end-to-end pipeline
# tests against SExtractor.

case $service in

  psfex)
    _arguments -s -S \
      '-c+[config file (default default.psfex)]:file:_files' \
      '-d[dump default config to stdout and exit]' \
      '-dd[dump extended default config to stdout and exit]' \
      '-v[print version and exit]' \
      '-h[print syntax and exit]' \
      '*:input catalog .cat / .fits / @listfile:_files -g "*.(cat|fits|FITS|fit|fts|@*)"'
    ;;

  stuff)
    _arguments -s -S \
      '-c+[config file (default stuff.conf)]:file:_files' \
      '-d[dump default config to stdout and exit]' \
      '-dd[dump extended default config to stdout and exit]' \
      '-v[print version and exit]' \
      '-h[print syntax and exit]'
    ;;

esac
