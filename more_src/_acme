#compdef acme

# completions for acme.sh ACME protocol client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--install[install acme.sh]' \
  '--uninstall[uninstall acme.sh]' \
  '--upgrade[upgrade acme.sh]' \
  '--issue[issue a certificate]' \
  '--renew[renew a certificate]' \
  '--renew-all[renew all certificates]' \
  '--revoke[revoke a certificate]' \
  '--remove[remove a certificate]' \
  '--list[list all certificates]' \
  '--info[show certificate info]' \
  '--install-cert[install certificate to target paths]' \
  '--register-account[register an account]' \
  '--deactivate-account[deactivate account]' \
  '-d+[specify domain]:domain' \
  '--domain=[specify domain]:domain' \
  '-w+[specify webroot path]:path:_directories' \
  '--webroot=[specify webroot path]:path:_directories' \
  '--standalone[use standalone mode]' \
  '--alpn[use TLS-ALPN-01 challenge]' \
  '--dns[use DNS challenge]:dns plugin' \
  '--dnssleep=[time to wait for DNS propagation]:seconds' \
  '-k+[specify key length]:key length:(2048 3072 4096 ec-256 ec-384)' \
  '--keylength=[specify key length]:key length:(2048 3072 4096 ec-256 ec-384)' \
  '--cert-file=[path to copy certificate to]:file:_files' \
  '--key-file=[path to copy key to]:file:_files' \
  '--ca-file=[path to copy CA certificate to]:file:_files' \
  '--fullchain-file=[path to copy fullchain certificate to]:file:_files' \
  '--reloadcmd=[command to run after cert is renewed]:command' \
  '--server=[ACME directory URL]:url' \
  '--staging[use staging server]' \
  '--force[force operation]' \
  '--debug[enable debug output]' \
  '--log=[log to file]:file:_files' \
  '--log-level=[log level]:level:(1 2)' \
  '--accountemail=[account email]:email' \
  '--auto-upgrade[enable auto upgrade]' \
  '--no-color[disable color output]' && ret=0

return ret
