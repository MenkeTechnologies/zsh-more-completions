#compdef d8flowdir D8FlowDir
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/D8FlowDirections.html
# TauDEM: compute D8 flow directions and slopes

local ret=1

_arguments -s -S \
  '-fel[input pit-filled elevation grid]:felfile:_files' \
  '-p[output D8 flow directions grid]:pfile:_files' \
  '-sd8[output D8 slopes grid]:sd8file:_files' \
  '*:file:_files' && ret=0

return ret
