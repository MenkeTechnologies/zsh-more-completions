#compdef mednaffe
# Documentation: https://github.com/AmatCoder/mednaffe/blob/master/src/mednaffe.c
# Reference accessed: 2026-05-16
# Verified: src/mednaffe.c main() (lines 77-113) - no GOptionEntry table,
# no g_application_add_main_option*. Only inherited GtkApplication/GApplication
# standard flags available.

# mednaffe: GTK GUI for Mednafen (no positional args; pure GUI front-end)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show GLib stock help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display to use]:display:' \
  '--class=[program class as used by window manager]:class:' \
  '--name=[program name as used by window manager]:name:' \
  '--gtk-debug=[GTK debug flags]:flags:' \
  '--gtk-no-debug=[GTK debug flags to disable]:flags:' && ret=0
return ret
