#compdef mkclean
# Documentation: https://github.com/Matroska-Org/foundation-source/blob/master/mkclean/mkclean.c
# mkclean - clean and optimize Matroska/WebM files

local ret=1

_arguments -s -S \
  '--keep-cues[keep original Cues content and move it to the front]' \
  '--doctype=[force doctype version]:version:(1 2 3 4 5)' \
  '--live[output file resembles a live stream]' \
  '--timecodescale=[force global TimecodeScale value]:scale:' \
  '--unsafe[do not output elements used for file recovery]' \
  '--optimize[use all possible optimization for output file]' \
  '--optimize_nv[optimize output, except video tracks]' \
  '--no-optimize[disable some optimization for output file]' \
  '--regression[output file suitable for regression tests]' \
  '--alt-3d=[track ID has alternate 3D fields (left first)]:track:' \
  '--quiet[only output errors]' \
  '--help[display options summary]' \
  '--version[display program version]' \
  '*:matroska file:_files -g "*.mkv *.mka *.mks *.mk3d *.webm *.weba"' && ret=0

return ret
