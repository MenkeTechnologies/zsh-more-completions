#compdef tdbrestore
# Documentation: https://manpages.debian.org/bookworm/tdb-tools/tdbrestore.8.en.html
# Reference accessed: 2026-05-16
# Verified: upstream lib/tdb/tools/tdbrestore.c - takes single positional
# dbname argument, reads tdbdump output from stdin. No flags.

# tdbrestore: restore TDB database from tdbdump output (stdin)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:dbname:_files -g "*.tdb"' && ret=0
return ret
