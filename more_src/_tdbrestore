#compdef tdbrestore
# Documentation: https://manpages.debian.org/bookworm/tdb-tools/tdbrestore.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tdbrestore: restore TDB database from tdbdump output (stdin)
# Single positional dbname argument, reads tdbdump output from stdin. No flags.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:dbname:_files -g "*.tdb"' && ret=0
return ret
