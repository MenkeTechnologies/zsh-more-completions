#compdef repeatgen
# Documentation: https://github.com/dftbplus/dftbplus/blob/main/tools/dptools/src/dptools/scripts/repeatgen.py
# DFTB+ dptools: build a supercell by repeating a gen geometry along lattice vectors

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --lattice-file)'{-l,--lattice-file}'+[file containing lattice vectors (overrides input)]:file:_files' \
  '(-o --output)'{-o,--output}'+[output file to store the resulting geometry]:file:_files' \
  '(-p --phonons)'{-p,--phonons}'[create a repeat geometry for phonon bandstructure]' \
  '1:gen input file:_files -g "*.gen"' \
  '2:N1 (repetition along first lattice vector):' \
  '3:N2 (repetition along second lattice vector):' \
  '4:N3 (repetition along third lattice vector):' && ret=0

return ret
