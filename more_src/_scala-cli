#compdef scala-cli

# Zsh completion for scala-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'compile:compile Scala code'
      'doc:generate API documentation'
      'fmt:format Scala code'
      'repl:start a Scala REPL'
      'run:compile and run Scala code'
      'shebang:run a script with shebang header'
      'test:compile and test Scala code'
      'bsp:start a BSP server'
      'clean:clean build directory'
      'export:export project to sbt or Mill'
      'fix:fix sources'
      'github:manage GitHub actions'
      'install:install completions and bloop'
      'install-completions:install shell completions'
      'install-home:install scala-cli'
      'new:create a new project'
      'package:compile and package Scala code'
      'pgp:PGP operations'
      'publish:publish Scala artifacts'
      'publish-local:publish locally'
      'setup-ide:generate IDE configuration'
      'uninstall:uninstall scala-cli'
      'update:update scala-cli'
      'version:print version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run|compile|test|repl|fmt|package)
        _arguments -s -S \
          '--scala=[Scala version]:version' \
          '--scala-version=[Scala version]:version' \
          '-S[Scala version]:version' \
          '--jvm=[JVM to use]:jvm' \
          '-j[JVM to use]:jvm' \
          '--java-home=[Java home]:directory:_directories' \
          '-O[scalac option]:option' \
          '--dep=[add dependency]:dependency' \
          '--jar=[add JAR]:jar:_files -g "*.jar"' \
          '--source=[add source]:source:_files' \
          '--resource-dir=[resource directory]:directory:_directories' \
          '--main-class=[main class]:class' \
          '-w[watch for changes]' \
          '--watch[watch for changes]' \
          '--restart[restart on changes]' \
          '--power[enable power mode]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:sources:_files -g "*.{scala,sc,java}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
