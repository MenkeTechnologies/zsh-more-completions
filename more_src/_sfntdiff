#compdef sfntdiff
# Documentation: https://adobe-type-tools.github.io/afdko/AFDKO-Overview.html
# AFDKO: low-level comparison of two OpenType font files

local ret=1

_arguments -s -S \
  '-u[print usage information]' \
  '-h[print usage and help information]' \
  '-T[show time-stamp of font files]' \
  '-d[set diff level of detail (0-4)]:level:(0 1 2 3 4)' \
  '(-i)-x[exclude one or more tables from comparisons]:tags:' \
  '(-x)-i[include only these tables for comparisons]:tags:' \
  '*:font:_files' && ret=0

return ret
