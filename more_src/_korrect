autoload -U is-at-least

_korrect() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_korrect_commands" \
"*::: :->korrect" \
&& ret=0
    case $state in
    (korrect)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:korrect-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[]' \
'--help[]' \
'-h[Print help]' \
'--help[Print help]' \
'::shell -- Generates shell completion scripts:(bash elvish fish nushell powershell zsh)' \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
'--force[Remove existing korrect installed files non-interactively.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
'--download-mode=[Define whether to download versions of kubectl or helm when desired]:DOWNLOAD_MODE:(never always ask)' \
'--version-strategy=[Latest will always use the latest available compatible version of kubectl or helm. Exact will match the server version.]:VERSION_STRATEGY:(exact latest)' \
'--no-manage-helm[Do not use korrect-shim to manage helm.]' \
'--force[Write/Overwrite existing korrect files non-interactively.]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_korrect__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:korrect-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(uninstall)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(setup)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_korrect_commands] )) ||
_korrect_commands() {
    local commands; commands=(
'completions:Generates shell completions' \
'uninstall:Removes all korrect installed files' \
'setup:Installs and configures the korrect-shim and creates the cache' \
'list:Lists the installed shimmed binaries' \
'config:Print the configuration' \
'version:Print the version' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'korrect commands' commands "$@"
}
