#compdef rdkit2fps
# Documentation: https://chemfp.readthedocs.io/en/latest/tools.html
# chemfp fingerprint generator using the RDKit toolkit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--id-tag=[SD field for record identifiers]:tag:' \
  '-o+[output filename]:file:_files' \
  '--using=[match fingerprint type from reference file]:file:_files' \
  '--rdmaccs[generate RDMACCS-type fingerprints]' \
  '--maccs166[create MACCS 166-bit fingerprints]' \
  '--morgan[generate Morgan circular fingerprints]' \
  '--radius=[Morgan fingerprint radius]:n:' \
  '--no-progress[disable progress display]' \
  '--errors=[error handling mode]:handler:(ignore report strict)' \
  '--type=[custom fingerprint type definition]:type:' \
  '*:structure file:_files' && ret=0

return ret
