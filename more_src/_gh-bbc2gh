#compdef gh-bbc2gh gh-blame-pr gh-view-md gh-xplr
# Documentation: upstream READMEs at github.com/{gh-migration-tools/gh-bbc2gh,uasi/gh-blame-pr,joshbeckman/gh-view-md,sayanarijit/gh-xplr}
# Reference accessed: 2026-05-30
# gh-extension family round 15. Cross-language harvest (C# + Ruby + Lua).
# Hunt-defer log this round:
#   gh-gl2gh (gh-migration-tools/gh-gl2gh) — README documents the
#     migrate-repo subcommand + --docker-image but doesn't enumerate
#     all flags. Defer until upstream documents the rest.
#   gh-note (vikdotdev/gh-note) — README documents purpose and planned
#     features but doesn't enumerate current CLI flags. Defer per the
#     gh-grep precedent.
#   gh-hello (akordowski/gh-hello) — template repo for building C#-based
#     gh extensions, not a real tool. Skip per template-repo precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-bbc2gh)
    # gh-migration-tools/gh-bbc2gh — Bitbucket Cloud → GitHub migration.
    # Single documented subcommand `migrate-repo` with many flags.
    local -a _subcmds
    _subcmds=(
      'migrate-repo:migrate a Bitbucket Cloud repo to GitHub'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-bbc2gh subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          migrate-repo)
            _arguments \
              '--bitbucket-workspace=[Bitbucket workspace identifier (required)]:workspace:' \
              '--bitbucket-repo=[Bitbucket repo name (required)]:repo:' \
              '--github-org=[target GitHub organization (required)]:org:' \
              '--github-repo=[target GitHub repository name (required)]:repo:' \
              '--bitbucket-open-prs-only[migrate only active PRs]' \
              '--bitbucket-prs-from-date=[filter PRs by creation date]:date (YYYY-MM-DD):' \
              '--target-repo-visibility=[target repo visibility]:visibility:(public private internal)' \
              '--queue-only[queue migration without waiting]' \
              '--archive-path=[local archive file (skip auto-retrieval)]:file:_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-blame-pr)
    # uasi/gh-blame-pr — find the most recent PR that modified a file.
    #   gh blame-pr [<options>] [--] <path>
    _arguments -s -S \
      '--max-count=[number of recent PRs to retrieve (default 1)]:N:' \
      '--no-browser[display URLs instead of opening browser]' \
      '--log[show merge commit logs and modification details]' \
      '-L+[line range to analyze]:range:' \
      '--merged-to=[merge destination branch]:branch:__git_branch_names' \
      '1:file path:_files' \
      && ret=0
    ;;

  gh-view-md)
    # joshbeckman/gh-view-md — render issues/PRs as markdown for LLM input.
    _arguments -s -S \
      '(-h --help)-h[show help]' \
      '(-h --help)--help[show help]' \
      '--max-diff=[diff line limit for PRs (default 800)]:lines:' \
      '1:issue or PR URL:' \
      && ret=0
    ;;

  gh-xplr)
    # sayanarijit/gh-xplr — interactive repo browser via xplr TUI.
    _arguments -s -S \
      '1:username/repository:' \
      && ret=0
    ;;

esac

return ret
