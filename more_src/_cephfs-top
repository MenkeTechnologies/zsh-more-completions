#compdef cephfs-top
# Documentation: https://docs.ceph.com/en/latest/man/8/cephfs-top/
# Display CephFS client performance metrics in a top-like interface.

local ret=1

_arguments -s -S \
  '--cluster=[Ceph cluster to connect to]:cluster:' \
  '--id=[client used to connect to the cluster]:id:' \
  '--selftest[run a sanity check of the stats module]' \
  '--conffile=[path to cluster configuration file]:file:_files' \
  '(-d --delay)'{-d+,--delay=}'[refresh interval in seconds]:secs:' \
  '--dump[output metrics to standard output]' \
  '--dumpfs=[dump metrics of the given filesystem to stdout]:fs:' && ret=0

return ret
