#compdef nanoemoji
# Documentation: https://github.com/googlefonts/nanoemoji
# Build color fonts (COLR/SVG/CBDT/sbix) from SVG sources

local ret=1

_arguments -s -S \
  '--helpfull[show all help including absl flags]' \
  '--upem=[units per em]:upem' \
  '--width=[advance width]:width' \
  '--ascender=[ascender]:ascender' \
  '--descender=[descender]:descender' \
  '--linegap=[line gap]:linegap' \
  '--transform=[user transform, in font coordinates]:transform' \
  '--version_major=[major version]:major' \
  '--version_minor=[minor version]:minor' \
  '--family=[family name]:family' \
  '--output_file=[output filename]:file:_files' \
  '--color_format=[color table format]:format' \
  '--keep_glyph_names[store glyph names in the font]' \
  '--clip_to_viewbox[clip content outside viewbox]' \
  '--reuse_tolerance=[glyph reuse tolerance]:tolerance' \
  '--ignore_reuse_error[ignore glyph reuse errors]' \
  '--pretty_print[pretty-print output XML]' \
  '--fea_file=[feature file]:file:_files' \
  '--bitmap_resolution=[bitmap resolutions]:resolutions' \
  '--use_zopflipng[compress PNGs using zopfli]' \
  '--use_pngquant[quantize PNGs using pngquant]' \
  '--pngquant_flags=[additional options to pass to pngquant]:flags' \
  '--gen_svg_font_diffs[generate image diffs of SVG vs compiled font output]' \
  '*:svg file:_files -g "*.(svg|SVG)"' && ret=0

return ret
