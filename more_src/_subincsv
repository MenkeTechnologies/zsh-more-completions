#compdef subincsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/subincsv.c
# SUBINCSV - 3D grid resolve and assign traces to cdps (cells)

local ret=1

_arguments -s -S \
  'rfile=[read a K-file containing parameter values]:f:_files' \
  'wfile=[write a K-file with parameter values]:f:_files' \
  'bintype=[binning option number]:b:' \
  'offset=[1 recompute offset key, 0 do not]:o:(0 1)' \
  'check=[1 print grid checking details]:c:(0 1)' \
  'rpkey=[receiver point key name]:k:' \
  'spkey=[source point key name]:k:' \
  'point_cru=[receiver point u coordinate]:p:' \
  'point_crz=[receiver point z coordinate]:p:' \
  'point_csu=[source point u coordinate]:p:' \
  'point_csz=[source point z coordinate]:p:' \
  'grid_xa=[grid corner A x coordinate]:g:' \
  'grid_ya=[grid corner A y coordinate]:g:' \
  'grid_xb=[grid corner B x coordinate]:g:' \
  'grid_yb=[grid corner B y coordinate]:g:' \
  'grid_xc=[grid corner C x coordinate]:g:' \
  'grid_yc=[grid corner C y coordinate]:g:' \
  'grid_wb=[grid cell width inline]:g:' \
  'grid_wc=[grid cell width crossline]:g:' \
  '*:SU file:_files' && ret=0

return ret
