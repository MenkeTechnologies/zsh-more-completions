#compdef encode_keychange
# Documentation: encode_keychange -h (Net-SNMP)
# Source: SNMPv3 KeyChange TC: encode old/new keys for user provisioning.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[echo passphrases to terminal (visible)]' \
    '-f[force read passphrases from stdin]' \
    '-P[turn off prompt indicators]' \
    '-v[verbose]' \
    '-t+[HMAC hash transform]:type:(md5 sha1)' \
    '-O+[old passphrase]:passphrase:' \
    '-N+[new passphrase]:passphrase:' \
    '-E+[engineID (hex with 0x prefix)]:engineid:' \
    && ret=0

return ret
