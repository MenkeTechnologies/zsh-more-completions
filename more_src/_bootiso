#compdef bootiso
# Zsh completion for bootiso - USB bootable ISO creator
# https://github.com/jsamr/bootiso

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device}'[set target USB device]:device:_files -W /dev' \
  '(-a --autoselect)'{-a,--autoselect}'[auto-select USB device if only one]' \
  '(-J --no-eject)'{-J,--no-eject}'[do not eject device after completion]' \
  '(-y --assume-yes)'{-y,--assume-yes}'[do not prompt for confirmation]' \
  '(-M --no-mime-check)'{-M,--no-mime-check}'[skip MIME type check]' \
  '(-H --no-hash-check)'{-H,--no-hash-check}'[skip hash verification]' \
  '--hash-file=[file containing hash to verify]:hash file:_files' \
  '(-t --type)'{-t,--type}'[set ISO type]:type:(hybrid dd raw)' \
  '--dd[force dd mode]' \
  '--icopy[force image copy mode (like dd)]' \
  '(-e --esp-size)'{-e,--esp-size}'[set EFI system partition size in MiB]:size:' \
  '(-L --label)'{-L,--label}'[set USB device label]:label:' \
  '(-f --format)'{-f,--format}'[format USB device before writing]' \
  '(-F --filesystem)'{-F,--filesystem}'[set filesystem type]:filesystem:(fat32 ntfs exfat ext4)' \
  '(-p --probe)'{-p,--probe}'[only probe the ISO and exit]' \
  '(-l --list-usb-drives)'{-l,--list-usb-drives}'[list available USB drives]' \
  '--no-wimsplit[disable wim file splitting for NTFS ISOs]' \
  '--local-bootloader[use local bootloader for UEFI]' \
  '--remote-bootloader=[download bootloader]:URL:' \
  '--no-size-check[skip device size check]' \
  '*:ISO image file:_files -g "*.iso(-.)"'
