#compdef airgraph-ng
# Documentation: https://man.archlinux.org/search?q=airgraph-ng
# Reference accessed: 2026-05-16

# airgraph-ng: visualise airodump-ng CSV output as a graph
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-i[input CSV from airodump-ng]:file:_files -g "*.csv"' \
  '--input=[input CSV from airodump-ng]:file:_files -g "*.csv"' \
  '-o[output image]:file:_files' \
  '--output=[output image]:file:_files' \
  '-g[graph type]:type:(CAPR CPG)' \
  '--graph=[graph type]:type:(CAPR CPG)' \
  '-d[depth]:n:' \
  '*::airgraph-ng args:_files' && ret=0
return ret
