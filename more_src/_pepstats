#compdef pepstats
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepstats.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepstats: statistics of protein properties (MW, pI, AA composition)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-aadata=[amino acid properties data file]:file:_files' \
  '-mwdata=[molecular weight data file]:file:_files' \
  '-pkdata=[pKa data file]:file:_files' \
  '-termini[show N-/C-terminal residue analysis]' \
  '-mono[use monoisotopic masses]' \
  '-outfile=[report output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
