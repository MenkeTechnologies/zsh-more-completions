#compdef mrbayes mb
# Documentation: https://man.archlinux.org/search?q=mrbayes
# Reference accessed: 2026-05-16

# MrBayes: Bayesian phylogenetic inference via MCMC
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-i[interactive mode (also default)]' \
  '*:NEXUS data/script file:_files -g "*.(nex|nexus|nx|nxs)"' && ret=0
return ret
