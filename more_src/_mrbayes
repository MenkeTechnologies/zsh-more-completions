#compdef mrbayes mb
# Documentation: https://nbisweden.github.io/MrBayes/manual.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MrBayes Bayesian phylogenetic
# inference via MCMC. Documented flags limited to -h and -i (interactive
# after file processing).

local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[interactive mode after file processing]' \
  '*:NEXUS data/script file:_files -g "*.(nex|nexus|nx|nxs)"' && ret=0
return ret
