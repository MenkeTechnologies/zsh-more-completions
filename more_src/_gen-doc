#compdef gen-doc
# _gen-doc — generate Markdown documentation from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/docgen.py (click).

_gen-doc() {
    local -a args
    args=(
        '(-d --directory)'{-d+,--directory=}'[output directory]:dir:_files -/'
        '--index-name=[name of the index document (default index)]:name:'
        '--dialect=[Markdown dialect / flavor]:dialect:(myst docusaurus mkdocs gh)'
        '--diagram-type=[diagram type to include]:type:(plantuml-class-diagram mermaid-class-diagram er-diagram none)'
        '--include-top-level-diagram[include a top-level diagram in the index]'
        '--no-include-top-level-diagram[omit the top-level diagram]'
        '--sort-by=[sort order for classes / slots]:order:(name rank uri)'
        '--genmeta[generate per-class metadata pages]'
        '--no-genmeta[do not generate metadata pages]'
        '--template-directory=[directory of custom jinja2 templates]:dir:_files -/'
        '--use-slot-uris[render slot URIs as headings]'
        '--no-use-slot-uris[render slot names as headings]'
        '--use-class-uris[render class URIs as headings]'
        '--no-use-class-uris[render class names as headings]'
        '--hierarchical-class-view[render the class hierarchy as a tree]'
        '--no-hierarchical-class-view[render classes as a flat list]'
        '--render-imports[render imported classes]'
        '--no-render-imports[skip imported classes]'
        '--example-directory=[directory of example YAML files to embed]:dir:_files -/'
        '*--include=[only include classes / slots matching this pattern]:pattern:'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-doc "$@"
