#compdef CollectRnaSeqMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectRnaSeqMetrics
# Picard: collect metrics describing the distribution of RNA-seq read bases

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  '--REF_FLAT=[gene annotations in refFlat format]:file:_files' \
  '--RIBOSOMAL_INTERVALS=[location of rRNA sequences (interval list)]:interval_list:_files -g "*.interval_list"' \
  '--STRAND_SPECIFICITY=[strand-specific library prep designation]:strand:(NONE FIRST_READ_TRANSCRIPTION_STRAND SECOND_READ_TRANSCRIPTION_STRAND)' \
  '--MINIMUM_LENGTH=[minimum transcript length for coverage calculations]:int:' \
  '--CHART_OUTPUT=[PDF plot output file]:pdf:_files -g "*.pdf"' \
  '*--IGNORE_SEQUENCE=[sequences to exclude from analysis]:seq:' \
  '--RRNA_FRAGMENT_PERCENTAGE=[overlap percentage for rRNA classification]:float:' \
  '--METRIC_ACCUMULATION_LEVEL=[level at which to accumulate metrics]:level:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
