#compdef git-gh-pages git-ignore-io git-lock git-locked git-local-commits git-show-merged-branches git-show-unmerged-branches git-show-tree git-stamp git-utimes
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 4. Companion to rounds 150 (_git-effort),
# 151 (_git-abort), 152 (_git-magic) + the pre-existing _git-changelog /
# _git-info / _git-ignore standalone files.

local curcontext="$curcontext" state line ret=1

case $service in

  git-gh-pages)
    # man/git-gh-pages.1 — no options. Creates the gh-pages branch with
    # a default initial index.html.
    _arguments -s -S \
      && ret=0
    ;;

  git-ignore-io)
    # man/git-ignore-io.1 — manage .gitignore via gitignore.io types.
    # Multiple long/short pairs; --append/--replace take type lists,
    # --list-in-table/--list-alphabetically are pure switches.
    _arguments -s -S \
      '(-a --append -r --replace)-a+[append types to .gitignore]:types:' \
      '(-a --append -r --replace)--append=[append types to .gitignore]:types:' \
      '(-a --append -r --replace)-r+[replace .gitignore with types]:types:' \
      '(-a --append -r --replace)--replace=[replace .gitignore with types]:types:' \
      '(-l --list-in-table -L --list-alphabetically)-l[print available types in table format]' \
      '(-l --list-in-table -L --list-alphabetically)--list-in-table[print available types in table format]' \
      '(-l --list-in-table -L --list-alphabetically)-L[print available types in alphabetical order]' \
      '(-l --list-in-table -L --list-alphabetically)--list-alphabetically[print available types in alphabetical order]' \
      '(-s --search)-s+[search word in available types]:word:' \
      '(-s --search)--search=[search word in available types]:word:' \
      '(-t --show-update-time)-t[show last modified time of ~/.gi_list]' \
      '(-t --show-update-time)--show-update-time[show last modified time of ~/.gi_list]' \
      '(-u --update-list)-u[update ~/.gi_list]' \
      '(-u --update-list)--update-list[update ~/.gi_list]' \
      && ret=0
    ;;

  git-lock)
    # man/git-lock.1 — mark a file as locked via the assume-unchanged bit.
    _arguments -s -S \
      '1:filename to lock:_files' \
      && ret=0
    ;;

  git-locked)
    # man/git-locked.1 — list all locked files. No options.
    _arguments -s -S \
      && ret=0
    ;;

  git-local-commits)
    # man/git-local-commits.1 — show commits not yet pushed.
    # All args are passed directly to `git log`.
    _arguments -s -S \
      '*:git log argument:' \
      && ret=0
    ;;

  git-show-merged-branches)
    # man/git-show-merged-branches.1 — no options.
    _arguments -s -S \
      && ret=0
    ;;

  git-show-unmerged-branches)
    # man/git-show-unmerged-branches.1 — no options.
    _arguments -s -S \
      && ret=0
    ;;

  git-show-tree)
    # man/git-show-tree.1 — no options.
    # Displays decorated commit-history graph across all branches.
    _arguments -s -S \
      && ret=0
    ;;

  git-stamp)
    # man/git-stamp.1 — append issue references to the last commit message.
    #   git stamp [<options>] <id> [<messages>]
    _arguments -s -S \
      '(-r --replace)-r[replace previous stamps sharing the same id]' \
      '(-r --replace)--replace[replace previous stamps sharing the same id]' \
      '1:stamp id:' \
      '*:stamp message(s):' \
      && ret=0
    ;;

  git-utimes)
    # man/git-utimes.1 — restore file mtimes to last-commit dates.
    _arguments -s -S \
      '--newer[only touch files newer than their last commit]' \
      && ret=0
    ;;

esac

return ret
