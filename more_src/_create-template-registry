#compdef create-template-registry
# Documentation: https://www.npmjs.com/package/create-template-registry
# Reference accessed: 2026-05-23
# Verified: npm view create-template-registry bin; npm readme CLI Options section.

# Zsh completion for create-template-registry - internal template registry scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--template=[template id]:template:(discord discord-base)'   '--dir=[target directory]:directory:_directories'   '--name=[project name for package.json]:name:'   '--package-manager=[package manager]:manager:(npm pnpm yarn)'   '--install[install dependencies automatically]'   '--skip-install[skip dependency installation]'   '--git[initialize git repository]'   '--skip-git[skip git initialization]'   '--advanced[enable advanced template-specific options]'   '--yes[skip interactive prompts and use defaults]'   '--list-templates[list available templates and exit]' && ret=0

return ret
