#compdef ovs-parse-backtrace
# _ovs-parse-backtrace — Open vSwitch ovs-parse-backtrace symbolize raw OVS process backtraces using local binary symbols (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-parse-backtrace() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '*:binary:_files'
}

_ovs-parse-backtrace "$@"
