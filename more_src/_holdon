#compdef holdon
# Source: cargo binstall holdon@0.2.1
# Probed via: --generate-completion zsh
# Repository: https://github.com/imjustprism/holdon

autoload -U is-at-least

_holdon() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--config=[Load defaults and additional targets from a TOML file]:PATH:_files' \
'--generate-completion=[Print a shell completion script to stdout and exit]:SHELL:(bash zsh fish power-shell elvish)' \
'-t+[]:TIMEOUT:_default' \
'--timeout=[]:TIMEOUT:_default' \
'--interval=[]:INTERVAL:_default' \
'--max-interval=[]:MAX_INTERVAL:_default' \
'--initial-delay=[]:INITIAL_DELAY:_default' \
'--attempt-timeout=[]:ATTEMPT_TIMEOUT:_default' \
'--output=[]:OUTPUT:(plain quiet json)' \
'--success-threshold=[]:SUCCESS_THRESHOLD:_default' \
'--at-least=[]:AT_LEAST:_default' \
'--expect-status=[]:EXPECT_STATUS:_default' \
'--timeout-exit-code=[]:TIMEOUT_EXIT_CODE:_default' \
'*-H+[Extra HTTP request header \`Name\: Value\` (repeatable)]:HEADERS:_default' \
'*--header=[Extra HTTP request header \`Name\: Value\` (repeatable)]:HEADERS:_default' \
'--method=[HTTP method for http(s)\:// probes]:METHOD:(get head post put delete options)' \
'--data=[Request body for http(s)\:// probes (sent as application/octet-stream unless overridden by -H)]:BODY:_default' \
'--expect-body=[Substring that must appear in the HTTP response body]:EXPECT_BODY:_default' \
'--expect-body-regex=[Regex the HTTP response body must match]:PATTERN:_default' \
'--expect-json=[Require JSON pointer POINTER (RFC 6901) to equal VALUE (e.g. /status=UP)]:POINTER=VALUE:_default' \
'--ca-cert=[Append PEM CA certificate(s) from PATH to the bundled webpki roots]:PATH:_files' \
'--tls-min=[Minimum TLS version for HTTPS probes]:TLS_MIN:(1.2 1.3)' \
'--generate-manpage[Print the man page to stdout and exit]' \
'-q[]' \
'--quiet[]' \
'--reverse[]' \
'--once[]' \
'-s[]' \
'--strict[]' \
'--sequential[]' \
'--no-jitter[]' \
'--no-color[]' \
'*-v[]' \
'*--verbose[]' \
'--insecure[Skip TLS certificate verification (dev only)]' \
'--no-follow-redirects[Do not follow HTTP redirects; report the first response status]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::targets:_default' \
&& ret=0
}

(( $+functions[_holdon_commands] )) ||
_holdon_commands() {
    local commands; commands=()
    _describe -t commands 'holdon commands' commands "$@"
}

if [ "$funcstack[1]" = "_holdon" ]; then
    _holdon "$@"
else
    compdef _holdon holdon
fi
