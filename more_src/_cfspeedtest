#compdef cfspeedtest
# Source: cargo binstall cfspeedtest@2.2.2
# Probed via: --generate-completion zsh
# Repository: https://github.com/code-inflation/cfspeedtest/

autoload -U is-at-least

_cfspeedtest() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-n+[Number of test runs per payload size]:NR_TESTS:_default' \
'--nr-tests=[Number of test runs per payload size]:NR_TESTS:_default' \
'--nr-latency-tests=[Number of latency tests to run]:NR_LATENCY_TESTS:_default' \
'-m+[The max payload size in bytes to use \[100k, 1m, 10m, 25m or 100m\]]:MAX_PAYLOAD_SIZE:_default' \
'--max-payload-size=[The max payload size in bytes to use \[100k, 1m, 10m, 25m or 100m\]]:MAX_PAYLOAD_SIZE:_default' \
'-o+[Set the output format \[csv, json or json-pretty\] > This silences all other output to stdout]:OUTPUT_FORMAT:_default' \
'--output-format=[Set the output format \[csv, json or json-pretty\] > This silences all other output to stdout]:OUTPUT_FORMAT:_default' \
'(--ipv6)--ipv4=[Force IPv4 with provided source IPv4 address or the default IPv4 address bound to the main interface]::IPv4:_default' \
'(--ipv4)--ipv6=[Force IPv6 with provided source IPv6 address or the default IPv6 address bound to the main interface]::IPv6:_default' \
'--generate-completion=[Generate shell completion script for the specified shell]:COMPLETION:(bash elvish fish powershell zsh)' \
'-v[Enable verbose output i.e. print boxplots of the measurements]' \
'--verbose[Enable verbose output i.e. print boxplots of the measurements]' \
'-d[Disables dynamically skipping tests with larger payload sizes if the tests for the previous payload size took longer than 5 seconds]' \
'--disable-dynamic-max-payload-size[Disables dynamically skipping tests with larger payload sizes if the tests for the previous payload size took longer than 5 seconds]' \
'(--upload-only)--download-only[Test download speed only]' \
'(--download-only)--upload-only[Test upload speed only]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
}

(( $+functions[_cfspeedtest_commands] )) ||
_cfspeedtest_commands() {
    local commands; commands=()
    _describe -t commands 'cfspeedtest commands' commands "$@"
}

if [ "$funcstack[1]" = "_cfspeedtest" ]; then
    _cfspeedtest "$@"
else
    compdef _cfspeedtest cfspeedtest
fi
