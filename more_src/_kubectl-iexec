#compdef kubectl-iexec

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[search all namespaces]' \
  '(-c --container)'{-c,--container=}'[container name filter]:container:' \
  '(-l --selector)'{-l,--selector=}'[label selector]:selector:' \
  '(--log-level)'--log-level='[log level]:level:(trace debug info warn error fatal panic)' \
  '(-v --vim-mode)'{-v,--vim-mode}'[vim-style selection UI]' \
  '(-x --naked)'{-x,--naked}'[disable color/decoration]' \
  '--as=[username to impersonate]:user:' \
  '--as-group=[group to impersonate]:group:' \
  '--as-uid=[UID to impersonate]:uid:' \
  '--cache-dir=[local cache directory]:dir:_files -/' \
  '--certificate-authority=[kube CA bundle]:file:_files' \
  '--client-certificate=[client cert]:file:_files' \
  '--client-key=[client key]:file:_files' \
  '--cluster=[kube cluster name]:cluster:' \
  '--context=[kube context]:context:' \
  '--disable-compression[toggle compression]' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--request-timeout=[request timeout]:duration:' \
  '--server=[Kubernetes API address]:url:' \
  '--tls-server-name=[TLS SNI name]:name:' \
  '--token=[bearer token]:token:' \
  '--user=[kube user]:user:' \
  '--namespace=[override namespace]:namespace:' \
  '1:pod name filter:' \
  '*:remote command: _default'
