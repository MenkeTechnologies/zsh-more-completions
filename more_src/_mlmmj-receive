#compdef mlmmj-receive
# Documentation: https://mlmmj.org/mlmmj-receive.html
# Reference accessed: 2026-05-30
# mlmmj-receive — entry point for mail delivered to mlmmj mailing lists. `-L PATH` is REQUIRED.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L+[full path to list directory (REQUIRED)]:dir:_directories' \
  '-P[skip mlmmj-process(1) execution (debug)]' \
  '-F[do not background/fork (debug)]' \
  && ret=0

return ret
