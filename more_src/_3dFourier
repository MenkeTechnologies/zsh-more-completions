#compdef 3dFourier
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dFourier.html
# Lowpass and/or highpass each voxel time series via the FFT

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-prefix[output 3D+time dataset name]:prefix:' \
  '-lowpass[low pass filter cutoff in Hz]:f:' \
  '-highpass[high pass filter cutoff in Hz]:f:' \
  '-ignore[ignore the first n images]:n:' \
  '-retrend[restore mean and linear trend after filtering]' \
  '*:dataset:_files' && ret=0

return ret
