# _hy-cli — Paul Tagliamonte Hylang hy-cli CLI command-line frontend wrapping the Hy Lisp dialect of Python embedded in Python's AST open-source written in Python originally Paul Tagliamonte now Hylang team Hy is a dialect of Lisp seamlessly integrating with the Python ecosystem AST a Lisp embedded in Python a Lisp-flavored python that gets compiled to standard Python AST hy2py hyc hy interactive REPL macros tail-calls quasiquote Python-interop S-expressions clojure-like-syntax cmd command pretty-format spy verbose repl-output-fn -i -s -c -E -V -h (Paul Tagliamonte Hylang team, Python); argparse
# upstream: http://hylang.org/

_hy-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '*-c+[command]:str:' \
        '-i+[script]:file:_files -g "*.hy"' \
        '-m+[module]:str:' \
        '-E[ignore PYTHONPATH]' \
        '-B[no .pyc]' \
        '-S[no site]' \
        '-s+[script]:file:_files -g "*.hy"' \
        '--spy[show Python output]' \
        '--repl-output-fn=+[fn]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--macro-debug[macro debug]' \
        '--show-tracebacks[show tracebacks]' \
        '--debug[debug]' \
        '--show-warnings[show warnings]' \
        '-W+[arg]:str:' \
        '*-W+[arg]:str:' \
        '--repl-output=+[file]:file:_files' \
        '--no-color[no color]' \
        '--with[only with]' \
        '*:hy file:_files -g "*.hy *.py"'
}

_hy-cli "$@"
