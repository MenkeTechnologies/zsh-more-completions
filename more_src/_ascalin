#compdef ascalin
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/ascalin.txt
# Calibrate ASCA Science File to produce linearized detector coordinates and PI values

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'datafile=[ASCA science file to be processed]:data file:_files' \
  'calfile=[Telescope Definition file for the instrument]:cal file:_files' \
  'tempofile=[Temporal History file for the instrument]:tempo file:_files' \
  'attitude=[Attitude File]:attitude file:_files' \
  'pointing=[pointing choice]:choice:(KEY USER ATT)' \
  'ranom=[aspect sky point R.A.]:ra:' \
  'decnom=[aspect sky point DEC]:dec:' \
  'eulerphi=[aspect first Euler angle phi]:angle:' \
  'eulertheta=[aspect second Euler angle theta]:angle:' \
  'gainnorm=[overall gain scale correction to PI values]:scale:' \
  'gainoff=[overall gain offset correction to PI values in keV]:offset:' \
  'verbose=[runtime information updates]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
