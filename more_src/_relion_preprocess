#compdef relion_preprocess
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: extract and normalise particles from micrographs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[STAR file with selected micrographs to extract from]:file:_files' \
  '--coord_suffix=[suffix for the coordinate files]:suffix' \
  '--coord_dir=[directory where the coordinate files are]:dir:_files -/' \
  '--coord_list=[2-column STAR file with micrographs and coordinate files]:file:_files' \
  '--part_dir=[output directory for particle stacks]:dir:_files -/' \
  '--part_star=[output STAR file with all particles metadata]:file:_files' \
  '--pick_star=[output STAR file with micrographs and coordinate files]:file:_files' \
  '--reextract_data_star=[_data.star from a refinement to re-extract]:file:_files' \
  '--float16[write in half-precision 16 bit floating point]' \
  '--keep_ctfs_micrographs[keep CTFs from input micrographs STAR file]' \
  '--reset_offsets[reset origin offsets from input _data.star to zero]' \
  '--recenter[re-center particle according to rlnOriginX/Y]' \
  '--recenter_x=[X-coordinate (pix in reference) to recenter on]:value' \
  '--recenter_y=[Y-coordinate (pix in reference) to recenter on]:value' \
  '--recenter_z=[Z-coordinate (pix in reference) to recenter on]:value' \
  '--ref_angpix=[pixel size of the reference used for recentering]:value' \
  '--extract[extract all particles from the micrographs]' \
  '--extract_size=[size of the box to extract the particles (pixels)]:value' \
  '--premultiply_ctf[premultiply micrograph with its CTF prior to extraction]' \
  '--premultiply_extract_size=[box size before CTF premultiplication]:value' \
  '--ctf_intact_first_peak[leave frequencies intact until the first peak]' \
  '--phase_flip[flip CTF-phases prior to particle extraction]' \
  '--extract_bias_x=[bias in X (pixels) added to coords]:value' \
  '--extract_bias_y=[bias in Y (pixels) added to coords]:value' \
  '--only_do_unfinished[extract only if STAR for that micrograph does not exist]' \
  '--minimum_pick_fom=[minimum rlnAutopickFigureOfMerit for extraction]:value' \
  '--project3d[project sub-tomograms along Z to generate 2D particles]' \
  '--scale=[re-scale the particles to this size (pixels)]:value' \
  '--window=[re-window the particles to this size (pixels)]:value' \
  '--norm[normalise background to average zero and stddev one]' \
  '--no_ramp[just subtract background mean instead of fitted ramp]' \
  '--bg_radius=[radius of circular mask defining background area (pixels)]:value' \
  '--white_dust=[sigma above which white dust is removed]:value' \
  '--black_dust=[sigma above which black dust is removed]:value' \
  '--invert_contrast[invert the contrast in the input images]' \
  '--operate_on=[operate on an input image stack]:file:_files' \
  '--operate_out=[output name when operating on a stack]:file:_files' \
  '--helix[extract helical segments]' \
  '--helical_outer_diameter=[outer diameter of helical tubes (A)]:value' \
  '--helical_tubes[extract helical segments from tube coordinates]' \
  '--helical_nr_asu=[number of helical asymmetrical units]:value' \
  '--helical_rise=[helical rise (A)]:value' \
  '--helical_bimodal_angular_priors[add bimodal angular priors for segments]' \
  '--helical_cut_into_segments[cut helical tubes into segments]' \
  '*:file:_files' && ret=0

return ret
