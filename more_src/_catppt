#compdef catppt

# Zsh completion for catppt - MS PowerPoint to text converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[set input charset]:charset' \
  '-l[list available charsets]' \
  '-s+[set source charset]:charset' \
  '*:files:_files -g "*.{ppt,PPT}"'
