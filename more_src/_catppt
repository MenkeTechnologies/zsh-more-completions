#compdef catppt
# Documentation: https://manpages.debian.org/testing/catdoc/catppt.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for catppt - MS PowerPoint to text converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[set input charset]:charset' \
  '-l[list available charsets]' \
  '-s+[set source charset]:charset' \
  '*:files:_files -g "*.{ppt,PPT}"'
