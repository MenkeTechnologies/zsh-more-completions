#compdef hypercorn

# Zsh completion for hypercorn - ASGI web server

_arguments -s -S \
  '(-b --bind)'{-b,--bind}'[bind address]:address' \
  '--insecure-bind[bind address for insecure HTTP]:address' \
  '--quic-bind[bind address for QUIC]:address' \
  '(-w --workers)'{-w,--workers}'[number of workers]:number' \
  '(-k --worker-class)'{-k,--worker-class}'[worker class]:class:(asyncio uvloop trio)' \
  '--backlog[listen backlog]:number' \
  '--ca-certs[CA certificates file]:file:_files' \
  '--certfile[SSL certificate file]:file:_files' \
  '--keyfile[SSL key file]:file:_files' \
  '--ciphers[SSL ciphers]:ciphers' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--graceful-timeout[graceful timeout in seconds]:seconds' \
  '--keep-alive[keep alive timeout in seconds]:seconds' \
  '--access-log[access log file]:file:_files' \
  '--access-logformat[access log format]:format' \
  '--error-log[error log file]:file:_files' \
  '--log-level[log level]:level:(debug info warning error critical)' \
  '--log-config[log config file]:file:_files' \
  '(-p --pid)'{-p,--pid}'[PID file]:file:_files' \
  '--root-path[ASGI root path]:path' \
  '--reload[enable auto-reload]' \
  '--statsd-host[statsd host]:host' \
  '--statsd-prefix[statsd metrics prefix]:prefix' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':application module' && return 0
