#compdef goplay
# _goplay — Go Playground client CLI
# upstream: https://github.com/phayes/goplay

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '--run[run the code on the playground]' \
    '--fmt[format the code on the playground]' \
    '--share[get a shareable playground URL]' \
    '--url=[playground URL to fetch]:url:_urls' \
    '(-o --output)'{-o,--output=}'[write output to file]:file:_files' \
    '*:Go source files:_files -g "*.go"' \
    && return 0
