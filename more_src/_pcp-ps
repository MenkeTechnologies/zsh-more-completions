#compdef pcp-ps
# _pcp-ps — PCP-based per-process statistics report (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/ps/pcp-ps.1 SYNOPSIS.

_pcp-ps() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '-e[show extended environment info]' \
        '-U+[filter by username]:user:_users' \
        '-c+[filter by command name]:cmd:' \
        '-P+[parent PID list (comma-separated)]:pids:' \
        '-p+[PID list (comma-separated)]:pids:' \
        '-o+[output columns (comma-separated or ALL)]:cols:' \
        '-O+[sort by columns (e.g. %mem,%cpu)]:cols:' \
        '-d[show diagnostic information]' \
        '-Z+[timezone]:tz:' \
        '-z[use archive recording timezone]'
}

_pcp-ps "$@"
