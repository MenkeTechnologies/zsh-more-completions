#compdef phoenix-shell

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h+[help]' \
  '-color+[colorize output]:flag:(true false)' \
  '-fastConnect+[skip table list for tab-completion]:flag:(true false)' \
  '-isolation+[isolation level]:level:' \
  '-maxColumnWidth+[max column width]:n:' \
  '-maxWidth+[max output width]:n:' \
  '-numberFormat+[number format]:format:' \
  '-outputformat+[output format]:format:(table vertical csv tsv)' \
  '-showHeader+[show header]:flag:(true false)' \
  '-showWarnings+[show warnings]:flag:(true false)' \
  '-silent+[silent mode]:flag:(true false)' \
  '-verbose+[verbose]:flag:(true false)' \
  '-d+[driver class]:class:' \
  '-u+[JDBC URL]:url:' \
  '-n+[username]:user:_users' \
  '-p+[password]:password:' \
  '-e+[query]:query:' \
  '-f+[script file]:file:_files -g "*.sql"' \
  '*:additional arg:' && ret=0

return ret
