#compdef phoenix-shell phoenix.shell
# Documentation: https://julianhyde.github.io/sqlline/manual.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# phoenix-shell wraps sqlline (Apache Phoenix SQL CLI).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '-u+[JDBC URL]:url:' \
  '-n+[username]:user:_users' \
  '-p+[password]:password:' \
  '-d+[JDBC driver class]:class:' \
  '-e+[command to execute]:query:' \
  '-f+[script file to execute]:file:_files -g "*.sql"' \
  '-log+[output log file]:file:_files' \
  '-nn+[connection nickname]:name:' \
  '-ch+[custom command handler]:handler:' \
  '--run=[execute script and exit]:file:_files' \
  '--color=[colorize output]:flag:(true false)' \
  '--verbose=[verbose stack traces]:flag:(true false)' \
  '--silent=[silent mode]:flag:(true false)' \
  '--showWarnings=[show warnings]:flag:(true false)' \
  '--showHeader=[show column header]:flag:(true false)' \
  '--showNestedErrs=[show nested errors]:flag:(true false)' \
  '--headerInterval=[header redisplay interval]:n:' \
  '--autoCommit=[auto-commit]:flag:(true false)' \
  '--maxWidth=[max output width]:n:' \
  '--maxColumnWidth=[max column width]:n:' \
  '--isolation=[transaction isolation level]:level:' \
  '--nullValue=[display value for nulls]:val:' \
  '--outputformat=[output format]:format:(table vertical csv tsv xmlattrs xmlelements json ansiconsole)' \
  '*:additional arg:' && ret=0

return ret
