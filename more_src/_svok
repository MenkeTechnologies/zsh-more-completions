#compdef svok
# _svok — daemontools svok (exit 0 if supervise(8) is running for SERVICE, exit 100 if not; standard liveness check in DJB-style monitoring scripts)
# upstream: https://github.com/schmonz/daemontools-encore
# Source: svok.8.in on tip; honors $SUPERVISEDIR.

_svok() {
    _arguments '1:service:_files -/'
}

_svok "$@"
