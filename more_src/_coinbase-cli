#compdef coinbase-cli coinbase
# _coinbase-cli — Coinbase coinbase-cli CLI command-line frontend wrapping the Coinbase Wallet Coinbase Exchange Commerce API managing accounts addresses transactions buys sells deposits withdrawals exchange-rates currencies users notifications-webhook-OAuth2-merchant-checkout-charges-events-shipping (Coinbase team, Go); cobra
# upstream: https://www.coinbase.com/

_coinbase-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'address:address operations'
        'transaction:transaction operations'
        'buy:buy operations'
        'sell:sell operations'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'exchange-rates:exchange rates'
        'currency:currency operations'
        'price:price operations'
        'user:user operations'
        'notification:notification operations'
        'commerce:Coinbase Commerce operations'
        'charge:Commerce charge operations'
        'checkout:Commerce checkout operations'
        'event:Commerce event operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--passphrase=+[phrase]:str:' \
        '--api-url=+[url]:str:' \
        '--api-version=+[v]:str:' \
        '--environment=+[e]:e:(sandbox production)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coinbase-cli subcommand' sub ;;
        args)
            case $words[1] in
                account|address|transaction|buy|sell|deposit|withdrawal|currency|price|user|notification|commerce|charge|checkout|event) _arguments '1:op:(list get create update delete commit cancel resolve)' '*:id:' ;;
            esac
            ;;
    esac
}

_coinbase-cli "$@"
