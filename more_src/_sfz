#compdef sfz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-b --bind)'{-b,--bind}'=[address to bind]:address' \
  '(-p --port)'{-p,--port}'=[port to listen on]:port' \
  '(-r --root)'{-r,--root}'=[root directory to serve]:directory:_directories' \
  '--render-index[render index.html when accessing a directory]' \
  '--no-log[disable request logging]' \
  '--cors[enable CORS headers]' \
  '--coi[enable cross-origin isolation headers]' \
  '--path-prefix=[URL path prefix]:prefix' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
