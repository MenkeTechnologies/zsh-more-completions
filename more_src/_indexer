#compdef indexer

# Zsh completion for ManticoreSearch indexer
# Documentation: https://manual.manticoresearch.com/

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[config file path]:file:_files -g "*.conf"' \
  '--all[reindex all indexes]' \
  '--rotate[rotate indexes after reindexing]' \
  '--buildstops=[build freq dictionary]:output_file count' \
  '--buildfreqs[also calculate document frequency]' \
  '--merge=[merge two indexes]:dst_index src_index' \
  '--merge-dst-range=[merge range filter]:attr min max' \
  '--merge-killlists[apply kill-lists during merge]' \
  '--dump-rows=[dump fetched rows to file]:file:_files' \
  '--sighup-each[send SIGHUP to searchd after each index]' \
  '--noprogress[suppress progress display]' \
  '--quiet[suppress all output]' \
  '--verbose[verbose output]' \
  '--print-queries[print SQL queries sent to source]' \
  '--print-rt[print data suitable for RT index insertion]' \
  '*:index name:->indexes' && ret=0

case $state in
  indexes)
    # Index names come from the config file; no easy dynamic completion
    _message -e indexes 'index name' && ret=0
    ;;
esac

return ret
