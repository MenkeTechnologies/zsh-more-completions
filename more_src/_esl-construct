#compdef esl-construct

# Easel esl-construct: build consensus secondary structure from MSA
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-a[print all individual sequence structures]' \
  '-r[remove pseudoknots]' \
  '-o[output file]:file:_files' \
  '--ffreq[base-pair frequency threshold]:val:' \
  '--cmin[minimum consensus pair conservation]:val:' \
  '--rfc[require pair to align with RF columns]' \
  '--informat[input format]:fmt:(stockholm pfam a2m afa clustal phylip)' \
  '*:alignment file:_files' && ret=0
return ret
