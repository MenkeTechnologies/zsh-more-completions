#compdef aver
# ============================================================================
# _aver — zsh completion for the Aver programming language, "a statically
#          typed language designed for AI to write in and humans to review"
#          (177th programming language entry, R980 round-number commit
#          landmark)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/jasisz/aver
#   Maintainer : jasisz
#   License    : MIT
#   Stars      : 44
#   Language   : Rust
#   Crate      : aver-lang  ([package] name = "aver-lang",
#                            default-run = "aver")
#   Binary     : aver  ([[bin]] name = "aver", path =
#                       "src/main.rs")
#   Source ext : .av  (Aver source files; `verify`, `intent =`,
#                      `?` doc-strings, `! [effects]`, qualified
#                      constructors, single-line match arms — the
#                      grammar curated in llms.txt)
#   Website    : https://averlang.dev
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Aver is a statically-typed language built around the idea
#   that the risky part of AI-written code is not syntax — it is
#   missing intent.  Effects are part of every function signature
#   (`! [Console.print, Args.get]`), `decision` blocks live next
#   to the code they explain, pure behavior lives in colocated
#   `verify <fn>` blocks with `left => right` example arms, and
#   selected effectful behavior can be verified with explicit
#   Oracle stubs (`given X: Time = stub`) and trace assertions
#   (`.trace.*`).  Effectful runs can be recorded and replayed
#   deterministically — recordings are byte-compatible across the
#   VM, the self-host backend, and the wasm-gc backend (a trace
#   written by any one of them replays cleanly under the other
#   two).
#
#   The toolchain is a single multi-command binary `aver` that
#   exposes the run / check / verify / format / audit / why /
#   context / shape / compile / bench / proof / replay surface.
#   Default backends:  the bytecode VM (`aver run`, `verify`,
#   `check`, `replay`), Rust codegen via `aver compile` (default
#   target), wasm-gc codegen via `aver compile --target wasm-gc`,
#   Lean proof export via `aver proof`, Dafny verification via
#   `--verify-mode`.  Project config lives in `aver.toml`
#   (effect-host / path / env-key allowlists, per-path
#   `[[check.suppress]]`, per-project `[[shape.layer]]` and
#   `[[shape.expected]]` fingerprints).
#
# CLI ARGUMENT GRAMMAR  (verbatim from docs/cli.md +
#                       Cargo.toml [[bin]] entries — extracted
#                       via `gh api repos/jasisz/aver/contents
#                       /docs/cli.md`)
#
#   aver <SUBCOMMAND> [args...]
#
#   Subcommands and their flags:
#
#     run <FILE.av> [-- <APP-ARGS>...]
#       --module-root <DIR>          Project root for module
#                                    resolution
#       --record <DIR>               Record effect traces for
#                                    replay
#       --self-host                  Run via the self-host
#                                    backend instead of the VM
#       --wasm-gc                    Run via the wasm-gc backend
#       -e <EXPR>                    Evaluate a top-level
#                                    expression
#
#     check <FILE-OR-DIR>
#       --module-root <DIR>
#       --deps                       Walk module deps as well
#       --json                       Emit machine-readable
#                                    diagnostics
#
#     verify <FILE-OR-DIR>
#       --module-root <DIR>
#       --deps
#       --wasm-gc                    Cross-target check via
#                                    wasm-gc backend
#       --json
#       --hostile                    Layer adversarial worlds
#                                    on every `verify <fn> law`
#                                    block  (0.13+)
#
#     format <PATH>
#       --check                      Exit non-zero on
#                                    formatting drift  (CI gate)
#
#     audit <FILE-OR-DIR>            Single-shot CI gate —
#                                    runs check + verify +
#                                    format --check in one pass
#       --module-root <DIR>
#       --deps
#       --json
#       --hostile
#
#     why <FILE.av>                  Explain reasoning trails
#                                    inside a module
#
#     context <FILE.av>              AI discovery workflow —
#                                    architecture map + selection
#                                    metadata
#       --module-root <DIR>
#       --depth <N|auto|unlimited>   [default: auto]
#       --budget <SIZE>              [default: 10kb]  e.g. 24kb
#       --decisions-only             Export only `decision`
#                                    blocks
#       --json
#       --output <FILE>              Write JSON to FILE
#
#     shape <FILE-OR-DIR>            Static module-shape
#                                    analyzer (archetype +
#                                    ModuleShape vector + Layer
#                                    classifier)
#       --summary                    Collapse per-fn listing
#       --json                       NDJSON for corpus mode
#       --lint                       Opt-in lint vs aver.toml
#                                    `[[shape.expected]]` table
#       --module-root <DIR>
#
#     compile <FILE.av>              Cross-target compiler
#       -o <DIR>                     Output directory
#       --module-root <DIR>
#       --target <KIND>              rust | wasm-gc | wasm
#                                    [default: rust — emits a
#                                    modular Cargo project]
#       --optimize <MODE>            size | speed  (post-process
#                                    via binaryen -Oz / -O3)
#       --preset <NAME>              cloudflare  (Workers pack —
#                                    drops worker.js +
#                                    wrangler.toml)
#       --handler <FN>               Cloudflare handler fn name
#                                    (signature
#                                    `Fn(HttpRequest)
#                                    -> HttpResponse`)
#       --emit-ir-after=<PASS>       parse | tco | typecheck |
#                                    interp_lower | buffer_build
#                                    | resolve | last_use |
#                                    analyze
#       --explain-passes             Per-pass diagnostic report
#                                    (no codegen)
#
#     bench <FILE-OR-DIR-OR-TOML>    Reproducible benchmark
#                                    harness
#       --iterations=<N>             [default: 30]
#       --warmup=<N>                 [default: 3]
#       --target=<KIND>              vm | wasm-local | rust
#                                    [default: vm]
#       --json                       Structured report  (NDJSON
#                                    in directory mode)
#       --save-baseline <FILE>       Capture baseline
#       --compare <FILE>             Compare against baseline
#       --baseline-dir <DIR>         Auto-pick
#                                    `<host.os>-<host.arch>-
#                                    <backend.name>.json`
#       --fail-on-regression         CI gate — exit non-zero
#                                    on regression
#
#     proof <FILE.av>                Lean proof export
#       -o <DIR>
#       --module-root <DIR>
#       --verify-mode <MODE>         auto | sorry |
#                                    theorem-skeleton
#                                    [default: auto]
#
#     replay <RECORDINGS>            Replay effectful run
#                                    captured via `aver run
#                                    --record`
#       --test                       Treat as a test run (exit
#                                    non-zero on divergence)
#       --diff                       Show divergence as a diff
#       --check-args                 Strictly compare call-site
#                                    arg shapes
#       --json
#       --wasm-gc                    Replay through wasm-gc
#                                    backend
#
#   Standard auto-flags:
#     -h, --help                     Show help (also `aver
#                                    <SUBCMD> --help`)
#     -V, --version                  Show version
#
# LANGUAGE-CORPUS POSITION
#   Aver is the 177th programming language entry in this
#   completion corpus and the new round-number landmark (R980
#   commit).  It joins Raven (R976 176th), HydraScript (R972
#   175th), Lazurite (R968 174th), duck-lang (R964 173rd),
#   Rascal (R960 172nd — R960 round-number commit landmark),
#   Ixion (R956 171st), KernelScript (R952 170th — round-number
#   170th-language milestone), Prog8 (R948 169th), Objeck (R944
#   168th), Feral (R940 167th — R940 round-number commit
#   landmark), Biscuit/BL (R936 166th), Rux (R932 165th), Jule
#   (R928 164th), Nevalang (R924 163rd), Corvid (R920 162nd —
#   round-number R920 commit landmark), Soppo (R916 161st),
#   Cyrus (R912 160th — round-number language milestone),
#   Lumina (R908 159th), Penne (R904 158th), EndBASIC (R900
#   157th — R900 TRIPLE-9 commit landmark), goboscript (R896
#   156th), Alan (R892 155th), Mech (R888 154th — triple-8
#   landmark), Lisette (R884 153rd), Bril (R880 152nd), Vyxal
#   (R876 151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th),
#   Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   Verified via:
#     gh api repos/jasisz/aver/contents/Cargo.toml
#       → [package] name = "aver-lang", default-run = "aver"
#       → [[bin]] name = "aver", path = "src/main.rs"
#     gh api repos/jasisz/aver/contents/README.md
#       → "cargo install aver-lang" → installs the `aver` binary
#       → quickstart sequence: aver run / verify / check /
#         audit / why / context / shape / compile / proof /
#         replay
#     gh api repos/jasisz/aver/contents/docs/cli.md
#       → per-command surface for run / check / verify /
#         format / audit / context / shape / compile / bench /
#         proof / replay
#
#   No completion for `aver` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_aver() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_aver_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            local module_root='--module-root=[project root for module resolution]:dir:_files -/'
            case $words[1] in
                run)
                    _arguments \
                        $module_root \
                        '--record=[record effect traces for replay]:dir:_files -/' \
                        '--self-host[run via the self-host backend]' \
                        '--wasm-gc[run via the wasm-gc backend]' \
                        '-e+[evaluate a top-level expression]:expr:' \
                        '1:Aver source file:_files -g "*.av"' \
                        '*::app args:' && ret=0 ;;
                check)
                    _arguments \
                        $module_root \
                        '--deps[walk module deps as well]' \
                        '--json[emit machine-readable diagnostics]' \
                        '*:file or directory:_files -g "*.av"' && ret=0 ;;
                verify)
                    _arguments \
                        $module_root \
                        '--deps[walk module deps as well]' \
                        '--wasm-gc[cross-target check via wasm-gc backend]' \
                        '--json[emit machine-readable output]' \
                        '--hostile[layer adversarial worlds on every verify <fn> law block]' \
                        '*:file or directory:_files -g "*.av"' && ret=0 ;;
                format)
                    _arguments \
                        '--check[exit non-zero on formatting drift]' \
                        '*:path:_files -g "*.av"' && ret=0 ;;
                audit)
                    _arguments \
                        $module_root \
                        '--deps[walk module deps as well]' \
                        '--json[emit machine-readable diagnostics]' \
                        '--hostile[layer adversarial worlds on verify blocks]' \
                        '*:file or directory:_files -g "*.av"' && ret=0 ;;
                why)
                    _arguments \
                        '1:Aver source file:_files -g "*.av"' && ret=0 ;;
                context)
                    _arguments \
                        $module_root \
                        '--depth=[architecture map depth]:depth:(auto unlimited 1 2 3 4 5)' \
                        '--budget=[discovery budget (e.g. 10kb, 24kb)]:size:' \
                        '--decisions-only[export only decision blocks]' \
                        '--json[emit machine-readable JSON]' \
                        '--output=[write JSON to FILE]:file:_files' \
                        '1:Aver source file:_files -g "*.av"' && ret=0 ;;
                shape)
                    _arguments \
                        $module_root \
                        '--summary[collapse per-fn listing]' \
                        '--json[NDJSON output for corpus mode]' \
                        '--lint[lint vs aver.toml [[shape.expected]] table]' \
                        '*:file or directory:_files -g "*.av"' && ret=0 ;;
                compile)
                    _arguments \
                        $module_root \
                        '-o+[output directory]:dir:_files -/' \
                        '--target=[codegen target]:target:(rust wasm-gc wasm)' \
                        '--optimize=[binaryen optimization mode]:mode:(size speed)' \
                        '--preset=[deployment preset]:preset:(cloudflare)' \
                        '--handler=[Cloudflare handler fn name]:fn:' \
                        '--emit-ir-after=[print IR snapshot after pass]:pass:(parse tco typecheck interp_lower buffer_build resolve last_use analyze)' \
                        '--explain-passes[per-pass diagnostic report (no codegen)]' \
                        '1:Aver source file:_files -g "*.av"' && ret=0 ;;
                bench)
                    _arguments \
                        '--iterations=[number of measured iterations]:n:' \
                        '--warmup=[number of warmup iterations]:n:' \
                        '--target=[bench backend]:target:(vm wasm-local rust)' \
                        '--json[structured (NDJSON in directory mode)]' \
                        '--save-baseline=[capture baseline to FILE]:file:_files' \
                        '--compare=[compare against baseline FILE]:file:_files' \
                        '--baseline-dir=[auto-pick baseline from DIR]:dir:_files -/' \
                        '--fail-on-regression[CI gate — exit non-zero on regression]' \
                        '1:.av file, .toml manifest, or directory:_files -g "*.av *.toml"' && ret=0 ;;
                proof)
                    _arguments \
                        $module_root \
                        '-o+[output directory]:dir:_files -/' \
                        '--verify-mode=[Lean export mode]:mode:(auto sorry theorem-skeleton)' \
                        '1:Aver source file:_files -g "*.av"' && ret=0 ;;
                replay)
                    _arguments \
                        '--test[treat as a test run (exit non-zero on divergence)]' \
                        '--diff[show divergence as a diff]' \
                        '--check-args[strictly compare call-site arg shapes]' \
                        '--json[emit machine-readable output]' \
                        '--wasm-gc[replay through wasm-gc backend]' \
                        '1:recordings directory or rec-*.json:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_aver_commands] )) ||
_aver_commands() {
    local -a commands
    commands=(
        'run:run an Aver program via the bytecode VM (or backends)'
        'check:run static contract diagnostics'
        'verify:run declared `left => right` examples and `law` blocks'
        'format:format Aver source files'
        'audit:single-shot CI gate (check + verify + format --check)'
        'why:explain reasoning trails inside a module'
        'context:AI discovery — architecture map + selection metadata'
        'shape:static module-shape analyzer (archetype + Layer classifier)'
        'compile:cross-target compile (Rust / wasm-gc / wasm)'
        'bench:reproducible benchmark harness'
        'proof:export Lean proofs'
        'replay:replay effectful recordings captured via --record'
    )
    _describe -t commands 'aver command' commands
}

_aver "$@"
