#compdef tracker3
# GNOME filesystem indexer and search tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'daemon:manage tracker daemon'
  'endpoint:manage endpoints'
  'export:export data'
  'extract:extract metadata'
  'index:manage file indexing'
  'info:show information about files'
  'reset:reset tracker data'
  'search:search indexed content'
  'sparql:run SPARQL queries'
  'sql:run SQL queries'
  'status:show indexer status'
  'tag:manage tags'
)

_arguments -s -S \
  '1:command:->command' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'tracker3 command' commands && ret=0
    ;;
esac

return ret
