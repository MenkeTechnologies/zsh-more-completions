_fail2ban_exporter() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show help (kong auto-generated)]' \
    '(-v --version)'{-v,--version}'[show version info and exit]' \
    '--dry-run[attempt to connect to fail2ban socket then exit before starting server]' \
    '--web.listen-address=[address to use for the metrics server]:address:_hosts' \
    '--collector.f2b.socket=[path to the fail2ban server socket]:path:_files' \
    '--collector.f2b.exit-on-socket-connection-error[exit immediately on fail2ban socket connection error]' \
    '--collector.textfile.directory=[directory to read text files with metrics from]:dir:_directories' \
    '--web.basic-auth.username=[username to protect endpoints with basic auth]:username:_users' \
    '--web.basic-auth.password=[password to protect endpoints with basic auth]:password:'
}

_fail2ban_exporter "$@"
