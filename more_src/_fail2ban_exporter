#
#  kong API:
#    import "github.com/alecthomas/kong"
#
#    var CLI struct {
#      // Struct tags drive parsing:
#      //   name:"..."     — explicit flag name (default: snake/
#      //                    kebab from field name)
#      //   short:"X"      — short flag char
#      //   help:"..."     — help text
#      //   default:"..."  — default value
#      //   required       — required flag/positional
#      //   env:"NAME"     — env var fallback for value
#      //   placeholder    — usage line placeholder
#      //   hidden         — exclude from --help
#      //   arg            — positional argument (vs default flag)
#      //   cmd            — subcommand (struct embedded as nested)
#      //   group:"NAME"   — group flags under heading in --help
#      VersionMode   bool   `name:"version"     short:"v" help:"Show version"`
#      DryRunMode    bool   `name:"dry-run"     help:"Dry run mode"`
#      ServerAddress string `name:"web.listen-address"
#                            env:"WEB_LISTEN"
#                            help:"Address" default:"${default_address}"`
#      // Subcommand example:
#      Build struct {
#        Target string `arg help:"Target"`
#      } `cmd help:"Build something"`
#    }
#
#    func main() {
#      ctx := kong.Parse(
#        &CLI,
#        kong.Name("mytool"),
#        kong.Description("My tool description"),
#        kong.UsageOnError(),
#        kong.Vars{
#          "default_address": ":8080",
#        },
#      )
#      err := ctx.Run()  // dispatch to subcommand .Run() methods
#      ctx.FatalIfErrorf(err)
#    }
#
#  kong distinctive features:
#    - STRUCT-TAG DECLARATIVE syntax (similar in spirit to jessevdk/
#      go-flags but with KONG'S OWN tag grammar and MUCH richer
#      feature set)
#    - DOTTED FLAG NAMES — `name:"web.listen-address"` produces
#      `--web.listen-address` (dots are LITERAL in the flag name,
#      not nested struct paths) — distinctive feature for Prometheus
#      exporter conventions
#    - SUBCOMMANDS via `cmd` tag on EMBEDDED STRUCT — nested struct
#      becomes a subcommand; nested fields become its flags
#    - POSITIONAL args via `arg` tag — captures positional values
#    - ENV VAR fallback via `env:"VAR_NAME"` tag — value read from
#      env if flag not given
#    - DEFAULTS via `default:"..."` tag — can reference `${name}`
#      from `kong.Vars{}` for runtime-resolved defaults
#    - REQUIRED via `required` tag (no value) — error if missing
#    - GROUPS via `group:"NAME"` tag — flags clustered under named
#      heading in auto-generated --help
#    - HIDDEN flags via `hidden` tag — exclude from --help
#    - PLACEHOLDER via `placeholder:"X"` — explicit usage-line
#      placeholder
#    - kong.Vars{} — runtime variable map for `${var}` interpolation
#      in defaults/help/etc.
#    - kong.Name("...") / kong.Description("...") — explicit binary
#      name and description for --help banner
#    - kong.UsageOnError() — print usage when parse fails (default
#      is to just print error)
#    - kong.UsageOnError() / kong.Exit() — pluggable exit/usage
#      hooks for testing
#    - kong.HelpOptions{Compact, Summary, Tree} — adjustable help
#      rendering
#    - kong.ConfigureHelp() — configure help command behavior
#    - kong.NewMapper(...) — register CUSTOM TYPE MAPPERS
#      (foxygoat/s's kongx.JSONFileMapper pattern: register a mapper
#      that parses a JSON file when a flag of that type is seen)
#    - kong.NamedMapper(name, mapper) — register a mapper bound to
#      a specific tag-name (use with `mapper:"jsonfile"` tag)
#    - ctx.Run() — dispatch to a `Run()` method on the matched
#      subcommand struct — kong USES INTERFACE-BASED DISPATCH
#      (your subcommand struct implements `Run(ctx *kong.Context)
#      error`); contrast cobra which uses Run/RunE FUNC FIELDS on
#      the Command struct
#    - INSPIRED BY jessevdk/go-flags (struct-tag-based) + kingpin
#      (Alec Thomas's earlier work) + the urge to bring kingpin's
#      RICH FEATURE SET into a struct-tag-driven API; Alec Thomas
#      explicitly considers kong his "kingpin v2"
#  Distinct from R237 Go spf13/cobra (subcommand-TREE with Command
#  structs and Run/RunE func fields — Hugo/Kubernetes/Docker), R237
#  Go spf13/pflag (POSIX-flag-compat replacement for stdlib flag —
#  used INSIDE cobra), R237 Go urfave/cli (action-callback
#  framework — Docker pre-cobra, restic), R237 Go alecthomas/
#  kingpin (KONG'S PREDECESSOR by SAME AUTHOR — chained-builder
#  fluent API; Prometheus core uses kingpin; KONG IS KINGPIN'S
#  STRUCT-TAG SUCCESSOR by same author), R237 Go jessevdk/go-flags
#  (struct-tag based; KONG'S STRONGEST INFLUENCE — kong's struct-
#  tag schema is conceptually a richer/more-featured version of
#  go-flags's), R237 Go mitchellh/cli (HashiCorp Terraform), R262
#  Go stdlib `flag` (POSIX-INCOMPATIBLE single-dash — gofmt/go
#  test), R363 Go peterbourgon/ff (functional-options 3-way config
#  flag/env/file merge), R367 Go akamensky/argparse (Python-
#  argparse-style port), R408 Go pborman/getopt (POSIX-getopt(3)
#  faithful BSD/C-style — oklog/ulid), R411 Go integrii/flaggy
#  (package-level functional-builder — joanbono/Gurp + jesseduffield/
#  lazydocker).  Go documented libraries so far: stdlib flag,
#  pflag, cobra, urfave-cli, kingpin, jessevdk/go-flags, mitchellh/
#  cli, ff, akamensky/argparse, pborman/getopt, flaggy, kong (this
#  round)... 13.  kong's distinguishing feature vs all other Go
#  libs: kong COMBINES struct-tag declarative ergonomics (like
#  jessevdk/go-flags) WITH the FULL RICH FEATURE SET of kingpin
#  (subcommands, env-var fallback, custom mappers, required-
#  argument grouping, hooks, interpolation) — explicitly the SAME
#  AUTHOR'S evolution from chained-builder kingpin to struct-tag
#  kong.  kong's approach: STRUCT-TAG-DECLARATIVE with `kong.
#  Parse(&CLI, opts...)` entry + tags `name`/`short`/`help`/
#  `default`/`required`/`env`/`placeholder`/`hidden`/`arg`/`cmd`/
#  `group`/`mapper` + DOTTED FLAG NAMES (`web.listen-address`
