_probot() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'run:run the bot (start HTTP server + webhook listener)'
        'receive:receive a single event and payload (replay for local dev/debug)'
        'help:display help for command'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[display help]' \
        '(-v --version)'{-v,--version}'[output version number]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'probot subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                run)
                    _arguments \
                        '(-h --help)'{-h,--help}'[display help]' \
                        '(-p --port)'{-p+,--port=}'[port to start server on (default 3000)]:port:' \
                        '(-H --host)'{-H+,--host=}'[host to start server on]:host:' \
                        '(-W --webhook-proxy)'{-W+,--webhook-proxy=}'[URL of webhook proxy service (default smee.io)]:url:' \
                        '(-w --webhook-path)'{-w+,--webhook-path=}'[URL path receiving webhooks (e.g. /webhook)]:path:' \
                        '(-a --app)'{-a+,--app=}'[GitHub App ID]:app id:' \
                        '(-s --secret)'{-s+,--secret=}'[webhook secret of the GitHub App]:secret:' \
                        '(-P --private-key)'{-P+,--private-key=}'[path to private key .pem file]:key file:_files -g "*.pem"' \
                        '(-L --log-level)'{-L+,--log-level=}'[log level]:level:(trace debug info warn error fatal)' \
                        '--log-format=[log format]:format:(pretty json)' \
                        '--log-level-in-string[log levels as words instead of numbers]' \
                        '--log-message-key=[key for message in log JSON object]:key:' \
                        '--sentry-dsn=[Sentry DSN URL]:dsn:' \
                        '--redis-url=[redis:// URL for cluster bottleneck request throttling]:redis url:' \
                        '--base-url=[GitHub API base URL (default https://api.github.com)]:url:' \
                        '*:app file:_files -g "*.(js|mjs|cjs|ts)"' && ret=0
                    ;;
                receive)
                    _arguments \
                        '(-h --help)'{-h,--help}'[display help]' \
                        '(-e --event)'{-e+,--event=}'[event name (push, pull_request, issues, etc.)]:event:(push pull_request issues issue_comment pull_request_review pull_request_review_comment release create delete fork watch star check_run check_suite workflow_dispatch workflow_run repository_dispatch deployment deployment_status status milestone label discussion discussion_comment)' \
                        '(-p --payload-path)'{-p+,--payload-path=}'[path to event payload (JSON file)]:payload:_files -g "*.json"' \
                        '(-t --token)'{-t+,--token=}'[access token for API read/write]:token:' \
                        '(-a --app)'{-a+,--app=}'[GitHub App ID]:app id:' \
                        '(-P --private-key)'{-P+,--private-key=}'[path to private key .pem file]:key file:_files -g "*.pem"' \
                        '(-L --log-level)'{-L+,--log-level=}'[log level]:level:(trace debug info warn error fatal)' \
                        '--log-format=[log format]:format:(pretty json)' \
                        '--log-level-in-string[log levels as words]' \
                        '--log-message-key=[message key for log JSON]:key:' \
                        '--sentry-dsn=[Sentry DSN URL]:dsn:' \
                        '--base-url=[GitHub API base URL]:url:' \
                        '*:app file:_files -g "*.(js|mjs|cjs|ts)"' && ret=0
                    ;;
                help)
                    _describe -t commands 'probot subcommand' subcmds && ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_probot "$@"
