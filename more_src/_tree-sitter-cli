#compdef tree-sitter-cli tree-sitter
# Documentation: https://tree-sitter.github.io/tree-sitter/cli/
# Reference accessed: 2026-05-21
# Verified: upstream source (crates/cli/src/main.rs) and docs at the URL above.

# Zsh completion for tree-sitter CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init-config:generate a default config file'
  'init:initialize a grammar repository'
  'generate:generate a parser from a grammar'
  'build:compile a parser to a shared object'
  'parse:parse files using a grammar'
  'test:run a grammar test suite'
  'fuzz:fuzz a grammar'
  'query:search files using a syntax tree query'
  'highlight:highlight a file'
  'tags:generate a list of tags'
  'playground:start the playground web UI'
  'dump-languages:print info about tree-sitter languages'
  'complete:generate shell completions'
  'version:show/increment the version of a grammar'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show tree-sitter version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tree-sitter command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(-u --update)'{-u,--update}'[update outdated files]' \
          '1:directory:_directories' && ret=0
        ;;
      (generate|gen|g)
        _arguments \
          '(-l --log)'{-l,--log}'[show log messages]' \
          '--abi=[ABI version]:version:' \
          '--no-parser[only generate grammar.json and node-types.json]' \
          '(-o --output)'{-o,--output}'=[output directory]:dir:_directories' \
          '--report-states-for-rule=[report states for a rule]:rule' \
          '--json-summary[report conflicts in JSON format]' \
          '1:grammar.js file:_files -g "grammar.js"' && ret=0
        ;;
      (parse|p)
        _arguments \
          '(-d --debug)'{-d,--debug}'[print parsing debug output]' \
          '(-D --debug-graph)'{-D,--debug-graph}'[produce a DOT graph]' \
          '(-t --time)'{-t,--time}'[print time for each file]' \
          '(-q --quiet)'{-q,--quiet}'[print less information]' \
          '(-s --stat)'{-s,--stat}'[print parse statistics]' \
          '(-x --xml)'{-x,--xml}'[print XML output]' \
          '(-c --cst)'{-c,--cst}'[print CST output]' \
          '(-T --timeout)'{-T,--timeout}'=[parse timeout (microseconds)]:microseconds' \
          '--paths=[file listing paths]:file:_files' \
          '*:file:_files' && ret=0
        ;;
      (test|t)
        _arguments \
          '(-i --include)'{-i,--include}'=[only run tests matching regex]:pattern' \
          '(-e --exclude)'{-e,--exclude}'=[skip tests matching regex]:pattern' \
          '(-d --debug)'{-d,--debug}'[print parsing debug output]' \
          '(-D --debug-graph)'{-D,--debug-graph}'[produce DOT graph]' \
          '(-u --update)'{-u,--update}'[update failing tests]' && ret=0
        ;;
      (highlight|hi)
        _arguments \
          '(-H --html)'{-H,--html}'[generate HTML output]' \
          '--check[check that highlights apply]' \
          '--config-path=[config path]:path:_files' \
          '*:file:_files' && ret=0
        ;;
      (query|q)
        _arguments \
          '(-b --byte-range)'{-b,--byte-range}'=[byte range]:range' \
          '(-r --row-range)'{-r,--row-range}'=[row range]:range' \
          '--captures[show capture names]' \
          '1:query file:_files' \
          '*:source file:_files' && ret=0
        ;;
      (build|b)
        _arguments \
          '(-o --output)'{-o,--output}'=[output path]:file:_files' \
          '--wasm[build to wasm]' \
          '--docker[use docker for wasm build]' \
          '(-d --debug)'{-d,--debug}'[build in debug mode]' \
          '1:path:_files -/' && ret=0
        ;;
      (fuzz|f)
        _arguments \
          '(-s --skip)'{-s,--skip}'=[test names to skip]:names' \
          '(-l --log-graphs)'{-l,--log-graphs}'[output graph log]' \
          '--rebuild[rebuild parser before fuzzing]' && ret=0
        ;;
      (complete)
        _arguments '--shell=[shell]:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
