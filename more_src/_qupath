#compdef qupath QuPath
# Documentation: https://qupath.readthedocs.io/en/stable/docs/advanced/command_line.html
# qupath: bioimage analysis command line interface

local ret=1
local -a commands

commands=(
  'script:run a script for a given image or project'
  'convert-ome:convert an input image to OME-TIFF'
  'help:display help information about the specified command'
)

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show this help message and exit]' \
  '(-i --image)'{-i,--image=}'[launch QuPath with a specified image]:image:_files' \
  '(-l --log)'{-l,--log=}'[log level]:level:(TRACE DEBUG INFO WARN ERROR ALL OFF)' \
  '(-p --project)'{-p,--project=}'[launch QuPath and open specified project]:project:_files' \
  '(-q --quiet)'{-q,--quiet}'[launch without setup dialogs or update checks]' \
  '(-r --reset)'{-r,--reset}'[reset all QuPath preferences]' \
  '(-t --tma)'{-t,--tma}'[launch standalone viewer for TMA summary results]' \
  '(-V --version)'{-V,--version}'[print version information and exit]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'qupath command' commands && ret=0
    ;;
  args)
    case $line[1] in
      script)
        _arguments -s \
          '(-a --args)'{-a,--args=}'[arguments to pass to the script]:arguments:' \
          '(-c --cmd)'{-c,--cmd=}'[Groovy script passed as a string]:command:' \
          '(-e --server)'{-e,--server=}'[arguments for ImageServer construction]:server args:' \
          '(-h --help)'{-h,--help}'[show this help message and exit]' \
          '(-i --image)'{-i,--image=}'[apply the script to the specified image]:image:_files' \
          '(-p --project)'{-p,--project=}'[path to a project file (.qpproj)]:project:_files' \
          '(-s --save)'{-s,--save}'[update data files for each image in the project]' \
          '*:script:_files -g "*.groovy"' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
