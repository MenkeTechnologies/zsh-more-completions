#compdef pto_var
# Documentation: https://man.archlinux.org/man/pto_var.1.en
# pto_var: change image/optimizer variables in a Hugin .pto project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto file]:file:_files -g "*.pto"' \
  '--opt=[change optimizer variables]:varlist:' \
  '--modify-opt[modify the existing optimizer variables]' \
  '--link=[link image variables together]:varlist:' \
  '--unlink=[unlink image variables]:varlist:' \
  '--set=[set variables to new values]:varlist:' \
  '--set-from-file=[read varlist from a file]:file:_files' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
