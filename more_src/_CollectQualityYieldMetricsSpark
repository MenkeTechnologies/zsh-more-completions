#compdef CollectQualityYieldMetricsSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/pipelines/metrics/CollectQualityYieldMetricsSpark.java
# GATK Spark: collect quality yield metrics from a SAM/BAM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  {-O,--output=}'[output metrics file]:file:_files' \
  {-OQ,--use-original-qualities}'[use original quality scores (OQ tag) if present]' \
  '*:argument:_files' && ret=0

return ret
