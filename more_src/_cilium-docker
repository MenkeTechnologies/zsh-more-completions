#compdef cilium-docker
# _cilium-docker — Cilium plugin for Docker libnetwork (networking + IPAM driver)
# upstream: https://github.com/cilium/cilium
# Flags from plugins/cilium-docker/main.go on tip.

_cilium-docker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-D --debug)'{-D,--debug}'[enable debug messages]' \
        '--cilium-api=[URI to server-side API]:uri:' \
        '--docker-host-path=[Docker socket]:socket:_files' \
        '--docker-plugins=[path to Docker plugins directory]:dir:_files -/'
}

_cilium-docker "$@"
