#compdef checkout-cli checkout
# _checkout-cli — Checkout.com checkout-cli CLI command-line frontend wrapping the Checkout.com global payments REST GraphQL API managing payments captures refunds reversals voids customers tokens sources webhooks disputes balances metadata reporting recipients risk forex authorizations Apple-Pay Google-Pay (Checkout.com team, Go); cobra
# upstream: https://www.checkout.com/

_checkout-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'payment:payment operations'
        'capture:capture operations'
        'refund:refund operations'
        'void:void operations'
        'reversal:reversal operations'
        'customer:customer operations'
        'token:token operations'
        'source:source operations'
        'webhook:webhook operations'
        'dispute:dispute operations'
        'balance:balance operations'
        'metadata:metadata operations'
        'report:report operations'
        'recipient:recipient operations'
        'risk:risk operations'
        'authorization:authorization operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--public-key=+[key]:str:' \
        '--secret-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[e]:e:(sandbox live)' \
        '--processing-channel=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'checkout-cli subcommand' sub ;;
        args)
            case $words[1] in
                payment|capture|refund|void|reversal|customer|token|source|webhook|dispute|balance|report|recipient|risk|authorization) _arguments '1:op:(list get create update delete approve decline)' '*:id:' ;;
            esac
            ;;
    esac
}

_checkout-cli "$@"
