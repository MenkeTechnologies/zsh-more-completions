#compdef zipgrep
# Documentation: https://man.archlinux.org/search?q=zipgrep
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-i[case insensitive]'
    '-c[count matches]'
    '-l[list matching files]'
    '-h[suppress filename prefix]'
    '-n[show line numbers]'
    '-v[invert match]'
    '-e[specify pattern]:pattern'
    '1:pattern:'
    '2:zip file:_files -g "*.zip"'
    '*:member:'
)

_arguments -s -S $arguments
