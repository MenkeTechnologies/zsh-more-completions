#compdef ovs-docker
# Documentation: https://docs.openvswitch.org/en/latest/howto/docker/
# attach Open vSwitch ports to Docker containers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help message]' \
  '--ipaddress=[set IP address on interface]:address' \
  '--gateway=[configure default gateway]:gateway' \
  '--macaddress=[set MAC address]:mac' \
  '--mtu=[configure maximum transmission unit]:mtu' \
  '1:command:(add-port del-port del-ports set-vlan)' \
  '*::args:_default' && ret=0

return ret
