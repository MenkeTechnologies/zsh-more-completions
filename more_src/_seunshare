#compdef seunshare
# _seunshare — SELinux seunshare (run a command in a per-user / per-context namespace with a private /tmp and /home/USER bind-mount, useful in sandbox(8) and other confinement front-ends; -t tmp dir override, -h home dir override, -k drop capabilities, -C use specified context, -v verbose, -V version; positional command then args)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux sandbox/seunshare.c on tip.

_seunshare() {
    _arguments \
        '-h+[home dir]:dir:_files -/' \
        '-t+[tmp dir]:dir:_files -/' \
        '-Z+[context]:context:' \
        '-k[drop capabilities]' \
        '-C+[context]:context:' \
        '-v[verbose]' \
        '-V[show version]' \
        '*::command:_command_names -e'
}

_seunshare "$@"
