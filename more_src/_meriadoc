_meriadoc_commands() {
    local commands; commands=(
'run:Run a task, job or shell' \
'task:Run a task (shortcut for '\''run task'\'')' \
't:Run a task (shortcut for '\''run task'\'')' \
'job:Run a job (shortcut for '\''run job'\'')' \
'j:Run a job (shortcut for '\''run job'\'')' \
'shell:Start a shell (shortcut for '\''run shell'\'')' \
's:Start a shell (shortcut for '\''run shell'\'')' \
'ls:List entities' \
'info:Show detailed info' \
'validate:Validate specs' \
'config:Manage config' \
'cache:Cache operations' \
'env:Environment variable operations' \
'doctor:Diagnose common problems' \
'serve:Start MCP server for AI agent integration (stdio)' \
'server:Start HTTP server with web UI' \
'completions:Print shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'meriadoc commands' commands "$@"
}
