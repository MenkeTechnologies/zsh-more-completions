#compdef prusaslicer prusa-slicer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--info[show system information]' \
  '--export-gcode[export G-code for the supplied models]' \
  '--export-stl[export the model as STL]' \
  '--export-3mf[export the model as 3MF]' \
  '--export-obj[export the model as OBJ]' \
  '--export-amf[export the model as AMF]' \
  '--export-sla[export the model for SLA printing]' \
  '--slice[slice the model and export G-code]' \
  '--repair[repair the model and exit]' \
  '--cut=[cut model at given Z height]:z height' \
  '--split[detect unconnected parts and split into separate objects]' \
  '--merge[merge all loaded models into a single object]' \
  '--gui[force GUI mode]' \
  '--no-gui[force command-line mode]' \
  '--datadir=[load and store settings at given directory]:directory:_directories' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '--load=[load configuration from file]:config file:_files' \
  '--save=[save configuration to file]:config file:_files' \
  '--loglevel=[set log verbosity level]:level:(0 1 2 3 4 5)' \
  '--single-instance[allow only a single instance of PrusaSlicer]' \
  '--center=[center the print around given coordinates]:coordinates (x,y)' \
  '--dont-arrange[do not rearrange the given models]' \
  '--ensure-on-bed[lift the object above the bed when it is partially below]' \
  '--rotate=[rotation angle around the Z axis in degrees]:angle' \
  '--rotate-x=[rotation angle around the X axis in degrees]:angle' \
  '--rotate-y=[rotation angle around the Y axis in degrees]:angle' \
  '--scale=[scaling factor or percentage]:factor' \
  '--scale-to-fit=[scale to fit the given volume]:dimensions (x,y,z)' \
  '--duplicate=[number of copies to create]:count' \
  '--duplicate-grid=[number of copies in grid]:grid (x,y)' \
  '--print-center=[center of print]:coordinates (x,y)' \
  '--threads=[number of threads to use]:count' \
  '--layer-height=[layer height in mm]:height' \
  '--first-layer-height=[first layer height in mm]:height' \
  '--fill-density=[infill density percentage]:percent' \
  '--fill-pattern=[infill pattern]:pattern' \
  '--infill-every-layers=[infill every N layers]:layers' \
  '--skirts=[number of skirt loops]:count' \
  '--brim-width=[brim width in mm]:width' \
  '--support-material[enable support material generation]' \
  '--nozzle-diameter=[nozzle diameter in mm]:diameter' \
  '--filament-diameter=[filament diameter in mm]:diameter' \
  '--temperature=[extrusion temperature in degrees C]:temperature' \
  '--bed-temperature=[bed temperature in degrees C]:temperature' \
  '*:input file:_files'
