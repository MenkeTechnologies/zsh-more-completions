#compdef run-example

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--master=[master URL]:url:' \
  '--deploy-mode=[where the driver runs]:mode:(client cluster)' \
  '--class=[application main class]:class:' \
  '--name=[application name]:name:' \
  '--jars=[comma-separated list of jars]:jars:' \
  '--packages=[comma-separated list of maven coordinates]:packages:' \
  '--exclude-packages=[comma-separated list of groupId:artifactId to exclude]:packages:' \
  '--repositories=[comma-separated list of additional remote repositories]:repos:' \
  '--driver-memory=[memory for driver]:size:' \
  '--executor-memory=[memory per executor]:size:' \
  '--proxy-user=[user to impersonate when submitting]:user:_users' \
  {-v,--verbose}'[print additional debug output]' \
  '1:example class:' \
  '*:example arg:' && ret=0

return ret
