#compdef janusgraph janusgraph-server.sh janusgraph.sh

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start the JanusGraph server'
  'stop:stop the running server'
  'restart:restart the server'
  'status:show server status'
  'console:run server in foreground console mode'
  'usage:show usage help'
  'show:show the version'
  'install:install a plugin into the server'
  'classpath:print server classpath'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'janusgraph command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start|restart|console)
        _arguments \
          '*:config_file:_files -g "*.{yaml,yml,properties}"' && ret=0 ;;
      (install)
        _arguments \
          '*:plugin_name:' && ret=0 ;;
    esac ;;
esac

return ret
