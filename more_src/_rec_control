#compdef rec_control

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add-cookies-unsupported:register cookie-non-supporting servers'
  'add-dont-throttle-names:exempt nameservers from throttling by name'
  'add-dont-throttle-netmasks:exempt nameservers from throttling by netmask'
  'add-nta:create Negative Trust Anchor'
  'add-ta:add Trust Anchor with DS record'
  'clear-cookies:clear cookie table'
  'clear-dont-throttle-names:remove names from no-throttle list'
  'clear-dont-throttle-netmasks:remove netmasks from no-throttle list'
  'clear-nta:delete Negative Trust Anchors'
  'clear-ta:delete Trust Anchors'
  'current-queries:show in-flight queries'
  'dump-cache:dump caches to file'
  'dump-cookies:dump cookie store'
  'dump-dot-probe-map:dump DoT probe map'
  'dump-edns:dump EDNS status'
  'dump-failedservers:dump failed-server map'
  'dump-non-resolving:dump unresolved NS names'
  'dump-nsspeeds:dump nameserver speed stats'
  'dump-rpz:dump RPZ zone'
  'dump-saved-parent-ns-sets:dump saved parent NS sets'
  'dump-throttlemap:dump throttle map'
  'get:fetch named statistics'
  'get-all:fetch all statistics'
  'get-dont-throttle-names:list non-throttled names'
  'get-dont-throttle-netmasks:list non-throttled netmasks'
  'get-ntas:list NTAs'
  'get-tas:list TAs'
  'get-parameter:fetch config parameter'
  'get-default-parameter:fetch parameter default'
  'get-proxymapping-stats:list proxy-mapped subnets'
  'get-qtypelist:query-type stats'
  'get-remotelogger-stats:remote logger stats'
  'hash-password:hash and salt password/API key'
  'help:list commands'
  'list-dnssec-algos:list DNSSEC algorithms'
  'ping:check liveness'
  'quit:shut down recursor'
  'quit-nicely:graceful shutdown'
  'reload-acls:refresh ACLs'
  'reload-lua-script:reload Lua script'
  'reload-lua-config:reload Lua config'
  'reload-yaml:refresh runtime YAML'
  'reload-zones:reload zones'
  'set-carbon-server:configure carbon server'
  'set-dnssec-log-bogus:toggle DNSSEC bogus logging'
  'set-ecs-minimum-ttl:ECS minimum TTL'
  'set-max-aggr-nsec-cache-size:NSEC cache size'
  'set-max-cache-entries:DNS cache entry limit'
  'set-max-packetcache-entries:packet cache entry limit'
  'set-minimum-ttl:minimum TTL override'
  'set-event-trace-enabled:toggle event tracing'
  'show-yaml:render config as YAML'
  'top-queries:top-20 queries'
  'top-pub-queries:top-20 by public suffix'
  'top-largeanswer-remotes:top-20 large answer remotes'
  'top-remotes:top-20 active remotes'
  'top-servfail-queries:top-20 servfail queries'
  'top-bogus-queries:top-20 bogus queries'
  'top-pub-servfail-queries:top-20 servfail by pub suffix'
  'top-pub-bogus-queries:top-20 bogus by pub suffix'
  'top-servfail-remotes:top-20 servfail remotes'
  'top-bogus-remotes:top-20 bogus remotes'
  'top-timeouts:top-20 timeout destinations'
  'trace-regex:enable resolution tracing'
  'unload-lua-script:remove Lua script'
  'version:version of running recursor'
  'wipe-cache:wipe domain entries from cache'
  'wipe-cache-typed:wipe typed entries from cache'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--config-dir=[config directory]:dir:_files -/' \
  '--config-name=[config name]:name:' \
  '--socket-dir=[socket directory]:dir:_files -/' \
  '--socket-pid=[socket PID]:pid:' \
  '--timeout=[timeout]:secs:' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rec_control subcommand' subcommands && ret=0
    ;;
esac

return ret
