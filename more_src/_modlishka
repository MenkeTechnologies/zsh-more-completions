#compdef modlishka Modlishka
# Documentation: https://github.com/drk1wi/Modlishka
# Modlishka - reverse proxy for phishing and 2FA bypass

local ret=1

_arguments -s -S \
  '-config[JSON configuration file]:file:_files' \
  '-target[target domain name]:domain:' \
  '-proxyDomain[proxy domain name to use]:domain:' \
  '-listeningAddress[listening address]:address:' \
  '-listeningPortHTTP[HTTP port]:port:' \
  '-listeningPortHTTPS[HTTPS port]:port:' \
  '-proxyAddress[upstream proxy (socks/https/http)]:proxy:' \
  '-cert[base64 encoded TLS certificate]:cert:' \
  '-certKey[base64 encoded TLS certificate key]:key:' \
  '-certPool[base64 encoded CA certificate]:ca:' \
  '-forceHTTP[strip TLS and proxy through HTTP only]' \
  '-forceHTTPS[strip clear-text and proxy through HTTPS only]' \
  '-jsRules[URL patterns and base64 JS payloads for injection]:rules:' \
  '-rules[string pattern replacements]:rules:' \
  '-credParams[credential regex with matching groups]:params:' \
  '-trackingCookie[cookie name for client tracking]:name:' \
  '-trackingParam[parameter name for tracking]:name:' \
  '-log[local file for request logging]:file:_files' \
  '-postOnly[log only HTTP POST requests]' \
  '-controlURL[URL for credentials panel]:url:' \
  '-controlCreds[username:password for credentials page]:creds:' \
  '-disableSecurity[disable anti-SSRF and other protections]' \
  '-dynamicMode[enable dynamic mode for client domain hooking]' \
  '-terminateUrl[redirect URL after session termination]:url:' \
  '-terminateTriggers[URLs triggering session termination]:urls:' \
  '-targetRes[domains not auto-translated]:domains:' \
  '-ignoreTranslateDomains[domains to never translate]:domains:' \
  '-staticLocations[FQDNs in location headers to preserve]:locations:' \
  '-disableDynamicSubdomains[translate domain names to proxy domain]' \
  '-pathHostRules[URL path patterns and target domains]:rules:' \
  '-allowSecureCookies[allow secure cookies with HTTPS]' \
  '-plugins[enabled plugin names]:plugins:' \
  '-debug[print debug information]' && ret=0

return ret
