#compdef pvpython

# ParaView pvpython: interactive Python shell with ParaView modules
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--enable-bt[backtrace on signal]' \
  '--force-offscreen-rendering[force OSMesa rendering]' \
  '--displays[display list]:list:' \
  '--multi-clients[multiple connections]' \
  '--multi-servers[multiple servers]' \
  '--no-mpi[disable MPI]' \
  '-V[verbose Python]' \
  '-i[interactive mode after script]' \
  '*:Python script:_files -g "*.py"' && ret=0
return ret
