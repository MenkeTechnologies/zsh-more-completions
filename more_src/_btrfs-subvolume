#compdef btrfs-subvolume
# _btrfs-subvolume — btrfs-progs btrfs subvolume (create/delete/snapshot/list/find-new/get-default/set-default/show/sync/sync subvolumes; -p print, -r read-only snapshot, -c commit after, -q quiet, -t terse, -R rootid)
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/subvolume.c on tip.

_btrfs-subvolume() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'subvolume command' '(create delete snapshot list find-new get-default set-default show sync)' ;;
        args)
            case $line[1] in
                snapshot) _arguments '-r[read-only]' '*:src dest:_files -/' ;;
                delete) _arguments '-c[commit after]' '-C[commit each]' '-i[bg]' '-v[verbose]' '*:subvol:_files -/' ;;
                list) _arguments \
                    '-p[print parent ID]' \
                    '-c[print last gen]' \
                    '-a[print all]' \
                    '-u[print uuid]' \
                    '-q[print parent uuid]' \
                    '-R[print root id]' \
                    '-s[snapshot only]' \
                    '-d[deleted]' \
                    '-G+[min gen]:gen:' \
                    '-C+[max gen]:gen:' \
                    '-r[print read-only flag]' \
                    '-t[tab-separated]' \
                    '--sort=*[sort]:key:(rootid gen ogen path)' \
                    '*:filesystem:_files -/' ;;
                create) _arguments '*:subvol:_files -/' ;;
                show|sync|find-new|get-default|set-default) _arguments '*:subvol:_files -/' ;;
            esac
            ;;
    esac
}

_btrfs-subvolume "$@"
