#compdef tsfuzz
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsfuzz.cpp
# tsfuzz - corrupt transport stream files for fuzzing tests

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-o --output)'{-o,--output}'=[output file or directory (required)]:file:_files' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
