#compdef ddgr

_ddgr() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-v,--version}'[Show version]' \
    {-n,--num}'[Number of results per page]:count:' \
    {-r,--reg}'[Region for results]:region:' \
    '--colorize[Colorize output]:when:(auto always never)' \
    {-C,--nocolor}'[Disable color output]' \
    '--colors[Set output colors]:colors:' \
    {-j,--ducky}'[Open first result in browser]' \
    {-t,--time}'[Time limit for results]:time:(d w m y)' \
    {-w,--site}'[Search specific site]:site:' \
    {-x,--expand}'[Show complete URL in results]' \
    {-p,--proxy}'[Proxy server]:proxy:' \
    '--unsafe[Disable safe search]' \
    '--noua[Disable user agent]' \
    '--json[Output in JSON format]' \
    '--gb[Use GUI browser]' \
    '--np[Non-interactive mode]' \
    '--noprompt[Do not show prompt]' \
    '--url-handler[URL handler program]:handler:_command_names' \
    '--show-browser-logs[Show browser logs]' \
    '*:keywords:'
}

_ddgr "$@"
