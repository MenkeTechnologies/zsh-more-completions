#compdef skabus-rpccctl
# _skabus-rpccctl — skabus skabus-rpccctl (control client for a skabus-rpcc instance: register/unregister an interface, query connected peers, or run a session-level command)
# upstream: https://github.com/skarnet/skabus
# Source: src/rpc/skabus-rpccctl.c on tip; subcommands from the USAGE line.

_skabus-rpccctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-t+[timeout (ms)]:ms:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'rpcc command' '(help interface interface-remove query)' ;;
    esac
}

_skabus-rpccctl "$@"
