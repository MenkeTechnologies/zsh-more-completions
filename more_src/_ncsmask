#compdef ncsmask
# CCP4: generate and manipulate NCS averaging masks

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input PDB file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'MSKIN[input mask file]:mask:_files' \
  'MSKOUT[output mask file]:mask:_files' \
  '*:keyword:(GRID SPACING SYMMETRY AXIS XYZLIM RADIUS PEAK EXPAND SMOOTH AVERAGE MONOMER OVERLAP NOTRIM END)' && ret=0

return ret
