#compdef datacube
# Documentation: https://opendatacube.readthedocs.io/en/stable/installation/cli.html
# Open Data Cube management command-line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--log-file=[log file location]:file:_files' \
  '(-E --env)'{-E,--env}'=[ODC environment to use]:env' \
  '(-C --config --config-file)'{-C,--config,--config-file}'=[configuration file path]:config:_files' \
  '(-R --raw-config --config-text)'{-R,--raw-config,--config-text}'=[configuration as a string]:config' \
  '--log-queries[print database queries]' \
  '1:command:(system dataset product metadata user spindex)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      system)  _values 'subcommand' init check clone && ret=0 ;;
      dataset) _values 'subcommand' add archive count find-duplicates info purge restore search update uri-search && ret=0 ;;
      product) _values 'subcommand' add delete list show update && ret=0 ;;
      metadata) _values 'subcommand' add list show update && ret=0 ;;
      user)    _values 'subcommand' create delete grant list && ret=0 ;;
      spindex) _values 'subcommand' create drop list update && ret=0 ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
