#compdef guayadeque
# Documentation: https://guayadeque.org/
# Reference accessed: 2026-05-16

# Guayadeque: wxWidgets music player and tag editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-V[show version]' \
  '--version[show version]' \
  '--play[start playing]' \
  '--play-pause[play/pause toggle]' \
  '--stop[stop playback]' \
  '--prev[previous track]' \
  '--next[next track]' \
  '*:music file:_files -g "*.(mp3|flac|ogg|m4a|wav|opus|wma)"' && ret=0
return ret
