#compdef upstash
# Documentation: https://github.com/upstash/cli
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for Upstash CLI (Redis, Vector, Search, QStash, team).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authentication commands'
  'redis:manage Upstash Redis databases'
  'vector:manage Upstash Vector indexes'
  'search:manage Upstash Search instances'
  'qstash:manage Upstash QStash resources'
  'team:manage team membership'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--dry-run[preview destructive operations]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'upstash command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (auth)
        local -a auth_cmds=(
          'login:store developer API credentials on this machine'
        )
        _describe -t commands 'auth command' auth_cmds && ret=0
        ;;
      (redis)
        local -a redis_cmds=(
          'list:display Redis databases'
          'create:provision a new Redis database'
          'exec:run commands against a Redis database'
        )
        _describe -t commands 'redis command' redis_cmds && ret=0
        ;;
      (vector)
        local -a vector_cmds=(
          'list:display vector indexes'
          'create:provision a new vector index'
        )
        _describe -t commands 'vector command' vector_cmds && ret=0
        ;;
      (search)
        local -a search_cmds=(
          'list:display search instances'
          'create:provision a new search instance'
        )
        _describe -t commands 'search command' search_cmds && ret=0
        ;;
      (qstash)
        local -a qstash_cmds=(
          'list:display QStash resources'
          'stats:retrieve QStash statistics'
        )
        _describe -t commands 'qstash command' qstash_cmds && ret=0
        ;;
      (team)
        local -a team_cmds=(
          'list:display teams'
          'add-member:invite a member to your team'
        )
        _describe -t commands 'team command' team_cmds && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
