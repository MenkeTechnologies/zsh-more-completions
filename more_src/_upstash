#compdef upstash

# Zsh completion for Upstash CLI (manage serverless Redis, Kafka, QStash, Vector)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate with Upstash'
  'redis:manage Upstash Redis databases'
  'kafka:manage Upstash Kafka clusters'
  'qstash:manage Upstash QStash messaging'
  'vector:manage Upstash Vector indexes'
  'team:manage team settings'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'upstash command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (auth)
        local -a auth_cmds=(
          'login:log in to Upstash'
          'logout:log out from Upstash'
        )
        _describe -t commands 'auth command' auth_cmds && ret=0
        ;;
      (redis)
        local -a redis_cmds=(
          'create:create a new Redis database'
          'delete:delete a Redis database'
          'list:list Redis databases'
          'stats:show database stats'
        )
        _arguments '1:subcommand:->redis_sub' '*:: :->redis_args' && ret=0
        case $state in
          (redis_sub)
            _describe -t commands 'redis command' redis_cmds && ret=0
            ;;
          (redis_args)
            case $words[1] in
              (create)
                _arguments \
                  '--name[database name]:name' \
                  '--region[region]:region:(us-east-1 us-west-1 eu-west-1 ap-southeast-1 us-central1)' \
                  '--global[create a global database]' \
                  '--eviction[enable eviction]' && ret=0
                ;;
              (delete)
                _arguments '--id[database ID]:id' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (kafka)
        local -a kafka_cmds=(
          'create:create a Kafka cluster'
          'delete:delete a Kafka cluster'
          'list:list Kafka clusters'
          'topic:manage topics'
        )
        _describe -t commands 'kafka command' kafka_cmds && ret=0
        ;;
      (qstash)
        local -a qstash_cmds=(
          'publish:publish a message'
          'topic:manage topics'
          'schedule:manage schedules'
        )
        _describe -t commands 'qstash command' qstash_cmds && ret=0
        ;;
      (vector)
        local -a vector_cmds=(
          'create:create a Vector index'
          'delete:delete a Vector index'
          'list:list Vector indexes'
          'query:query a Vector index'
          'upsert:upsert vectors'
        )
        _describe -t commands 'vector command' vector_cmds && ret=0
        ;;
      (team)
        local -a team_cmds=(
          'list:list team members'
          'switch:switch active team'
        )
        _describe -t commands 'team command' team_cmds && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
