#compdef auto-commit
# Documentation: https://github.com/m1guelpf/auto-commit
# Source: m1guelpf/auto-commit — Rust CLI generating commit messages via OpenAI GPT-3.5.
# Reference accessed: 2026-06-02
# Reads OPENAI_API_KEY from the environment.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
    '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
    '--dry-run[show the generated message without committing]' \
    '(-r --review)'{-r,--review}'[allow editing the message before commit]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
