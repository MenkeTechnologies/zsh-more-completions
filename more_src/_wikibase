#compdef wikibase wb wd
# Documentation: https://github.com/maxlath/wikibase-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'summary:get entity labels, descriptions, and claims'
  'search:query for entities by text'
  'label:retrieve entity labels'
  'description:get entity descriptions'
  'aliases:fetch alternative names'
  'lemma:get lexeme lemmas'
  'claims:access entity claims with optional filtering'
  'data:retrieve raw JSON entity data'
  'generate-template:create pre-formatted data files for editing'
  'revisions:get entity revision history'
  'id:convert Wikipedia article titles to Wikidata IDs'
  'props:list all Wikibase properties'
  'sparql:execute SPARQL queries'
  'query:generate and run simple SPARQL queries'
  'graph-path:find relation paths between entities'
  'convert:transform between external IDs and Wikibase IDs'
  'open:open entities in a web browser'
  'hub:access the Hub tool for URL-based queries'
  'lang:identify languages and retrieve language data'
  'badges:list available sitelink badges'
  'set-label:assign a label to an entity in a specific language'
  'remove-label:delete a label from an entity in a specific language'
  'set-description:assign a description to an entity in a specific language'
  'remove-description:delete a description from an entity in a specific language'
  'add-alias:add aliases to an entity'
  'remove-alias:remove aliases from an entity'
  'set-alias:replace all aliases for an entity in a language'
  'add-claim:add a claim to an entity'
  'update-claim:modify a claim value'
  'move-claim:relocate claims between entities or properties'
  'remove-claim:delete a claim from an entity'
  'add-qualifier:attach a qualifier to a claim'
  'update-qualifier:change a qualifier value'
  'move-qualifier:change a qualifier property'
  'remove-qualifier:delete a qualifier from a claim'
  'add-reference:attach a reference to a claim'
  'remove-reference:delete a reference from a claim'
  'set-sitelink:link an entity to an article on a wiki'
  'remove-sitelink:remove a wiki article link'
  'add-badge:add badges to an existing sitelink'
  'remove-badge:remove badges from a sitelink'
  'create-entity:generate a new item or property'
  'edit-entity:modify an existing item or property'
  'merge-entity:combine one entity into another'
  'delete-entity:remove an entity'
  'config:manage persistent options'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'wikibase command' commands && ret=0
    ;;
esac

return ret
