#compdef rawdog

# Zsh completion for rawdog — LLM code runner

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-m --model)'{-m,--model}'[model name]:model' \
  '(-p --prompt)'{-p,--prompt}'[system prompt]:text' \
  '*:files:_files' && ret=0

return ret
