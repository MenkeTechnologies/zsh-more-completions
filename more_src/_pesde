#compdef pesde
# Documentation: https://docs.pesde.dev
# pesde - package manager for the Luau programming language

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'init:initialize a new project'
      'add:add a dependency to the manifest'
      'remove:remove a dependency from the manifest'
      'install:install all dependencies'
      'update:update dependencies'
      'outdated:list outdated dependencies'
      'list:list dependencies in the manifest'
      'run:run a binary from a dependency'
      'execute:download and run a one-off package'
      'publish:publish a package to a registry'
      'yank:yank a published version'
      'deprecate:deprecate a published package'
      'patch:prepare a dependency for patching'
      'patch-commit:finalize a dependency patch'
      'self-install:install pesde itself'
      'self-upgrade:upgrade pesde itself'
      'auth:manage registry authentication'
      'config:manage pesde configuration'
      'cas:manage the content-addressable store'
    )
    _describe -t commands 'pesde command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments -s \
          '(-i --index)'{-i,--index}'[index to search for the package]:index:' \
          '(-t --target)'{-t,--target}'[target environment of the package]:target:' \
          '(-a --alias)'{-a,--alias}'[alias to use for the package]:alias:' \
          '(-p --peer -d --dev)'{-p,--peer}'[add as a peer dependency]' \
          '(-d --dev -p --peer)'{-d,--dev}'[add as a dev dependency]' \
          '1:package name:' && ret=0
        ;;
      install)
        _arguments -s \
          '--locked[error on changes in the lockfile]' \
          '--prod[do not install dev dependencies]' \
          '--network-concurrency=[max concurrent network requests]:n:' \
          '--force[re-install all dependencies]' && ret=0
        ;;
      update)
        _arguments -s \
          '--no-install[update dependencies but do not install them]' \
          '--network-concurrency=[max concurrent network requests]:n:' \
          '--force[re-install all dependencies]' && ret=0
        ;;
      publish)
        _arguments -s \
          '(-d --dry-run)'{-d,--dry-run}'[output a tarball instead of publishing]' \
          '(-y --yes)'{-y,--yes}'[agree to all prompts]' \
          '(-i --index)'{-i,--index}'[index to publish to]:index:' \
          '--no-verify[skip syntax validation]' && ret=0
        ;;
      execute|x)
        _arguments -s \
          '(-i --index)'{-i,--index}'[index URL to use for the package]:index:' \
          '1:package:' \
          '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
