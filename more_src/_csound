#compdef csound

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-U+[utility name]:utility:(atsa cvanal dnoise envext extractor het_export het_import hetro lpanal lpc_export lpc_import mixer pvanal pvlook pvplot scale sndinfo srconv)' \
  '-d[suppress all displays]' \
  '-g[suppress graphics displays]' \
  '-G[postscript graphics displays]' \
  '-m+[message level]:n:(0 1 2 3 4 5 6 7)' \
  '-W[write WAV format output]' \
  '-A[write AIFF format output]' \
  '-J[write IRCAM format output]' \
  '-h[no header on output sound file]' \
  '-c[8-bit signed char output samples]' \
  '-a[alaw output samples]' \
  '-u[ulaw output samples]' \
  '-s[short integer output samples]' \
  '-l[long integer output samples]' \
  '-f[32-bit floating point output samples]' \
  '-3[24-bit integer output samples]' \
  '-8[8-bit unsigned char output samples]' \
  '-o+[output filename]:file:_files' \
  '-i+[input audio file]:file:_files' \
  '-F+[MIDI input file]:file:_files -g "*.mid"' \
  '-M+[MIDI input device]:device:' \
  '-Q+[MIDI output device]:device:' \
  '-T[terminate when MIDI score finishes]' \
  '-r+[sample rate override]:rate:' \
  '-k+[control rate override]:rate:' \
  '-K+[do not generate PEAK chunks]:_:' \
  '-b+[output buffer samples]:n:' \
  '-B+[hardware buffer samples]:n:' \
  '-+name=[set named option]:opt:' \
  '-O+[message log file]:file:_files' \
  '-S[score is in old style]' \
  '-x+[extract a part of the score]:file:_files' \
  '-t+[neither sort nor preprocess score]:file:_files' \
  '-Z+[dither output]:n:(0 1 2 3)' \
  '-z+[list opcodes]:flag:(0 1 2)' \
  '--port=[UDP port to listen on]:port:' \
  '--realtime[realtime mode]' \
  '--orc[run as orchestra-only]' \
  '--sco+[score file]:file:_files -g "*.sco"' \
  '--orc-name=[orchestra name]:name:' \
  '--midi-key=[MIDI key controller]:n:' \
  '--midi-velocity=[MIDI velocity controller]:n:' \
  '*:csound file:_files -g "*.(csd|orc|sco)"' && ret=0

return ret
