#compdef bisect-ppx-report
# _bisect-ppx-report — report generator for Bisect_ppx OCaml coverage (aantron/bisect_ppx)
# upstream: https://github.com/aantron/bisect_ppx
# Subcommands from src/report/main.ml (cmdliner term_info).

_bisect-ppx-report() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                html:'generate HTML report locally'
                send-to:'send report to a supported web service (Coveralls/Codecov)'
                summary:'write coverage summary to stdout'
                cobertura:'generate Cobertura XML report'
                coveralls:'generate Coveralls JSON report'
                merge:'merge coverage files'
            )
            _describe -t commands command cmds
            ;;
        args)
            local -a common=(
                '*--coverage-path=[directory to search for .coverage files]:dir:_files -/'
                '*--source-path=[directory to look for source files]:dir:_files -/'
                '--ignore-missing-files[do not fail if source files are missing]'
                '*--expect=[expect coverage for this file/dir]:path:_files'
                '*--do-not-expect=[do not expect coverage for this file/dir]:path:_files'
            )
            case $words[1] in
                html)
                    _arguments $common \
                        '--title=[HTML report title]:title:' \
                        '--tree[generate per-file index tree]' \
                        '(-o --output-directory)'{-o+,--output-directory=}'[output directory]:dir:_files -/' \
                        '*:coverage file:_files' ;;
                send-to)
                    _arguments $common \
                        '--service-name=[service name embedded in report]:name:' \
                        '--service-number=[service number embedded in report]:n:' \
                        '--service-job-id=[service job id embedded in report]:id:' \
                        '1:service:(Coveralls Codecov)' \
                        '*:coverage file:_files' ;;
                summary)
                    _arguments $common \
                        '--per-file[print per-file summary]' \
                        '*:coverage file:_files' ;;
                cobertura)
                    _arguments $common \
                        '1:output file:_files' \
                        '*:coverage file:_files' ;;
                coveralls)
                    _arguments $common \
                        '--service-name=[service name]:name:' \
                        '--service-number=[service number]:n:' \
                        '--service-job-id=[service job id]:id:' \
                        '1:output file:_files' \
                        '*:coverage file:_files' ;;
                merge)
                    _arguments \
                        '1:output coverage file:_files' \
                        '*:input coverage file:_files' ;;
            esac
            ;;
    esac
}

_bisect-ppx-report "$@"
