#compdef fzy

local -a arguments

arguments=(
  '(-l --lines)'{-l,--lines}'[number of lines to show]:lines:'
  '(-p --prompt)'{-p,--prompt}'[prompt string]:prompt:'
  '(-e --show-matches)'{-e,--show-matches}'[non-interactive, show matches for query]:query:'
  '(- *)'{-h,--help}'[display help]'
  '(- *)'{-v,--version}'[display version]'
)

_arguments -s -S $arguments
