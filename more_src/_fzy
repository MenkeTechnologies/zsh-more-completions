#compdef fzy
# Documentation: https://github.com/jhawthorn/fzy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-l --lines)'{-l,--lines}'[number of lines to show]:lines:'
  '(-p --prompt)'{-p,--prompt}'[input prompt]:prompt:'
  '(-q --query)'{-q,--query}'[initial search query]:query:'
  '(-e --show-matches)'{-e,--show-matches}'[non-interactive, output sorted matches]:query:'
  '(-t --tty)'{-t,--tty}'[TTY device file]:tty:_files'
  '(-s --show-scores)'{-s,--show-scores}'[show match scores]'
  '(-0 --read-null)'{-0,--read-null}'[read input delimited by ASCII NUL]'
  '(-j --workers)'{-j,--workers}'[number of search workers]:workers:'
  '(-i --show-info)'{-i,--show-info}'[show selection info line]'
  '(- *)'{-h,--help}'[display help]'
  '(- *)'{-v,--version}'[display version]'
)

_arguments -s -S $arguments
