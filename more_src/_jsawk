#compdef jsawk
# Documentation: https://github.com/micha/jsawk
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for jsawk (micha/jsawk)

local ret=1

_arguments -s -S \
  '-h[wrapper: skip JSON line preprocessing]' \
  '-i[wrapper: read JSON from file]:file:_files' \
  '-s[wrapper: read JSON from string literal]:json' \
  '-n[no print: suppress default JSON output]' \
  '-j[js interpreter binary]:command:_command_names' \
  '*-f[preload JavaScript file]:file:_files' \
  '-q[register jsonquery filter]:query' \
  '-b[beforeEach script fragment]:js' \
  '-a[afterAll script fragment]:js' \
  '-v[NAME=VALUE passed to script]:pair' \
  '::inline script:_files' && ret=0

return ret
