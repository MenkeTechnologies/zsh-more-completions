#compdef presidio
# Documentation: https://man.archlinux.org/search?q=presidio
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration YAML file]:file:_files -g "*.{yaml,yml,presidiocli}"' \
  '(-d --data)'{-d+,--data=}'[inline YAML configuration]:yaml:' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(standard github colored parsable auto)' \
  '--language=[language code (e.g. en, es)]:lang:(en es de fr it pt ja zh)' \
  '*--entities=[entities to detect]:entity:(PERSON EMAIL_ADDRESS CREDIT_CARD US_SSN PHONE_NUMBER IP_ADDRESS US_BANK_NUMBER US_PASSPORT US_DRIVER_LICENSE LOCATION DATE_TIME URL CRYPTO MEDICAL_LICENSE NRP)' \
  '--ignore=[paths to ignore]:patterns:' \
  '*::path:_files' && ret=0

return ret
