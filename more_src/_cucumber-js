#compdef cucumber-js

_arguments -s \
  '(-c --config)'{-c,--config=}'[config file path]:file:_files' \
  '*'{-p,--profile=}'[profile from config]:profile:' \
  '(- *)'{-v,--version}'[print version]' \
  '(- *)'{-h,--help}'[show help]' \
  '--i18n-keywords=[print Gherkin keywords for ISO-639-1 code]:code:' \
  '--i18n-languages[list supported Gherkin languages]' \
  '--force-exit[force event-loop shutdown after tests]' \
  '*--format=[formatter]:format:' \
  '*--format-options=[formatter options]:json:' \
  '*--require=[require module/file]:path:_files' \
  '*--require-module=[require Node module]:module:' \
  '*--import=[import module/file]:path:_files' \
  '--tags=[tag expression]:expr:' \
  '--name=[scenario name regex]:regex:' \
  '--parallel=[number of parallel workers]:n:' \
  '--retry=[retry failing tests]:n:' \
  '--retry-tag-filter=[only retry scenarios matching tags]:expr:' \
  '--dry-run[do not execute steps]' \
  '--fail-fast[stop on first failure]' \
  '--strict[fail on undefined/pending steps]' \
  '--no-strict[do not fail on undefined steps]' \
  '*--world-parameters=[world parameters JSON]:json:' \
  '--publish[publish reports]' \
  '--publish-quiet[publish silently]' \
  '--language=[Gherkin language]:lang:' \
  '--exit[force exit after run]' \
  '*:path:_files'
