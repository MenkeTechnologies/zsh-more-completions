#compdef cartographer_autogenerate_ground_truth
# Documentation: https://github.com/cartographer-project/cartographer/blob/master/cartographer/ground_truth/autogenerate_ground_truth_main.cc
# Autogenerate ground truth data from a Cartographer pose graph

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[show help]' \
  '-pose_graph_filename=[proto stream file containing the pose graph]:file:_files -g "*.pbstream"' \
  '-output_filename=[file to write the ground truth proto to]:file:_files' \
  '-min_covered_distance=[minimum covered distance before loop closure is a candidate]:m' \
  '-outlier_threshold_meters=[distance in meters beyond which constraints are outliers]:m' \
  '-outlier_threshold_radians=[distance in radians beyond which constraints are outliers]:rad' && ret=0

return ret
