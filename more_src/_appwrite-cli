#compdef appwrite
# Documentation: https://appwrite.io/docs/tooling/command-line/commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new project'
  'login:log into Appwrite'
  'logout:log out'
  'whoami:show current user'
  'console:open Console'
  'pull:pull resources'
  'push:push resources'
  'run:run dev server'
  'types:generate types'
  'organizations:organization commands'
  'account:account commands'
  'avatars:avatar commands'
  'databases:database commands'
  'functions:function commands'
  'health:health endpoints'
  'locale:locale endpoints'
  'messaging:messaging commands'
  'projects:project commands'
  'storage:storage commands'
  'teams:team commands'
  'tokens:token commands'
  'users:user commands'
  'graphql:graphql commands'
  'completion:generate shell completion'
  'help:show help'
  'register:register subcommands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--endpoint=[endpoint URL]:url:' \
  '*--project-id=[project ID]:p:' \
  '*--key=[API key]:k:' \
  '*--config=[config dir]:dir:_files -/' \
  '*--json[json output]' \
  '*--no-color[no color]' \
  '*--verbose[verbose]' \
  '*--all[run on all]' \
  '*--force[force]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'appwrite command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (functions|databases|users|teams|storage|messaging|projects|account|tokens|locale|avatars|graphql|health|messaging|organizations)
        _arguments \
          '1:subcommand:' \
          '*: :' && ret=0 ;;
      (push)
        _arguments \
          '1:resource:(all functions databases collections buckets teams settings)' \
          '*: :' && ret=0 ;;
      (pull)
        _arguments \
          '1:resource:(all functions databases collections buckets teams settings)' \
          '*: :' && ret=0 ;;
      (init)
        _arguments \
          '1:resource:(project function bucket team collection messaging-topic)' \
          '*: :' && ret=0 ;;
      (run)
        _arguments \
          '--port=[port]:p:' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
