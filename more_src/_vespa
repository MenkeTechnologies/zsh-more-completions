#compdef vespa

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'activate:activate a previously prepared application package'
  'auth:manage Vespa Cloud authentication'
  'clone:clone a sample application from sample-apps'
  'config:set/get/unset persistent CLI configuration values'
  'curl:send custom HTTP requests with Vespa authentication'
  'deploy:prepare and activate an application package'
  'destroy:remove a deployed application from a cloud target'
  'document:issue document operations (put/get/update/remove)'
  'feed:feed documents from JSON files (or stdin) to a cluster'
  'fetch:download the active application package as a ZIP'
  'inspect:inspect application contents (e.g. profile of a query)'
  'log:show recent logs from a deployed application'
  'prepare:prepare an application package for activation'
  'prod:manage production deployments'
  'query:issue a search query against a deployed application'
  'status:show status of a deployment or container endpoint'
  'test:run application system/integration tests'
  'version:show vespa CLI version'
  'visit:visit (export) documents matching a selection'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(-t --target)'{-t,--target=}'[target platform]:target:(local cloud hosted)' \
  '(-c --color)'{-c,--color=}'[colorize output]:mode:(auto never always)' \
  '(-q --quiet)'{-q,--quiet}'[print only errors]' \
  '(-z --zone)'{-z,--zone=}'[deployment zone (cloud)]:zone:' \
  '(-i --instance)'{-i,--instance=}'[application instance]:instance:' \
  '(-a --application)'{-a,--application=}'[tenant.application.instance]:app:' \
  '(-C --cluster)'{-C,--cluster=}'[container cluster name]:cluster:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vespa subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (auth)
        _values 'auth action' \
          'api-key' 'cert' 'login' 'logout' 'show' && ret=0
        ;;
      (config)
        _values 'config action' \
          'get' 'set' 'unset' && ret=0
        ;;
      (document)
        _values 'document action' \
          'put' 'get' 'update' 'remove' && ret=0
        ;;
      (prod)
        _values 'prod action' \
          'init' 'deploy' 'submit' && ret=0
        ;;
      (deploy|prepare|activate|fetch)
        _files -/
        ret=0
        ;;
      (feed)
        _files
        ret=0
        ;;
    esac
    ;;
esac

return ret
