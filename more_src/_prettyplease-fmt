#compdef prettyplease-fmt
# Documentation: https://github.com/danielhenrymantilla/prettyplease-cli
# Source: https://github.com/danielhenrymantilla/prettyplease-cli/blob/main/src/main.rs
# Reference accessed: 2026-06-01
# Unofficial CLI wrapper around the `::prettyplease` Rust formatter library
# (David Tolnay's prettyplease). Binary name is `prettyplease-fmt`
# (the crate is `prettyplease-cli`).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--check[exit nonzero if any file is ill-formatted; print diffs]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:Rust source file:_files -g "*.rs"' \
    && ret=0

return ret
