#compdef checkcites
# Documentation: checkcites --help (v2.8)
# Source: Lua reference checker for LaTeX bibliographies (unused + undefined cites).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help message]' \
    '(- *)'{-v,--version}'[print script version]' \
    '(-a --all -u --unused -U --undefined)'{-a,--all}'[list all unused and undefined references]' \
    '(-a --all -u --unused -U --undefined)'{-u,--unused}'[list only unused references]' \
    '(-a --all -u --unused -U --undefined)'{-U,--undefined}'[list only undefined references]' \
    '(-c --crossrefs)'{-c,--crossrefs}'[enable cross-reference checks]' \
    '(-b --backend)'{-b+,--backend=}'[backend-based file lookup policy]:backend:(bibtex biber)' \
    '(-j --json)'{-j+,--json=}'[export report as JSON file]:file:_files -g "*.json"' \
    '*:aux or bbl file:_files -g "*.(aux|bbl|bcf|blg)"' \
    && ret=0

return ret
