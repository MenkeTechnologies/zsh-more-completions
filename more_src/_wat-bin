#compdef wat
# _wat-bin — wat WebAssembly text inspection (WABT project); shorthand alias around wabt's wat2wasm/wasm2wat
# upstream: https://github.com/WebAssembly/wabt

_wat-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '--enable-all[enable all wasm features]' \
        '*:wat file:_files -g "*.(wat|wast)"'
}

_wat-bin "$@"
