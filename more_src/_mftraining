#compdef mftraining
# Documentation: https://tesseract-ocr.github.io/tessdoc/TrainingTesseract-3.03%E2%80%933.05.html
# Reference accessed: 2026-05-19
# Verified: mftraining --help output (tesseract training tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '--debug_level=[trainer debug level]:n:' \
  '--load_images=[load images with tr files]:flag:(0 1)' \
  '--clusterconfig_min_samples_fraction=[min samples per proto]:fraction:' \
  '--clusterconfig_max_illegal=[max illegal sample fraction]:fraction:' \
  '--clusterconfig_independence=[desired independence between dimensions]:value:' \
  '--clusterconfig_confidence=[clustering confidence level]:value:' \
  '--configfile=[file to load more configs from]:file:_files' \
  '--D=[output directory]:dir:_files -/' \
  '--F=[font properties file]:file:_files' \
  '--X=[font xheights file]:file:_files' \
  '--U=[unicharset input file]:file:_files' \
  '--O=[unicharset output file]:file:_files' \
  '--output_trainer=[output trainer file]:file:_files' \
  '--test_ch=[UTF8 test character string]:char:' \
  '--fonts_dir=[fonts directory]:dir:_files -/' \
  '--fontconfig_tmpdir=[fontconfig tmpdir]:dir:_files -/' \
  '*:tr file:_files -g "*.tr"' && ret=0

return ret
