#compdef cilium-bugtool
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-bugtool/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cilium-bugtool: collect diagnostic info from a Cilium node
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--archive=[create archive]:bool:(true false)' \
  '--archive-prefix=[archive prefix]:prefix:' \
  {-o,--archiveType=}'[archive type]:type:(tar gz)' \
  '--config=[configuration file]:file:_files' \
  '--dry-run[generate config without executing commands]' \
  '--exec-timeout=[command execution timeout]:duration:' \
  '--enable-markdown[output in markdown format]' \
  {-t,--tmp=}'[temp directory for extracted files]:dir:_files -/' \
  '--envoy-dump=[extract Envoy configuration]:bool:(true false)' \
  '--envoy-metrics=[collect Envoy metrics]:bool:(true false)' \
  '--hubble-metrics=[gather Hubble metrics]:bool:(true false)' \
  '--hubble-metrics-port=[Hubble metrics port]:port:' \
  '--exclude-object-files[skip per-endpoint object files]' \
  '--get-pprof[retrieve pprof traces from cilium-agent]' \
  '--pprof-port=[pprof connection port]:port:' \
  '--pprof-trace-seconds=[CPU trace duration]:seconds:' \
  {-H,--host=}'[Cilium API server URI]:addr:' \
  '--parallel-workers=[concurrent tasks (0 = CPU count)]:n:' \
  '*::cilium-bugtool args:_files' && ret=0
return ret
