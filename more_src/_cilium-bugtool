#compdef cilium-bugtool

# cilium-bugtool: collect diagnostic info from a Cilium node
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-t[tar archive]' \
  '--archive[tar archive]' \
  '--archive-prefix=[archive prefix]:prefix:' \
  '--archive-type=[archive type]:type:(tar gz)' \
  '-d[dump path]:dir:_files -/' \
  '--dump-path=[dump path]:dir:_files -/' \
  '--exclude-object-files[exclude .o files]' \
  '--get-pprof[get pprof profile]' \
  '--enable-markdown[enable markdown output]' \
  '--host=[Cilium agent address]:addr:' \
  '--config-flags=[show config flags]' \
  '*::cilium-bugtool args:_files' && ret=0
return ret
