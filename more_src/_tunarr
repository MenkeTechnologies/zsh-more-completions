_tunarr() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--log_level=[log level (default from getDefaultLogLevel)]:level:(trace debug info warn error fatal silent)'
        '(-v --verbose)'{-v,--verbose}'[increase verbose level (repeatable)]'
        '(-d --database)'{-d,--database=}'[path to the database directory]:directory:_files -/'
        '--hide_banner[hide the ASCII TUNARR banner at startup]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'server:run the Tunarr server (default action when no subcommand specified)'
                'start-worker:start a Tunarr worker (internal use only — meant to be run as a worker thread)'
                'generate-openapi:generate the OpenAPI JSON definition of the Tunarr API'
                'fixer:run a specific fixer task (positional fixer name from FixerNames)'
                'db:database commands (subcommand: migration)'
                'settings:view/update Tunarr settings (subcommand: view / update)'
            )
            _describe -t commands 'tunarr command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                server)
                    _arguments \
                        $global_opts \
                        '(-p --port)'{-p,--port=}'[override the Tunarr server listen port]:port:' \
                        '--printRoutes[print all available routes at startup (env TUNARR_PRINT_ROUTES)]' \
                        '--trustProxy=[trust proxy passed directly to Fastify (env TUNARR_TRUST_PROXY)]:value:' \
                        '--searchPort=[statically define the port to start the search server on]:port:' && ret=0
                    ;;
                start-worker)
                    _arguments \
                        $global_opts && ret=0
                    ;;
                generate-openapi)
                    _arguments \
                        $global_opts \
                        '(-p --port)'{-p,--port=}'[port to run the Tunarr server on]:port:' && ret=0
                    ;;
                fixer)
                    _arguments \
                        $global_opts \
                        '1:fixer name (from FixerNames):' && ret=0
                    ;;
                db)
                    _arguments \
                        $global_opts \
                        '1: :->db_cmds' \
                        '*::arg:->db_args' && ret=0
                    case $state in
                        db_cmds)
                            local -a sub; sub=('migration:database migration commands (list / up / down / sync)')
                            _describe -t commands 'db subcommand' sub && ret=0
                            ;;
                        db_args)
                            case $words[1] in
                                migration)
                                    _arguments \
                                        '1: :->mig_cmds' \
                                        '*::arg:->mig_args' && ret=0
                                    case $state in
                                        mig_cmds)
                                            local -a sub; sub=(
                                                'list:list all migrations and their status'
                                                'up:apply the next or up to the specified migration'
                                                'down:undo the last or specified migration'
                                                'sync:apply all pending migrations'
                                            )
                                            _describe -t commands 'migration subcommand' sub && ret=0
                                            ;;
                                        mig_args)
                                            case $words[1] in
                                                up|down|sync)
                                                    _arguments '1:migration name (optional):' && ret=0
                                                    ;;
                                            esac
                                            ;;
                                    esac
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                settings)
                    _arguments \
                        $global_opts \
                        '1: :->settings_cmds' \
                        '*::arg:->settings_args' && ret=0
                    case $state in
                        settings_cmds)
                            local -a sub; sub=(
                                'view:view Tunarr settings JSON'
                                'update:update Tunarr settings directly via JSON patch'
                            )
                            _describe -t commands 'settings subcommand' sub && ret=0
                            ;;
                        settings_args)
                            case $words[1] in
                                view)
                                    _arguments \
                                        '--pretty[print settings JSON with spacing]' \
                                        '*--path=[filter settings JSON down to one or more paths (JSON path syntax, e.g. settings.ffmpeg.ffmpegExecutablePath)]:path:' && ret=0
                                    ;;
                                update)
                                    _arguments \
                                        '--pretty[print settings JSON with spacing]' \
                                        '--settings=[settings JSON patch payload]:json:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_tunarr "$@"
