#compdef abcm2ps

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-V[show version and quit]' \
  '-O+[output filename]:file:_files -g "*.(ps|pdf|svg|eps)"' \
  '-F+[format file]:file:_files -g "*.fmt"' \
  '*-D+[search directory]:dir:_files -/' \
  '-N+[page number style]:style:(0 1 2 3 4)' \
  '-B+[bars per line]:n:' \
  '-c[continue tunes between lines]' \
  '-l[landscape orientation]' \
  '-1[one tune per page]' \
  '-x[show line numbers]' \
  '-i[indicate empty lines]' \
  '-E[output as EPS files]' \
  '-g[output as SVG]' \
  '-v[output one tune per page as multiple SVG files]' \
  '-X[output as XHTML]' \
  '-z[treat input as ABC plus]' \
  '-w+[paper width (cm)]:cm:' \
  '-T+[transpose semitones]:n:' \
  '-s+[scale]:factor:' \
  '-a[show ascii format only]' \
  '-G[no music display]' \
  '-M[no music]' \
  '-A[justify all lines]' \
  '-j+[measure numbering]:n:' \
  '-k+[clef change]:offset:' \
  '-m+[left margin (cm)]:cm:' \
  '-d+[default duration]:duration:' \
  '*:ABC tune file:_files -g "*.abc"' && ret=0

return ret
