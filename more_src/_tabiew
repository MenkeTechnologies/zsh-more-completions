#compdef tabiew
# tabiew - Lightweight TUI for viewing and querying tabular data (CSV, TSV, Parquet, etc.)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--separator=[field separator for CSV]:separator:' \
  '--no-header[first row is data, not headers]' \
  '--theme=[color theme]:theme:(monokai solarized-dark nord dracula gruvbox)' \
  '--schema[show the schema/column types and exit]' \
  '--infer-schema=[max rows to infer schema from]:rows:' \
  '--ignore-errors[ignore parse errors]' \
  '--null=[string used to represent null values]:null string:' \
  '--type=[force file type]:type:(csv tsv parquet json jsonl arrow)' \
  '*:data file:_files -g "*.{csv,tsv,parquet,json,jsonl,arrow,xlsx}"' \
  && ret=0

return ret
