#compdef browser-use-tui
# Documentation: https://github.com/browser-use/browser-use
# Reference accessed: 2026-05-23
# Verified: browser-use-tui --help (browser-use PyPI console script).

# Zsh completion for browser-use-tui - Browser Use interactive TUI and templates

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version and exit]' \
  '--template[generate template file]:template:(default advanced tools)' \
  '(-o --output)'{-o+,--output=}'[template output path]:file:_files' \
  '(-f --force)'{-f,--force}'[overwrite existing template files]' \
  '--model[LLM model ID]:model:' \
  '--debug[verbose startup logging]' \
  '--headless[run browser headless]' \
  '--window-width[browser window width]:pixels:' \
  '--window-height[browser window height]:pixels:' \
  '--user-data-dir[Chrome user data directory]:directory:_directories' \
  '--profile-directory[Chrome profile name]:profile:' \
  '--cdp-url[connect via CDP URL]:url:' \
  '--proxy-url[proxy server URL]:url:' \
  '--no-proxy[hosts to bypass proxy]:hosts:' \
  '--proxy-username[proxy username]:user:' \
  '--proxy-password[proxy password]:password:' \
  '(-p --prompt)'{-p+,--prompt=}'[single headless task prompt]:prompt:' \
  '--mcp[run as MCP server on stdin/stdout]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'browser-use-tui command' \
      'auth[authenticate with Browser Use Cloud]' \
      'init[generate browser-use template]' \
      'install[install Chromium and dependencies]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-t --template)'{-t+,--template=}'[template name]:template:' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-f --force)'{-f,--force}'[overwrite without asking]' \
          '(-l --list)'{-l,--list}'[list available templates]' && ret=0
        ;;
      auth|install)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
