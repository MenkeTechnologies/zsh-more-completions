#compdef mbed
# Documentation: https://os.mbed.com/docs/mbed-os/v6.16/build-tools/compile.html
# Arm Mbed CLI - command-line tool for Mbed OS development

local ret=1
local context state line
typeset -A opt_args

_mbed_cmds() {
  local -a cmds
  cmds=(
    'new:create a new Mbed program or library'
    'import:import an existing Mbed program'
    'add:add a library to the program'
    'remove:remove a library from the program'
    'deploy:find and import missing libraries'
    'update:update the program or library'
    'compile:compile code using the Mbed build tools'
    'test:find, build and run tests'
    'export:generate IDE project files'
    'detect:detect connected Mbed targets'
    'config:configure Mbed CLI settings'
    'target:set or get the default target'
    'toolchain:set or get the default toolchain'
    'sterm:open a serial terminal to the target'
    'ls:list defined libraries'
    'releases:show release tags for the program'
  )
  _describe -t commands 'mbed command' cmds
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :_mbed_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      compile)
        _arguments -s -S \
          '(-t --toolchain)'{-t,--toolchain}'[toolchain to use]:toolchain:(ARM GCC_ARM IAR)' \
          '(-m --target)'{-m,--target}'[build target]:target:' \
          '(-c --clean)'{-c,--clean}'[clean before building]' \
          '(-f --flash)'{-f,--flash}'[flash the built firmware]' \
          '--sterm[open serial terminal after flashing]' \
          '--profile=[build profile]:profile:(develop debug release)' \
          '--library[compile as a static library]' \
          '--no-archive[do not produce an archive .a file]' \
          '*--source=[source directory]:dir:_files -/' \
          '--build=[build output directory]:dir:_files -/' \
          '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs:' \
          '(-S --supported)'{-S,--supported}'[show supported targets and toolchains]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '--config[show configuration parameters]' \
          '*--prefix=[filter config output by prefix]:prefix:' \
          '*-D[define a macro]:macro:' \
          '(-N --artifact-name)'{-N,--artifact-name}'[name of the output artifact]:name:' && ret=0
        ;;
      sterm)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[serial port]:port:' \
          '(-b --baudrate)'{-b,--baudrate}'[baud rate]:baud:' \
          '(-e --echo)'{-e,--echo}'[local echo]:echo:(on off)' \
          '(-r --reset)'{-r,--reset}'[reset the target before connecting]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
