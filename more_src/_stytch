#compdef stytch stytch-cli
# Documentation: https://man.archlinux.org/search?q=stytch
# Reference accessed: 2026-05-16

_stytch() {
    local line state
    local -a commands
    commands=(
        'authenticate:Authenticate with Stytch'
        'logout:Logout from Stytch'
        'version:Show version'
        'projects:Manage Stytch projects'
        'redirecturls:Manage redirect URLs'
        'sdks:Manage SDK configurations'
        'secrets:Manage project secrets'
        'emailtemplates:Manage email templates'
        'jwttemplates:Manage JWT templates'
    )

    _arguments -C \
        '--client-id[Stytch client ID]:id:' \
        '--project-id[Stytch project ID]:id:' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'stytch command' commands
            ;;
    esac
}

_stytch "$@"
