#compdef prodigal-gv
# Documentation: https://github.com/apcamargo/prodigal-gv
# prodigal-gv - Prodigal fork for giant virus and huge phage gene prediction

local ret=1

_arguments -s -S \
  '(- *)-h[print help menu and exit]' \
  '(- *)-v[print version number and exit]' \
  '-a+[write protein translations to file]:file:_files' \
  '-d+[write nucleotide sequences to file]:file:_files' \
  '-i+[specify input file (default stdin)]:file:_files' \
  '-o+[specify output file (default stdout)]:file:_files' \
  '-s+[write all potential genes with scores to file]:file:_files' \
  '-t+[write/read training file location]:file:_files' \
  '-w+[write summary statistics to file]:file:_files' \
  '-f+[specify output format]:format:(gbk gff sqn sco)' \
  '-g+[specify translation table to use]:table:(11 4 1)' \
  '-p+[specify mode]:mode:(single meta)' \
  '-c[closed ends; do not allow partial genes at edges]' \
  '-m[treat runs of N as masked and do not build genes across]' \
  '-n[bypass Shine-Dalgarno trainer and force a full motif scan]' \
  '-q[run quietly (suppress logging output)]' && ret=0

return ret
