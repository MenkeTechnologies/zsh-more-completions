#compdef ndppd
# Documentation: https://manpages.debian.org/testing/ndppd/ndppd.1.en.html
# Reference accessed: 2026-05-30
# ndppd — IPv6 Neighbor Discovery Protocol Proxy Daemon.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[alternate config file (default /etc/ndppd.conf)]:file:_files -g "*.conf"' \
  '-d[daemonize: run in background, enable syslog logging]' \
  '-p+[create PID file at this location]:file:_files' \
  '*-v[increase logging verbosity (stackable)]' \
  && ret=0

return ret
