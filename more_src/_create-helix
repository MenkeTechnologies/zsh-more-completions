#compdef create-helix
# Documentation: https://www.npmjs.com/package/create-helix
# Reference accessed: 2026-05-23
# Verified: npm view create-helix bin; dist/args.js and npm readme.

# Zsh completion for create-helix - HELiX web components project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C   '--template=[framework template]:template:(wc-storybook react-next react-vite remix vue-nuxt vue-vite solid-vite qwik-vite svelte-kit angular astro vanilla lit-vite preact-vite stencil ember)'   '--preset=[Drupal preset]:preset:(standard blog healthcare intranet)'   '--bundles=[component bundles; comma-separated]:bundle:(all core forms navigation data-display feedback layout)'   '(-o --output-dir)'{-o,--output-dir=}'[output directory]:directory:_directories'   '--profile=[scaffold profile]:profile:'   '--ds-name=[design system codename for wc-storybook]:name:'   '--token-prefix=[CSS custom property prefix]:prefix:'   '--brand-tagline=[brand tagline for Cover and Brand MDX]:tagline:'   '--brand-verticals=[comma-separated brand verticals]:verticals:'   '--dry-run[preview scaffold without writing files]'   '--force[overwrite existing output]'   '--no-install[skip dependency install]'   '--quiet[minimal output]'   '(-q --quiet)'{-q,--quiet}'[minimal output]'   '--json[JSON output mode]'   '--drupal[scaffold a Drupal theme]'   '--show-experimental[enable experimental templates]'   '--monorepo[force monorepo layout for app frameworks]'   '--no-design-system[scaffold flat app without bundled design-system package]'   '--typescript[enable TypeScript]'   '--no-typescript[disable TypeScript]'   '--eslint[enable ESLint]'   '--no-eslint[disable ESLint]'   '--dark-mode[enable dark mode support]'   '--no-dark-mode[disable dark mode support]'   '--tokens[include design tokens]'   '--no-tokens[omit design tokens]'   '--skip-audit[skip post-scaffold audit]'   '--offline[offline mode]'   '--no-config[skip config file generation]'   '--verbose[verbose errors and stack traces]'   '--quick[quick doctor checks]'   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'command' list info doctor upgrade config && ret=0
    ;;
  args)
    case $line[1] in
      info|config)
        _arguments -C           ':template or preset id:' && ret=0
        ;;
      list|doctor|upgrade)
        _arguments -C           '--show-experimental[include experimental templates in list]'           '--json[JSON output]'           '--quick[quick doctor mode]'           '--verbose[verbose output]' && ret=0
        ;;
      *)
        _arguments -C           '--template=[framework template]:template:(wc-storybook react-next react-vite svelte-kit astro)'           '--preset=[Drupal preset]:preset:(standard blog healthcare intranet)'           '--no-install[skip dependency install]'           '--dry-run[preview without writing files]'           ':project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
