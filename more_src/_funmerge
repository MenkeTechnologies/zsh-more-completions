#compdef funmerge
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funmerge.1
# Merge multiple Funtools table files into a single output file

local ret=1

_arguments -s -S \
  '-f+[append a column identifying the source file]:colname' \
  '-w[recalibrate position values based on WCS]' \
  '-x[recalibrate via WCS, preserving original values]' \
  '*:file:_files' && ret=0

return ret
