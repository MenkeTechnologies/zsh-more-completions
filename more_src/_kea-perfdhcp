#compdef perfdhcp kea-perfdhcp
# _kea-perfdhcp — ISC Kea perfdhcp DHCPv4 and DHCPv6 server benchmark and load tester (isc team, C++); custom argparse
# upstream: https://gitlab.isc.org/isc-projects/kea

_kea-perfdhcp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-4[DHCPv4]' \
        '-6[DHCPv6]' \
        '-b+[base value]:str:' \
        '-c[checksum offload off]' \
        '-d+[drop time secs]:n:' \
        '-e+[lease type]:t:(address-only prefix-only address-and-prefix)' \
        '-E+[time offset]:n:' \
        '-f+[renew rate]:n:' \
        '-F+[release rate]:n:' \
        '-g+[script]:str:' \
        '-i[only send INIT_REBOOT]' \
        '-I+[ip-offset]:n:' \
        '-l+[local interface or address]:str:' \
        '-L+[local port]:port:_ports' \
        '-M+[mac template]:str:' \
        '-n+[num requests]:n:' \
        '-N+[remote port]:port:_ports' \
        '-O+[rand offset]:n:' \
        '-p+[period secs]:n:' \
        '-P+[preload]:n:' \
        '-r+[request rate]:n:' \
        '-R+[clients]:n:' \
        '-s+[seed]:n:' \
        '-S+[server name]:str:' \
        '-t+[report interval]:n:' \
        '-T+[template file]:file:_files' \
        '-u+[uniform interval ms]:n:' \
        '-w+[wrapped script]:str:' \
        '-W+[exit wait time]:n:' \
        '-x+[diagnostic selectors]:str:' \
        '-X+[xid offset]:n:' \
        '-y+[transaction template]:str:' \
        '-Y+[option offset]:n:' \
        '*:server:_hosts'
}

_kea-perfdhcp "$@"
