#compdef zipUpMesh
# Reads in a mesh with hanging vertices and zips up the cells to guarantee a correct mesh

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-region+[specify alternative mesh region]:region:' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' && ret=0

return ret
