#compdef tsbs_load
# Documentation: https://github.com/timescale/tsbs#load-data
# Time Series Benchmark Suite data loader

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '--config=[config file to load]:config file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'tsbs_load command' \
      'load[load data into a specified target database]' \
      'config[generate example config yaml file]' && ret=0
    ;;
  args)
    case $line[1] in
      load)
        _values 'target database' \
          cassandra clickhouse influx mongo siridb timescaledb \
          akumuli cratedb prometheus victoriametrics timestream questdb && ret=0
        _arguments -s \
          '--loader.runner.workers=[number of parallel clients inserting]:count' \
          '--loader.runner.batch-size=[number of items per insert]:size' \
          '--loader.runner.limit=[number of items to insert (0 = all)]:count' \
          '--loader.runner.db-name=[name of database]:db name' \
          '--loader.runner.reporting-period=[period to report write stats]:duration' \
          '--loader.runner.seed=[PRNG seed]:seed' \
          '--loader.runner.do-load=[whether to write data]:bool:(true false)' \
          '--loader.runner.do-create-db=[whether to create the database]:bool:(true false)' \
          '--loader.runner.do-abort-on-exist=[abort if database already exists]' \
          '--loader.runner.hash-workers=[consistently hash insert data to the same workers]' \
          '--loader.runner.insert-intervals=[time to wait between each insert]:intervals' \
          '--loader.runner.flow-control=[use flow-control when scanning data]' \
          '--loader.runner.channel-capacity=[capacity of the channel holding ready batches]:capacity' \
          '--data-source.type=[data source type]:type' \
          '--data-source.file.location=[file to read data from]:file:_files' && ret=0
        ;;
      config)
        _arguments -s \
          '--target=[target database for the config]:target' \
          '--data-source=[data source for the config]:source' && ret=0
        ;;
    esac
    ;;
esac

return ret
