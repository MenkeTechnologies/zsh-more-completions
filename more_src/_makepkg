#compdef makepkg

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --ignorearch)'{-A,--ignorearch}'[ignore architecture check]' \
  '(-c --clean)'{-c,--clean}'[clean leftover files after build]' \
  '--cleanafter[clean only after a successful build]' \
  '(-C --cleanbuild)'{-C,--cleanbuild}'[remove srcdir before build]' \
  '(-d --nodeps)'{-d,--nodeps}'[skip dependency checks]' \
  '(-e --noextract)'{-e,--noextract}'[do not extract source files]' \
  '(-f --force)'{-f,--force}'[overwrite existing package]' \
  '(-g --geninteg)'{-g,--geninteg}'[generate integrity checksums]' \
  '--skipinteg[skip all integrity checks]' \
  '--skipchecksums[skip checksum verification]' \
  '--skippgpcheck[skip PGP signature check]' \
  '(-i --install)'{-i,--install}'[install via pacman after build]' \
  '(-L --log)'{-L,--log}'[log build to file]' \
  '(-m --nocolor)'{-m,--nocolor}'[disable color output]' \
  '(-o --nobuild)'{-o,--nobuild}'[download/extract sources only]' \
  '-p=[alternate build script]:file:_files' \
  '(-r --rmdeps)'{-r,--rmdeps}'[remove built dependencies after build]' \
  '(-R --repackage)'{-R,--repackage}'[repackage without rebuilding]' \
  '(-s --syncdeps)'{-s,--syncdeps}'[install missing dependencies via pacman]' \
  '(-S --source)'{-S,--source}'[generate source-only tarball]' \
  '--allsource[generate source tarball with downloaded sources]' \
  '--check[run check() function]' \
  '--nocheck[skip check() function]' \
  '--noprepare[skip prepare() function]' \
  '--sign[sign resulting package]' \
  '--nosign[do not sign package]' \
  '--key=[GPG key id for signing]:key:' \
  '--noarchive[do not create the final archive]' \
  '--holdver[do not update VCS pkgver]' \
  '--packagelist[list package filenames]' \
  '--printsrcinfo[print source info to stdout]' \
  '--verifysource[verify source files only]' \
  '--config=[config file]:file:_files'
