#compdef multus-cni
# Documentation: https://k8snetworkplumbingwg.github.io/multus-cni/docs/how-to-use.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Multus CNI: multi-network CNI for Kubernetes pods
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--config-file=[config file]:file:_files' \
  '--multus-conf-file=[Multus conf file]:file:_files' \
  '--multus-bin-file=[Multus bin path]:file:_files' \
  '--cni-bin-dir=[CNI bin dir]:dir:_files -/' \
  '--cni-conf-dir=[CNI conf dir]:dir:_files -/' \
  '--readiness-indicator-file=[readiness file]:file:_files' \
  '--namespace-isolation=[namespace isolation]:bool:(true false)' \
  '--multus-log-to-stderr=[log to stderr]:bool:(true false)' \
  '--multus-log-level=[log level]:level:(verbose debug error)' \
  '--multus-log-file=[log file]:file:_files' \
  '*::multus-cni args:_files' && ret=0
return ret
