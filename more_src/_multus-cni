#compdef multus-cni
# Documentation: https://k8snetworkplumbingwg.github.io/multus-cni/docs/how-to-use.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Multus CNI: multi-network CNI for Kubernetes pods
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--cni-conf-dir=[CNI conf dir]:dir:_files -/' \
  '--cni-bin-dir=[CNI bin dir]:dir:_files -/' \
  '--cni-version=[CNI spec version]:version:' \
  '--multus-conf-file=[Multus conf file]:file:_files' \
  '--multus-bin-file=[Multus bin path]:file:_files' \
  '--multus-autoconfig-dir=[Multus auto-config dir]:dir:_files -/' \
  '--multus-kubeconfig-file-host=[kubeconfig path]:file:_files' \
  '--multus-master-cni-file-name=[master CNI file name]:name:' \
  '--multus-log-to-stderr=[log to stderr]:bool:(true false)' \
  '--multus-log-level=[log level]:level:(panic error warning verbose debug)' \
  '--multus-log-file=[log file]:file:_files' \
  '--namespace-isolation=[namespace isolation]:bool:(true false)' \
  '--global-namespaces=[comma-separated namespace list]:namespaces:' \
  '--readiness-indicator-file=[readiness file]:file:_files' \
  '--cleanup-config-on-exit=[cleanup config on exit]:bool:(true false)' \
  '--skip-config-watch[disable config watching]' \
  '--rename-conf-file=[rename source conf files]:bool:(true false)' \
  '--additional-bin-dir=[additional binary directory]:dir:_files -/' \
  '--skip-multus-binary-copy[skip binary copy]' \
  '*::multus-cni args:_files' && ret=0
return ret
