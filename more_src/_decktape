#compdef decktape

local curcontext="$curcontext" ret=1
typeset -A opt_args

_arguments -C -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '*-s+[Viewport size WIDTHxHEIGHT]:size:' \
  '*--size=[Viewport size WIDTHxHEIGHT]:size:' \
  '*-p+[Pause in ms before each slide (default 1000)]::' \
  '*--pause=[Pause in ms before each slide]::' \
  '--load-pause=[Delay ms after page load before export]::' \
  '--url-load-timeout=[Initial URL load timeout ms]::' \
  '--page-load-timeout=[Slide deck load timeout ms]::' \
  '--buffer-timeout=[Slide buffering wait ms (0 disables)]::' \
  '--screenshots[Export each slide as an image]' \
  '--screenshots-directory=[Screenshots output dir]:directory:_directories' \
  '*--screenshots-size=[Screenshot resolution WxH]:size:' \
  '--screenshots-format=[Image format]:format:(jpg png)' \
  '--slides=[Slide indexes/ranges e.g. 1-3,5,8]:range:' \
  '--headless=[Puppeteer headless mode]:mode:(new true false)' \
  '--headers=[Comma-separated HTTP header pairs]:headers:' \
  '--chrome-path=[Chrome/Chromium binary]:executable:_files' \
  '*--chrome-arg=[Extra Chromium flag]:flag:' \
  '--pdf-author=[PDF author metadata]:author:' \
  '--pdf-title=[PDF title metadata]:title:' \
  '--pdf-subject=[PDF subject metadata]:subject:' \
  '1:plugin:(automatic bespoke deck dzslides flowtime generic impress inspire nuedeck remark reveal shower slidy webslides)' \
  '2:url: :' \
  '3:output pdf: :_files' && ret=0

return ret
