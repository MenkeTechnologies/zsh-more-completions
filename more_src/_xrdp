#compdef xrdp
# Documentation: https://man.archlinux.org/search?q=xrdp
# Reference accessed: 2026-05-16

_arguments -s \
  '(-k --kill)'{-k,--kill}'[kill running xrdp daemon]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[run in foreground]' \
  '(-p --port)'{-p,--port=}'[TCP port]:port:' \
  '(-f --fork)'{-f,--fork}'[fork per connection]' \
  '--dump-config[print configuration]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files'
