#compdef clusterpedia-apiserver
# _clusterpedia-apiserver — Clusterpedia aggregated apiserver (serves clusterpedia.io/v1beta1 resources backed by the multi-cluster storage)
# upstream: https://github.com/clusterpedia-io/clusterpedia
# Flags from cmd/apiserver/app/{apiserver,options/options}.go on tip + k8s.io/apiserver generic-apiserver flags + storage backend flags.

_clusterpedia-apiserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version=[print version and exit]:fmt:(true raw)' \
        '--max-requests-inflight=[max non-mutating requests in flight]:n:' \
        '--max-mutating-requests-inflight=[max mutating requests in flight]:n:' \
        '--secure-port=[HTTPS port]:port:' \
        '--bind-address=[address the secure server binds to]:addr:' \
        '--tls-cert-file=[TLS certificate]:file:_files' \
        '--tls-private-key-file=[TLS private key]:file:_files' \
        '--client-ca-file=[client CA bundle]:file:_files' \
        '--storage-config=[storage backend config file]:file:_files' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr]:bool:(true false)' \
        '--logging-format=[log format]:fmt:(text json)'
}

_clusterpedia-apiserver "$@"
