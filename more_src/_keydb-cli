#compdef keydb-cli

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[server hostname]:host:_hosts' \
  '-p[server port]:port:' \
  '-s[server socket]:socket:_files' \
  '-a[password]:password:' \
  '--user=[username for ACL auth]:username:' \
  '-n[database number]:database:' \
  '-u[server URI]:uri:' \
  '--tls[establish a secure TLS connection]' \
  '--cert=[client certificate file for TLS]:file:_files' \
  '--key=[private key file for TLS]:file:_files' \
  '--cacert=[CA certificate file for TLS]:file:_files' \
  '-r[execute command N times]:count:' \
  '-i[interval between commands in seconds]:interval:' \
  '-x[read last argument from STDIN]' \
  '-c[enable cluster mode]' \
  '--raw[use raw formatting for replies]' \
  '--no-raw[force formatted output]' \
  '--csv[output in CSV format]' \
  '--resp2[use RESP2 protocol mode]' \
  '--resp3[use RESP3 protocol mode]' \
  '--pipe[transfer raw protocol from stdin to server]' \
  '--pipe-timeout=[timeout for --pipe mode in milliseconds]:ms:' \
  '--bigkeys[sample keys looking for big keys]' \
  '--memkeys[sample keys looking for memory-heavy keys]' \
  '--hotkeys[sample keys looking for hot keys]' \
  '--scan[list all keys using SCAN]' \
  '--pattern=[pattern for keys to match]:pattern:' \
  '--count=[count for SCAN hint]:count:' \
  '--intrinsic-latency=[test intrinsic latency for given seconds]:seconds:' \
  '--latency[enter latency mode]' \
  '--latency-history[enter latency history mode]' \
  '--latency-dist[show latency as a spectrum]' \
  '--lru-test=[simulate a cache workload with N keys]:keys:' \
  '--slave[simulate a slave showing commands from master]' \
  '--replica[simulate a replica showing commands from master]' \
  '--rdb=[transfer RDB dump from remote server to local file]:file:_files' \
  '--cluster=[enter cluster sub-command mode]:subcommand:' \
  '--stat[print rolling stats about server]' \
  '--no-auth-warning[suppress warning when using password on command line]' \
  '--no-motd[suppress server message of the day]' \
  '--verbose[verbose mode]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:command:' && ret=0

return ret
