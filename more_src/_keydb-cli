#compdef keydb-cli
# Documentation: https://github.com/Snapchat/KeyDB/blob/main/src/redis-cli.c
# Reference accessed: 2026-05-19
# Verified: against the usage() text in upstream KeyDB src/redis-cli.c.
# Corrected from prior file: removed invented --resp2/--resp3/--count/
# --slave/--pipe value-join issues; -3 is the RESP3 flag; --user takes
# a space-separated value; added real --askpass, --quoted-input,
# --quoted-pattern, -d/-D, --sni, --cacertdir, --tls-ciphers,
# --tls-ciphersuites, --insecure, --eval, --ldb, --ldb-sync-mode,
# --force, --memkeys-samples, -X.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[server hostname]:host:_hosts' \
  '-p[server port]:port:' \
  '-s[server socket]:socket:_files' \
  '-a[password]:password:' \
  '--user[username for ACL auth]:username:' \
  '--pass[password to use]:password:' \
  '--askpass[prompt for password interactively]' \
  '-u[server URI]:uri:' \
  '-r[execute command N times]:count:' \
  '-i[interval between commands in seconds]:interval:' \
  '-n[database number]:database:' \
  '-3[use RESP3 protocol mode]' \
  '-x[read last argument from STDIN]' \
  '-X[read named argument from STDIN]:argument name:' \
  '-d[delimiter between response bytes for raw formatting]:delimiter:' \
  '-D[delimiter between responses for raw formatting]:delimiter:' \
  '-c[enable cluster mode]' \
  '-e[return exit error code when command execution fails]' \
  '-t[server connection timeout in seconds]:seconds:' \
  '--tls[establish a secure TLS connection]' \
  '--sni[server name indication for TLS]:host:' \
  '--cacert[CA certificate file for TLS]:file:_files' \
  '--cacertdir[directory of trusted CA certificates]:dir:_files -/' \
  '--insecure[skip TLS certificate validation]' \
  '--cert[client certificate file for TLS]:file:_files' \
  '--key[private key file for TLS]:file:_files' \
  '--tls-ciphers[TLSv1.2 and lower cipher list]:ciphers:' \
  '--tls-ciphersuites[TLSv1.3 ciphersuites]:ciphersuites:' \
  '--raw[use raw formatting for replies]' \
  '--no-raw[force formatted output even when not a tty]' \
  '--quoted-input[force input to be parsed as quoted strings]' \
  '--csv[output in CSV format]' \
  '--show-pushes[whether to print RESP3 PUSH messages]:value:(yes no)' \
  '--stat[print rolling stats about server]' \
  '--latency[enter latency mode]' \
  '--latency-history[enter latency history mode]' \
  '--latency-dist[show latency as a spectrum]' \
  '--lru-test[simulate a cache workload with N keys]:keys:' \
  '--replica[simulate a replica showing commands from master]' \
  '--rdb[transfer RDB dump from remote server to local file]:file:_files' \
  '--pipe[transfer raw protocol from stdin to server]' \
  '--pipe-timeout[timeout for --pipe mode in seconds]:seconds:' \
  '--bigkeys[sample keys looking for big keys]' \
  '--memkeys[sample keys looking for memory-heavy keys]' \
  '--memkeys-samples[sample size for --memkeys]:n:' \
  '--hotkeys[sample keys looking for hot keys]' \
  '--scan[list all keys using SCAN]' \
  '--pattern[pattern for keys to match in --scan/--bigkeys]:pattern:' \
  '--quoted-pattern[same as --pattern, with a quoted-string pattern]:pattern:' \
  '--intrinsic-latency[test intrinsic latency for given seconds]:seconds:' \
  '--eval[send an EVAL command using the Lua script at path]:file:_files -g "*.lua"' \
  '--ldb[used with --eval, enable the Redis Lua debugger]' \
  '--ldb-sync-mode[like --ldb but uses synchronous mode]' \
  '--cluster[enter cluster sub-command mode]:subcommand:' \
  '--verbose[verbose mode]' \
  '--no-auth-warning[suppress warning when using password on command line]' \
  '--no-motd[suppress server message of the day]' \
  '--force[force connection without confirmation]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:command:' && ret=0

return ret
