#compdef checkov
# _checkov-bin — Bridgecrew Checkov IaC static analyzer (Prisma Cloud, Python); scans Terraform/CFN/k8s/Helm/ARM for policy violations
# upstream: https://github.com/bridgecrewio/checkov

_checkov-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-d --directory)'{-d,--directory}'+[directory to scan]:dir:_files -/' \
        '(-f --file)'{-f,--file}'+[file to scan]:file:_files' \
        '--external-checks-dir+[external checks dir]:dir:_files -/' \
        '--external-checks-git+[external checks git url]:url:_urls' \
        '(-l --list)'{-l,--list}'[list available checks]' \
        '-o+[output format]:fmt:(cli json junitxml github_failed_only sarif csv cyclonedx cyclonedx_json gitlab_sast)' \
        '--output+[output format]:fmt:' \
        '--output-file-path+[output file]:file:_files' \
        '--output-bc-ids[output bridgecrew check ids]' \
        '--no-guide[do not include guide URLs]' \
        '--quiet[quiet]' \
        '--compact[compact summary]' \
        '--framework+[framework]:framework:(all argo_workflows arm azure_pipelines bicep cloudformation circleci_pipelines dockerfile github_configuration github_actions gitlab_configuration gitlab_ci helm json yaml kubernetes kustomize openapi sca_image sca_package secrets serverless terraform terraform_plan terraform_json bitbucket_configuration ansible)' \
        '--skip-framework+[skip framework]:framework:' \
        '--check+[check ids]:ids:' \
        '-c+[check ids]:ids:' \
        '--skip-check+[skip check ids]:ids:' \
        '--soft-fail[never return non-zero exit]' \
        '--soft-fail-on+[soft fail on ids]:ids:' \
        '--hard-fail-on+[hard fail on ids]:ids:' \
        '--config-file+[config file]:file:_files' \
        '--block-list-secret-scan+[block secret scan]:str:' \
        '--evaluate-variables+[evaluate variables]:bool:' \
        '--bc-api-key+[Bridgecrew API key]:str:' \
        '--prisma-api-url+[Prisma API URL]:url:_urls' \
        '--repo-id+[repo id]:str:' \
        '--branch+[branch]:str:' \
        '--ca-certificate+[CA cert]:file:_files' \
        '--include-all-checkov-policies[include all policies]' \
        '--no-fail-on-crash[do not fail on crash]' \
        '--policy-metadata-filter+[policy metadata filter]:str:' \
        '--secrets-scan-file-type+[secrets file type]:type:' \
        '--enable-secret-scan-all-files[secret scan all]' \
        '--openai-api-key+[openai api key]:str:' \
        '--summary-position+[summary position]:pos:(top bottom)' \
        '--download-external-modules+[download tf modules]:bool:' \
        '--enable-git-history-secret-scan[git history secret scan]' \
        '--scan-secrets-history[scan secret history]' \
        '*:target:_files'
}

_checkov-bin "$@"
