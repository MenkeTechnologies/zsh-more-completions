#compdef odo
# Documentation: https://man.archlinux.org/search?q=odo
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:bootstrap a new component'
  'dev:development mode (live updates)'
  'deploy:deploy a component'
  'run:run a devfile command directly'
  'build-images:build container images'
  'add:add a resource (e.g. binding)'
  'remove:remove a resource (e.g. binding)'
  'create:create a resource (e.g. namespace)'
  'set:set a resource (e.g. namespace)'
  'list:list components/services/namespaces/bindings'
  'describe:describe component or binding'
  'delete:delete component or namespace'
  'logs:view application logs'
  'login:login to a cluster'
  'logout:logout from a cluster'
  'registry:manage devfile registries'
  'preference:configure odo preferences'
  'completion:generate shell completion'
  'version:show odo version'
  'analyze:analyze project (alpha)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--namespace=[Kubernetes namespace]:namespace:' \
  '--context=[kube context]:context:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '-o+[output format]:format:(json text)' \
  '--platform=[target platform]:platform:(kubernetes podman)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'odo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--name=[component name]:name:' \
          '--devfile=[devfile name]:devfile:' \
          '--devfile-registry=[registry to use]:registry:' \
          '--devfile-version=[devfile version]:version:' \
          '--devfile-path=[devfile path]:file:_files' \
          '--starter=[starter project]:starter:' \
          '--run-port=[run port]:port:' \
          '--application=[application]:app:' && ret=0 ;;
      (dev)
        _arguments \
          '--no-watch[disable watch mode]' \
          '--debug[run in debug mode]' \
          '--port-forward=[local:remote port forward]:mapping:' \
          '--ignore-localhost[ignore localhost in port forward]' \
          '--randomports[use random ports]' \
          '--var=[CLI variable to override]:var:' \
          '--var-file=[variables file]:file:_files' \
          '--build-command=[devfile build command]:cmd:' \
          '--run-command=[devfile run command]:cmd:' \
          '--debug-command=[devfile debug command]:cmd:' && ret=0 ;;
      (deploy)
        _arguments \
          '--var=[CLI variable to override]:var:' \
          '--var-file=[variables file]:file:_files' && ret=0 ;;
      (build-images)
        _arguments \
          '--push[push images after build]' \
          '--var=[CLI variable]:var:' \
          '--var-file=[variables file]:file:_files' && ret=0 ;;
      (add)
        _arguments '*::sub:(binding)' && ret=0 ;;
      (remove)
        _arguments '*::sub:(binding)' && ret=0 ;;
      (create)
        _arguments '*::sub:(namespace project)' && ret=0 ;;
      (set)
        _arguments '*::sub:(namespace project)' && ret=0 ;;
      (delete)
        _arguments '*::sub:(component namespace project)' && ret=0 ;;
      (list)
        _arguments '*::sub:(component services namespace project bindings)' && ret=0 ;;
      (describe)
        _arguments '*::sub:(component binding)' && ret=0 ;;
      (registry)
        _arguments '*::sub:(add list delete update)' && ret=0 ;;
      (preference)
        _arguments '*::sub:(view set unset add remove)' && ret=0 ;;
      (logs)
        _arguments \
          '--follow[follow log output]' \
          '--platform=[platform]:platform:(kubernetes podman)' \
          '--dev[show dev mode logs]' \
          '--deploy[show deploy mode logs]' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
