#compdef watchfiles

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--target-type[type of target to run]:type:(command function coerce)' \
  '*--args[arguments to pass to the command]:args' \
  '--filter[file filter]:filter:(default python all)' \
  '*--ignore-paths[paths to ignore]:path:_files' \
  '--verbose[enable verbose output]' \
  '--non-recursive[do not watch recursively]' \
  '--sigint-timeout[timeout for SIGINT]:seconds' \
  '--sigkill-timeout[timeout for SIGKILL]:seconds' \
  '1:command or function:_command_names' \
  '*:path:_files' && ret=0

return ret
