#compdef watchfiles
# Documentation: https://watchfiles.helpmanual.io/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--ignore-paths=[exclude directories (comma-separated)]:paths' \
  '--target-type=[execution type]:type:(command function auto)' \
  '--filter=[which files to monitor]:filter:(default python all)' \
  '--args=[command-line arguments for function targets]:args' \
  '--verbose[enable debug-level logging]' \
  '--non-recursive[do not recurse into subdirectories]' \
  '--verbosity=[log level]:level:(warning info debug)' \
  '--sigint-timeout=[seconds before sending SIGKILL after SIGINT]:seconds' \
  '--grace-period=[seconds to delay before monitoring]:seconds' \
  '--sigkill-timeout=[seconds before raising timeout after SIGKILL]:seconds' \
  '--ignore-permission-denied[suppress permission errors]' \
  '1:target (command or dotted function path):' \
  '*:path:_files' && ret=0

return ret
