#compdef bmxd bmx6 bmx7
# _bmx — B.A.T.M.A.N. eXperimental BMX6/BMX7 mesh routing daemon (per-node link-state mesh routing daemon developed by qmp.cat / freifunk; -h help, -v version, -f config file, -d debug level, -P pidfile, -L log file, -i interface (repeated for multiple mesh devs), -p plugin path, -t throttle ms, -m mode (server|client), -r tunnel ranges; interactive control socket exposes show/list/add/delete commands)
# upstream: https://github.com/bmx-routing/bmx7
# Flags from bmx7 src/main.c on tip.

_bmx() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-f+[config file]:file:_files' \
        '-d+[debug level]:level:' \
        '-P+[pidfile]:file:_files' \
        '-L+[log file]:file:_files' \
        '*-i+[interface]:interface:_net_interfaces' \
        '*-p+[plugin path]:file:_files -g "*.so"' \
        '-t+[throttle ms]:ms:' \
        '-m+[mode]:mode:(server client)' \
        '-r+[tunnel range]:range:'
}

_bmx "$@"
