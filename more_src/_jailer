#compdef jailer

# jailer: Firecracker jailer (resource isolation wrapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '--id=[microVM unique id]:id:' \
  '--exec-file=[Firecracker binary to run]:file:_files' \
  '--node=[NUMA node]:n:' \
  '--uid=[UID inside chroot]:n:' \
  '--gid=[GID inside chroot]:n:' \
  '--chroot-base-dir=[chroot base dir]:dir:_files -/' \
  '--netns=[network namespace]:path:' \
  '--cgroup=[cgroup setting]:kv:' \
  '--cgroup-version=[cgroup version]:ver:(1 2)' \
  '--daemonize[detach (daemonize)]' \
  '--new-pid-ns[new PID namespace]' \
  '--resource-limit=[resource limit]:kv:' \
  '--parent-cgroup=[parent cgroup]:path:' \
  '*::jailer args:_files' && ret=0
return ret
