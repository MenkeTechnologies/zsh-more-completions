#compdef enumer
# Documentation: https://github.com/dmarkham/enumer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-type)'-type+'[Generate for named type]:type:' \
  '(-json)'-json'[Output JSON]' \
  '(-yaml)'-yaml'[Output YAML]' \
  '(-sql)'-sql'[Output SQL]' \
  '(-trimprefix)'-trimprefix+'[Trim prefix from strings]:prefix:' \
  '1:source file:_files -g "*.go(-.)"'
