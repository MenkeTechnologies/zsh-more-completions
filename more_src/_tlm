#
# WHAT IS doublestar AND WHY IS IT THE 68TH GO CLI LIBRARY?
#
# doublestar (https://github.com/bmatcuk/doublestar, 701+ stars) is
# **Bob Matcuk's "Implements support for double star (**) matches
# in golang's path.Match and filepath.Glob"** — the canonical Go
# library for EXTENDED GLOB PATTERN MATCHING beyond what the
# stdlib `path/filepath` package supports.  Where afero (R638)
# solves Go's filesystem-abstraction-for-tests problem,
# doublestar solves Go's missing `**` (zero-or-more path segments)
# glob support problem.
#
# doublestar's distinguishing characteristics:
#
#   1. ** RECURSIVE GLOB SUPPORT — doublestar's central feature
#      is adding `**` to Go's glob dialect, which stdlib does NOT
#      support:
#
#          import "github.com/bmatcuk/doublestar/v4"
#
#          // stdlib filepath.Match doesn't understand **:
#          // filepath.Match("**/*.go", "src/foo/bar/baz.go")
#          //   → false, nil  (because ** isn't a stdlib glob char)
#
#          // doublestar correctly matches:
#          doublestar.Match("**/*.go", "src/foo/bar/baz.go")
#              → true, nil
#          doublestar.Match("src/**/main.go", "src/cmd/server/main.go")
#              → true, nil
#          doublestar.Match("**/{tests,test}/**/*_test.go",
#              "pkg/foo/tests/integration/full_test.go")
#              → true, nil
#
#      The `**` zero-or-more-path-segments behavior is the same
#      as bash globstar (`shopt -s globstar`), Node's micromatch,
#      Python's pathlib.Path.glob, Rust's globset, etc.  Go's
#      stdlib is one of the few mainstream languages MISSING this
#      from its stdlib glob.
#      Compare:
#         * Rust globset/glob: ** built-in
#         * Rust ignore (Burntsushi): ** built-in
#         * Node micromatch: ** built-in (and the dialect basis)
#         * Node fast-glob (R639): ** built-in
#         * Python pathlib.Path.glob: ** built-in (Python 3.5+)
#         * Go path/filepath.Match: NO ** support
#         * Go afero (R638): Glob() but uses stdlib pattern syntax
#         * Go doublestar: ADDS ** to fill the stdlib gap
#      FIRST documented Go Axis 14 library specifically targeted
#      at the stdlib glob-dialect gap.
#
#   2. FULL BASH EXTGLOB DIALECT (v4+) — doublestar/v4 supports
#      the complete bash extended glob syntax beyond just `**`:
#
#          // Zero-or-one:
#          doublestar.Match("file.?(yml|yaml)", "file.yml")    → true
#          doublestar.Match("file.?(yml|yaml)", "file")        → true
#
#          // Zero-or-more:
#          doublestar.Match("file.*(test|spec).go", "file.test.go") → true
#          doublestar.Match("file.*(test|spec).go", "file.go")      → true
#
#          // One-or-more:
#          doublestar.Match("a+(bc).go", "abcbc.go")           → true
#          doublestar.Match("a+(bc).go", "a.go")               → false
#
#          // Exactly-one:
#          doublestar.Match("user.@(jpg|png|gif)", "user.png") → true
#          doublestar.Match("user.@(jpg|png|gif)", "user.bmp") → false
#
#          // Negation:
#          doublestar.Match("!(*_test).go", "main.go")          → true
#          doublestar.Match("!(*_test).go", "main_test.go")    → false
#
#          // Brace expansion:
#          doublestar.Match("{src,tests}/*.go", "src/main.go") → true
#          doublestar.Match("{src,tests}/*.go", "tests/foo.go") → true
#
#          // Character classes:
#          doublestar.Match("[abc]*.txt", "alpha.txt")          → true
#
#      Compare:
#         * Go stdlib filepath.Match: only *, ?, [abc]
#         * Go afero.Glob: uses stdlib pattern (limited)
#         * Node fast-glob (R639): full micromatch (similar)
#         * Rust globset: full bash glob (similar)
#         * doublestar: full BASH EXTGLOB (matches micromatch +
#                        Rust globset)
#      FIRST documented Go Axis 14 library with full bash
#      extglob dialect including ?()/+()/*()/@()/!().
#
#   3. FOUR API MODES — doublestar provides four entry points
#      for different use cases:
#
#          // 1. Pattern-only matching (no filesystem):
#          matched, err := doublestar.Match("**/*.go", "src/main.go")
#
#          // 2. Filesystem glob (returns matching paths):
#          fsys := os.DirFS(".")
#          matches, err := doublestar.Glob(fsys, "**/*.go")
#
#          // 3. Streaming glob with callback (memory-efficient):
#          err := doublestar.GlobWalk(fsys, "**/*.go",
#              func(path string, d fs.DirEntry) error {
#                  // Process each match as discovered
#                  fmt.Println(path)
#                  return nil
#              })
#
#          // 4. OS-specific path matching (handles \ on Windows):
#          matched, err := doublestar.PathMatch("**/*.go",
#              `src\foo\main.go`)
#
#      Compare:
#         * Go stdlib filepath.Match: pattern-only
#         * Go stdlib filepath.Glob: filesystem only
#         * Go afero.Glob: filesystem only with Fs abstraction
#         * Node fast-glob (R639): sync/async/streaming
#         * doublestar: 4 modes (Match, Glob, GlobWalk, PathMatch)
#      FIRST documented Go Axis 14 library with 4 distinct API
#      entry points covering pattern/filesystem/streaming/OS-
#      specific.
#
#   4. io/fs.FS COMPATIBLE (v4+) — doublestar/v4 uses Go 1.16's
#      io/fs.FS interface, composing naturally with afero (R638)
#      + embed.FS + testing/fstest.MapFS + S3-backed fs
#      implementations:
#
#          // Use doublestar with afero (R638):
#          import "github.com/spf13/afero"
#          import "github.com/bmatcuk/doublestar/v4"
#          import "io/fs"
#
#          memFs := afero.NewMemMapFs()
#          afero.WriteFile(memFs, "/src/main.go", []byte(""), 0644)
#
#          fsys := afero.NewIOFS(memFs)  // afero → io/fs.FS adapter
#          matches, _ := doublestar.Glob(fsys, "**/*.go")
#
#          // Use doublestar with embed.FS:
#          //go:embed templates/**/*.html
#          var templates embed.FS
#          htmlFiles, _ := doublestar.Glob(templates, "**/*.html")
#
#          // Use doublestar with testing/fstest.MapFS:
#          testFs := fstest.MapFS{
#              "src/foo.go": &fstest.MapFile{Data: []byte("...")},
#          }
#          matches, _ := doublestar.Glob(testFs, "**/*.go")
#
#      This io/fs.FS composability is unique in the Axis 14
#      taxonomy — doublestar slots into ANY io/fs.FS-implementing
#      filesystem.
#      Compare:
#         * Go stdlib filepath.Glob: only os filesystem
#         * Go afero: own Fs interface (not io/fs.FS)
#         * Rust walkdir: only std::path (no abstraction)
#         * Rust ignore: only std::path
#         * doublestar/v4: io/fs.FS compatible
#      FIRST documented Go Axis 14 library composable with
#      arbitrary io/fs.FS implementations.
#
#   5. BOB MATCUK PROVENANCE — doublestar is by Bob Matcuk
#      (bmatcuk on GitHub).  Maintained since 2014.  Downstream
#      users:
#         * mutagen-io/mutagen (4.2k stars file sync)
#         * snyk/driftctl (2.6k stars infra drift detection)
#         * camptocamp/terraboard (2k stars Terraform dashboard)
#         * ZupIT/horusec (1.3k stars security scanner)
#         * yusufcanb/tlm (THIS — 1.5k stars AI CLI copilot)
#         * Hashicorp/copywrite (R607 — already documented!)
#         * 1500+ Go applications
#      Hashicorp/copywrite (R607) is now confirmed to use libraries
#      across THREE documented axes: go-hclog (Axis 9 Logging),
#      koanf (Axis 13 Configuration), and doublestar (Axis 14
#      Paths) — making it the most cross-axis-composed tool in
#      the taxonomy.
#      FIRST documented Go Axis 14 library with this specific
#      Bob-Matcuk single-author maintenance provenance + cross-
#      axis-composition role in hashicorp/copywrite.
#
# doublestar's relationship to afero (R638) and other Axis 14
# libraries:
#
#   * Unlike afero (R638, Go) — afero is filesystem-abstraction
#                                 (Fs interface for testing/
#                                  scoping/overlay); doublestar
#                                 is pattern-matching (** + bash
#                                 extglob on paths)
#   * Closest cross-language analogs:
#         * Rust globset/glob — full glob library
#         * Rust ignore (Burntsushi) — gitignore + glob
#         * Node fast-glob (R639) — closest direct analog
#         * Node micromatch — the JS micromatch dialect inspiration
#         * Python pathlib.Path.glob — stdlib ** support
#     doublestar is the SECOND documented Go Axis 14 library
#     providing extended ** glob support + full bash extglob
#     dialect + 4 API modes + io/fs.FS composability + Bob
#     Matcuk maintenance.
#
# -----------------------------------------------------------------------------
#
# THE tlm CLI — urfave/cli/v2 + doublestar + Ollama + 4 subcommands
#
# tlm's CLI is in pkg/app/app.go.  Uses urfave/cli/v2 with
# subcommands per AI operation:
#
#     import (
#         ollama "github.com/jmorganca/ollama/api"
#         "github.com/urfave/cli/v2"
#         "github.com/yusufcanb/tlm/pkg/ask"
#         "github.com/yusufcanb/tlm/pkg/explain"
#         "github.com/yusufcanb/tlm/pkg/suggest"
#         "github.com/yusufcanb/tlm/pkg/config"
#     )
#
#     cliApp := &cli.App{
#         Name:    "tlm",
#         Usage:   "terminal copilot, powered by open-source models.",
#         Commands: []*cli.Command{
#             ask.Command(),
#             sug.Command(),       // suggest
#             exp.Command(),       // explain
#             con.Command(),       // config
#             { Name: "version", Aliases: []string{"v"}, ... },
#         },
#     }
#
# Subcommands (4 + version):
#   ask        Ask a question with optional file context
#   suggest    Suggest a shell command for a prompt (alias: s)
#   explain    Explain a shell command (alias: e)
#   config     Manage tlm configuration
#   version    Print tlm version
#
# `ask` subcommand flags (uses doublestar for --include/--exclude
# globs):
#   -c, --context PATH         Context directory path
#   -i, --include PATTERN      Include glob patterns (repeatable)
#                               e.g. --include="*.md" or
#                                    --include="**/*.go"
#   -e, --exclude PATTERN      Exclude glob patterns (repeatable)
#                               e.g. --exclude="**/*_test.go"
#   -it, --interactive          Enable interactive chat mode
#   -m, --model MODEL          Override LLM model
#
# `suggest` / `explain` subcommands:
#   -m, --model MODEL          Override LLM model
#   -s, --style stable|balanced|creative  Generation style
#
# doublestar is used in pkg/packer/ for matching --include +
# --exclude glob patterns against files in the --context
# directory, packing matched files into the LLM context window.
#
# Five-axis distinctness from afero (R638):
#
#   1. ** RECURSIVE GLOB — doublestar adds zero-or-more-path-
#      segments matching missing from Go stdlib filepath.Match.
#
#   2. FULL BASH EXTGLOB DIALECT — ?()/+()/*()/@()/!() in
#      addition to **.
#
#   3. 4 API MODES — Match (pattern-only) / Glob (filesystem) /
#      GlobWalk (streaming) / PathMatch (OS-specific paths).
#
#   4. io/fs.FS COMPATIBLE — composes with afero/embed.FS/
#      testing/fstest.MapFS/etc.
#
#   5. BOB MATCUK PROVENANCE + CROSS-AXIS COMPOSITION in
#      hashicorp/copywrite (R607).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/yusufcanb/tlm/blob/main/pkg/app/app.go
# https://github.com/yusufcanb/tlm/blob/main/pkg/ask/cli.go
# https://github.com/yusufcanb/tlm/blob/main/pkg/suggest/cli.go
# https://github.com/yusufcanb/tlm/blob/main/pkg/explain/cli.go
# urfave/cli/v2 Command + Flag definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tlm_cmds _tlm_styles
_tlm_cmds=(
    'ask:ask a question with optional file context (alias: a)'
    'a:ask alias'
    'suggest:suggest a shell command (alias: s)'
    's:suggest alias'
    'explain:explain a shell command (alias: e)'
    'e:explain alias'
    'config:manage tlm configuration'
    'version:print tlm version (alias: v)'
    'v:version alias'
    'help:show help for a subcommand'
)
_tlm_styles=(
    'stable:deterministic generation (temperature 0)'
    'balanced:balanced creativity (default)'
    'creative:high-temperature varied output'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'tlm subcommand' _tlm_cmds && ret=0
        ;;
    args)
        case $words[1] in
            ask|a)
                _arguments \
                    '(-c --context)'{-c+,--context=}'[context directory path]:dir:_directories' \
                    '*'{-i+,--include=}'[include glob pattern (e.g. **/*.go)]:pattern:_default' \
                    '*'{-e+,--exclude=}'[exclude glob pattern]:pattern:_default' \
                    '(-it --interactive)'{-it,--interactive}'[enable interactive chat mode]' \
                    '(-m --model)'{-m+,--model=}'[override LLM model (e.g. llama3.2:1b)]:model:_default' \
                    '1:prompt:_default' \
                    && ret=0
                ;;
            suggest|s)
                _arguments \
                    '(-m --model)'{-m+,--model=}'[override LLM model]:model:_default' \
                    '(-s --style)'{-s+,--style=}'[generation style]:style:(stable balanced creative)' \
                    '1:prompt:_default' \
                    && ret=0
                ;;
            explain|e)
                _arguments \
                    '(-m --model)'{-m+,--model=}'[override LLM model]:model:_default' \
                    '(-s --style)'{-s+,--style=}'[generation style]:style:(stable balanced creative)' \
                    '1:shell command:_default' \
                    && ret=0
                ;;
            config)
                _arguments \
                    '(- *)'{-h,--help}'[show config help]' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _tlm_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
