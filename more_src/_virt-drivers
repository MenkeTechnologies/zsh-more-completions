#compdef virt-drivers
# Documentation: https://libguestfs.org/virt-drivers.1.html
# detect bootloader, kernel and drivers inside a disk image or guest

local ret=1

_arguments -s -S \
  '--help[display help information]' \
  '(-V --version)'{-V,--version}'[display version and exit]' \
  '*'{-a,--add}'[add disk image from a virtual machine]:file:_files' \
  '--blocksize=[set sector size for disks added with -a]:size:(512 4096)' \
  '(-c --connect)'{-c,--connect}'[specify libvirt connection URI]:uri' \
  '(-d --domain)'{-d,--domain}'[add all disks from the named libvirt guest]:guest' \
  '--format=[disk image format]:format:(raw qcow2 auto)' \
  '*--key=[specify key for encrypted devices]:selector' \
  '--colors[use ANSI colour sequences for output]' \
  '--colours[use ANSI colour sequences for output]' \
  '--echo-keys[display key input while typing]' \
  '--keys-from-stdin[read keys from standard input]' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '(-v --verbose)'{-v,--verbose}'[enable debugging output]' \
  '--wrap[wrap error and warning messages]' \
  '-x[enable libguestfs API call tracing]' && ret=0

return ret
