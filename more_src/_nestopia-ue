#compdef nestopia-ue nestopia
# Documentation: https://github.com/0ldsk00l/nestopia/blob/master/source/fltkui/fltkui.cpp
# Reference accessed: 2026-05-16
# Verified: source/fltkui/fltkui.cpp main() lines 798-905 flag parsing.
# Removed from prior file: -h (no short form, only --help), -w/--window
# (not in source), -x (no scale flag), -r/--region (region is config-only,
# not CLI), -y (no patches flag), -c (no config flag - config read from
# settings dir).

# Nestopia UE: NES emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help / version banner]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen with loaded ROM]' \
  '(-m --mute)'{-m,--mute}'[start muted]' \
  '*:ROM file:_files -g "*.(nes|fds|unif|unf|nsf)"' && ret=0
return ret
