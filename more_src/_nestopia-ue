#compdef nestopia-ue
# Documentation: https://github.com/0ldsk00l/nestopia/blob/master/source/fltkui/fltkui.cpp
# Reference accessed: 2026-05-19
# Verified: source/fltkui/fltkui.cpp argv parsing in main().

# Nestopia UE: NES emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help / version banner]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen with loaded ROM]' \
  '(-m --mute)'{-m,--mute}'[start muted]' \
  '*:ROM file:_files -g "*.(nes|fds|unif|unf|nsf)"' && ret=0
return ret
