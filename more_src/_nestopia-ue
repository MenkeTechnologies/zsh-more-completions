#compdef nestopia-ue nestopia
# Documentation: https://github.com/0ldsk00l/nestopia/wiki
# Reference accessed: 2026-05-16

# Nestopia UE: NES emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-f[fullscreen]' \
  '--fullscreen[fullscreen]' \
  '-w[windowed]' \
  '--window[windowed]' \
  '-x[scale]:n:' \
  '-r[region]:region:(ntsc pal ntsc-j)' \
  '--region=[region]:region:(ntsc pal ntsc-j)' \
  '-y[apply patches]:file:_files' \
  '-c[load config]:file:_files' \
  '*:ROM file:_files -g "*.(nes|fds|unif|nsf)"' && ret=0
return ret
