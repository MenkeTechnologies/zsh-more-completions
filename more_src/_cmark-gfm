#compdef cmark-gfm

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--to=[output format]:format:(html xml commonmark plaintext latex man)' \
  '-t+[output format]:format:(html xml commonmark plaintext latex man)' \
  '--width=[specify wrap width]:width' \
  '--sourcepos[include source position attributes]' \
  '--hardbreaks[treat newlines as hard line breaks]' \
  '--nobreaks[render soft line breaks as spaces]' \
  '--unsafe[allow raw HTML and unsafe URLs]' \
  '--smart[use smart punctuation]' \
  '--validate-utf8[replace invalid UTF-8 sequences]' \
  '--liberal-html-tag[allow HTML tags in first column]' \
  '-e+[activate extension]:extension:(table strikethrough autolink tagfilter tasklist)' \
  '--extension=[activate extension]:extension:(table strikethrough autolink tagfilter tasklist)' \
  '--list-extensions[list available extensions]' \
  '*:file:_files' && ret=0

return ret
