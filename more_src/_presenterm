#compdef presenterm
# Zsh completion for presenterm
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-p --present)'{-p,--present}'[present mode]' \
  '--export-pdf[export presentation to PDF]' \
  '(-t --theme)'{-t,--theme}'[theme name]:theme:' \
  '--force-default-theme[force the default theme]' \
  '--publish[publish the presentation]' \
  '--acknowledgements[show acknowledgements]' \
  '--validate[validate the presentation]' \
  '--config-file[configuration file]:file:_files' \
  '--enable-snippet-execution[enable snippet execution]' \
  '--enable-snippet-execution-replace[enable snippet execution with replacement]' \
  '--image-protocol[image rendering protocol]:protocol:(auto kitty iterm sixel)' \
  '--generate-config[generate default configuration file]' \
  '--generate-acknowledgements[generate acknowledgements file]' \
  '--list-themes[list available themes]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:markdown file:_files -g "*.md"' && ret=0
return ret
