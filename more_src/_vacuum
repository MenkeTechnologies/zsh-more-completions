#compdef vacuum

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'lint:lint OpenAPI spec'
  'report:generate vacuum snapshot report'
  'dashboard:interactive console UI'
  'html-report:generate HTML report'
  'spectral-report:Spectral-compatible JSON output'
  'references:inspect external references'
  'version:show CLI version'
  'bundle:consolidate exploded spec'
  'generate-ruleset:create custom rule config'
  'language-server:run LSP'
  'apply-overlay:apply OpenAPI overlay'
  'open-collection:work with OpenAPI collections'
  'change-detection:detect spec changes'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '--time[show execution timing]' \
  '--base=[base URL]:url:' \
  '(-r --ruleset)'{-r,--ruleset=}'[ruleset file]:file:_files -g "*.(yaml|yml|json)"' \
  '--original=[original spec]:file:_files' \
  '--changes-summary[changed items only]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'vacuum subcommand' subcommands
    _files -g '*.(yaml|yml|json)' && ret=0
    ;;
  (args)
    case $line[1] in
      (lint|report)
        _arguments \
          '-d[detailed output]' \
          '-s[show snippets]' \
          '-e[errors only]' \
          '-c=[filter by category]:cat:' \
          '--ignore-file=[ignore errors file]:file:_files' \
          '--fix[auto-fix in place]' \
          '--fix-file=[fix output file]:file:_files' \
          '-T[turbo mode]' \
          '*:spec:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
      (dashboard)
        _arguments \
          '(-w --watch)'{-w,--watch}'[watch mode]' \
          ':spec:_files -g "*.(yaml|yml|json)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
