#compdef sealer
# Documentation: https://github.com/sealerio/sealer
# sealer - build, share and run a whole Kubernetes cluster as a ClusterImage

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(( \
    run\:"run a Kubernetes cluster or application ClusterImage" \
    apply\:"apply a Kubernetes cluster from a Clusterfile" \
    build\:"build a ClusterImage from a Kubefile" \
    push\:"push a ClusterImage to a registry" \
    pull\:"pull a ClusterImage from a registry" \
    tag\:"create a new tag for an existing ClusterImage" \
    save\:"save ClusterImages to a tar archive" \
    load\:"load ClusterImages from a tar archive" \
    images\:"list local ClusterImages" \
    rmi\:"remove one or more local ClusterImages" \
    login\:"log in to a container registry" \
    delete\:"delete an existing cluster" \
    exec\:"execute a command on cluster nodes" \
    cp\:"copy files between local host and cluster nodes" \
    version\:"print sealer version" \
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run|apply)
        _arguments -s \
          '--masters=[master node IP addresses]:masters' \
          '--nodes=[worker node IP addresses]:nodes' \
          '--passwd=[SSH password for the nodes]:password' \
          '(-f --kubefile)'{-f,--kubefile}'=[path to the Clusterfile]:file:_files' && ret=0
        ;;
      build)
        _arguments -s \
          '-f=[path to the Kubefile]:file:_files' \
          '-t=[name and optionally a tag for the image]:tag' \
          '--type=[image type to build]:type:(kube-installer app-installer)' && ret=0
        ;;
      delete)
        _arguments -s \
          '-a=[delete the whole cluster]' && ret=0
        ;;
    esac
    ;;
esac

return ret
