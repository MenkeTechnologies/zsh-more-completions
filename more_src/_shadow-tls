#compdef shadow-tls
# Documentation: https://github.com/ihciah/shadow-tls/wiki/How-to-Run
# shadow-tls - proxy to expose real service over TLS 1.3 handshaking with a real server

local ret=1
local context curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --threads)'{-t,--threads}'=[set thread count manually]:threads' \
  '(-d --disable-nodelay)'{-d,--disable-nodelay}'[disable TCP_NODELAY]' \
  '--v3[enable V3 protocol (must match on both sides)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _values 'shadow-tls command' \
      'client[run in client mode]' \
      'server[run in server mode]' && ret=0
    ;;
  args)
    case $line[1] in
      client)
        _arguments -s -S \
          '--listen=[listen address with port]:addr' \
          '--server=[ShadowTLS server address with port]:addr' \
          '--sni=[TLS SNI names, semicolon separated]:sni' \
          '--password=[password, must match server]:password' \
          '--alpn=[ALPN ext, semicolon separated]:alpn' && ret=0
        ;;
      server)
        _arguments -s -S \
          '--listen=[listen address with port]:addr' \
          '--server=[data server address with port]:addr' \
          '--tls=[TLS handshake target ServerName:Host:Port, semicolon separated]:tls' \
          '--password=[password, must match client]:password' \
          '--wildcard-sni=[wildcard SNI mode (off/authed/all)]:mode:(off authed all)' && ret=0
        ;;
    esac
    ;;
esac

return ret
