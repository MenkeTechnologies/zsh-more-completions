#compdef font-manager
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/font-manager.1.html
# Simple font management for GTK+ desktop environments

local ret=1

_arguments -s -S \
  '(-a --about)'{-a,--about}'[about the application]' \
  '(-v --version)'{-v,--version}'[show application version]' \
  '--list[list available font families]' \
  '--list-full[full listing including face information (JSON)]' \
  '(-e --enable)'{-e,--enable}'[enable specified font family]:family:' \
  '(-d --disable)'{-d,--disable}'[disable specified font family]:family:' \
  '(-i --install)'{-i,--install}'[space separated list of files to install]:files:_files' && ret=0

return ret
