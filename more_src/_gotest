#compdef gotest
# Documentation: https://github.com/rakyll/gotest
# Reference accessed: 2026-06-04

# Zsh completion for gotest (colorized go test runner)
# gotest is a drop-in replacement for go test; all go test flags apply.
local -a arguments

arguments=(
  '-v[verbose output]'
  '-run=[run only tests matching regexp]:pattern:'
  '-bench=[run only benchmarks matching regexp]:pattern:'
  '-benchmem[print memory allocation statistics for benchmarks]'
  '-benchtime=[run enough iterations of each benchmark to take the given duration]:duration:'
  '-count=[run each test and benchmark n times]:n:'
  '-cover[enable coverage analysis]'
  '-covermode=[set the mode for coverage analysis]:mode:(set count atomic)'
  '-coverprofile=[write a coverage profile to file]:file:_files'
  '-cpuprofile=[write a CPU profile to file]:file:_files'
  '-memprofile=[write a memory profile to file]:file:_files'
  '-blockprofile=[write a goroutine blocking profile to file]:file:_files'
  '-mutexprofile=[write a mutex contention profile to file]:file:_files'
  '-outputdir=[place output files in the specified directory]:directory:_directories'
  '-parallel=[allow parallel execution of test functions]:n:'
  '-short[tell long-running tests to shorten their run time]'
  '-timeout=[timeout for each test binary]:duration:'
  '-failfast[do not start new tests after the first failure]'
  '-json[log verbose output in JSON format]'
  '-list=[list tests, benchmarks, fuzz tests, or examples matching regexp]:pattern:'
  '-race[enable data race detection]'
  '-shuffle=[randomize the execution order of tests and benchmarks]:mode:(on off)'
  '-vet=[configure vet analysis during go test]:list:'
  '-tags=[set build tags]:tags:'
  '-ldflags=[set linker flags]:flags:'
  '-gcflags=[set compiler flags]:flags:'
  '-mod=[module download mode]:mode:(mod vendor readonly)'
  '-modfile=[read an alternate go.mod file]:file:_files -g "*.mod"'
  '*:package:_files -/'
)

_arguments -s -S $arguments
