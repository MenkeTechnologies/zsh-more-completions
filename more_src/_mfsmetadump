#compdef mfsmetadump
# Documentation: https://manpages.debian.org/bookworm/moosefs-master/mfsmetadump.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsmetadump: dump master metadata to ASCII
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[replace non-printable characters with .]' \
  '*-s[dump only specified section]:section:(HEAD SESS LABS SCLA NODE EDGE FREE QUOT XATR PACL OPEN FLCK PLCK CSDB CHNK)' \
  '*:metadata file:_files' && ret=0
return ret
