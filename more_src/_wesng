#compdef wes
# _wesng — Windows Exploit Suggester next-gen (Arris Huijgen, Python); cross-reference systeminfo output with CVE database for authorized assessments
# upstream: https://github.com/bitsadmin/wesng

_wesng() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-u --update)'{-u,--update}'[update CVE info]' \
        '--update-wes[update wes itself]' \
        '(-p --patches)'{-p,--patches}'+[patches file]:file:_files' \
        '(-d --definitions)'{-d,--definitions}'+[definitions file]:file:_files' \
        '(-c --color)'{-c,--color}'[colorize output]' \
        '(-i --impact)'{-i,--impact}'+[impact]:impact:(Information Disclosure Privilege Escalation Remote Code Execution Tampering Spoofing Security Feature Bypass Denial of Service)' \
        '(-s --severity)'{-s,--severity}'+[severity]:level:(Critical Important Medium Low)' \
        '(-e --exploits-only)'{-e,--exploits-only}'[only show CVEs with exploits]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-m --missing)'{-m,--missing}'+[missing KB numbers]:str:' \
        '--only-kb+[only specific KB IDs]:kb:' \
        '--hide+[hide CVE IDs]:cves:' \
        '--exploits[show exploits column]' \
        '*:systeminfo:_files'
}

_wesng "$@"
