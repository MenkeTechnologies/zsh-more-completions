#compdef papis

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a document to the library'
  'addto:add files to an existing document'
  'browse:browse a document online'
  'cache:manage the cache'
  'citations:manage citations'
  'config:print configuration values'
  'doctor:check library for problems'
  'edit:edit document information'
  'explore:explore documents from online sources'
  'export:export documents'
  'git:run git commands in the library'
  'init:initialize a papis library'
  'list:list documents in the library'
  'merge:merge two documents'
  'mv:move a document to another library'
  'open:open document files'
  'rename:rename a document folder'
  'rm:remove a document'
  'run:run a command in the document folder'
  'serve:start the web interface'
  'tag:tag documents'
  'update:update document information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[increase verbosity]' \
  '-l[specify library]:library:' \
  '-s[set a configuration option]:key=value:' \
  '--log[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--color[colorize output]:when:(always auto never)' \
  '--cc[clear cache before running]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'papis command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (add)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--from[source to fetch from]:source:(doi pmid isbn arxiv url bibtex yaml)' \
          '-s[set a field value]:key value:' \
          '--folder-name[set folder name]:name:' \
          '--confirm[confirm before adding]' \
          '--no-confirm[do not confirm before adding]' \
          '--open[open files after adding]' \
          '--edit[edit info file after adding]' \
          '--no-document[add entry without document file]' \
          '--batch[batch mode]' \
          '*:file:_files' && ret=0
        ;;
      (open)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--tool[tool to open with]:tool:_command_names' \
          '--dir[open the document directory]' \
          '--all[open all matching documents]' \
          '*:query:' && ret=0
        ;;
      (edit)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--editor[editor to use]:editor:_command_names' \
          '--notes[edit notes file]' \
          '--all[edit all matching documents]' \
          '*:query:' && ret=0
        ;;
      (export)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format[export format]:format:(bibtex json yaml)' \
          '-o[output file]:file:_files' \
          '--all[export all matching documents]' \
          '*:query:' && ret=0
        ;;
      (rm)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[do not confirm removal]' \
          '--all[remove all matching documents]' \
          '*:query:' && ret=0
        ;;
      (list)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format[output format template]:template:' \
          '-p[show file paths]' \
          '-d[show directory paths]' \
          '--all[list all documents]' \
          '*:query:' && ret=0
        ;;
      (browse)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--all[browse all matching documents]' \
          '*:query:' && ret=0
        ;;
      (update)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-s[set a field value]:key value:' \
          '--from[update from source]:source:(doi pmid isbn arxiv url bibtex yaml)' \
          '--all[update all matching documents]' \
          '*:query:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
