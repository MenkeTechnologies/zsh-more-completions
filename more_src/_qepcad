#compdef qepcad
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/qepcad.1.html
# QEPCAD: quantifier elimination by partial cylindrical algebraic decomposition

local ret=1

_arguments -s -S \
  '-h[help information]' \
  '-v[print version string]' \
  '-noecho[turn off echoing of input]' \
  '-t[set a timeout in seconds]:seconds' \
  '+N-[set garbage collected space to given number of cells]:numcells' \
  '+h[print Saclib help message]' && ret=0

return ret
