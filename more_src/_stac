#compdef stac
# Documentation: https://stactools.readthedocs.io/en/stable/cli.html
# stactools CLI for working with SpatioTemporal Asset Catalogs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output]' \
  '1:command:(add add-asset add-raster copy create-item describe info layout lint merge migrate move-assets summary update-extent update-geometry validate version browse)' \
  '*::arg:_files' && ret=0

return ret
