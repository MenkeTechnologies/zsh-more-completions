#compdef gnome-mplayer
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/gnome-mplayer.1.html
# gnome-mplayer - a simple GUI for MPlayer

local ret=1

_arguments -s -S \
  '(-? --help)'{-?,--help}'[display summary of options]' \
  '--help-all[show all help options]' \
  '--help-gtk[display GTK+ options]' \
  '--window=[embed player in specified window]:WID' \
  '(-w --width)'{-w,--width=}'[set embedded window width]:X' \
  '(-h --height)'{-h,--height=}'[set embedded window height]:Y' \
  '--controlid=[unique DBUS controller identifier]:CID' \
  '--playlist[treat file argument as playlist]' \
  '(-v --verbose)'{-v,--verbose}'[increase console output]' \
  '--reallyverbose[further increase console verbosity]' \
  '--fullscreen[launch in fullscreen mode]' \
  '--softvol[enable software volume control]' \
  '--mixer=[specify mixer device]:mixer' \
  '--volume=[set initial volume percentage]:volume' \
  '--showcontrols=[toggle control visibility]:state:(0 1)' \
  '--showsubtitles=[toggle subtitle display]:state:(0 1)' \
  '--autostart=[auto-play media on load]:state:(0 1)' \
  '--disablecontextmenu[remove right-click menu]' \
  '--disablefullscreen[disable fullscreen in browser]' \
  '--loop[repeat playlist continuously]' \
  '(-q --quit_on_complete)'{-q,--quit_on_complete}'[exit after final track]' \
  '--random[randomize playlist order]' \
  '--cache=[configure cache size]:cache' \
  '--forcecache[enable cache for streams]' \
  '--disabledeinterlace[turn off deinterlacing]' \
  '--disableframedrop[prevent frame skipping]' \
  '--disableass[use legacy subtitle rendering]' \
  '--disableembeddedfonts[ignore matroska fonts]' \
  '--vertical[activate vertical layout]' \
  '--showplaylist[open playlist initially]' \
  '--showdetails[display details on startup]' \
  '--subtitle=[load subtitle file]:file:_files' \
  '--tvdevice=[TV device path]:device:_files' \
  '--tvdriver=[TV driver]:driver:(v4l v4l2)' \
  '--single_instance[allow only one instance]' \
  '--replace_and_play[replace mode for single instance]' \
  '--large_buttons[display larger interface icons]' \
  '--new_instance[bypass single-instance setting]' \
  '--keep_on_top[window stays above others]' \
  '--disable_cover_art_fetch[skip cover art retrieval]' \
  '--display=[X display to use]:display' \
  '*:file:_files' && ret=0

return ret
