#compdef pset
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/pset.txt
# Set one or more parameters in an IRAF-style parameter file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:parameter file:_files -g "*.par"' \
  '*:parameter assignment (parameter=value):' && ret=0

return ret
