#compdef fapropos
# Searches FTOOLS help files for a given word

local ret=1

_arguments -s \
  "-b[search whole word boundaries]" \
  "-e[exact match]" \
  "-h[show help]" \
  "-l[long listing]" \
  "-p[print matching lines]" \
  "-s[case sensitive search]" \
  "-w[match whole words]" \
  "*:word:" && ret=0

return ret
