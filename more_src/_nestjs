#compdef nest

# Zsh completion for NestJS CLI

_nestjs() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'new:generate Nest application'
    'generate:generate a Nest element'
    'build:build Nest application'
    'start:run Nest application'
    'info:display Nest project details'
    'add:import a library that has been packaged as a Nest library'
    'update:update Nest dependencies'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'nest command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new|n)
          _arguments -s -S \
            '--directory=[specify the destination directory]:directory:' \
            '(-d --dry-run)'{-d,--dry-run}'[report actions that would be taken without writing results]' \
            '(-g --skip-git)'{-g,--skip-git}'[skip git repository initialization]' \
            '(-s --skip-install)'{-s,--skip-install}'[skip package install]' \
            '(-p --package-manager)'{-p,--package-manager}'[specify package manager]:manager:(npm yarn pnpm)' \
            '(-l --language)'{-l,--language}'[programming language]:language:(TS JS TypeScript JavaScript)' \
            '(-c --collection)'{-c,--collection}'[schematics collection]:collection:' \
            '--strict[enable strict mode in TypeScript]' \
            '1:name:' \
            && ret=0
          ;;
        generate|g)
          local -a schematics=(
            'application:generate a new application workspace'
            'class:generate a new class'
            'configuration:generate a CLI configuration file'
            'controller:generate a controller declaration'
            'decorator:generate a custom decorator'
            'filter:generate a filter declaration'
            'gateway:generate a gateway declaration'
            'guard:generate a guard declaration'
            'interceptor:generate an interceptor declaration'
            'interface:generate an interface'
            'library:generate a new library within a monorepo'
            'middleware:generate a middleware declaration'
            'module:generate a module declaration'
            'pipe:generate a pipe declaration'
            'provider:generate a provider declaration'
            'resolver:generate a GraphQL resolver declaration'
            'resource:generate a new CRUD resource'
            'service:generate a service declaration'
            'sub-app:generate a new application within a monorepo'
          )
          _arguments -s -S \
            '1:schematic:->schematic' \
            '2:name:' \
            '(-d --dry-run)'{-d,--dry-run}'[report actions without writing]' \
            '(-p --project)'{-p,--project}'[project that element should be added to]:project:' \
            '--flat[enforce flat structure]' \
            '--no-flat[enforce a directory is created]' \
            '--spec[enforce spec files generation]' \
            '--no-spec[disable spec files generation]' \
            '(-c --collection)'{-c,--collection}'[schematics collection]:collection:' \
            && ret=0

          case $state in
            (schematic)
              _describe -t schematics 'schematic' schematics && ret=0
              ;;
          esac
          ;;
        build)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'[path to nest-cli configuration file]:config file:_files -g "nest-cli.json"' \
            '(-p --path)'{-p,--path}'[path to tsconfig file]:tsconfig file:_files -g "tsconfig*.json"' \
            '-w[watch mode]' \
            '--watch[watch mode]' \
            '--watchAssets[watch non-TS files mode]' \
            '--webpack[use webpack for compilation]' \
            '--webpackPath=[path to webpack configuration]:webpack config:_files' \
            '--tsc[use tsc for compilation]' \
            '--preserveWatchOutput[keep outdated console output in watch mode]' \
            && ret=0
          ;;
        start)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'[path to nest-cli configuration file]:config file:_files' \
            '(-p --path)'{-p,--path}'[path to tsconfig file]:tsconfig file:_files -g "tsconfig*.json"' \
            '-w[watch mode]' \
            '--watch[watch mode]' \
            '--watchAssets[watch non-TS files mode]' \
            '-d[debug mode]' \
            '--debug=[debug mode]:host\:port:' \
            '--webpack[use webpack for compilation]' \
            '--webpackPath=[path to webpack configuration]:webpack config:_files' \
            '--tsc[use tsc for compilation]' \
            '--exec=[binary to run]:binary:_command_names' \
            '--preserveWatchOutput[keep outdated console output in watch mode]' \
            '--entryFile=[entry file]:file:_files -g "*.{ts,js}"' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '(-d --dry-run)'{-d,--dry-run}'[report actions without writing]' \
            '(-s --skip-install)'{-s,--skip-install}'[skip package install]' \
            '(-p --project)'{-p,--project}'[project]:project:' \
            '1:library:' \
            && ret=0
          ;;
        update|u)
          _arguments -s -S \
            '(-f --force)'{-f,--force}'[force update]' \
            '(-t --tag)'{-t,--tag}'[dist-tag]:tag:' \
            '-s[skip install]' \
            '--skip-install[skip install]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_nestjs "$@"
