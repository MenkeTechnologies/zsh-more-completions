#compdef clipcatctl

# Zsh completion for clipcatctl (clipcat clipboard manager control)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'clear:clear the clipboard'
  'default-config:print default config'
  'get:get a clipboard entry'
  'insert:insert text into the clipboard'
  'length:show the number of entries'
  'list:list clipboard entries'
  'load:load clipboard entries from file'
  'promote:promote an entry to the top'
  'remove:remove a clipboard entry'
  'save:save clipboard entries to file'
  'update:mark an entry as the current'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--config[config file]:file:_files' \
  '--grpc-host[gRPC host]:host:_hosts' \
  '--grpc-port[gRPC port]:port:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'clipcatctl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (insert)
        _arguments '1:text:' && ret=0
        ;;
      (get|remove|promote|update)
        _arguments '1:id:' && ret=0
        ;;
      (list)
        _arguments '--no-id[do not show IDs]' && ret=0
        ;;
      (save|load)
        _arguments '1:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
