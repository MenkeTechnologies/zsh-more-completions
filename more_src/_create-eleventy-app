#compdef create-eleventy-app
# Documentation: https://github.com/uncenter/create-eleventy-app#readme
# Reference accessed: 2026-05-24
# Verified: npm view create-eleventy-app bin; GitHub README Options at the URL above.

# Zsh completion for create-eleventy-app - Eleventy static site scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-s --silent)'{-s,--silent}'[silence CLI output]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose CLI output]' \
  '(-i --install)'{-i,--install=}'[package manager for dependencies]:manager:(npm yarn pnpm bun)' \
  '(-e --set)'{-e,--set=}'[Eleventy version to install]:version:' \
  ':project directory:_directories' && ret=0

return ret
