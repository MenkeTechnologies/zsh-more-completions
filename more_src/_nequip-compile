#compdef nequip-compile
# Documentation: https://nequip.readthedocs.io/en/latest/guide/getting-started/workflow.html
# NequIP: compile a model for deployment (TorchScript / AOTInductor)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--device=[target device]:device:(cpu cuda)' \
  '--mode=[compilation mode]:mode:(torchscript aotinductor)' \
  '--target=[integration target]:target:(ase pair_nequip pair_allegro)' \
  '--input-fields=[manual input field specification]:fields' \
  '--output-fields=[manual output field specification]:fields' \
  '*:arg:_files' && ret=0

return ret
