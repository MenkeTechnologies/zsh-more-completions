#compdef dhall-to-yaml
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-yaml
# Source: dhall-lang/dhall-haskell dhall-yaml/dhall-to-yaml/Main.hs — compile Dhall to YAML.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--explain[explain error messages in detail]' \
    '--documents[output a YAML document per Dhall list element, separated by ---]' \
    '--quoted[prevent generating unquoted scalars]' \
    '--generated-comment[prepend a comment identifying the YAML as generated]' \
    '--preserve-header[preserve any header from the input Dhall file]' \
    '--file=[read Dhall expression from FILE instead of stdin]:file:_files' \
    '--output=[write YAML to FILE instead of stdout]:file:_files' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
