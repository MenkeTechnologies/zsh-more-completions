#compdef xmaxima
# Documentation: https://man.archlinux.org/search?q=xmaxima
# Reference accessed: 2026-05-16

# xmaxima: Tcl/Tk frontend for Maxima
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--browser[start as documentation browser]' \
  '--maxima=[maxima binary]:file:_files' \
  '--display=[X display]:display:' \
  '*:script:_files -g "*.mac"' && ret=0
return ret
