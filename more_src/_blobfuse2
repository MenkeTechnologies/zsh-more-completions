#compdef blobfuse2

# Zsh completion for blobfuse2 (Azure Blob Storage FUSE driver)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'mount:mount a container'
      'mountv1:mount using v1 configuration'
      'unmount:unmount a container'
      'secure:manage encrypted configuration'
      'completion:generate shell completions'
      'health-monitor:monitor blobfuse2 health'
      'gen-test-config:generate test configuration'
      'version:display version'
    )
    _describe -t commands 'blobfuse2 command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (mount)
        _arguments \
          '--config-file[config file]:file:_files -g "*.{yaml,yml}"' \
          '--container-name[container name]:name' \
          '--tmp-path[temp cache path]:path:_files -/' \
          '--passphrase[config passphrase]:passphrase' \
          '--allow-other[allow other users]' \
          '--read-only[mount read-only]' \
          '--disable-writeback-cache[disable writeback cache]' \
          '--foreground[run in foreground]' \
          '--log-level[log level]:level:(LOG_OFF LOG_CRIT LOG_ERR LOG_WARNING LOG_INFO LOG_DEBUG LOG_TRACE)' \
          '--log-file-path[log file]:file:_files' \
          '--log-type[log type]:type:(base syslog silent)' \
          '-o[FUSE mount options]:options' \
          '--attr-cache-timeout[attribute cache timeout]:seconds' \
          '--entry-cache-timeout[entry cache timeout]:seconds' \
          '--negative-cache-timeout[negative entry timeout]:seconds' \
          '1:mount point:_files -/' && ret=0
        ;;
      (unmount)
        _arguments \
          '-a[unmount all]' \
          '-l[lazy unmount]' \
          '1:mount point:_files -/' && ret=0
        ;;
      (secure)
        _arguments '1:subcommand:(encrypt decrypt get set)' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
