#compdef btfs
# Documentation: https://github.com/johang/btfs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# torrent FUSE mount (johang/btfs)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--browse-only[disable uploading]' \
  '--keep[keep files after unmount]' \
  '--utp-only[use only uTP]' \
  '--data-directory=[data directory]:dir:_files -/' \
  '--min-port=[lowest listen port]:port:' \
  '--max-port=[highest listen port]:port:' \
  '--max-download-rate=[max download rate KB/s]:kb/s:' \
  '--max-upload-rate=[max upload rate KB/s]:kb/s:' \
  '*:torrent or magnet:_files -g "*.torrent"'
