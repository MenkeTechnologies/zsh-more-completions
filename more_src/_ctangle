#compdef ctangle
# Documentation: ctangle --help (TeX Live 2026 CWEB)
# Source: CWEB system — tangle WEBFILE.w into a C/C++ program.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[display help]' \
    '(- *)--version[output version information]' \
    '+b[print banner line on terminal]' \
    '+h[print success message on completion]' \
    '+p[print progress report messages]' \
    '(+q -q --quiet +v -v --verbose)'{+q,-q,--quiet}'[shortcut for -bhp (quiet)]' \
    '(+q -q --quiet +v -v --verbose)'{+v,-v,--verbose}'[shortcut for +bhp (verbose; default)]' \
    '+c[check temporary output for changes]' \
    '-d-[set kpathsea_debug to N (0..127)]:n:' \
    '+k[keep separators in numeric literals in the output]' \
    '+s[print usage statistics]' \
    '+u[transliterate UTF-8 characters in C code]' \
    '1:cweb source:_files -g "*.w"' \
    '2:change file:_files -g "*.ch"' \
    '3:c output:_files -g "*.c"' \
    && ret=0

return ret
