#compdef sc2sim
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss58.html
# SMURF: simulate the data taken by a SCUBA-2 subarray observing an image plus atmosphere.

local ret=1

_arguments -s -S \
  'OBSPAR=[observation parameters group]:par:_files' \
  'SIMPAR=[simulation parameters group]:par:_files' \
  'SIMTYPE=[simulation type]:type:(FULL WEIGHTS)' \
  'SIMSTATS=[report properties without executing]:flag:(TRUE FALSE)' \
  'BADBOL=[ARD file for bad bolometer mask]:file:_files' \
  'MAXWRITE=[samples to write per output file]:n:' \
  'OVERWRITE=[overwrite existing files]:flag:(TRUE FALSE)' \
  'SEED=[random number generator seed]:seed:' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:file:_files' && ret=0

return ret
