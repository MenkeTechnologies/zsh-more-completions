#compdef nix-hash

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--flat[compute hash of flat file]' \
  '--base32[print hash in base32]' \
  '--base16[print hash in base16]' \
  '--sri[print hash in SRI format]' \
  '--type=[hash type]:type:(md5 sha1 sha256 sha512)' \
  '--truncate[truncate hash]' \
  '--to-base16[convert to base16]:hash' \
  '--to-base32[convert to base32]:hash' \
  '--to-sri[convert to SRI]:hash' \
  '*:file or path:_files' && ret=0

return ret
