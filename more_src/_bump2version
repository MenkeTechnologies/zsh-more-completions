#compdef bump2version

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file[config file to read]:file:_files' \
  '--current-version[version that is currently set]:version' \
  '--new-version[new version that should be set]:version' \
  '--parse[regex parsing the version string]:regex' \
  '--serialize[how to format the version string]:format' \
  '--search[template for complete string to search]:template' \
  '--replace[template for complete string to replace]:template' \
  '--no-configured-files[only replace version in files specified on command line]' \
  '--tag[create a tag in version control]' \
  '--no-tag[do not create a tag]' \
  '--sign-tags[sign tags if created]' \
  '--tag-name[tag name template]:template' \
  '--tag-message[tag message template]:template' \
  '--commit[commit to version control]' \
  '--no-commit[do not commit to version control]' \
  '(-m --message)'{-m,--message}'[commit message template]:message' \
  '--allow-dirty[allow dirty working directory]' \
  '--verbose[print verbose output]' \
  '--list[list machine readable information]' \
  '--dry-run[do not write any files, just pretend]' \
  '1:part:(major minor patch)' \
  '*:file:_files' && ret=0

return ret
