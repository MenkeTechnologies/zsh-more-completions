#compdef polbin
# Documentation: https://starlink.eao.hawaii.edu/docs/sun223.htx/sun223ss1.html
# POLPACK: bins a catalogue containing Stokes parameters.

local ret=1

_arguments -s -S \
  'IN=[input catalogue]:cat:_files' \
  'OUT=[output catalogue]:cat:_files' \
  'BOX=[X and Y bin sizes]:box:' \
  'ZBOX=[bin size along Z axis]:box:' \
  'METHOD=[binning method]:method:(MEAN MEDIAN SIGMA)' \
  'MINVAL=[min good values per cell]:n:' \
  'SIGMAS=[std-dev rejection threshold]:n:' \
  'INTEGRATE=[place all vectors in single bin]:flag:(TRUE FALSE)' \
  'DEBIAS=[apply statistical bias correction]:flag:(TRUE FALSE)' \
  'DEBIASTYPE=[bias estimator type]:type:(AS MAS)' \
  'RADEC=[add RA/DEC columns]:flag:(TRUE FALSE)' \
  '*:cat:_files' && ret=0

return ret
