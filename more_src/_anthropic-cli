#compdef anthropic-cli
# Documentation: https://pypi.org/project/anthropic-cli/
# Reference accessed: 2026-05-23
# Verified: anthropic-cli --help (third-party Anthropic API CLI).

# Zsh completion for anthropic-cli - Anthropic API command-line tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-g --message)'{-g+,--message=}'[add message with role and content]:message:' \
  '(-i --image)'{-i+,--image=}'[path to image or PDF file]:file:_files' \
  '(-m --model)'{-m+,--model=}'[Anthropic model]:model:' \
  '(-s --system)'{-s+,--system=}'[system message]:message:' \
  '(-t --temperature)'{-t+,--temperature=}'[temperature]:value:' \
  '(-k --top_k)'{-k+,--top_k=}'[top-k sampling]:value:' \
  '(-p --top_p)'{-p+,--top_p=}'[top-p sampling]:value:' \
  '(-x --max_tokens)'{-x+,--max_tokens=}'[maximum response tokens]:count:' && ret=0

return ret
