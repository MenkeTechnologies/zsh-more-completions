#compdef vg2svg
# Documentation: https://vega.github.io/vega/usage/
# vega-cli: render a Vega JSON spec to an SVG image

local ret=1

_arguments -s -S \
  '(- *)--help[print usage help to the console]' \
  '(-b --base)'{-b,--base}'=[base directory for data and image loading]:dir:_files -/' \
  '(-h --header)'{-h,--header}'[include XML header and DOCTYPE in SVG output]' \
  '(-s --scale)'{-s,--scale}'=[resolution scale factor (default 1)]:factor:' \
  '--seed=[seed for random number generation]:seed:' \
  '(-c --config)'{-c,--config}'=[provide a Vega config object]:config:_files' \
  '(-f --format)'{-f,--format}'=[set the number format locale]:locale:' \
  '(-t --timeFormat)'{-t,--timeFormat}'=[set the date/time format locale]:locale:' \
  '(-l --loglevel)'{-l,--loglevel}'=[level of log messages written to stderr]:level:(error warn info debug none)' \
  '1:input vega json:_files -g "*.(json|vg.json)"' \
  '2:output svg:_files -g "*.svg"' && ret=0

return ret
