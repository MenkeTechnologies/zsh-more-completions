#compdef cartconv
# Documentation: https://vice-emu.sourceforge.io/vice_15.html#SEC308
# Reference accessed: 2026-05-16

# cartconv: VICE cartridge image conversion utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-?[show help]' \
  '-i[input file]:file:_files -g "*.(crt|bin)"' \
  '-o[output file]:file:_files -g "*.(crt|bin)"' \
  '-t[cartridge type]:type:' \
  '-n[cartridge name]:name:' \
  '-l[list known types]' \
  '-r[raw mode]' \
  '-q[quiet]' \
  '*::cartconv args:_files' && ret=0
return ret
