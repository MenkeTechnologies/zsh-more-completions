#compdef avro-tools

local curcontext="$curcontext" state line ret=1

_avro_tools_commands() {
  local -a commands=(
    'tojson:convert Avro data file to JSON'
    'fromjson:convert JSON to Avro data file'
    'compile:compile Avro schema to Java'
    'concat:concatenate Avro data files'
    'fragtojson:convert Avro fragment to JSON'
    'fromtext:convert text file to Avro data file'
    'getmeta:print metadata of an Avro data file'
    'getschema:print schema of an Avro data file'
    'idl:generate Avro schema from IDL'
    'idl2schemata:convert IDL to individual schema files'
    'induce:induce schema from a Java class'
    'jsontofrag:convert JSON to Avro fragment'
    'random:generate random Avro data'
    'recodec:change codec of an Avro data file'
    'repair:repair an Avro data file'
    'rpctool:Avro RPC tool'
    'totext:convert Avro data file to text'
    'trevni_meta:print metadata of a Trevni file'
    'trevni_tojson:convert Trevni file to JSON'
    'trevni_random:generate random Trevni data'
    'trevni_create:create a Trevni file'
  )
  _describe -t commands 'avro-tools command' commands
}

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:command:_avro_tools_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      tojson)
        _arguments -s -S \
          '--help[show help]' \
          '--pretty[pretty-print JSON output]' \
          '--head[number of records to output]:count' \
          '*:avro file:_files -g "*.avro"' && ret=0
        ;;
      fromjson)
        _arguments -s -S \
          '--help[show help]' \
          '--codec[compression codec]:codec:(null deflate snappy bzip2)' \
          '--schema-file[schema file]:file:_files' \
          '--schema[inline schema]:schema' \
          '*:json file:_files -g "*.json"' && ret=0
        ;;
      recodec)
        _arguments -s -S \
          '--help[show help]' \
          '--codec[compression codec]:codec:(null deflate snappy bzip2)' \
          '*:avro file:_files -g "*.avro"' && ret=0
        ;;
      random)
        _arguments -s -S \
          '--help[show help]' \
          '--count[number of records to generate]:count' \
          '--codec[compression codec]:codec:(null deflate snappy bzip2)' \
          '--schema-file[schema file]:file:_files' \
          '--schema[inline schema]:schema' \
          '*:output file:_files' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '--help[show help]' \
          '1:type:(schema protocol)' \
          '*:file:_files' && ret=0
        ;;
      concat|repair)
        _arguments -s -S \
          '--help[show help]' \
          '*:avro file:_files -g "*.avro"' && ret=0
        ;;
      getmeta|getschema)
        _arguments -s -S \
          '--help[show help]' \
          '*:avro file:_files -g "*.avro"' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--help[show help]' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
