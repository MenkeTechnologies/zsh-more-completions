#compdef galaxy run.sh galaxyctl galaxy-ctl
# _galaxy — Galaxy Project galaxy open web-based platform for accessible reproducible data-intensive biomedical research (galaxyproject team, Python); custom argparse
# upstream: https://github.com/galaxyproject/galaxy

_galaxy() {
    local -a sub=(
        'start:start Galaxy server'
        'stop:stop Galaxy server'
        'restart:restart Galaxy server'
        'status:show Galaxy server status'
        'log:show Galaxy logs'
        'manage_db:run database migrations'
        'create_db:create Galaxy database'
        'manage_toolbox:manage tool config'
        'set_dataset_sizes:reset dataset sizes'
        'manage_uploads:cleanup uploads'
        'install:install Galaxy'
        'update:update Galaxy'
        'fetch_tool_dependencies:fetch tool dependencies'
        'cleanup:cleanup Galaxy data'
        'tool-shed:tool shed subcommands'
        'create-tool:scaffold a tool'
        'shed_tool_data_path:manage shed tool data'
        'configure:configure Galaxy'
        'admin:admin subcommands'
        'users:user subcommands'
        'workflow:workflow subcommands'
        'job:job subcommands'
        'history:history subcommands'
        'tool:tool subcommands'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "galaxy.yml galaxy.ini *.yml *.ini"' \
        '--config-file=+[config file]:file:_files -g "galaxy.yml galaxy.ini *.yml *.ini"' \
        '--daemonize[run as daemon]' \
        '-d[run as daemon]' \
        '--pid-file=+[pid file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--user=+[user]:user:_users' \
        '--server-name=+[server name]:str:' \
        '--port=+[port]:port:_ports' \
        '-p+[port]:port:_ports' \
        '--host=+[host]:host:_hosts' \
        '--workers=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--reload[reload on change]' \
        '--debug[debug mode]' \
        '--profile[profile mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'galaxy subcommand' sub ;;
        args)
            case $words[1] in
                tool-shed) _arguments '1:tool-shed cmd:(install update search list)' ;;
                admin|users|workflow|job|history|tool) _arguments '1:cmd:(list get create update delete)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_galaxy "$@"
