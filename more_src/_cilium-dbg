#compdef cilium-dbg
# _cilium-dbg — Cilium debug/inspect CLI (eBPF maps, BGP, policy, etc.)
# upstream: https://github.com/cilium/cilium
# Subcommands + flags from cilium-dbg/cmd/root.go on tip.

_cilium-dbg() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file (default \$HOME/.cilium.yaml)]:file:_files' \
        '(-D --debug)'{-D,--debug}'[enable debug messages]' \
        '*--log-driver=[csv of logging endpoints (e.g. syslog)]:csv:' \
        '--log-opt=[log driver options (e.g. format=json)]:k=v:' \
        '(-H --host)'{-H,--host=}'[server-side API URI]:uri:_urls' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'bgp:inspect BGP state (peers/routes)'
                'bpf:inspect/manipulate Cilium eBPF maps'
                'build-config:dump build configuration'
                'cgroups:inspect cgroup state'
                'config:get/set Cilium daemon config'
                'debuginfo:dump debug info for support'
                'encrypt:inspect transparent encryption state'
                'endpoint:inspect/manage local endpoints'
                'envoy:inspect Envoy state'
                'fqdn:inspect FQDN policy cache'
                'identity:list / get Cilium identities'
                'ip:list IP-to-identity mappings'
                'kvstore:interact with the KV store'
                'loadinfo:dump dataplane load info'
                'lrp:list local redirect policies'
                'map:inspect Cilium maps'
                'metrics:dump daemon metrics'
                'monitor:stream BPF monitor events'
                'node:list cluster nodes'
                'policy:inspect/manage policy'
                'prefilter:inspect prefilter state'
                'preflight:run preflight checks (e.g. CRDs)'
                'service:inspect Cilium services'
                'statedb:inspect statedb tables'
                'status:show Cilium agent status'
                'sysdump:capture a full diagnostic dump'
                'troubleshoot:run guided diagnostic flows'
                'shell:open the Cilium hive shell'
                'completion:generate shell completion'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_cilium-dbg "$@"
