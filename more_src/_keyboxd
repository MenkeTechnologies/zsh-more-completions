#compdef keyboxd
# Documentation: https://www.gnupg.org/documentation/manuals/gnupg/
# GnuPG: public key management daemon (keybox)

local ret=1

_arguments -s -S \
  '--daemon[run in daemon mode (background)]' \
  '--server[run in server mode (foreground)]' \
  '--no-detach[do not detach from the console]' \
  '--options=[read options from FILE]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[be somewhat more quiet]' \
  '--log-file=[use a log file for the server]:file:_files' \
  '--version[print version information]' \
  '--help[show help]' \
  '*:arg:_default' && ret=0

return ret
