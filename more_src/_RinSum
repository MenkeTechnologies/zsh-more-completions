#compdef RinSum
# Documentation: https://github.com/SGL-UT/GPSTk/blob/main/core/apps/Rinextools/RinSum.cpp
# GPSTk RINEX observation file summary

local ret=1

_arguments -s \
  '(-f --file)'{-f,--file}'[configuration file with additional options]:file:_files' \
  '--obs[RINEX observation file name]:file:_files' \
  '--obspath[path to input RINEX files]:dir:_files -/' \
  '--start[begin processing at specified epoch]:epoch' \
  '--stop[stop processing at specified epoch]:epoch' \
  '*--exSat[exclude satellite or system]:sat' \
  '*--onlySat[include only specified satellites/systems]:sat' \
  '--currentRinex[output in current RINEX version]' \
  '--RinexVer[output in specified RINEX version]:ver' \
  '--timefmt[time tag format for output]:fmt' \
  '(-b --brief)'{-b,--brief}'[produce brief output]' \
  '--nohead[omit header from output]' \
  '--notable[omit satellite/obs table]' \
  '--dt[nominal time step (sec)]:sec' \
  '--milli[detect millisecond clock adjustments]' \
  '--gaps[print data gap table]' \
  '--vis[graphical visibility display]:n' \
  '--vtab[tabular visibility output]' \
  '--ycode[treat v2.11 P codes as Y codes]' \
  '(-q --quiet)'{-q,--quiet}'[reduce output verbosity]' \
  '*:RINEX obs file:_files' && ret=0

return ret
