#compdef sst
# Documentation: https://sst.dev/docs/reference/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new SST project'
  'dev:run app in dev mode with multiplexed processes'
  'deploy:deploy application to specified stage'
  'diff:preview resource changes before deployment'
  'add:add and install a provider package'
  'install:install providers defined in config'
  'secret:manage encrypted secrets'
  'shell:execute commands with linked resources'
  'remove:remove application from a stage'
  'unlock:release deployment lock if stuck'
  'version:display current CLI version'
  'upgrade:update CLI to latest or specified version'
  'telemetry:manage anonymous usage data collection'
  'refresh:synchronize local state with cloud provider'
  'state:manage app state'
  'cert:generate locally-trusted HTTPS certificate'
  'tunnel:create VPC connection for local development'
  'diagnostic:generate debugging report as zip file'
)

_arguments -C \
  '--stage=[set the stage the CLI is running on]:stage:' \
  '--config=[path to SST config file]:file:_files' \
  '--print-logs[display logs to screen from .sst/ directory]' \
  '--verbose[print extra information to log files in .sst/]' \
  '(- *)--help[display help information]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sst command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (secret)
        _arguments '1:subcommand:(set remove load list)' && ret=0 ;;
      (state)
        _arguments '1:subcommand:(edit export list remove repair)' && ret=0 ;;
      (cert)
        _arguments '1:subcommand:(install uninstall)' && ret=0 ;;
      (tunnel)
        _arguments '1:subcommand:(start install uninstall)' && ret=0 ;;
      (*) _files ;;
    esac
    ;;
esac

return ret
