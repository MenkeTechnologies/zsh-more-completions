#compdef sst

# Zsh completion for SST (Serverless Stack)

_sst() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize a new SST project'
    'dev:start the local development environment'
    'deploy:deploy your application'
    'remove:remove your application from AWS'
    'build:build your application'
    'bind:bind SST resources to a command'
    'console:open the SST console'
    'diff:show changes to be deployed'
    'secrets:manage secrets'
    'shell:open a shell with SST bound'
    'telemetry:manage telemetry'
    'update:update SST and dependencies'
    'version:print SST version'
    'add:add a new resource'
    'install:install providers for resources'
    'refresh:refresh state of your application'
    'unlock:unlock state'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sst command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        dev)
          _arguments -s -S \
            '--stage=[stage to deploy to]:stage:' \
            '--verbose[verbose output]' \
            '--print-logs[print all function logs]' \
            && ret=0
          ;;
        deploy)
          _arguments -s -S \
            '--stage=[stage to deploy to]:stage:' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        remove)
          _arguments -s -S \
            '--stage=[stage to remove]:stage:' \
            '--verbose[verbose output]' \
            && ret=0
          ;;
        secrets)
          _arguments -s -S \
            '1:subcommand:(set get list remove)' \
            '--stage=[stage]:stage:' \
            '--fallback[set a fallback value]' \
            && ret=0
          ;;
        bind)
          _arguments -s -S \
            '--stage=[stage]:stage:' \
            '*:command:' \
            && ret=0
          ;;
        shell)
          _arguments -s -S \
            '--stage=[stage]:stage:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--stage=[stage]:stage:' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_sst "$@"
