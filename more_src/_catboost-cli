#compdef catboost-cli catboost catboost2
# _catboost-cli — Yandex CatBoost catboost-cli CLI command-line frontend wrapping the Yandex CatBoost gradient-boosting library specialized in categorical features supporting fit calc eval-metrics predict ranking classification regression multiclassification dump model-summary feature-importance model-statistics roc-curve roc-prediction-mode ostr-modes (Yandex team, C++); custom argparse
# upstream: https://catboost.ai/

_catboost-cli() {
    local -a sub=(
        'fit:train a model'
        'calc:apply a model'
        'predict:run predictions'
        'eval-metrics:evaluate metrics'
        'eval-feature:evaluate features'
        'metadata:show metadata'
        'roc-curve:show ROC curve'
        'normalize-model:normalize model'
        'ostr:object importance'
        'fstr:feature importance'
        'sum-models:sum models'
        'dump-model:dump model to text'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--loss-function=+[f]:f:(Logloss CrossEntropy RMSE MAE Quantile LogLinQuantile Poisson MAPE Lq Huber FairLoss NumErrors SMAPE R2 MSLE MedianAbsoluteError PythonUserDefinedPerObject PythonUserDefinedMultiClass MultiClass MultiClassOneVsAll Tweedie PairLogit PairLogitPairwise YetiRank YetiRankPairwise QueryRMSE GroupQuantile QuerySoftMax QueryCrossEntropy StochasticFilter Combination)' \
        '--eval-metric=+[m]:m:(Logloss CrossEntropy RMSE MAE Quantile LogLinQuantile Lq Huber FairLoss NumErrors SMAPE R2 MSLE MedianAbsoluteError MultiClass MultiClassOneVsAll PairLogit PairLogitPairwise YetiRank PFound NDCG AUC HingeLoss HammingLoss ZeroOneLoss Accuracy BalancedAccuracy Precision Recall F1 TotalF1 Kappa WKappa MCC)' \
        '--learn-set=+[file]:file:_files' \
        '--test-set=+[file]:file:_files' \
        '--cd=+[file]:file:_files -g "*.cd"' \
        '--column-description=+[file]:file:_files -g "*.cd"' \
        '--iterations=+[N]:n:' \
        '--learning-rate=+[N]:str:' \
        '--depth=+[N]:n:' \
        '--max-depth=+[N]:n:' \
        '--l2-leaf-reg=+[N]:str:' \
        '--rsm=+[N]:str:' \
        '--border-count=+[N]:n:' \
        '--feature-border-type=+[t]:t:(Median Uniform UniformAndQuantiles MaxLogSum GreedyLogSum MinEntropy)' \
        '--model-format=+[f]:f:(CatboostBinary AppleCoreML json python cpp onnx pmml)' \
        '--output-model=+[file]:file:_files' \
        '--model-file=+[file]:file:_files' \
        '-m+[model file]:file:_files' \
        '--input-path=+[file]:file:_files' \
        '--output-path=+[file]:file:_files' \
        '--task-type=+[t]:t:(CPU GPU)' \
        '--devices=+[ids]:str:' \
        '--thread-count=+[N]:n:' \
        '--gpu-ram-part=+[N]:str:' \
        '--bagging-temperature=+[N]:str:' \
        '--random-seed=+[N]:n:' \
        '--use-best-model=+[bool]:s:(true false)' \
        '--snapshot-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'catboost-cli subcommand' sub ;;
    esac
}

_catboost-cli "$@"
