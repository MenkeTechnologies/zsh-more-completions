#compdef gtrash

# Zsh completion for gtrash - trash CLI written in Go

_gtrash() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '1:command:->commands' \
    '*::arg:->args' && ret=0

  case $state in
    commands)
      local -a commands=(
        'put:move files to trash'
        'find:search for files in trash'
        'restore:restore files from trash'
        'prune:remove old files from trash'
        'summary:show trash summary'
      )
      _describe -t commands 'gtrash command' commands && ret=0
      ;;
    args)
      case $line[1] in
        put)
          _arguments -s -S \
            '(-f --force)'{-f,--force}'[force trash without confirmation]' \
            '(-r --recursive)'{-r,--recursive}'[recursively trash directories]' \
            '(-v --verbose)'{-v,--verbose}'[verbose output]' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:files:_files' && ret=0
          ;;
        find)
          _arguments -s -S \
            '--day=[filter by age in days]:days:' \
            '--size=[filter by size]:size:' \
            '--regex[use regex for matching]' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:pattern:' && ret=0
          ;;
        restore)
          _arguments -s -S \
            '--day=[filter by age in days]:days:' \
            '--size=[filter by size]:size:' \
            '--regex[use regex for matching]' \
            '(-h --help)'{-h,--help}'[show help]' \
            '*:pattern:' && ret=0
          ;;
        prune)
          _arguments -s -S \
            '--day=[remove files older than days]:days:' \
            '(-h --help)'{-h,--help}'[show help]' && ret=0
          ;;
        summary)
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show help]' && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_gtrash "$@"
