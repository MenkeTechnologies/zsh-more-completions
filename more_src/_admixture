#compdef admixture
# Documentation: https://dalexander.github.io/admixture/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ADMIXTURE: maximum-likelihood ancestry estimation
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '-h[help]' \
  '-j[number of CPU threads]:n:' \
  '-s[random seed (number or "time")]:seed:' \
  '-B[bootstrap replicate count]:n:' \
  '--cv[cross-validation]' \
  '--cv=[N-fold cross-validation]:n:' \
  '-C[stop when delta-loglikelihood < epsilon]:eps:' \
  '-c[stop after N iterations]:n:' \
  '--haploid[input is haploid]:opt:' \
  '-P[supervised mode using .pop file]' \
  '*:input PED/BED and K:_files -g "*.(ped|bed)"' && ret=0
return ret
