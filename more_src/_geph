#compdef geph geph4-client geph5-client geph4-exit
# Documentation: https://man.archlinux.org/search?q=geph
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'connect:connect to Geph network'
  'auth:authenticate'
  'sync:sync exits/bridges'
  'binder-proxy:binder proxy mode'
  'bridge-test:test bridge connection'
  'debugpack:export debug logs'
  'sync-public-bridges:sync public bridges'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--credential-cache=[credential cache path]:dir:_files -/' \
  '--exit-server=[exit server hostname]:host:_hosts' \
  '--use-bridges[force bridge usage]' \
  '--http-proxy-listen=[HTTP proxy listen]:addr:' \
  '--socks5-listen=[SOCKS5 listen]:addr:' \
  '--stats-listen=[stats listen]:addr:' \
  '--dns-listen=[DNS listen]:addr:' \
  '--vpn-mode=[VPN mode]:mode:(tun-route windivert tun-no-route)' \
  '--vpn-tun-name=[TUN device name]:name:' \
  '--bypass=[bypass cidrs csv]:cidrs:' \
  '--exclude-prc[exclude PRC IPs]' \
  '--force-protocol=[force protocol]:p:(udp tcp tls obfs http)' \
  '--official-only[use only official bridges]' \
  '--debugpack=[debug pack file]:file:_files' \
  '--cache=[cache directory]:dir:_files -/' \
  '--config=[config file]:file:_files -g "*.toml *.json"' \
  '--quiet[quiet output]' \
  '--use-tcp[force TCP for bridges]' \
  '--print-test-cookie[print test cookie]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'geph command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments \
          'auth-password[password auth]' \
          '--username=[username]:user:' \
          '--password=[password]:pw:' \
          'auth-keypair[keypair auth]' && ret=0 ;;
      (connect)
        _arguments \
          '--exit-server=[exit server hostname]:host:_hosts' \
          'auth-password[password auth]' \
          '--username=[username]:user:' \
          '--password=[password]:pw:' && ret=0 ;;
    esac ;;
esac

return ret
