#compdef earthly
# _earthly-cli — Earthly container-aware build system (Earthly Technologies, Go); Earthfile DSL for reproducible builds
# upstream: https://github.com/earthly/earthly

_earthly-cli() {
    local -a sub=(
        'account:Earthly Cloud account'
        'billing:billing commands'
        'bootstrap:install shell completion + cache'
        'config:configuration'
        'debug:debug commands'
        'doc:print target docs'
        'docker:run a target as docker image'
        'docker-build:wrap docker build with Earthfile'
        'docs:open Earthly docs'
        'github:GitHub commands'
        'help:show help'
        'init:initialize new Earthfile'
        'ls:list targets'
        'org:org commands'
        'preview:preview Earthfile'
        'project:project commands'
        'prune:prune cache'
        'satellite:satellite commands'
        'secrets:secrets commands'
        'sso:SSO commands'
        'token:token commands'
        'web:open Earthly web'
        'work:work commands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--config+[config file]:file:_files' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--strict[strict]' \
        '--use-inline-cache[use inline cache]' \
        '--save-inline-cache[save inline cache]' \
        '--use-remote-cache+[remote cache]:image:' \
        '--save-remote-cache+[remote cache]:image:' \
        '--cache-from+[cache from]:image:' \
        '--build-arg+[build arg]:KEY=VAL:' \
        '--secret+[secret]:KEY=VAL:' \
        '-s+[secret]:KEY=VAL:' \
        '--secret-file+[secret file]:KEY=file:' \
        '--push[push results]' \
        '-P[push results]' \
        '--no-cache[no cache]' \
        '--allow-privileged[allow privileged]' \
        '-p[allow privileged]' \
        '--ci[CI mode]' \
        '--output[force LOCALLY output]' \
        '--platform+[platform]:platform:' \
        '--no-output[no output]' \
        '--server+[buildkit server]:url:_urls' \
        '--remote-cache+[remote cache]:image:' \
        '--max-remote-cache[unlimited remote cache]' \
        '--interactive[interactive shell on fail]' \
        '-i[interactive]' \
        '--save-artifact-locally+[save artifact]:str:' \
        '--git-username+[git username]:user:' \
        '--git-password+[git password]:pass:' \
        '--ssh-auth-sock+[ssh auth sock]:file:_files' \
        '--logstream[log stream]' \
        '--no-fake-dep[no fake deps]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'earthly subcommand' sub ;;
        args)
            case $words[1] in
                ls) _arguments '*:dir:_files -/' ;;
                docker) _arguments \
                    '--platform+[platform]:platform:' \
                    '*:target:' ;;
                init) _arguments '*:dir:_files -/' ;;
            esac
            ;;
    esac
}

_earthly-cli "$@"
