#compdef upbound
# Documentation: https://docs.upbound.io/reference/cli/command-reference/
# Reference accessed: 2026-05-21
# Verified: upstream CLI reference page (up v0.48+).

_upbound_commands() {
    local -a commands
    commands=(
        'login:authenticate with Upbound'
        'logout:log out of Upbound'
        'organization:create and manage organizations'
        'group:manage groups within Spaces'
        'controlplane:create and manage Spaces control planes'
        'composition:generate and render compositions'
        'operation:generate and render operations'
        'function:generate embedded functions'
        'dependency:manage package dependencies'
        'example:generate sample XR/XRC resources'
        'profile:manage CLI profiles'
        'ctx:select kubernetes context'
        'alpha:alpha features'
        'xpkg:manage Crossplane packages'
    )
    _describe -t commands 'upbound command' commands
}

_upbound() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:command:_upbound_commands' \
        '*::arg:->args'
}

_upbound "$@"
