#compdef upbound

_upbound_commands() {
    local -a commands
    commands=(
        'login:Login to Upbound'
        'logout:Logout from Upbound'
        'organization:Manage organizations'
        'controlplane:Manage control planes'
        'configuration:Manage configurations'
        'repository:Manage repositories'
        'robot:Manage robot accounts'
        'team:Manage teams'
        'profile:Manage CLI profiles'
        'space:Manage Upbound Spaces'
        'ctx:Set or view the current context'
        'alpha:Alpha features'
        'xpkg:Manage Crossplane packages'
    )
    _describe -t commands 'upbound command' commands
}

_upbound() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '-q[Suppress output]' \
        '-v[Verbose output]' \
        '--format[Output format]:format:(json yaml table)' \
        '--profile[Use a specific profile]:profile:' \
        '--account[Use a specific account]:account:' \
        '--domain[Upbound domain]:domain:' \
        '--insecure-skip-tls-verify[Skip TLS certificate verification]' \
        '1:command:_upbound_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                controlplane)
                    _arguments \
                        '1:action:(create get list delete connect disconnect pull-secret configuration connector provider)' \
                        '--name[Control plane name]:name:' \
                        '--group[Control plane group]:group:'
                    ;;
                organization)
                    _arguments \
                        '1:action:(create get list delete)' \
                        '--name[Organization name]:name:'
                    ;;
                configuration)
                    _arguments \
                        '1:action:(create get list delete template)' \
                        '--name[Configuration name]:name:'
                    ;;
                repository)
                    _arguments \
                        '1:action:(create get list delete)' \
                        '--name[Repository name]:name:'
                    ;;
                robot)
                    _arguments \
                        '1:action:(create get list delete token)' \
                        '--name[Robot name]:name:'
                    ;;
                team)
                    _arguments \
                        '1:action:(create get list delete members)' \
                        '--name[Team name]:name:'
                    ;;
                xpkg)
                    _arguments \
                        '1:action:(build push xp-extract init batch)' \
                        '--package-root[Package root directory]:dir:_directories' \
                        '-f[Package file]:file:_files'
                    ;;
                space)
                    _arguments \
                        '1:action:(init destroy upgrade billing attach detach)' \
                        '--token[Token]:token:'
                    ;;
                profile)
                    _arguments \
                        '1:action:(list use current view config)' \
                        '--name[Profile name]:name:'
                    ;;
            esac
            ;;
    esac
}

_upbound "$@"
