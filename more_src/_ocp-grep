#compdef ocp-grep
# Documentation: https://github.com/OCamlPro/ocp-index
# Search OCaml source files for occurrences of a fully qualified ident

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '(-c --color)'{-c,--color}'=[colorize the output]:when:(always never auto)' \
  '(-s --strings)'{-s,--strings}'[also search inside string literals]' \
  '(-e --regexp-strings)'{-e,--regexp-strings}'[treat the search term as a regexp on strings]' \
  '1:ident:' \
  '*:files:_files' && ret=0

return ret
