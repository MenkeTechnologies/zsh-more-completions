#compdef anyrun
# Documentation: https://github.com/anyrun-org/anyrun
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config-dir)'{-c+,--config-dir=}'[override config directory]:dir:_files -/' \
  '*--plugins=[plugin shared object]:plugin:' \
  '--position=[anchor position]:pos:(top center bottom)' \
  '--width=[fraction of screen width]:val:' \
  '--height=[fraction of screen height]:val:' \
  '--hide-icons[hide entry icons]' \
  '--hide-plugin-info[hide plugin info]' \
  '--show-results-immediately[show results without query]' \
  '--max-entries=[max entries to show]:n:' \
  '--close-on-click[close window on outside click]' \
  '--ignore-exclusive-zones[ignore layer-shell exclusive zones]' \
  '--layer=[layer-shell layer]:layer:(background bottom top overlay)' \
  '--keyboard-mode=[keyboard mode]:mode:(none exclusive on-demand)' && ret=0

return ret
