#compdef rviz2
# Documentation: https://github.com/ros2/rviz/blob/rolling/rviz_common/src/rviz_common/visualizer_app.cpp
# rviz2 - 3D visualization tool for ROS 2

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --display-config)'{-d,--display-config}'[load display config file]:config:_files -g "*.rviz"' \
  '(-f --fixed-frame)'{-f,--fixed-frame}'[set the fixed frame]:frame:' \
  '(-s --splash-screen)'{-s,--splash-screen}'[set a custom splash screen image]:image:_files' \
  '(-t --display-title-format)'{-t,--display-title-format}'[set the window title format]:format:' \
  '(-l --ogre-log)'{-l,--ogre-log}'[enable the Ogre.log file]' \
  '--fullscreen[start in fullscreen mode]' \
  '*:display config:_files -g "*.rviz"' && ret=0

return ret
