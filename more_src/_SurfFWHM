#compdef SurfFWHM
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfFWHM.html
# AFNI/SUMA calculate local and global FWHM on surface datasets

local ret=1

_arguments -s -S \
  '-input[dataset for FWHM calculation]:dset:_files' \
  '-prefix[output dataset prefix]:prefix:' \
  '-clean[remove descriptive text for easier parsing]' \
  '-detrend[remove polynomial trends up to order q]:q:' \
  '-detpoly[detrend using polynomials of order p]:p:' \
  '-detprefix[save detrended data to prefix]:d:' \
  '-hood[neighborhood radius for local FWHM]:r:' \
  '-nbhd_rad[neighborhood radius for local FWHM]:r:' \
  '-vox_size[nominal voxel size in mm]:d:' \
  '-ok_warn[allow warnings during execution]' \
  '-examples[display command-line examples and exit]' \
  '-n_mask[apply to specified node indices only]:file:_files' \
  '-b_mask[binary mask file (1 include, 0 exclude)]:file:_files' \
  '-c_mask[expression-based masking criteria]:expr:' \
  '*:dataset:_files' && ret=0

return ret
