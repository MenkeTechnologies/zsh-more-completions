#compdef jack_transport
# Documentation: https://man.archlinux.org/search?q=jack_transport
# Reference accessed: 2026-05-16

# jack_transport: interactive JACK transport control (play/stop/locate)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:transport command:(start stop play pause locate stop activate exit quit help status)' && ret=0
return ret
