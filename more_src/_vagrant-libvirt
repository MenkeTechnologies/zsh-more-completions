#compdef vagrant-libvirt
# _vagrant-libvirt — Vagrant libvirt plugin helper (CLI entry-point bundled with vagrant-libvirt that helps prepare host networking and storage pool before vagrant up; subcommands: setup-network, setup-storage, install-vagrant-libvirt, prune-cloud-domain, version, status)
# upstream: https://github.com/vagrant-libvirt/vagrant-libvirt
# Subcommands from vagrant-libvirt lib/vagrant-libvirt/commands on tip.

_vagrant-libvirt() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'vagrant-libvirt command' '(setup-network setup-storage install-vagrant-libvirt prune-cloud-domain status version)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_vagrant-libvirt "$@"
