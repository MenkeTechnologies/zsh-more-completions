#compdef a2x
# Documentation: a2x --help (AsciiDoc toolchain manager)
# Source: build chunks/EPUB/PDF/manpage/text/xhtml outputs from AsciiDoc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*'{-a+,--attribute=}'[set asciidoc attribute value]:attr=value:' \
    '--asciidoc-opts=[options for asciidoc]:opts:' \
    '--conf-file=[configuration file]:file:_files' \
    '(-D --destination-dir)'{-D+,--destination-dir=}'[output directory]:dir:_files -/' \
    '(-d --doctype)'{-d+,--doctype=}'[document type]:doctype:(article manpage book)' \
    '(-b --backend)'{-b+,--backend=}'[backend plugin]:backend:' \
    '--epubcheck[check EPUB output with epubcheck]' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(chunked epub htmlhelp manpage pdf text xhtml dvi ps tex docbook)' \
    '--icons[use admonition/callout/navigation icons]' \
    '--icons-dir=[icons directory]:dir:_files -/' \
    '(-k --keep-artifacts)'{-k,--keep-artifacts}'[do not delete temp files]' \
    '--lynx[use lynx for text generation]' \
    '(-L --no-xmllint)'{-L,--no-xmllint}'[do not run xmllint]' \
    '(-n --dry-run)'{-n,--dry-run}'[print commands without executing]' \
    '*'{-r+,--resource=}'[resource file or directory]:resource:_files' \
    '(-m --resource-manifest)'{-m+,--resource-manifest=}'[manifest file]:file:_files' \
    '--stylesheet=[CSS stylesheet]:file:_files -g "*.css"' \
    '--dblatex-opts=[dblatex options]:opts:' \
    '--backend-opts=[backend plugin options]:opts:' \
    '--fop[use FOP for PDF generation]' \
    '--fop-opts=[FOP options]:opts:' \
    '--xsltproc-opts=[xsltproc options]:opts:' \
    '--xsl-file=[custom XSL stylesheet]:file:_files -g "*.xsl"' \
    '(-v --verbose)*'{-v,--verbose}'[verbose (repeatable)]' \
    '1:asciidoc source:_files -g "*.(asc|adoc|asciidoc|txt)"' \
    && ret=0

return ret
