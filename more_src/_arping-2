#compdef arping2 arping-thomas
# _arping-2 — Thomas Habets arping (variant that pings live MAC addresses (not just IPs), with timestamps and rich output formatting; -c count, -i interface, -b broadcast, -p promiscuous, -s source mac, -S source ip, -t target mac, -T target ip, -w deadline seconds, -W interval seconds, -q quiet, -r raw rtt output, -A all stats, -d hex dump, -e audible beep)
# upstream: https://github.com/ThomasHabets/arping
# Flags from ThomasHabets/arping src/arping.c on tip.

_arping-2() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[count]:n:' \
        '-i+[interface]:interface:_net_interfaces' \
        '-I+[interface]:interface:_net_interfaces' \
        '-b[broadcast]' \
        '-p[promiscuous]' \
        '-s+[source mac]:mac:' \
        '-S+[source ip]:ip:' \
        '-t+[target mac]:mac:' \
        '-T+[target ip]:ip:' \
        '-w+[deadline seconds]:seconds:' \
        '-W+[interval seconds]:seconds:' \
        '-q[quiet]' \
        '-r[raw rtt]' \
        '-A[all stats]' \
        '-d[hex dump]' \
        '-e[audible beep]' \
        '-Q+[802.1p priority]:n:' \
        '1:target:_hosts'
}

_arping-2 "$@"
