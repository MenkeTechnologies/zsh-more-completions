#compdef check_if_email_exists
# Documentation: https://man.archlinux.org/search?q=check_if_email_exists
# Reference accessed: 2026-05-16

# https://github.com/reacherhq/check-if-email-exists — SMTP reachability probe (no email sent)

_arguments -s -S \
  '--from-email=[MAIL FROM address]:email:' \
  '--hello-name=[EHLO/EHLO hostname]:host:' \
  '--proxy-host=[SOCKS5 proxy host]:host:' \
  '--proxy-port=[SOCKS5 proxy port]:port:' \
  '--proxy-username=[SOCKS5 username]:user:' \
  '--proxy-password=[SOCKS5 password]:pass:' \
  '--smtp-port=[destination SMTP port]:port:' \
  '--check-gravatar[toggle gravatar existence check]' \
  '--haveibeenpwned-api-key=[optional HIBP API key]:key:' \
  '1:email_to_check:_default' && return 0
