#compdef bioformats2raw
# Documentation: https://github.com/glencoesoftware/bioformats2raw
# Convert image file formats to OME-Zarr using Bio-Formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--resolutions=[number of pyramid resolution levels]:levels' \
  '--target-min-size=[smallest resolution maximum dimension]:size' \
  '--use-existing-resolutions[preserve existing pyramid resolutions]' \
  '--tile-width=[maximum tile width]:width' \
  '--tile-height=[maximum tile height]:height' \
  '--dimension-order=[output dimension order (deprecated)]:order' \
  '--compression=[Zarr compression type]:type:(blosc gzip zlib zstd null)' \
  '--compression-properties=[codec-specific compression options]:props' \
  '--max-workers=[number of worker threads]:n' \
  '--downsample-type=[downsampling algorithm]:type:(SIMPLE GAUSSIAN AREA LINEAR CUBIC LANCZOS)' \
  '--ngff-version=[OME-Zarr NGFF version]:version:(0.4 0.5)' \
  '--pyramid-name=[subdirectory name for Zarr output]:name' \
  '--scale-format-string=[series/resolution naming format]:fmt' \
  '--no-ome-meta-export[omit OME-XML metadata]' \
  '--no-original-metadata[skip OriginalMetadata annotations]' \
  '--no-root-group[do not create root Zarr group]' \
  '--no-minmax[omit OMERO rendering metadata]' \
  '*--series=[convert only specified series index]:index' \
  '--extra-readers=[include/exclude experimental readers]:readers' \
  '*--options=[reader-specific configuration]:opt' \
  '--memo-directory=[directory for memo cache files]:dir:_files -/' \
  '--keep-memo-files[retain .bfmemo files after conversion]' \
  '--debug[enable verbose debug output]' \
  '--log-level=[set logging level]:level:(OFF ERROR WARN INFO DEBUG TRACE ALL)' \
  '--warn-no-exec[warn instead of fail on noexec temp directories]' \
  '1:input file:_files' \
  '2:output directory:_files -/' && ret=0

return ret
