#compdef vector-tap

# vector-tap: live-tap a running Vector pipeline
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-u[Vector API URL]:url:' \
  '--url=[Vector API URL]:url:' \
  '-c[component name (output)]:component:' \
  '--component=[component name (output)]:component:' \
  '-i[inputs of given components]:list:' \
  '--inputs-of=[inputs of given components]:list:' \
  '-l[max events per second]:n:' \
  '--limit=[max events per second]:n:' \
  '-f[output format]:fmt:(json yaml logfmt)' \
  '--format=[output format]:fmt:(json yaml logfmt)' \
  '-q[quiet]' \
  '*:component name:' && ret=0
return ret
