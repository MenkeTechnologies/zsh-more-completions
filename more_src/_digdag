#compdef digdag
# Documentation: https://man.archlinux.org/search?q=digdag
# Reference accessed: 2026-05-16

# treasure-data/digdag — workflow engine CLI (`digdag --help`). Core verbs: server, init, push, start, session, attempt, log, secret, selfcheck, …

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'server:run embedded server'
  'init:init project dir'
  'push:upload revision'
  'start:start a session'
  'retry:retry session'
  'delete:delete attempts/sessions'
  'kill:stop running attempt'
  'session:list or show sessions'
  'attempt:inspect attempts'
  'log:fetch task logs'
  'tasks:show DAG tasks'
  'secrets:manage secrets'
  'projects:list projects'
  'schedules:manage schedules'
  'backfill:run backfill'
  'selfcheck:verify install'
  'version:print version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '-e+[endpoint URL]:url' \
  '-c+[config path]:file:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'digdag command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
