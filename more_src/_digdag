#compdef digdag
# Documentation: https://docs.digdag.io/command_reference.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# treasure-data/digdag workflow engine CLI (`digdag --help`).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'init:create a new workflow project'
  'run:run a workflow locally'
  'check:show workflow definitions'
  'scheduler:run a scheduler server'
  'selfupdate:update digdag to the latest version'
  'server:start digdag server'
  'push:upload current project files to server'
  'download:download project files from server'
  'start:start a new session attempt of a workflow'
  'retry:retry a session'
  'kill:kill a running session attempt'
  'backfill:start sessions of a schedule for past times'
  'reschedule:skip sessions of a schedule to a future time'
  'log:show logs of a session attempt'
  'workflows:show registered workflow definitions'
  'schedules:show registered schedules'
  'disable:disable a workflow schedule'
  'enable:enable a workflow schedule'
  'sessions:show past and current sessions'
  'session:show a single session'
  'attempts:show past and current attempts'
  'attempt:show a single attempt'
  'tasks:show tasks of a session attempt'
  'delete:delete a project'
  'projects:show projects'
  'secrets:manage secrets'
  'version:show client and server version'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '-e+[endpoint URL]:url' \
  '-c+[config path]:file:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'digdag command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
