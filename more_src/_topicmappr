#compdef topicmappr autothrottle metricsfetcher
# ============================================================================
# _topicmappr — zsh completion for DataDog/kafka-kit, "Kafka storage
#                rebalancing, automated replication throttle, cluster API
#                and more" — Go=162 leader bump continuing Axis 107 Apache
#                Kafka via the canonical Go Kafka client
#                github.com/confluentinc/confluent-kafka-go (the same
#                librdkafka-C-backed family as the Rust rdkafka used in
#                R1015).
#                Covers three of the four kafka-kit binaries (the `registry`
#                bin name is already taken by distribution/distribution):
#                  topicmappr      — partition rebalancer / placement planner
#                  autothrottle    — automated replication-throttle controller
#                  metricsfetcher  — Kafka cluster metrics scraper
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/DataDog/kafka-kit
#   Maintainer : Datadog Inc.
#   License    : Apache-2.0
#   Stars      : 498
#   Language   : Go (module github.com/DataDog/kafka-kit/v4,
#                go 1.23)
#   Binaries   : topicmappr     (cmd/topicmappr/main.go)
#                autothrottle   (cmd/autothrottle/main.go)
#                metricsfetcher (cmd/metricsfetcher/main.go)
#                registry       (cmd/registry/main.go — covered
#                                separately as `_registry` for
#                                the distribution/distribution
#                                tool with the same bin name)
#   Last push  : 2026-05-24
#
# WHAT IT IS
#   kafka-kit is Datadog's Kafka cluster-management toolkit —
#   a suite of binaries that DD operates internally at scale
#   (10,000s of brokers) and released as OSS:
#
#     topicmappr      — Partition-placement planner.  Given
#                       the current Kafka cluster state +
#                       broker metrics (free disk, network
#                       throughput) it produces a target
#                       partition map that rebalances /
#                       rebuilds / scales the cluster while
#                       minimizing reassignment churn.
#                       Subcommands:
#                         rebalance  — Rebalance partition
#                                      allotments
#                         rebuild    — Rebuild a partition
#                                      map for one or more
#                                      topics
#                         scale      — Redistribute partitions
#                                      to additional brokers
#                         version    — Print the version
#
#     autothrottle    — Automated replication-throttle
#                       controller.  Detects in-flight
#                       reassignments and dynamically tunes
#                       `replica.alter.log.dirs.io.max.bytes.
#                       per.second` + `leader.replication.
#                       throttled.rate` + `follower.replication
#                       .throttled.rate` based on real-time
#                       network-utilization metrics to keep the
#                       cluster healthy during a rebalance.
#
#     metricsfetcher  — Polls broker metrics (free disk,
#                       network in/out) and writes them to
#                       a ZooKeeper /topicmappr/<key> path
#                       that topicmappr consumes for
#                       placement decisions.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/topicmappr/
#                       commands/{root,rebalance,rebuild,
#                       scale,version}.go + cmd/autothrottle/
#                       main.go + cmd/metricsfetcher/main.go;
#                       extracted via `gh api repos/DataDog/
#                       kafka-kit/contents/cmd/...`)
#
#   topicmappr [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global persistent flags  (every subcommand):
#     --kafka-addr <ADDR>            Kafka bootstrap address
#                                    [default:
#                                    localhost:9092]
#     --zk-addr <ADDR>               ZooKeeper connect string
#                                    [default:
#                                    localhost:2181]
#     --zk-prefix <PREFIX>           ZooKeeper prefix (if
#                                    Kafka is configured with
#                                    a chroot path prefix)
#     --zk-metrics-prefix <PREFIX>   ZooKeeper namespace prefix
#                                    for Kafka metrics
#                                    [default: topicmappr]
#     --ignore-warns                 Produce a map even if
#                                    warnings are encountered
#
#   Every persistent flag is also configurable via the
#   `TOPICMAPPR_*` env var prefix
#   (`envy.ParseCobra(rootCmd, envy.CobraConfig{Prefix:
#   "TOPICMAPPR", Persistent: true, Recursive: false})`).
#
#   Subcommands:
#     rebalance                      Rebalance partition
#                                    allotments among a set
#                                    of topics and brokers
#     rebuild                        Rebuild a partition map
#                                    for one or more topics
#     scale                          Redistribute partitions
#                                    to additional brokers
#     version                        Print the version
#
#   autothrottle [OPTIONS]           Continuous controller —
#                                    no subcommands; flags
#                                    configure the throttle
#                                    policy (refresh interval,
#                                    high-watermark thresholds,
#                                    Kafka admin + ZooKeeper
#                                    bootstrap, Datadog API
#                                    credentials for metrics
#                                    consumption, etc.)
#
#   metricsfetcher [OPTIONS]         Continuous poller — no
#                                    subcommands; flags
#                                    configure scrape interval,
#                                    Kafka admin + ZooKeeper
#                                    bootstrap, Datadog API
#                                    credentials, ZooKeeper
#                                    write path
#
#   Standard cobra auto-flags  (where applicable):
#     -h, --help                     Show help (root + each
#                                    subcommand)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/confluentinc/confluent-
#   kafka-go v1.4.0` declared in go.mod — `confluent-kafka-go`
#   is THE canonical Go Apache Kafka client maintained by
#   Confluent Inc. (the company founded by the original Apache
#   Kafka authors at LinkedIn), distributed at the
#   confluentinc/confluent-kafka-go repository (4,800+ stars;
#   the predominant production-grade Go Kafka client wrapping
#   Confluent's `librdkafka` C library — the same engine used
#   by Rust's `rdkafka` crate that we opened Axis 107 with in
#   R1015's _kumod, by Python's `confluent-kafka-python`, by
#   C#'s `confluent-kafka-dotnet`, and by Node.js's `node-
#   rdkafka` — making it the de-facto Kafka client across
#   every language with a C FFI).  confluent-kafka-go exposes
#   the typed `Producer` constructor with
#   `kafka.NewProducer(&kafka.ConfigMap{"bootstrap.servers":
#   "kafka:9092", "client.id": "metricsfetcher", "acks": "all",
#   "compression.type": "lz4", "linger.ms": 5, "batch.size":
#   65536, "enable.idempotence": true, "max.in.flight.requests
#   .per.connection": 5})` and the typed `Consumer` constructor
#   with
#   `kafka.NewConsumer(&kafka.ConfigMap{"bootstrap.servers":
#   "kafka:9092", "group.id": "consumer-group", "enable.auto.
#   commit": false, "auto.offset.reset": "earliest", "session.
#   timeout.ms": 6000, "isolation.level": "read_committed"})`,
#   the typed `producer.Produce(&kafka.Message{TopicPartition:
#   kafka.TopicPartition{Topic: &topic, Partition: kafka.
#   PartitionAny}, Value: payload, Key: key, Headers: hdrs},
#   deliveryChan)` API, the typed `consumer.SubscribeTopics
#   ([]string{"topic"}, rebalanceCb)` /
#   `consumer.ReadMessage(timeout)` /
#   `consumer.CommitMessage(msg)` /
#   `consumer.StoreOffsets(offsets)` /
#   `consumer.Seek(partition, offset)` /
#   `consumer.Assignment()` /
#   `consumer.Subscription()` /
#   `consumer.Position(partitions)` consumer surface, the
#   typed `kafka.Message` /  `kafka.TopicPartition` /
#   `kafka.Offset` /  `kafka.Error` /  `kafka.AssignedPartitions`
#   /  `kafka.RevokedPartitions` /  `kafka.RebalanceCb` /
#   `kafka.Event` /  `kafka.OAuthBearerTokenRefresh`
#   primitives, the typed `AdminClient` with
#   `adminClient.CreateTopics(ctx, []kafka.TopicSpecification{
#   {Topic: "name", NumPartitions: 3, ReplicationFactor: 2,
#   Config: map[string]string{...}}}, opts)` /
#   `adminClient.DeleteTopics(ctx, topics)` /
#   `adminClient.CreatePartitions(ctx, partitions)` /
#   `adminClient.AlterConfigs(ctx, resources)` /
#   `adminClient.DescribeConfigs(ctx, resources)` /
#   `adminClient.ListConsumerGroups(ctx, opts)` /
#   `adminClient.DescribeConsumerGroups(ctx, groups)` /
#   `adminClient.ListConsumerGroupOffsets(ctx, ...)` /
#   `adminClient.AlterConsumerGroupOffsets(ctx, ...)` /
#   `adminClient.DeleteConsumerGroups(ctx, groups)` /
#   `adminClient.GetMetadata(topic, all, timeout)` /
#   `adminClient.ClusterID(ctx)` /
#   `adminClient.ControllerID(ctx)` /
#   `adminClient.AlterUserScramCredentials(...)` /
#   `adminClient.DescribeUserScramCredentials(...)`, the
#   `kafka.LibraryVersion()` runtime introspection, the
#   `Schema Registry` REST client wrapper, and the
#   `OAUTHBEARER` SASL mechanism via the
#   `kafka.OAuthBearerToken{Principal, Extensions, TokenValue,
#   Expiration}` setter.  kafka-kit's `kafkaadmin/...` and
#   `kafkametrics/...` packages wrap typed `AdminClient` +
#   `Consumer` constructors per binary invocation, dispatching
#   topic-listing / partition-assignment / consumer-group-
#   offset / broker-metadata queries that drive topicmappr's
#   placement planner.  Verified via:
#     gh api repos/DataDog/kafka-kit/contents/go.mod
#       → module github.com/DataDog/kafka-kit/v4
#       → github.com/confluentinc/confluent-kafka-go v1.4.0
#       → github.com/spf13/cobra v1.5.0
#     gh api repos/DataDog/kafka-kit/contents/cmd/
#         topicmappr/commands/{root,rebalance,rebuild,scale,
#         version}.go
#       → rootCmd.Use = "topicmappr"
#       → PersistentFlags: --kafka-addr (default localhost:
#                          9092), --zk-addr (default
#                          localhost:2181), --zk-prefix,
#                          --zk-metrics-prefix (default
#                          topicmappr), --ignore-warns
#       → subcommands: rebalance, rebuild, scale, version
#     gh api repos/DataDog/kafka-kit/contents/cmd/{auto
#         throttle,metricsfetcher}/main.go
#       → continuous-controller binaries with flat option
#         spaces (no subcommands)
#   This entry is the Go=162 leader bump that continues Axis
#   107 (Apache Kafka client) at 2/0/0 following R1015 _kumod
#   (Rust=162 OPENED the axis on rdkafka v0.38 — the same
#   librdkafka C-library family that confluent-kafka-go
#   wraps).  TS-Node=162 closing pair to follow at R1017
#   (candidates: kafkajs / node-rdkafka /
#   @confluentinc/kafka-javascript consumers).
#
#   No completion for `topicmappr`, `autothrottle`, or
#   `metricsfetcher` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_topicmappr() {
    case "${service:-${words[1]}}" in
        autothrottle|metricsfetcher)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '*: :' ;;
        topicmappr|*)
            _arguments -C \
                '(- *)'{-h,--help}'[show help]' \
                '--kafka-addr=[Kafka bootstrap address (default localhost:9092; env TOPICMAPPR_KAFKA_ADDR)]:addr:' \
                '--zk-addr=[ZooKeeper connect string (default localhost:2181; env TOPICMAPPR_ZK_ADDR)]:addr:' \
                '--zk-prefix=[ZooKeeper chroot prefix (env TOPICMAPPR_ZK_PREFIX)]:prefix:' \
                '--zk-metrics-prefix=[ZooKeeper namespace prefix for Kafka metrics (default topicmappr)]:prefix:' \
                '--ignore-warns[produce a map even if warnings are encountered]' \
                '1: :_topicmappr_commands' \
                '*::arg:->args'
            case $state in
                args)
                    _arguments '*: :' ;;
            esac ;;
    esac
}

(( $+functions[_topicmappr_commands] )) ||
_topicmappr_commands() {
    local -a commands
    commands=(
        'rebalance:rebalance partition allotments among a set of topics and brokers'
        'rebuild:rebuild a partition map for one or more topics'
        'scale:redistribute partitions to additional brokers'
        'version:print the version'
    )
    _describe -t commands 'topicmappr command' commands
}

_topicmappr "$@"
