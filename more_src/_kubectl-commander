#compdef kubectl-commander
# Documentation: https://github.com/schabrolles/kubectl-commander
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (kubectl-commander script).

# kubectl-commander (schabrolles/kubectl-commander): interactive fzf menu.
# Usage: kubectl commander <type> [OPTIONS]

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-A[search across all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[search in a specific namespace]:namespace:' \
  '-o+[output mode (e.g. wide)]:format:(wide)' \
  '(-q --query)'{-q+,--query=}'[start fzf with this query]:query:' \
  '(-s --sort)'{-s+,--sort=}'[sort by field]:field:(date creation age creationTimestamp creationDate)' \
  '(-y --yq)'{-y+,--yq=}'[yq filter on YAML preview]:expr:' \
  '1:resource type:_default'
