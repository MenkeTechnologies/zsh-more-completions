#compdef spamc

_arguments -s \
  '(-B --bsmtp)'{-B,--bsmtp}'[input is BSMTP-formatted message]' \
  '(-c --check)'{-c,--check}'[check only]' \
  '(-d --dest)'{-d,--dest=}'[spamd hosts]:hosts:_hosts' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '(-e --pipe-to)'{-e,--pipe-to=}'[pipe output to command]:command:' \
  '(-E --exitcode)'{-E,--exitcode}'[set exit code by spam/ham]' \
  '(-F --config)'{-F,--config=}'[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(-H --randomize)'{-H,--randomize}'[randomize host IPs]' \
  '(-l --log-to-stderr)'{-l,--log-to-stderr}'[log to stderr]' \
  '(-L --learntype)'{-L,--learntype=}'[submit for learning]:type:(spam ham forget)' \
  '(-C --reporttype)'{-C,--reporttype=}'[collaborative filter type]:type:(report revoke)' \
  '(-p --port)'{-p,--port=}'[spamd port]:port:' \
  '(-r --full-spam)'{-r,--full-spam}'[full report if spam]' \
  '(-R --full)'{-R,--full}'[full report always]' \
  '(-s --max-size)'{-s,--max-size=}'[message size cap]:bytes:' \
  '--connect-retries=[connect retries]:n:' \
  '--retry-sleep=[retry sleep secs]:secs:' \
  '--filter-retries=[filter retries]:n:' \
  '--filter-retry-sleep=[filter retry sleep]:secs:' \
  '(-S --ssl)'{-S,--ssl}'[use SSL]' \
  '--ssl-cert=[SSL cert]:file:_files' \
  '--ssl-key=[SSL key]:file:_files' \
  '--ssl-ca-file=[SSL CA file]:file:_files' \
  '--ssl-ca-path=[SSL CA path]:dir:_files -/' \
  '(-t --timeout)'{-t,--timeout=}'[I/O timeout]:secs:' \
  '(-n --connect-timeout)'{-n,--connect-timeout=}'[connect timeout]:secs:' \
  '(-u --username)'{-u,--username=}'[override user]:user:_users' \
  '(-U --socket)'{-U,--socket=}'[UNIX socket]:path:_files' \
  '(- *)'{-V,--version}'[show version]' \
  '(-x --no-safe-fallback)'{-x,--no-safe-fallback}'[no safe fallback]' \
  '(-X --unavailable-tempfail)'{-X,--unavailable-tempfail}'[temp fail when unavailable]' \
  '(-y --tests)'{-y,--tests}'[output hit rule names]' \
  '-K[keep-alive ping]' \
  '-z[gzip-compress message]' \
  '--headers[rewrite headers only]'
