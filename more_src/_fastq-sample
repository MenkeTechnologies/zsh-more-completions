#compdef fastq-sample
# Documentation: https://github.com/dcjones/fastq-tools
# randomly sample reads, with or without replacement

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this message]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '-n+[the number of reads to sample (default: 10000)]:count:' \
  '-p+[the proportion of the total reads to sample]:proportion:' \
  '(-o --output)'{-o,--output=}'[output file prefix]:prefix:' \
  '(-c --complement-output)'{-c,--complement-output=}'[output reads not in the sample to a file]:file:_files' \
  '(-r --with-replacement)'{-r,--with-replacement}'[sample with replacement]' \
  '(-s --seed)'{-s,--seed=}'[a manual seed to the random number generator]:seed:' \
  '*:fastq file:_files' && ret=0

return ret
