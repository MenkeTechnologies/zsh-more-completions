#compdef 2ms

# Zsh completion for Checkmarx 2ms secret scanner

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--config=[config file]:file:_files -g "*.yaml *.yml *.json"' \
  '--log-level=[verbosity]:level:(none trace debug info warn error fatal)' \
  '*--report-path=[report output path (.json/.yaml/.sarif)]:file:_files' \
  '--stdout-format=[console format]:format:(json yaml sarif)' \
  '*--regex=[custom Go regex patterns]:pattern' \
  '*--rule=[include rules by name or tag]:rule' \
  '*--ignore-rule=[exclude rules by name or tag]:rule' \
  '*--ignore-result=[ignore findings by id]:id' \
  '*--allowed-values=[known-safe secret values to ignore]:value' \
  '*--add-special-rule=[enable special rules]:rule' \
  '--ignore-on-exit=[treat exit codes as success]:mode:(all results errors none)' \
  '--max-target-megabytes=[skip files larger than N MB]:n' \
  '--max-findings=[stop after N findings]:n' \
  '--max-rule-matches-per-fragment=[cap matches per rule per fragment]:n' \
  '--max-secret-size=[ignore secrets larger than N bytes]:n' \
  '--validate[verify candidate secrets]' \
  '--custom-rules-path=[custom rules JSON/YAML]:file:_files' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      rules confluence discord filesystem git paligo slack
    )
    _describe -t commands '2ms command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
