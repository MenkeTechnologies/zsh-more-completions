#compdef atticd
# _atticd — Attic Nix binary cache server (zhaofengli/attic)
# upstream: https://github.com/zhaofengli/attic
# Flags from server/src/main.rs (clap).

_atticd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --config)'{-f+,--config=}'[config file path]:file:_files -g "*.toml"' \
        '(-l --listen)'{-l+,--listen=}'[socket address to listen on]:addr:' \
        '--mode=[server mode]:mode:(monolithic api-server garbage-collector db-migrations garbage-collector-once check-config)' \
        '--tokio-console[enable tokio-console]'
}

_atticd "$@"
