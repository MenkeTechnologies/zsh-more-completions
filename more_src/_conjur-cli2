#compdef conjur-cli2 conjur2
# _conjur-cli2 — CyberArk Conjur conjur-cli2 CLI command-line frontend wrapping the Conjur Open-Source CyberArk's flagship secrets management solution for DevOps tools and cloud-native applications written in Ruby/Python init login logout authenticate host user policy load update delete variable get set value retrieve resource permitted-roles role memberships rotate-api-key audit list show grant deny describe revoke serve trace whoami help authorize plugin (CyberArk team Geri Jennings Kevin Gilpin, Ruby/Python); thor
# upstream: https://www.conjur.org/

_conjur-cli2() {
    local -a sub=(
        'init:initialize Conjur CLI'
        'login:authenticate'
        'logout:revoke session'
        'authenticate:get an access token'
        'authn-jwt:JWT authn'
        'whoami:show identity'
        'host:host operations'
        'user:user operations'
        'policy:policy operations'
        'variable:variable operations'
        'list:list resources'
        'show:show a resource'
        'role:role operations'
        'resource:resource operations'
        'check:permission check'
        'permitted-roles:show permitted roles'
        'memberships:show memberships'
        'rotate-api-key:rotate API key'
        'audit:audit operations'
        'plugin:plugin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '-a+[account]:str:' \
        '--account=+[name]:str:' \
        '-l+[login]:str:' \
        '--login=+[user]:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '--api-key=+[key]:str:' \
        '-c+[cert file]:file:_files -g "*.pem *.crt"' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--insecure[skip TLS verify]' \
        '-f+[policy file]:file:_files -g "*.yml *.yaml"' \
        '--file=+[file]:file:_files -g "*.yml *.yaml"' \
        '-b+[branch]:str:' \
        '--branch=+[name]:str:' \
        '--mode=+[m]:m:(update replace dry-run policy-load)' \
        '--policy-mode=+[m]:m:(append patch replace)' \
        '-i+[identifier]:str:' \
        '--id=+[id]:str:' \
        '--kind=+[k]:k:(variable user host group layer policy webservice)' \
        '-o+[output format]:f:(json yaml table)' \
        '--output=+[fmt]:f:(json yaml table)' \
        '--token-file=+[file]:file:_files' \
        '--privilege=+[p]:p:(read execute update)' \
        '--role=+[role]:str:' \
        '--annotation=+[k=v]:str:' \
        '*--annotation=+[k=v]:str:' \
        '--value=+[value]:str:' \
        '--from-file=+[file]:file:_files' \
        '--text[plain text]' \
        '--insecure-as-warning[insecure as warning]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'conjur subcommand' sub ;;
        args)
            case $words[1] in
                policy) _arguments '1:op:(load update replace fetch delete)' '*:arg:' ;;
                variable) _arguments '1:op:(get set values has-value)' '*:id:' ;;
                user|host) _arguments '1:op:(rotate-api-key change-password)' '*:id:' ;;
                role) _arguments '1:op:(memberships members exists)' '*:id:' ;;
                resource) _arguments '1:op:(show check exists permitted-roles)' '*:id:' ;;
                list) _arguments '*:kind:(variable user host group layer policy webservice)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_conjur-cli2 "$@"
