#compdef hours
# Documentation: https://github.com/dhth/hours
# hours - a no-frills time tracking toolkit for the command line

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dbpath=[path to the database file]:file:_files' \
  '1:command:((
    report:"output reports based on task log entries"
    log:"output task log entries"
    stats:"output statistics for tracked time"
    active:"show the currently tracked task"
    gen:"generate dummy data"
    themes:"manage custom themes"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-i --interactive)'{-i,--interactive}'[view via interactive interface]' \
      '(-t --template)'{-t,--template}'=[output format template]:template:' \
      '--theme=[load a specific theme]:theme:' \
      '(-h --help)'{-h,--help}'[show help]' && ret=0
    ;;
esac

return ret
