#compdef dtrx
# Documentation: https://github.com/brettcs/dtrx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into nested archives and extract them]' \
  '(-o --overwrite)'{-o,--overwrite}'[use default directory name even if it exists]' \
  '(-f --flat)'{-f,--flat}'[extract everything into current directory, no subdir]' \
  '(-n --noninteractive)'{-n,--noninteractive}'[suppress prompts; use conservative defaults]' \
  '(-l -t --list --table)'{-l,-t,--list,--table}'[list archive contents without extracting]' \
  '(-m --metadata)'{-m,--metadata}'[extract metadata from .deb and .gem archives]' \
  '(-q --quiet)'{-q,--quiet}'[suppress warnings (twice for silent)]' \
  '(-v --verbose)'{-v,--verbose}'[show extracted files (twice for debug)]' \
  '(--one --one-entry)'{--one,--one-entry=}'[handling of single-entry archives]:method:(inside rename here)' \
  '*:archive file:_files' && ret=0

return ret
