#compdef getdist
# Documentation: https://getdist.readthedocs.io/en/latest/
# GetDist: compute marginalized statistics from MCMC chains

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ignore_rows=[initial fraction of chains to cut as burn in]:fraction' \
  '--make_param_file=[produce a sample distparams.ini file to edit]:file:_files' \
  '--make_plots[make PDFs from any requested plot script files]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '1:ini file:_files -g "*.ini"' \
  '2:chain root:_files' && ret=0

return ret
