#compdef flowise-cli
# Documentation: https://github.com/FlowiseAI/Flowise
# Reference accessed: 2026-05-23
# Verified: Flowise oclif CLI (see also _flowise).

# Zsh completion for flowise-cli - Flowise AI workflow server CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start Flowise server'
  'worker:start Flowise queue worker'
  'user:list users or reset password'
)

_arguments -C \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flowise command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start|worker)
        _arguments \
          '--PORT=[server port]:port:' \
          '--DEBUG=[debug mode]:bool:(true false)' \
          '--LOG_PATH=[log file]:path:_files -/' \
          '--LOG_LEVEL=[log level]:level:(error warn info debug)' \
          '--DATABASE_TYPE=[database]:type:(sqlite mysql postgres mariadb)' \
          '--DATABASE_PATH=[sqlite path]:path:_files -/' \
          '--DATABASE_HOST=[db host]:host:_hosts' \
          '--DATABASE_PORT=[db port]:port:' \
          '--DATABASE_NAME=[db name]:name:' \
          '--DATABASE_USER=[db user]:user:' \
          '--DATABASE_PASSWORD=[db password]:password:' \
          '--CORS_ORIGINS=[CORS origins]:origins:' \
          '--STORAGE_TYPE=[storage]:type:(local s3 gcs azure)' \
          '--FLOWISE_FILE_SIZE_LIMIT=[max upload size]:limit:' \
          '--MODE=[runtime mode]:mode:(main queue)' \
          '--REDIS_URL=[Redis URL]:url:' && ret=0
        ;;
      (user)
        _arguments \
          '--email=[user email]:email:' \
          '--password=[new password]:password:' && ret=0
        ;;
    esac
    ;;
esac

return ret
