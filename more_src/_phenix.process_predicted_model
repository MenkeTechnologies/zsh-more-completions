#compdef phenix.process_predicted_model
# Phenix: process AlphaFold/RoseTTAFold predictions (trim, convert pLDDT, split domains)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'model=[input predicted model (PDB/mmCIF)]:file:_files -g "*.(pdb|cif)"' \
  'pae_file=[predicted alignment error matrix (JSON)]:file:_files -g "*.json"' \
  'chain_id=[process specific chain only]:chain:' \
  'selection=[process only selected model portion]:selection:' \
  'b_value_field_is=[B-value field type]:type:(plddt lddt rmsd b_value)' \
  'input_plddt_is_fractional=[pLDDT ranges 0-1 vs 0-100]:bool:(True False)' \
  'minimum_plddt=[confidence threshold (fractional)]:val:' \
  'maximum_rmsd=[error cutoff in Angstroms]:rmsd:' \
  'remove_low_confidence_residues=[trim uncertain regions]:bool:(True False)' \
  'split_model_by_compact_regions=[break into domains]:bool:(True False)' \
  'domain_size=[approximate domain size in Angstroms]:size:' \
  'maximum_domains=[domain limit]:n:' \
  'pae_power=[weighting exponent for PAE analysis]:power:' \
  'pae_cutoff=[PAE threshold for graph edges]:cutoff:' \
  'processed_model_prefix=[output filename prefix]:prefix:' \
  'target_output_format=[output format]:fmt:(pdb mmcif)' \
  '*:model file:_files -g "*.(pdb|cif)"' && ret=0

return ret
