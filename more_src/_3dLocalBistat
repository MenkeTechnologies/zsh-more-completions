#compdef 3dLocalBistat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLocalBistat.html
# AFNI: compute bivariate statistics between two datasets in a neighborhood

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-nbhd[neighborhood definition string]:nbhd:' \
  '*-stat[bivariate statistic to compute]:stat:(pearson spearman quadrant mutinfo normuti jointent hellinger crU crM crA num)' \
  '-mask[mask dataset]:mask:_files' \
  '-automask[create mask from input]' \
  '-weight[weight dataset]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-histpow[histogram bin width exponent]:p:' \
  '-histbin[number of histogram bins]:n:' \
  '-hclip1[clip first dataset to range]:a b:' \
  '-hclip2[clip second dataset to range]:a b:' \
  '*:dataset:_files' && ret=0

return ret
