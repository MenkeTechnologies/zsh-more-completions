#compdef DualSPHysics DualSPHysics5 DualSPHysics5_linux64
# Documentation: https://github.com/DualSPHysics/DualSPHysics/wiki/5.-Running-DualSPHysics
# DualSPHysics smoothed-particle hydrodynamics CFD solver

local ret=1

_arguments -s \
  '-h[show help on parameters]' \
  '-ver[show version information]' \
  '-opt[load configuration from file]:file:_files' \
  '-cpu[execute on CPU (default)]' \
  '-gpu[execute on GPU, optional :id]' \
  '-stable[ensure reproducible ordered operations]' \
  '-saveposdouble[save particle positions in double precision]' \
  '-svres[generate execution summary file]' \
  '-svtimers[report per-process computational time]' \
  '-svdomainvtk[generate domain limits VTK file]' \
  '-sv[output formats none,binx,ascii,vtk,csv,info]:formats:' \
  '-symplectic[symplectic time-stepping algorithm]' \
  '-verlet[Verlet time-stepping, optional :steps]' \
  '-cubic[cubic spline kernel]' \
  '-wendland[Wendland kernel]' \
  '-gaussian[Gaussian kernel]' \
  '-viscoart[artificial viscosity value]:value:' \
  '-viscolamsps[laminar+SPS viscosity value]:value:' \
  '-viscoboundfactor[boundary viscosity multiplier]:value:' \
  '-deltasph[Delta-SPH constant]:value:' \
  '-shifting[shifting correction none,nobound,nofixed,full]:mode:(none nobound nofixed full)' \
  '-tmax[maximum simulation time]:value:' \
  '-tout[time interval between output files]:value:' \
  '-ftpause[time before floating body activation]:value:' \
  '-partbegin[restart from output file index]:index:' \
  '-rhopout[density limits min:max for particle exclusion]:range:' \
  '-domain_particles[adjust domain to particles]:limits:' \
  '-domain_fixed[fixed domain limits]:values:' \
  '-incz[expand domain in z-direction]:value:' \
  '-cellmode[cell division mode]:mode:' \
  '-ompthreads[number of CPU OpenMP threads]:n:' \
  '-blocksize[CUDA kernel block size mode]:mode:' \
  '-name[case path and name]:name:_files' \
  '-runname[execution name]:name:' \
  '-dirout[output directory]:dir:_files -/' \
  '-dirdataout[binary data output subdirectory]:dir:_files -/' \
  '-createdirs[create full output paths]:flag:(0 1)' \
  '-csvsep[CSV separator 0=semicolon 1=comma]:flag:(0 1)' \
  '*:case:_files' && ret=0

return ret
