#compdef expac

# Zsh completion for expac - pacman database extraction utility

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-Q --query)'{-Q,--query}'[query the local database]' \
  '(-S --sync)'{-S,--sync}'[query the sync database]' \
  '(-s --search)'{-s,--search}'[search each package name]' \
  '(-g --group)'{-g,--group}'[list packages in groups]' \
  '(-H --humansize)'{-H,--humansize}'[human readable sizes]:unit:(B K M G T)' \
  '(-l --listdelim)'{-l,--listdelim}'[set list delimiter]:delimiter' \
  '(-d --delim)'{-d,--delim}'[set output delimiter]:delimiter' \
  '(-t --timefmt)'{-t,--timefmt}'[set strftime format]:format' \
  '(-1 --readone)'{-1,--readone}'[use first match only]' \
  '(-p --file)'{-p,--file}'[query a package file]:file:_files -g "*.pkg.tar.*"' \
  '(-v --verbose)'{-v,--verbose}'[show extra information]' \
  '1:format string' \
  '*:package'
