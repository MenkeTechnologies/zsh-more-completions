#compdef antsApplyTransformsToGifti
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/antsApplyTransformsToGifti.cxx — apply ANTs transforms to a GIfTI surface (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-p --precision)'{-p+,--precision=}'[float precision (0/1)]:n:(0 1)' \
    '(-i --input)'{-i+,--input=}'[input GIfTI surface]:file:_files -g "*.gii"' \
    '(-o --output)'{-o+,--output=}'[output GIfTI surface]:file:_files -g "*.gii"' \
    '*'{-t+,--transform=}'[transform (or [file,useInverse])]:transform:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
