#compdef cfm-id
# Documentation: https://hub.docker.com/r/wishartlab/cfmid
# cfm-id: identify a molecule from ESI-MS/MS spectra against candidates (CFM-ID)

local ret=1

_arguments -s \
  '1:spectrum_file (.msp or peak list):_files' \
  '2:id (target molecule identifier):' \
  '3:candidate_file (id + SMILES/InChI pairs):_files' \
  '4:num_highest (top results, -1 for all):' \
  '5:ppm_mass_tol:' \
  '6:abs_mass_tol:' \
  '7:prob_thresh:' \
  '8:param_file (trained model parameters):_files' \
  '9:config_file (model configuration):_files' \
  '10:score_type:(Jaccard Dice DotProduct)' \
  '11:apply_postprocessing:(0 1)' \
  '12:output_file:_files' \
  '13:output_msp_or_mgf:_files' && ret=0

return ret
