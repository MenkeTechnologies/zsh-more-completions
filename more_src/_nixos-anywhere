#compdef nixos-anywhere
# Documentation: https://github.com/nix-community/nixos-anywhere (src/nixos-anywhere.sh)
# Reference accessed: 2026-05-29
# Install NixOS to remote hosts via SSH+kexec+disko.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --flake)'{-f,--flake=}'[flake URI to install (e.g. .#mymachine)]:uri:' \
  '--target-host=[SSH target host]:user@host:_hosts' \
  '-i+[SSH identity file]:file:_files' \
  '(-p --ssh-port)'{-p,--ssh-port=}'[SSH connection port]:port:' \
  '*--ssh-option=[additional SSH option]:option:' \
  '(-L --print-build-logs)'{-L,--print-build-logs}'[print full build logs]' \
  '--env-password[use SSHPASS env var for ssh-copy-id]' \
  '(-s --store-paths)'{-s,--store-paths}'[provide direct store paths instead of building from flake]:disko-script: :nixos-system:' \
  '--kexec=[custom kexec tarball for bootstrapping]:path:_files' \
  '--force-kexec[run kexec even if already in installer]' \
  '--kexec-extra-flags=[additional flags for kexec execution]:flags:' \
  '*--ssh-store-setting=[SSH store setting key value]:key: :value:' \
  '--post-kexec-ssh-port=[SSH port after kexec (default 22)]:port:' \
  '--copy-host-keys[copy existing SSH host keys to installation]' \
  '*--extra-files=[recursively copy local files to root of new system]:path:_files -/' \
  '*--chown=[change file ownership]:path:_files -/:ownership:' \
  '*--disk-encryption-keys=[copy encryption keys to installer]:remote_path: :local_path:_files' \
  '--no-substitute-on-destination[disable substitute-on-destination during copy]' \
  '--no-use-machine-substituters[skip copying substituters from target machine]' \
  '--debug[enable debug output]' \
  '--show-trace[show Nix build traces]' \
  '*--option=[pass Nix option]:key: :value:' \
  '--from=[source Nix store URL]:uri:' \
  '--build-on-remote[build closure on remote machine (deprecated)]' \
  '--vm-test[test disk configuration in VM without installing]' \
  '--generate-hardware-config=[generate hardware config (backend path)]:backend:(nixos-facter nixos-generate-config):path:_files' \
  '--phases=[comma-separated phases to run]:phases:_values -s , phase kexec disko install reboot' \
  '--disko-mode=[disko mode]:mode:(disko mount format)' \
  '--no-disko-deps[skip uploading partitioning tool dependencies]' \
  '--build-on=[build location]:mode:(auto local remote)' \
  '*: :->dest' && ret=0

case $state in
  dest)
    _alternative \
      'hosts:remote host:_hosts' \
      'flake-target:flake target:'
    ret=0
    ;;
esac

return ret
