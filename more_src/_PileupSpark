#compdef PileupSpark
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/spark/PileupSpark.java
# Prints read alignments in samtools pileup format on Spark

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[output directory for scattered output]:dir:_files -/' \
  '(-verbose --show-verbose)'{-verbose,--show-verbose}'[add extra informative columns to pileup output]' \
  '*--metadata=[features file(s) containing metadata]:file:_files' \
  '--output-insert-length[add insert lengths to the output pileup]' \
  '*'{-L,--intervals}'=[genomic intervals to operate over]:intervals:' \
  '--spark-master=[URL of the Spark master to submit jobs to]:url:' \
  '--num-reducers=[number of reducers for Spark]:n:' \
  '*--conf=[Spark property name=value]:conf:' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
