#compdef ccget ccwrite ccframe cda
# Documentation: source-direct extraction from upstream
# cclib/cclib pyproject.toml [project.scripts] entry-point
# registration:
#   ccget   = "cclib.scripts.ccget:ccget"
#   ccwrite = "cclib.scripts.ccwrite:main"
#   ccframe = "cclib.scripts.ccframe:main"
#   cda     = "cclib.scripts.cda:main"
# Per-script argparse `add_argument(...)` declarations decoded
# source-direct from each cclib/scripts/<name>.py module.
# ccget mutex group (--list XOR --json XOR --multi) decoded
# source-direct from `group = parser.add_mutually_exclusive_
# group()`.  Enum autocompletes decoded source-direct from
# `choices=(...)` keyword args.
# Reference accessed: 2026-05-30 via gh api.
# cclib R185 — follow-up to R184's hunt-skip note on "cclib
# provides 4 CLI binaries (ccget/ccwrite/ccfind/ccframework) -
# deferred for a separate harvest".  Actual upstream binary
# names are ccget/ccwrite/ccframe/cda (correcting R184's
# original naming: ccfind/ccframework do NOT exist in upstream;
# cda is the 4th binary).  cclib is the open-source Python
# library for parsing logfiles from computational-chemistry
# packages (Gaussian, GAMESS, ORCA, NWChem, Psi4, VASP, Q-Chem,
# Turbomole, Molpro, etc.) and the 4 binaries expose its
# parsing surface as standalone CLI tools.  Sister tools to the
# heavily-covered computational chemistry family (psi4/nwchem/
# vasp/quantum-espresso/gmx/mdtraj/antechamber/amber/cpptraj/
# vmd/pymol/ovito/pyscf/gabedit + R184 pmg) already in the
# corpus.

case $service in

  ccget)
    # Extract specific attributes from compchem logfile(s).
    # Variadic positional accepts attribute-names AND logfile-
    # paths interleaved - the parser distinguishes via
    # ccData._attrlist membership + fuzzy-match fallback +
    # URL/file/glob detection (decoded source-direct from the
    # `for arg in arglist:` arg-classification loop).
    _arguments -s -S \
      '(--list -l --json -j --multi -m)'{--list,-l}'[print a list of attributes available in each file]' \
      '(--list -l --json -j --multi -m)'{--json,-j}'[given logfile is in CJSON format]' \
      '(--list -l --json -j --multi -m)'{--multi,-m}'[parse multiple input files as one input stream]' \
      '(--verbose -v)'{--verbose,-v}'[more verbose parsing output (only errors by default)]' \
      '(--future -u)'{--future,-u}'[use experimental features (currently optdone_as_list)]' \
      '(--full -f)'{--full,-f}'[toggle full print behaviour for attributes]' \
      '*:attribute name or compchem logfile path:_files'
    ;;

  ccwrite)
    # Convert compchem logfile(s) to JSON/CJSON/CML/XYZ/Molden/
    # WFX format.
    _arguments -s -S \
      '(-v --verbose)'{-v,--verbose}'[more verbose parsing output (only errors by default)]' \
      '(-g --ghost)'{-g+,--ghost=}'[symbol to use for ghost atoms]:symbol:' \
      '(-t --terse)'{-t,--terse}'[CJSON output not indented (saves space)]' \
      '(-u --future)'{-u,--future}'[use experimental features (currently optdone_as_list)]' \
      '(-i --index)'{-i+,--index=}'[zero-based index for which structure to extract]:n:' \
      '(-n --naturalorbitals)'{-n,--naturalorbitals}'[(molden only) write natural orbitals instead of molecular orbitals]' \
      '1:output format:(json cjson cml xyz molden wfx)' \
      '*:compchem logfile to parse and convert:_files'
    ;;

  ccframe)
    # Parse logfile(s) into a pandas DataFrame and write to disk.
    # Output format inferred from the -O file extension.
    _arguments -s -S \
      '(-O --output)'{-O+,--output=}'[output document (extension determines format)]:file:_files -g "*.(csv|h5|hdf|hdf5|json|pickle|pkl|xlsx)"' \
      '--identifier=[sheet name (xlsx) or HDFStore group identifier (default logfiles)]:name:' \
      '(-f --force)'{-f,--force}'[overwrite output file if it exists]' \
      '*:compchem logfile to parse and convert:_files'
    ;;

  cda)
    # Charge Decomposition Analysis between a supermolecule and
    # two fragments.  No flags - just 3 positional logfiles.
    _arguments -s -S \
      '1:logfile containing the supermolecule:_files' \
      '2:logfile containing the first fragment:_files' \
      '3:logfile containing the second fragment:_files'
    ;;

esac
