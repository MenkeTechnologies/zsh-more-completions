#compdef genrestr gmx-genrestr
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-genrestr.html
# Generate a topology include file with position or distance restraints

local ret=1

_arguments -s -S \
  '-f+[structure file]:structure:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-o+[include file for topology]:itp file:_files -g "*.itp"' \
  '-of+[index file for freezing atoms]:index file:_files -g "*.ndx"' \
  '-fc+[force constants kJ/mol nm^2]:vector:' \
  '-freeze+[B-factor threshold for atom selection]:value:' \
  '-disre_dist+[distance range for restraints nm]:value:' \
  '-disre_frac+[fraction of distance as interval]:value:' \
  '-disre_up2+[distance for constant force region]:value:' \
  '-cutoff+[cutoff distance for atom pairs nm]:value:' \
  '-disre[generate distance restraint matrix]' \
  '-constr[generate constraint matrix instead]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
