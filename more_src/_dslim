#compdef dslim slim docker-slim
# _dslim — container optimization tool that minifies Docker images (slimtoolkit/slim)
# upstream: https://github.com/slimtoolkit/slim

_dslim() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--report=[report output file]:path:_files' \
        '--check-version[check for new version]' \
        '--debug[enable debug logging]' \
        '--verbose[enable verbose logging]' \
        '--log-level=[set log level]:level:(debug info warn error fatal panic trace)' \
        '--log=[log output file]:path:_files' \
        '--log-format=[log format]:format:(text json)' \
        '--quiet[suppress output]' \
        '--output-format=[output format]:format:(text json)' \
        '--tls[use TLS]' \
        '--tls-verify[verify TLS]' \
        '--tls-cert-path=[TLS cert path]:path:_directories' \
        '--host=[Docker host]:host:' \
        '--state-path=[state directory path]:path:_directories' \
        '--archive-state=[archive state path]:path:_files' \
        '--in-container[run in container mode]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_dslim_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)
                    _arguments \
                        '--target=[target image]:image:' \
                        '*--tag=[image tag for optimized image]:name:' \
                        '--http-probe[enable HTTP probing]' \
                        '*--http-probe-cmd=[HTTP probe commands]:cmd:' \
                        '*--http-probe-port=[HTTP probe ports]:port:' \
                        '--show-clogs[show container logs]' \
                        '--show-blogs[show build logs]' \
                        '--copy-meta-artifacts=[copy meta artifacts]:path:_directories' \
                        '--remove-file-artifacts[remove file artifacts]' \
                        '*--include-path=[include path in minified image]:path:_files' \
                        '--include-path-file=[file with paths to include]:path:_files' \
                        '*--include-bin=[include binary and deps]:binary:_command_names' \
                        '*--include-exe=[include executable and deps]:exe:_command_names' \
                        '--include-shell[include shell]' \
                        '*--mount=[mount volume]:src\:dst:' \
                        '--entrypoint=[override entrypoint]:cmd:' \
                        '--cmd=[override CMD]:cmd:' \
                        '--workdir=[override workdir]:path:_directories' \
                        '*--env=[set environment variable]:key=val:' \
                        '*--expose=[expose port]:port:' \
                        '--new-entrypoint=[new entrypoint for optimized image]:cmd:' \
                        '--new-cmd=[new cmd for optimized image]:cmd:' \
                        '*--new-expose=[new exposed port for optimized image]:port:' \
                        '--new-workdir=[new workdir for optimized image]:path:_directories' \
                        '*--new-env=[new env var for optimized image]:key=val:' \
                        '--image-overrides=[image instruction overrides]:json:' \
                        '--continue-after=[continue after mode]:mode:(probe exec signal timeout)' \
                        '--use-local-mounts[use local mounts]' \
                        '--use-sensor-volume=[use sensor volume]:name:' \
                        '--keep-tmp-artifacts[keep temp artifacts]' \
                        '*--exec=[execute command in container]:cmd:' \
                        '--exec-file=[file with commands to execute]:path:_files' \
                        '*--publish-port=[publish port]:port:' \
                        '--publish-exposed-ports[publish all exposed ports]' \
                        '--network=[network to use]:name:' \
                        '--dockerfile=[Dockerfile path]:path:_files' \
                        '--delete-generated[delete generated artifacts]' \
                        '--compose-file=[Docker Compose file]:path:_files -g "*(docker-compose|compose)*.y(a|)ml"' && ret=0 ;;
                xray)
                    _arguments \
                        '--target=[target image]:image:' \
                        '--changes=[change types to show]:type:(none all delete modify add)' \
                        '--layer=[show specific layer]:index:' \
                        '--add-image-manifest[add image manifest]' \
                        '--add-image-config[add image config]' \
                        '--detect-duplicates[detect duplicate files]' \
                        '--show-special-perms[show special permissions]' \
                        '--detect-all-certs[detect all certificates]' \
                        '--detect-all-cert-pks[detect all certificate private keys]' \
                        '--hash-data[hash file data]' \
                        '--top-changes-max=[max top changes to show]:n:' && ret=0 ;;
                lint)
                    _arguments \
                        '--target=[target Dockerfile]:path:_files -g "*Dockerfile*"' \
                        '--target-type=[target type]:type:(dockerfile image)' \
                        '--skip-build-context[skip build context]' \
                        '--build-context-dir=[build context directory]:path:_directories' \
                        '--skip-dockerignore[skip .dockerignore]' && ret=0 ;;
                profile)
                    _arguments \
                        '--target=[target image]:image:' && ret=0 ;;
                run)
                    _arguments \
                        '--target=[target image]:image:' \
                        '*:args:' && ret=0 ;;
                convert)
                    _arguments \
                        '--target=[target image]:image:' \
                        '*:args:' && ret=0 ;;
                merge)
                    _arguments \
                        '*--image=[image to merge]:image:' \
                        '*:args:' && ret=0 ;;
                registry)
                    _arguments '*:args:' && ret=0 ;;
                vulnerability)
                    _arguments \
                        '--target=[target image]:image:' \
                        '*:args:' && ret=0 ;;
                images)
                    _arguments '*:args:' && ret=0 ;;
                version|help|update) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_dslim_commands] )) ||
_dslim_commands() {
    local -a commands
    commands=(
        'build:analyze and optimize a container image'
        'xray:analyze a container image'
        'lint:lint a Dockerfile'
        'profile:profile a container image'
        'version:show version'
        'help:show help'
        'update:update dslim'
        'images:list images'
        'merge:merge container images'
        'registry:manage registries'
        'vulnerability:scan for vulnerabilities'
        'run:run a container'
        'convert:convert container images'
    )
    _describe -t commands 'dslim command' commands
}

_dslim "$@"
