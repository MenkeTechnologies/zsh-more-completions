#compdef argo
# _argo-cli — Argo Workflows CLI (Argo Project + CNCF, Go); manage Argo Workflows on k8s
# upstream: https://github.com/argoproj/argo-workflows

_argo-cli() {
    local -a sub=(
        'archive:archive commands'
        'auth:auth tokens commands'
        'cluster-template:cluster workflow templates'
        'completion:print shell completion'
        'cp:copy artifacts'
        'cron:cron workflows'
        'delete:delete a workflow'
        'executor-plugin:executor plugins'
        'get:get a workflow'
        'lint:lint a workflow'
        'list:list workflows'
        'logs:view workflow logs'
        'node:node commands'
        'resubmit:resubmit a workflow'
        'resume:resume a workflow'
        'retry:retry a workflow'
        'server:start an Argo server'
        'stop:stop a workflow'
        'submit:submit a workflow'
        'suspend:suspend a workflow'
        'template:workflow templates'
        'terminate:terminate a workflow'
        'version:show version'
        'wait:wait for workflows to complete'
        'watch:watch a workflow'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--argo-base-href+[server base href]:str:' \
        '--argo-http1[use HTTP/1]' \
        '--argo-server+[server addr]:host:port:' \
        '-s+[server addr]:host:port:' \
        '--as+[impersonate user]:user:' \
        '--as-group+[impersonate group]:group:' \
        '--certificate-authority+[CA cert]:file:_files' \
        '--client-certificate+[client cert]:file:_files' \
        '--client-key+[client key]:file:_files' \
        '--cluster+[k8s cluster]:cluster:' \
        '--context+[kube context]:context:' \
        '--gloglevel+[glog level]:n:' \
        '--header+[header to send]:header:' \
        '--http1[use HTTP/1]' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '-k[skip TLS verify]' \
        '--instanceid+[instance id]:str:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--loglevel+[log level]:level:(debug info warn error fatal panic)' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--password+[password]:str:' \
        '--request-timeout+[request timeout]:duration:' \
        '--server+[server addr]:host:_hosts' \
        '--token+[bearer token]:str:' \
        '--user+[kubeconfig user]:user:' \
        '--username+[username]:user:_users' \
        '-v+[log verbosity]:n:' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argo subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments '*:workflow file:_files' \
                    '-p+[parameter]:KEY=VAL:' \
                    '--parameter+[parameter]:KEY=VAL:' \
                    '-f+[parameters file]:file:_files' \
                    '--from+[from resource]:resource:' \
                    '--name+[workflow name]:str:' \
                    '--generate-name+[workflow generate name]:str:' \
                    '--wait[wait]' \
                    '-w[watch]' \
                    '--log[print logs while running]' \
                    '--watch[watch]' ;;
                list|get|delete|stop|suspend|resume|terminate|resubmit|retry|wait|watch|logs) _arguments '*:workflow:' ;;
                lint) _arguments '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-cli "$@"
