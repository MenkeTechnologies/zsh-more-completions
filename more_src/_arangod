#compdef arangod arangoimport arangoexport arangobench arangobackup arangoinspect arangovpack arangodump
# Documentation: https://docs.arangodb.com/3.12/components/arangodb-server/options/
# Reference accessed: 2026-05-29
# ArangoDB server + sibling client tools. They share the --server.* and --log.* option families.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--dump-options[print all CLI options as JSON]' \
  '(- *)--dump-dependencies[print module dependencies as JSON]' \
  '*--config=[load options from configuration file]:file:_files -g "*.conf"' \
  '*-c+[load options from configuration file]:file:_files -g "*.conf"' \
  '--check-configuration[validate config file and exit]' \
  '--default-language=[default language (ISO-639 code)]:lang:' \
  '--icu-language=[default language as ICU locale]:lang:' \
  '--server.endpoint=[server endpoint (tcp\://host\:port, ssl\://host\:port, unix\://path)]:endpoint:' \
  '--server.authentication=[enable authentication]:bool:(true false)' \
  '--server.authentication-system-only=[only authenticate _system requests]:bool:(true false)' \
  '--server.authentication-timeout=[authentication cache timeout (seconds)]:seconds:' \
  '--server.authentication-unix-sockets=[disable authentication for unix sockets]:bool:(true false)' \
  '--server.jwt-secret=[JWT authentication secret]:secret:' \
  '--server.jwt-secret-folder=[folder containing JWT secrets]:dir:_directories' \
  '--server.io-threads=[number of I/O threads]:n:' \
  '--server.maximal-threads=[maximum worker threads]:n:' \
  '--server.minimal-threads=[minimum worker threads]:n:' \
  '--server.scheduler-queue-size=[scheduler queue size]:n:' \
  '--server.statistics=[enable statistics gathering]:bool:(true false)' \
  '--server.statistics-history=[enable statistics history]:bool:(true false)' \
  '--server.storage-engine=[storage engine]:engine:(auto rocksdb mmfiles)' \
  '--database.directory=[database directory]:dir:_directories' \
  '--database.auto-upgrade[perform database upgrade at startup]' \
  '--database.maximal-journal-size=[max journal size in bytes]:bytes:' \
  '--database.password=[default password for new databases]:password:' \
  '--database.required-directory-state=[required state of directory]:state:(any non-existent existing empty populated service-data)' \
  '--query.memory-limit=[max memory per AQL query (bytes)]:bytes:' \
  '--query.tracking=[enable slow query tracking]:bool:(true false)' \
  '--query.optimizer-rules=[enable/disable optimizer rules]:rules:' \
  '--query.parallelize-traversals=[parallelize traversals]:bool:(true false)' \
  '--javascript.v8-contexts=[max V8 contexts]:n:' \
  '--javascript.v8-contexts-minimum=[min V8 contexts]:n:' \
  '--javascript.startup-directory=[JS startup directory]:dir:_directories' \
  '--javascript.app-path=[Foxx app path]:dir:_directories' \
  '--javascript.enabled=[enable JavaScript subsystem]:bool:(true false)' \
  '--javascript.copy-installation=[copy JS installation files to database dir]:bool:(true false)' \
  '--foxx.queues=[enable Foxx queue processing]:bool:(true false)' \
  '--foxx.queues-poll-interval=[Foxx queue poll interval (seconds)]:seconds:' \
  '--rocksdb.enable-statistics=[enable RocksDB statistics]:bool:(true false)' \
  '--rocksdb.block-cache-size=[RocksDB block cache size (bytes)]:bytes:' \
  '--rocksdb.max-background-jobs=[RocksDB max background jobs]:n:' \
  '--rocksdb.max-write-buffer-number=[max write buffer number]:n:' \
  '--rocksdb.write-buffer-size=[RocksDB write buffer size]:bytes:' \
  '--rocksdb.target-file-size-base=[target file size base (bytes)]:bytes:' \
  '--rocksdb.encryption-keyfile=[encryption key file]:file:_files' \
  '--cluster.my-address=[my external endpoint in cluster]:endpoint:' \
  '--cluster.my-role=[my role in cluster]:role:(DBSERVER COORDINATOR AGENT SINGLE)' \
  '--cluster.agency-endpoint=[agency endpoint]:endpoint:' \
  '--cluster.write-concern=[default cluster write concern]:n:' \
  '--cluster.replication-factor=[default replication factor]:n:' \
  '--cluster.create-waits-for-sync-replication=[wait for sync replication]:bool:(true false)' \
  '--ssl.cafile=[CA file]:file:_files' \
  '--ssl.cipher-list=[OpenSSL cipher list]:list:' \
  '--ssl.keyfile=[SSL key file]:file:_files' \
  '--ssl.session-cache=[enable SSL session cache]:bool:(true false)' \
  '--ssl.protocol=[SSL protocol]:proto:(unknown sslv2 sslv23 sslv3 tlsv1 tlsv12 tlsv13)' \
  '--log.level=[log level]:level:(fatal error warning info debug trace)' \
  '*--log.output=[log output target]:target:(stdout stderr syslog file://path)' \
  '--log.use-local-time=[use local time in logs]:bool:(true false)' \
  '--log.use-microtime=[use microsecond precision]:bool:(true false)' \
  '--log.role=[log role information]:bool:(true false)' \
  '--log.file=[log file path]:file:_files' \
  '--log.foreground-tty=[output to TTY when in foreground]:bool:(true false)' \
  '--temp.path=[temporary directory path]:dir:_directories' \
  '--daemon[run server as background process (requires --pid-file)]' \
  '--supervisor[enable automatic restart on unexpected termination]' \
  '--uid=[user identity for server process]:user:_users' \
  '--gid=[group identity for server process]:group:_groups' \
  '--pid-file=[process ID file location]:file:_files' \
  '--console[launch interactive emergency console (disables networking)]' \
  '*: :_files' && ret=0

return ret
