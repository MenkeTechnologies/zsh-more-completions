#compdef llvm-mt
# _llvm-mt — LLVM Microsoft manifest tool (LLVM project, C++); merge/embed Windows manifests
# upstream: https://github.com/llvm/llvm-project

_llvm-mt() {
    _arguments \
        '/?[show help]' \
        '/help[show help]' \
        '--help[show help]' \
        '/version[show version]' \
        '--version[show version]' \
        '/manifest+[manifest file]:file:_files' \
        '/identity+[identity]:str:' \
        '/rgs+[rgs file]:file:_files' \
        '/tlb+[tlb file]:file:_files' \
        '/dll+[dll file]:file:_files' \
        '/replacements+[replacements file]:file:_files' \
        '/managedassemblyname+[managed assembly]:str:' \
        '/nologo[no logo]' \
        '/notify_update[notify update]' \
        '/hashupdate+[hash update]:file:_files' \
        '/makecdfs+[make cdfs]:file:_files' \
        '/validate_manifest[validate manifest]' \
        '/validate_file_hashes+[validate file hashes]:file:_files' \
        '/canonicalize[canonicalize]' \
        '/check_for_duplicates[check for duplicates]' \
        '/inputresource+[input resource]:file:_files' \
        '/out+[output file]:file:_files' \
        '/outputresource+[output resource]:file:_files' \
        '*:file:_files'
}

_llvm-mt "$@"
