#compdef BandSelect
# Documentation: https://step.esa.int/main/wp-content/help/versions/12.0.0/snap-toolboxes/eu.esa.microwavetbx.sar.op.utilities.ui/operators/BandSelectOp.html
# ESA SNAP gpt BandSelect operator - select bands by polarisation, name or pattern

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PselectedPolarisations=[the list of polarisations]:polarisations' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PbandNamePattern=[band name regular expression pattern]:pattern' \
  '*:graph xml:_files' && ret=0

return ret
