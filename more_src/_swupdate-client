#compdef swupdate-client
# Documentation: source-direct extraction from upstream
# sbabic/swupdate tools/swupdate-client.c lines 36-51 (usage)
# + line 194 (`getopt(argc, argv, "dhqvpe:g:s:")`).
# Reference accessed: 2026-05-30 via gh api.
# Sister tool to R210's swupdate.  swupdate-client is the
# IPC-based driver that pushes a .swu image into a running
# SWUpdate daemon over its control socket (default
# /tmp/sockinstctrl) and watches progress over the progress
# socket (default /tmp/swupdateprog).  When called with no swu
# file (or `-`), reads the image from STDIN — useful for
# piping a remote download straight in:
#   curl https://... | swupdate-client -v -e stable,main -

# Short-only options decoded source-direct from getopt(3)
# string "dhqvpe:g:s:".  swupdate-client uses bare getopt (NOT
# getopt_long), so there are NO long-form aliases — every flag
# is single-letter.

_arguments -s -S \
  '-h[print help and exit]' \
  '-d[ask the server to only perform a dry-run]' \
  '-q[go quiet, reset verbosity]' \
  '-v[go verbose, print upgrade status messages from server]' \
  '-p[ask the server to run post-update commands if upgrade succeeds]' \
  '-e+[select software-images set + source (format: <set>,<mode> e.g. stable,main)]:select:' \
  '-s+[path to SWUpdate IPC control socket (default /tmp/sockinstctrl)]:socket:_files' \
  '-g+[path to SWUpdate progress socket (default /tmp/swupdateprog)]:socket:_files' \
  '*:swu image (or - / omit to read from STDIN):_files -g "*.swu"'
