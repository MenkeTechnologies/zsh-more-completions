#compdef catalog-operator catalog
# _catalog-operator — OLMv0 catalog operator (CatalogSource/InstallPlan reconciler)
# upstream: https://github.com/operator-framework/operator-lifecycle-manager
# Flags from cmd/catalog/start.go on tip.

_catalog-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print OLM version and exit]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--namespace=[catalog operator namespace]:ns:' \
        '--configmapServerImage=[image used to serve configmap-based catalogs]:image:' \
        '--opmImage=[image used to unpack bundle content with opm]:image:' \
        '--util-image=[image containing OLM utilities]:image:' \
        '--writeStatusName=[ClusterOperator name to write status to ("" disables)]:name:' \
        '--set-workload-user-id[run registry/unpack workloads as uid 1001]' \
        '--debug[enable debug log level]' \
        '--tls-key=[TLS private key file]:file:_files' \
        '--tls-cert=[TLS certificate file]:file:_files' \
        '--client-ca=[watch path for client-CA bundle]:file:_files' \
        '--interval=[wake-up interval]:dur:' \
        '--bundle-unpack-timeout=[bundle unpack timeout]:dur:' \
        '--install-plan-retry-timeout=[InstallPlan fatal-error timeout]:dur:' \
        '-v[klog verbosity level]:n:'
}

_catalog-operator "$@"
