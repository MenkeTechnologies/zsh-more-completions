#compdef elasticsearch-setup-passwords

# elasticsearch-setup-passwords: set built-in user passwords (auto/interactive)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-b[batch mode]' \
  '--batch[batch mode]' \
  '-u[cluster URL]:url:' \
  '--url=[cluster URL]:url:' \
  '-E[config setting key=value]:kv:' \
  '1:mode:(auto interactive)' && ret=0
return ret
