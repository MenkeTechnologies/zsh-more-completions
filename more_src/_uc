#compdef uc

local curcontext="$curcontext" state line ret=1
local -a entities

entities=(
  'auth:authentication operations'
  'catalog:manage catalogs'
  'schema:manage schemas'
  'volume:manage volumes'
  'table:manage tables'
  'metastore:manage metastores'
  'credential:manage credentials'
  'external_location:manage external locations'
  'function:manage and call functions'
  'registered_model:manage registered models'
  'model_version:manage model versions'
  'permission:manage permissions'
  'user:manage users'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--server=[Unity Catalog server URI]:url:' \
  '--auth_token=[auth bearer token]:token:' \
  '--output=[output format]:format:(json yaml table)' \
  '1: :->entity' \
  '*::arg:->args' && ret=0

case $state in
  (entity)
    _describe -t entities 'uc entity' entities && ret=0
    ;;
  (args)
    case $line[1] in
      (catalog|schema|volume|table|metastore|credential|external_location|registered_model|model_version|user)
        _values 'action' \
          'create' 'list' 'get' 'update' 'delete' && ret=0
        ;;
      (function)
        _values 'function action' \
          'create' 'list' 'get' 'delete' 'call' && ret=0
        ;;
      (permission)
        _values 'permission action' \
          'create' 'get' 'update' 'delete' && ret=0
        ;;
      (auth)
        _values 'auth action' 'login' && ret=0
        ;;
    esac
    ;;
esac

return ret
