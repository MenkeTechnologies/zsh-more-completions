#compdef mSubimage
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mSubimage.html
# Extract a rectangular subimage from a FITS file by sky or pixel location

local ret=1

_arguments -s -S \
  '-p[pixel mode: use pixel locations instead of sky]' \
  '-d[enable diagnostic output]' \
  '-a[force retrieval of whole image]' \
  '-h+[operate on specified FITS extension (HDU)]:hdu' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '*:argument:_files' && ret=0

return ret
