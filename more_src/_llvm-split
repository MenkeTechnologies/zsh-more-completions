#compdef llvm-split
# _llvm-split — LLVM module splitter (LLVM project, C++); split a module into N partitions for parallel compilation
# upstream: https://github.com/llvm/llvm-project

_llvm-split() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output prefix]:file:_files' \
        '-j+[number of partitions]:n:' \
        '--preserve-locals[preserve locals]' \
        '--mcpu=+[cpu]:cpu:' \
        '--mtriple=+[triple]:triple:' \
        '*:file:_files -g "*.(bc|ll)"'
}

_llvm-split "$@"
