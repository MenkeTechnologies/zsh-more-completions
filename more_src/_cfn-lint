#compdef cfn-lint

_cfn-lint() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)--version[Show version]' \
    '--list-rules[List all available rules]' \
    {-t,--template}'[CloudFormation template file]:file:_files -g "*.(json|yaml|yml|template)"' \
    {-b,--ignore-bad-template}'[Ignore bad template errors]' \
    {-f,--format}'[Output format]:format:(default json quiet parseable pretty-print sarif)' \
    {-l,--include-checks}'[Include specific rules]:rules:' \
    {-e,--include-experimental}'[Include experimental rules]' \
    {-x,--configure-rule}'[Configure a rule]:config:' \
    {-c,--ignore-checks}'[Ignore specific rules]:rules:' \
    {-I,--include-checks}'[Include additional rules]:rules:' \
    {-a,--append-rules}'[Append custom rules directory]:dir:_directories' \
    {-o,--override-spec}'[Override spec file]:file:_files -g "*.json"' \
    {-r,--regions}'[AWS regions to validate]:region:' \
    {-i,--ignore-templates}'[Templates to ignore]:templates:' \
    {-u,--update-specs}'[Update the CloudFormation specs]' \
    {-D,--debug}'[Enable debug logging]' \
    '--non-zero-exit-code[Non-zero exit code]:mode:(none informational warning error)' \
    '--merge-configs[Merge configs from multiple files]:files:_files' \
    '--config-file[Path to config file]:file:_files' \
    '--registry-schemas[Additional registry schemas]:dir:_directories' \
    '--force[Force re-download of specs]' \
    '*:template:_files -g "*.(json|yaml|yml|template)"'
}

_cfn-lint "$@"
