#compdef rpm2cpio
# Documentation: https://man.archlinux.org/search?q=rpm2cpio
# Reference accessed: 2026-05-16

# Zsh completion for rpm2cpio - extract cpio archive from RPM package

_arguments \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:rpm file:_files -g "*.rpm"'
