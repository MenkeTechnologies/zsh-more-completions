#compdef opencti-cli opencti octi
# _opencti-cli — Filigran OpenCTI opencti-cli CLI command-line frontend wrapping the OpenCTI Open Cyber Threat Intelligence open-source CTI threat intelligence platform STIX2-OASIS-compliant TAXII2 MISP MITRE-ATT&CK observables indicators threat-actor intrusion-set campaign malware infrastructure attack-pattern vulnerability identity location report case incident artifact tool channel narrative event grouping note opinion case-rfi case-rft data-component data-source x-opencti-killchain-phase (Filigran team Samuel Hassine, Python/JavaScript); click
# upstream: https://www.opencti.io/

_opencti-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'indicator:indicator operations'
        'observable:observable operations'
        'threat-actor:threat actor operations'
        'intrusion-set:intrusion set operations'
        'campaign:campaign operations'
        'malware:malware operations'
        'infrastructure:infrastructure operations'
        'attack-pattern:attack pattern operations'
        'vulnerability:vulnerability operations'
        'identity:identity operations'
        'location:location operations'
        'report:report operations'
        'case-incident:case-incident operations'
        'case-rfi:case-RFI operations'
        'case-rft:case-RFT operations'
        'artifact:artifact operations'
        'tool:tool operations'
        'channel:channel operations'
        'narrative:narrative operations'
        'event:event operations'
        'grouping:grouping operations'
        'note:note operations'
        'opinion:opinion operations'
        'taxii:TAXII operations'
        'connector:connector operations'
        'stream:stream operations'
        'import:import data'
        'export:export data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml *.json"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml *.json"' \
        '-o+[format]:f:(json yaml table stix2)' \
        '--output=+[format]:f:(json yaml table stix2)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opencti subcommand' sub ;;
        args)
            case $words[1] in
                indicator|observable|threat-actor|intrusion-set|campaign|malware|infrastructure|attack-pattern|vulnerability|identity|location|report|case-incident|case-rfi|case-rft|artifact|tool|channel|narrative|event|grouping|note|opinion) _arguments '1:op:(list get create update delete merge enrich)' '*:id:' ;;
                taxii) _arguments '1:op:(collection discover poll)' '*:arg:' ;;
            esac
            ;;
    esac
}

_opencti-cli "$@"
