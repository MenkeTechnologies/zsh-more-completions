#compdef cf-agent
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-agent.html
# Source: cfengine/core cf-agent/cf-agent.c — CFEngine configuration agent.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --timing-output)'{-t,--timing-output}'[output timing info in verbose mode]' \
    '(-w --workdir)'{-w+,--workdir=}'[override work directory]:dir:_directories' \
    '(-f --file)'{-f+,--file=}'[alternative input file]:file:_files' \
    '(-b --bundlesequence)'{-b+,--bundlesequence=}'[override bundlesequence]:bundles:_default' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-B --bootstrap)'{-B+,--bootstrap=}'[bootstrap to policy server]:server:_default' \
    '(-K --no-lock)'{-K,--no-lock}'[ignore locking constraints]' \
    '(-D --define)'{-D+,--define=}'[define classes at startup]:classes:_default' \
    '(-N --negate)'{-N+,--negate=}'[undefine classes at startup]:classes:_default' \
    '(-I --inform)'{-I,--inform}'[print basic info about system changes]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-g --log-level)'{-g+,--log-level=}'[verbosity level]:level:(error warning notice info verbose debug)' \
    '(-n --dry-run)'{-n,--dry-run}'[dry-run, no changes]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '-M[generate manpage output]' \
    '(-x --self-diagnostics)'{-x,--self-diagnostics}'[run installation diagnostics]' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '(-E --no-extensions)'{-E,--no-extensions}'[disable extension loading]' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps on each line]' \
    '(-T --trust-server)'{-T+,--trust-server=}'[trust server during bootstrap]:choice:(yes no)' \
    '(-p --profile)'{-p+,--profile=}'[output bundle execution diagnostic]:profile:_default' \
    '--ignore-preferred-augments[skip def_preferred.json]' \
    '*--log-modules=[detailed debug logging for module]:module:_default' \
    '--no-augments[do not load def.json]' \
    '--no-host-specific-data[skip host_specific.json]' \
    '--show-evaluated-classes=[show final classes (optional regex filter)]:filter:_default' \
    '--show-evaluated-vars=[show final variables (optional regex filter)]:filter:_default' \
    '--skip-bootstrap-policy-run[do not run policy at end of bootstrap]' \
    '--skip-bootstrap-service-start[do not start services during bootstrap]' \
    '--skip-db-check[skip DB integrity checks at startup]' \
    '--simulate=[simulation mode]:mode:(manifest manifest-full diff)' \
    && ret=0

return ret
