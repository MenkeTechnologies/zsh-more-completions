#compdef cargo-fresh
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall cargo-fresh@0.9.8
# Probed via: completion zsh
# Repository: https://github.com/jenkinpan/cargo-fresh

autoload -U is-at-least

_cargo-fresh() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-v+[Show detailed information]: :_default' \
'--verbose=[Show detailed information]: :_default' \
'-u+[Show only packages with updates]: :_default' \
'--updates-only=[Show only packages with updates]: :_default' \
'--no-interactive=[Non-interactive mode (default is interactive mode)]: :_default' \
'--include-prerelease=[Include prerelease versions (alpha, beta, rc, etc.)]: :_default' \
'--batch=[Batch mode - automatically update all packages without confirmation]: :_default' \
'--filter=[Filter packages by name pattern (supports glob patterns)]:PATTERN:_default' \
'-h[Print help]' \
'--help[Print help]' \
":: :_cargo-fresh_commands" \
"*::: :->cargo-fresh" \
&& ret=0
    case $state in
    (cargo-fresh)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cargo-fresh-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
'--cargo-fresh[Generate completion for cargo fresh subcommand]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::shell -- Shell to generate completion script for:((bash\:"Bash shell"
zsh\:"Zsh shell"
fish\:"Fish shell"
powershell\:"PowerShell"
elvish\:"Elvish shell"
nushell\:"Nushell"))' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_cargo-fresh__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:cargo-fresh-help-command-$line[1]:"
        case $line[1] in
            (completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_cargo-fresh_commands] )) ||
_cargo-fresh_commands() {
    local commands; commands=(
'completion:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cargo-fresh commands' commands "$@"
}
(( $+functions[_cargo-fresh__completion_commands] )) ||
_cargo-fresh__completion_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-fresh completion commands' commands "$@"
}
(( $+functions[_cargo-fresh__help_commands] )) ||
_cargo-fresh__help_commands() {
    local commands; commands=(
'completion:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'cargo-fresh help commands' commands "$@"
}
(( $+functions[_cargo-fresh__help__completion_commands] )) ||
_cargo-fresh__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-fresh help completion commands' commands "$@"
}
(( $+functions[_cargo-fresh__help__help_commands] )) ||
_cargo-fresh__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'cargo-fresh help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_cargo-fresh" ]; then
    _cargo-fresh "$@"
else
    compdef _cargo-fresh cargo-fresh
fi
