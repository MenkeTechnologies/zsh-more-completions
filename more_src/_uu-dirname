#compdef uu-dirname
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-dirname() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-z[separate output with NUL rather than newline]' \
'--zero[separate output with NUL rather than newline]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::dir:_files' \
&& ret=0
}

(( $+functions[_uu-dirname_commands] )) ||
_uu-dirname_commands() {
    local commands; commands=()
    _describe -t commands 'uu-dirname commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-dirname" ]; then
    _uu-dirname "$@"
else
    compdef _uu-dirname uu-dirname
fi
