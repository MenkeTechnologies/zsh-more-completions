#compdef kubetest2-gke
# _kubetest2-gke — kubetest2 deployer for GKE (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from kubetest2-gke/deployer/options/ (gpflag).

_kubetest2-gke() {
    _arguments \
        '--build[build kubernetes]' \
        '--up[provision the test cluster]' \
        '--down[tear down the test cluster]' \
        '--test=[tester to run after deployer up]:tester:(ginkgo exec node clusterloader2)' \
        '--environment=[Container API endpoint]:env:(test staging prod)' \
        '--gcloud-command-group=[gcloud command group]:group:(alpha beta)' \
        '--autopilot[create GKE Autopilot clusters]' \
        '--gcloud-extra-flags=[extra gcloud flags for cluster creation]:flags:' \
        '--create-command=[override gcloud subcommand for cluster creation]:cmd:' \
        '*--region=[cluster region (comma list)]:region:' \
        '*--zone=[cluster zone (comma list)]:zone:' \
        '--num-clusters=[number of clusters to create]:n:' \
        '*--cluster-name=[comma-separated cluster names]:names:' \
        '--machine-type=[machine type]:type:' \
        '--num-nodes=[number of nodes per zone]:n:' \
        '--image-type=[image type]:type:' \
        '--release-channel=[GKE release channel]:channel:(rapid regular stable extended)' \
        '--cluster-version=[GKE version]:ver:' \
        '--enable-workload-identity[enable workload identity]' \
        '--firewall-rule-allow=[allowed protocols/ports for firewall rules]:rules:' \
        '--enable-windows[enable Windows node pool]' \
        '--windows-num-nodes=[Windows node pool size]:n:' \
        '--windows-machine-type=[Windows node machine type]:type:' \
        '--windows-image-type=[Windows image type]:type:' \
        '*--windows-extra-args=[extra Windows nodepool flags]:flags:' \
        '--nodepool-create-concurrency=[nodepools to create concurrently]:n:' \
        '*--extra-nodepool=[extra nodepool spec key=value&...]:spec:' \
        '*--retryable-error-patterns=[regex patterns for retryable creation errors]:patterns:' \
        '*--project=[GCP project(s) (comma list)]:projects:' \
        '--boskos-location=[Boskos server URL]:url:_urls' \
        '--boskos-acquire-timeout-seconds=[Boskos acquire timeout]:s:' \
        '--boskos-heartbeat-interval-seconds=[Boskos heartbeat interval]:s:' \
        '*--boskos-resource-type=[Boskos resource type]:type:' \
        '*--projects-requested=[number of projects to request from Boskos]:n:' \
        '*::tester args:_normal'
}

_kubetest2-gke "$@"
