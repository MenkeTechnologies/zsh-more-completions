#compdef gxscomp
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gXSecComp.cxx
# gxscomp - GENIE utility to compare cross-section graphs from ROOT files

local ret=1

_arguments -s -S \
  '-f[ROOT file with GENIE cross-section graphs (optional ,label)]:file:_files' \
  '-r[reference file with GENIE cross-section graphs (optional ,label)]:file:_files' \
  '-o[output filename (default xsec.ps)]:outfile:_files' \
  '*: :_files' && ret=0

return ret
