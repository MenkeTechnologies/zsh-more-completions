#compdef vmbackup
# Documentation: https://docs.victoriametrics.com/vmbackup/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-storageDataPath=[VictoriaMetrics data path]:dir:_files -/' \
  '-snapshot.createURL=[snapshot create URL]:url:' \
  '-snapshot.deleteURL=[snapshot delete URL]:url:' \
  '-dst=[backup destination (gs/s3/azblob/fs URL)]:url:' \
  '-origin=[origin backup for server-side copy]:url:' \
  '-credsFilePath=[GCS/S3 credentials file]:file:_files' \
  '-configFilePath=[S3 config file]:file:_files' \
  '-configProfile=[S3 profile name]:profile:' \
  '-customS3Endpoint=[custom S3 endpoint]:url:' \
  '-s3StorageClass=[S3 storage class]:class:' \
  '-s3ACL=[S3 ACL]:acl:' \
  '-s3SSEKMSKeyId=[S3 SSE KMS key ID]:keyid:' \
  '-deleteAllObjectVersions[remove all object versions on delete]' \
  '-concurrency=[concurrent upload workers]:n:' \
  '-maxBytesPerSecond=[upload speed limit]:bps:' \
  '-filestream.disableFadvise[disable fadvise syscall]' \
  '-httpListenAddr=[HTTP metrics listen addr]:addr:' \
  '-tls[enable HTTPS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)' \
  '-pushmetrics.url=[push metrics URL]:url:' \
  '-license=[Enterprise license key]:key:' \
  '-licenseFile=[Enterprise license file]:file:_files' \
  '-eula[accept Enterprise EULA]'
