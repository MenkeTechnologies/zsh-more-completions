#compdef vmbackup

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-storageDataPath=[storage data path]:dir:_files -/' \
  '-snapshot.createURL=[snapshot create URL]:url:' \
  '-snapshot.deleteURL=[snapshot delete URL]:url:' \
  '-snapshotName=[snapshot name]:name:' \
  '-dst=[backup destination URL]:url:' \
  '-origin=[origin URL for server-side copy]:url:' \
  '-credsFilePath=[creds file]:file:_files' \
  '-configFilePath=[config file]:file:_files' \
  '-configProfile=[config profile]:profile:' \
  '-customS3Endpoint=[custom S3 endpoint]:url:' \
  '-s3ACL=[S3 ACL]:acl:' \
  '-s3StorageClass=[S3 storage class]:class:' \
  '-s3ObjectTags=[S3 object tags]:tags:' \
  '-s3SSEKMSKeyId=[S3 SSE KMS key ID]:keyid:' \
  '-s3TLSInsecureSkipVerify[skip S3 TLS verify]' \
  '-s3ForcePathStyle[force S3 path style]' \
  '-deleteAllObjectVersions[delete all object versions]' \
  '-objectMetadata=[object metadata]:meta:' \
  '-concurrency=[concurrency]:n:' \
  '-maxBytesPerSecond=[max bytes per second]:bps:' \
  '-snapshot.tlsCAFile=[snapshot TLS CA]:file:_files' \
  '-snapshot.tlsCertFile=[snapshot TLS cert]:file:_files' \
  '-snapshot.tlsKeyFile=[snapshot TLS key]:file:_files' \
  '-snapshot.tlsInsecureSkipVerify[skip snapshot TLS verify]' \
  '-snapshot.tlsServerName=[snapshot TLS server name]:name:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-tlsMinVersion=[TLS min version]:version:(TLS10 TLS11 TLS12 TLS13)' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)' \
  '-loggerOutput=[log output]:dest:' \
  '-license=[license key]:key:' \
  '-licenseFile=[license file]:file:_files' \
  '-eula[accept EULA]' \
  '-pushmetrics.url=[push metrics URL]:url:' \
  '-pushmetrics.interval=[push metrics interval]:duration:' \
  '-enableTCP6[enable TCP6]'
