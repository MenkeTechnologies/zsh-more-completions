#compdef tuna
# Documentation: https://man.archlinux.org/search?q=tuna
# Reference accessed: 2026-05-16

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-browser[do not open browser automatically]' \
  '(-p --port)'{-p,--port}'=[port to serve on]:port' \
  '*:profile file:_files -g "*.prof"'
