#compdef vgexport
# _vgexport — make a volume group inactive on this host (LVM2); prepare for vgimport on another host
# upstream: https://gitlab.com/lvmteam/lvm2

_vgexport() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --all)'{-a,--all}'[all inactive vgs]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:vg:'
}

_vgexport "$@"
