#compdef ConvertScalarImageToRGB
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ConvertScalarImageToRGB.cxx — apply colormap to a scalar image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImage:_files' \
    '4:mask image (use none for no mask):_files' \
    '5:colormap:(grey red green blue copper jet hsv spring summer autumn winter hot cool overunder custom)' \
    '6::customColormapFile (when colormap=custom):_files' \
    '7::minimumInput (default min):_default' \
    '8::maximumInput (default max):_default' \
    '9::minimumRGBOutput (default 0):_default' \
    '10::maximumRGBOutput (default 255):_default' \
    '11::vtkLookupTable:_files' \
    && ret=0

return ret
