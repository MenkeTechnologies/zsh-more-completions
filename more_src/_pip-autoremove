#compdef pip-autoremove
# Documentation: https://man.archlinux.org/search?q=pip-autoremove
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --leaves)'{-l,--leaves}'[list leaves only]' \
  '(-y --yes)'{-y,--yes}'[do not ask for confirmation]' \
  '*:package' && ret=0

return ret
