#compdef fleet

# Zsh completion for fleet - Fleet device management CLI (osquery)

local curcontext="$curcontext" state line ret=1

_fleet_commands() {
  local -a commands=(
    'prepare:prepare Fleet before starting the server'
    'serve:run the Fleet server'
    'config_dump:dump parsed Fleet configuration'
    'version:print version and exit'
    'help:show help'
    'debug:debugging commands'
  )
  _describe -t commands 'fleet command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config[config file path]:file:_files' \
  '1: :_fleet_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      serve)
        _arguments \
          '--config[config file path]:file:_files' \
          '--dev[enable dev mode]' \
          '--dev_license[accept dev license]' \
          '--mysql_address[MySQL address]:address' \
          '--mysql_database[MySQL database]:database' \
          '--mysql_username[MySQL username]:user' \
          '--mysql_password[MySQL password]:password' \
          '--redis_address[Redis address]:address' \
          '--server_address[HTTPS bind address]:address' \
          '--server_cert[HTTPS cert file]:file:_files' \
          '--server_key[HTTPS key file]:file:_files' \
          '--logging_debug[enable debug logging]' \
          '--logging_json[log in JSON format]' && ret=0
        ;;
      prepare)
        _arguments \
          '1:subcommand:(db)' \
          '--config[config file path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
