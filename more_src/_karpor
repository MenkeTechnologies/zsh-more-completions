#compdef karpor
# Documentation: https://man.archlinux.org/search?q=karpor
# Reference accessed: 2026-05-16

# Karpor: search engine for Kubernetes (Cloud Native AI surveillance)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'server:run Karpor server'
  'syncer:run Karpor syncer'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--namespace=[namespace]:ns:' \
  '--debug[debug mode]' \
  '--port=[bind port]:port:' \
  '--profile[enable profiling]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'karpor command' commands && ret=0 ;;
esac
return ret
