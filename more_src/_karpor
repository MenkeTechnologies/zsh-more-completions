#compdef karpor
# Documentation: https://www.kusionstack.io/karpor/next/references/cli-commands/karpor
# Reference accessed: 2026-05-19
# Verified: upstream docs + source (cmd/karpor) at the URL above. The
# karpor root command IS the API server; its only subcommand is "syncer"
# (no server/completion/version subcommands). Removed invented
# --config/--namespace/--debug/--port/--profile.

# Karpor: intelligence/search engine for Kubernetes
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'syncer:start a resource syncer to sync resource from clusters'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--secure-port=[port to serve HTTPS with authn/authz]:port:' \
  '--bind-address=[IP address to listen for the --secure-port]:addr:' \
  '--tls-cert-file=[file containing the default x509 Certificate for HTTPS]:file:_files' \
  '--tls-private-key-file=[file containing the default x509 private key]:file:_files' \
  '--etcd-servers=[list of etcd servers to connect with]:servers:' \
  '--enable-rbac[enable RBAC authorization]' \
  '--read-only-mode[enable read-only mode]' \
  '--github-badge[enable GitHub badge]' \
  '--search-storage-type=[search storage type]:type:' \
  '--elastic-search-addresses=[elastic search addresses]:addr:' \
  '--elastic-search-username=[elastic search username]:user:' \
  '--elastic-search-password=[elastic search password]:password:' \
  '--ai-backend=[AI backend]:backend:' \
  '--ai-model=[AI model]:model:' \
  '--ai-auth-token=[AI auth token]:token:' \
  '--ai-base-url=[AI base URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'karpor command' commands && ret=0 ;;
esac
return ret
