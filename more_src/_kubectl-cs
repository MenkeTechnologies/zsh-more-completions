#compdef kubectl-cs
# Documentation: https://github.com/dodevops/kc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-cs (dodevops/kc): quick context switcher. Positional arg is a
# context:namespace pair (either side optional).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--only-current-context[enumerate namespaces of only the current context]' \
  '*:context\:namespace:_default'
