#compdef ClipReads
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/ClipReads.java
# Clip reads in a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'=[output SAM/BAM/CRAM file]:value:_files' \
  '(--output-statistics -os)'{--output-statistics,-os}'=[file to output statistics]:value:_files' \
  '(--q-trimming-threshold -QT)'{--q-trimming-threshold,-QT}'=[quality trimming threshold]:value:' \
  '(--cycles-to-trim -CT)'{--cycles-to-trim,-CT}'=[cycle ranges to clip]:value:' \
  '(--clip-sequences-file -XF)'{--clip-sequences-file,-XF}'=[file of clip sequences]:value:_files' \
  '*'{--clip-sequence,-X}'=[clip a literal sequence]:value:' \
  '(--clip-representation -CR)'{--clip-representation,-CR}'=[how to represent clipped bases]:value:(WRITE_NS WRITE_Q0S WRITE_NS_Q0S SOFTCLIP_BASES REVERT_SOFTCLIPPED_BASES HARDCLIP_BASES)' \
  '(--clip-adapter -CA)'{--clip-adapter,-CA}'[clip the adapter sequence]' \
  '--read=[only clip the named read]:value:' \
  '--min-read-length-to-output=[minimum read length to output]:value:' \
  '*:argument:_files' && ret=0

return ret
