#compdef ttygif

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-f[playback speed factor]:speed' \
  '-n[no loop in output GIF]' \
  '-o[output file name]:file:_files' \
  '-s[number of frames to skip]:count' \
  '1:ttyrec file:_files' && ret=0

return ret
