#compdef gt

# Zsh completion for gt - Graphite CLI for stacked diffs

local curcontext="$curcontext" state line ret=1

_gt_branches() {
  local -a branches
  branches=(${(f)"$(_call_program branches git branch --format='%(refname:short)' 2>/dev/null)"})
  _describe -t branches 'branch' branches
}

local -a commands=(
  'auth:authenticate with Graphite'
  'checkout:interactively check out a branch'
  'co:interactively check out a branch'
  'commit:commit changes to the current branch'
  'c:commit changes to the current branch'
  'create:create a new branch with staged changes'
  'delete:delete a branch'
  'info:display info about a branch'
  'init:initialize Graphite in this repo'
  'log:display the current stack'
  'l:display the current stack'
  'ls:list all tracked branches'
  'modify:modify the current branch'
  'm:modify the current branch'
  'pr:submit a pull request for the stack'
  'rename:rename a branch'
  'squash:squash commits on the current branch'
  'submit:submit branches in the current stack'
  's:submit branches in the current stack'
  'sync:sync with remote and clean merged branches'
  'trunk:switch to the trunk branch'
  'up:move up one branch in the stack'
  'u:move up one branch in the stack'
  'down:move down one branch in the stack'
  'd:move down one branch in the stack'
  'top:move to the top of the stack'
  't:move to the top of the stack'
  'bottom:move to the bottom of the stack'
  'b:move to the bottom of the stack'
  'continue:continue an operation after resolving conflicts'
  'fold:fold a branch into its parent'
  'split:split a branch'
  'upstack:operations on the upstack'
  'us:operations on the upstack'
  'downstack:operations on the downstack'
  'ds:operations on the downstack'
  'restack:rebase branches onto their parents'
  'completion:generate shell completion'
  'feedback:send feedback to Graphite'
  'dash:open the Graphite dashboard'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '--quiet[suppress output]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'gt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      checkout|co|delete|rename)
        _gt_branches && ret=0
        ;;
      create|c)
        _arguments \
          '(-m --message)'{-m,--message}'[commit message]:message:' \
          '(-a --all)'{-a,--all}'[stage all changes]' \
          '--no-interactive[do not prompt]' && ret=0
        ;;
      commit)
        _arguments \
          '(-m --message)'{-m,--message}'[commit message]:message:' \
          '(-a --all)'{-a,--all}'[stage all changes]' \
          '--amend[amend the last commit]' && ret=0
        ;;
      submit|s)
        _arguments \
          '--draft[submit as draft PR]' \
          '--publish[publish the PR (not draft)]' \
          '(-m --edit)'{-m,--edit}'[edit PR body before submitting]' \
          '--no-interactive[do not prompt]' \
          '--stack[submit the whole stack]' \
          '--branch[only submit the current branch]' && ret=0
        ;;
      sync)
        _arguments \
          '--no-interactive[do not prompt]' \
          '--force[force sync]' \
          '--restack[restack branches after sync]' && ret=0
        ;;
    esac
    ;;
esac

return ret
