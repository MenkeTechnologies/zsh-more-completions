#compdef SurfSmooth
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfSmooth.html
# Smooth data on a surface or smooth a surface itself

local ret=1

_arguments -s \
  '-met[smoothing method]:method:(HEAT_07 HEAT_05 LM NN_geom)' \
  '-input[data to smooth (1D or NIML)]:file:_files' \
  '-output[output file name]:file:_files' \
  '-Niter[number of smoothing iterations]:num' \
  '-fwhm[FWHM blur in surface units]:fwhm' \
  '-target_fwhm[final desired FWHM]:fwhm' \
  '-blurmaster[reference dataset for blurring]:dataset:_files' \
  '-detrend_master[detrend reference with polynomials]:order' \
  '-sigma[smoothing kernel bandwidth per iteration]:sigma' \
  '-kpb[band pass frequency parameter]:kpb' \
  '-lm[lambda and mu parameters]:params' \
  '-surf_out[write smoothed surface coords]:file:_files' \
  '-iw[interpolation weights]:weights:(Equal Fujiwara Desbrun)' \
  '-match_size[adjust smoothed surface size to original]' \
  '-match_vol[match volume to original]' \
  '-match_area[match area to original]' \
  '-match_sphere[project nodes onto sphere of radius]:radius' \
  '-match_center[center smoothed surface to original]' \
  '-add_index[output node index in first column]' \
  '-talk_suma[send progress to SUMA viewer]' \
  '-dbg_n[debug info for a node]:node' \
  '-overwrite[allow overwriting output]' \
  '*:surface:_files' && ret=0

return ret
