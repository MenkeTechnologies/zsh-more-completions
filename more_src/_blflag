#compdef blflag
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/blflag.html
# Interactive flagging task

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[vis keyword]:vis:' \
  'line=[line keyword]:line:' \
  'device=[device keyword]:device:' \
  'stokes=[stokes keyword]:stokes:' \
  'select=[select keyword]:select:' \
  'axis=[axis keyword]:axis:' \
  'xrange=[xrange keyword]:xrange:' \
  'yrange=[yrange keyword]:yrange:' \
  'options=[options keyword]:options:' \
  '*:visibility dataset:_files' && ret=0

return ret
