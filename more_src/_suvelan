#compdef suvelan
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/velocity_analysis/suvelan.c
# SUVELAN - compute stacking velocity semblance for cdp gathers

local ret=1

_arguments -s -S \
  'nv=[number of velocities]:n:' \
  'dv=[velocity sampling interval]:d:' \
  'fv=[first velocity]:f:' \
  'anis1=[quartic term numerator coefficient]:a:' \
  'anis2=[quartic term denominator coefficient]:a:' \
  'smute=[NMO stretch exceeding smute is zeroed]:s:' \
  'dtratio=[ratio of output to input time sampling]:d:' \
  'nsmooth=[length of semblance smoothing window]:n:' \
  'verbose=[=1 for diagnostic print on stderr]:v:(0 1)' \
  'pwr=[semblance value to the power]:p:' \
  '*:SU file:_files' && ret=0

return ret
