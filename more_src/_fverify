#compdef fverify
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fverify.txt
# Verify that a FITS file conforms to the FITS Standard

local ret=1

_arguments -s \
  "infile=[input FITS file to verify]:file:_files" \
  "outfile=[output report file]:file:_files" \
  "prhead=[print header keywords]:bool:(yes no)" \
  "prstat=[print verification statistics]:bool:(yes no)" \
  "errreport=[error report level]:level:(w e v)" \
  "testdata=[test data values]:bool:(yes no)" \
  "tchksum=[test checksum keywords]:bool:(yes no)" \
  "testfill=[test fill areas]:bool:(yes no)" \
  "heasarc=[apply HEASARC conventions]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
