#compdef esbmc
# Documentation: https://github.com/esbmc/esbmc
# ESBMC bounded model checker for C/C++

local ret=1

_arguments -s -S \
  '--help[display usage information]' \
  '--version[show version details]' \
  '--incremental-bmc[select incremental BMC strategy]' \
  '--k-induction[use k-induction proof-rule algorithm]' \
  '--unwind=[set loop unwinding bound]:bound' \
  '--depth=[set verification depth]:depth' \
  '--timeout=[specify time limit]:timeout' \
  '--memlimit=[set memory constraints]:limit' \
  '--no-bounds-check[disable array bounds verification]' \
  '--no-pointer-check[disable pointer safety checks]' \
  '--overflow-check[enable overflow detection]' \
  '--multi-property[check multiple properties simultaneously]' \
  '--witness-output=[generate verification witness file]:witness file:_files' \
  '*:source file:_files' && ret=0

return ret
