#compdef goimports
# Documentation: https://pkg.go.dev/golang.org/x/tools/cmd/goimports
# Source: golang/tools cmd/goimports/goimports.go — gofmt with auto-imports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-l -w -d)-l[list files whose formatting differs]' \
    '(-l -w -d)-w[write result to source file (instead of stdout)]' \
    '(-l -w -d)-d[display diffs instead of rewriting files]' \
    '-srcdir[choose imports as if source were from dir]:dir:_directories' \
    '-cpuprofile[CPU profile output]:file:_files' \
    '-memprofile[memory profile output]:file:_files' \
    '-memrate[set runtime.MemProfileRate]:rate:' \
    '-e[report all errors (not just first 10)]' \
    '-local[prefix for local imports (comma-separated)]:prefix:' \
    '-format-only[only format; do not fix imports]' \
    '-v[verbose logging]' \
    '*:Go source file:_files -g "*.go"' \
    && ret=0

return ret
