#compdef unvanquished
# Documentation: (no Debian/Ubuntu manpage; wiki.unvanquished.net returns 404)
# Reference accessed: 2026-05-16
# Verified: no upstream docs retrievable. Unvanquished uses the Daemon engine
# (Tremulous successor); engine accepts +cmd cbuf-style commands at runtime.

# Unvanquished: alien-vs-human FPS (Daemon engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
