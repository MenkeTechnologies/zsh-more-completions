#compdef dafny

# Zsh completion for dafny - Dafny verification-aware programming language

local curcontext="$curcontext" state line ret=1

_dafny_common_flags() {
  _arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    {-t,--target}'[compilation target]:target:(cs go java js py cpp lib dfy)' \
    '--input[input file]:file:_files -g "*.dfy"' \
    {-o,--output}'[output file/directory]:output:_files' \
    '--verbose[increase verbosity]' \
    '--log-format[format string for verification log]:format: ' \
    '--print[print Dafny program after parsing]:file:_files' \
    '--unicode-char[enable unicode char type]:value:(true false)' \
    '--function-syntax[select function syntax]:syntax:(3 4 migration3to4 experimentalDefaultGhost experimentalDefaultCompiled experimentalPredicateAlwaysGhost)' \
    '--quantifier-syntax[select quantifier syntax]:syntax:(3 4 migration3to4)' \
    '--warn-shadowing[warn when names are shadowed]' \
    '--warn-missing-constructor-parentheses[warn on missing constructor parentheses]' \
    '--track-print-effects[track print effects]' \
    '--warn-redundant-assumptions[warn on redundant assumptions]' \
    '--allow-deprecation[allow deprecated features]' \
    '--standard-libraries[enable standard libraries]' \
    '--prelude[use custom prelude file]:file:_files -g "*.dfy"' \
    '--no-verify[skip verification]' \
    '--verification-time-limit[time limit per assertion in seconds]:seconds: ' \
    '--resource-limit[set resource limit]:units: ' \
    '--cores[number of verification cores]:count: ' \
    '--isolate-assertions[verify each assertion in isolation]' \
    '--boogie[additional Boogie options]:options: ' \
    '--solver-path[path to SMT solver]:solver:_files' \
    '--solver-plugin[path to solver plugin]:plugin:_files' \
    '--solver-log[log solver interactions to file]:file:_files' \
    "$@"
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a subcommands=(
      'verify:verify a Dafny program'
      'build:compile a Dafny program'
      'run:compile and run a Dafny program'
      'test:run tests in a Dafny program'
      'translate:translate Dafny to target language'
      'format:format Dafny source files'
      'doc:generate documentation'
      'measure-complexity:measure code complexity'
      'resolve:resolve and typecheck a program'
      'server:start the Dafny language server'
      'generate-tests:generate tests for a Dafny program'
      'audit:audit a Dafny program for verification gaps'
      'merge-coverage-reports:merge multiple coverage reports'
    )
    _describe -t commands 'dafny command' subcommands && ret=0
    ;;
  args)
    case "${line[1]}" in
      verify)
        _dafny_common_flags \
          '--filter-symbol[only verify matching symbols]:symbol pattern: ' \
          '--filter-position[only verify at matching positions]:position: ' \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      build)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      run)
        _dafny_common_flags \
          '--input[input file]:file:_files -g "*.dfy"' \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      test)
        _dafny_common_flags \
          '--filter-symbol[only test matching symbols]:symbol pattern: ' \
          '--filter-position[only test at matching positions]:position: ' \
          '--methods-to-test[number of methods to test]:count: ' \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      translate)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      format)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--check[check formatting without modifying files]' \
          '--print[print formatted output]:file:_files' \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      doc)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      resolve)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      audit)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      generate-tests)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      measure-complexity)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      merge-coverage-reports)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:coverage report file:_files' && ret=0
        ;;
      *)
        _dafny_common_flags \
          '*:Dafny source file:_files -g "*.dfy"' && ret=0
        ;;
    esac
    ;;
esac

return ret
