#compdef fslchfiletype
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# fslchfiletype - change the file type of an image

local ret=1

_arguments -s -S \
  '1:file type:(ANALYZE ANALYZE_GZ NIFTI NIFTI_GZ NIFTI_PAIR NIFTI_PAIR_GZ NIFTI2 NIFTI2_GZ NIFTI2_PAIR NIFTI2_PAIR_GZ)' \
  '2:input image:_files' \
  '3:output image:_files' && ret=0

return ret
