#compdef microplane

local curcontext="$curcontext" state line ret=1

_microplane_commands() {
  local -a commands=(
    'clone:clone repos matching a query'
    'init:initialize a microplane workflow'
    'merge:merge open pull requests'
    'plan:run a command against each cloned repo'
    'push:push changes and open pull requests'
    'status:show status of current workflow'
  )
  _describe -t commands 'microplane command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_microplane_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s -S \
          '(-r --repo)'{-r,--repo}'[single repo to target]:repo' \
          '*:org/query' && ret=0
        ;;
      clone)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      plan)
        _arguments -s -S \
          '(-b --branch)'{-b,--branch}'[branch name]:branch' \
          '(-m --message)'{-m,--message}'[commit message]:message' \
          '*:command' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(-b --body)'{-b,--body}'[PR body]:body' \
          '(-t --title)'{-t,--title}'[PR title]:title' \
          '--assignee[PR assignee]:user' \
          '--label[PR label]:label' \
          '--draft[create as draft PR]' && ret=0
        ;;
      merge)
        _arguments -s -S \
          '--delete-branch[delete branch after merge]' \
          '--merge-method[merge method]:method:(merge squash rebase)' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
