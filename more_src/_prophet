#compdef prophet

# EMBOSS prophet: scan sequence(s) with a Gribskov or Henikoff profile
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[sequence(s) to scan]:sequence USA:_files' \
  '-infile=[profile file (from prophecy)]:file:_files' \
  '-gapopen=[gap opening penalty]:val:' \
  '-gapextend=[gap extension penalty]:val:' \
  '-outfile=[report output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
