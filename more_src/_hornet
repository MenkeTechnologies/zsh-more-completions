#compdef hornet
# Documentation: https://man.archlinux.org/search?q=hornet
# Reference accessed: 2026-05-16

_arguments -s -S \
  '--config=[Path to Hornet config JSON]:file:_files' \
  '--peering=[Peering profile name]:profile:' \
  '--db=[Database path]:directory:_directories' \
  '--profiling[Enable pprof HTTP server]' \
  '--help[Show help]' \
  '--version[Show version]' \
  '*::arguments: _default'
