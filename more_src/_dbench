#compdef dbench tbench
# Documentation: https://man.archlinux.org/search?q=dbench
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-V[show version]' \
  '(-c --loadfile)'{-c+,--loadfile=}'[client load file]:file:_files' \
  '(-D --directory)'{-D+,--directory=}'[base test directory]:dir:_files -/' \
  '(-t --timelimit)'{-t+,--timelimit=}'[run for seconds]:secs:' \
  '(-T --tcp-options)'{-T+,--tcp-options=}'[TCP socket options csv]:opts:' \
  '--run-once[do not loop client load]' \
  '(-s --sync-open)'{-s,--sync-open}'[use O_SYNC for opens]' \
  '(-S --sync-dirs)'{-S,--sync-dirs}'[fsync directories]' \
  '(-x --xattr)'{-x,--xattr}'[exercise xattrs]' \
  '(-w --warmup)'{-w+,--warmup=}'[warmup seconds]:secs:' \
  '(-O --stat-check)'{-O,--stat-check}'[verify stat fields]' \
  '(-N --no-resolve)'{-N,--no-resolve}'[do not resolve hostnames]' \
  '(-Z --no-clean)'{-Z,--no-clean}'[do not cleanup at exit]' \
  '(-R --random-write)'{-R+,--random-write=}'[fraction of random writes 0-1]:f:' \
  '(-B --backend)'{-B+,--backend=}'[backend type]:b:(fileio sockio nfs scsi iscsi)' \
  '--scsi=[SCSI device]:dev:_files' \
  '--iscsi-share=[iSCSI share]:share:' \
  '--nfs=[NFS share]:share:' \
  '--clients-per-process=[clients per process]:n:' \
  '--server=[connect to server]:host:_hosts' \
  '--target-rate=[max ops/sec]:n:' \
  '--no-resolve[do not resolve names]' \
  '--start-from=[start client number]:n:' \
  '--no-burst[disable burst mode]' \
  '*:client count:' && ret=0

return ret
