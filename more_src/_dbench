#compdef dbench tbench
# Documentation: https://www.samba.org/ftp/tridge/dbench/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Repo: https://github.com/sahlberg/dbench

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-c+[path to client.txt loadfile]:file:_files' \
  '-t+[benchmark runtime in seconds (default 600)]:secs:' \
  '-D+[base directory for filesystem operations]:dir:_files -/' \
  '-s[synchronous file I/O for all file operations]' \
  '-S[synchronous I/O for directory operations]' \
  '-x[exercise xattrs (simulate Samba4 xattr load)]' \
  '-T+[(tbench) socket options csv]:opts:' \
  '*:number of clients:' && ret=0

return ret
