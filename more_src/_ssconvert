#compdef ssconvert
# Documentation: https://manpages.debian.org/bookworm/gnumeric/ssconvert.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian manpage at the URL above.
# Removed fabricated -r/--merge-to (-r does not exist; --merge-to is -M only)
# and the speculative export-type fixed-value list (IDs come from
# --list-exporters at runtime, not a canonical static enum).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-libspreadsheet[show Gnumeric options]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity about operations]' \
  '(-T --import-type)'{-T,--import-type}'=[importer format ID]:ID' \
  '(-I --import-encoding)'{-I,--import-encoding}'=[encoding for imported content]:encoding' \
  '(-t --export-type)'{-t,--export-type}'=[exporter format ID]:ID' \
  '(-O --export-options)'{-O,--export-options}'=[exporter options string]:options' \
  '(-S --export-file-per-sheet)'{-S,--export-file-per-sheet}'[create separate file per sheet]' \
  '(-M --merge-to)'{-M,--merge-to}'=[consolidate workbooks into FILENAME]:file:_files' \
  '--recalc[recalculate all cells before output]' \
  '*--set=[assign value to specific cell]:CELL=CONTENTS' \
  '--export-graphs[extract charts to image files]' \
  '--list-importers[display available importers]' \
  '--list-exporters[display available exporters]' \
  '--list-image-formats[display supported image formats]' \
  '*:spreadsheet:_files -g "*.{gnumeric,xls,xlsx,ods,csv,tsv,html}"' && ret=0

return ret
