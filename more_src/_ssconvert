#compdef ssconvert

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-T --import-type)'{-T,--import-type}'+[import type]:type:' \
  '(-I --import-encoding)'{-I,--import-encoding}'+[encoding]:enc:' \
  '(-S --export-file-per-sheet)'{-S,--export-file-per-sheet}'[one file per sheet]' \
  '(-O --export-options)'{-O,--export-options}'+[export options]:opts:' \
  '(-t --export-type)'{-t,--export-type}'+[export format]:type:(Gnumeric_html:xhtml Gnumeric_html:xhtml_range Gnumeric_html:html32 Gnumeric_html:html40 Gnumeric_html:html40frag Gnumeric_html:latex Gnumeric_html:latex_table Gnumeric_html:roff Gnumeric_html:beamer Gnumeric_html:beamer_article Gnumeric_Excel:excel_dsf Gnumeric_Excel:excel_biff7 Gnumeric_Excel:excel_biff8 Gnumeric_Excel:xlsx Gnumeric_OpenCalc:openoffice Gnumeric_OpenCalc:odf Gnumeric_OpenCalc:fods Gnumeric_stf:stf_assistant Gnumeric_stf:stf_csv Gnumeric_dif:dif Gnumeric_sylk:sylk Gnumeric_QPro:qpro Gnumeric_paradox:paradox Gnumeric_perl:perl Gnumeric_python_loader:python Gnumeric_pln:pln Gnumeric_mps:mps Gnumeric_lpsolve:lpsolve Gnumeric_glpk:glpk Gnumeric_applix:applix)' \
  '(-M --merge-to)'{-M,--merge-to}'+[merge into file]:file:_files' \
  '(-E --recalc)'{-E,--recalc}'[recalc before save]' \
  '--list-importers[list importers]' \
  '--list-exporters[list exporters]' \
  '--object-export=+[export object]:obj:' \
  '(-r --merge-to)'{-r,--merge-to}'+[output range]:range:' \
  '*:spreadsheet:_files -g "*.{gnumeric,xls,xlsx,ods,csv,tsv,html}"' && ret=0

return ret
