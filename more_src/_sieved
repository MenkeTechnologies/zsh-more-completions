#compdef sieved
# _sieved — Cyrus IMAP sieved (managesieve protocol daemon that lets MUAs upload/install/delete sieve filter scripts on the IMAP server; -C config file, -d debug, -f foreground, -p port, -v verbose; reads /etc/cyrus.conf for service{} block but is normally launched by master(8))
# upstream: https://github.com/cyrusimap/cyrus-imapd
# Flags from cyrusimap/cyrus-imapd imap/sieved.c on tip.

_sieved() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files' \
        '-d[debug]' \
        '-f[foreground]' \
        '-p+[port]:port:'
}

_sieved "$@"
