#compdef hackrf_clock
# Documentation: https://github.com/greatscottgadgets/hackrf/blob/master/host/hackrf-tools/src/hackrf_clock.c
# Reference accessed: 2026-05-27
# Verified: upstream usage() function and long_options[] in hackrf_clock.c

# Zsh completion for hackrf_clock (HackRF clock configuration utility)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help]' \
  '(-r --read)'{-r+,--read=}'[read settings for clock_num]:clock_num:' \
  '(-a --all)'{-a,--all}'[read settings for all clocks]' \
  '(-i --clkin)'{-i+,--clkin=}'[get CLKIN status]:arg:' \
  '(-o --clkout)'{-o+,--clkout=}'[enable/disable CLKOUT]:clkout_enable:(0 1)' \
  '(-1 --p1)'{-1+,--p1=}'[select HackRF Pro P1 SMA connector signal]:signal:(clkin trigger_in trigger_out p22_clkin pps_out aux_clk1 aux_clk2 off)' \
  '(-2 --p2)'{-2+,--p2=}'[select HackRF Pro P2 SMA connector signal]:signal:(clkout trigger_in trigger_out)' \
  '(-c --clkin-ctrl)'{-c+,--clkin-ctrl=}'[select HackRF Pro CLKIN signal]:signal:(p1 p22)' \
  '(-d --device)'{-d+,--device=}'[serial number of desired HackRF]:serial_number:' && ret=0

return ret
