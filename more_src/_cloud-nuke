#compdef cloud-nuke

# Zsh completion for cloud-nuke - clean up cloud resources

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'aws:nuke AWS resources'
  'defaults-aws:nuke default VPCs and security groups'
  'inspect-aws:inspect AWS resources'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'cloud-nuke command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (aws|defaults-aws|inspect-aws)
        _arguments -s -S \
          '--region=[target specific region]:region' \
          '--exclude-region=[exclude a region]:region' \
          '--resource-type=[target specific resource type]:type' \
          '--exclude-resource-type=[exclude a resource type]:type' \
          '--older-than=[only nuke resources older than this]:duration' \
          '--newer-than=[only nuke resources newer than this]:duration' \
          '--config=[path to config file]:file:_files -g "*.{yml,yaml}"' \
          '--list-resource-types[list available resource types]' \
          '--dry-run[dry run mode - list resources without deleting]' \
          '--force[skip confirmation prompt]' \
          '--delete-unaliased-kms-keys[delete KMS keys without aliases]' \
          '--no-delete-first-seen-tag[do not delete the first-seen tag]' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--delete-first-seen-tag[delete the first-seen tag after nuking]' && ret=0
        ;;
    esac
    ;;
esac

return ret
