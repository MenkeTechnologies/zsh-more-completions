#compdef setconfig
# Documentation: https://github.com/ulfalizer/Kconfiglib
# setconfig - set Kconfig configuration values from the command line

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kconfig=[top-level Kconfig file]:file:_files' \
  '--no-check-exists[ignore assignments to non-existent symbols]' \
  '--no-check-value[ignore assignments that did not take effect]' \
  '*:assignment (NAME=value):' && ret=0

return ret
