#compdef toe
# _toe — ncurses toe (Table Of Entries: list terminfo terminal types known in the terminfo directories; -a covers all directories on TERMINFO/TERMINFO_DIRS path, -s sorts, -h adds headers, -u/-U dump uses)
# upstream: https://github.com/mirror/ncurses
# Flags from ncurses progs/toe.c on tip.

_toe() {
    _arguments \
        '-0[one description per line]' \
        '-1[one name per line]' \
        '-a[scan all terminfo directories]' \
        '-h[show headers]' \
        '-s[sort by name]' \
        '-u+[show uses for terminal]:term:' \
        '-U+[show used-by for terminal]:term:' \
        '-v+[verbosity level]:level:(0 1 2 3 4 5)' \
        '*:directory:_files -/'
}

_toe "$@"
