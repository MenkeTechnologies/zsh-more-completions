#compdef shortcuts-cli
# _shortcuts-cli — Apple macOS Shortcuts CLI alias (Apple, Swift); custom argparse
# upstream: builtin macOS Monterey+

_shortcuts-cli() {
    local -a sub=(
        'list:list shortcuts'
        'run:run shortcut'
        'view:view shortcut'
        'sign:sign shortcut file'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shortcuts subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments \
                    '--folder-name=+[folder name]:str:' \
                    '-f+[folder name]:str:' \
                    '--folders[show folders]' ;;
                run) _arguments \
                    '1:shortcut-name:' \
                    '--input-path=+[input path]:file:_files' \
                    '-i+[input path]:file:_files' \
                    '--output-path=+[output path]:file:_files' \
                    '-o+[output path]:file:_files' \
                    '--output-type=+[output type]:str:' ;;
                view) _arguments \
                    '1:shortcut-name:' ;;
                sign) _arguments \
                    '--input=+[input shortcut]:file:_files -g "*.shortcut"' \
                    '-i+[input shortcut]:file:_files -g "*.shortcut"' \
                    '--output=+[output shortcut]:file:_files' \
                    '-o+[output shortcut]:file:_files' \
                    '--mode=+[signing mode]:m:(anyone people-who-know-the-link)' \
                    '-m+[signing mode]:m:(anyone people-who-know-the-link)' ;;
            esac
            ;;
    esac
}

_shortcuts-cli "$@"
