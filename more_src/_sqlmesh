#compdef sqlmesh

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'audit:run audits for target models'
  'check_intervals:show missing intervals respecting signals'
  'clean:clear SQLMesh cache and build artifacts'
  'create_external_models:create external models schema file'
  'create_test:generate unit test fixture for model'
  'dag:render DAG as html file'
  'destroy:remove all state, cache, project resources'
  'dlt_refresh:attach to DLT pipeline and update models'
  'diff:show diff between local and target env'
  'environments:list SQLMesh environments and expiry'
  'evaluate:evaluate model and return dataframe'
  'fetchdf:run SQL query and display results'
  'format:format all SQL models and audits'
  'info:print SQLMesh project info'
  'init:create new SQLMesh repository'
  'invalidate:invalidate environment for janitor removal'
  'janitor:run janitor on-demand'
  'lint:run linter on target models'
  'migrate:migrate to current running version'
  'plan:apply local changes to target environment'
  'prompt:use LLM to generate SQL from prompt'
  'render:render a models query'
  'rewrite:transform SQL with semantic refs'
  'rollback:rollback to previous migration'
  'run:evaluate missing intervals for env'
  'state:state interaction commands'
  'table_diff:diff between tables or models in envs'
  'table_name:print physical table name for model'
  'test:run model unit tests'
  'ui:start browser-based UI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --paths)'{-p+,--paths=}'[path to SQLMesh project]:dir:_files -/' \
  '--config=[config file or python module]:cfg:' \
  '--gateway=[gateway name from config]:gw:' \
  '--ignore-warnings[suppress warnings]' \
  '--debug[enable debug logging]' \
  '--log-to-stdout[log to stdout]' \
  '--log-file-dir=[log file directory]:dir:_files -/' \
  '--dotenv=[load .env file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sqlmesh command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (plan)
        _arguments \
          '--start=[start date]:date:' \
          '--end=[end date]:date:' \
          '--execution-time=[execution time]:dt:' \
          '--create-from=[create env from existing]:env:' \
          '--skip-tests[skip unit tests]' \
          '--restate-model=*[restate model]:model:' \
          '--no-gaps[do not allow gaps]' \
          '--skip-backfill[skip backfill]' \
          '--forward-only[forward-only changes]' \
          '--effective-from=[forward-only effective date]:date:' \
          '--no-prompts[no interactive prompts]' \
          '--auto-apply[auto-apply changes]' \
          '--no-auto-categorization[disable change auto categorisation]' \
          '--include-unmodified[include unmodified models]' \
          '*:environment:' && ret=0 ;;
      (run|test|audit|format|migrate|info|ui|init|clean|destroy)
        _arguments '*:: :' && ret=0 ;;
    esac ;;
esac

return ret
