#capture _ldns-zonediff
#compdef ldns-zonediff
# _ldns-zonediff — NLnet Labs ldns-zonediff (compare two BIND-format DNS zone files emitting an IXFR-style RFC1995 diff of additions and deletions; -i print only IXFR records, -s sort, -v verbose; positional arguments are the old zone file and the new zone file)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-zonediff.c on tip.

_ldns-zonediff() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-i[IXFR records only]' \
        '-s[sort]' \
        '1:old zone file:_files' \
        '2:new zone file:_files'
}

_ldns-zonediff "$@"
