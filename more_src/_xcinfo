#compdef xcinfo
# Documentation: https://github.com/xcodereleases/xcinfo
# Reference accessed: 2026-05-21
# Verified: Sources/xcinfo/XCInfo.swift (DefaultOptions, ListOptions, VersionOptions,
# DownloadOptions, ExtractionOptions, InstallationOptions) and SubCommands/*.swift.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'cleanup:remove keychain entries, cookies and user defaults'
      'download:download a version of Xcode'
      'extract:extract a downloaded XIP'
      'info:show detailed information about an Xcode version'
      'install:install a version of Xcode'
      'installed:list Xcode versions installed in /Applications'
      'list:list all available Xcode versions'
      'uninstall:remove an installed Xcode'
    )
    _describe -t commands 'xcinfo command' commands && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '(-a --all)'{-a,--all}'[show all Xcode versions ever released]' \
          '--update-list[update list of known versions]' \
          '--no-update-list[use cached list]' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '--update-list[update list of known versions]' \
          '--no-update-list[use cached list]' \
          '--xip-path=[path to existing XIP file]:file:_files -g "*.xip"' \
          '(-d --download-directory)'{-d,--download-directory=}'[download destination]:dir:_files -/' \
          '(-i --installation-directory)'{-i,--installation-directory=}'[install destination]:dir:_files -/' \
          '--sleep[allow system to sleep]' \
          '--no-sleep[prevent system sleep]' \
          '--use-system-unxip[use slower system unxip]' \
          '--preserve-xip[do not delete XIP after extraction]' \
          '--no-symlink[skip /Applications/Xcode.app symlink]' \
          '--no-xcode-select[skip selecting new Xcode as command-line tools]' \
          '*:Xcode version or latest:' && ret=0
        ;;
      download)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '--update-list[update list of known versions]' \
          '--no-update-list[use cached list]' \
          '(-d --download-directory)'{-d,--download-directory=}'[download destination]:dir:_files -/' \
          '--sleep[allow system to sleep]' \
          '--no-sleep[prevent system sleep]' \
          '*:Xcode version or latest:' && ret=0
        ;;
      extract)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '(-i --installation-directory)'{-i,--installation-directory=}'[install destination]:dir:_files -/' \
          '--use-system-unxip[use slower system unxip]' \
          '*:xip file:_files -g "*.xip"' && ret=0
        ;;
      info|uninstall)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '*:Xcode version or latest:' && ret=0
        ;;
      installed|cleanup)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' && ret=0
        ;;
    esac
    ;;
esac

return ret
