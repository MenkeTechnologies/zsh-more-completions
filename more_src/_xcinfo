#compdef xcinfo

# Zsh completion for xcinfo (XcodeReleasesOrg/xcinfo, swift-argument-parser)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'cleanup:remove stored Apple ID credentials'
      'download:download an Xcode xip'
      'extract:extract an already downloaded XIP'
      'info:show metadata for a version'
      'install:download and install an Xcode'
      'installed:list /Applications Xcode bundles'
      'list:list known Xcode releases'
      'uninstall:remove an installed Xcode'
    )
    _describe -t commands 'xcinfo command' commands && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '(-a --all)'{-a,--all}'[show all historical releases]' \
          '--no-update-list[use cached release list]' && ret=0
        ;;
      info|download|install|extract|uninstall)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' \
          '--no-update-list[use cached release list]' \
          '*:Xcode version or latest:' && ret=0
        ;;
      installed|cleanup)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
          '--ansi[colorized output]' \
          '--no-ansi[disable colors]' && ret=0
        ;;
    esac
    ;;
esac

return ret
