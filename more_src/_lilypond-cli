#compdef lilypond-cli
# _lilypond-cli — LilyPond music engraving program CLI alias (lilypond team, C++/Scheme); custom argparse
# upstream: https://gitlab.com/lilypond/lilypond

_lilypond-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--about[about info]' \
        '-d+[ly setting]:str:' \
        '--define-default=+[ly setting]:str:' \
        '-D+[scheme define]:str:' \
        '--define-scheme=+[scheme define]:str:' \
        '-e+[scheme expression]:str:' \
        '--evaluate=+[scheme expression]:str:' \
        '-f+[format]:f:(pdf png ps eps svg midi)' \
        '--format=+[format]:f:(pdf png ps eps svg midi)' \
        '-I+[include dir]:dir:_files -/' \
        '--include=+[include dir]:dir:_files -/' \
        '-i+[init file]:file:_files' \
        '--init=+[init file]:file:_files' \
        '-j+[jail dir]:dir:_files -/' \
        '--jail=+[jail dir]:dir:_files -/' \
        '-l+[loglevel]:l:(NONE ERROR WARNING BASIC PROGRESS INFO DEBUG)' \
        '--loglevel=+[loglevel]:l:(NONE ERROR WARNING BASIC PROGRESS INFO DEBUG)' \
        '-o+[output base]:file:_files' \
        '--output=+[output base]:file:_files' \
        '-O+[bitmap optimize]:m:(safe minimal high)' \
        '--pdf-bitmap-optimize=+[mode]:m:(safe minimal high)' \
        '-s[silent]' \
        '--silent[silent]' \
        '-V[show verbose log]' \
        '--verbose[show verbose log]' \
        '-w+[warning level]:n:' \
        '--warranty[show warranty]' \
        '--pdf[output PDF]' \
        '--png[output PNG]' \
        '--ps[output PostScript]' \
        '--svg[output SVG]' \
        '--eps[output EPS]' \
        '--no-pdf[no PDF]' \
        '--preview[preview output]' \
        '--bigpdfs[generate big PDFs]' \
        '--pdf-bitmap=+[resolution]:n:' \
        '--header=+[header]:str:' \
        '--include-settings=+[file]:file:_files' \
        '*:input files:_files -g "*.{ly,ily}"'
}

_lilypond-cli "$@"
