#compdef cyrus-mbexamine
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/mbexamine.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org mbexamine(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-mbexamine: examine a Cyrus mailbox
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '(-u --uid)'{-u+,--uid=}'[dump info for the given UID only]:uid:' \
  '(-s --seq)'{-s+,--seq=}'[dump info for the given sequence number only]:seqnum:' \
  '(-q --check-quota)'{-q,--check-quota}'[compare cyrus.index quota usage to actual message file sizes]' \
  '(-c --check-message-files)'{-c,--check-message-files}'[compare cyrus.index records to actual message files]' \
  '*:mailbox:' && ret=0
return ret
