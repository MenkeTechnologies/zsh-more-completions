#compdef redocly

# Zsh completion for redocly - Redocly OpenAPI CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files' \
  '--format=[output format]:format:(codeframe stylish json checkstyle codeclimate summary)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'lint:lint OpenAPI definitions'
      'bundle:bundle OpenAPI definitions'
      'preview-docs:preview API reference docs'
      'stats:show API definition statistics'
      'join:join multiple API definitions'
      'split:split an API definition'
      'push:push API definitions to Redocly'
      'login:log in to Redocly'
      'logout:log out of Redocly'
    )
    _describe -t commands 'redocly command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      lint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--format=[output format]:format:(codeframe stylish json checkstyle codeclimate summary)' \
          '--extends=[rulesets to extend]:rulesets' \
          '--skip-rule=[rule to skip]:rule' \
          '--skip-preprocessor=[preprocessor to skip]:name' \
          '--generate-ignore-file[generate ignore file]' \
          '--max-problems=[maximum number of problems]:int' \
          '--lint-config=[lint config severity]:severity:(warn error off)' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--format=[output format]:format:(codeframe stylish json checkstyle codeclimate summary)' \
          {-o,--output}'=[output file]:file:_files' \
          '--ext=[output file extension]:extension:(json yaml)' \
          '--dereferenced[produce a fully dereferenced bundle]' \
          '--force[force overwrite of output file]' \
          '--remove-unused-components[remove unused components]' \
          '--keep-url-references[keep URL references]' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      preview-docs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--port=[port to listen on]:port' \
          '--host=[host to bind to]:host' \
          '--skip-decorator=[decorator to skip]:name' \
          '--use-community-edition[use community edition]' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      stats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--format=[output format]:format:(codeframe stylish json checkstyle codeclimate summary)' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      join)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          {-o,--output}'=[output file]:file:_files' \
          '--prefix-tags-with-info-prop=[property to prefix tags with]:property' \
          '--prefix-tags-with-filename[prefix tags with filename]' \
          '--prefix-components-with-info-prop=[property to prefix components with]:property' \
          '--without-x-tag-groups[do not include x-tagGroups]' \
          '*:api definitions:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      split)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--outDir=[output directory]:directory:_directories' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[config file]:file:_files' \
          '--destination=[push destination]:destination' \
          {-b,--branch}'=[branch name]:branch' \
          '--batch-size=[batch size]:int' \
          '--upsert[upsert the API definition]' \
          '1:api definition:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      login|logout)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
