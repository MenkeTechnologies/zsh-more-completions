#compdef imtab
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imtab.html
# MIRIAD: tabulate image data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'region=[region of interest]:region:' \
  'clip=[tabulate above threshold]:clip:' \
  'scale=[data multiplier]:scale:' \
  'mode=[output format]:mode:(uvgen nemo)' \
  'format=[Fortran format specification]:format:' \
  'units=[coordinate units]:units:' \
  'log=[output destination]:log:_files' \
  '*:image:_files' && ret=0

return ret
