#compdef cellwriter
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cellwriter.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy cellwriter(1) manpage. GTK app, not KDE.
# Removed from prior file: bogus man.archlinux.org search URL.

# cellwriter: grid-entry natural handwriting recognition
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--log-level=[log detail level]:n:(0 3 4 5 7 8)' \
  '--log-file=[redirect log to file]:file:_files' \
  '--xid[start in embedded mode]' \
  '--disable-overwrite[prevent keymap modification]' \
  '--profile=[load profile file]:file:_files' \
  '--read-only[do not save profile changes]' \
  '--keyboard-only[keyboard-only mode]' \
  '(--hide-window)--show-window[show main window regardless of profile]' \
  '(--show-window)--hide-window[hide main window regardless of profile]' \
  '--window-x=[main window X position]:px:' \
  '--window-y=[main window Y position]:px:' \
  '--dock-window=[window docking]:n:((0\:none 1\:top 2\:bottom))' \
  '--window-struts[apply extended WM struts hint]' && ret=0
return ret
