#compdef staq_simplifier
# Documentation: https://github.com/softwareQinc/staq/wiki/The-staq-tool-suite
# staq tool: gate cancellation simplifier for OpenQASM

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-fixpoint[prevent iterative simplification]' && ret=0

return ret
