#compdef blocky

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'serve:start the DNS server'
  'blocking:control blocking state'
  'lists:manage block lists'
  'query:query the resolver'
  'cache:cache commands'
  'validate:validate config'
  'refresh:refresh lists'
  'version:print version'
  'healthcheck:health check'
)

_arguments -C \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.(yaml|yml)"' \
  '--apiHost=[API host]:host:_hosts' \
  '--apiPort=[API port]:port:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'blocky subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (blocking)
        _values 'blocking action' status enable disable && ret=0
        ;;
      (lists)
        _values 'lists action' refresh stats && ret=0
        ;;
    esac
    ;;
esac

return ret
