#compdef yandex-cli
# _yandex-cli — Yandex Cloud yandex-cli convenience alias (Yandex Cloud team); thin alias around `yc`
# upstream: https://github.com/yandex-cloud/yc

_yandex-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--profile+[profile]:profile:' \
        '--format+[output format]:fmt:(text json json-rest yaml)' \
        '--folder-id+[folder id]:str:' \
        '--cloud-id+[cloud id]:str:' \
        '--debug[debug]' \
        '--endpoint+[endpoint]:host:_hosts' \
        '*::args:'
}

_yandex-cli "$@"
