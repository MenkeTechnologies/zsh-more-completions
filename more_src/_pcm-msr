#compdef pcm-msr
# Documentation: https://man.archlinux.org/search?q=pcm-msr
# Reference accessed: 2026-05-16

# pcm-msr: Intel PCM raw MSR read/write helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[core (0-based)]:core:' \
  '-w[write value]:value:' \
  '-d[decimal output]' \
  '-i[show INDEX MSR table]' \
  '*:MSR register (hex):' && ret=0
return ret
