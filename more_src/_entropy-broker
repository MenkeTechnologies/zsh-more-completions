#compdef entropy-broker
# Documentation: https://www.vanheusden.com/entropybroker/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# entropy-broker: broker for distributing entropy across hosts (flok99/entropybroker).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '-l[log file]:file:_files' \
  '-p[PID file]:file:_files' \
  '-n[do not fork]' \
  '-s[show statistics]' \
  '-v[verbose]' \
  '*::entropy-broker args:_files' && ret=0
return ret
