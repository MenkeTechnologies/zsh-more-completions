#compdef ts-node-cli
# _ts-node-cli — Blake Embrey ts-node TypeScript execution for Node.js CLI alias (TypeStrong team, TypeScript); custom argparse
# upstream: https://github.com/TypeStrong/ts-node

_ts-node-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-e+[evaluate code]:str:' \
        '--eval=+[evaluate code]:str:' \
        '-p+[print result]:str:' \
        '--print=+[print result]:str:' \
        '-i[interactive REPL]' \
        '--interactive[interactive REPL]' \
        '-T[transpile only]' \
        '--transpile-only[transpile only]' \
        '-H+[language compiler host]:str:' \
        '--compiler-host=+[language compiler host]:str:' \
        '--esm[ES module mode]' \
        '--cwd-mode[cwd mode]' \
        '--script-mode[script mode]' \
        '-O+[compiler options json]:str:' \
        '--compiler-options=+[compiler options json]:str:' \
        '--type-check[type check (override --transpile-only)]' \
        '--swc[use swc for transpile]' \
        '--files[load files from tsconfig.json]' \
        '--prefer-ts-exts[prefer ts files]' \
        '--no-experimental-repl-await[no experimental REPL await]' \
        '-C+[compiler implementation]:str:' \
        '--compiler=+[compiler implementation]:str:' \
        '-I+[ignore pattern]:str:' \
        '--ignore=+[ignore pattern]:str:' \
        '-P+[tsconfig path]:file:_files -g "tsconfig*.json"' \
        '--project=+[tsconfig path]:file:_files -g "tsconfig*.json"' \
        '--skip-project[skip tsconfig]' \
        '-r+[require module]:str:' \
        '--require=+[require module]:str:' \
        '--scope[scope to current dir]' \
        '--scope-dir=+[dir]:dir:_files -/' \
        '--no-pretty[disable pretty errors]' \
        '--log-error[log error level]' \
        '--show-config[show resolved config]' \
        '--node-modules[respect node_modules]' \
        '--swc-only[swc only]' \
        '--debug[debug]' \
        '*:script args:_files'
}

_ts-node-cli "$@"
