#compdef marcel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --command)'{-c,--command}'=[execute command]:command:' \
  '(-e --execute)'{-e,--execute}'=[execute script file]:file:_files' \
  '--dill[use dill for serialization]' \
  '*:script:_files' && ret=0

return ret
