#compdef martin-cp
# Documentation: https://maplibre.org/martin/martin-cp.html
# martin-cp - bulk-copy tiles from Martin sources into an mbtiles file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-s,--source}'=[name of the source to copy from]:source' \
  '(-o --output-file)'{-o,--output-file}'=[path to the mbtiles file to copy to]:file:_files' \
  '--mbtiles-type=[output mbtiles schema]:type:(flat flat-with-hash normalized)' \
  '*--bbox=[bounds to copy (min_lon,min_lat,max_lon,max_lat)]:bbox' \
  '--min-zoom=[minimum zoom level to copy]:zoom' \
  '--max-zoom=[maximum zoom level to copy]:zoom' \
  '(-z --zoom-levels)'{-z,--zoom-levels}'=[list of zoom levels to copy]:levels' \
  '--concurrency=[number of concurrent connections]:n' \
  '(-p --pool-size)'{-p,--pool-size}'=[maximum Postgres connections pool size]:n' \
  '--skip-agg-tiles-hash[skip generating a global hash for mbtiles validation]' \
  '*--set-meta=[set additional metadata values (KEY=VALUE)]:keyvalue' \
  '*:connection:_default' && ret=0

return ret
