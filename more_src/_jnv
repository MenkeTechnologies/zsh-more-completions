#compdef jnv
# Documentation: https://man.archlinux.org/search?q=jnv
# Reference accessed: 2026-05-16

# Zsh completion for jnv - Interactive JSON filter using jq

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-e --edit-mode)'{-e,--edit-mode}'[edit mode for the interface]:mode:(insert overwrite)' \
  '(-n --no-hint)'{-n,--no-hint}'[disable jq filter hints]' \
  '(-f --filter)'{-f,--filter}'[initial jq filter]:filter:' \
  '*:JSON file:_files -g "*.json"' && ret=0

return ret
