#compdef jnv
# Documentation: https://github.com/ynqa/jnv
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Interactive JSON filter using jq. Corrected from prior file:
# the real CLI options are -c/--config, --default-filter and
# --write-to-stdout; the previous -e/--edit-mode, -n/--no-hint
# and -f/--filter flags were invented (those are config-file keys).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[path to configuration file]:config file:_files' \
  '--default-filter=[initial jq filter for the input data]:filter:' \
  '--write-to-stdout[write the current JSON result to stdout on exit]' \
  '*:JSON file:_files -g "*.json"' && ret=0

return ret
