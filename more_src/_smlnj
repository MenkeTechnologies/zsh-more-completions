#compdef sml smlnj ml-build ml-makedepend
# Documentation: https://man.archlinux.org/search?q=sml
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-quiet[quiet]' \
  '-Cprint.depth=[set print depth]:n:' \
  '-Ccompiler.poly-eq-warn=[poly-eq warn]:flag:(true false)' \
  '-Dname=value[define]:name=value:' \
  '-H[64-bit heap]' \
  '-m+[use makefile]:file:_files' \
  '-noload[do not load anything]' \
  '*:file:_files -g "*.{sml,sig,cm}"' && ret=0

return ret
