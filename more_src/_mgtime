#compdef mgtime
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/mgtime.txt
# Merge two or more GTI FITS files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'ingtis=[input GTI FITS file names to merge]:input files:_files' \
  'outgti=[merged output GTI FITS file]:output file:_files' \
  'merge=[merge mode AND or OR]:mode:(AND OR)' \
  'instarts=[start time column names in input files]:column:' \
  'instops=[stop time column names in input files]:column:' \
  'indates=[reference date keyword names]:keyword:' \
  'intimes=[reference start time keyword names]:keyword:' \
  'outstart=[start time column name in output file]:column:' \
  'outstop=[stop time column name in output file]:column:' \
  '*:file:_files' && ret=0

return ret
