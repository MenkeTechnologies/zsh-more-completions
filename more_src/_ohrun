#compdef ohrun
# Documentation: https://man.archlinux.org/search?q=ohrun
# Reference accessed: 2026-05-16

# ohrun: lightweight OpenHPI CLI wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-D[OpenHPI domain id]:n:' \
  '-d[debug output]' \
  '-c[OpenHPI config file]:file:_files' \
  '*:ohrun args:' && ret=0
return ret
