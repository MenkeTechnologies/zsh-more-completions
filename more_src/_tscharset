#compdef tscharset
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tscharset.cpp
# tscharset - test tool for DVB and ARIB character sets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --c-style)'{-c,--c-style}'[output binary data in C/C++ syntax using 0x prefix]' \
  '(-d --decode)'{-d,--decode}'=[decode binary data per default character set]:hexdata:' \
  '(-e --encode)'{-e,--encode}'=[encode string per default character set]:string:' \
  '(-8 --from-utf-8)'{-8,--from-utf-8}'[parameter is binary digits of UTF-8]' \
  '(-6 --from-utf-16)'{-6,--from-utf-16}'[parameter is binary digits of UTF-16]' \
  '--generate-arib-b24-encoding-table[generate ARIB STD-B24 encoding table]' \
  '(-l --list-charsets)'{-l,--list-charsets}'[list all known character set names]' \
  '(-o --output)'{-o,--output}'=[output file name]:file:_files' \
  '--to-utf-8[with --decode, display UTF-8 hex representation]' \
  '--to-utf-16[with --decode, display UTF-16 hex representation]' && ret=0

return ret
