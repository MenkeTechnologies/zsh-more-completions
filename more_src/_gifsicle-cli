#compdef gifsicle-cli
# _gifsicle-cli — Eddie Kohler gifsicle GIF animation tool CLI alias (kohler team, C); custom argparse
# upstream: https://github.com/kohler/gifsicle

_gifsicle-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--info[print info]' \
        '-I[print info]' \
        '--color-info[color info]' \
        '--cinfo[color info]' \
        '--extension-info[ext info]' \
        '--xinfo[ext info]' \
        '--size-info[size info]' \
        '--sinfo[size info]' \
        '--no-warnings[no warnings]' \
        '-w[no warnings]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--output=+[file]:file:_files -g "*.gif"' \
        '-o+[file]:file:_files -g "*.gif"' \
        '--multifile[multifile mode]' \
        '--explode[explode multi-image]' \
        '-e[explode multi-image]' \
        '--explode-by-name[explode by name]' \
        '-E[explode by name]' \
        '--unoptimize[unoptimize]' \
        '-U[unoptimize]' \
        '--no-comments[no comments]' \
        '--comment=+[comment]:str:' \
        '-c+[comment]:str:' \
        '--no-extensions[no extensions]' \
        '--no-names[no name extensions]' \
        '--extension=+[ext spec]:str:' \
        '-x+[ext spec]:str:' \
        '--app-extension=+[ext spec]:str:' \
        '--background=+[color]:str:' \
        '-B+[color]:str:' \
        '--loop=+[count]:n:' \
        '-l+[count]:n:' \
        '--no-loopcount[no loop count]' \
        '--delay=+[ms]:n:' \
        '-d+[ms]:n:' \
        '--disposal=+[mode]:m:(none asis background previous)' \
        '-D+[mode]:m:(none asis background previous)' \
        '--position=+[xy]:str:' \
        '-p+[xy]:str:' \
        '--transparent=+[color]:str:' \
        '-t+[color]:str:' \
        '--crop=+[geometry]:str:' \
        '--crop-transparency[crop transparent]' \
        '--flip-horizontal[flip horizontal]' \
        '--flip-vertical[flip vertical]' \
        '--rotate-90[rotate 90]' \
        '--rotate-180[rotate 180]' \
        '--rotate-270[rotate 270]' \
        '--no-rotate[no rotate]' \
        '--resize=+[wxh]:str:' \
        '--resize-fit=+[wxh]:str:' \
        '--resize-fit-height=+[h]:n:' \
        '--resize-fit-width=+[w]:n:' \
        '--resize-method=+[method]:m:(point lanczos2 lanczos3 mitchell mix sample)' \
        '--scale=+[ratio]:str:' \
        '--colors=+[count]:n:' \
        '-k+[count]:n:' \
        '--color-method=+[method]:m:(diversity blend-diversity median-cut)' \
        '--dither[dither]' \
        '-f[dither]' \
        '--gamma=+[g]:str:' \
        '--use-colormap=+[map]:str:' \
        '--optimize=+[level 1-3]:n:' \
        '-O+[level 1-3]:n:' \
        '--threads=+[n]:n:' \
        '-j+[n]:n:' \
        '--lossy=+[level]:n:' \
        '--careful[careful]' \
        '--change-color=+[c1 c2]:str:' \
        '*:files:_files -g "*.{gif,GIF}"'
}

_gifsicle-cli "$@"
