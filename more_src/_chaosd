#compdef chaosd

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'attack:create a chaos attack'
      'recover:recover from a chaos attack'
      'search:search chaos attacks'
      'server:start the chaosd server'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (attack)
        _arguments -C \
          '1:type:->attack_types' \
          '*::arg:->attack_args' && ret=0
        case $state in
          (attack_types)
            local -a types=(
              'process:attack processes'
              'network:attack network'
              'stress:stress system resources'
              'disk:attack disk'
              'host:attack host'
              'jvm:attack JVM'
              'clock:attack system clock'
            )
            _describe -t types 'attack type' types && ret=0
            ;;
          (attack_args)
            case ${words[1]} in
              (process)
                _arguments \
                  '1:action:(kill stop)' \
                  '(-p --process)'{-p,--process}'=[process name]:process:' \
                  '--signal=[signal to send]:signal:' \
                  '--uid=[experiment UID]:uid:' && ret=0
                ;;
              (network)
                _arguments \
                  '1:action:(delay loss duplicate corrupt partition dns bandwidth)' \
                  '--device=[network device]:device:' \
                  '--ip-address=[target IP]:ip:' \
                  '--hostname=[target hostname]:hostname:' \
                  '--direction=[traffic direction]:direction:(to from both)' \
                  '--latency=[latency in ms]:ms:' \
                  '--jitter=[jitter in ms]:ms:' \
                  '--correlation=[correlation percentage]:percent:' \
                  '--percent=[loss/corrupt/duplicate percentage]:percent:' \
                  '--uid=[experiment UID]:uid:' && ret=0
                ;;
              (stress)
                _arguments \
                  '1:action:(cpu mem)' \
                  '(-w --workers)'{-w,--workers}'=[number of workers]:workers:' \
                  '(-l --load)'{-l,--load}'=[CPU load percentage]:load:' \
                  '--size=[memory allocation size]:size:' \
                  '--uid=[experiment UID]:uid:' && ret=0
                ;;
              (disk)
                _arguments \
                  '1:action:(fill payload)' \
                  '(-p --path)'{-p,--path}'=[file path]:path:_files' \
                  '(-s --size)'{-s,--size}'=[fill size]:size:' \
                  '--percent=[fill percentage]:percent:' \
                  '--uid=[experiment UID]:uid:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (recover)
        _arguments '--uid=[experiment UID to recover]:uid:' && ret=0
        ;;
      (search)
        _arguments \
          '--uid=[experiment UID]:uid:' \
          '--status=[filter by status]:status:(created success destroyed revoked)' \
          '--kind=[filter by kind]:kind:' \
          '--all[show all experiments]' && ret=0
        ;;
      (server)
        _arguments \
          '(-p --port)'{-p,--port}'=[listen port]:port:' \
          '--host=[listen host]:host:' \
          '--log-level=[log level]:level:(debug info warn error)' && ret=0
        ;;
    esac
    ;;
esac

return ret
