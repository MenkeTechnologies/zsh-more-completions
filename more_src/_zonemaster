#compdef zonemaster-cli
# _zonemaster — Zonemaster CLI (Nordic-Net Zonemaster project's command-line DNS-zone testing tool; --level severity floor (DEBUG|INFO|NOTICE|WARNING|ERROR|CRITICAL), --test test name filter, --no-ipv4/--no-ipv6, --ns nameserver IP override, --time iso-8601 timestamps, --json output JSON; positional argument is the zone name to test)
# upstream: https://github.com/zonemaster/zonemaster-cli
# Flags from zonemaster/zonemaster-cli bin/zonemaster-cli on tip.

_zonemaster() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--level+[level]:level:(DEBUG INFO NOTICE WARNING ERROR CRITICAL)' \
        '*--test+[test name]:test:(address basic connectivity consistency delegation dnssec nameserver syntax zone)' \
        '--no-ipv4[no IPv4]' \
        '--no-ipv6[no IPv6]' \
        '*--ns+[ns ip override]:ip:' \
        '--time[show ISO timestamps]' \
        '--json[JSON output]' \
        '--save+[save report to file]:file:_files' \
        '--locale+[locale]:locale:' \
        '--profile+[profile file]:file:_files' \
        '--ds+[DS record]:ds:' \
        '--encoding+[output encoding]:encoding:' \
        '1:zone:'
}

_zonemaster "$@"
