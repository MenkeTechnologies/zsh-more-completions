#compdef nibid
# Documentation: https://github.com/NibiruChain/nibiru
# nibid - Nibiru Chain Cosmos-SDK node daemon

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'start:run the full node daemon'
  'init:initialize node config and state'
  'status:query remote node status'
  'keys:keyring management'
  'tx:create and broadcast transactions'
  'query:query blockchain state'
  'q:query alias'
  'genesis:genesis file commands'
  'comet:CometBFT subcommands'
  'config:create or query config'
  'export:export state to JSON'
  'rollback:rollback CometBFT state by one height'
  'prune:prune app state'
  'snapshots:state snapshot management'
  'debug:debug helpers'
  'version:print version'
  'help:show help'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--home=[node home directory]:dir:_files -/' \
  '--chain-id=[chain id]:id:' \
  '--node=[CometBFT RPC endpoint]:url:' \
  '--keyring-backend=[keyring backend]:b:(os file kwallet pass test memory)' \
  '--log_level=[log level]:l:(trace debug info warn error fatal panic)' \
  '--log_format=[log format]:f:(plain json)' \
  '(-o --output)'{-o,--output}'=[output format]:f:(text json)' \
  '--trace[print full stack trace on errors]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'nibid command' sub && ret=0 ;;
  args)
    case $words[1] in
      keys) _arguments '1:keys cmd:(add delete export import list mnemonic parse rename show migrate)' && ret=0 ;;
      comet) _arguments '1:comet cmd:(show-node-id show-validator show-address version reset-state unsafe-reset-all)' && ret=0 ;;
      genesis) _arguments '1:genesis cmd:(add-genesis-account collect-gentxs gentx migrate validate-genesis)' && ret=0 ;;
    esac
    ;;
esac

return ret
