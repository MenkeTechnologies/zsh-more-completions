#compdef marcli
# Documentation: https://github.com/hectorcorrea/marcli
# Reference accessed: 2026-05-19
# Verified: hectorcorrea/marcli README. Go-style single-dash long flags.
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# -h/--help and -V/--version flags (marcli does not document them).

# marcli: MARC (ISO 2709) command line parser

_arguments -s -S \
  '-file[MARC file to parse (binary or XML)]:file:_files' \
  '-match[filter records containing string]:string:' \
  '-matchRegEx[filter records matching regex]:pattern:' \
  '-matchFields[limit match to specific MARC fields]:fields:' \
  '-fields[output only specified fields]:fields:' \
  '-hasFields[output only records containing specified fields]:fields:' \
  '-exclude[remove full fields from output]:fields:' \
  '-format[output format]:format:(mrk xml json binary count-only)' \
  '-start[beginning position for record range]:n:' \
  '-count[number of records to output]:n:'
