#compdef git-number
# Documentation: https://man.archlinux.org/search?q=git-number
# Reference accessed: 2026-05-16

# https://formulae.brew.sh/formula/git-number — Numbered git index short aliases

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*::args:_default' && return 0
