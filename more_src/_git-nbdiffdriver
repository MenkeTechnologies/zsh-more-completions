#compdef git-nbdiffdriver
# Documentation: https://nbdime.readthedocs.io/en/latest/vcs.html
# git-nbdiffdriver - git diff driver entry point for Jupyter notebooks (nbdime)

local ret=1
local -a subcmds
subcmds=(
  'config:register/unregister the nbdime diff driver with git'
  'diff:run the terminal diff (invoked by git)'
  'webdiff:run the web diff (invoked by git)'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'git-nbdiffdriver command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      config)
        _arguments \
          '--enable[register the diff driver]' \
          '--disable[unregister the diff driver]' \
          '--global[apply at user level]' \
          '--system[apply at system level]' && ret=0
        ;;
      diff|webdiff)
        _arguments '--ip=[interface to listen on]:ip:' '*:notebook:_files -g "*.ipynb"' && ret=0
        ;;
    esac
    ;;
esac

return ret
