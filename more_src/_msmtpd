#compdef msmtpd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--interface=[listen on specified interface]:interface:_net_interfaces' \
  '--port=[listen on specified port]:port number:' \
  '--log=[set log type]:log type:(none syslog file)' \
  '--command=[pipe mail to specified command]:command:_command_names' \
  '--version[display version information]' \
  '--help[display help information]' \
  && ret=0

return ret
