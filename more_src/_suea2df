#compdef suea2df
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/suea2df.c
# (An)elastic anisotropic 2D finite difference forward modeling, 4th order in space

local ret=1

_arguments -s -S \
  'c11file=[c11 Voigt elasticity parameter filename]:c11file:_files' \
  'c55file=[c55 Voigt elasticity parameter filename]:c55file:_files' \
  'dt=[time sampling interval (s)]:dt' \
  'ft=[first time (s)]:ft' \
  'lt=[last time (s)]:lt' \
  'nx=[number of values in x-direction]:nx' \
  'dx=[spatial sampling interval x-coordinate (m)]:dx' \
  'fx=[first x coordinate (m)]:fx' \
  'nz=[number of values in z-dimension]:nz' \
  'dz=[spatial sampling interval z-coordinate (m)]:dz' \
  'fz=[first z coordinate (m)]:fz' \
  'sx=[source x position (m)]:sx' \
  'sz=[source z position (m)]:sz' \
  'stype=[source type: p v pw]:stype:(p v pw)' \
  'sang=[plane wave angle (degrees)]:sang' \
  'wtype=[wave type: dg ga ri sp sp2]:wtype:(dg ga ri sp sp2)' \
  'ts=[source duration (s)]:ts' \
  'favg=[source average frequency (Hz)]:favg' \
  'aniso=[=1 to include anisotropy parameters]:aniso:(0 1)' \
  'c13file=[c13 stiffness file]:c13file:_files' \
  'c33file=[c33 stiffness file]:c33file:_files' \
  'c15file=[c15 stiffness file]:c15file:_files' \
  'c35file=[c35 stiffness file]:c35file:_files' \
  'qsw=[=1 to include attenuation]:qsw:(0 1)' \
  'qfile=[Q parameter filename]:qfile:_files' \
  'bc=[boundary conditions top,left,bottom,right]:bc' \
  'bc_a=[absorbing boundary taper parameter]:bc_a' \
  'bc_r=[absorbing boundary taper parameter]:bc_r' \
  'sofile=[source filename]:sofile:_files' \
  'snfile=[snapshot filename]:snfile:_files' \
  'snaptime=[snapshot times]:snaptime' \
  'vrslfile=[vertical seismogram output file]:vrslfile:_files' \
  'hsfile=[horizontal seismogram output file]:hsfile:_files' \
  'vsx=[receiver line x coordinate]:vsx' \
  'hsz=[receiver line z coordinate]:hsz' \
  'rhofile=[density filename]:rhofile:_files' \
  'verbose=[=1 to print progress]:verbose:(0 1)' \
  'mode=[=0 particle velocity; =1 stresses]:mode:(0 1)' \
  'tsw=[=1 to use shear stress only in non-fluid media]:tsw:(0 1)' \
  'mfile=[model filename]:mfile:_files' \
  '*:file:_files' && ret=0

return ret
