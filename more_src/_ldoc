#compdef ldoc
# Documentation: https://stevedonovan.github.io/ldoc/manual/doc.md.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-d --dir)'{-d+,--dir=}'[output directory]:dir:_files -/' \
  '(-o --output)'{-o+,--output=}'[output file name]:name:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.lua"' \
  '(-f --format)'{-f+,--format=}'[markup processor]:format:(plain markdown discount)' \
  '(-s --style)'{-s+,--style=}'[stylesheet directory]:dir:_files -/' \
  '(-l --template)'{-l+,--template=}'[template directory]:dir:_files -/' \
  '(-p --project)'{-p+,--project=}'[project name]:name:' \
  '(-t --title)'{-t+,--title=}'[page title]:title:' \
  '(-b --package)'{-b+,--package=}'[base package name]:name:' \
  '(-x --ext)'{-x+,--ext=}'[output file extension]:extension:' \
  '(-a --all)'{-a,--all}'[include local functions]' \
  '(-B --no-boilerplate)'{-B,--no-boilerplate}'[ignore first comment block]' \
  '(-C --colon)'{-C,--colon}'[use colon-style tags instead of @]' \
  '-m+[look up installed Lua module]:module:' \
  '(-w --wrap)'{-w,--wrap}'[allow long names to wrap]' \
  '--dump[dump parsed module data]' \
  '--tags=[extract specified tags]:tags:' \
  '--filter=[process output with custom function]:function:' \
  '*:input:_files -g "*.lua"' && ret=0

return ret
