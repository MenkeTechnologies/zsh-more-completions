#compdef ldoc
# Documentation: https://man.archlinux.org/search?q=ldoc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d+[output directory]:dir:_files -/' \
  '-o+[output file name]:name:' \
  '-c+[config file]:file:_files -g "*.lua"' \
  '-f+[output format]:format:(html plain markdown latex)' \
  '-s+[stylesheet]:file:_files -g "*.css"' \
  '-l+[template directory]:dir:_files -/' \
  '-p+[project name]:name:' \
  '-t+[title]:title:' \
  '-b+[base path]:dir:_files -/' \
  '-i[ignore docstring of items beginning with underscore]' \
  '-x+[exclude pattern]:pattern:' \
  '-X+[exclude pattern (regex)]:pattern:' \
  '-D+[debug level]:level:' \
  '-m+[merge multiple files]:files:' \
  '-r[recurse subdirectories]' \
  '-q[quiet]' \
  '-S[show source]' \
  '-w+[wrapping format]:fmt:' \
  '-a[all files]' \
  '-A[create README]' \
  '-B+[base dir]:dir:_files -/' \
  '-C+[examples dir]:dir:_files -/' \
  '-E+[topic dir]:dir:_files -/' \
  '-F[fail on errors]' \
  '-M+[multi-file template]:tpl:' \
  '-O+[output module]:mod:' \
  '-P+[pretty-print code]:flag:' \
  '-T+[topic file]:file:_files' \
  '-Z[run unit tests]' \
  '*:input:_files -g "*.lua"' && ret=0

return ret
