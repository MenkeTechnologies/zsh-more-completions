#compdef ismindex
# Documentation: https://man.archlinux.org/search?q=ismindex
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-split[split files into multiple files]' \
  '-ismf[generate ISMF format]' \
  '-n+[base name]:name:' \
  '-path-prefix+[path prefix]:prefix:' \
  '-ismc-prefix+[ISMC prefix]:prefix:' \
  '-output+[output directory]:dir:_files -/' \
  '*:input file:_files' && ret=0

return ret
