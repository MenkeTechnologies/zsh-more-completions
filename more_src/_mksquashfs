#compdef mksquashfs

_arguments -s \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-comp[compression algorithm]:algorithm:(gzip lzma lzo lz4 xz zstd)' \
  '-b[block size]:block size' \
  '-no-progress[do not display progress bar]' \
  '-progress[display progress bar]' \
  '-percentage[display completion percentage]' \
  '-info[print files as they are compressed]' \
  '-no-exports[do not make filesystem exportable]' \
  '-no-sparse[do not detect sparse files]' \
  '-no-xattrs[do not store extended attributes]' \
  '-xattrs[store extended attributes]' \
  '-xattrs-exclude[exclude xattrs matching regex]:regex' \
  '-xattrs-include[include only xattrs matching regex]:regex' \
  '-noI[do not compress inode table]' \
  '-noD[do not compress data blocks]' \
  '-noF[do not compress fragment blocks]' \
  '-noX[do not compress extended attributes]' \
  '-no-fragments[do not use fragments]' \
  '-always-use-fragments[always use fragments]' \
  '-no-duplicates[do not perform duplicate checking]' \
  '-all-root[make all files owned by root]' \
  '-root-uid[set root directory uid]:uid' \
  '-root-gid[set root directory gid]:gid' \
  '-root-time[set root directory time]:time' \
  '-root-mode[set root directory permissions]:mode' \
  '-root-becomes[make original root a subdirectory]:name' \
  '-processors[number of processors to use]:number' \
  '-mem[set memory limit]:size' \
  '-quiet[suppress output]' \
  '-one-file-system[do not cross filesystem boundaries]' \
  '-keep-as-directory[keep source directory as subdirectory]' \
  '-noappend[do not append to existing filesystem]' \
  '-append[append to existing filesystem]' \
  '-force-uid[set all file uids]:uid' \
  '-force-gid[set all file gids]:gid' \
  '-e[exclude files]:exclude list' \
  '-ef[exclude files listed in file]:exclude file:_files' \
  '-wildcards[allow wildcards in exclude list]' \
  '-regex[allow POSIX regex in exclude list]' \
  '-p[pseudo file definition]:definition' \
  '-pf[pseudo file list]:file:_files' \
  '-sort[sort file]:sort file:_files' \
  '-no-strip[do not strip directory prefix]' \
  '-nostrip[do not strip directory prefix]' \
  '-offset[skip bytes at start of destination]:offset' \
  '-o[set byte order]:order:(be le)' \
  '-Xbcj[BCJ filter]:filter' \
  '-Xdict-size[dictionary size]:size' \
  '-Xcompression-level[compression level]:level' \
  '1:destination filesystem:_files' \
  '*:source:_files'
