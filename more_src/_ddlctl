#compdef ddlctl
# Documentation: https://man.archlinux.org/search?q=ddlctl
# Reference accessed: 2026-05-16
# Derived from https://github.com/hakadoriya/ddlctl/blob/main/pkg/ddlctl/ddlctl.go (Apache-2.0)

local curcontext="$curcontext" state line ret=1
local -a cmds

cmds=(
  'version:show build version'
  'generate:generate DDL from source to destination'
  'gen:alias for generate'
  'show:show DDL from DSN (SHOW CREATE TABLE style)'
  'diff:diff DDL between sources'
  'apply:apply DDL from source to destination'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--trace[trace mode enabled]' \
  '--debug[debug mode]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'ddlctl command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      generate|gen)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lang=[programming language]:lang:(go)' \
          '--dialect=[SQL dialect]:dialect:(mysql postgres cockroachdb spanner)' \
          '--go-column-tag=[Go struct column tag key]:key:' \
          '--go-ddl-tag=[Go struct DDL tag key]:key:' \
          '--go-pk-tag=[Go struct primary key tag key]:key:' \
          '*:path:_files' && ret=0
        ;;
      show)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dialect=[SQL dialect]:dialect:(mysql postgres cockroachdb spanner)' \
          '*:args:' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lang=[programming language]:lang:(go)' \
          '--dialect=[SQL dialect]:dialect:(mysql postgres cockroachdb spanner)' \
          '--go-column-tag=[Go struct column tag key]:key:' \
          '--go-ddl-tag=[Go struct DDL tag key]:key:' \
          '--go-pk-tag=[Go struct primary key tag key]:key:' \
          '*:path:_files' && ret=0
        ;;
      apply)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lang=[programming language]:lang:(go)' \
          '--dialect=[SQL dialect]:dialect:(mysql postgres cockroachdb spanner)' \
          '--go-column-tag=[Go struct column tag key]:key:' \
          '--go-ddl-tag=[Go struct DDL tag key]:key:' \
          '--go-pk-tag=[Go struct primary key tag key]:key:' \
          '--auto-approve[auto approve without prompt]' \
          '*:path:_files' && ret=0
        ;;
      version)
        _message 'no arguments' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
