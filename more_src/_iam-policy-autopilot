#compdef iam-policy-autopilot
# ============================================================================
# _iam-policy-autopilot — zsh completion for awslabs/iam-policy-autopilot,
#                          "an open source static code analysis tool that
#                          helps your AI coding assistants quickly create
#                          baseline IAM policies" (Rust=144 leader bump
#                          OPENING Axis 89 AWS SDK / aws-sdk-rust)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/awslabs/iam-policy-autopilot
#   Maintainer : AWS Labs (awslabs)
#   License    : Apache-2.0
#   Stars      : 370
#   Language   : Rust
#   Crate      : iam-policy-autopilot-cli  (workspace member)
#   Binary     : iam-policy-autopilot  (iam-policy-autopilot-cli/
#                Cargo.toml [[bin]] name = "iam-policy-autopilot",
#                path = "src/main.rs")
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   iam-policy-autopilot is "an open source Model Context Protocol
#   (MCP) server and command-line tool that helps your AI coding
#   assistants quickly create baseline IAM policies that you can
#   refine as your application evolves" — AWS Labs' static-analysis
#   driver that walks source files (Python, TypeScript, JavaScript,
#   Go, Rust, Java, C++, C, C#) and Terraform projects via
#   ast-grep, identifies every AWS SDK method call, joins each
#   call to the canonical IAM action via Service Reference data,
#   and emits a minimal-permission IAM policy document.  It also
#   parses CloudTrail / Lambda / raw AccessDenied error messages,
#   computes the missing permission delta, and (with `--yes`)
#   uploads the policy fix back to AWS through aws-sdk-iam.
#
# CLI ARGUMENT GRAMMAR  (verbatim from iam-policy-autopilot-cli/
#                       src/main.rs `Commands` enum — clap derive)
#   iam-policy-autopilot <SUBCOMMAND> [args...]
#
#   Subcommands:
#     fix-access-denied [<ERROR_TEXT>]
#                                    Parse AccessDenied error and
#                                    generate / apply the IAM
#                                    policy fix (reads stdin if no
#                                    arg).  Supports explicit and
#                                    implicit (CloudTrail) denial
#                                    forms.
#       -y, --yes                      Apply fix without prompting
#                                      (implicit identity denials
#                                      only)
#
#     generate-policies <FILES...>   Generate baseline IAM policy
#                                    documents from source files +
#                                    optional Terraform project
#       -p, --pretty                   Pretty-print JSON output
#       -l, --language <LANG>          Override language detection
#                                      (python|typescript|
#                                      javascript|go|rust|java|
#                                      cpp|c|csharp)
#       --region <REGION>              AWS region
#       --account <ACCOUNT_ID>         AWS account ID
#       --individual-policies          Emit per-service policies
#                                      instead of a merged policy
#       --upload-policies [<PREFIX>]   Upload policies to AWS IAM
#                                      with optional name prefix
#       --minimize-policy-size         Allow cross-service merging
#                                      to minimize policy bytes
#       --disable-cache                Disable filesystem cache
#                                      for service references
#       --service-hints <SVC...>       Restrict analysis to listed
#                                      AWS services
#       --explain [<ACTION...>]        Emit explanations for added
#                                      actions
#       --explain-resources <ARN...>   Filter resource-binding
#                                      explanations by ARN pattern
#       --tf-dir <DIR>                 Terraform project directory
#       --tf-files <FILE...>           Individual Terraform files
#       --tfvars <FILE...>             Explicit .tfvars files
#       --tfstate <FILE...>            terraform.tfstate paths
#       --full-output                  Emit full ExtractedMethods
#                                      structure (with metadata)
#
#     extract-sdk-calls <FILES...>   [HIDDEN] Extract AWS SDK
#                                    method calls from source as
#                                    JSON without enrichment
#       -p, --pretty / -l, --language / --full-output /
#       --service-hints                (same as generate-policies)
#
#     mcp-server                     Start the MCP server for AI
#                                    coding assistant integration
#       -t, --transport <TRANSPORT>    Transport (stdio|http)
#                                      [default: stdio]
#       -p, --port <PORT>              HTTP port (only with
#                                      --transport=http)
#                                      [default: 8001]
#       -b, --bind-address <ADDR>      Bind address (only with
#                                      --transport=http)
#                                      [default: 127.0.0.1]
#
#     telemetry                      Manage anonymous telemetry
#                                    settings (persisted at
#                                    ~/.iam-policy-autopilot/
#                                    config.json)
#       --enable                       Enable telemetry
#       --disable                      Disable telemetry
#       --status                       Show current telemetry state
#
#     version                        Print version information
#       -V, --version                  (also as short/long flag at
#                                      root: `iam-policy-autopilot
#                                      -V` / `--version`)
#
#   Note: telemetry can also be disabled via env
#   DISABLE_IAM_POLICY_AUTOPILOT_TELEMETRY=true.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `aws-sdk-iam = "1.108.1"` and
#   `aws-sdk-sts = "1.103.0"` declared in the
#   `iam-policy-autopilot-access-denied` workspace crate
#   (transitively pulled in by the CLI binary).  `aws-sdk-iam`,
#   `aws-sdk-sts`, and the broader `aws-sdk-*` family are THE
#   canonical Rust AWS SDK maintained by AWS itself (awslabs/
#   aws-sdk-rust, 4K+ stars).  aws-sdk-rust is the
#   smithy-rs-generated, async-tokio-native, fully typed Rust
#   counterpart of aws-sdk-go-v2 and aws-sdk-js v3:  it exposes
#   `aws_config::load_defaults`, `aws_config::SdkConfig`, the
#   per-service `aws_sdk_iam::Client`, `aws_sdk_sts::Client`,
#   `aws_sdk_s3::Client`, etc., with typed input/output Smithy
#   shapes, paginators, waiters, credential providers
#   (`aws_credential_types::Credentials`,
#   `aws_credential_types::provider::SharedCredentialsProvider`),
#   STS assume-role flow, IAM Identity Center / SSO,
#   IMDSv2 instance metadata, environment-variable + shared-
#   config-file chains, transport layers via `aws-smithy-runtime`
#   over `hyper-rustls`, and a uniform error model
#   (`aws_sdk_*::Error`).  iam-policy-autopilot's
#   `iam-policy-autopilot-tools` crate uses
#   `aws_sdk_iam::Client::put_user_policy`,
#   `aws_sdk_iam::Client::create_policy`, and
#   `aws_sdk_iam::Client::attach_user_policy` to upload
#   generated policies, and `aws_sdk_sts::Client::
#   get_caller_identity` to resolve the active account when
#   `--account` is omitted.  Verified via:
#     gh api repos/awslabs/iam-policy-autopilot/contents/
#         Cargo.toml
#       → aws-sdk-iam = "1.108.1"
#       → aws-sdk-sts = "1.103.0"
#       → license = "Apache-2.0"
#     gh api repos/awslabs/iam-policy-autopilot/contents/
#         iam-policy-autopilot-cli/Cargo.toml
#       → [[bin]] name = "iam-policy-autopilot"
#         path = "src/main.rs"
#     gh api repos/awslabs/iam-policy-autopilot/contents/
#         iam-policy-autopilot-access-denied/Cargo.toml
#       → aws-sdk-iam = { workspace = true }
#       → aws-sdk-sts = { workspace = true }
#     gh api repos/awslabs/iam-policy-autopilot/contents/
#         iam-policy-autopilot-cli/src/main.rs
#       → enum Commands { FixAccessDenied{...},
#           ExtractSdkCalls{...}, GeneratePolicies{...},
#           McpServer{...}, Version{...}, Telemetry{...} }
#   This entry is the Rust=144 leader bump that OPENS Axis 89
#   (AWS SDK / aws-sdk-rust) at 1/0/0.  Pairing Go and TS-Node
#   bumps will follow at R946 and R947 (Go=144 candidates
#   aws/aws-sdk-go-v2-based CLIs; TS-Node=144 candidates
#   @aws-sdk/client-* AWS SDK v3 users).
#
#   No completion for `iam-policy-autopilot` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_iam-policy-autopilot() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_iam_policy_autopilot_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                fix-access-denied)
                    _arguments \
                        '(-y --yes)'{-y,--yes}'[apply fix without prompting (implicit denials only)]' \
                        '::AccessDenied error text:' && ret=0 ;;
                generate-policies)
                    _arguments \
                        '(-p --pretty)'{-p,--pretty}'[pretty-print JSON output]' \
                        '(-l --language)'{-l,--language}'=[override language detection]:lang:(python typescript javascript go rust java cpp c csharp)' \
                        '--region=[AWS region]:region:' \
                        '--account=[AWS account ID]:account:' \
                        '--individual-policies[emit per-service policies]' \
                        '--upload-policies=[upload to AWS with optional name prefix]:prefix:' \
                        '--minimize-policy-size[allow cross-service merging]' \
                        '--disable-cache[disable filesystem cache]' \
                        '*--service-hints=[restrict to listed AWS services]:svc:' \
                        '--explain=[emit explanations for added actions]:action:' \
                        '*--explain-resources=[filter resource-binding by ARN pattern]:arn:' \
                        '--tf-dir=[Terraform project directory]:dir:_files -/' \
                        '*--tf-files=[individual Terraform files]:file:_files' \
                        '*--tfvars=[explicit .tfvars files]:file:_files -g "*.tfvars"' \
                        '*--tfstate=[terraform.tfstate paths]:file:_files' \
                        '--full-output[emit full ExtractedMethods structure]' \
                        '*:source file:_files' && ret=0 ;;
                extract-sdk-calls)
                    _arguments \
                        '(-p --pretty)'{-p,--pretty}'[pretty-print JSON output]' \
                        '(-l --language)'{-l,--language}'=[override language detection]:lang:(python typescript javascript go rust java cpp c csharp)' \
                        '--full-output[emit full ExtractedMethods structure]' \
                        '*--service-hints=[restrict to listed AWS services]:svc:' \
                        '*:source file:_files' && ret=0 ;;
                mcp-server)
                    _arguments \
                        '(-t --transport)'{-t,--transport}'=[transport mechanism]:transport:(stdio http)' \
                        '(-p --port)'{-p,--port}'=[HTTP port (only with --transport=http)]:port:' \
                        '(-b --bind-address)'{-b,--bind-address}'=[bind address (only with --transport=http)]:addr:' && ret=0 ;;
                telemetry)
                    _arguments \
                        '--enable[enable anonymous telemetry]' \
                        '--disable[disable anonymous telemetry]' \
                        '--status[show current telemetry state]' && ret=0 ;;
                version)
                    _arguments && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_iam_policy_autopilot_commands] )) ||
_iam_policy_autopilot_commands() {
    local -a commands
    commands=(
        'fix-access-denied:parse AccessDenied error and generate/apply IAM policy fix'
        'generate-policies:generate baseline IAM policy documents from source files'
        'extract-sdk-calls:extract AWS SDK method calls from source as JSON'
        'mcp-server:start the MCP server for AI coding assistant integration'
        'telemetry:manage anonymous telemetry settings'
        'version:print version information'
    )
    _describe -t commands 'iam-policy-autopilot command' commands
}

_iam-policy-autopilot "$@"
