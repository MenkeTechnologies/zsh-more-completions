#compdef rmate

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-H+,--host=}'[connect to HOST]:host:_hosts' \
  {-p+,--port=}'[port]:port:' \
  {-w,--wait}'[wait for editor to close before exiting]' \
  {-l+,--line=}'[line number to open at]:n:' \
  {-m+,--name=}'[name for the document]:name:' \
  {-t+,--type=}'[file type]:type:' \
  {-n,--new}'[create a new document if file does not exist]' \
  {-f,--force}'[open file even if not writable]' \
  {-v,--verbose}'[verbose output]' \
  '--no-rec[do not write modified file]' \
  '*:file:_files' && ret=0

return ret
