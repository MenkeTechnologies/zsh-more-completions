#compdef openvpn3
# _openvpn3 — OpenVPN 3 Linux openvpn3 client (Linux-only D-Bus-based OpenVPN 3 client; subcommands: session-start, session-stats, session-manage, session-acl, sessions-list, config-import, config-manage, config-acl, configs-list, log, version, system-info, journal, completion; --config import path / --config-path D-Bus path, --persist-tun, --persist-key, --setenv KEY=VAL)
# upstream: https://github.com/OpenVPN/openvpn3-linux
# Subcommands from OpenVPN/openvpn3-linux src/ovpn3cli on tip.

_openvpn3() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'openvpn3 command' '(session-start session-stats session-manage session-acl sessions-list config-import config-manage config-acl configs-list configs-prefer-persist log journal version completion system-info help)' ;;
        args)
            case $line[1] in
                session-start) _arguments \
                    '--config+[ovpn config]:file:_files -g "*.ovpn"' \
                    '--config-path+[D-Bus path]:path:' \
                    '--persist-tun[persist tun]' \
                    '--persist-key[persist key]' \
                    '*--setenv+[KEY=VAL]:env:' ;;
                config-import) _arguments \
                    '--config+[ovpn config]:file:_files -g "*.ovpn"' \
                    '--name+[friendly name]:name:' \
                    '--persistent[persistent]' \
                    '--single-use[single use]' ;;
                completion) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_openvpn3 "$@"
