#compdef grit

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'apply:apply a GritQL pattern or named pattern'
      'check:check for pattern matches without applying'
      'list:list available patterns'
      'patterns-list:list available patterns'
      'patterns-test:test patterns'
      'version:print version'
      'plumbing:low-level plumbing commands'
      'lsp:start the language server'
      'install:install grit modules'
      'init:initialize a grit project'
      'auth:authenticate with grit cloud'
    )
    _describe -t commands 'grit command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (apply)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--language=[target language]:language:(js ts python rust go java css html json yaml toml sql ruby php swift kotlin)' \
          '--output=[output format]:format:(standard json)' \
          '--json[output results as JSON]' \
          '--force[apply changes without confirmation]' \
          '--dry-run[preview changes without applying]' \
          '1:pattern' \
          '*:path:_files' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--language=[target language]:language:(js ts python rust go java css html json yaml toml sql ruby php swift kotlin)' \
          '--output=[output format]:format:(standard json)' \
          '--json[output results as JSON]' \
          '1:pattern' \
          '*:path:_files' && ret=0
        ;;
      (list|patterns-list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--json[output as JSON]' && ret=0
        ;;
      (patterns-test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:pattern name' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--global[initialize globally]' && ret=0
        ;;
      (auth)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          'login:authenticate with grit cloud' \
          'logout:log out of grit cloud' && ret=0
        ;;
    esac
    ;;
esac

return ret
