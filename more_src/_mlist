#compdef mlist
# Documentation: https://manpages.debian.org/testing/mblaze/mlist.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-D[only list draft messages]' \
  '-F[only list flagged messages]' \
  '-P[only list passed messages]' \
  '-R[only list replied-to messages]' \
  '-S[only list seen messages]' \
  '-T[only list trashed messages]' \
  '-X+[only list messages with marker characters in str]:str:' \
  '-d[exclude draft messages]' \
  '-f[exclude flagged messages]' \
  '-p[exclude passed messages]' \
  '-r[exclude replied-to messages]' \
  '-s[exclude seen messages]' \
  '-t[exclude trashed messages]' \
  '-x+[exclude messages with marker characters in str]:str:' \
  '-C[only list messages in cur]' \
  '-N[only list messages in new]' \
  '-c[exclude messages in cur]' \
  '-n[exclude messages in new]' \
  '-i[print one-line summary per folder instead of filenames]' \
  '*:maildir:_files -/' && ret=0

return ret
