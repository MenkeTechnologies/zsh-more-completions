#compdef mlist

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-s[show only seen messages]' \
  '-S[show only unseen messages]' \
  '-r[show only replied messages]' \
  '-R[show only unreplied messages]' \
  '-f[show only flagged messages]' \
  '-F[show only unflagged messages]' \
  '-d[show only draft messages]' \
  '-D[show only non-draft messages]' \
  '-t[show only trashed messages]' \
  '-T[show only non-trashed messages]' \
  '-p[show only passed/forwarded messages]' \
  '-P[show only non-passed messages]' \
  '-i[print message IDs]' \
  '-N[show only new messages]' \
  '*:maildir:_files -/' && ret=0

return ret
