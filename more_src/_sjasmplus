#compdef sjasmplus sjasm
# Documentation: https://z00m128.github.io/sjasmplus/documentation.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--zxnext[ZX Spectrum Next]' \
  '--zxnext=cspect[CSpect mode]' \
  '--i8080[Intel 8080]' \
  '--lr35902[Game Boy CPU]' \
  '--reversepop[reverse pop order]' \
  '--norevpop[no reverse pop]' \
  '--dirbol[directives at beginning]' \
  '--nofakes[no fake instructions]' \
  '--fakes[allow fakes]' \
  '--dos866[DOS 866 charset]' \
  '--syntax=[syntax options]:opts:' \
  '*-i+[include path]:dir:_files -/' \
  '*-I+[include path]:dir:_files -/' \
  '*--inc=[include path]:dir:_files -/' \
  '-D+[define]:macro:' \
  '*--define=[define]:macro:' \
  '--lst+[list file]:file:_files' \
  '--lstlab+[list with labels]:opt:(sort nosort)' \
  '--sym+[symbol output]:file:_files' \
  '--exp+[exports file]:file:_files' \
  '--raw+[raw output]:file:_files' \
  '--msg+[message level]:m:(none err war all lst lstlab)' \
  '--fullpath[full path in errors]' \
  '--longptr[long pointers]' \
  '--color=[color mode]:m:(on off auto)' \
  '*: :_files -g "*.asm *.z80 *.s *.inc"' && ret=0

return ret
