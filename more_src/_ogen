#compdef ogen

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '(* -)--version[print version and exit]' \
  '--config=[path to ogen config]:file:_files -g "*.yaml" "*.yml"' \
  '--clean[clean generated *_gen.go files before write]' \
  '--package=[Go package name for output]:name:' \
  '--strict[disable cross-type constraint interpretation]' \
  '--target=[output directory]:dir:_files -/' \
  '--cpuprofile=[write CPU profile to file]:file:_files' \
  '--memprofile=[write heap profile to file]:file:_files' \
  '--memprofilerate=[runtime.MemProfileRate value]:rate:' \
  '1:OpenAPI file or URL:_files'
