#compdef sic
# Documentation: https://github.com/foresterre/sic
# Reference accessed: 2026-05-17
# Verified: foresterre/sic Rust image conversion CLI (imagineer-
# generated). NOTE: distinct from suckless.org `sic` IRC client
# (which uses single-dash flags -h HOST, -p PORT, -n NICK, -k PASS,
# -f FULLNAME, -v). This completion targets the Rust image tool.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::script path or operation:_files' && ret=0

return ret
