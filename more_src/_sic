#compdef sic
# Documentation: https://man.archlinux.org/search?q=sic
# Reference accessed: 2026-05-16

# https://github.com/foresterre/sic — CLI is generated via imagineer; defer to --help for pipelines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::script path or operation:_files' && ret=0

return ret
