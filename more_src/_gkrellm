#compdef gkrellm gkrellmd

local curcontext="$curcontext" ret=1

case $service in
  (gkrellmd)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-c --config)'{-c,--config}'+[config file]:file:_files' \
      '(-d --detach)'{-d,--detach}'[run as daemon]' \
      '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
      '(-p --port)'{-p,--port}'+[listen port]:port:' \
      '(-u --update-hz)'{-u,--update-hz}'+[update Hz]:hz:' \
      '(-m --max-clients)'{-m,--max-clients}'+[max clients]:n:' \
      '(-A --allow-host)'{-A,--allow-host}'+[allow host]:host:_hosts' \
      '(-P --pid-file)'{-P,--pid-file}'+[PID file]:file:_files' \
      '(-D --debug-level)'{-D,--debug-level}'+[debug level]:level:' \
      '(--io-timeout)--io-timeout=+[I/O timeout sec]:sec:' \
      '(--reconnect-timeout)--reconnect-timeout=+[reconnect timeout sec]:sec:' \
      '(--mailbox)--mailbox=+[monitor mailbox]:file:_files' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-d --debug-level)'{-d,--debug-level}'+[debug level]:level:' \
      '(-g --geometry)'{-g,--geometry}'+[geometry WxH+X+Y]:geom:' \
      '(-p --plugin)'{-p,--plugin}'+[load plugin]:plugin:_files' \
      '(-P --port)'{-P,--port}'+[connect to port]:port:' \
      '(-s --server)'{-s,--server}'+[server host]:host:_hosts' \
      '(-t --theme)'{-t,--theme}'+[theme]:dir:_files -/' \
      '(-w --withdrawn)'{-w,--withdrawn}'[start withdrawn]' \
      '--display=[X display]:display:' \
      '--demo[demo mode]' \
      '--config=[config dir]:dir:_files -/' \
      '--logfile=[log file]:file:_files' \
      '--without-libsensors[disable lm_sensors]' && ret=0 ;;
esac

return ret
