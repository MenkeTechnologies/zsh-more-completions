#compdef gkrellm gkrellmd
# Documentation: https://manpages.debian.org/testing/gkrellm/gkrellm.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (gkrellmd)
    # Documentation: https://manpages.debian.org/testing/gkrellmd/gkrellmd.1.en.html
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-V --verbose)'{-V,--verbose}'[verbose mode]' \
      '(-u --update-hz)'{-u,--update-hz}'+[update Hz (1-10)]:hz:' \
      '(-m --max-clients)'{-m,--max-clients}'+[max clients]:n:' \
      '(-A --address)'{-A,--address}'+[bind address]:host:_hosts' \
      '(-P --port)'{-P,--port}'+[listen port]:port:' \
      '(-a --allow-host)'{-a,--allow-host}'+[allow host]:host:_hosts' \
      '(-c --clear-hosts)'{-c,--clear-hosts}'[clear allowed hosts list]' \
      '(-d --detach)'{-d,--detach}'[run as daemon]' \
      '(-p --plugin)'{-p,--plugin}'+[load plugin]:plugin:_files' \
      '(-pe --plugin-enable)'{-pe,--plugin-enable}'+[enable installed plugin]:plugin:' \
      '--plist[list available plugins]' \
      '--plog[show plugin installation log]' \
      '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
      '--syslog[log to syslog]' \
      '(-U --user)'{-U,--user}'+[run as user]:user:_users' \
      '(-G --group)'{-G,--group}'+[run as group]:group:_groups' \
      '--pidfile=[PID file]:file:_files' \
      '--inet-interval=[Internet monitor read interval]:sec:' \
      '--io-timeout=[client disconnect timeout sec]:sec:' \
      '--reconnect-timeout=[auto-reconnect interval sec]:sec:' \
      '--mailbox=+[monitor mailbox]:file:_files' \
      '--net-timer=[network interface monitor]:iface:_net_interfaces' \
      '--mbmon-port=[mbmon daemon port]:port:' && ret=0 ;;
  (*)
    _arguments \
      '--help[show help]' \
      '(-t --theme)'{-t,--theme}'+[theme directory]:dir:_files -/' \
      '(-g --geometry)'{-g,--geometry}'+[window position +x+y]:geom:' \
      '-wm[force window manager decorations]' \
      '(-w --withdrawn)'{-w,--withdrawn}'[start in withdrawn mode]' \
      '(-c --config)'{-c,--config}'+[alternate config suffix]:suffix:' \
      '-nc[disable configuration menu]' \
      '(-f --force-host-config)'{-f,--force-host-config}'[append hostname to config files]' \
      '-demo[demo mode (theme development)]' \
      '(-p --plugin)'{-p,--plugin}'+[load plugin .so]:plugin:_files' \
      '(-s --server)'{-s,--server}'+[server host (client mode)]:host:_hosts' \
      '(-P --port)'{-P,--port}'+[server port]:port:' \
      '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' && ret=0 ;;
esac

return ret
