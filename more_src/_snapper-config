#compdef snapper-config

# snapper config: list/edit a btrfs/LVM snapper config (front-end for snapper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c[snapper config name]:config:' \
  '--list[list all configs]' \
  '--get[print key]:key:' \
  '--set[set key=value]:key=value:' \
  '*:argument:_files' && ret=0
return ret
