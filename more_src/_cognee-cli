#compdef cognee-cli
# Documentation: https://github.com/topoteretes/cognee
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for cognee-cli - AI memory / knowledge graph CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-ui[open the local web interface]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'cognee-cli command' \
      'remember[store data permanently in the knowledge graph]' \
      'recall[query the knowledge graph]' \
      'forget[delete data from the knowledge graph]' && ret=0
    ;;
  args)
    case $line[1] in
      forget)
        _arguments '--all[remove everything from the graph]' && ret=0
        ;;
    esac
    ;;
esac

return ret
