#compdef phylum
# Documentation: https://man.archlinux.org/search?q=phylum
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:link repository to Phylum project'
      'analyze:analyze package lockfile or SBOM'
      'package:inspect package metadata'
      'auth:authentication helpers'
      'extension:manage phylum extensions'
      'update:self-update CLI'
    )
    _describe -t commands 'phylum command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-c --config)'{-c,--config}'=[config file]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
