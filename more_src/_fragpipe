#compdef fragpipe fragpipe.bat
# Documentation: https://fragpipe.nesvilab.org/docs/tutorial_headless.html
# FragPipe: headless command-line mode for the proteomics analysis pipeline

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the help message]' \
  '--headless[run in headless mode]' \
  '--workflow[path to workflow file]:file:_files' \
  '--manifest[path to manifest file]:file:_files' \
  '--workdir[result directory]:dir:_files -/' \
  '--dry-run[dry run, do not really run FragPipe]' \
  '--ram[max allowed memory in GB (0=auto)]:gb:' \
  '--threads[number of threads]:n:' \
  '--config-tools-folder[folder containing MSFragger, IonQuant, diaTracer]:dir:_files -/' \
  '--config-diann[path to DIA-NN]:path:_files' \
  '--config-python[path to Python]:path:_files' && ret=0

return ret
