#compdef kjumpingcube
# Documentation: https://apps.kde.org/kjumpingcube/
# Reference accessed: 2026-05-19
# Verified: upstream KDE app page at the URL above.
# STUB: kjumpingcube is a GUI-only KDE tactical strategy game with no
# game-specific CLI options; only the standard KDE/Qt QCommandLineParser
# flags apply. Corrected prior bogus "Mad Bomber" description.

# kjumpingcube: KDE tactical strategy game (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show help including Qt-specific options]' \
  '(- *)--version[show version]' \
  '(- *)--author[show author information]' \
  '(- *)--license[show license information]' && ret=0
return ret
