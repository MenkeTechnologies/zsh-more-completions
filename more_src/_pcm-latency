#compdef pcm-latency
# Documentation: https://raw.githubusercontent.com/intel/pcm/master/src/pcm-latency.cpp
# Intel PCM memory latency monitor (DDR / PMM)

local ret=1

_arguments -s -S \
  '(-h --help /h)'{-h,--help,/h}'[show help]' \
  '--version[print version]' \
  '(--PMM -pmm)'{--PMM,-pmm}'[measure PMM persistent memory latency]' \
  '(-i /i)'{-i=,/i=}'[number of iterations]:count' \
  '(-silent /silent)'{-silent,/silent}'[suppress informational output]' \
  '(-v --verbose /v)'{-v,--verbose,/v}'[verbose output]' \
  '*::delay:_normal' && ret=0

return ret
