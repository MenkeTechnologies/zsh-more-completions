#compdef openl2tpd
# Documentation: https://github.com/breed/openl2tp/blob/master/doc/openl2tpd.8
# Reference accessed: 2026-05-16
# Verified: upstream doc/openl2tpd.8 manpage. Single-dash only.

# openl2tpd: L2TPv2 daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[debug trace mask]:mask:(SYSTEM API PROTOCOL FSM DATA FUNC XPRT AVP AVPHIDE AVPDATA)' \
  '-D[enable debug on all created tunnels/sessions]' \
  '-f[run in foreground]' \
  '-L[log facility]:facility:(local0 local1 local2 local3 local4 local5 local6 local7)' \
  '*-p[load L2TP PPP plugin]:file:_files' \
  '-R[enable remote management (Sun RPC)]' \
  '-u[UDP port (default 1701)]:port:' \
  '-c[config file (default /etc/openl2tpd.conf)]:file:_files' \
  '-S[enable system status files under /var/run/openl2tpd]' \
  '-y[max concurrent pppd create/delete operations]:rate:' && ret=0
return ret
