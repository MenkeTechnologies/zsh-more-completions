#compdef swiftformat
# Documentation: https://github.com/nicklockwood/SwiftFormat
# Reference accessed: 2026-05-21
# Verified: upstream README and Rules.md at the URL above.

# Zsh completion for SwiftFormat. Flag set restricted to README-documented
# top-level CLI flags; the very long list of rule-specific tuning options
# (--indentcase, --commas, etc.) is open-ended and version-dependent — use
# `swiftformat --options` to enumerate them for the installed version.

_swiftformat() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--config=[path to configuration file]:config file:_files' \
    '--output=[output path]:output path:_files' \
    '--stdin-path=[virtual path for stdin input]:path:' \
    '--exclude=[paths to exclude]:paths:_files' \
    '--unexclude=[paths to unexclude]:paths:_files' \
    '--rules=[comma-separated list of rules to enable exclusively]:rules:' \
    '--disable=[comma-separated list of rules to disable]:rules:' \
    '--enable=[comma-separated list of opt-in rules to enable]:rules:' \
    '--lintonly=[rules to apply only in lint mode]:rules:' \
    '--rule-info=[show information about a rule]:rule:' \
    '--lint[lint mode - report issues without fixing]' \
    '--lenient[suppress errors when lint fails]' \
    '--strict[strict mode with enhanced error checking]' \
    '--dry-run[run in dry run mode]' \
    '--verbose[display verbose output]' \
    '--quiet[suppress non-error output]' \
    '--options[list available formatting options]' \
    '--infer-options[infer options from the input file(s)]' \
    '--swift-version=[target Swift compiler version]:version:' \
    '--language-mode=[Swift language mode]:mode:(5 6)' \
    '--min-version=[fail if older SwiftFormat is used]:version:' \
    '--cache=[cache control]:cache:(clear ignore)' \
    '--reporter=[lint report format]:format:(default github-actions-log json xml)' \
    '--report=[path to write lint report]:report file:_files' \
    '--markdown-files=[format Swift code in markdown]:mode:(strict lenient)' \
    '--help[display help]' \
    '--version[display version]' \
    '*:swift files:_files -g "*.swift"' \
    && ret=0

  return ret
}

_swiftformat "$@"
