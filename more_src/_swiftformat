#compdef swiftformat

# Zsh completion for SwiftFormat

_swiftformat() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--config=[path to configuration file]:config file:_files' \
    '--inferoptions[infer options from the input file(s)]' \
    '--output=[output path]:output path:_files' \
    '--exclude=[paths to exclude]:paths:_files' \
    '--unexclude=[paths to unexclude]:paths:_files' \
    '--symlinks=[how symlinks are handled]:mode:(follow ignore)' \
    '--fragment[treat input as a fragment]' \
    '--conflictmarkers=[how conflict markers are handled]:mode:(reject ignore)' \
    '--swiftversion=[target Swift version]:version:' \
    '--rules=[comma-separated list of rules]:rules:' \
    '--disable=[comma-separated list of rules to disable]:rules:' \
    '--enable=[comma-separated list of rules to enable]:rules:' \
    '--lint[lint mode - report issues without fixing]' \
    '--lenient[suppress errors when lint fails]' \
    '--verbose[display verbose output]' \
    '--quiet[suppress non-error output]' \
    '--dryrun[run in dry run mode]' \
    '--cache=[path to cache file or clear]:cache:(clear ignore)' \
    '--stdinpath=[virtual path for stdin input]:path:' \
    '--report=[path to write lint report]:report file:_files' \
    '--reporter=[lint report format]:format:(summary json csv xml junit github)' \
    '--header=[header text]:header:' \
    '--ifdef=[how to handle #if directives]:mode:(indent no-indent outdent)' \
    '--indent=[indentation]:indentation:' \
    '--indentcase=[indent case statements]:enabled:(true false)' \
    '--allman=[use Allman brace style]:enabled:(true false)' \
    '--linebreaks=[linebreak style]:style:(cr crlf lf)' \
    '--maxwidth=[max line width]:width:' \
    '--wraparguments=[wrap arguments]:mode:(before-first after-first preserve disabled)' \
    '--wrapparameters=[wrap parameters]:mode:(before-first after-first preserve disabled)' \
    '--wrapcollections=[wrap collections]:mode:(before-first after-first preserve disabled)' \
    '--closingparen=[closing paren position]:mode:(balanced same-line)' \
    '--commas=[trailing commas]:mode:(always inline)' \
    '--decimalgrouping=[decimal grouping]:grouping:(ignore none)' \
    '--elseposition=[else/catch position]:position:(same-line next-line)' \
    '--emptybraces=[empty braces]:mode:(no-space linebreak)' \
    '--enumnamespaces=[enum namespaces]:mode:(always structs-only)' \
    '--extensionacl=[extension access control]:mode:(on-extension on-declarations)' \
    '--funcattributes=[function attributes]:mode:(prev-line same-line)' \
    '--guardelse=[guard else]:mode:(same-line next-line auto)' \
    '--importgrouping=[import grouping]:mode:(alphabetized testable-bottom testable-top)' \
    '--lifecycle=[lifecycle attributes]:mode:' \
    '--lineaftermarks=[blank line after marks]:enabled:(true false)' \
    '--markextensions=[mark extensions]:mode:(always never if-not-empty)' \
    '--marktypes=[mark types]:mode:(always never if-not-empty)' \
    '--modifierorder=[modifier order]:order:' \
    '--nospaceoperators=[no space operators]:operators:' \
    '--nowrapoperators=[no wrap operators]:operators:' \
    '--operatorfunc=[operator function spacing]:mode:(spaced no-space)' \
    '--patternlet=[pattern let]:mode:(hoist inline)' \
    '--redundanttype=[redundant type]:mode:(inferred explicit infer-locals-only)' \
    '--self=[self]:mode:(insert remove init-only)' \
    '--semicolons=[semicolons]:mode:(inline never)' \
    '--shortoptionals=[short optional syntax]:mode:(always except-properties)' \
    '--smarttabs=[smart tabs]:enabled:(enabled disabled)' \
    '--stripunusedargs=[strip unused args]:mode:(always closure-only unnamed-only)' \
    '--tabwidth=[tab width]:width:' \
    '--trailingclosures=[trailing closures]:closures:' \
    '--trimwhitespace=[trim whitespace]:mode:(always nonblank-lines)' \
    '--typeattributes=[type attributes]:mode:(prev-line same-line)' \
    '--voidtype=[void type]:type:(void tuples)' \
    '--wrapconditions=[wrap conditions]:mode:(before-first after-first preserve auto)' \
    '--wrapeffects=[wrap effects]:mode:(if-multiline never preserve)' \
    '--wrapternary=[wrap ternary]:mode:(default before-operators)' \
    '--xcodeindentation=[Xcode indentation]:enabled:(enabled disabled)' \
    '--help[display help]' \
    '--version[display version]' \
    '*:swift files:_files -g "*.swift"' \
    && ret=0

  return ret
}

_swiftformat "$@"
