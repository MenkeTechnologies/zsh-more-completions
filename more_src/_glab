#compdef glab

# Zsh completion for glab - GitLab CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:manage glab authentication state'
  'api:make an authenticated API request'
  'issue:work with GitLab issues'
  'mr:work with GitLab merge requests'
  'ci:work with GitLab CI/CD pipelines'
  'release:manage GitLab releases'
  'repo:work with GitLab repositories'
  'label:manage labels on a GitLab project'
  'variable:manage GitLab CI/CD variables'
  'ssh-key:manage SSH keys'
  'alias:create command aliases'
  'completion:generate shell completion scripts'
  'config:set and get glab settings'
  'version:show glab version'
)

_arguments -s -S \
  '1:command:->command' \
  '--help[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'glab command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (issue)
        local -a issue_cmds=(
          'create:create a new issue'
          'list:list project issues'
          'view:view an issue'
          'close:close an issue'
          'reopen:reopen an issue'
          'delete:delete an issue'
          'update:update an issue'
          'note:add a comment to an issue'
          'subscribe:subscribe to an issue'
          'unsubscribe:unsubscribe from an issue'
          'board:work with issue boards'
        )
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'[select a repository]:repo' \
          '1:subcommand:->issue_cmd' \
          '*:: :->issue_args' && ret=0
        case $state in
          (issue_cmd) _describe -t commands 'issue command' issue_cmds && ret=0 ;;
        esac
        ;;
      (mr)
        local -a mr_cmds=(
          'create:create a new merge request'
          'list:list merge requests'
          'view:view a merge request'
          'close:close a merge request'
          'reopen:reopen a merge request'
          'delete:delete a merge request'
          'update:update a merge request'
          'merge:merge a merge request'
          'approve:approve a merge request'
          'revoke:revoke approval of a merge request'
          'note:add a comment to a merge request'
          'checkout:checkout a merge request branch'
          'diff:view merge request diff'
          'todo:add a merge request to a todo list'
        )
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'[select a repository]:repo' \
          '1:subcommand:->mr_cmd' \
          '*:: :->mr_args' && ret=0
        case $state in
          (mr_cmd) _describe -t commands 'merge request command' mr_cmds && ret=0 ;;
        esac
        ;;
      (ci)
        local -a ci_cmds=(
          'view:view CI/CD pipeline'
          'list:list CI/CD pipelines'
          'run:create a new pipeline run'
          'trace:trace a CI/CD job log'
          'delete:delete a CI/CD pipeline'
          'lint:validate .gitlab-ci.yml file'
          'get:get CI/CD variables'
          'retry:retry a CI/CD job'
          'status:view pipeline status'
          'artifact:download pipeline artifacts'
        )
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'[select a repository]:repo' \
          '1:subcommand:->ci_cmd' \
          '*:: :->ci_args' && ret=0
        case $state in
          (ci_cmd) _describe -t commands 'CI command' ci_cmds && ret=0 ;;
        esac
        ;;
      (release)
        local -a release_cmds=(
          'create:create a new release'
          'list:list releases'
          'view:view a release'
          'delete:delete a release'
          'download:download release assets'
          'upload:upload release assets'
        )
        _arguments -s -S \
          '(-R --repo)'{-R,--repo}'[select a repository]:repo' \
          '1:subcommand:->release_cmd' \
          '*:: :->release_args' && ret=0
        case $state in
          (release_cmd) _describe -t commands 'release command' release_cmds && ret=0 ;;
        esac
        ;;
      (repo)
        local -a repo_cmds=(
          'clone:clone a repository'
          'fork:fork a repository'
          'view:view a repository'
          'archive:download repository archive'
          'create:create a new repository'
          'delete:delete a repository'
          'search:search for repositories'
          'transfer:transfer a repository'
          'mirror:mirror a repository'
        )
        _arguments -s -S \
          '1:subcommand:->repo_cmd' \
          '*:: :->repo_args' && ret=0
        case $state in
          (repo_cmd) _describe -t commands 'repo command' repo_cmds && ret=0 ;;
        esac
        ;;
      (auth)
        local -a auth_cmds=(
          'login:authenticate with a GitLab instance'
          'logout:log out of a GitLab instance'
          'status:view authentication status'
        )
        _arguments -s -S \
          '1:subcommand:->auth_cmd' \
          '*:: :->auth_args' && ret=0
        case $state in
          (auth_cmd) _describe -t commands 'auth command' auth_cmds && ret=0 ;;
        esac
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (config)
        local -a config_cmds=(
          'get:get a config value'
          'set:set a config value'
        )
        _arguments -s -S \
          '1:subcommand:->config_cmd' \
          '*:: :->config_args' && ret=0
        case $state in
          (config_cmd) _describe -t commands 'config command' config_cmds && ret=0 ;;
        esac
        ;;
      (api)
        _arguments -s -S \
          '(-X --method)'{-X,--method}'[HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '*'{-F,--field}'[add a parameter]:key=value' \
          '*'{-H,--header}'[add a HTTP header]:header' \
          '(-f --raw-field)'{-f,--raw-field}'[add a raw parameter]:key=value' \
          '--paginate[fetch all pages of results]' \
          '(-i --include)'{-i,--include}'[include HTTP response headers]' \
          '--silent[do not print the response body]' \
          '1:endpoint' && ret=0
        ;;
      (*)
        _arguments --help && ret=0
        ;;
    esac
    ;;
esac

return ret
