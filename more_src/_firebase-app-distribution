#compdef firebase-app-distribution
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/firebase-app-distribution
# Codemagic CLI tools - get release data from Firebase App Distribution

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(get-latest-build-version releases)' \
  '*::args:->args' && ret=0

return ret
