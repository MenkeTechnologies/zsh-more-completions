#compdef arize arize-phoenix phoenix
# _arize — Arize AI Phoenix open-source observability for LLM applications evaluation tracing and embeddings (Arize-ai team, Python); typer
# upstream: https://github.com/Arize-ai/phoenix

_arize() {
    local -a sub=(
        'serve:launch Phoenix server'
        'session:session subcommands'
        'space:space subcommands'
        'evaluate:run evaluations'
        'eval:run evaluations alias'
        'config:configuration subcommands'
        'auth:authentication subcommands'
        'export:export data'
        'import:import data'
        'db:database subcommands'
        'docs:open docs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--endpoint=+[Phoenix endpoint]:url:_urls' \
        '--api-key=+[API key]:str:' \
        '--space-id=+[space ID]:str:' \
        '--api-base=+[API base]:url:_urls' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--no-color[disable color]' \
        '--output=+[format]:f:(text json yaml table)' \
        '-o+[format]:f:(text json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arize subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--grpc-port=+[grpc port]:port:_ports' \
                    '--workers=+[N]:n:' \
                    '--db=+[db url]:str:' \
                    '--storage-dir=+[storage dir]:dir:_files -/' \
                    '--root-url=+[root URL]:url:_urls' \
                    '--enable-auth[enable auth]' \
                    '--secret=+[secret]:str:' \
                    '--access-token-expiry-minutes=+[N]:n:' \
                    '--refresh-token-expiry-minutes=+[N]:n:' ;;
                evaluate|eval) _arguments \
                    '--type=+[eval type]:t:(qa hallucination relevance toxicity ragas summarization classification regression)' \
                    '--model=+[model]:str:' \
                    '--dataset=+[dataset]:str:' \
                    '--num-workers=+[N]:n:' \
                    '*:input file:_files' ;;
                export|import) _arguments \
                    '--format=+[format]:f:(parquet csv json jsonl arrow)' \
                    '*:file:_files' ;;
                session) _arguments '1:session cmd:(list show clear export)' ;;
                space) _arguments '1:space cmd:(list create delete update show)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                auth) _arguments '1:auth cmd:(login logout status)' ;;
                db) _arguments '1:db cmd:(migrate reset backup restore)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_arize "$@"
