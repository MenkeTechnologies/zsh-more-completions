#compdef zns
# Documentation: https://github.com/znscli/zns (cmd/root.go)
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage]' \
  '(- *)--version[show version]' \
  '(-s --server)'{-s+,--server=}'[DNS server to query]:server:' \
  '(-q --query-type)'{-q+,--query-type=}'[DNS query type]:qtype:(A AAAA NS TXT MX CNAME SOA SRV CAA PTR DS DNSKEY)' \
  '--debug[enable debug output]' \
  '--json[JSON output]' \
  '1:domain name:_hosts'
