#compdef zns

# https://github.com/znscli/zns — cobra root (cmd/root.go)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '--version[show version]' \
  '(-s --server)'{-s,--server}'[DNS resolver address (port :53 added if none)] :server:' \
  '(-q --query-type)'{-q,--query-type}'[single RR type to query (e.g. A, NS, TXT)] :qtype:' \
  '--debug[enable debug logging]' \
  '--json[JSON output]' \
  '1:domain name:_hosts'
