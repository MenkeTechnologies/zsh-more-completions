#compdef tracee
# Documentation: https://github.com/aquasecurity/tracee
# Reference accessed: 2026-05-21
# Verified: upstream cmd/tracee/cmd/root.go flag definitions.

# Zsh completion for tracee (Linux runtime security and forensics)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[global config file path]:file:_files' \
  '*'{-s+,--scope=}'[filter expressions for workload selection]:scope' \
  '*'{-e+,--events=}'[event names and filters to trace]:events' \
  '*'{-p+,--policy=}'[policy file or directory paths]:policy:_files' \
  '*'{-o+,--output=}'[output format control]:output' \
  '*'{-a+,--artifacts=}'[artifact capture types]:artifact:(file-write executable mem net module bpf)' \
  '*'{-E+,--enrichment=}'[enrichment features]:enrichment' \
  '*--signatures-dir=[Go plugin signature directories]:dir:_files -/' \
  '*'{-d+,--detectors=}'[YAML detector search directories]:dir:_files -/' \
  '*'{-b+,--buffers=}'[buffer size configurations]:buffers' \
  '*--stores=[store configurations]:stores' \
  '*--server=[server options and endpoints]:server' \
  '*'{-C+,--capabilities=}'[capability definitions]:capabilities:(bypass add drop)' \
  '*'{-L+,--logging=}'[logger options]:log:(debug info warn error fatal)' \
  '--no-signatures[disable signature processing]'
