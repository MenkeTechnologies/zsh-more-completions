#compdef tracee

# Zsh completion for tracee (Linux runtime security)

_arguments -s -S \
  '--scope[select scope to trace]:scope:' \
  '--events[select events to trace]:events:' \
  '--output[output options]:output:' \
  '--filter[filter events]:filter:' \
  '--capture[capture artifacts]:artifact:(exec mem net module bpf)' \
  '--cache[cache options]:cache:' \
  '--capabilities[select capabilities]:capabilities:' \
  '--install-path[path to install tracee]:path:_files -/' \
  '--rego[Rego policies directory]:dir:_files -/' \
  '--signatures-dir[signatures directory]:dir:_files -/' \
  '--log[log options]:log:' \
  '--pprof[enable pprof server]' \
  '--metrics[enable prometheus metrics server]' \
  '--healthz[enable health check server]' \
  '--listen-addr[listen address for servers]:addr:' \
  '--perf-buffer-size[perf buffer size]:size:' \
  '--blob-perf-buffer-size[blob perf buffer size]:size:' \
  '--containers[only trace containers]' \
  '--crs[container runtime socket]:socket:_files' \
  '--dnscache[enable DNS cache]' \
  '--grpc-listen-addr[gRPC listen address]:addr:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && return 0
