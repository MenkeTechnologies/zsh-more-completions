#compdef newgidmap
# Documentation: https://man7.org/linux/man-pages/man1/newgidmap.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:pid:_pids' \
  '*:gid mapping (innerGID outerGID count):' && ret=0

return ret
