#compdef nw_order
# Documentation: https://github.com/tjunier/newick_utils
# Newick Utilities: order tree nodes.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-c+[criterion: a (alpha) / n (num descendants) / d (de-ladderize)]:crit:(a n d)' \
  '-r[reverse sort order]' \
  '*:newick file:_files' && ret=0

return ret
