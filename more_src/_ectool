#compdef ectool
# Documentation: https://chromium.googlesource.com/chromiumos/platform/ec/+/master/util/ectool.c
# ChromeOS embedded controller (EC) control tool

local ret=1

_arguments -s -S \
  '--dev[device index]:dev:' \
  '--interface[EC interface]:interface:(dev i2c lpc)' \
  '--name[EC device name]:name:' \
  '--ascii[use ASCII transport]' \
  '--i2c_bus[I2C bus number]:bus:' \
  '*:command:(version hello temps fanduty pwmsetfanrpm led battery chargestate reboot_ec flashinfo flashread flashwrite flasherase inventory sysinfo console gpioget gpioset pwmgetfanrpm thermalget thermalset chipinfo)' && ret=0

return ret
