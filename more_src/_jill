#compdef jill
# Documentation: https://github.com/johnnychen94/jill.py
# jill.py - a cross-platform installer for the Julia programming language

local ret=1
local curcontext="$curcontext" state line

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds
    cmds=(
      'install:download and install a Julia release with symlinks'
      'download:download Julia binaries without installing'
      'list:list symlinks and their target Julia versions'
      'switch:change which Julia version a symlink points to'
      'upstream:show available download mirror servers'
    )
    _describe -t commands 'jill command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '--unstable[get latest including unstable releases]' \
          '--confirm[no confirmation before installation]' \
          '--upstream=[download from a specific upstream server]:server' \
          '--keep_downloads[retain downloaded files]' \
          '--reinstall[force reinstallation]' \
          '--preferred-arch=[specify architecture preference]:arch:(x86_64 i686 arm64 aarch64)' \
          '--bypass-ssl[skip certificate verification]' \
          '--skip-symlinks[omit symbolic link generation]' \
          '--install_dir=[set installation location (deprecated)]:dir:_files -/' \
          '--symlink_dir=[set symlink location (deprecated)]:dir:_files -/' \
          '*:version' && ret=0
        ;;
      download)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '--sys=[specify operating system]:system:(linux macos freebsd winnt)' \
          '--arch=[specify architecture]:arch:(x86_64 i686 arm64 aarch64)' \
          '--upstream=[download from a specific upstream server]:server' \
          '*:version' && ret=0
        ;;
      switch)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '--target=[which symlink to modify]:target' \
          '*:version or path' && ret=0
        ;;
      list)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:version' && ret=0
        ;;
      upstream)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
