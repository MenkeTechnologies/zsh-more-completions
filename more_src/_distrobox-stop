#compdef distrobox-stop

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-Y --yes)'{-Y,--yes}'[do not ask confirmation]' \
  '--all[stop all containers]' \
  '(-v --verbose)'{-v,--verbose}'[show more verbosity]' \
  '*:container name:' && ret=0

return ret
