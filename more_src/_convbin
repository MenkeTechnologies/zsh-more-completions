#compdef convbin
# Documentation: https://manpages.debian.org/bullseye/rtklib/convbin.1.en.html
# RTKLIB converter from receiver binary log to RINEX/SBAS

local ret=1

_arguments -s \
  '-ts[start time (y/m/d h:m:s)]:start' \
  '-te[end time (y/m/d h:m:s)]:end' \
  '-tr[approximated time for rtcm messages]:time' \
  '-ti[observation data interval (s)]:interval' \
  '-span[time span (h)]:span' \
  '-r[input log format]:format:(rtcm2 rtcm3 nov oem3 ubx ss2 hemis stq javad nvs binex rt17 sbf rinex)' \
  '-ro[receiver options]:opt' \
  '-f[number of frequencies]:freq' \
  '-hc[rinex header: comment line]:comment' \
  '-hm[rinex header: marker name]:marker' \
  '-hn[rinex header: marker number]:markno' \
  '-ht[rinex header: marker type]:marktype' \
  '-ho[rinex header: observer name and agency]:observ' \
  '-hr[rinex header: receiver number, type, version]:rec' \
  '-ha[rinex header: antenna number and type]:ant' \
  '-hp[rinex header: approx position x/y/z]:pos' \
  '-hd[rinex header: antenna delta h/e/n]:delta' \
  '-v[rinex version]:ver' \
  '-od[include doppler frequency in rinex obs]' \
  '-os[include snr in rinex obs]' \
  '-oi[include iono correction in rinex nav header]' \
  '-ot[include time correction in rinex nav header]' \
  '-ol[include leap seconds in rinex nav header]' \
  '-scan[scan input file]' \
  '-mask[signal mask]:sig' \
  '-nomask[exclude signals]:sig' \
  '-x[exclude satellite]:sat' \
  '-y[exclude GNSS system]:sys:(G R E J S C)' \
  '-d[output directory]:dir:_files -/' \
  '-c[station ID for RINEX naming]:staid' \
  '-o[output RINEX OBS file]:ofile:_files' \
  '-n[output RINEX NAV file]:nfile:_files' \
  '-g[output RINEX GNAV file]:gfile:_files' \
  '-h[output RINEX HNAV file]:hfile:_files' \
  '-q[output RINEX QNAV file]:qfile:_files' \
  '-l[output RINEX LNAV file]:lfile:_files' \
  '-s[output SBAS message file]:sfile:_files' \
  '-trace[output trace level]:level' \
  '*:input binary log file:_files' && ret=0

return ret
