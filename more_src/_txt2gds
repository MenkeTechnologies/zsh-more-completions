#compdef txt2gds txt2oas
# txt2gds - KLayout buddy tool: convert a text-dump layout back into GDS2/OASIS
# Source: KLayout/klayout src/buddies (bdConverterMain.cc + bdReaderOptions.cc + bdWriterOptions.cc); https://www.klayout.de/
# Reference accessed: 2026-06-21

local ret=1

_arguments -s \
  '-is[skip unknown layers]' \
  '-im+[input layer mapping]:map:' \
  '--layer-map=[input layer mapping]:map:' \
  '--layer-map-file=[input layer mapping file]:file:_files' \
  '-id+[input database unit (dbu)]:dbu:' \
  '--dbu-in=[input database unit (dbu)]:dbu:' \
  '--keep-layer-names[keep layer names]' \
  '-os+[scale layout upon writing]:factor:' \
  '--scale-factor=[scale layout upon writing]:factor:' \
  '-of+[output format]:format:(GDS2 GDS2Text OASIS)' \
  '--format=[output format]:format:(GDS2 GDS2Text OASIS)' \
  '-od+[output database unit (dbu)]:dbu:' \
  '--dbu-out=[output database unit (dbu)]:dbu:' \
  '-ol+[library name]:libname:' \
  '--libname=[library name]:libname:' \
  '--drop-empty-cells[drop empty cells]' \
  '--keep-instances[keep instances of dropped cells]' \
  '--write-cells=[cells to write]:sel:' \
  '-ov+[max points per polygon (GDS2)]:count:' \
  '--max-vertex-count=[max points per polygon (GDS2)]:count:' \
  '--no-timestamps[do not write timestamps (GDS2)]' \
  '--no-context-info[do not write context info]' \
  '-ok+[OASIS compression level]:level:' \
  '--compression-level=[OASIS compression level]:level:' \
  '-ot[OASIS strict mode]' \
  '--strict-mode[OASIS strict mode]' \
  '*:input then output file:_files' && ret=0

return ret
