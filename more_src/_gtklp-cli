#compdef gtklp-cli

# gtklp-cli: command-line dialog for gtklp
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '-P[printer]:printer:' \
  '-d[printer]:printer:' \
  '-#[copies]:n:' \
  '-n[copies]:n:' \
  '-J[job name]:name:' \
  '-T[title]:title:' \
  '-H[server host]:host:_hosts' \
  '-U[remote username]:user:_users' \
  '-o[printer option key=value]:opt:' \
  '*:files:_files' && ret=0
return ret
