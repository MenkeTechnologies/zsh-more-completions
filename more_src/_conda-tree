#compdef conda-tree
# Documentation: https://github.com/conda-incubator/conda-tree
# conda-tree: conda dependency tree helper

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --prefix)'{-p,--prefix}'=[full path to environment prefix]:prefix:_files -/' \
  '(-n --name)'{-n,--name}'=[name of environment]:name:' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '1:command:(leaves cycles whoneeds depends deptree unowned-files who-owns)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      leaves)
        _arguments -s -S \
          '--export[export leaves dependencies]' \
          '--with-cycles[include orphan cycles]' \
          '--json[print packages in json format]' && ret=0
        ;;
      whoneeds|depends)
        _arguments -s -S \
          '(-r --recursive)'{-r,--recursive}'[show dependencies recursively]' \
          '(-t --tree)'{-t,--tree}'[show dependencies in tree form]' \
          '--dot[print a graphviz dot graph notation]' \
          '--json[print packages in json format]' \
          '--exclude=[exclude packages from the tree]:packages:' \
          '--small[exclude conda and python dependencies]' \
          '--full[show the complete dependency tree with redundancies]' \
          '1:package:' && ret=0
        ;;
      deptree)
        _arguments -s -S \
          '(-t --tree)'{-t,--tree}'[show dependencies in tree form]' \
          '--dot[print a graphviz dot graph notation]' \
          '--json[print packages in json format]' \
          '--exclude=[exclude packages from the tree]:packages:' \
          '--small[exclude conda and python dependencies]' \
          '--full[show the complete dependency tree with redundancies]' && ret=0
        ;;
      who-owns)
        _arguments '1:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
