#compdef nohup-cli
# _nohup-cli — GNU coreutils nohup run command immune to hangups CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_nohup-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '*:command:_command_names'
}

_nohup-cli "$@"
