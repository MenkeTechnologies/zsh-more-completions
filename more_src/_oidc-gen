#compdef oidc-gen
# Documentation: https://manpages.debian.org/experimental/oidc-agent-cli/oidc-gen.1.en.html
# oidc-gen - generate account configuration files for oidc-agent

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[display help information]' \
  '--usage[show brief usage message]' \
  '(-V --version)'{-V,--version}'[display program version]' \
  '(-d --delete)'{-d,--delete}'[delete configuration for the given account]' \
  '(-l --accounts)'{-l,--accounts}'[print a list of all configured account configurations]' \
  '(-p --print)'{-p,--print=}'[print the decrypted content of FILE]:file:_files' \
  '--reauthenticate[update existing account with a new refresh token]' \
  '--rename=[rename an existing account configuration file]:new shortname' \
  '(-u --update)'{-u,--update=}'[decrypt and reencrypt the content for FILE]:file:_files' \
  '--client-id=[use CLIENT_ID as client id]:client id' \
  '--client-secret=[use CLIENT_SECRET as client secret]:client secret' \
  '(-f --file)'{-f,--file=}'[read the client configuration from FILE]:file:_files' \
  '--iss=[set ISSUER_URL as the issuer url to be used]:issuer url' \
  '(-m --manual)'{-m,--manual}'[do not use Dynamic Client Registration]' \
  '--no-save[do not save any configuration files]' \
  '--port=[use specified port in local redirect URI]:port' \
  '--pub[use a public client defined in publicclient.conf]' \
  '--redirect-uri=[use URI as redirect URI]:uri' \
  '--scope=[set SCOPE as the scope to be used]:scope' \
  '--scope-all[use all available scopes for this provider]' \
  '--at=[use access token for registration endpoint authorization]:access token' \
  '--aud=[limit issued tokens to the specified audience]:audience' \
  '--cnid=[additional identifier used in the client name]:identifier' \
  '--cp=[path to a CA bundle file]:file:_files' \
  '--dae=[use specified device authorization endpoint]:endpoint uri' \
  '--only-at[print access token instead of creating configuration]' \
  '--op-password=[use password in password flow]:password' \
  '--op-username=[use username in password flow]:username' \
  '--rt=[use REFRESH_TOKEN as the refresh token]:refresh token' \
  '--rt-env=[like --rt but read the refresh token from environment]:env var' \
  '(-w --flow)'{-w,--flow=}'[specify the OIDC flow to be used]:flow:(code device password refresh)' \
  '--codeExchange=[use URI to complete account configuration generation]:uri' \
  '--confirm-default[confirm all prompts with the default value]' \
  '--confirm-no[confirm all prompts with no]' \
  '--confirm-yes[confirm all prompts with yes]' \
  '--no-scheme[do not use custom URI scheme redirect]' \
  '--no-url-call[do not automatically open the authorization url]' \
  '--no-webserver[do not start webserver for authorization code flow]' \
  '--prompt=[change how oidc-gen prompts for information]:mode:(cli gui none)' \
  '--pw-cmd=[read encryption password from command output]:command' \
  '--pw-env=[read encryption password from environment variable]:env var' \
  '--pw-file=[use the first line of FILE as the encryption password]:file:_files' \
  '--pw-gpg=[use the passed GPG key for encryption]:key id' \
  '--pw-prompt=[change password prompt mode]:mode:(cli gui)' \
  '--seccomp[enable seccomp system call filtering]' \
  '(-g --debug)'{-g,--debug}'[set log level to DEBUG]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '*:account shortname:' && ret=0

return ret
