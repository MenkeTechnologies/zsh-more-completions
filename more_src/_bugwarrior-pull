#compdef bugwarrior-pull
# _bugwarrior-pull — sync remote issue trackers into TaskWarrior (ralphbean/bugwarrior)
# upstream: https://github.com/GothenburgBitFactory/bugwarrior

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug logging]' \
  '--dry-run[do not modify TaskWarrior]' \
  '(-i --interactive)'{-i,--interactive}'[interactively choose tasks to import]' \
  '--flavor=[flavor section to use]:flavor:'
