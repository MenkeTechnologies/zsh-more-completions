#compdef nearleyc nearley-test nearley-railroad nearley-unparse

local curcontext="$curcontext" state line ret=1

case $service in
  (nearleyc)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-o --out)'{-o+,--out=}'[output file]:file:_files' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-e --export-name)'{-e+,--export-name=}'[exported name]:name:' \
      '(--nojs)--nojs[no JS code]' \
      '*: :_files -g "*.ne *.nearley"' && ret=0 ;;
  (nearley-test)
    _arguments -C \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-i --input)'{-i+,--input=}'[input string]:input:' \
      '(-s --start)'{-s+,--start=}'[start rule]:rule:' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-f --first)'{-f+,--first=}'[only first n parses]:n:' \
      '*: :_files -g "*.js"' && ret=0 ;;
  (nearley-railroad)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-o --out)'{-o+,--out=}'[output html]:file:_files' \
      '*: :_files -g "*.ne *.nearley"' && ret=0 ;;
  (nearley-unparse)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-o --out)'{-o+,--out=}'[output]:file:_files' \
      '(-s --start)'{-s+,--start=}'[start rule]:rule:' \
      '(-d --depth)'{-d+,--depth=}'[max depth]:n:' \
      '(-n --count)'{-n+,--count=}'[number of strings]:n:' \
      '*: :_files -g "*.js"' && ret=0 ;;
esac

return ret
