#compdef tailscaled

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-cleanup[clean up system state and exit]' \
  '-debug+[listen address for debug server]:address:' \
  '-bird-socket+[path to BIRD socket]:path:_files' \
  '-outbound-http-proxy-listen+[address for outbound HTTP proxy]:address:' \
  '-port+[UDP port for WireGuard]:port:' \
  '-socket+[path of control socket]:path:_files' \
  '-state+[path to state file]:path:_files' \
  '-statedir+[path to state directory]:directory:_files -/' \
  '-tun+[tunnel interface name]:interface:(userspace-networking tailscale0)' \
  '-verbose+[log verbosity level]:level:(0 1 2)' \
  '-version[show version]' \
  '-no-logs-no-support[disable log uploads]' && ret=0

return ret
