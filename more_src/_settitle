#compdef settitle
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss186.html
# KAPPA SETTITLE - set a new title for an NDF data structure

local ret=1

_arguments -C \
  'NDF=[NDF data structure whose title is modified]:NDF file:_files' \
  'TITLE=[new value for the TITLE component]:title:' \
  '*:NDF file:_files' && ret=0

return ret
