#compdef drtext
# Documentation: https://man.archlinux.org/search?q=drtext
# Reference accessed: 2026-05-16

# EMBOSS drtext: retrieve textual data resource entries in plain text
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-resource=[input data resource USA]:USA:' \
  '-html[include HTML formatting]' \
  '-outfile=[output file]:file:_files' \
  '*:resource USA:' && ret=0
return ret
