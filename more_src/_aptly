#compdef aptly

# Zsh completion for aptly - Debian repository management tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_aptly_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--config=[path to config file]:config file:_files -g "*.{json,yaml,conf}"'
  '--architectures=[list of architectures]:architectures:'
  '--dep-follow-all-variants[follow all variants when processing dependencies]'
  '--dep-follow-recommends[follow Recommends when processing dependencies]'
  '--dep-follow-source[follow source packages when processing dependencies]'
  '--dep-follow-suggests[follow Suggests when processing dependencies]'
  '--dep-verbose-resolve[verbose dependency resolution output]'
  '--gpg-provider=[PGP implementation]:provider:(gpg gpg1 gpg2 internal)'
)

_aptly_mirror_commands() {
  local -a commands
  commands=(
    'create:Create a new mirror'
    'list:List configured mirrors'
    'show:Show details of a mirror'
    'drop:Delete a mirror'
    'edit:Edit mirror settings'
    'update:Update mirror from remote repository'
    'rename:Rename a mirror'
    'search:Search mirror for packages'
  )
  _describe -t commands 'mirror commands' commands
}

_aptly_repo_commands() {
  local -a commands
  commands=(
    'create:Create a local repository'
    'show:Show details of a local repository'
    'list:List local repositories'
    'drop:Delete a local repository'
    'add:Add packages to local repository'
    'remove:Remove packages from local repository'
    'move:Move packages between local repositories'
    'copy:Copy packages between local repositories'
    'edit:Edit local repository settings'
    'import:Import packages from mirror to local repository'
    'include:Include .changes files into local repository'
    'search:Search repository for packages'
  )
  _describe -t commands 'repo commands' commands
}

_aptly_snapshot_commands() {
  local -a commands
  commands=(
    'create:Create a snapshot'
    'list:List snapshots'
    'show:Show details of a snapshot'
    'verify:Verify snapshot dependencies'
    'pull:Pull packages from another snapshot'
    'diff:Show difference between snapshots'
    'merge:Merge snapshots'
    'drop:Delete a snapshot'
    'filter:Filter snapshot by package query'
    'rename:Rename a snapshot'
    'search:Search snapshot for packages'
  )
  _describe -t commands 'snapshot commands' commands
}

_aptly_publish_commands() {
  local -a commands
  commands=(
    'snapshot:Publish a snapshot'
    'repo:Publish a local repository'
    'list:List published repositories'
    'show:Show details of published repository'
    'drop:Remove a published repository'
    'update:Update a published repository'
    'switch:Switch published snapshot'
  )
  _describe -t commands 'publish commands' commands
}

_aptly_package_commands() {
  local -a commands
  commands=(
    'search:Search for packages'
    'show:Show package details'
  )
  _describe -t commands 'package commands' commands
}

_aptly_db_commands() {
  local -a commands
  commands=(
    'cleanup:Remove unreferenced database entries and files'
    'recover:Recover database after crash'
  )
  _describe -t commands 'db commands' commands
}

_aptly_api_commands() {
  local -a commands
  commands=(
    'serve:Start REST API server'
  )
  _describe -t commands 'api commands' commands
}

_aptly_config_commands() {
  local -a commands
  commands=(
    'show:Show current configuration'
  )
  _describe -t commands 'config commands' commands
}

_aptly_task_commands() {
  local -a commands
  commands=(
    'run:Run a task'
  )
  _describe -t commands 'task commands' commands
}

_aptly_mirrors() {
  local -a mirrors
  mirrors=(${(f)"$(aptly mirror list -raw 2>/dev/null)"})
  [[ -n "$mirrors" ]] && compadd -a mirrors
}

_aptly_repos() {
  local -a repos
  repos=(${(f)"$(aptly repo list -raw 2>/dev/null)"})
  [[ -n "$repos" ]] && compadd -a repos
}

_aptly_snapshots() {
  local -a snapshots
  snapshots=(${(f)"$(aptly snapshot list -raw 2>/dev/null)"})
  [[ -n "$snapshots" ]] && compadd -a snapshots
}

_arguments -s -S -C \
  "${_aptly_global_flags[@]}" \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'mirror:Manage mirrors of remote repositories'
      'repo:Manage local package repositories'
      'snapshot:Manage package snapshots'
      'publish:Manage published repositories'
      'package:Search and show packages'
      'db:Manage internal database'
      'serve:Start HTTP file server'
      'api:Start REST API server'
      'graph:Render graph of relationships'
      'config:Manage configuration'
      'task:Run tasks'
      'version:Show version'
    )
    _describe -t commands 'aptly commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      mirror)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_mirror_commands' \
          '*::arg:->mirror_args' && ret=0
        case "$state" in
          mirror_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--filter=[package query filter]:filter:' \
                  '--filter-with-deps[include dependencies of filtered packages]' \
                  '--with-sources[download source packages]' \
                  '--with-udebs[download .udeb packages]' \
                  '--force-components[enforce component list]' \
                  '1:mirror name:' \
                  '2:archive url:' \
                  '3:distribution:' \
                  '*:components:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-packages[show package list]' \
                  '1:mirror name:_aptly_mirrors' && ret=0
                ;;
              update)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force[force update]' \
                  '--ignore-checksums[ignore checksum mismatches]' \
                  '--ignore-signatures[ignore signature verification]' \
                  '1:mirror name:_aptly_mirrors' && ret=0
                ;;
              drop)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force[force drop even if used by snapshots]' \
                  '1:mirror name:_aptly_mirrors' && ret=0
                ;;
              edit)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--filter=[package query filter]:filter:' \
                  '--filter-with-deps[include dependencies of filtered packages]' \
                  '--with-sources[download source packages]' \
                  '--with-udebs[download .udeb packages]' \
                  '1:mirror name:_aptly_mirrors' && ret=0
                ;;
              rename)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:old name:_aptly_mirrors' \
                  '2:new name:' && ret=0
                ;;
              search)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-deps[include dependencies]' \
                  '1:mirror name:_aptly_mirrors' \
                  '2:package query:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--raw[display list in machine-readable format]' \
                  '--json[display list in JSON format]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      repo)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_repo_commands' \
          '*::arg:->repo_args' && ret=0
        case "$state" in
          repo_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--comment=[repository comment]:comment:' \
                  '--component=[default component]:component:' \
                  '--distribution=[default distribution]:distribution:' \
                  '1:repo name:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-packages[show package list]' \
                  '1:repo name:_aptly_repos' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--raw[display list in machine-readable format]' \
                  '--json[display list in JSON format]' && ret=0
                ;;
              drop)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force[force drop even if published]' \
                  '1:repo name:_aptly_repos' && ret=0
                ;;
              add)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force-replace[replace conflicting packages]' \
                  '--remove-files[remove files after importing]' \
                  '1:repo name:_aptly_repos' \
                  '*:package files:_files -g "*.deb"' && ret=0
                ;;
              remove)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not remove, only show what would be removed]' \
                  '1:repo name:_aptly_repos' \
                  '2:package query:' && ret=0
                ;;
              move)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not move, only show what would be moved]' \
                  '--with-deps[include dependencies]' \
                  '1:source repo:_aptly_repos' \
                  '2:destination repo:_aptly_repos' \
                  '3:package query:' && ret=0
                ;;
              copy)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not copy, only show what would be copied]' \
                  '--with-deps[include dependencies]' \
                  '1:source repo:_aptly_repos' \
                  '2:destination repo:_aptly_repos' \
                  '3:package query:' && ret=0
                ;;
              edit)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--comment=[repository comment]:comment:' \
                  '--component=[default component]:component:' \
                  '--distribution=[default distribution]:distribution:' \
                  '1:repo name:_aptly_repos' && ret=0
                ;;
              import)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not import, only show what would be imported]' \
                  '--with-deps[include dependencies]' \
                  '1:mirror name:_aptly_mirrors' \
                  '2:repo name:_aptly_repos' \
                  '3:package query:' && ret=0
                ;;
              include)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--accept-unsigned[accept unsigned .changes files]' \
                  '--ignore-signatures[ignore signature verification]' \
                  '--no-remove-files[do not remove files after processing]' \
                  '--force-replace[replace conflicting packages]' \
                  '--repo=[target repository]:repo:_aptly_repos' \
                  '*:changes files:_files -g "*.changes"' && ret=0
                ;;
              search)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-deps[include dependencies]' \
                  '1:repo name:_aptly_repos' \
                  '2:package query:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      snapshot)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_snapshot_commands' \
          '*::arg:->snapshot_args' && ret=0
        case "$state" in
          snapshot_args)
            case "${line[1]}" in
              create)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:snapshot name:' \
                  'from:from keyword:(from)' \
                  '*::source:->create_source' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--raw[display list in machine-readable format]' \
                  '--json[display list in JSON format]' \
                  '--sort=[sort order]:sort:(name time)' && ret=0
                ;;
              show)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-packages[show package list]' \
                  '1:snapshot name:_aptly_snapshots' && ret=0
                ;;
              verify)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:snapshot name:_aptly_snapshots' \
                  '*:source snapshots:_aptly_snapshots' && ret=0
                ;;
              pull)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not create snapshot, only show what would be pulled]' \
                  '--no-deps[do not process dependencies]' \
                  '--all-matches[pull all matching packages]' \
                  '1:destination snapshot:_aptly_snapshots' \
                  '2:source snapshot:_aptly_snapshots' \
                  '3:new snapshot name:' \
                  '4:package query:' && ret=0
                ;;
              diff)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--only-matching[only show matching packages]' \
                  '1:snapshot A:_aptly_snapshots' \
                  '2:snapshot B:_aptly_snapshots' && ret=0
                ;;
              merge)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--latest[use latest version if duplicated]' \
                  '--no-remove[do not remove duplicate packages]' \
                  '1:new snapshot name:' \
                  '*:source snapshots:_aptly_snapshots' && ret=0
                ;;
              drop)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force[force drop even if used]' \
                  '1:snapshot name:_aptly_snapshots' && ret=0
                ;;
              filter)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-deps[include dependencies]' \
                  '1:source snapshot:_aptly_snapshots' \
                  '2:new snapshot name:' \
                  '3:package query:' && ret=0
                ;;
              rename)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:old name:_aptly_snapshots' \
                  '2:new name:' && ret=0
                ;;
              search)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-deps[include dependencies]' \
                  '1:snapshot name:_aptly_snapshots' \
                  '2:package query:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      publish)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_publish_commands' \
          '*::arg:->publish_args' && ret=0
        case "$state" in
          publish_args)
            case "${line[1]}" in
              snapshot)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--component=[component name]:component:' \
                  '--distribution=[distribution name]:distribution:' \
                  '--gpg-key=[GPG key ID]:key id:' \
                  '--skip-signing[skip GPG signing]' \
                  '--origin=[repository origin]:origin:' \
                  '--label=[repository label]:label:' \
                  '1:snapshot name:_aptly_snapshots' \
                  '2:prefix:' && ret=0
                ;;
              repo)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--component=[component name]:component:' \
                  '--distribution=[distribution name]:distribution:' \
                  '--gpg-key=[GPG key ID]:key id:' \
                  '--skip-signing[skip GPG signing]' \
                  '--origin=[repository origin]:origin:' \
                  '--label=[repository label]:label:' \
                  '1:repo name:_aptly_repos' \
                  '2:prefix:' && ret=0
                ;;
              list)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--raw[display list in machine-readable format]' \
                  '--json[display list in JSON format]' && ret=0
                ;;
              show)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:distribution:' \
                  '2:prefix:' && ret=0
                ;;
              drop)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--force-drop[force removal]' \
                  '--skip-cleanup[skip cleanup of unreferenced files]' \
                  '1:distribution:' \
                  '2:prefix:' && ret=0
                ;;
              update)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--gpg-key=[GPG key ID]:key id:' \
                  '--skip-signing[skip GPG signing]' \
                  '--force-overwrite[force overwrite of published files]' \
                  '1:distribution:' \
                  '2:prefix:' && ret=0
                ;;
              switch)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--component=[component name]:component:' \
                  '--gpg-key=[GPG key ID]:key id:' \
                  '--skip-signing[skip GPG signing]' \
                  '--force-overwrite[force overwrite of published files]' \
                  '1:distribution:' \
                  '2:new snapshot:_aptly_snapshots' \
                  '3:prefix:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      package)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_package_commands' \
          '*::arg:->package_args' && ret=0
        case "$state" in
          package_args)
            case "${line[1]}" in
              search)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '1:package query:' && ret=0
                ;;
              show)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--with-files[show file information]' \
                  '--with-references[show references]' \
                  '1:package query:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      db)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_db_commands' \
          '*::arg:->db_args' && ret=0
        case "$state" in
          db_args)
            case "${line[1]}" in
              cleanup)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--dry-run[do not delete, only show what would be removed]' \
                  '--verbose[be more verbose]' && ret=0
                ;;
              recover)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      serve)
        _arguments -s -S \
          "${_aptly_global_flags[@]}" \
          '--listen=[listen address]:address\:port:' && ret=0
        ;;
      api)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_api_commands' \
          '*::arg:->api_args' && ret=0
        case "$state" in
          api_args)
            case "${line[1]}" in
              serve)
                _arguments -s -S \
                  "${_aptly_global_flags[@]}" \
                  '--listen=[listen address]:address\:port:' \
                  '--no-lock[do not lock the database]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      graph)
        _arguments -s -S \
          "${_aptly_global_flags[@]}" \
          '--format=[output format]:format:(png svg pdf)' \
          '--output=[output file]:file:_files' && ret=0
        ;;
      config)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_config_commands' && ret=0
        ;;
      task)
        _arguments -s -S -C \
          "${_aptly_global_flags[@]}" \
          '1:subcommand:_aptly_task_commands' && ret=0
        ;;
      version)
        _arguments -s -S \
          "${_aptly_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
