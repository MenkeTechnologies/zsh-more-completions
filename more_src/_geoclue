#compdef geoclue
# _geoclue — geolocation service daemon (geoclue/geoclue)
# upstream: https://gitlab.freedesktop.org/geoclue/geoclue
# Flags from src/gclue-main.c (GOptionEntry entries[]).

_geoclue() {
    _arguments \
        '--version[display version number]' \
        '(-t --timeout)'{-t+,--timeout=}'[exit after T seconds of inactivity (0 = never, default 60)]:T:' \
        '(-s --submit-data)'{-s,--submit-data}'[enable submission of network data]' \
        '(-n --submit-nick)'{-n+,--submit-nick=}'[nickname for network data submission (empty or 2-32 chars)]:nick:' \
        '(-u --nmea-socket)'{-u+,--nmea-socket=}'[path to NMEA UNIX socket]:socket:_files'
}

_geoclue "$@"
