#compdef xbuild
# Documentation: https://learn.microsoft.com/en-us/visualstudio/msbuild/msbuild-command-line-reference
# Reference accessed: 2026-05-21
# Verified: Mono xbuild is an MSBuild-compatible tool; flag forms verified against MSBuild reference.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '/help[show help]' \
  '/?[show help]' \
  '/version[show version]' \
  '/nologo[no banner]' \
  '/target:-[targets to build csv]:targets:' \
  '/t:-[targets to build csv]:targets:' \
  '/property:-[property name=value]:prop:' \
  '/p:-[property name=value]:prop:' \
  '/logger:-[custom logger]:logger:' \
  '/l:-[custom logger]:logger:' \
  '/verbosity:-[verbosity level]:lvl:(quiet minimal normal detailed diagnostic)' \
  '/v:-[verbosity level]:lvl:(quiet minimal normal detailed diagnostic)' \
  '/toolsversion:-[toolset version]:ver:(2.0 3.5 4.0 12.0 14.0 15.0)' \
  '/tv:-[toolset version]:ver:(2.0 3.5 4.0 12.0 14.0 15.0)' \
  '/consoleloggerparameters:-[console logger params]:params:' \
  '/clp:-[console logger params]:params:' \
  '/noconsolelogger[disable default console logger]' \
  '/noconlog[disable default console logger]' \
  '/fileLogger[log to file]' \
  '/fl[log to file]' \
  '/fileLoggerParameters:-[file logger params]:params:' \
  '/flp:-[file logger params]:params:' \
  '/distributedFileLogger[distributed file logger]' \
  '/dfl[distributed file logger]' \
  '/distributedlogger:-[distributed logger]:logger:' \
  '/dl:-[distributed logger]:logger:' \
  '/maxcpucount:-[max parallel processes]:n:' \
  '/m:-[max parallel processes]:n:' \
  '/validate[validate project against schema]' \
  '/val[validate project against schema]' \
  '/validate:-[validate against schema file]:file:_files -g "*.xsd"' \
  '/preprocess:-[preprocess output to file]:file:_files' \
  '/pp:-[preprocess output to file]:file:_files' \
  '*:project file:_files -g "*.csproj *.fsproj *.vbproj *.sln *.proj *.targets *.props"' && ret=0

return ret
