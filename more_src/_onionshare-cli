#compdef onionshare-cli

# OnionShare CLI: anonymous file sharing over Tor onion services
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --local-only)'{-l,--local-only}'[do not use Tor (local testing)]' \
  '--no-autostop-timer[do not auto-stop after first download]' \
  '--autostop-timer=[auto-stop after seconds]:sec:' \
  '--autostart-timer=[auto-start after seconds]:sec:' \
  '--public[public share (no password)]' \
  '--connect-timeout=[connect timeout]:sec:' \
  '--gui[force GUI mode]' \
  '--share[share mode (default)]' \
  '--receive[receive files mode]' \
  '--website[website hosting mode]' \
  '--chat[anonymous chat room mode]' \
  '--data-dir=[downloads/data directory]:dir:_files -/' \
  '--ephemeral-tor[use ephemeral Tor (do not connect to system Tor)]' \
  '--auto-start-timer=[start delay sec]:sec:' \
  '--ephemeral[ephemeral connection]' \
  '*:files to share:_files' && ret=0
return ret
