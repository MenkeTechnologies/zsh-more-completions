#compdef onionshare-cli

# onionshare-cli: anonymous file sharing/chat over Tor (CLI mode)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a modes=(
  'share:share files'
  'receive:receive files'
  'website:host a website'
  'chat:run a chat server'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '--filename=[output file/path]:file:_files' \
  '--receive[receive files mode]' \
  '--share[share mode]' \
  '--website[website mode]' \
  '--chat[chat mode]' \
  '--public[disable private mode (no password)]' \
  '--auto-start-timer=[auto start timer (seconds)]:seconds:' \
  '--auto-stop-timer=[auto stop timer (seconds)]:seconds:' \
  '--no-autostop-sharing[no auto-stop when share is downloaded]' \
  '--data-dir=[data directory (for receive mode)]:dir:_files -/' \
  '--webhook-url=[webhook URL]:url:' \
  '--disable-text[disable text uploads]' \
  '--disable-files[disable file uploads]' \
  '--persistent=[persistent session file]:file:_files' \
  '--title=[custom title]:title:' \
  '--connect-timeout=[connect timeout (seconds)]:seconds:' \
  '--local-only[do not use Tor]' \
  '--qr[show QR code of address]' \
  '1: :->mode' \
  '*:files:_files' && ret=0
case $state in
  mode) _describe -t modes 'onionshare-cli mode' modes && ret=0 ;;
esac
return ret
