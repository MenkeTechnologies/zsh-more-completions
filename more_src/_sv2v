#compdef sv2v
# Documentation: https://verilator.org/guide/latest/
# SystemVerilog to Verilog conversion

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[print version information]' \
  '--numeric-version[print version number only]' \
  '*'{-I,--incdir=}'[add directory to include search path]:dir:_files -/' \
  '*'{-y,--libdir=}'[add library search path for undefined modules]:dir:_files -/' \
  '*'{-D,--define=}'[define macro for preprocessing]:name[=value]' \
  '--siloed[lex files separately so macros do not carry between files]' \
  '--skip-preprocessor[disable macro and comment preprocessing]' \
  '--pass-through[output input without converting]' \
  '*'{-E,--exclude=}'[exclude specific conversions]:conv:(Always Assert Interface Logic SeverityTask UnbasedUnsized)' \
  '(-v --verbose)'{-v,--verbose}'[retain conversion artifacts]' \
  '(-w --write)'{-w,--write=}'[specify output mode]:mode/file/dir' \
  '--top=[keep only specified top module]:name' \
  '--oversized-numbers[disable 32-bit limit on unsized number literals]' \
  '--dump-prefix=[create intermediate output files for debugging]:path:_files' \
  '--bugpoint=[reduce input by pruning unnecessary components]:substr' \
  '*:source file:_files -g "*.(sv|svh|v|vh)"' && ret=0

return ret
