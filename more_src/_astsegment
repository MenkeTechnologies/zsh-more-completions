#compdef astsegment
# astsegment — GNU Astronomy Utilities segmentation

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cite[show citation info]' \
  '(-q --quiet)'{-q,--quiet}'[suppress informational messages]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '--hdu[HDU/extension name or number]:hdu:' \
  '--detection[detection file]:file:_files -g "*.fits"' \
  '--dhdu[detection HDU]:hdu:' \
  '--kernel[convolution kernel]:file:_files -g "*.fits"' \
  '--khdu[kernel HDU]:hdu:' \
  '--convolved[already convolved input]:file:_files -g "*.fits"' \
  '--tilesize[tile size]:size:' \
  '--numchannels[number of channels]:channels:' \
  '--remainderfrac[remainder fraction]:fraction:' \
  '--workoverch[work over channels]' \
  '--interpnumngb[interpolation neighbors]:number:' \
  '--interpmetric[interpolation metric]:metric:(radial manhattan)' \
  '--minskyfrac[minimum sky fraction]:fraction:' \
  '--sigmaclip[sigma-clip multiples]:multiples:' \
  '--snminarea[S/N minimum area]:area:' \
  '--snquant[S/N quantile]:quantile:' \
  '--gthresh[growth threshold]:threshold:' \
  '--minriverlength[minimum river length]:length:' \
  '--objbordersn[object border S/N]:sn:' \
  '--grownclumps[grow clumps]' \
  '--checksn[check S/N values]' \
  '--checkclumps[check clumps]' \
  '--rawoutput[raw output without catalog]' \
  '*:input file:_files -g "*.fits"'
