#compdef astsegment
# astsegment — segment detections into clumps and objects

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress extra information]' \
  '--log[store program activity in a log file]' \
  '(-N --numthreads)'{-N,--numthreads}'[number of CPU threads]:number' \
  '--minmapsize[minimum bytes to use memory-mapped files]:size' \
  '--quietmmap[do not report memory-mapped file creation]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[output data type]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case in matching column names]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and exit]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for current directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for current user]' \
  '--cite[show BibTeX citation for this program]' \
  '--config[configuration file to use]:file:_files' \
  '--checkconfig[print all config files and variables]' \
  '--onlyversion[only run if program version matches]:version' \
  '--searchin[search column metadata]:where:(name unit comment)' \
  '(-Z --tilesize)'{-Z,--tilesize}'[regular tile size on each dimension]:sizes' \
  '(-M --numchannels)'{-M,--numchannels}'[number of channels in each dimension]:channels' \
  '(-F --remainderfrac)'{-F,--remainderfrac}'[fraction of remainder to merge with tiles]:fraction' \
  '--interpnumngb[number of neighbors for interpolation]:number' \
  '--interpmetric[metric for nearest neighbor interpolation]:metric:(radial manhattan)' \
  '--interponlyblank[only interpolate over blank tiles]' \
  '--workoverch[work over channels instead of all input]' \
  '--checktiles[save tessellation in a file]' \
  '--oneelempertile[one element per tile in interpolation]' \
  '(-d --detection)'{-d,--detection}'[detection image file to segment]:file:_files' \
  '--dhdu[HDU containing detection image]:HDU' \
  '(-k --kernel)'{-k,--kernel}'[kernel file for convolution]:file:_files' \
  '--khdu[HDU of kernel image]:HDU' \
  '--convolved[convolved image file to skip convolution]:file:_files' \
  '--chdu[HDU of convolved image]:HDU' \
  '--sky[sky value or sky image file]:value or file' \
  '--skyhdu[HDU containing sky value]:HDU' \
  '--std[sky standard deviation value or file]:value or file' \
  '--stdhdu[HDU containing sky STD]:HDU' \
  '--variance[STD input is actually variance]' \
  '(-L --largetilesize)'{-L,--largetilesize}'[size of larger tiles]:sizes' \
  '--rawoutput[output only CLUMPS and/or OBJECTS HDUs]' \
  '--noobjects[finish with clumps, do not create objects]' \
  '--grownclumps[save grown clumps instead of original]' \
  '(-C --continueaftercheck)'{-C,--continueaftercheck}'[continue processing after checks]' \
  '(-B --minskyfrac)'{-B,--minskyfrac}'[minimum fraction of undetected area in tile]:fraction' \
  '--minima[build internal clumps from minima]' \
  '(-m --snminarea)'{-m,--snminarea}'[minimum area of clumps for S/N estimation]:area' \
  '--checksn[save clump S/N values into a file]' \
  '--minnumfalse[minimum number for S/N estimation]:number' \
  '(-c --snquant)'{-c,--snquant}'[S/N quantile of true sky clumps]:quantile' \
  '(-v --keepmaxnearriver)'{-v,--keepmaxnearriver}'[keep clumps with peak touching a river]' \
  '(-s --clumpsnthresh)'{-s,--clumpsnthresh}'[S/N threshold of true clumps]:threshold' \
  '(-G --gthresh)'{-G,--gthresh}'[multiple of STD to stop growing clumps]:multiple' \
  '(-y --minriverlength)'{-y,--minriverlength}'[minimum length of useful grown clump rivers]:length' \
  '(-O --objbordersn)'{-O,--objbordersn}'[minimum S/N for grown clumps as one object]:S/N' \
  '--checksegmentation[store segmentation steps in a file]' \
  '*:input FITS image:_files -g "*.fits(|.gz|.fz)(N)"'
