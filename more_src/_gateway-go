# gateway-go: OpenIoTHub LAN-side gateway (no documented CLI flags; config via YAML).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :_files' && ret=0

return ret
