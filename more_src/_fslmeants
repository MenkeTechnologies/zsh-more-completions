#compdef fslmeants
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# FSL: output the average timeseries of a set of voxels or each individual time series

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i[input 4D image]:input:_files' \
  '-o[output text file]:output:_files' \
  '-m[input 3D mask]:mask:_files' \
  '-c[requested spatial coordinate]:coord:' \
  '--usemm[use mm coordinates instead of voxel]' \
  '--showall[show all voxel time series instead of mean]' \
  '--eig[calculate Eigenvariate(s) instead of mean]' \
  '--order=[order of Eigenvariates]:order:' \
  '--no_bin[do not binarise the mask]' \
  '--transpose[output in transpose format]' \
  '*:image:_files' && ret=0

return ret
