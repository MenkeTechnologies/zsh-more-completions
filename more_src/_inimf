#compdef inimf inimp inivf mf metafont mpost-base mpost-orig
# Documentation: inimf --help / inimp --help (TeX Live 2026)
# Source: TeX Live MetaFont / MetaPost format-dumping initializers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-cnf-line=[parse STRING as configuration line]:string:' \
    '-fmt=[format file]:name:' \
    '-halt-on-error[stop at first error]' \
    '(-file-line-error -no-file-line-error)-file-line-error[file\:line\:error style]' \
    '(-file-line-error -no-file-line-error)-no-file-line-error[disable file\:line\:error style]' \
    '-ini[be ini (dumping)]' \
    '-interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '-jobname=[job name]:string:' \
    '-kpathsea-debug=[kpathsea debug bitmask]:n:' \
    '(--mktex --no-mktex)-mktex=[enable mktexFMT]:fmt:(tex tfm)' \
    '(--mktex --no-mktex)-no-mktex=[disable mktexFMT]:fmt:(tex tfm)' \
    '-mem=[memory file]:file:' \
    '-output-directory=[output directory]:dir:_files -/' \
    '(-parse-first-line -no-parse-first-line)-parse-first-line[parse first line of input]' \
    '(-parse-first-line -no-parse-first-line)-no-parse-first-line[do not parse first line]' \
    '-progname=[program name]:string:' \
    '-recorder[enable filename recorder]' \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '*:MetaFont / MetaPost source:_files -g "*.{mf,mp}"' \
    && ret=0

return ret
