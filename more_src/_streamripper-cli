#compdef streamripper-cli
# _streamripper-cli — Greg Sharp streamripper Shoutcast/icecast stream recorder CLI alias (streamripper team, C); custom argparse
# upstream: https://sourceforge.net/projects/streamripper/

_streamripper-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[file]:file:_files' \
        '-A[record to single file]' \
        '-c[don'\''t auto-reconnect]' \
        '-d+[output dir]:dir:_files -/' \
        '-D+[filename pattern]:str:' \
        '-E+[command]:str:' \
        '-i[disable id3 tags]' \
        '-I+[interface]:_net_interfaces' \
        '-k+[count]:n:' \
        '-l+[max seconds]:n:' \
        '-L+[playlist file]:file:_files' \
        '-m+[max timeout]:n:' \
        '-M+[max megabytes]:n:' \
        '-o+[option]:o:(always larger version never)' \
        '-p+[proxy URL]:str:' \
        '-P+[output prefix]:str:' \
        '-q[disable splitting]' \
        '-r+[port]:port:' \
        '-R+[max relay connections]:n:' \
        '-s[no individual tracks]' \
        '-t[no overwrite]' \
        '-T[track creator]' \
        '-u+[user agent]:str:' \
        '-U+[username]:_users' \
        '-w+[rules file]:file:_files' \
        '-W+[passwd]:str:' \
        '-x[xml ouput]' \
        '-X+[xml log file]:file:_files' \
        '--codeset-filesys=+[encoding]:str:' \
        '--codeset-id3=+[encoding]:str:' \
        '--codeset-metadata=+[encoding]:str:' \
        '--codeset-relay=+[encoding]:str:' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '--rip-folder=+[dir]:dir:_files -/' \
        '--stderr[log to stderr]' \
        '*:url:_urls'
}

_streamripper-cli "$@"
