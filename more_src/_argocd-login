#compdef argocd-login
# Documentation: https://argo-cd.readthedocs.io/en/stable/user-guide/commands/argocd_login/
# Argo CD login: log in to Argo CD

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--auth-token=[authentication token]:token:' \
  '--insecure[skip server certificate and domain verification]' \
  '--grpc-web[enable gRPC-web protocol]' \
  '--config=[path to Argo CD config]:file:_files' \
  '--plaintext[disable TLS]' \
  '--client-crt=[client certificate file]:file:_files' \
  '--client-crt-key=[client certificate key file]:file:_files' \
  '*:server:' && ret=0

return ret
