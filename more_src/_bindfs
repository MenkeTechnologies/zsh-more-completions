#compdef bindfs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--map=[user/group mapping]:mapping' \
  '--create-for-user=[user for new files]:user:_users' \
  '--create-for-group=[group for new files]:group:_groups' \
  '--create-with-perms=[permissions for new files]:perms' \
  '--mirror=[mirror ownership to these users]:users' \
  '--mirror-only=[mirror only these users]:users' \
  '(-p --perms)'{-p,--perms}'=[permission bits to set]:perms' \
  '--chmod-ignore[ignore chmod operations]' \
  '--chown-ignore[ignore chown operations]' \
  '--chgrp-ignore[ignore chgrp operations]' \
  '--delete-deny[deny file deletion]' \
  '--rename-deny[deny file renaming]' \
  '--xattr-none[disable extended attributes]' \
  '--realistic-permissions[realistic permission checks]' \
  '--ctime-from-mtime[set ctime from mtime]' \
  '--hide-hard-links[show hard link count as 1]' \
  '--multithreaded[enable multithreaded mode]' \
  '(-n --no-allow-other)'{-n,--no-allow-other}'[do not add allow_other FUSE option]' \
  '--uid-offset=[offset for user IDs]:offset' \
  '--gid-offset=[offset for group IDs]:offset' \
  '--force-user=[force owner user]:user:_users' \
  '--force-group=[force owner group]:group:_groups' \
  '(-o)-o[FUSE mount options]:options' \
  '--no-default-permissions[disable default permission checking]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:source directory:_directories' \
  '2:mount point:_directories' && ret=0

return ret
