#compdef tfctl
# Documentation: https://docs.gitops.weaveworks.org/docs/0.26.0/terraform/tfctl/
# Command-line tool for the Weave GitOps Terraform Controller

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[Kubernetes namespace for CLI requests]:namespace' \
  '--terraform=[location of the terraform binary]:file:_files' \
  '1:command:((
    completion\:"generate shell autocompletion script"
    create\:"create a Terraform resource"
    delete\:"delete a Terraform resource"
    get\:"get Terraform resources"
    help\:"help about any command"
    install\:"install the tf-controller"
    plan\:"plan a Terraform configuration"
    reconcile\:"trigger a reconcile of the provided resource"
    resume\:"resume reconciliation for the provided resource"
    suspend\:"suspend reconciliation for the provided resource"
    uninstall\:"uninstall the tf-controller"
    version\:"print tf-controller and tfctl version information"
  ))' \
  '*::arg:_default' && ret=0

return ret
