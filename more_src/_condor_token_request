#compdef condor_token_request
# _condor_token_request — HTCondor condor_token_request (client side of the IDTOKEN request flow: ask a remote daemon to mint a token for the current user; -identity identity hint, -lifetime seconds, -authz csv list, -name target daemon, -pool collector address, -type daemon type, -addr explicit address, -file output token file)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_request on tip.

_condor_token_request() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-identity+[identity hint]:identity:' \
        '-lifetime+[seconds]:seconds:' \
        '-authz+[authz csv]:authz:(READ WRITE ADMINISTRATOR ADVERTISE_STARTD ADVERTISE_SCHEDD ADVERTISE_MASTER NEGOTIATOR DAEMON)' \
        '-name+[daemon name]:name:' \
        '-pool+[collector]:host:_hosts' \
        '-addr+[address]:addr:' \
        '-type+[daemon type]:type:(master collector schedd startd negotiator credd)' \
        '-file+[output file]:file:_files'
}

_condor_token_request "$@"
