#compdef sbctl

# Zsh completion for sbctl - Secure Boot key manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create-keys:create secure boot signing keys'
  'enroll-keys:enroll secure boot keys into firmware'
  'sign:sign a file with secure boot keys'
  'sign-all:sign all enrolled files'
  'remove-file:remove a file from the signing database'
  'verify:verify the signing of a file'
  'list-files:list enrolled files'
  'list-bundles:list enrolled bundles'
  'bundle:create a bundle'
  'generate-bundles:generate all bundles'
  'remove-bundle:remove a bundle'
  'rotate-keys:rotate signing keys'
  'status:show secure boot status'
  'setup:setup secure boot'
  'reset:reset secure boot configuration'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--json[output in JSON]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'sbctl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      sign)
        _arguments \
          '(-o --output)'{-o,--output}'[output filename]:file:_files' \
          '(-s --save)'{-s,--save}'[save file to signing database]' \
          '1:file to sign:_files' && ret=0
        ;;
      verify)
        _arguments '*:file to verify:_files' && ret=0
        ;;
      remove-file)
        _arguments '1:file:_files' && ret=0
        ;;
      enroll-keys)
        _arguments \
          '--microsoft[include Microsoft keys]' \
          '--tpm-eventlog[include TPM eventlog]' \
          '--yes-this-might-brick-my-machine[skip confirmation]' && ret=0
        ;;
      bundle)
        _arguments \
          '(-a --amducode)'{-a,--amducode}'[AMD microcode]:file:_files' \
          '(-c --cmdline)'{-c,--cmdline}'[kernel cmdline]:cmdline' \
          '(-e --esp)'{-e,--esp}'[ESP path]:path:_files -/' \
          '(-i --initramfs)'{-i,--initramfs}'[initramfs]:file:_files' \
          '(-I --intelucode)'{-I,--intelucode}'[Intel microcode]:file:_files' \
          '(-k --kernel-img)'{-k,--kernel-img}'[kernel image]:file:_files' \
          '(-o --os-release)'{-o,--os-release}'[os-release file]:file:_files' \
          '(-s --save)'{-s,--save}'[save bundle to database]' \
          '(-S --splash)'{-S,--splash}'[splash image]:file:_files' \
          '1:output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
