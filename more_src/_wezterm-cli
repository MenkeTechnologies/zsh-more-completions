#compdef wezterm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cli:control wezterm via the gui or mux server'
  'connect:connect to a remote multiplexer'
  'help:show help'
  'imgcat:render an image inline'
  'ls-fonts:list known fonts'
  'replay:replay a recorded session'
  'serial:open a serial port'
  'set-working-directory:emit OSC 7'
  'shell-completion:print shell completions'
  'show-keys:show key assignments'
  'ssh:run a SSH client'
  'start:start the GUI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-n+[skip config]:b:' \
  '*--skip-config[skip config]' \
  '*--config-file=[file]:file:_files -g "*.lua"' \
  '*--config=[k=v]:v:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wezterm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '(--cwd)--cwd=[dir]:dir:_files -/' \
          '(--always-new-process)--always-new-process[no spawn into existing]' \
          '(--no-auto-connect)--no-auto-connect[no auto connect]' \
          '(--position)--position=[x,y or screen:x,y]:p:' \
          '(--class)--class=[class]:c:' \
          '(--workspace)--workspace=[name]:w:' \
          '(--domain)--domain=[name]:d:' \
          '(--attach)--attach[attach domain]' \
          '(-e --)*-e[execute remaining as command]' \
          '*:command:_command_names -e' && ret=0 ;;
      (cli)
        _arguments \
          '1:subcommand:(activate-pane activate-pane-direction activate-tab adjust-pane-size get-pane-direction get-text kill-pane list list-clients move-pane-to-new-tab proxy rename-workspace send-text set-tab-title set-window-title spawn split-pane zoom-pane)' \
          '(--no-auto-start)--no-auto-start[no auto start]' \
          '(--prefer-mux)--prefer-mux[prefer mux]' \
          '(--class)--class=[class]:c:' \
          '*: :' && ret=0 ;;
      (ssh)
        _arguments \
          '(--config -o)*-o+[k=v]:v:' \
          '*: :_hosts' && ret=0 ;;
      (connect)
        _arguments \
          '(--workspace)--workspace=[name]:w:' \
          '(--new-tab)--new-tab[new tab]' \
          '(--class)--class=[class]:c:' \
          '*:domain:' && ret=0 ;;
      (imgcat)
        _arguments \
          '(--width)--width=[w]:w:' \
          '(--height)--height=[h]:h:' \
          '(--no-preserve-aspect-ratio)--no-preserve-aspect-ratio[no preserve aspect]' \
          '(--position)--position=[h-pos]:p:' \
          '(--clear-before)--clear-before[clear before]' \
          '(--show-name)--show-name[show name]' \
          '(--no-resample)--no-resample[no resample]' \
          '(--max-pixels)--max-pixels=[n]:n:' \
          '*: :_files' && ret=0 ;;
      (replay)
        _arguments \
          '(--explain)--explain[explain]' \
          '(--explain-only)--explain-only[explain only]' \
          '*: :_files' && ret=0 ;;
      (serial)
        _arguments \
          '(--baud -b)'{-b+,--baud=}'[baud]:n:' \
          '*: :_files -g "/dev/tty*"' && ret=0 ;;
      (shell-completion)
        _arguments '(--shell)--shell=[shell]:shell:(bash zsh fish elvish power-shell)' && ret=0 ;;
      (ls-fonts)
        _arguments \
          '(--list-system)--list-system[list system fonts]' \
          '(--text)--text=[text to render]:t:' \
          '(--family)--family=[family]:f:' \
          '(--codepoints)--codepoints=[codepoints]:c:' \
          '(--rasterize-ascii)--rasterize-ascii[render ASCII]' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
