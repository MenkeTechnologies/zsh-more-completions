#compdef wezterm-cli
# Documentation: https://wezterm.org/cli/cli/index.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: wezterm-cli is not a separate upstream binary; the `cli` subcommand
# is invoked via `wezterm cli ...` and completed by _wezterm. This file is a
# defensive stub for any user alias/symlink named `wezterm-cli`.

local curcontext="$curcontext" state line ret=1
local -a cli_commands
cli_commands=(
  'activate-pane:activate a specific pane'
  'activate-pane-direction:activate an adjacent pane'
  'activate-tab:activate a specific tab'
  'adjust-pane-size:resize a pane'
  'get-pane-direction:query pane direction info'
  'get-text:extract text from panes'
  'kill-pane:close a pane'
  'list:show window/tab/pane info'
  'list-clients:display connected clients'
  'move-pane-to-new-tab:relocate a pane to a new tab'
  'proxy:proxy a multiplexer connection'
  'rename-workspace:rename a workspace'
  'send-text:send text to a pane'
  'set-tab-title:set tab title'
  'set-window-title:set window title'
  'spawn:spawn a command in a new window/tab'
  'split-pane:split the current pane'
  'tlscreds:obtain TLS credentials'
  'zoom-pane:zoom/unzoom a pane'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:cli command:->cmd' \
  '*::args:_files' && ret=0

case $state in
  cmd) _describe -t cmds 'wezterm cli command' cli_commands && ret=0 ;;
esac

return ret
