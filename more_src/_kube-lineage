#compdef kube-lineage
# Documentation: https://github.com/tohjustin/kube-lineage
# Reference accessed: 2026-05-19
# Verified: tohjustin/kube-lineage README. Removed from prior file:
# invented tree/list/graph subcommands; added real helm/split/split-wide
# subcommands and -D/--dependencies, -d/--depth, --exclude-types,
# --include-types, -S/--scopes, -o/--output, -L/--label-columns,
# --no-headers, --show-group, --show-label, --show-namespace flags;
# corrected -A/--all-namespaces; replaced bogus man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'helm:display Helm release resources and their dependents'
  'split:output grouping resources by type'
  'split-wide:wide variant of the split output'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-D --dependencies)'{-D,--dependencies}'[list object dependencies instead of dependents]' \
  '(-d --depth)'{-d+,--depth=}'[maximum depth for relationship discovery]:n:' \
  '--exclude-types=[comma-separated resource types to exclude]:types:' \
  '--include-types=[comma-separated resource types to include only]:types:' \
  '(-S --scopes)'{-S+,--scopes=}'[additional namespaces for discovery]:namespaces:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(wide split split-wide)' \
  '*'{-L+,--label-columns=}'[label to present as a column]:label:' \
  '--no-headers[do not print headers]' \
  '--show-group[show resource group in the Kind column]' \
  '--show-label[show all labels as the last column]' \
  '--show-namespace[show namespace as the first column]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[discover relationships across all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[target namespace]:namespace:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kube-lineage command' commands && ret=0 ;;
  (args) _default && ret=0 ;;
esac

return ret
