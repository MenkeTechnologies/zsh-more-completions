#compdef dipy_mask
# Documentation: https://docs.dipy.org/stable/reference_cmd/dipy_mask.html
# DIPY: create a binary mask from threshold bounds

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ub=[upper bound value; defaults to infinity]:ub' \
  '--out_dir=[output directory]:dir:_files -/' \
  '--out_mask=[name of the masked output file]:file:_files' \
  '*:input (image lb):_files' && ret=0

return ret
