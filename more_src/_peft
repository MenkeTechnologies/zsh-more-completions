#compdef peft
# _peft — Hugging Face peft Parameter Efficient Fine-Tuning CLI for LoRA QLoRA AdaLoRA prefix-tuning prompt-tuning IA3 and adapter merge operations (huggingface team, Python); typer/click
# upstream: https://github.com/huggingface/peft

_peft() {
    local -a sub=(
        'env:show environment'
        'merge:merge adapter into base model'
        'unload:unload adapter from base'
        'add-adapter:add new adapter'
        'delete-adapter:delete adapter'
        'set-adapter:set active adapter'
        'list-adapters:list adapters'
        'convert:convert adapter format'
        'cast-mixed-precision-params:cast mixed precision params'
        'save:save adapter'
        'load:load adapter'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'peft subcommand' sub ;;
        args)
            case $words[1] in
                merge) _arguments \
                    '--base-model=+[model id or path]:str:' \
                    '--adapter-model=+[adapter id or path]:str:' \
                    '--output-dir=+[dir]:dir:_files -/' \
                    '--torch-dtype=+[dtype]:d:(float16 bfloat16 float32)' \
                    '--device-map=+[map]:m:(auto cpu cuda mps cuda:0 cuda:1)' \
                    '--safe-serialization[safetensors]' \
                    '--push-to-hub[push to hub]' \
                    '--token=+[token]:str:' ;;
                add-adapter|delete-adapter|set-adapter) _arguments \
                    '--adapter-name=+[name]:str:' \
                    '--peft-type=+[type]:t:(LORA ADAPTION_PROMPT PREFIX_TUNING P_TUNING PROMPT_TUNING IA3 LOHA LOKR LN_TUNING POLY ADALORA BOFT)' \
                    '--r=+[rank]:n:' \
                    '--lora-alpha=+[N]:n:' \
                    '--lora-dropout=+[F]:f:' \
                    '--target-modules=+[csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_peft "$@"
