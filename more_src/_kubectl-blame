#compdef kubectl-blame
# Documentation: https://man.archlinux.org/search?q=kubectl-blame
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '--time=[time format]:fmt:(full relative none)' \
  '(-f --filename)*'{-f+,--filename=}'[remote file]:file:_files -g "*.yaml *.yml *.json"' \
  '(-i --input)*'{-i+,--input=}'[local file]:file:_files -g "*.yaml *.yml *.json"' \
  '--context=[kubectl context]:ctx:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--cluster=[cluster name]:cluster:' \
  '--user=[user]:user:' \
  '-v+[verbosity]:lvl:' \
  '*:resource:' && ret=0

return ret
