#compdef ExtractIlluminaBarcodes
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/illumina/ExtractIlluminaBarcodes.java
# Picard: tool to determine the barcode for each read in an Illumina lane

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-B --BASECALLS_DIR)'{-B,--BASECALLS_DIR}'=[Illumina basecalls directory]:dir:_files -/' \
  '(-L --LANE)'{-L,--LANE}'=[lane number to process]:n:' \
  '(-RS --READ_STRUCTURE)'{-RS,--READ_STRUCTURE}'=[read structure describing logical reads]:s:' \
  '--BARCODE_FILE=[tab-delimited file of barcode sequences]:file:_files' \
  '*--BARCODE=[barcode sequence]:s:' \
  '(-M --METRICS_FILE)'{-M,--METRICS_FILE}'=[output barcode metrics file]:file:_files' \
  '--OUTPUT_DIR=[directory for barcode output files]:dir:_files -/' \
  '--MAX_MISMATCHES=[max mismatches allowed for a barcode]:n:' \
  '--MIN_MISMATCH_DELTA=[min mismatch delta to best vs next-best match]:n:' \
  '--MAX_NO_CALLS=[max no-calls allowed in a barcode]:n:' \
  '(-Q --MINIMUM_BASE_QUALITY)'{-Q,--MINIMUM_BASE_QUALITY}'=[min base quality for a base to be counted]:n:' \
  '--MINIMUM_QUALITY=[min quality threshold]:n:' \
  '--DISTANCE_MODE=[distance metric for barcode matching]:m:(HAMMING FREE)' \
  '(-GZIP --COMPRESS_OUTPUTS)'{-GZIP,--COMPRESS_OUTPUTS}'=[gzip compress output files]:b:(true false)' \
  '--NUM_PROCESSORS=[number of processors to use]:n:' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
