#compdef aide

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-B --before)'{-B+,--before=}'[before line config]:cfg:' \
  '(-A --after)'{-A+,--after=}'[after line config]:cfg:' \
  '(-D --config-check)'{-D,--config-check}'[check config]' \
  '(-i --init)'{-i,--init}'[initialize database]' \
  '(-C --check)'{-C,--check}'[check files]' \
  '(-r --report)'{-r+,--report=}'[report URL]:url:' \
  '(-u --update)'{-u,--update}'[update database]' \
  '(-E --compare)'{-E,--compare}'[compare databases]' \
  '(-l --limit)'{-l+,--limit=}'[limit regex]:re:' \
  '(-V --verbose)'{-V+,--verbose=}'[verbose level]:n:' \
  '(-L --log-level)'{-L+,--log-level=}'[log level]:l:(error warning notice info compare config rule debug trace)' \
  '*: :_files' && ret=0

return ret
