#compdef mtools mcopy mdel mdir mformat mlabel mmd mrd mren mtype mattrib mcat mcd mcopy mdel mdeltree

# Zsh completion for mtools - access DOS/FAT filesystems

case "$service" in
  mcopy)
    _arguments \
      '-b[batch mode]' \
      '-p[preserve file attributes]' \
      '-Q[quit on failure]' \
      '-r[recursive copy]' \
      '-s[recursive copy]' \
      '-t[text mode transfer]' \
      '-n[no confirmation for overwrite]' \
      '-m[preserve modification time]' \
      '-v[verbose]' \
      '*:files:_files'
    ;;
  mdir)
    _arguments \
      '-a[also list hidden files]' \
      '-f[fast listing (no free space)]' \
      '-w[wide output]' \
      '-b[brief output]' \
      '-s[recursive listing]' \
      '*:path:'
    ;;
  mformat)
    _arguments \
      '-t+[number of cylinders]:cylinders:' \
      '-h+[number of heads]:heads:' \
      '-s+[number of sectors]:sectors:' \
      '-f+[format capacity]:size:(360 720 1200 1440 2880)' \
      '-1[single sided]' \
      '-4[360K formatting of 1.2M disk]' \
      '-8[8 sector formatting]' \
      '-v+[volume label]:label:' \
      '-N+[serial number]:serial:' \
      '-F[format FAT32]' \
      '-S+[sector size code]:code:(0 1 2 3)' \
      '-2[double sided]' \
      '-B+[boot sector]:file:_files' \
      '-k[keep existing boot sector]' \
      '-r+[root directory size]:size:' \
      '-L+[fat length]:sectors:' \
      '-c+[cluster size]:sectors:' \
      '-A[atari format]' \
      '-X[format as XDF]' \
      '1:drive letter:'
    ;;
  mattrib)
    _arguments \
      '+a[set archive attribute]' \
      '-a[unset archive attribute]' \
      '+h[set hidden attribute]' \
      '-h[unset hidden attribute]' \
      '+r[set read-only attribute]' \
      '-r[unset read-only attribute]' \
      '+s[set system attribute]' \
      '-s[unset system attribute]' \
      '-X[recursively process subdirectories]' \
      '-p[replay mode]' \
      '*:msdos files:'
    ;;
  *)
    _arguments '*:files:_files'
    ;;
esac
