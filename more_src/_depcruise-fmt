#compdef depcruise-fmt
# _depcruise-fmt — format dependency-cruiser JSON output (sverweij/dependency-cruiser)
# upstream: https://github.com/sverweij/dependency-cruiser
# Flags from bin/depcruise-fmt.mjs (parseArgs).

_depcruise-fmt() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --output-to)'{-f+,--output-to=}'[output file (- for stdout)]:file:_files' \
        '(-T --output-type)'{-T+,--output-type=}'[output type]:type:(err err-long err-html dot ddot archi flat d2 mermaid json teamcity baseline cdot)' \
        '(-I --include-only)'{-I+,--include-only=}'[include only matching modules]:regex:' \
        '(-F --focus)'{-F+,--focus=}'[focus on matching modules]:regex:' \
        '--focus-depth=[focus depth]:n:' \
        '(-R --reaches)'{-R+,--reaches=}'[modules that reach matching]:regex:' \
        '(-H --highlight)'{-H+,--highlight=}'[highlight matching modules]:regex:' \
        '(-x --exclude)'{-x+,--exclude=}'[exclude matching modules]:regex:' \
        '(-S --collapse)'{-S+,--collapse=}'[collapse to folder depth or regex]:spec:' \
        '(-P --prefix)'{-P+,--prefix=}'[link prefix]:prefix:' \
        '--suffix=[link suffix]:suffix:' \
        '(-e --exit-code)'{-e,--exit-code}'[non-zero exit on rule violations]' \
        '1:dependency-cruiser JSON:_files -g "*.json"'
}

_depcruise-fmt "$@"
