#compdef fio

# Zsh completion for fio (Flexible I/O Tester)

_arguments -s -S \
  '--name[job name]:name:' \
  '--filename[file(s) to use for I/O]:file:_files' \
  '--directory[working directory for file]:dir:_files -/' \
  '--rw[type of I/O pattern]:pattern:(read write randread randwrite readwrite randrw trim randtrim trimwrite)' \
  '--readwrite[alias for --rw]:pattern:(read write randread randwrite readwrite randrw)' \
  '--bs[block size]:size:' \
  '--blocksize[alias for --bs]:size:' \
  '--iodepth[number of I/Os to keep in flight]:depth:' \
  '--size[total size of I/O]:size:' \
  '--numjobs[number of clones of this job]:jobs:' \
  '--runtime[run time]:seconds:' \
  '--time-based[keep running for duration even if file is fully read/written]' \
  '--ioengine[I/O engine to use]:engine:(sync psync vsync libaio posixaio io_uring mmap splice sg null)' \
  '--direct[use O_DIRECT]:bool:(0 1)' \
  '--buffered[use buffered I/O]:bool:(0 1)' \
  '--fsync[issue fsync after this many blocks]:blocks:' \
  '--fdatasync[issue fdatasync after this many blocks]:blocks:' \
  '--offset[start I/O at this offset]:offset:' \
  '--offset_increment[offset increment per job]:increment:' \
  '--nrfiles[number of files to use]:count:' \
  '--openfiles[max number of open files]:count:' \
  '--filesize[file size]:size:' \
  '--fill_device[fill device to full]:bool:(0 1)' \
  '--rwmixread[percentage of reads in mixed workload]:percent:' \
  '--rwmixwrite[percentage of writes in mixed workload]:percent:' \
  '--rate[throttle I/O rate]:rate:' \
  '--rate_iops[throttle IOPS]:iops:' \
  '--rate_min[minimum I/O rate]:rate:' \
  '--thinktime[idle time between I/Os]:usec:' \
  '--group_reporting[merge stats for all jobs]' \
  '--output[write output to file]:file:_files' \
  '--output-format[output format]:format:(terse json json+ normal)' \
  '--minimal[alias for --output-format=terse]' \
  '--append-terse[append terse output to file]:file:_files' \
  '--eta[ETA display]:mode:(auto always never)' \
  '--debug[set debug flags]:flags:' \
  '--section[run only section]:section:' \
  '--alloc-size[internal smalloc pool size]:kib:' \
  '--warnings-fatal[treat warnings as fatal errors]' \
  '--cpus_allowed[set affinity]:cpus:' \
  '--cpus_allowed_policy[CPU affinity policy]:policy:(shared split)' \
  '--thread[use threads instead of processes]' \
  '--loops[loop count]:count:' \
  '--verify[verify data written]:method:(md5 crc16 crc32 crc32c crc64 crc7 sha1 sha256 sha512 meta pattern null)' \
  '--do_verify[perform verify phase]:bool:(0 1)' \
  '--stonewall[wait for preceding jobs before starting]' \
  '--log_avg_msec[logging average period]:msec:' \
  '--write_bw_log[write bandwidth log]:prefix:' \
  '--write_lat_log[write latency log]:prefix:' \
  '--write_iops_log[write IOPS log]:prefix:' \
  '--randrepeat[seed random generator predictably]:bool:(0 1)' \
  '--norandommap[do not use a random map]' \
  '--softrandommap[allow random map allocation failures]' \
  '--lat_percentiles[report latency percentiles]:bool:(0 1)' \
  '--percentile_list[specify percentile list]:list:' \
  '--clocksource[clock source]:source:(gettimeofday clock_gettime cpu)' \
  '--server[start fio as a server]' \
  '--client[connect to fio server]:hostname:_hosts' \
  '--idle-prof[report CPU idleness]:method:(calibrate system percpu)' \
  '--status-interval[status update interval]:interval:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:jobfile:_files' && return 0
