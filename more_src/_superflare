#compdef superflare
# _superflare — full-stack framework for Cloudflare Workers (jplhomer/superflare)
# upstream: https://github.com/jplhomer/superflare
# Subcommands from packages/superflare/cli.ts (yargs).

_superflare() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'migrate:migrate database and update types'
                'dev:start the development server'
                'generate:scaffold useful things'
                'g:alias for generate'
                'new:create a new Superflare project'
                'console:open interactive developer console'
                'c:alias for console'
                'db:manage your database'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                new) _arguments '1:project name:' ;;
                generate|g) _arguments '1:type:(model controller migration)' '2:name:' ;;
                dev) _arguments '1:entrypoint:_files' ;;
                db) _arguments '1:subcommand:(create drop fresh seed reset list)' ;;
            esac
            ;;
    esac
}

_superflare "$@"
