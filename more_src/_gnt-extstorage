#compdef gnt-extstorage
# _gnt-extstorage — Google Ganeti gnt-extstorage CLI for managing external storage providers in the Ganeti virtualisation cluster diagnose info list modify parameters for external storage extstorage-shared SAN block backend (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-extstorage() {
    local -a sub=(
        'diagnose:diagnose providers'
        'info:show provider info'
        'list:list providers'
        'modify:modify provider'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--reason=+[text]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-extstorage subcommand' sub ;;
        args)
            case $words[1] in
                modify) _arguments \
                    '--extstorage-params=+[K=V csv]:str:' \
                    '--hidden=+[b]:b:(yes no)' \
                    '--blacklisted=+[b]:b:(yes no)' \
                    '*:provider name:' ;;
                info) _arguments '*:provider name:' ;;
            esac
            ;;
    esac
}

_gnt-extstorage "$@"
