#compdef gfan_groebnerfan
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/gfan.1.html
# gfan tool (groebnerfan): Groebner fans and tropical geometry

local ret=1

_arguments -s -S \
  '--help[display help describing functionality and options]' \
  '*--log+[control verbosity of progress information to stderr]:level' \
  '--stdin[specify input file instead of standard input]:input file:_files' \
  '--stdout[specify output file instead of standard output]:output file:_files' \
  '--xml[output polyhedral fans in XML format instead of text]' \
  '*:input file:_files' && ret=0

return ret
