#compdef flay

# Zsh completion for flay (Ruby code structural similarity detector)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-d,--diff}'[show differences in detected duplicates]' \
  {-f,--fuzzy}'=[fuzzy match level]:level' \
  {-l,--liberal}'[use more liberal matching]' \
  {-m,--mass}'=[minimum mass threshold (default 16)]:mass' \
  {-s,--summary}'[summary only]' \
  {-t,--timeout}'=[timeout in seconds]:seconds' \
  {-v,--verbose}'[verbose output]' \
  '--only=[only check specific sexp types]:node type' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
