#compdef reddix
# Documentation: https://man.archlinux.org/search?q=reddix
# Reference accessed: 2026-05-16

# https://github.com/ck-zhang/reddix — SQLite Reddit TUI (urfave/cli; `reddix -h`)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-d --db)'{-d,--db}'=-[SQLite path]:file:_files' \
  '*:unused:_default'
