#compdef splunkctl
# _splunkctl — Splunk splunkctl CLI alternative command-line frontend to the Splunk Enterprise Splunk Cloud REST API providing search index event input search-job kvstore lookup roles users saved-search alerts macros props transforms admin operations bulk-CRUD for SOAR-SOC dashboarding (Splunk team, Go); cobra
# upstream: https://docs.splunk.com/Documentation/Splunk/latest/RESTREF/RESTprolog

_splunkctl() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'search:run a search'
        'jobs:job operations'
        'kvstore:KV store operations'
        'lookup:lookup operations'
        'index:index management'
        'input:data input management'
        'role:role management'
        'user:user management'
        'app:app management'
        'savedsearch:saved-search management'
        'alert:alert management'
        'macro:macro management'
        'props:props.conf management'
        'transforms:transforms.conf management'
        'deploy:deployment management'
        'cluster:cluster management'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--session-key=+[key]:str:' \
        '--app=+[app]:str:' \
        '--owner=+[user]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.toml"' \
        '-f+[format]:f:(json yaml csv table xml raw)' \
        '--format=+[format]:f:(json yaml csv table xml raw)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--earliest=+[time]:str:' \
        '--latest=+[time]:str:' \
        '--max-count=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'splunkctl subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments '*:SPL:' ;;
                jobs|kvstore|index|input|role|user|app|savedsearch|alert|macro|props|transforms|deploy|cluster) _arguments '1:op:(list show create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_splunkctl "$@"
