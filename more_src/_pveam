#compdef pveam
# Documentation: https://pve.proxmox.com/pve-docs/pveam.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pveam - Proxmox VE appliance manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'available:list available templates'
  'download:download an appliance template'
  'list:list installed templates'
  'remove:remove a template'
  'update:update template database'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pveam command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (available)
        _arguments -s -S \
          '--section=[filter by section]:section:(mail system turnkeylinux)' && ret=0
        ;;
      (download)
        _arguments -s -S \
          '1:storage' \
          '2:template' && ret=0
        ;;
      (list)
        _arguments -s -S '1:storage' && ret=0
        ;;
      (remove)
        _arguments -s -S '1:template path' && ret=0
        ;;
      (update)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
