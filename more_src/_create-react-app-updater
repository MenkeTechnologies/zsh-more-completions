#compdef create-react-app-updater
# Documentation: https://www.npmjs.com/package/create-react-app-updater
# Reference accessed: 2026-05-24
# Verified: npm view create-react-app-updater bin; npm readme Options table.

# Zsh completion for create-react-app-updater - Create React App migration/updater CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--from=[starting version different from package.json]:version:' \
  '--to=[target version to update to]:version:(latest beta)' \
  '--resolve-conflicts[automatically run git mergetool on conflicts]' \
  '--run-codemods[run applicable React codemods]' \
  '--reset[reset project to default boilerplate at new version]' \
  '--compare-only[show version diff without updating]' \
  '--stats-only[show calculated project values only]' \
  '--list-codemods[list available codemods]' \
  '--global[operate on globally installed create-react-app]' \
  '--hard[hard reset during migration]' && ret=0

return ret
