#compdef tdo
# Documentation: https://github.com/2KAbhishek/tdo
# tdo - fast and simple command-line note-taking system

local ret=1
local line

_arguments -s -C \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'entry:open journal entry with flexible date'
      'e:open journal entry with flexible date'
      'note:create new timestamped note in drafts'
      'n:create new timestamped note in drafts'
      'find:interactively search all notes'
      'f:interactively search all notes'
      'todo:display all pending todos'
      't:display all pending todos'
      'pending:show pending todo count'
      'p:show pending todo count'
      'commit:commit changes'
      'c:commit changes'
      'h:display help information'
    )
    _describe -t commands 'tdo command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      find|f)
        _arguments -s '*:search text:' && ret=0
        ;;
      commit|c)
        _arguments -s '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
