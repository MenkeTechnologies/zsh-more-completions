#compdef sonobuoy

_sonobuoy_cmds() {
    local -a commands=(
        'run:launch conformance tests'
        'status:check the status of a sonobuoy run'
        'logs:dump diagnostic logs'
        'retrieve:download results archive'
        'results:inspect results archive'
        'delete:clean up sonobuoy resources'
        'gen:generate a manifest for a sonobuoy run'
        'e2e:run Kubernetes e2e tests'
        'images:manage images used in a sonobuoy run'
        'version:print sonobuoy version'
    )
    _describe -t commands 'sonobuoy command' commands
}

_sonobuoy() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '--kubeconfig=[path to kubeconfig]:file:_files' \
        '--context=[kubeconfig context to use]:context' \
        '--namespace=[namespace to run sonobuoy in]:namespace' \
        '-n=[namespace to run sonobuoy in]:namespace' \
        '--level=[log level]:level:(panic fatal error warn info debug trace)' \
        '1:command:_sonobuoy_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                run)
                    _arguments \
                        '--mode=[mode to run]:mode:(certified-conformance conformance-lite quick non-disruptive-conformance)' \
                        '--plugin=[plugin to run]:plugin:_files' \
                        '--e2e-focus=[e2e test focus regex]:regex' \
                        '--e2e-skip=[e2e test skip regex]:regex' \
                        '--image-pull-policy=[image pull policy]:policy:(Always IfNotPresent Never)' \
                        '--kube-conformance-image=[conformance image]:image' \
                        '--sonobuoy-image=[sonobuoy image]:image' \
                        '--timeout=[timeout in seconds]:seconds' \
                        '--wait=[wait timeout]:duration' \
                        '--plugin-env=[plugin environment variables]:env'
                    ;;
                status)
                    _arguments \
                        '--json[output as JSON]' \
                        '--show-all[show all plugins]'
                    ;;
                retrieve)
                    _arguments \
                        '--extract[extract results]' \
                        '--filename=[output filename]:file:_files' \
                        '1:directory:_directories'
                    ;;
                results)
                    _arguments \
                        '--mode=[output mode]:mode:(detailed dump)' \
                        '--node=[filter by node]:node' \
                        '--plugin=[filter by plugin]:plugin' \
                        '--skip-prefix=[skip prefix in output]:prefix' \
                        '1:archive:_files'
                    ;;
                delete)
                    _arguments \
                        '--all[delete everything including results]' \
                        '--wait=[wait timeout]:duration' \
                        '--rbac=[RBAC mode]:mode:(Enable Disable Detect)'
                    ;;
                gen)
                    _arguments \
                        '--mode=[mode to generate]:mode:(certified-conformance conformance-lite quick non-disruptive-conformance)' \
                        '--plugin=[plugin to include]:plugin:_files' \
                        '--e2e-focus=[e2e test focus regex]:regex' \
                        '--e2e-skip=[e2e test skip regex]:regex'
                    ;;
                images)
                    _arguments \
                        '--e2e-registry-config=[registry config]:file:_files' \
                        '--plugin=[plugin images]:plugin:_files' \
                        '1:action:(pull list download delete)'
                    ;;
            esac
            ;;
    esac
}

_sonobuoy "$@"
