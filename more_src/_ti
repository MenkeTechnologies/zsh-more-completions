#compdef ti
# Documentation: https://github.com/sharat87/ti
# ti - a simple command line time tracker

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help,help}'[show help]' \
  '1:command:((
    on:"start tracking time for an activity"
    o:"start tracking time for an activity"
    fin:"end tracking for the current activity"
    f:"end tracking for the current activity"
    status:"display the current tracking status"
    s:"display the current tracking status"
    tag:"add tags to the current activity"
    t:"add tags to the current activity"
    note:"add notes to the current activity"
    n:"add notes to the current activity"
    log:"display a table of all activities and time spent"
    l:"display a table of all activities and time spent"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*:argument:' && ret=0
    ;;
esac

return ret
