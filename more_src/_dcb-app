#compdef dcb-app
# Documentation: https://man.archlinux.org/man/dcb-app.8.en
# dcb app - manage the DCB Application Priority Table

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'dcb app command' \
      'show[display entries with a given selector]' \
      'flush[remove all entries with a given selector]' \
      'add[add APP 3-tuples to the table]' 'del[remove APP 3-tuples]' \
      'replace[replace priorities for selector]' \
      'dev[network device]' 'default-prio[priority for unspecified traffic]' \
      'ethtype-prio[map EtherType to priorities]' \
      'stream-port-prio[map TCP/SCTP dest ports to priorities]' \
      'dgram-port-prio[map UDP/DCCP dest ports to priorities]' \
      'port-prio[map ports to priorities]' \
      'dscp-prio[map DSCP code points to priorities]' \
      'pcp-prio[map PCP/DEI values to priorities]' && ret=0
    ;;
esac

return ret
