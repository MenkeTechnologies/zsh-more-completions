#compdef Polarimetric-Matrices
# Documentation: https://raw.githubusercontent.com/senbox-org/s1tbx/master/rstb/rstb-op-polarimetric-tools/src/main/java/org/csa/rstb/polarimetric/gpf/PolarimetricMatricesOp.java
# ESA SNAP gpt Polarimetric-Matrices operator - generate covariance or coherency matrices

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-Pmatrix=[the covariance or coherency matrix]:matrix:(C2 C3 C4 T3 T4)' \
  '*:graph xml:_files' && ret=0

return ret
