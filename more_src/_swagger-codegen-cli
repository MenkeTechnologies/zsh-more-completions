#compdef swagger-codegen-cli
# _swagger-codegen-cli — SmartBear Swagger Codegen API stub generator CLI alias (SmartBear, Java); custom argparse
# upstream: https://github.com/swagger-api/swagger-codegen

_swagger-codegen-cli() {
    local -a sub=(
        'generate:generate code from spec'
        'config-help:show config help'
        'meta:generate metadata generator'
        'langs:list languages'
        'help:show help'
        'validate:validate spec'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swagger-codegen subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '-i+[input spec]:file:_files -g "*.yaml *.yml *.json"' \
                    '--input-spec=+[input spec]:file:_files -g "*.yaml *.yml *.json"' \
                    '-l+[language]:l:(android aspnet5 aspnetcore async-scala bash clojure cwiki csharp cpprest dart dart-jaguar eiffel elixir elm erlang-client erlang-server flash python-flask go go-server groovy java jaxrs jaxrs-cxf jaxrs-resteasy jaxrs-spec inflector java-vertx javascript javascript-closure-angular jmeter kotlin kotlin-server lumen msf4j nancyfx nodejs-server objc okhttp-gson perl php php-laravel php-lumen php-slim php-symfony php-zend-expressive powershell python python-flask qt5cpp r rails5 restbed ruby rust rust-server scala scala-akka scala-akka-http-server scala-finch scala-gatling scala-lagom-server scala-play-server scalatra silex-PHP sinatra-php SinatraServerPHP slim spring static-html static-html2 swagger swagger-yaml swift swift3 swift4 swift5 tizen typescript-aurelia typescript-angular typescript-angularjs typescript-fetch typescript-inversify typescript-jquery typescript-node undertow ze-ph)' \
                    '--lang=+[language]:l:' \
                    '-o+[output dir]:dir:_files -/' \
                    '--output=+[output dir]:dir:_files -/' \
                    '-c+[config file]:file:_files' \
                    '--config=+[config file]:file:_files' \
                    '-t+[template dir]:dir:_files -/' \
                    '--template-dir=+[template dir]:dir:_files -/' \
                    '--auth=+[auth]:str:' \
                    '--api-package=+[api package]:str:' \
                    '--model-package=+[model package]:str:' \
                    '--invoker-package=+[invoker package]:str:' \
                    '--group-id=+[group id]:str:' \
                    '--artifact-id=+[artifact id]:str:' \
                    '--artifact-version=+[artifact version]:str:' \
                    '--git-user-id=+[git user id]:str:_users' \
                    '--git-repo-id=+[git repo id]:str:' \
                    '--git-host=+[git host]:host:_hosts' \
                    '--http-user-agent=+[http user agent]:str:' \
                    '--release-note=+[release notes]:str:' \
                    '--instantiation-types=+[instantiation types]:str:' \
                    '--language-specific-primitives=+[language specific primitives]:str:' \
                    '--library=+[library]:str:' \
                    '--system-properties=+[system properties]:str:' \
                    '--type-mappings=+[type mappings]:str:' \
                    '--additional-properties=+[additional properties]:str:' \
                    '--reserved-words-mappings=+[reserved words mappings]:str:' \
                    '--ignore-file-override=+[ignore file override]:file:_files' \
                    '--remove-operation-id-prefix[remove operation id prefix]' \
                    '--skip-overwrite[skip overwrite]' \
                    '-s[skip overwrite]' \
                    '--verbose[verbose]' \
                    '-v[verbose]' \
                    '--minimal-update[minimal update]' ;;
                config-help) _arguments \
                    '-l+[language]:str:' \
                    '--lang=+[language]:str:' \
                    '--markdown-header[markdown header]' \
                    '--format=+[format]:fmt:(text markdown json yaml)' \
                    '-o+[output file]:file:_files' \
                    '--output=+[output file]:file:_files' ;;
                meta) _arguments \
                    '-n+[name]:str:' \
                    '--name=+[name]:str:' \
                    '-p+[package]:str:' \
                    '--package=+[package]:str:' \
                    '-t+[template type]:t:(SERVER CLIENT DOCUMENTATION CONFIG OTHER)' \
                    '--type=+[template type]:t:(SERVER CLIENT DOCUMENTATION CONFIG OTHER)' \
                    '-o+[output dir]:dir:_files -/' ;;
                validate) _arguments \
                    '-i+[input spec]:file:_files' \
                    '--input-spec=+[input spec]:file:_files' ;;
            esac
            ;;
    esac
}

_swagger-codegen-cli "$@"
