#compdef argocd-vault-plugin

# Zsh completion for argocd-vault-plugin (Argo CD plugin for secrets from HashiCorp Vault and others)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:Generate manifests with secrets replaced'
  'version:Print version'
  'completion:Generate shell completion'
)

_arguments -s -S -C \
  '-h[Print help]' \
  '--help[Print help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'argocd-vault-plugin command' commands && ret=0
    ;;
  args)
    case $words[1] in
      generate)
        _arguments -s -S \
          '-s+[Auth secret name]:secret name' \
          '-c+[Config file path]:file:_files -g "*.{yaml,yml}"' \
          '--verbose-sensitive-output[Print sensitive output for debugging]' \
          ':path:_files -/' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
