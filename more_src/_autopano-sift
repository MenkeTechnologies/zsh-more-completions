#compdef autopano-sift autopano-sift-c

# autopano-sift: SIFT-based panorama control-point detector
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--maxmatches=[max matches per image]:n:' \
  '--projection=[projection model]:n:(0 1 2 3 4 5)' \
  '--ransac=[RANSAC iterations]:n:' \
  '--downscale[downscale large images]' \
  '*:output pto and image files:_files' && ret=0
return ret
