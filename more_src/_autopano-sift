#compdef autopano-sift

# autopano-sift / autopano-sift-c: SIFT control point detector for Hugin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--maxmatches[max matches per pair]:n:' \
  '--ransac[RANSAC iterations]:n:' \
  '--integer-coordinates[force integer feature coordinates]' \
  '--projection[expected projection]:type:(rectilinear panoramic stereographic equirectangular cylindrical fisheye)' \
  '-o[output file (.pto / .panos)]:file:_files' \
  '*:input images:_files -g "*.(jpg|jpeg|tif|tiff|png|pgm|ppm)"' && ret=0
return ret
