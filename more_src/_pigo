#
# THE pigo CLI
#
# pigo is a single-command CLI built on Go's standard
# `flag` package (NOT cobra/urfave/kong — bare-stdlib
# argv parsing).  Invocation:
#   pigo -in <input> -out <output> -cf <cascade> [flags]
#
# All flags use SINGLE-DASH convention per Go's `flag`
# package (e.g. `-in foo.jpg` or `-in=foo.jpg`, not
# `--in foo.jpg`).
#
# Required flags:
#   -in <path>                       source image file
#                                    (use "-" for stdin)
#   -out <path>                      destination image file
#                                    (use "-" for stdout)
#   -cf <path>                       cascade binary file
#                                    (typically cascade/facefinder)
#
# Optional flags:
#   -min <int>                       minimum face size (default 20)
#   -max <int>                       maximum face size (default 1000)
#   -shift <float>                   detection window shift
#                                    percentage (default 0.15)
#   -scale <float>                   detection window scale
#                                    percentage (default 1.15)
#   -angle <float>                   detection angle (0.0=0 rad,
#                                    1.0=2*pi rad; default 0.0)
#   -iou <float>                     Intersection-over-Union
#                                    threshold for non-max
#                                    suppression (default 0.15)
#   -marker <shape>                  detection marker shape:
#                                    rect|circle|ellipse
#                                    (default rect)
#   -plc <path>                      pupils/eyes localization
#                                    cascade file
#   -flpc <path>                     facial landmark points
#                                    cascade directory
#   -mark                            mark detected eyes
#                                    (default true)
#   -json <path>                     output detection points
#                                    to JSON file
#   -h, -help                        show help
#
# Common invocations:
#   # Basic face detection: input.jpg → output.png with rect markers
#   pigo -in input.jpg -out output.png -cf cascade/facefinder
#
#   # Constrain face size search (faster when range is known)
#   pigo -in input.jpg -out output.png -cf cascade/facefinder \
#     -min 80 -max 200
#
#   # Tighter IoU threshold for more dense detections
#   pigo -in crowd.jpg -out crowd-annotated.png \
#     -cf cascade/facefinder -iou 0.1
#
#   # Use ellipse marker instead of rectangle
#   pigo -in input.jpg -out output.png -cf cascade/facefinder \
#     -marker ellipse
#
#   # Full pipeline: face + eyes + facial landmarks
#   pigo -in input.jpg -out output.png \
#     -cf cascade/facefinder \
#     -plc cascade/puploc \
#     -flpc cascade/lps \
#     -mark
#
#   # JSON output for downstream pipeline consumption
#   pigo -in input.jpg -out /dev/null \
#     -cf cascade/facefinder \
#     -json detections.json
#
#   # Pipe through stdin/stdout
#   cat input.jpg | pigo -in - -out - -cf cascade/facefinder \
#     > output.png
#
#   # Detect rotated faces (rotated 45 degrees ≈ 0.125 of 2π)
#   pigo -in tilted.jpg -out tilted-out.png \
#     -cf cascade/facefinder -angle 0.125
#
#   # Tune shift + scale for performance vs accuracy
#   pigo -in input.jpg -out output.png \
#     -cf cascade/facefinder \
#     -shift 0.10 -scale 1.10
#
# OPTIONS (sourced directly from
# https://github.com/esimov/pigo/blob/master/cmd/pigo/main.go):
#
#   -in <path>                       source image (default "-")
#   -out <path>                      destination image (default "-")
#   -cf <path>                       cascade binary file
#   -min <int>                       minimum face size (default 20)
#   -max <int>                       maximum face size (default 1000)
#   -shift <float>                   shift detection window by % (default 0.15)
#   -scale <float>                   scale detection window by % (default 1.15)
#   -angle <float>                   detection angle 0..1 (default 0.0)
#   -iou <float>                     IoU threshold (default 0.15)
#   -marker <rect|circle|ellipse>    detection marker (default rect)
#   -plc <path>                      pupils localization cascade
#   -flpc <path>                     facial landmark cascade directory
#   -mark <bool>                     mark detected eyes (default true)
#   -json <path>                     output JSON detection points
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _pigo_markers
_pigo_markers=(
    'rect:rectangle marker (default; fastest to draw)'
    'circle:circle marker (decorative)'
    'ellipse:ellipse marker (approximates face outline)'
)

_arguments -C \
    '-in[source image file (use "-" for stdin)]:source image:_files -g "*.(jpg|jpeg|png|JPG|JPEG|PNG)"' \
    '-out[destination image file (use "-" for stdout)]:destination image:_files' \
    '-cf[cascade binary file]:cascade file:_files' \
    '-min[minimum face size in pixels (default 20)]:min size: ' \
    '-max[maximum face size in pixels (default 1000)]:max size: ' \
    '-shift[shift detection window by percentage (default 0.15)]:shift: ' \
    '-scale[scale detection window by percentage (default 1.15)]:scale: ' \
    '-angle[detection angle 0.0=0rad 1.0=2*pi rad (default 0.0)]:angle: ' \
    '-iou[Intersection-over-Union threshold (default 0.15)]:iou: ' \
    '-marker[detection marker shape]:shape:->marker' \
    '-plc[pupils/eyes localization cascade file]:puploc file:_files' \
    '-flpc[facial landmark points cascade directory]:flploc dir:_directories' \
    '-mark[mark detected eyes (default true)]' \
    '-json[output detection points to JSON file]:json file:_files -g "*.json"' \
    '(- *)'{-h,-help,--help}'[show help]' \
    && ret=0

case $state in
    marker)
        _describe -t markers 'detection marker shape' _pigo_markers && ret=0
        ;;
esac

return ret
