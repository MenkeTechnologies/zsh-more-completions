#compdef dkctl
# Documentation: man dkctl(8)
# Source: netbsd/src sbin/dkctl — disk wedge and disk property control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:disk device:_default' \
    '2::command:(addwedge badsector delwedge getcache getgeometry getwedgeinfo keeplabel listwedges makewedges setcache strategy synccache)' \
    '*::arg:_default' \
    && ret=0

return ret
