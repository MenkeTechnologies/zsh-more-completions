#compdef kubectl-kudo
# Documentation: https://kudo.dev/docs/cli/commands.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:initialize or upgrade the KUDO server and client'
      'install:install a KUDO package'
      'upgrade:upgrade a KUDO operator instance'
      'update:update installed operator instance parameters'
      'uninstall:uninstall an existing KUDO operator instance'
      'get:get information about installed instances/operators'
      'plan:view operator plans (history/status)'
      'package:interact with KUDO packages'
      'repo:manage KUDO package repositories'
      'diagnostics:collect and analyze diagnostics data'
      'version:print version'
    )
    _describe -t commands 'kubectl-kudo command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
