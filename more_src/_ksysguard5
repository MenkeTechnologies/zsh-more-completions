#compdef ksysguard5 ksysguard
# Documentation: https://github.com/KDE/ksysguard/blob/master/gui/ksysguard.cpp
# Reference accessed: 2026-05-16
# Verified: upstream KDE ksysguard.cpp main() - no app-specific
# options; only positional worksheet file argument.
# Removed from prior file: bogus man.archlinux.org search URL.

# ksysguard5/ksysguard: KDE5 system monitor (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '*:worksheet file:_files -g "*.sgrd(-.)"' && ret=0
return ret
