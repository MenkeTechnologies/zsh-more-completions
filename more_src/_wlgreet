#compdef wlgreet
# Documentation: https://git.sr.ht/~kennylevinsen/wlgreet
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for wlgreet (raw Wayland greeter for greetd)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[configuration file path]:config file:_files' \
  '--command=[default command to run after login]:command:_command_names' && ret=0

return ret
