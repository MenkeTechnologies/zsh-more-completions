#compdef streamsets-cli streamsets
# _streamsets-cli — StreamSets streamsets-cli CLI command-line frontend wrapping the StreamSets Data Collector Data Collector Engine pipeline-orchestration data-integration data-engineering platform managing pipelines runtime configuration deployment login authorize execute stop pause history libraries authentication-token JWT-API REST (StreamSets team, Python); click
# upstream: https://streamsets.com/

_streamsets-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'pipeline:pipeline management'
        'job:job management'
        'engine:engine management'
        'deployment:deployment management'
        'environment:environment management'
        'metric:metrics operations'
        'topology:topology operations'
        'manager:manager management'
        'connection:connection management'
        'fragment:fragment management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server-url=+[url]:str:' \
        '--user-id=+[id]:str:' \
        '--user-password=+[password]:str:' \
        '--api-token=+[token]:str:' \
        '--organization=+[id]:str:' \
        '--engine-id=+[id]:str:' \
        '--engine-type=+[t]:t:(COLLECTOR TRANSFORMER)' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml table csv)' \
        '--format=+[format]:f:(json yaml table csv)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'streamsets-cli subcommand' sub ;;
        args)
            case $words[1] in
                pipeline|job|engine|deployment|environment|topology|manager|connection|fragment) _arguments '1:op:(list get create update delete start stop pause resume reset rollback metric history publish import export draft)' '*:id:' ;;
            esac
            ;;
    esac
}

_streamsets-cli "$@"
