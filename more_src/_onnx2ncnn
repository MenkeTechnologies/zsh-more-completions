#compdef onnx2ncnn
# Documentation: https://github.com/Tencent/ncnn/wiki/use-ncnn-with-pytorch-or-onnx
# Convert an ONNX model to ncnn param/bin

local ret=1

_arguments -s -S \
  '1:onnx model:_files -g "*.onnx"' \
  '2:output ncnn param:_files -g "*.param"' \
  '3:output ncnn bin:_files -g "*.bin"' && ret=0

return ret
