#compdef rpmdev-packager
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-packager
# Reference accessed: 2026-05-16
# Verified: upstream rsrchboy/rpmdevtools. Minimal script - prints
# packager "Name <email>" from rpm macros / git config.
# Removed from prior file: bogus man.archlinux.org search URL.

# rpmdev-packager: print packager name+email from rpm macros / git config
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0
return ret
