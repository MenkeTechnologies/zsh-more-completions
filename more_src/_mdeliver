#compdef mdeliver
# Documentation: https://man.archlinux.org/search?q=mdeliver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[strstrp strstrpper character]' \
  '-M[strstrp strstrpper directory prefix]:directory:_files -/' \
  '-v[verbose output]' \
  '*:maildir:_files -/' && ret=0

return ret
