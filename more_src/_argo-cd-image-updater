#compdef argo-cd-image-updater argocd-image-updater
# Documentation: https://github.com/argoproj-labs/argocd-image-updater
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Argo CD Image Updater
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'run:run image updater'
  'test:test a specific image config'
  'template:apply Argo CD application template'
  'version:show version'
  'completion:emit shell completions'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--loglevel=[log level]:level:(panic fatal error warn info debug trace)' \
  '--logformat=[log format]:fmt:(text json)' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--argocd-server-addr=[Argo CD server addr]:host:' \
  '--argocd-insecure[insecure Argo CD]' \
  '--argocd-plaintext[Argo CD plaintext]' \
  '--argocd-grpc-web[force Argo CD gRPC-web]' \
  '--argocd-auth-token=[Argo CD auth token]:token:' \
  '--registries-conf-path=[registries config]:file:_files' \
  '--git-commit-user=[git commit user]:user:' \
  '--git-commit-email=[git commit email]:email:' \
  '--git-commit-message=[git commit message]:msg:' \
  '--once[run once and exit]' \
  '--interval=[run interval]:duration:' \
  '--max-concurrency=[max parallelism]:n:' \
  '--dry-run[do not write changes]' \
  '--health-port=[health probe port]:port:' \
  '--metrics-port=[metrics port]:port:' \
  '--match-application-name=[regex pattern]:pattern:' \
  '--application-namespaces=[namespaces]:namespaces:' \
  '--applications-api=[applications api]:api:(argocd kubernetes)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'argo-cd-image-updater command' commands && ret=0 ;;
esac
return ret
