#compdef ferretdb

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'run:start FerretDB server (default if omitted)'
      'version:print version'
    )
    _describe -t commands 'ferretdb command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '-mode=[backend mode]:mode:(normal proxy diff)' \
          '-listen-addr=[TCP listen address]:addr' \
          '-listen-unix=[Unix socket path]:path:_files' \
          '-state-dir=[state directory]:dir:_directories' \
          '-debug[enable debug logs]' \
          '--log-level=[log level]:level' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
