#compdef nostril
# Documentation: upstream nostril.c at github.com/jb55/nostril
# Reference accessed: 2026-05-30 via gh api inspection of every
# strcmp(arg, "..." ) branch.
# nostril R69 — Nostr event creator/signer CLI (Damus author jb55).
# C source single-binary CLI with 16 flags.

_arguments -s -S \
  '(- *)--help[show help]' \
  '--content=[text contents of the note]:text:' \
  '--dm=[create a direct message (kind-4 note) to recipient pubkey]:pubkey:' \
  '--envelope[wrap the event with ["EVENT", ...] for relay transmission]' \
  '--giftwrap-to=[wrap a note with giftwrap to a specific pubkey]:pubkey:' \
  '--kind=[event kind]:kind:' \
  '--created-at=[creation timestamp (default auto)]:timestamp:' \
  '--sec=[secret key for signing (default random)]:hex secret:' \
  '--mine-pubkey[mine a pubkey]' \
  '--pow=[leading 0 bits of proof-of-work to mine]:N:' \
  '--tag=[add a tag with a single value]:name value:' \
  '--tagn=[add a tag with zero or more elements]:name values:' \
  '--tags=[set all tags as a JSON array]:json:' \
  '*-t+[shorthand for --tag t VALUE (hashtag)]:hashtag:' \
  '*-p+[shorthand for --tag p VALUE (pubkey reference)]:pubkey:' \
  '*-e+[shorthand for --tag e VALUE (event reference)]:event id:'
