#compdef abiview
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/abiview.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS abiview: read ABI .ab1 file, display trace and extract base calls
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-fname=[ABI trace file]:file:_files -g "*.(ab1|abi)"' \
  '-startbase=[first base to display]:n:' \
  '-endbase=[last base to display]:n:' \
  '-yticks[show Y axis ticks]' \
  '-separate[separate ATGC traces]' \
  '-window=[smoothing window size]:n:' \
  '-bases=[bases to plot (one-letter codes)]:bases:' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outseq=[base-called sequence output]:file:_files' \
  '*:ABI file:_files -g "*.(ab1|abi)"' && ret=0
return ret
