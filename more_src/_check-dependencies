#compdef check-dependencies
# ============================================================================
#  _check-dependencies — check-dependencies: npm/bower dependency checker
#                       (Michał Gołębiowski-Owczarek)
#
#  Source-direct extraction from
#    https://github.com/mgol/check-dependencies/blob/master/bin/cli.js
#    https://nodejs.org/api/util.html#utilparseargsconfig (Node.js
#    built-in util.parseArgs documentation)
#
#  Maintained by Michał Gołębiowski-Owczarek / mgol (mgol/check-
#  dependencies).  118 GH stars.  check-dependencies is an npm
#  package that VERIFIES INSTALLED DEPENDENCIES match package.json /
#  bower.json declared versions — used in CI pipelines to fail builds
#  when node_modules is out-of-date with the lockfile.  Distinguishes
#  from `npm ls` by being PROGRAMMATIC + reportable + supporting
#  bower.json + scoped packages + optional dependencies + git URLs.
#  Sister tools: npm-check (in corpus via _npm-check), depcheck (IN
#  CORPUS via _depcheck), npm-check-updates (IN CORPUS via _npm-check-
#  updates), syncpack (in corpus), pnpm doctor (in corpus).
#
#  CLI library taxonomy update: 5th TypeScript-Node CLI library —
#  Node.js stdlib **util.parseArgs** module (built into Node 18.3+,
#  Bun, and Deno --compat).  TypeScript-Node ecosystem now has 5
#  documented CLI libraries (R340 oclif + R341 yargs + R343 tj/
#  commander.js + R393 meow + R395 node:util.parseArgs).
#
#  Node.js stdlib `util.parseArgs` (`node:util`) is the JavaScript
#  STANDARD LIBRARY argument parser — added in Node.js 18.3+ as a
#  zero-dependency built-in alternative to npm libraries like yargs/
#  commander/meow.  ECMAScript-shaped (similar to but smaller than
#  yargs/commander) with a schema-driven config object.  Works
#  natively in Node.js 18.3+, Bun (full compat), Deno (via `--compat`
#  flag), and Deno-with-Node-compat mode.  Used by Node.js's own CLI
#  tooling, Bun ecosystem tools (Bun supports node:util identical to
#  Node), kill-the-newsletter (Leandro Facchinetti's email-to-RSS
#  service, 3017 stars), facundoolano/feedi (personal feed reader,
#  942 stars), check-dependencies (118 stars), oasis-tcs/odata-openapi,
#  ccc-devtools (Cocos Creator devtools, 1237 stars), Express
#  generator, Microsoft react-native-test-app, AWS Amplify backend,
#  flowglad (uses Node's built-in `util.parseArgs` instead of manual
#  `process.argv` parsing), and many modern Node.js CLI tools that
#  want zero-dependency arg parsing.
#
#  node:util.parseArgs API:
#    const util = require('node:util');
#    // or: import { parseArgs } from 'node:util';
#
#    const { values, positionals, tokens } = util.parseArgs({
#      // Args to parse (default: process.argv.slice(2))
#      args: process.argv.slice(2),
#
#      // Options schema
#      options: {
#        verbose: {
#          type: 'boolean',
#          short: 'v',
#          default: false,
#        },
#        output: {
#          type: 'string',
#          short: 'o',
#          default: 'out.txt',
#        },
#        include: {
#          type: 'string',
#          short: 'I',
#          multiple: true,         // collects into array
#        },
#        port: {
#          type: 'string',
#          // node:util.parseArgs only supports 'string' or 'boolean';
#          // caller does numeric coercion via Number(...) or parseInt
#        },
#      },
#
#      // Allow positionals (default: false)
#      allowPositionals: true,
#
#      // Strict mode (default: true; throws on unknown options)
#      strict: true,
#
#      // Allow negation (--no-foo) for boolean flags (Node 20.4+)
#      allowNegative: true,
#
#      // Return raw tokens for advanced processing
#      tokens: true,
#    });
#
#    // values: { verbose: true, output: 'foo.txt', include: ['a', 'b'] }
#    // positionals: ['file1.txt', 'file2.txt']
#    // tokens: [{kind: 'option', name: 'verbose', ...}, ...]
#
#  node:util.parseArgs distinctive features:
#    - NODE.JS STDLIB — `require('node:util')` or `import {
#      parseArgs } from 'node:util'`; built-in since Node 18.3+; zero
#      external dependencies (vs yargs/commander/meow npm packages)
#    - WORKS IN BUN AND DENO — Bun has full Node compat including
#      `node:util.parseArgs`; Deno supports via `--compat` flag
#    - SCHEMA-DRIVEN — single options object with `args`/`options`/
#      `strict`/`allowPositionals`/`allowNegative`/`tokens` keys
#    - `options: { NAME: { type, short, default, multiple } }` —
#      per-option schema with limited types
#    - `type: 'string'` or `'boolean'` ONLY — node:util.parseArgs is
#      DELIBERATELY MINIMAL; no number/array/enum types (caller
#      coerces from string via `Number()` / `parseInt`)
#    - `short: 'X'` — single-char short alias (e.g. `-v` for verbose)
#    - `default: VALUE` — fallback value when flag not provided
#    - `multiple: true` — REPEATABLE flag (collects into array)
#    - `args: process.argv.slice(2)` — args to parse (default uses
#      process.argv); also accepts `Bun.argv.slice(2)` in Bun runtime
#    - `strict: true` (default) — THROWS on unknown options (set false
#      for forward-compat)
#    - `allowPositionals: true` (default false) — allow positional
#      args; positionals returned in `positionals` array
#    - `allowNegative: true` — allow `--no-FLAG` form for boolean
#      negation (added in Node 20.4+)
#    - `tokens: true` — return RAW TOKENS array for advanced
#      processing (each token has `kind`, `name`, `rawName`, `value`,
#      `index`, etc.)
#    - RESULT: `{ values, positionals, tokens? }` named-tuple object
#      with `values` (parsed flag values) + `positionals` (string
#      array of positional args) + optional `tokens` (raw token
#      array when `tokens: true`)
#    - NO automatic --help (caller writes help text manually; this is
#      the BIGGEST FRICTION vs yargs/commander)
#    - NO automatic --version (caller handles)
#    - NO subcommand support (caller hand-rolls subcommand dispatch)
#    - NO kebab-to-camel conversion (vs meow R393) — caller does this
#      manually (`mgol/check-dependencies` does this post-process)
#    - PROCESS EXIT model — caller controls via process.exit(N); errors
#      thrown as ERR_PARSE_ARGS_INVALID_OPTION_VALUE et al
#    - JS-NATIVE — no transpilation needed; works in plain JS (.js
#      and .mjs) and TypeScript
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework with plugin system + `@Command` class + `flags = {}`
#  static prop), R341 TypeScript-Node yargs (Node.js fluent builder
#  via `.option('name', {})` / `.command('cmd', desc, builder, handler)`
#  chains), R343 TypeScript-Node tj/commander.js (Node.js fluent
#  builder by TJ Holowaychuk via `.option('-o, --output <file>',
#  'Output')` / `.command('cmd <arg>')`), R393 TypeScript-Node meow
#  (Sindre Sorhus's CLI helper with usage-string-as-help-text + flags
#  schema + auto-help/version + kebab-to-camel conversion), R389 Deno
#  @std/cli/parse-args (Deno's stdlib parse-args — similar
#  philosophy but Deno-specific JSR distribution).  node:util.parseArgs'
#  approach: NODE.JS STDLIB (built-in since Node 18.3+, zero npm
#  deps) + SCHEMA-DRIVEN single options object (`args`/`options`/
#  `strict`/`allowPositionals`/`allowNegative`/`tokens` keys) +
#  LIMITED TYPES (string/boolean only; caller coerces) + `short: 'X'`/
#  `default: V`/`multiple: true` per-option schema + RESULT `{ values,
#  positionals, tokens? }` named-tuple + WORKS IN BUN AND DENO via
#  Node-compat + NO automatic --help/--version (caller writes) + NO
#  subcommand support (caller dispatches) + NO kebab-to-camel
#  conversion + PROCESS EXIT controlled by caller — corpus's **first
#  documented Node.js-stdlib-zero-dependency-built-in CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 134;
#  TypeScript-Node ecosystem now has 5 documented CLI libraries.
#
#  Surface (verbatim from `bin/cli.js` util.parseArgs schema):
#
#  Options:
#        --package-manager NAME     Package manager to use (npm/bower)
#        --package-dir DIR          Package directory path
#        --only-specified           Only check specified dependencies
#        --install                  Install missing/wrong-version deps
#        --scope-list NAME...       Dependency scopes to check
#                                   (REPEATABLE via multiple: true;
#                                    e.g. dependencies, devDependencies,
#                                    peerDependencies)
#        --optional-scope-list NAME... Optional scopes to also check
#                                   (REPEATABLE)
#        --check-git-urls           Check git/github URL dependencies
#        --verbose                  Verbose output (handled by CLI
#                                   wrapper, not passed to library)
#
#  Notes:
#    - kebab-case flags (`--package-manager`) are converted to camelCase
#      (`packageManager`) by the CLI wrapper after parseArgs returns
#      (node:util.parseArgs does NOT auto-camelCase; caller must do it)
#    - Multi-value flags `--scope-list a --scope-list b` collect into
#      array `['a', 'b']` via `multiple: true`
#    - The library's behavior is also configurable via .check-dependencies
#      file or package.json/bower.json field
#
#  Examples:
#    check-dependencies                          # check npm deps
#    check-dependencies --install                # auto-install missing
#    check-dependencies --package-manager=bower  # check bower deps
#    check-dependencies --scope-list=dependencies --scope-list=devDependencies
#    check-dependencies --check-git-urls --verbose
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also node:util.parseArgs users):
#    - kill-the-newsletter (leafac/kill-the-newsletter 3017 stars —
#      email-to-RSS service; uses node:util.parseArgs but minimal
#      2-flag surface, less of a showcase)
#    - feedi (facundoolano/feedi 942 stars — personal feed reader;
#      uses node:util.parseArgs but minimal 1-flag surface)
#    - cccdev (potato47/ccc-devtools 1237 stars — Cocos Creator
#      devtools; uses node:util.parseArgs)
#    - odata-openapi (oasis-tcs/odata-openapi 218 stars — OASIS
#      OData OpenAPI tools)
#    - express-generator (Node.js Express's project generator —
#      uses node:util.parseArgs)
#    - Microsoft react-native-test-app, AWS Amplify backend, flowglad
#      (use node:util.parseArgs but as internal build scripts)
# ============================================================================

_check-dependencies() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--package-manager=[package manager to use]:name:(npm bower)' \
    '--package-dir=[package directory path]:dir:_directories' \
    '--only-specified[only check specified dependencies]' \
    '--install[install missing or wrong-version deps]' \
    '*--scope-list=[dependency scope to check (repeatable)]:scope:(dependencies devDependencies peerDependencies optionalDependencies)' \
    '*--optional-scope-list=[optional dependency scope (repeatable)]:scope:(dependencies devDependencies peerDependencies optionalDependencies)' \
    '--check-git-urls[check git/github URL dependencies]' \
    '--verbose[verbose output]'
}

_check-dependencies "$@"
