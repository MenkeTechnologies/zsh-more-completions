#compdef searchd

_searchd() {
    local curcontext="$curcontext" ret=1

    _arguments \
        '(-c --config)'{-c,--config}'[configuration file path]:config file:_files' \
        '--stop[send SIGTERM to running searchd]' \
        '--stopwait[send SIGTERM and wait for shutdown]' \
        '--status[query running searchd status]' \
        '--pidfile[PID file path]:pid file:_files' \
        '--console[run in console (foreground) mode]' \
        '--logdebug[enable debug logging]' \
        '--logdebugv[enable verbose debug logging]' \
        '--logdebugvv[enable very verbose debug logging]' \
        '--logreplication[enable replication debug logging]' \
        '--new-cluster[bootstrap a new replication cluster]' \
        '--new-cluster-force[force bootstrap a new replication cluster]' \
        '(-p --port)'{-p,--port}'[listen on this port]:port:' \
        '(-l --listen)'{-l,--listen}'[listen on this address]:address:' \
        '--force-preread[force pre-reading of index files]' \
        '--coredump[enable core dumps]' \
        '--replay-flags[binary log replay flags]:flags:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' && ret=0

    return ret
}

_searchd "$@"
