#compdef palsave
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss136.html
# KAPPA: saves the current palette of a colour table to an NDF

local ret=1

_arguments -s \
  'DEVICE=[graphics device]:device' \
  'PALETTE=[output NDF to hold the palette]:ndf:_files -g "*.sdf"' \
  'TITLE=[title for the output NDF]:title' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
