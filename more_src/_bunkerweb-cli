#compdef bunkerweb-cli bunkerweb bwcli
# _bunkerweb-cli — bunkerity BunkerWeb bunkerweb-cli CLI command-line frontend wrapping the BunkerWeb open-source next generation web application firewall WAF written in Lua and Python based on NGINX provides automatic HTTPS via Let's-Encrypt blocks-malicious-requests-bot-detection-cookie-pre-check-bad-bot-network-anti-DDOS bunkerity-Linux-Docker-Kubernetes-Swarm-autoconf-Docker-autoconf-Kubernetes integrations CrowdSec ModSecurity-CRS plugins prometheus exposing-stats ban allow unban allowlist plugin watch reload restart status configure rate-limit anti-bot self-hosted (bunkerity team Florian Maury Bourcier, Lua/Python); custom argparse
# upstream: https://www.bunkerweb.io/

_bunkerweb-cli() {
    local -a sub=(
        'ban:ban an IP'
        'unban:unban an IP'
        'allow:add to allowlist'
        'plugin:plugin operations'
        'list-bans:list bans'
        'list-allow:list allow list'
        'reload:reload config'
        'restart:restart service'
        'status:show status'
        'configure:configure'
        'watch:watch logs'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '-c+[config file]:file:_files -g "variables.env *.env *.yml *.yaml"' \
        '--config=+[file]:file:_files -g "variables.env *.env *.yml *.yaml"' \
        '--integration=+[i]:i:(docker docker-autoconf swarm kubernetes linux autoconf)' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--server-name=+[name]:str:' \
        '--variable=+[k=v]:str:' \
        '*--variable=+[k=v]:str:' \
        '--ip=+[ip]:str:' \
        '-i+[ip]:str:' \
        '--ttl=+[sec]:n:' \
        '-t+[ttl]:n:' \
        '--reason=+[text]:str:' \
        '--service=+[name]:str:' \
        '-s+[service]:str:' \
        '--all[apply to all services]' \
        '--global[global]' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--method=+[name]:str:' \
        '--insecure[skip TLS verify]' \
        '-o+[output format]:f:(json yaml table text)' \
        '--output=+[fmt]:f:(json yaml table text)' \
        '--list-plugins[list plugins]' \
        '--enable=+[name]:str:' \
        '--disable=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bunkerweb subcommand' sub ;;
        args)
            case $words[1] in
                ban|unban|allow) _arguments '*:ip:' ;;
                plugin) _arguments '1:op:(list install uninstall enable disable update)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_bunkerweb-cli "$@"
