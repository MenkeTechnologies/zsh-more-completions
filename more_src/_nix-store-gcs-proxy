#compdef nix-store-gcs-proxy
# Documentation: https://github.com/tweag/nix-store-gcs-proxy
# HTTP Nix store that proxies reads and writes to Google Cloud Storage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--bucket-name=[name of the Google Storage bucket]:bucket:' \
  '--addr=[address for the proxy to listen on]:addr:' && ret=0

return ret
