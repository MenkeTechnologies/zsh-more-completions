#compdef thor-lite
# Documentation: https://thor-manual.nextron-systems.com/en/latest/usage/flags.html
# THOR Lite - Fast IOC and YARA scanner (Nextron Systems)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*--path[scan a specific file path (repeatable)]:path:_files -/' \
  '--quick[speed up scanning by disabling resource-intensive modules]' \
  '--intense[intense scan mode]' \
  '--soft[skip CPU/RAM intensive modules on constrained systems]' \
  '--lab[lab scan mode (file system only, forensic)]' \
  '--allhds[scan all local hard drives (Windows)]' \
  '--alldrives[scan all local drives including network drives]' \
  '--lookback[analyze this many past days]:days' \
  '--global-lookback[apply lookback to all supported modules]' \
  '--diff[only examine elements changed since last scan]' \
  '--cpulimit[pause actions when CPU usage exceeds threshold]:percent' \
  '--threads[run this amount of THOR threads in parallel]:count' \
  '--lowprio[reduce process priority]' \
  '--max-file-size[skip files exceeding this size]:bytes' \
  '--noprocs[skip process analysis]' \
  '--nofilesystem[skip filesystem scanning]' \
  '--noreg[skip registry analysis]' \
  '--noeventlog[skip event log analysis]' \
  '--noyara[disable YARA signature checks]' \
  '--logfile[log file for text output]:file:_files' \
  '--jsonfile[log file for JSON output]:file:_files' \
  '--csvfile[generate CSV with file hashes and scores]:file:_files' \
  '--htmlfile[log file for HTML output]:file:_files' \
  '--nolog[skip generating text/HTML reports]' \
  '--min[only report files with at least this score]:score' \
  '--silent[suppress command-line output]' \
  '--reduced[output only warnings, alerts and errors]' \
  '--syslog[write output to the specified syslog server]:server' \
  '--encrypt[encrypt generated log and CSV files]' \
  '--scan-id[assign unique identifier to scan run]:id' \
  '--template[process default scan parameters from this YAML file]:file:_files' \
  '*:path:_files' && ret=0

return ret
