#compdef s6-fdholder-retrieve
# _s6-fdholder-retrieve — s6 fdholder s6-fdholder-retrieve (fetch one stored fd from s6-fdholderd by id, then exec child with that fd on stdin; -D also deletes the holder entry after retrieval)
# upstream: https://github.com/skarnet/s6
# Flags from src/fdholder/s6-fdholder-retrieve.c on tip.

_s6-fdholder-retrieve() {
    _arguments \
        '-D[delete entry after retrieval]' \
        '-t+[timeout (ms)]:ms:' \
        '1:socket:_files' \
        '2:id:' \
        '*::program:_command_names -e'
}

_s6-fdholder-retrieve "$@"
