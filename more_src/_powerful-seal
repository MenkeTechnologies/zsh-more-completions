#compdef powerful-seal
# Documentation: https://powerfulseal.github.io/powerfulseal/
# PowerfulSeal: chaos engineering tool for Kubernetes clusters

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '--kubeconfig=[location of kube-config file]:file:_files' \
  '--execution-mode=[failure injection method]:mode:(kubernetes ssh)' \
  '--remote-user=[user for SSH connections]:user:_users' \
  '--ssh-allow-missing-host-keys[allow connection to hosts not in known_hosts]' \
  '--override-ssh-host=[execute all commands on a different host]:host:_hosts' \
  '--use-private-ip[use private IP instead of public IP for nodes]' \
  '--ssh-path-to-private-key=[path to SSH private key]:file:_files' \
  '--ssh-password=[SSH password]:password' \
  '--ssh-kill-command=[remote command to kill containers]:command' \
  '--openstack[use OpenStack cloud provider]' \
  '--aws[use AWS cloud provider]' \
  '--azure[use Azure cloud provider]' \
  '--gcp[use GCP cloud provider]' \
  '--no-cloud[do not use a cloud provider]' \
  '--inventory-file=[inventory file in INI format]:file:_files' \
  '--inventory-kubernetes[read Kubernetes cluster nodes as inventory]' \
  '--policy-file=[policy file to run]:file:_files' \
  '--prometheus-collector[store metrics in Prometheus]' \
  '--datadog-collector[send metrics to Datadog using DogStatsD]' \
  '--stdout-collector[print metrics to stdout]' \
  '--host=[web server host]:host:_hosts' \
  '--port=[web server port]:port' \
  '--headless[run policy without starting UI]' \
  '--accept-proxy-headers[accept X-Forwarded-* headers]' \
  '--kubernetes-namespace=[namespace for label mode operations]:namespace' \
  '--config=[config file path]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-s --silent)'{-s,--silent}'[silent logging]' \
  '(- *)'{-V,--version}'[display version information]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :_default' && ret=0

case $state in
  cmds)
    _values 'mode' \
      'interactive[start an interactive CLI with autocomplete]' \
      'autonomous[read the policy file and execute it]' \
      'label[kill pods based on their seal/* labels]' \
      'validate[validate a file against the policy schema]' \
      'version[display version information]' && ret=0
    ;;
esac

return ret
