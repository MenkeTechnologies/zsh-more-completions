#compdef home-manager

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f+[home configuration file]:config file:_files' \
  '-A+[override nix path attribute]:attribute' \
  '-I+[add nix expression search path]:path:_directories' \
  '-b+[backup file extension]:extension' \
  '--flake=[flake URI]:flake URI' \
  '-n[dry run]' \
  '--dry-run[dry run]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--show-trace[show nix trace on error]' \
  '--impure[allow impure expressions]' \
  '--keep-failed[keep failed build directory]' \
  '--keep-going[keep going on build failure]' \
  '--option=[set nix option]:option' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:build home configuration'
      'edit:open home configuration in editor'
      'expire-generations:remove old generations'
      'generations:list generations'
      'help:show help'
      'init:initialize home configuration'
      'news:show news entries'
      'option:inspect configuration option'
      'packages:list installed packages'
      'remove-generations:remove specific generations'
      'switch:build and activate configuration'
      'uninstall:remove Home Manager'
    )
    _describe -t commands 'home-manager command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build|switch)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--cores=[number of cores]:cores' \
          '--max-jobs=[max parallel jobs]:jobs' && ret=0
        ;;
      expire-generations)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:time spec' && ret=0
        ;;
      remove-generations)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:generation id' && ret=0
        ;;
      option)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:option name' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--switch[immediately activate after init]' \
          '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
