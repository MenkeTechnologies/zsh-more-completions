#compdef script_exporter
# Documentation: https://github.com/ricoberger/script_exporter
# Prometheus exporter that executes scripts and exposes their results

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show context-sensitive help]' \
  '--config.files=[configuration files (glob patterns allowed)]:files:_files' \
  '--config.reload-interval=[reload interval of the configuration file]:interval' \
  '--config.check[validate the configuration files and exit]' \
  '--log.env[log environment variables passed to a script]' \
  '--script.no-args[restrict scripts to accept no arguments]' \
  '--script.timeout-offset=[offset to subtract from timeout in seconds]:offset' \
  '--web.external-url=[URL under which Script Exporter is externally reachable]:url' \
  '--web.route-prefix=[prefix for internal routes of web endpoints]:prefix' \
  '--discovery.host=[host for service discovery]:host' \
  '--discovery.port=[port for service discovery]:port' \
  '--discovery.scheme=[scheme for service discovery]:scheme' \
  '--web.listen-address=[addresses on which to expose metrics and web interface]:addr' \
  '--web.config.file=[path to TLS/authentication config file]:file:_files' \
  '--log.level=[only log messages with given severity or above]:level' \
  '--log.format=[output format of log messages]:format:(logfmt json)' \
  '--version[show application version]' && ret=0

return ret
