#compdef cistopbm
# Documentation: man cistopbm (Netpbm)
# Source: convert a CompuServe RLE (CIS) image to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[invert black/white]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:cis file:_files' \
    && ret=0

return ret
