#compdef mri_ca_label
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_ca_label
# FreeSurfer label volume using a Gaussian classifier atlas

local ret=1

_arguments -s -S \
  '-cross-sequence[label volume from sequence different than atlas]' \
  '-nogibbs[disable gibbs priors]' \
  '-wm[use wm segmentation]:path:_files' \
  '-conform[interpolate volume to isotropic 1mm^3]' \
  '-topo_dist_thresh[relabel disconnected ventricle by distance]:dist:' \
  '-topo_volume_thresh1[ventricle volume threshold 1]:volume:' \
  '-topo_volume_thresh2[ventricle volume threshold 2]:volume:' \
  '-t1[use file to label thin temporal lobe]:gca_t1:_files' \
  '-normpd[normalize PD image to GCA means]' \
  '-debug_voxel[debug voxel x y z]:voxel:' \
  '-debug_node[debug node x y z]:node:' \
  '-debug_label[debug label]:n:' \
  '-tr[set TR in msec]:TR:' \
  '-te[set TE in msec]:TE:' \
  '-alpha[set alpha in radians]:ALPHA:' \
  '-example[use volume and segmentation as example]:mri_vol segmentation:' \
  '-pthresh[p threshold for adaptive renormalization (def .7)]:thresh:' \
  '-niter[max likelihood iterations (default 2)]:n:' \
  '-novar[do not use variance in classification]' \
  '-regularize[regularize variance]:reg:' \
  '-nohippo[do not auto-edit hippocampus]' \
  '-fwm[use fixed white matter segmentation]:mri_vol:_files' \
  '-mri[write most likely MR volume]:mri_vol:_files' \
  '-heq[use histogram equalization from volume]:mri_vol:_files' \
  '-renorm[renormalize using predicted intensity values]:mri_vol:_files' \
  '-flash[use FLASH forward model to predict intensity]' \
  '-flash_params[FLASH forward model with tissue parameters]:filename:_files' \
  '-renormalize[renorm class means iter times]:wsize iter:' \
  '-r[set input volume]:mri_vol:_files' \
  '-h[use GCA to histogram normalize input image]' \
  '-a[mean filter n times to conditional densities]:n:' \
  '-w[write snapshots of gibbs process every n]:n filename:' \
  '-m[use volume to mask final labeling]:mri_vol:_files' \
  '-e[expand]:n:' \
  '-n[set max iterations (default 200)]:n:' \
  '-f[filter labeled volume with threshold (def .5)]:f thresh:' \
  '-nowmsa[disable WMSA labels]' \
  '-write_probs[write label probabilities to file]:filename:_files' \
  '-L[longitudinal: tp1 label and LTA registration]:mri_vol LTA:' \
  '-RELABEL_UNLIKELY[reclassify outlier voxels]:args:' \
  '*:arg:_files' && ret=0

return ret
