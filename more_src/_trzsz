#compdef trzsz

# trzsz/trzsz-go — tmux-aware `trz`/`tsz` wrapper (`trzsz/trzsz.go` parseTrzszArgs)

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r)'{-r,--relay}'[run as trzsz relay server]' \
  '(-t)'{-t,--tracelog}'[enable trace log for debugging]' \
  '(-d)'{-d,--dragfile}'[enable drag file(s) to upload]' \
  '(-z)'{-z,--zmodem}'[enable zmodem lrzsz (rz/sz)]' \
  '(-o)'{-o,--osc52}'[enable clipboard integration (OSC52)]' \
  '*::command and arguments:_normal' && ret=0
return ret
