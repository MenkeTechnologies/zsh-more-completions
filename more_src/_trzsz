#compdef trzsz

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d[transfer directory]' \
  '-q[quiet mode, hide progress bar]' \
  '-y[overwrite existing files without confirmation]' \
  '-b[binary transfer mode]' \
  '-e[escape all control characters]' \
  '-B[buffer size in KB]:buffer size:' \
  '-t[timeout in seconds]:timeout:' \
  '*:file:_files' && ret=0

return ret
