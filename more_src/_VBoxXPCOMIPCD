#compdef VBoxXPCOMIPCD
# Documentation: https://man.archlinux.org/search?q=VBoxXPCOMIPCD
# Reference accessed: 2026-05-16

# VBoxXPCOMIPCD: VirtualBox XPCOM inter-process communication daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::VBoxXPCOMIPCD args:_files' && ret=0
return ret
