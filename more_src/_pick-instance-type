#compdef pick-instance-type
# Documentation: https://github.com/gruntwork-io/terratest/tree/master/cmd/pick-instance-type
# pick-instance-type - terratest helper to pick an EC2 instance type available in all AZs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:AWS region:' \
  '*:instance type:' && ret=0

return ret
