#compdef promptflow-cli pf
# Documentation: https://github.com/microsoft/promptflow/blob/main/docs/reference/pf-command-reference.md
# Reference accessed: 2026-05-21
# Verified: upstream pf command reference at the URL above.

# Zsh completion for promptflow-cli (pf) - Microsoft prompt engineering CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[enable debug output]' \
  '--verbose[verbose output]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'pf command' \
      'flow[manage prompt flows]' \
      'connection[manage connections]' \
      'run[manage flow runs]' \
      'tool[manage flow tools]' \
      'config[manage CLI configuration]' \
      'service[manage prompt flow service]' \
      'upgrade[upgrade CLI]' \
      'trace[manage traces]' && ret=0
    ;;
  args)
    case $line[1] in
      flow)
        _values 'flow subcmd' init test validate build serve && ret=0
        ;;
      connection)
        _values 'connection subcmd' create update show list delete && ret=0
        ;;
      run)
        _values 'run subcmd' \
          create update stream list show show-details show-metrics visualize archive restore && ret=0
        ;;
      tool)
        _values 'tool subcmd' init list validate && ret=0
        ;;
      config)
        _values 'config subcmd' set show && ret=0
        ;;
      service)
        _values 'service subcmd' start stop status && ret=0
        ;;
      trace)
        _values 'trace subcmd' delete && ret=0
        ;;
    esac
    ;;
esac

return ret
