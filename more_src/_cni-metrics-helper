#compdef cni-metrics-helper
# _cni-metrics-helper — AWS VPC CNI metrics helper (publishes CNI metrics to CloudWatch and/or a Prometheus endpoint)
# upstream: https://github.com/aws/amazon-vpc-cni-k8s
# Flags from cmd/cni-metrics-helper/main.go on tip; runtime config via env vars USE_CLOUDWATCH, USE_PROMETHEUS, METRIC_UPDATE_INTERVAL.

_cni-metrics-helper() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cloudwatch=[publish metrics to CloudWatch]:bool:(true false)' \
        '--prometheus[expose Prometheus metrics on port 61681]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_cni-metrics-helper "$@"
