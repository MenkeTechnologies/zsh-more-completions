#compdef typos
# Documentation: https://github.com/crate-ci/typos
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: -e+ as "file extension to check" (real -e is
# --exclude); --no-check-files (not in upstream docs); --no-unicode
# (not in upstream docs); --color=ansi (only auto/always/never).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file]:config:_files -g "*.toml"' \
  '--isolated[ignore implicit config files]' \
  '(-w --write-changes)'{-w,--write-changes}'[fix typos]' \
  '--diff[print diff of fixes]' \
  '--format=[output format]:format:(brief long json)' \
  '(-j --threads)'{-j+,--threads=}'[number of threads]:threads' \
  '--force-exclude[force exclusion patterns]' \
  '--hidden[check hidden files and directories]' \
  '--no-check-filenames[skip checking filenames]' \
  '--locale=[locale]:locale:(en en-us en-gb en-au en-ca)' \
  '*'{-e+,--exclude=}'[files to exclude]:pattern' \
  '*'{-t+,--type=}'[file type to check]:type' \
  '--type-list[list supported file types]' \
  '--files[print files that would be checked]' \
  '--identifiers[print identifiers]' \
  '--words[print words]' \
  '--color=[color output]:mode:(auto always never)' \
  '--dump-config=[dump effective config]:file:_files' \
  '*:path:_files' && ret=0

return ret
