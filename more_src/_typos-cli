#compdef typos

# Zsh completion for typos-cli - source code spell checker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[configuration file]:config:_files -g "*.toml"' \
  '--config=[configuration file]:config:_files -g "*.toml"' \
  '--isolated[ignore implicit config files]' \
  '-w[fix typos]' \
  '--write-changes[fix typos]' \
  '--diff[print diff of fixes]' \
  '--format=[output format]:format:(brief long json)' \
  '-j+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '--force-exclude[force exclusion patterns]' \
  '--hidden[check hidden files and directories]' \
  '--no-check-filenames[skip checking filenames]' \
  '--no-check-files[skip checking file contents]' \
  '--no-unicode[disable Unicode support]' \
  '--locale=[locale]:locale:(en en-us en-gb en-au en-ca)' \
  '-e+[file extension to check]:extension' \
  '--type=[file type to check]:type' \
  '--type-list[list supported file types]' \
  '--exclude=[files to exclude]:pattern' \
  '--color=[color output]:mode:(auto always never ansi)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--dump-config=[dump effective config]:format:(current default long-help)' \
  '*:path:_files' && ret=0

return ret
