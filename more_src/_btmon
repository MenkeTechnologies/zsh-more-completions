#compdef btmon
# _btmon — BlueZ btmon (HCI traffic monitor: reads mgmt monitor socket and decodes packets in real time or from a btsnoop file; -i hciX device filter, -r read btsnoop file, -w write btsnoop file, -t time format, -j JSON output, --no-color)
# upstream: https://github.com/bluez/bluez (monitor/main.c)
# Flags from bluez monitor/main.c on tip.

_btmon() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[hciX device]:device:' \
        '-r+[read btsnoop file]:file:_files' \
        '-w+[write btsnoop file]:file:_files' \
        '-t+[time format]:format:(default time delta absolute)' \
        '-T[absolute time]' \
        '-d+[devices file]:file:_files' \
        '-D+[serial dump file]:file:_files' \
        '-A[show address types]' \
        '-F+[index filter]:filter:' \
        '-I[filter by index]' \
        '-S+[script file]:file:_files' \
        '-E+[ELL events]:events:' \
        '-J[JSON output]' \
        '-Y[Y2K compliance]' \
        '-M[monitor only]' \
        '-n[do not pause output]' \
        '--no-color[disable color]'
}

_btmon "$@"
