#compdef scss-lint
# Documentation: https://github.com/sds/scss-lint
# configurable tool for writing clean and consistent SCSS

local ret=1

_arguments -s -S \
  '(-c --config)'{-c+,--config=}'[configuration file to use]:config:_files' \
  '(-e --exclude)'{-e+,--exclude=}'[exclude one or more files from linting]:pattern' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(Default CleanFiles Config Files JSON TAP Stats)' \
  '(-o --out)'{-o+,--out=}'[write output to a file]:file:_files' \
  '(-r --require)'{-r+,--require=}'[require a file/library]:library:_files' \
  '(-i --include-linter)'{-i+,--include-linter=}'[run only the specified linters]:linters' \
  '(-x --exclude-linter)'{-x+,--exclude-linter=}'[do not run the specified linters]:linters' \
  '--stdin-file-path=[treat STDIN as having the given path]:path' \
  '--[no-]color[whether to output in color]' \
  '--show-formatters[show all available formatters]' \
  '--show-linters[show all available linters]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:SCSS file:_files' && ret=0

return ret
