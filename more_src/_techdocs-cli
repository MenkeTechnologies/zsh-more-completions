#compdef techdocs-cli
# Documentation: https://github.com/backstage/techdocs-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1: : _default' \
  '*::args: _default'
