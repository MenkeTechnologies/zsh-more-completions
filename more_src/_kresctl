#compdef kresctl
# Documentation: https://man.archlinux.org/search?q=kresctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:read or modify configuration'
  'cache:control cache operations'
  'metrics:show prometheus metrics'
  'reload:reload configuration without restart'
  'schema:dump the JSON schema of the configuration'
  'stop:stop the resolver'
  'validate:validate a configuration file'
  'convert:convert configuration to new format'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '-c+[configuration file]:file:_files' \
  '-s+[socket path]:socket:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kresctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '1:op:(get set delete)' \
          '*:path:' && ret=0 ;;
      (cache)
        _arguments \
          '1:op:(clear)' && ret=0 ;;
      (validate)
        _arguments \
          '1:file:_files' && ret=0 ;;
      (convert)
        _arguments \
          '1:src:_files' \
          '2:dest:_files' && ret=0 ;;
    esac ;;
esac

return ret
