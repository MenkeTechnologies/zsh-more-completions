#compdef kresctl
# Documentation: https://knot.pages.nic.cz/knot-resolver/manager-client.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above. Removed undocumented
# -V and the fake `help` subcommand; -h/-s/-c are the only global
# options. config has get/set/delete/migrate subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:read or modify configuration'
  'cache:control cache operations'
  'metrics:show prometheus metrics'
  'reload:reload configuration without restart'
  'schema:dump the JSON schema of the configuration'
  'stop:stop the resolver'
  'validate:validate a configuration file'
  'convert:transform declarative configuration into a Lua script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[path to declarative configuration file]:file:_files' \
  '(-s --socket)'{-s+,--socket=}'[management API socket or network interface]:socket:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kresctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '1:op:(get set delete migrate)' \
          '*:path:' && ret=0 ;;
      (cache)
        _arguments \
          '1:op:(clear)' && ret=0 ;;
      (validate)
        _arguments \
          '1:file:_files' && ret=0 ;;
      (convert)
        _arguments \
          '1:src:_files' \
          '2:dest:_files' && ret=0 ;;
    esac ;;
esac

return ret
