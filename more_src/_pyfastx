#compdef pyfastx
# Documentation: https://github.com/lmdu/pyfastx
# pyfastx: fast random access to FASTA/Q files via subcommands

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'pyfastx command' \
      'index[build index for FASTA/Q file]' \
      'stat[show detailed statistics information]' \
      'split[split FASTA/Q file into multiple files]' \
      'fq2fa[convert FASTQ file to FASTA file]' \
      'subseq[get subsequences from FASTA file by region]' \
      'sample[randomly sample sequences from FASTA/Q file]' \
      'extract[extract sequences from FASTA/Q file by name]' && ret=0
    ;;
  args)
    case $line[1] in
      index)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --full)'{-f,--full}'[build full index with base composition calculation]' \
          '*:fastx file:_files' && ret=0
        ;;
      stat)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          ':fastx file:_files' && ret=0
        ;;
      split)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n+[split into N files with even size]:count' \
          '-c+[split into files with same sequence counts]:count' \
          '(-o --out-dir)'{-o,--out-dir}'+[output directory]:dir:_files -/' \
          ':fastx file:_files' && ret=0
        ;;
      fq2fa)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --out-file)'{-o,--out-file}'+[output file (default stdout)]:file:_files' \
          ':fastx file:_files' && ret=0
        ;;
      subseq)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-r --region-file)'{-r,--region-file}'+[tab-delimited region file (1-based)]:file:_files' \
          '(-b --bed-file)'{-b,--bed-file}'+[BED format file (0-based start, 1-based end)]:file:_files' \
          '(-o --out-file)'{-o,--out-file}'+[output file (default stdout)]:file:_files' \
          ':fastx file:_files' \
          '*:region:' && ret=0
        ;;
      sample)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n+[number of sequences to sample]:count' \
          '-p+[proportion to sample (0-1)]:proportion' \
          '(-s --seed)'{-s,--seed}'+[random seed]:seed' \
          '--sequential-read[use sequential reading for large samples]' \
          '(-o --out-file)'{-o,--out-file}'+[output file (default stdout)]:file:_files' \
          ':fastx file:_files' && ret=0
        ;;
      extract)
        _arguments -s \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-l --list-file)'{-l,--list-file}'+[file containing names (one per line)]:file:_files' \
          '--reverse-complement[output reverse complement]' \
          '--out-fasta[convert FASTQ to FASTA format]' \
          '--sequential-read[use sequential reading for large extractions]' \
          '(-o --out-file)'{-o,--out-file}'+[output file (default stdout)]:file:_files' \
          ':fastx file:_files' \
          '*:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
