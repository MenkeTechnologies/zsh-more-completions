#compdef cwltest
# Documentation: https://cwltest.readthedocs.io/en/latest/
# cwltest: conformance test runner for CWL (Common Workflow Language) implementations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--test=[YAML file describing test cases]:test file:_files -g "*.(yml|yaml)"' \
  '--basedir=[basedir to use for tests]:dir:_files -/' \
  '--baseuri=[base URI to use links in the report]:uri' \
  '-l[list tests then exit]' \
  '-n+[run specific tests, format is 1,3-6,9]:tests' \
  '-s+[run specific tests by short names, comma separated]:names' \
  '-N+[exclude specific tests by number, format is 1,3-6,9]:tests' \
  '-S+[exclude specific tests by short names, comma separated]:names' \
  '--tool=[CWL runner executable to use (default cwl-runner)]:runner:_command_names -e' \
  '--only-tools[only test CommandLineTools]' \
  '--tags=[tags to be tested]:tags' \
  '--exclude-tags=[tags not to be tested]:tags' \
  '--show-tags[show all tags]' \
  '--junit-xml=[path to JUnit xml file]:file:_files' \
  '--junit-verbose[store more verbose output to JUnit XML file]' \
  '--test-arg=[additional argument and required prefix for tool runner]:arg' \
  '-j+[number of tests to run simultaneously]:count' \
  '--verbose[more verbose output during test run]' \
  '--classname=[specify classname for the test suite]:classname' \
  '--timeout=[seconds after which a test is skipped (default 600)]:seconds' \
  '--badgedir=[create JSON badges, one for each tag]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
