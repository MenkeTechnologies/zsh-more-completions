#compdef docuum

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '(-t --threshold)'{-t,--threshold}'[Maximum amount of disk space to use]:threshold:' \
  '(-k --keep)'{-k,--keep}'[Minimum age to keep images]:duration:' \
  '--deletion-chunk-size=[Number of images to delete at a time]:count:' \
  '(-d --debug)'{-d,--debug}'[Enable debug logging]' && return 0
