#compdef MapIcosahedron
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/MapIcosahedron.html
# Create standard-mesh surfaces via icosahedron mapping

local ret=1

_arguments -s \
  '-spec[spec file of original-mesh surfaces]:spec file:_files' \
  '-rd[recursive tessellation depth]:depth' \
  '-ld[linear tessellation edge divides]:depth' \
  '-morph[spherical surface to inflate to]:surface' \
  '-it[number of smoothing iterations]:num' \
  '-prefix[output file prefix]:prefix' \
  '-NN_dset_map[map dataset, nearest neighbor]:dataset:_files' \
  '-dset_map[map dataset, barycentric]:dataset:_files' \
  '-sphere_at_origin[center morphSurf sphere at 0 0 0]' \
  '-sphere_center[geometric center cx cy cz]:center' \
  '-sphere_radius[sphere radius]:radius' \
  '-use_com[use center of mass as center]' \
  '-morph_sphere_check[quality check morphSurf and exit]' \
  '-all_surfs_spec[include all surfaces in output spec]' \
  '-fix_cut_surfaces[fix cross-cut connections]' \
  '-check_cut_surfaces[check surfaces with cuts]' \
  '-forget_cut_surface[skip cut checking]' \
  '-write_nodemap[write node mapping file]' \
  '-no_nodemap[disable nodemap output]' \
  '-write_dist[write distortion vectors]:prefix' \
  '-verb[verbose output]' \
  '-help[display help]' && ret=0

return ret
