#compdef snscrape

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-n,--max-results}'[maximum number of results]:count:' \
  '--since[only return results since date]:date (YYYY-MM-DD):' \
  {-f,--format}'[output format string]:format:' \
  '--jsonl[output as JSON Lines]' \
  '--with-entity[include full entity in JSON output]' \
  '--progress[show progress bar]' \
  {-v,--verbose}'[increase verbosity]' \
  '--retry[number of retries]:count:' \
  '--proxy[proxy URL]:url:' \
  '1: :->scraper' \
  '*::arg:->args' && ret=0

case $state in
  scraper)
    local -a scrapers=(
      'twitter-search:search Twitter'
      'twitter-user:scrape a Twitter user timeline'
      'twitter-hashtag:scrape a Twitter hashtag'
      'twitter-cashtag:scrape a Twitter cashtag'
      'twitter-profile:scrape a Twitter user profile'
      'twitter-list-posts:scrape a Twitter list'
      'twitter-trend:scrape Twitter trends'
      'reddit-search:search Reddit'
      'reddit-subreddit:scrape a subreddit'
      'reddit-user:scrape a Reddit user'
      'instagram-user:scrape an Instagram user'
      'instagram-hashtag:scrape an Instagram hashtag'
      'instagram-location:scrape an Instagram location'
      'facebook-user:scrape a Facebook user'
      'facebook-group:scrape a Facebook group'
      'facebook-community:scrape a Facebook community'
      'facebook-page:scrape a Facebook page'
      'youtube-channel:scrape a YouTube channel'
      'youtube-search:search YouTube'
      'vkontakte-user:scrape a VKontakte user'
      'telegram-channel:scrape a Telegram channel'
      'mastodon-user:scrape a Mastodon user'
      'mastodon-hashtag:scrape a Mastodon hashtag'
    )
    _describe -t scrapers 'scraper' scrapers && ret=0
    ;;
  args)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '*:query:' && ret=0
    ;;
esac

return ret
