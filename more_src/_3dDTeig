#compdef 3dDTeig
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDTeig.html
# AFNI: compute eigenvalues/eigenvectors and FA from a diffusion tensor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-prefix[output dataset prefix]:pname:_files' \
  '-datum[output data type]:type:(byte short float)' \
  '-sep_dsets[write output as separate datasets]' \
  '-uddata[input tensor is in upper-diagonal order]' \
  '*:dataset:_files' && ret=0

return ret
