#compdef idris

# Zsh completion for idris - a functional dependently typed programming language

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '--check[type check only]' \
  '--quiet[quiet output]' \
  '--nocolour[disable colour output]' \
  '(-i --ibcsubdir)'{-i,--ibcsubdir}'[write IBC files to dir]:dir:_directories' \
  '-p[import package]:package' \
  '--package[import package]:package' \
  '--idrispath[show the Idris lib path]' \
  '--libdir[show the Idris library directory]' \
  '--docdir[show the Idris doc directory]' \
  '--pkgdir[show the Idris package directory]' \
  '--pkg[build package description]:file:_files -g "*.ipkg"' \
  '--pkg-check[type check package]:file:_files -g "*.ipkg"' \
  '--pkg-clean[clean package]:file:_files -g "*.ipkg"' \
  '--pkg-repl[run REPL on package]:file:_files -g "*.ipkg"' \
  '--mkdoc[generate IdrisDoc from package]:file:_files -g "*.ipkg"' \
  '--codegen[select code generation backend]:backend:(C javascript node)' \
  '--cg-opt[option for the code generator]:option' \
  '--total[check totality]' \
  '--warnpartial[warn on unused partial functions]' \
  '--warnreach[warn about reachability issues]' \
  '--log[set logging level]:level' \
  '--nobasepkgs[do not load base packages]' \
  '--noprelude[do not load prelude]' \
  '--nobuiltins[do not load built-ins]' \
  '--port[REPL port]:port' \
  '--client[send command to background Idris]:command' \
  '--interface[show module interface]:module' \
  '*:file:_files -g "*.(idr|lidr|ipkg)"' && ret=0

return ret
