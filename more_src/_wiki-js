#compdef wiki wiki-js wikijs
# _wiki-js — requarks wiki.js modern Node-based open-source wiki CLI managing setup database migrations user import LDAP sync analytics with Postgres MySQL MariaDB MSSQL backends (requarks team, JavaScript); commander.js
# upstream: https://github.com/requarks/wiki

_wiki-js() {
    local -a sub=(
        'start:start wiki server'
        'stop:stop wiki server'
        'restart:restart wiki server'
        'setup:run setup wizard'
        'reset-password:reset administrator password'
        'reset-2fa:reset two-factor auth'
        'reload-config:reload config'
        'upgrade:upgrade wiki'
        'rebuild-search:rebuild search index'
        'migrate-db:run database migrations'
        'export-html:export HTML dump'
        'export-markdown:export Markdown dump'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '-c+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '--cwd=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wiki-js subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--ssl[enable SSL]' \
                    '--ssl-port=+[port]:n:' ;;
                reset-password) _arguments \
                    '--email=+[email]:str:' \
                    '--password=+[password]:str:' ;;
                export-html|export-markdown) _arguments \
                    '--output=+[dir]:dir:_files -/' \
                    '--locale=+[locale]:str:' \
                    '--include-attachments[include attachments]' ;;
                migrate-db) _arguments \
                    '--direction=+[d]:d:(up down latest rollback)' \
                    '--to-version=+[v]:str:' ;;
            esac
            ;;
    esac
}

_wiki-js "$@"
