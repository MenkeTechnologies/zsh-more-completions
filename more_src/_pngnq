#compdef pngnq
# Documentation: https://manpages.debian.org/bookworm/pngnq/pngnq.1.en.html
# Reference accessed: 2026-05-30
# pngnq — Stuart Coyle's PNG quantizer (NeuQuant-based palette reducer).
# Maps full-color PNG to 8-bit palette PNG for smaller file size; Floyd-
# Steinberg dithering optional. Output filename gets `-nq8.png` suffix by
# default.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version + library versions]' \
  '-v[verbose: print status messages]' \
  '-f[force overwrite existing output files]' \
  '-s+[NeuQuant sample factor (default 3; higher = faster, less accurate)]:factor:' \
  '-n+[target palette colors (2..256, default 256)]:colors:' \
  '-Q+[dither method (n = none default, f = Floyd-Steinberg)]:method:(n f)' \
  '-g+[image gamma correction (default: read from PNG, fall back 1.0)]:gamma:' \
  '-e+[output filename suffix (default `-nq8.png`)]:suffix:' \
  '-d+[output directory (default: alongside input)]:dir:_files -/' \
  '*:input PNG (stdin if omitted):_files -g "*.png"' \
  && ret=0

return ret
