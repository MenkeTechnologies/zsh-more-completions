#compdef palread
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss135.html
# KAPPA: fills the palette of a colour table from an NDF

local ret=1

_arguments -s \
  'DEVICE=[graphics device]:device' \
  'PALETTE=[NDF holding the palette data]:ndf:_files -g "*.sdf"' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
