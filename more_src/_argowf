#compdef argowf argo-workflows
# _argowf — Argo Project argowf workflow engine CLI for the Kubernetes-native workflow engine submitting suspending resuming listing logging workflows DAG step CronWorkflow ClusterWorkflowTemplate artifact passing with optional GraphQL Hera Conditions (argoproj team, Go); cobra
# upstream: https://github.com/argoproj/argo-workflows

_argowf() {
    local -a sub=(
        'submit:submit new workflow'
        'list:list workflows'
        'get:get workflow info'
        'logs:show workflow logs'
        'delete:delete workflow'
        'retry:retry workflow'
        'resubmit:resubmit workflow'
        'suspend:suspend workflow'
        'resume:resume workflow'
        'stop:stop workflow'
        'terminate:terminate workflow'
        'wait:wait for workflow'
        'watch:watch workflow'
        'lint:lint workflow yaml'
        'cron:cron workflow operations'
        'template:workflow template operations'
        'clusterworkflowtemplate:cluster workflow template'
        'archive:archived workflow operations'
        'auth:auth operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
        'server:run argo server'
        'token:show service account token'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[namespace]:str:' \
        '--namespace=+[namespace]:str:' \
        '-A[all namespaces]' \
        '--all-namespaces[all namespaces]' \
        '--context=+[ctx]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--server=+[url]:str:' \
        '-s+[url]:str:' \
        '--secure=+[b]:b:(true false)' \
        '--insecure-skip-verify[skip TLS verify]' \
        '-k+[bearer token]:str:' \
        '--token=+[bearer token]:str:' \
        '--instanceid=+[id]:str:' \
        '--gloglevel=+[level]:n:' \
        '--logtostderr=+[b]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argowf subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments \
                    '--from=+[r]:r:(workflowtemplate cwf cronwf workflow)' \
                    '--watch[watch]' \
                    '--wait[wait]' \
                    '-w[wait]' \
                    '--log[show logs]' \
                    '-l[show logs]' \
                    '--name=+[name]:str:' \
                    '--generate-name=+[prefix]:str:' \
                    '--entrypoint=+[name]:str:' \
                    '--parameter=+[K=V]:str:' \
                    '-p+[K=V]:str:' \
                    '--parameter-file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
                    '--service-account=+[name]:str:' \
                    '--labels=+[csv]:str:' \
                    '--node-field-selector=+[selector]:str:' \
                    '*:workflow file:_files -g "*.yaml *.yml"' ;;
                logs) _arguments \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--container=+[name]:str:' \
                    '-c+[name]:str:' \
                    '--podselector=+[selector]:str:' \
                    '--no-color[no color]' \
                    '*:workflow:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argowf "$@"
