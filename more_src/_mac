#compdef mac
# Documentation: https://github.com/fernandotcl/monkeys-audio/blob/master/man/mac.1
# Reference accessed: 2026-05-16
# Verified: upstream fernandotcl/monkeys-audio mac(1) manpage. Quality
# levels are 1000/2000/3000/4000/5000.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# mac: Monkey's Audio encoder/decoder (APE codec)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-c[encode WAVE input at quality]:quality:(1000 2000 3000 4000 5000)' \
  '-d[decode input to WAVE]' \
  '-n[recompress encoded input at quality]:quality:(1000 2000 3000 4000 5000)' \
  '-v[verify input for data corruption]' \
  '*:audio file:_files -g "*.(ape|wav)(-.)"' && ret=0
return ret
