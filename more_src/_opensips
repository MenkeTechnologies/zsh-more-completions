#compdef opensips
# Documentation: https://github.com/OpenSIPS/opensips/blob/master/main.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version and compile information]' \
  '-D[enable full debug mode]' \
  '-E[log to stderr]' \
  '-F[do not daemonize (run in foreground)]' \
  '-f+[main config file]:file:_files -g "*.cfg"' \
  '-C[check config with extended validation]' \
  '-c[check config and exit]' \
  '-l+[add listening socket address]:addr:' \
  '-n+[number of UDP worker processes]:n:' \
  '-N+[number of TCP worker processes]:n:' \
  '-T[enable testing framework mode]' \
  '-w+[working directory]:dir:_files -/' \
  '-u+[user]:user:_users' \
  '-g+[group]:group:_groups' \
  '-P+[PID file]:file:_files' \
  '-G+[PGID file]:file:_files' \
  '-p+[preprocessor command]:cmd:' \
  '-A+[global address]:addr:' \
  '-b+[max receive buffer]:n:' \
  '-m+[shared memory size MB]:mb:' \
  '-M+[package memory size MB]:mb:' \
  '-i[disable module revision checking]' \
  '-v[enable Via header checking]' \
  '-r[enable DNS resolution for received field]' \
  '-R[enable reverse DNS lookup]' \
  '-W+[poll method]:method:(epoll poll select kqueue)' \
  '-o+[add argument variable]:var:' \
  '-d[increase debug logging level]' \
  '-t+[chroot directory]:dir:_files -/' \
  '*::passthrough:' && ret=0

return ret
