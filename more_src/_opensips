#compdef opensips

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-D[fork and daemonize]' \
  '-E[log to stderr]' \
  '-F[do not daemonize]' \
  '-f+[main config file]:file:_files -g "*.cfg"' \
  '-C[check config and exit]' \
  '-c[check config but stop after parse]' \
  '-l+[listen address]:addr:' \
  '*-n+[number of worker processes]:n:' \
  '-N+[per-listener children]:n:' \
  '-T[disable TCP]' \
  '-w+[working directory]:dir:_files -/' \
  '-u+[user]:user:_users' \
  '-g+[group]:group:_groups' \
  '-P+[PID file]:file:_files' \
  '-p+[pre-cache script]:script:_files' \
  '-A+[set ID]:id:' \
  '-b+[max receive buffer]:n:' \
  '-x+[debug level]:n:' \
  '-X[detailed memory debug]' \
  '-v[show config and exit]' \
  '-d+[debug level]:n:' \
  '-O+[script optimizer]:n:(0 1 2)' \
  '*::passthrough:' && ret=0

return ret
