#compdef kubeaudit
# Documentation: https://github.com/Shopify/kubeaudit/blob/main/cmd/commands/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to local Kubernetes config file]:config file:_files' \
  '(-c --context)'{-c+,--context=}'[name of the kubeconfig context to use]:context:' \
  '(-m --minseverity)'{-m+,--minseverity=}'[lowest severity level to report]:severity:(error warning info)' \
  '(-p --format)'{-p+,--format=}'[output format to use]:format:(sarif pretty logrus json)' \
  '(-n --namespace)'{-n+,--namespace=}'[only audit resources in the specified namespace]:namespace:' \
  '(-g --includegenerated)'{-g,--includegenerated}'[include generated resources in scan]' \
  '--no-color[do not produce colored output]' \
  '(-f --manifest)'{-f+,--manifest=}'[path to the yaml configuration to audit]:file:_files' \
  '(-e --exitcode)'{-e+,--exitcode=}'[exit code to use if there are error results]:code:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'all:run all available auditors'
      'apparmor:detect missing AppArmor annotations'
      'asat:identify auto-mounted default service account tokens'
      'capabilities:audit container capabilities'
      'deprecatedapis:find deprecated API versions'
      'hostns:detect HostPID, HostIPC and HostNetwork usage'
      'image:validate image tags and versions'
      'limits:check CPU and memory limits'
      'mounts:identify sensitive host path mounts'
      'netpols:verify default-deny network policies'
      'nonroot:find containers running as root'
      'privesc:detect privilege escalation'
      'privileged:find privileged containers'
      'rootfs:check read-only root filesystem'
      'seccomp:detect missing Seccomp profiles'
      'autofix:automatically fix security issues'
      'version:print current version'
    )
    _describe -t commands 'kubeaudit command' commands && ret=0
    ;;
  args)
    case $line[1] in
      autofix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --outfile)'{-o+,--outfile=}'[file to write fixed manifest to]:file:_files' \
          '(-k --kconfig)'{-k+,--kconfig=}'[path to kubeaudit config]:file:_files' && ret=0
        ;;
      image)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-i --image)'{-i+,--image=}'[image to check against]:image:' && ret=0
        ;;
    esac
    ;;
esac

return ret
