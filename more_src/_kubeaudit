#compdef kubeaudit

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[kubeconfig file]:config file:_files' \
  '--kubeconfig=[kubeconfig file]:config file:_files' \
  '--context=[kubeconfig context]:context:' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '-A[audit all namespaces]' \
  '--all-namespaces[audit all namespaces]' \
  '-f+[audit manifest file]:file:_files' \
  '--manifest=[audit manifest file]:file:_files' \
  '-d+[audit directory of manifests]:directory:_directories' \
  '-p+[output format]:format:(logrus json)' \
  '--format=[output format]:format:(logrus json)' \
  '--minseverity=[minimum severity]:severity:(error warning info)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'all:run all auditors'
      'apparmor:audit AppArmor annotations'
      'asat:audit automounting of service account tokens'
      'caps:audit container capabilities'
      'deprecatedapis:audit deprecated API versions'
      'hostns:audit host namespace usage'
      'image:audit container images'
      'limits:audit resource limits'
      'mounts:audit mount paths'
      'netpols:audit network policies'
      'nonroot:audit running as root'
      'privesc:audit privilege escalation'
      'privileged:audit privileged containers'
      'rootfs:audit read-only root filesystem'
      'seccomp:audit Seccomp profiles'
      'autofix:auto-fix security issues'
      'version:show version'
      'completion:generate shell completion'
    )
    _describe -t commands 'kubeaudit command' commands && ret=0
    ;;
  args)
    case $line[1] in
      autofix)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output file]:output file:_files' \
          '--output=[output file]:output file:_files' && ret=0
        ;;
      image)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--image=[expected image]:image:' \
          '--no-tag[audit images without tags]' \
          '--no-local[audit images from local registries]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
