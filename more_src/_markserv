#compdef markserv

local -a arguments

arguments=(
  '(-p --port)'{-p,--port}'=[port to serve on]:port:'
  '(-h --host)'{-h,--host}'=[host to bind to]:host:'
  '(-b --browser)'{-b,--browser}'[open browser after starting]'
  '--livereload[enable live reload]'
  '--no-browser[do not open browser]'
  '--silent[suppress output]'
  '--verbose[verbose output]'
  '--help[show help]'
  '--version[show version]'
  '1:directory:_files -/'
)

_arguments -s -S $arguments
