#compdef markserv
# Documentation: https://github.com/markserv/markserv
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-p+[change HTTP port]:port:'
  '-a+[server address for external network access]:address:'
  '--theme=[theme name]:theme:(light dark synthwave solarized)'
  '--light[use light theme]'
  '--synthwave[use synthwave theme]'
  '--solarized[use solarized theme]'
  '--templates[enable just-in-time templating]'
  '--no-hotreload[disable hot-reload]'
  '--help[show help]'
  '1:directory or file:_files'
)

_arguments -s -S $arguments
