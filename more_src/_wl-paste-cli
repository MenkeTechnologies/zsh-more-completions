#compdef wl-paste
# _wl-paste-cli — wl-clipboard paste (Sergey Bugaev); Wayland selection read, pbpaste equivalent
# upstream: https://github.com/bugaevc/wl-clipboard

_wl-paste-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-p --primary)'{-p,--primary}'[use primary selection]' \
        '(-n --no-newline)'{-n,--no-newline}'[no trailing newline]' \
        '(-l --list-types)'{-l,--list-types}'[list types in offer]' \
        '(-t --type)'{-t,--type}'+[mime type]:type:' \
        '(-w --watch)'{-w,--watch}'+[run on each selection]:cmd:_command_names -e' \
        '(-s --seat)'{-s,--seat}'+[wayland seat]:seat:'
}

_wl-paste-cli "$@"
