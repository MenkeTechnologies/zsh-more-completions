#compdef cargo-benchcmp
# Documentation: https://man.archlinux.org/search?q=cargo-benchcmp
# Reference accessed: 2026-05-16

# https://github.com/BurntSushi/cargo-benchcmp — compare criterion bench outputs

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '--include-missing[print benchmarks missing from either side]' \
  '--threshold=[only show changes above percent threshold]:percent:' \
  '--variance[include timing variance columns]' \
  '--improvements[only improvements]' \
  '--regressions[only regressions]' \
  '--color=[row coloring]:when:(never always auto)' \
  '1:first_input:(file benchmark_prefix)' \
  '2:second_input:(file benchmark_prefix)' \
  '3:optional_single_file:_files' && return 0
