#compdef fprcp
# Documentation: fprcp (Free Pascal)
# Source: extract FPC constants from resource scripts (preprocessor).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input file]:file:_files' \
    '-n[disable Pascal comments nesting]' \
    '-C[output as C header instead of preprocessed script]' \
    '-l+[programming language for include files]:language:(PASCAL C)' \
    '-p+[path to include files]:path:_files -/' \
    '1:resource file:_files' \
    && ret=0

return ret
