#compdef ntpd-cli
# _ntpd-cli — NTP Project ntpd Network Time Protocol daemon CLI alias (ntp team, C); custom argparse
# upstream: https://github.com/ntp-project/ntp

_ntpd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-a[require authentication]' \
        '-A[do not require authentication]' \
        '-b[broadcast client]' \
        '-c+[config file]:file:_files -g "ntp.conf"' \
        '--configfile=+[config file]:file:_files -g "ntp.conf"' \
        '-d[debug]' \
        '--debug-level[debug]' \
        '-D+[debug level]:n:' \
        '--set-debug-level=+[debug level]:n:' \
        '-e+[authentication delay]:n:' \
        '-f+[drift file]:file:_files' \
        '--driftfile=+[drift file]:file:_files' \
        '-g[allow large clock step]' \
        '--panicgate[allow large clock step]' \
        '-i+[jail dir]:dir:_files -/' \
        '--jaildir=+[jail dir]:dir:_files -/' \
        '-I+[interface]:_net_interfaces' \
        '--interface=+[interface]:_net_interfaces' \
        '-k+[keys file]:file:_files' \
        '--keyfile=+[keys file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-L[do not listen to virtual addresses]' \
        '-n[do not fork]' \
        '--nofork[do not fork]' \
        '-N[high priority]' \
        '--nice[high priority]' \
        '-p+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '-P+[priority]:n:' \
        '--priority=+[priority]:n:' \
        '-q[exit after time correction]' \
        '--quit[exit after time correction]' \
        '-r+[broadcast delay seconds]:str:' \
        '--propagationdelay=+[broadcast delay]:str:' \
        '-s+[stats dir]:dir:_files -/' \
        '--statsdir=+[stats dir]:dir:_files -/' \
        '-S+[stepsignal command]:str:' \
        '-t+[trusted key id]:n:' \
        '--trustedkey=+[trusted key id]:n:' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-U+[force allow upgrades]:n:' \
        '--updateinterval=+[update interval]:n:' \
        '-w+[wait sync]:str:' \
        '--waitsync=+[wait sync]:str:' \
        '-x[slew clock]' \
        '--slew[slew clock]' \
        '-z[do not exit on time set if not in panicgate]' \
        '*:arg:'
}

_ntpd-cli "$@"
