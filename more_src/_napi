#compdef napi
# _napi — napi-rs CLI for building Node.js native addons in Rust (napi-rs/napi-rs)
# upstream: https://github.com/napi-rs/napi-rs
# Subcommands from cli/src/cli.ts + commands/*.ts (clipanion).

_napi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_napi_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                new)
                    _arguments \
                        '--name=[project name]:name:' \
                        '--license=[license]:license:' \
                        '--enable-github-actions[generate GitHub Actions workflow]' \
                        '--enable-default-target=[enable a default Cargo target]:bool:(true false)'
                    ;;
                build)
                    _arguments \
                        '--target=[Rust target triple]:triple:' \
                        '(-p --platform)'{-p,--platform}'[append platform info to filename]' \
                        '--js=[output JS bindings file]:file:_files' \
                        '--dts=[output .d.ts bindings file]:file:_files' \
                        '--cargo-name=[override Cargo package name]:name:' \
                        '--release[build in release mode]' \
                        '--cargo-flags=[extra cargo flags]:flags:'
                    ;;
                version)
                    _arguments \
                        '--prefix=[npm scope prefix]:scope:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_napi_commands] )) ||
_napi_commands() {
    local -a commands
    commands=(
        'new:scaffold a new napi-rs project'
        'build:build the native addon and JS bindings'
        'create-npm-dirs:create per-platform npm package dirs'
        'artifacts:collect built artifacts into per-platform dirs'
        'universalize:combine per-arch macOS binaries into a universal one'
        'rename:rename the project / package name'
        'pre-publish:perform pre-publish steps (sync version, etc.)'
        'version:bump and sync per-platform package versions'
        'cli-version:print the napi CLI version'
        'help:show help for a command'
    )
    _describe -t commands 'napi command' commands
}

_napi "$@"
