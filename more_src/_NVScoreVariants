#compdef NVScoreVariants
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/vqsr/NVScoreVariants.java
# Annotate a VCF with scores from a PyTorch-based Convolutional Neural Network (CNN)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Output VCF file]:value:_files' \
  '(--variant -V)'{--variant,-V}'[Input VCF file containing variants to score]:value:_files' \
  '(--reference -R)'{--reference,-R}'[Reference sequence file]:value:_files' \
  '(--input -I)'{--input,-I}'[BAM file containing reads, if using the 2D model]:value:_files' \
  '--tensor-type=[Name of the tensors to generate\: reference for 1D reference tensors and read_tensor fo...]:value:' \
  '--batch-size=[Batch size]:value:' \
  '--random-seed=[Seed to initialize the random number generator]:value:' \
  '--tmp-file=[The temporary VCF-like file where variants scores will be written]:value:_files' \
  '--accelerator=[Type of hardware accelerator to use (auto, cpu, cuda, mps, tpu, etc)]:value:' \
  '*:argument:_files' && ret=0

return ret
