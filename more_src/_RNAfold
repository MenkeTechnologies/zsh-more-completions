#compdef RNAfold
# Documentation: https://man.archlinux.org/search?q=RNAfold
# Reference accessed: 2026-05-16

# ViennaRNA RNAfold: predict secondary structure of RNA sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--verbose[verbose output]' \
  '--temp=[folding temperature in C]:temp:' \
  '(-p --partfunc)'{-p,--partfunc}'[compute partition function and base-pair probs]' \
  '(-p0)-p0[compute pf without producing bracket structure]' \
  '(-MEA --MEA)'{-MEA,--MEA}'[compute maximum expected accuracy structure]:gamma:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling-end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[fold as a circular RNA]' \
  '(-G --gquad)'{-G,--gquad}'[allow G-quadruplex formation]' \
  '--noLP[disallow lonely (unstacked) pairs]' \
  '--noGU[disallow GU pairs]' \
  '--noClosingGU[disallow GU pairs at helix ends]' \
  '--paramFile=[free-energy parameter file]:file:_files' \
  '--nsp=[non-standard base pair list]:pairs:' \
  '--energyModel=[energy model]:em:(0 1 2)' \
  '(-S --pfScale)'{-S,--pfScale=}'[pf scaling factor]:factor:' \
  '(-T --bppmThreshold)'{-T,--bppmThreshold=}'[bpp threshold for plot]:thresh:' \
  '(-o --outfile)'{-o,--outfile=}'[output file prefix]:prefix:' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '--commands=[command file]:file:_files' \
  '--noPS[suppress PostScript plot output]' \
  '(-a --auto-id)'{-a,--auto-id}'[auto-generate sequence IDs]' \
  '--id-prefix=[ID prefix]:prefix:' \
  '--id-start=[first ID number]:n:' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
