#compdef multus multus-cni multusctl
# _multus — Kubernetes Network Plumbing Working Group multus CLI Multus CNI multi-network plugin and command-line manager for Kubernetes pods enabling attaching multiple network interfaces SR-IOV Macvlan ipvlan host-device bridge with NetworkAttachmentDefinition NAD CRD CNI delegate-plugin chained for KubeVirt Telco-CNF use cases (NPWG team, Go); cobra
# upstream: https://github.com/k8snetworkplumbingwg/multus-cni

_multus() {
    local -a sub=(
        'install:install multus into cluster'
        'uninstall:remove multus from cluster'
        'list:list NetworkAttachmentDefinitions'
        'get:get a NAD'
        'create:create a NAD'
        'delete:delete a NAD'
        'attach:attach networks to a pod'
        'detach:detach networks from a pod'
        'verify:verify multus installation'
        'show:show running pod interfaces'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '--cni-conf-dir=+[dir]:dir:_files -/' \
        '--cni-bin-dir=+[dir]:dir:_files -/' \
        '--multus-conf-file=+[file]:file:_files' \
        '--multus-log-level=+[l]:l:(panic error warning info debug verbose)' \
        '--multus-log-file=+[file]:file:_files' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'multus subcommand' sub ;;
        args)
            case $words[1] in
                list|verify|show) ;;
                get|delete) _arguments '*:nad name:' ;;
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--type=+[t]:t:(macvlan bridge ipvlan host-device sriov bond ptp)' \
                    '--master=+[interface]:_net_interfaces' \
                    '--cidr=+[cidr]:str:' \
                    '--gateway=+[ip]:_hosts' ;;
                attach|detach) _arguments '*:pod and network:' ;;
            esac
            ;;
    esac
}

_multus "$@"
