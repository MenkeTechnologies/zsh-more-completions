#compdef cds
# Documentation: https://cap.cloud.sap/
# Reference accessed: 2026-05-23
# Verified: npx @sap/cds-dk --help.

# Zsh completion for cds - SAP Cloud Application Programming Model CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:jump-start cds-based projects'
  'i:alias for init'
  'add:add a feature to an existing project'
  'a:alias for add'
  'import:add models from external sources'
  'm:alias for import'
  'compile:compile cds models'
  'c:alias for compile'
  'parse:parse cds models'
  'p:alias for parse'
  'serve:run services in local server'
  's:alias for serve'
  'watch:run and restart on file changes'
  'w:alias for watch'
  'mock:serve with mocked services'
  'repl:read-eval-print loop'
  'env:inspect effective configuration'
  'e:alias for env'
  'build:prepare for deployment'
  'b:alias for build'
  'deploy:deploy to databases'
  'd:alias for deploy'
  'up:build and deploy to the cloud'
  'bind:bind application to remote services'
  'y:alias for bind'
  'debug:debug the application'
  'subscribe:subscribe tenant to multitenant SaaS app'
  'unsubscribe:unsubscribe tenant from multitenant SaaS app'
  'login:login to extensible multitenant SaaS app'
  'l:alias for login'
  'logout:logout from extensible multitenant SaaS app'
  'pull:pull base model of extensible SaaS app'
  'push:push extension to extensible SaaS app'
  'lint:run linter for env or model checks'
  'version:detailed version information'
  'v:alias for version'
  'completion:manage shell completion'
  'help:detailed usage information'
  'h:alias for help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cds command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
