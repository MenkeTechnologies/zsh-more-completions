#compdef labwc-tweaks

# labwc-tweaks: GUI to tweak labwc Wayland compositor settings
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*::labwc-tweaks args:_files' && ret=0
return ret
