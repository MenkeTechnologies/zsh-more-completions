#compdef fits
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/fits.html
# MIRIAD fits - convert between Miriad and FITS formats

local ret=1

_arguments -s -S \
  'in=[input file (FITS or Miriad)]:in:_files' \
  'op=[operation uvin/uvout/xyin/xyout/print]:op:(uvin uvout xyin xyout print)' \
  'out=[output file (Miriad or FITS)]:out:_files' \
  'line=[output line type for op=uvout]:line' \
  'region=[region of interest for op=xyout]:region' \
  'select=[uv selection for op=uvout]:select' \
  'stokes=[Stokes selection for op=uvout]:stokes' \
  'velocity=[velocity info for op=uvin velsys,refval,refchan]:velocity' \
  'options=[compress,nochi,lefty,varwt,blcal,nofq,nocal,nopol,nopass,topo,rawdss,nod2]:options' \
  '*:file:_files' && ret=0

return ret
