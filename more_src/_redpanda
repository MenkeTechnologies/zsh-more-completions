#compdef rpk

# Zsh completion for Redpanda CLI (rpk)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'acl:manage ACLs'
  'cloud:manage Redpanda Cloud'
  'cluster:manage a Redpanda cluster'
  'container:manage a local Redpanda container'
  'debug:debug tools'
  'generate:generate configurations and scripts'
  'group:manage consumer groups'
  'help:show help'
  'iotune:measure filesystem performance'
  'plugin:manage rpk plugins'
  'profile:manage rpk profiles'
  'redpanda:manage a Redpanda node'
  'registry:manage schema registry'
  'topic:manage topics'
  'transform:manage data transforms'
  'version:show version'
)

_arguments -s -S \
  '--brokers=[comma-separated list of broker addresses]:brokers:' \
  '--config=[config file]:file:_files -g "*.{yaml,yml}"' \
  '--tls-cert=[TLS certificate]:file:_files' \
  '--tls-key=[TLS key]:file:_files' \
  '--tls-truststore=[TLS truststore]:file:_files' \
  '--sasl-mechanism=[SASL mechanism]:mechanism:(SCRAM-SHA-256 SCRAM-SHA-512)' \
  '--user=[SASL username]:user:' \
  '--password=[SASL password]:password:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'rpk command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      topic)
        local -a topic_cmds=(
          'add-partitions:add partitions to a topic'
          'alter-config:alter topic configuration'
          'consume:consume records from a topic'
          'create:create a topic'
          'delete:delete a topic'
          'describe:describe a topic'
          'list:list topics'
          'produce:produce records to a topic'
          'trim-prefix:trim records from beginning of partitions'
        )
        _describe -t commands 'topic command' topic_cmds && ret=0
        ;;
      group)
        local -a group_cmds=(
          'delete:delete a consumer group'
          'describe:describe a consumer group'
          'list:list consumer groups'
          'offset-delete:delete committed offsets'
          'seek:set consumer group offsets'
        )
        _describe -t commands 'group command' group_cmds && ret=0
        ;;
      cluster)
        local -a cluster_cmds=(
          'config:manage cluster configuration'
          'health:check cluster health'
          'info:show cluster info'
          'license:manage cluster license'
          'logdirs:manage cluster log directories'
          'maintenance:manage maintenance mode'
          'metadata:show cluster metadata'
          'partitions:manage cluster partitions'
          'self-test:run cluster self-test'
          'storage:manage cluster storage'
        )
        _describe -t commands 'cluster command' cluster_cmds && ret=0
        ;;
      container)
        local -a container_cmds=(
          'purge:remove a container cluster'
          'start:start a container cluster'
          'status:show container cluster status'
          'stop:stop a container cluster'
        )
        _describe -t commands 'container command' container_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
