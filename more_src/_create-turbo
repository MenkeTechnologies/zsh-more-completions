#compdef create-turbo
# Documentation: https://www.npmjs.com/package/create-turbo
# Reference accessed: 2026-05-23
# Verified: npx create-turbo --help.

# Zsh completion for create-turbo - scaffold a new Turborepo monorepo

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --package-manager)'{-m,--package-manager=}'[package manager]:manager:(npm yarn pnpm bun)' \
  '--skip-install[skip package manager install after create]' \
  '--skip-transforms[skip post-create code transforms]' \
  '--turbo-version=[turbo version to use]:version:' \
  '(-e --example)'{-e,--example=}'[example name or GitHub URL]:example:' \
  '(-p --example-path)'{-p,--example-path=}'[path within example repo]:path:' \
  '--no-git[skip git repository initialization]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':project directory:_directories' && ret=0

return ret
