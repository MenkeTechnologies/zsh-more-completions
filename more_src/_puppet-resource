#compdef puppet-resource
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/resource.md
# puppet resource - interactively retrieve and modify resource state via RAL

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this help message]' \
  '(-d --debug)'{-d,--debug}'[enable full debugging]' \
  '(-v --verbose)'{-v,--verbose}'[print extra information]' \
  '(-e --edit)'{-e,--edit}'[edit query results as a manifest]' \
  '(-p --param)'{-p,--param}'+[add parameters to output]:param:' \
  '(-t --types)'{-t,--types}'[list all available types]' \
  '(-y --to_yaml)'{-y,--to_yaml}'[output resources in yaml format]' \
  '--fail[fail with exit 1 if resource not modified]' \
  '*:resource type:' && ret=0

return ret
