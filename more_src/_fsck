#compdef fsck
# _fsck — OpenBSD fsck (run filesystem-specific checkers from fstab(5) or argv; -p preen mode (rc reboot path), -y/-n yes/no to all, -f forces clean filesystems, -l caps parallel checks, -T per-fstype option overrides)
# upstream: https://github.com/openbsd/src (sbin/fsck)
# Flags from sbin/fsck/fsck.8 on tip.

_fsck() {
    _arguments \
        '-d[debug]' \
        '-f[force check even if clean]' \
        '-N[no-op (do not write changes)]' \
        '-n[answer no to all questions]' \
        '-p[preen mode]' \
        '-v[verbose]' \
        '-y[answer yes to all questions]' \
        '-b+[alternate superblock block#]:block:' \
        '-l+[max parallel checks]:n:' \
        '*-T+[fstype:fsoptions]:fstype:fsoptions:' \
        '-t+[fstype]:fstype:(ffs ext2fs msdos ntfs cd9660 udf vnd)' \
        '*:special or node:_files'
}

_fsck "$@"
