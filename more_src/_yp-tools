#compdef yp-tools yppasswd ypchsh ypchfn ypwhich ypcat ypmatch yppoll ypset
# _yp-tools — Thorsten Kukuk yp-tools collection of NIS Yellow Pages client utilities including yppasswd ypchsh ypchfn ypwhich ypcat ypmatch yppoll ypset for managing NIS+ domains map lookups password changes shell-info changes (kukuk team, C); getopt
# upstream: https://github.com/thkukuk/yp-tools

_yp-tools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '-h+[host]:h:_hosts' \
        '--host=+[host]:h:_hosts' \
        '-m+[map]:m:(passwd.byname passwd.byuid group.byname group.bygid hosts.byname hosts.byaddr networks.byname networks.byaddr services.byname services.byport protocols.byname protocols.bynumber rpc.byname rpc.bynumber netgroup.byhost netgroup.byuser ethers.byname ethers.byaddr mail.aliases bootparams netid.byname netmasks.byaddr publickey.byname services.bynumber)' \
        '-k+[key]:str:' \
        '--key=+[key]:str:' \
        '-l[show name]' \
        '--shell[change shell]' \
        '--gecos[change gecos]' \
        '-s+[server]:h:_hosts' \
        '--server=+[server]:h:_hosts' \
        '-t[do not look up nicknames]' \
        '--no-nicknames[do not look up nicknames]' \
        '-x[list nickname translations]' \
        '*:user or map:'
}

_yp-tools "$@"
