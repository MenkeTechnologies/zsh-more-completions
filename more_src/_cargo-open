#compdef cargo-open
# open an installed crate in your editor

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --manifest-path)'{-m,--manifest-path}'[use a specific manifest file]:file:_files -g "*.toml"' \
  '(-p --print-path)'{-p,--print-path}'[print the crate directory]' \
  '1:crate:' && ret=0

return ret
