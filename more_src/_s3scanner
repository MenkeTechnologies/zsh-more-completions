#compdef s3scanner
# Documentation: https://github.com/sa7mon/S3Scanner
# Scan for open cloud storage buckets across providers.

local ret=1

_arguments -s -S \
  '-bucket[name of bucket to check]:bucket' \
  '-bucket-file[file of bucket names to check]:file:_files' \
  '-mq[connect to RabbitMQ to get buckets]' \
  '-db[save results to a Postgres database]' \
  '-json[print logs to stdout in JSON format]' \
  '-enumerate[enumerate bucket objects (time-consuming)]' \
  '-provider[object storage provider (default aws)]:provider:(aws custom digitalocean dreamhost gcp linode scaleway)' \
  '-threads[number of threads to scan with (default 4)]:threads' \
  '-verbose[enable verbose logging]' \
  '-version[print version]' && ret=0

return ret
