#compdef hxtdead
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/hxtdead.txt
# Corrects a HEXTE spectral or light curve FITS file for detector dead time

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'coefficients_file=[calibration file with dead-time coefficients]:cal file:_files' \
  'rates_file=[file containing status apid values]:rates file:_files' \
  'science_file=[file containing events list/archive data]:science file:_files' \
  'file_to_correct=[spectral or light curve file to modify]:file:_files' \
  'chatter=[verbosity level]:level:' \
  'detectors=[detector list, - for all]:detectors:' \
  '*:file:_files' && ret=0

return ret
