#compdef dotgit
# Documentation: https://github.com/kobus-v-schoor/dotgit
# dotgit - a comprehensive solution to managing your dotfiles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '--dry-run[do not actually execute any file operations]' \
  '--hard[use hard links instead of symlinks]' \
  '1:action:(init update restore clean diff commit passwd)' \
  '*:category:' && ret=0

return ret
