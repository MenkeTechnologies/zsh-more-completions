#compdef snapper
# Documentation: https://manpages.debian.org/testing/snapper/snapper.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list-configs:list configurations'
  'create-config:create configuration'
  'modify-config:modify configuration'
  'delete-config:delete configuration'
  'get-config:show config values'
  'set-config:set config values'
  'create:create new snapshot'
  'modify:modify snapshot'
  'delete:delete snapshot'
  'list:list snapshots'
  'cleanup:run cleanup algorithm'
  'mount:mount snapshot'
  'umount:unmount snapshot'
  'rollback:rollback to snapshot'
  'undochange:undo change'
  'diff:show diff between snapshots'
  'status:show changes between snapshots'
  'xadiff:show xadiff'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-c+[config name]:c:' \
  '*--config=[config name]:c:' \
  '*--no-dbus[no dbus]' \
  '*--root=[root path]:dir:_files -/' \
  '*--ambit=[ambit]:a:' \
  '*--csvout[csv output]' \
  '*--quiet[quiet]' \
  '*--verbose[verbose]' \
  '*--utc[UTC times]' \
  '*--iso[ISO format]' \
  '*--no-headers[no headers]' \
  '*--separator=[separator]:s:' \
  '*--columns=[columns csv]:list:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'snapper command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '(-t --type)'{-t+,--type=}'[type]:t:(single pre post)' \
          '(--pre-number)--pre-number=[pre number]:n:' \
          '(-c --cleanup-algorithm)'{-c+,--cleanup-algorithm=}'[algo]:a:(number timeline empty-pre-post)' \
          '(-d --description)'{-d+,--description=}'[description]:d:' \
          '(-p --print-number)'{-p,--print-number}'[print number]' \
          '(--read-only)--read-only[read only]' \
          '(--read-write)--read-write[read write]' \
          '(--from)--from=[from snapshot]:n:' \
          '(--userdata)--userdata=[k=v]:v:' \
          '(--command)--command=[command]:c:' \
          '*: :' && ret=0 ;;
      (delete)
        _arguments \
          '--sync[sync after]' \
          '*: :' && ret=0 ;;
      (list)
        _arguments \
          '(-a --all-configs)'{-a,--all-configs}'[all configs]' \
          '(-t --type)'{-t+,--type=}'[type]:t:(all single pre post)' \
          '*: :' && ret=0 ;;
      (rollback)
        _arguments \
          '(-d --description)'{-d+,--description=}'[description]:d:' \
          '(--cleanup-algorithm)--cleanup-algorithm=[algo]:a:' \
          '(--userdata)--userdata=[k=v]:v:' \
          '(-p --print-number)'{-p,--print-number}'[print number]' \
          '*: :' && ret=0 ;;
      (cleanup)
        _arguments '1:algorithm:(number timeline empty-pre-post)' '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
