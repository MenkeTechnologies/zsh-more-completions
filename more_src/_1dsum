#compdef 1dsum
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dsum.html
# Compute column-wise sums (or means) of numeric data in 1D files

local ret=1

_arguments -s -S \
  '-ignore[skip the first nn rows of each input file]:nn' \
  '-use[process only mm rows from each input file]:mm' \
  '-mean[calculate column averages instead of sums]' \
  '-nocomment[suppress header comments from first input file]' \
  '-OKempty[treat empty 1D files as zero and exit gracefully]' \
  '*:file:_files' && ret=0

return ret
