#compdef matrixToBarChartBed
# UCSC kent: attach a labeled expression matrix to a bed file

local ret=1

_arguments -s -S \
  '-bedIx=[use the Nth column of the mapping.bed as the id column (default 4)]:n' \
  '-trackDb=[output a trackDb stanza for this as a track]:file:_files' \
  '-stats=[stats file from matrixClusterColumns for better coloring]:file:_files -g "*.tsv"' \
  '1:matrix tsv:_files -g "*.tsv"' \
  '2:mapping bed:_files -g "*.bed"' \
  '3:barChart output bed:_files -g "*.bed"' && ret=0

return ret
