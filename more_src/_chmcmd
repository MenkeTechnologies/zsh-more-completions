#compdef chmcmd
# Documentation: chmcmd --help (Free Pascal CHM compiler)
# Source: compile a CHM (Windows HTML Help) from .hhp/.xml project.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(--html-scan --no-html-scan)--html-scan[scan HTML for missing files/alinks]' \
    '(--html-scan --no-html-scan)--no-html-scan[do not scan HTML]' \
    '--verbosity=[verbosity level 0..5]:level:(0 1 2 3 4 5)' \
    '--generate-xml[generate XML project from .hhp]' \
    '1:hhp or xml file:_files -g "*.(hhp|xml)"' \
    && ret=0

return ret
