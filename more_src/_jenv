#compdef jenv
# Documentation: https://www.jenv.be/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; cross-checked `jenv commands`.

local -a _jenv_cmds

_jenv_cmds=(
  'add:add a JDK installation to jenv'
  'commands:list all available jenv commands'
  'completions:list completions for a command'
  'disable-plugin:disable a jenv plugin'
  'doctor:diagnose jenv installation'
  'enable-plugin:enable a jenv plugin'
  'exec:run an executable with the selected Java version'
  'global:set or show the global Java version'
  'global-options:show JVM options for the global Java version'
  'help:show help for a command'
  'hooks:list hook scripts for a command'
  'info:show information about jenv'
  'init:configure the shell environment for jenv'
  'javahome:display JAVA_HOME for the selected version'
  'local:set or show the local application-specific Java version'
  'local-options:show JVM options for the local Java version'
  'macos-javahome:toggle macOS java_home integration'
  'options:show JVM options for the current Java version'
  'options-file:detect the file that sets JVM options'
  'options-file-read:read JVM options from an options file'
  'options-file-write:write JVM options to an options file'
  'options-origin:explain how the current JVM options are set'
  'plugins:list available jenv plugins'
  'prefix:display the directory where a Java version is installed'
  'refresh-plugins:refresh installed jenv plugins'
  'refresh-versions:refresh the list of known Java versions'
  'rehash:rehash jenv shims'
  'remove:remove a JDK from jenv'
  'root:display the jenv root directory'
  'shell:set or show the shell-specific Java version'
  'shell-options:show JVM options for the shell Java version'
  'shims:list existing shims'
  'version:show the current Java version and its origin'
  'version-file:detect the file that sets the current jenv version'
  'version-file-read:read the version from a version file'
  'version-file-write:write a version to a version file'
  'version-name:show the current Java version'
  'version-origin:explain how the current Java version is set'
  'versions:list all Java versions available to jenv'
  'whence:list all Java versions that contain the given executable'
  'which:display the full path to an executable'
  'with:run a command with the selected Java version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'jenv command' _jenv_cmds
    ;;
  args)
    case $words[1] in
      add)
        _arguments '1:JDK path:_directories'
        ;;
      remove)
        _arguments '1:Java version:'
        ;;
      global|local|shell)
        _arguments '1:Java version:'
        ;;
      enable-plugin|disable-plugin)
        _arguments '1:plugin name:(export maven gradle ant sbt springboot lein)'
        ;;
      exec)
        _arguments '*:command:_command_names'
        ;;
      which|whence)
        _arguments '1:command name:'
        ;;
    esac
    ;;
esac
