#compdef easytier-core

local curcontext="$curcontext" ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '*-w+[Config server URL]:url:' \
  '*--config-server=[Config server URL]:url:' \
  '--machine-id=[Stable machine identifier]:id:' \
  '*-f+[TOML config files (comma-separated)]:config:_files -g "*.toml"' \
  '*--config-file=[TOML config files]:config:_files -g "*.toml"' \
  '--config-dir=[Directory with config TOMLs]:directory:_directories' \
  '--network-name=[Virtual network name]:name:' \
  '--network-secret=[Shared network secret]:secret:' \
  '*-i+[Virtual IPv4 address CIDR]:ipv4:' \
  '*--ipv4=[Virtual IPv4 address CIDR]:ipv4:' \
  '--ipv6=[Virtual IPv6 address CIDR]:ipv6:' \
  '--ipv6-public-addr-provider=[Enable IPv6 public provider discovery]' \
  '--ipv6-public-addr-auto=[Auto IPv6 public address]' \
  '--ipv6-public-addr-prefix=[IPv6 prefix for derived public address]:prefix:' \
  '*-d+[Use DHCP for virtual IP]:dhcp:' \
  '*--dhcp=[Use DHCP for virtual IP]:dhcp:' \
  '*-p+[Peer URIs tcp:// or udp:// (comma-allowed, repeatable)]:peer:' \
  '*--peers=[Peer URIs]:peer:' \
  '*--external-node=[Bootstrap peer URL]:url:' \
  '*-n+[Subnet proxy CIDR (repeatable)]:cidr:' \
  '*--proxy-networks=[Subnet proxy CIDRs]:cidr:' \
  '*-l+[Listener ports or URIs]:listener:' \
  '*--listeners=[Listener ports or URIs]:listener:' \
  '*--mapped-listeners=[Mapped listener URLs]:url:' \
  '--no-listener[Do not listen for incoming peers]' \
  '--hostname=[Advertised hostname]:host:' \
  '*-m+[Friendly instance name]:name:' \
  '*--instance-name=[Friendly instance name]:name:' \
  '--vpn-portal=[WireGuard portal wg://host:port/subnet]:wgurl:' \
  '--default-protocol=[Default peer protocol]:proto:' \
  '*-u+[Disable encryption]:noenc:' \
  '--disable-encryption=[Disable encryption]:noenc:' \
  '--encryption-algorithm=[Encryption algorithm]:algo:' \
  '--multi-thread=[Use multi-threaded runtime]:bool:' \
  '--multi-thread-count=[Worker thread count]:n:' \
  '--disable-ipv6=[Disable IPv6 on tunnel]:bool:' \
  '--dev-name=[TUN device name]:name:' \
  '--mtu=[TUN MTU]:mtu:' \
  '--latency-first=[Prefer lowest latency path]:bool:' \
  '*--exit-nodes=[Exit node peer URLs]:peer:' \
  '--enable-exit-node=[Act as exit node]:bool:' \
  '--proxy-forward-by-system=[Forward proxy via system stack]:bool:' \
  '--no-tun=[Do not create TUN device]:bool:' \
  '--use-smoltcp=[Use userspace TCP/IP stack]:bool:' \
  '*--manual-routes=[Extra static routes CIDR]:route:' \
  '*--relay-network-whitelist=[Foreign networks allowed to relay]:nets:' \
  '--p2p-only=[Only P2P tunnels]:bool:' \
  '--lazy-p2p=[Defer P2P until needed]:bool:' \
  '--disable-p2p=[Disable P2P features]:bool:' \
  '--disable-udp-hole-punching=[Disable UDP hole punching]:bool:' \
  '--disable-tcp-hole-punching=[Disable TCP hole punching]:bool:' \
  '--disable-sym-hole-punching=[Disable symmetric hole punching]:bool:' \
  '--disable-upnp=[Disable UPnP]:bool:' \
  '--relay-all-peer-rpc=[Relay all peer RPC]:bool:' \
  '--need-p2p=[Require working P2P]:bool:' \
  '--compression=[Traffic compression none|zstd]:mode:(none zstd)' \
  '--bind-device=[Bind sockets to default route device]:bool:' \
  '--enable-kcp-proxy=[Enable KCP proxy helper]:bool:' \
  '--disable-kcp-input=[Disable inbound KCP]:bool:' \
  '--enable-quic-proxy=[Enable QUIC proxy helper]:bool:' \
  '--disable-quic-input=[Disable inbound QUIC]:bool:' \
  '*--port-forward=[Port forward udp://bind/destination specs]:spec:' \
  '--accept-dns=[Handle Magic DNS on TUN]:bool:' \
  '--tld-dns-zone=[Magic DNS zone suffix]:zone:' \
  '--private-mode=[Private network mode flag]:bool:' \
  '--foreign-relay-bps-limit=[Foreign relay bandwidth limit]:bps:' \
  '--instance-recv-bps-limit=[Instance ingress bandwidth limit]:bps:' \
  '*--tcp-whitelist=[Allowed TCP ports/ranges]:ports:' \
  '*--udp-whitelist=[Allowed UDP ports/ranges]:ports:' \
  '--disable-relay-kcp=[Disable relay over KCP]:bool:' \
  '--disable-relay-quic=[Disable relay over QUIC]:bool:' \
  '--enable-relay-foreign-network-kcp=[Relay foreign nets over KCP]:bool:' \
  '--enable-relay-foreign-network-quic=[Relay foreign nets over QUIC]:bool:' \
  '*--stun-servers=[STUN servers host:port]:stun:' \
  '*--stun-servers-v6=[IPv6 STUN servers]:stun:' \
  '--secure-mode=[Enable local public/private key mode]:bool:' \
  '--local-private-key=[Local secure-mode private key]:key:' \
  '--local-public-key=[Local secure-mode public key]:key:' \
  '--credential=[Inline credential secret]:secret:' \
  '--credential-file=[Path to credential file]:file:_files' \
  '--console-log-level=[Console log level]:level:' \
  '--file-log-level=[File log level]:level:' \
  '--file-log-dir=[File log directory]:directory:_directories' \
  '--file-log-size=[Rotating log chunk size MB]:size:' \
  '--file-log-count=[Rotating log file count]:count:' \
  '*-r+[RPC portal SocketAddr for easytier-cli]:addr:' \
  '*--rpc-portal=[RPC portal listen address]:addr:' \
  '*--rpc-portal-whitelist=[RPC caller IP whitelist]:addrs:' \
  '--gen-autocomplete=[Emit shell completions]:shell:' \
  '--check-config[Validate configuration and exit]' \
  '--daemon[Run detached as daemon]' \
  '--disable-env-parsing[Ignore ET_* environment overrides]' && ret=0

return ret
