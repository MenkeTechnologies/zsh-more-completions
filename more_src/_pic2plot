#compdef pic2plot plot plotfont spline tek2plot ode
# Documentation: GNU plotutils man pages
# Reference accessed: 2026-05-30 via WebFetch of
# manpages.ubuntu.com/manpages/jammy/man1/{plot,ode,spline,plotfont,
# tek2plot}.1.html for option lists. The existing `graph` completion
# covers the master plot driver; this round adds the 6 sister
# utilities documented in the plotutils info system. NOTE: pic2plot
# shares plot/tek2plot's flag conventions; documented options
# transcribed from sister-binary man pages where pic2plot's manpage
# proper is empty (per upstream "documentation is in info system" notice).
# GNU plotutils R84 — 6-stem multi-binary harvest. Common flags
# across the suite: -T/--output-format (12-value enum), --help,
# --version.

local curcontext="$curcontext" state line ret=1
local -a _formats _pagesizes _rotations
_formats=( X png pnm gif svg ai ps cgm fig pcl hpgl regis tek meta )
_pagesizes=( letter legal a0 a1 a2 a3 a4 b5 )
_rotations=( 0 90 180 270 )

case $service in

  plot)
    # Plot the GNU Plot metafile format (master plot driver).
    _arguments -s -S \
      '(-T --output-format)'{-T,--output-format}'=[output format]:type:($_formats)' \
      '(-p --page-number)'{-p,--page-number}'=[output only page N]:N:' \
      '(-s --merge-pages)'{-s,--merge-pages}'[combine pages and frames into single output]' \
      '--bitmap-size=[graphics display dimensions in pixels (default 570x570)]:WxH:' \
      '--page-size=[page dimensions]:size:($_pagesizes)' \
      '--rotation=[rotate display by degrees]:angle:($_rotations)' \
      '(-f --font-size)'{-f,--font-size}'=[initial font size as fraction of display width]:fraction:' \
      '(-F --font-name)'{-F,--font-name}'=[initial font name]:font:' \
      '--bg-color=[background color (default white)]:color:' \
      '--pen-color=[initial pen color (default black)]:color:' \
      '(-W --line-width)'{-W,--line-width}'=[initial line width as display fraction]:fraction:' \
      '--emulate-color=[convert colors to grayscale]:option:' \
      '--max-line-length=[polygon points before flushing (default 500)]:N:' \
      '(-O --portable-output)'{-O,--portable-output}'[output human-readable metafile]' \
      '(-h --high-byte-first-input)'{-h,--high-byte-first-input}'[traditional binary metafile, high byte first]' \
      '(-l --low-byte-first-input)'{-l,--low-byte-first-input}'[traditional binary metafile, low byte first]' \
      '(-A --ascii-input)'{-A,--ascii-input}'[traditional ASCII metafile format]' \
      '--help[show help]' \
      '--help-fonts[show available fonts]' \
      '--list-fonts[list fonts one-per-line]' \
      '--version[show version]' \
      '*:metafile:_files'
    ;;

  ode)
    # Numerical ODE integrator.
    _arguments -s -S \
      '(-f --input-file)'{-f,--input-file}'=[read input from file before stdin]:file:_files' \
      '(-p --precision)'{-p,--precision}'=[significant digits for numerical output (default 6)]:N:' \
      '(-t --title)'{-t,--title}'[print title line naming variables]' \
      '(-R --runge-kutta)'{-R,--runge-kutta}'=[fifth-order Runge-Kutta-Fehlberg (default)]:stepsize:' \
      '(-A --adams-moulton)'{-A,--adams-moulton}'=[fourth-order Adams-Moulton predictor-corrector]:stepsize:' \
      '(-E --euler)'{-E,--euler}'=[Euler scheme (constant stepsize)]:stepsize:' \
      '(-H --step-size-bound)'{-H,--step-size-bound}'=[step-size bounds]:hmin\ \[hmax\]:' \
      '(-r --relative-error-bound)'{-r,--relative-error-bound}'=[constrain relative single-step error]:rmax\ \[rmin\]:' \
      '(-e --absolute-error-bound)'{-e,--absolute-error-bound}'=[constrain absolute single-step error]:emax\ \[emin\]:' \
      '(-s --suppress-error-bound)'{-s,--suppress-error-bound}'[disable error ceiling enforcement]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:ode script:_files'
    ;;

  spline)
    # Cubic / Bessel / sub-tension spline interpolator.
    local -a _io_formats
    _io_formats=( a f d i )
    _arguments -s -S \
      '(-f --filter)'{-f,--filter}'[real-time local cubic Bessel filter (requires -t)]' \
      '(-k --boundary-condition)'{-k,--boundary-condition}'=[boundary condition (default 1.0)]:value:' \
      '(-n --no-of-intervals)'{-n,--no-of-intervals}'=[subdivide interval into N (default 100)]:N:' \
      '(-p --periodic)'{-p,--periodic}'[periodic spline (first and last y values must match)]' \
      '(-T --tension)'{-T,--tension}'=[tension value (default 0)]:value:' \
      '(-t --t-spacing)'{-t,--t-spacing}'=[t-spacing]:tmin\ tmax\ \[spacing\]:' \
      '(-d --y-dimension)'{-d,--y-dimension}'=[dependent variable dimensionality (default 1)]:N:' \
      '(-I --input-format)'{-I,--input-format}'=[input format]:fmt:($_io_formats)' \
      '(-O --output-format)'{-O,--output-format}'=[output format]:fmt:($_io_formats)' \
      '(-P --precision)'{-P,--precision}'=[significant digits for ASCII output (default 6)]:N:' \
      '(-a --auto-abscissa)'{-a,--auto-abscissa}'[auto-generate independent variable]' \
      '(-A --auto-dist-abscissa)'{-A,--auto-dist-abscissa}'[generate t as polygonal arclength]' \
      '(-s --suppress-abscissa)'{-s,--suppress-abscissa}'[omit independent variable from output]' \
      '--help[show help]' \
      '--version[show version]' \
      '*:data file:_files'
    ;;

  plotfont)
    # Display available fonts in plot output format.
    _arguments -s -S \
      '(-T --output-format)'{-T,--output-format}'=[output format]:type:($_formats)' \
      '(-1 --lower-half)'{-1,--lower-half}'[generate character map for lower half (default)]' \
      '(-2 --upper-half)'{-2,--upper-half}'[generate character map for upper half]' \
      '(-o --octal)'{-o,--octal}'[number characters in octal]' \
      '(-x --hexadecimal)'{-x,--hexadecimal}'[number characters in hexadecimal]' \
      '--box[surround each character with a box]' \
      '--bg-color=[background color]:color:' \
      '--numbering-font=[font for character numbering]:font:' \
      '--help[show help]' \
      '--help-fonts[show available fonts]' \
      '--list-fonts[list fonts one-per-line]' \
      '--version[show version]' \
      '*:font name:'
    ;;

  tek2plot)
    # Convert Tektronix 4010/4014 vector data to plot output.
    _arguments -s -S \
      '(-T --output-format)'{-T,--output-format}'=[output format]:type:($_formats)' \
      '(-p --page-number)'{-p,--page-number}'=[output only page N]:N:' \
      '(-F --font-name)'{-F,--font-name}'=[font name for Tektronix text]:font:' \
      '--position-chars[position characters individually]' \
      '(-W --line-width)'{-W,--line-width}'=[line width as display fraction]:fraction:' \
      '--bg-color=[background color]:color:' \
      '--pen-color=[pen color]:color:' \
      '--bitmap-size=[graphics display dimensions in pixels]:WxH:' \
      '--page-size=[page dimensions]:size:($_pagesizes)' \
      '--rotation=[rotate display by degrees]:angle:($_rotations)' \
      '--emulate-color=[convert colors to grayscale]:option:' \
      '--max-line-length=[max polygon points]:N:' \
      '--use-tek-fonts[use original Tektronix bitmap fonts]' \
      '(-O --portable-output)'{-O,--portable-output}'[output human-readable metafile]' \
      '--help[show help]' \
      '--help-fonts[show available fonts]' \
      '--list-fonts[list fonts one-per-line]' \
      '--version[show version]' \
      '*:tek file:_files'
    ;;

  pic2plot)
    # Convert troff/groff pic input to plot output.
    # Shares plot/tek2plot flag conventions per upstream info system.
    _arguments -s -S \
      '(-T --output-format)'{-T,--output-format}'=[output format]:type:($_formats)' \
      '(-p --page-number)'{-p,--page-number}'=[output only page N]:N:' \
      '(-s --merge-pages)'{-s,--merge-pages}'[combine pages and frames]' \
      '(-f --font-size)'{-f,--font-size}'=[initial font size]:fraction:' \
      '(-F --font-name)'{-F,--font-name}'=[initial font name]:font:' \
      '(-W --line-width)'{-W,--line-width}'=[initial line width]:fraction:' \
      '--bg-color=[background color]:color:' \
      '--pen-color=[pen color]:color:' \
      '--bitmap-size=[graphics display dimensions]:WxH:' \
      '--page-size=[page dimensions]:size:($_pagesizes)' \
      '--rotation=[rotate display]:angle:($_rotations)' \
      '--emulate-color=[convert colors to grayscale]:option:' \
      '--max-line-length=[max polygon points]:N:' \
      '(-O --portable-output)'{-O,--portable-output}'[output human-readable metafile]' \
      '--help[show help]' \
      '--help-fonts[show available fonts]' \
      '--list-fonts[list fonts one-per-line]' \
      '--version[show version]' \
      '*:pic file:_files'
    ;;

esac
