#compdef koch
# Documentation: upstream docs at nim-lang.org/docs/koch.html
# Reference accessed: 2026-05-30
# Nim's koch — build orchestrator for the Nim compiler itself.

local curcontext="$curcontext" state line ret=1
local -a _subcmds
_subcmds=(
  'boot:bootstrap the compiler'
  'csource:build C sources for installation'
  'temp:build compiler with different name (nim_temp) for testing'
  'test:compile + run the test suite'
  'tests:alias for test'
  'web:convert documentation from RST to HTML'
  'pdf:build PDF versions of documentation'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'koch subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      boot|csource)
        _arguments \
          '-d:release[optimized release build (instead of debug)]' \
          '-d:nimUseLinenoise[use linenoise library for interactive mode (non-Windows)]' \
          '-d:leanCompiler[compiler without JS codegen or docs generator]' && ret=0
        ;;
      web)
        _arguments \
          '--parallelBuild=[parallel job count (1 = serial)]:N:' && ret=0
        ;;
    esac
    ;;
esac

return ret
