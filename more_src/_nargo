#compdef nargo noir

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new:create a new Noir project'
      'init:initialize a Noir project in current directory'
      'check:check the project for errors'
      'compile:compile the project'
      'execute:execute the project'
      'prove:generate a proof'
      'verify:verify a proof'
      'test:run tests'
      'info:show project info and circuit size'
      'lsp:start the Noir language server'
      'fmt:format Noir source files'
      'export:export project artifacts'
      'debug:debug a Noir program'
    )
    _describe -t commands 'nargo command' commands && ret=0
    ;;
  (args)
    local -a common_flags=(
      '(- *)'{-h,--help}'[show help]'
    )

    case ${words[1]} in
      (new)
        _arguments -s -S \
          $common_flags \
          '--name=[project name]:name' \
          '--lib[create a library package]' \
          '--bin[create a binary package]' \
          '--contract[create a contract package]' \
          '1:project path:_files -/' && ret=0
        ;;
      (init)
        _arguments -s -S \
          $common_flags \
          '--name=[project name]:name' \
          '--lib[create a library package]' \
          '--bin[create a binary package]' \
          '--contract[create a contract package]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          $common_flags \
          '--package=[package to check]:package' \
          '--workspace[check all packages in workspace]' \
          '--overwrite[overwrite existing artifacts]' && ret=0
        ;;
      (compile)
        _arguments -s -S \
          $common_flags \
          '--package=[package to compile]:package' \
          '--workspace[compile all packages in workspace]' \
          '--include-keys[include proving and verification keys]' \
          '--expression=[expression to compile]:expression' \
          '--show-output[show compilation output]' && ret=0
        ;;
      (execute)
        _arguments -s -S \
          $common_flags \
          '--package=[package to execute]:package' \
          '--workspace[execute all packages in workspace]' \
          '--expression=[expression to execute]:expression' \
          '--show-output[show program output]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:witness name' && ret=0
        ;;
      (prove)
        _arguments -s -S \
          $common_flags \
          '--package=[package to prove]:package' \
          '--workspace[prove all packages in workspace]' \
          '--expression=[expression to prove]:expression' \
          '--show-output[show program output]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '--verify[verify proof after generating]' \
          '1:proof name' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          $common_flags \
          '--package=[package to verify]:package' \
          '--workspace[verify all packages in workspace]' \
          '1:proof name' && ret=0
        ;;
      (test)
        _arguments -s -S \
          $common_flags \
          '--package=[package to test]:package' \
          '--workspace[test all packages in workspace]' \
          '--show-output[show program output]' \
          '--exact[only run tests that exactly match the filter]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:test filter' && ret=0
        ;;
      (info)
        _arguments -s -S \
          $common_flags \
          '--package=[package to inspect]:package' \
          '--workspace[show info for all packages in workspace]' \
          '--json[output as JSON]' && ret=0
        ;;
      (fmt)
        _arguments -s -S \
          $common_flags \
          '--check[check if files are formatted]' \
          '--package=[package to format]:package' \
          '--workspace[format all packages in workspace]' && ret=0
        ;;
      (export)
        _arguments -s -S \
          $common_flags \
          '--package=[package to export]:package' \
          '--workspace[export all packages in workspace]' && ret=0
        ;;
      (debug)
        _arguments -s -S \
          $common_flags \
          '--package=[package to debug]:package' \
          '--expression=[expression to debug]:expression' \
          '--show-output[show program output]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:witness name' && ret=0
        ;;
      (lsp)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
