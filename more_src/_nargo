#compdef nargo
# Documentation: https://noir-lang.org/docs/reference/nargo_commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'new:create a Noir project in a new directory'
      'init:create a Noir project in the current directory'
      'check:check a local package and dependencies for errors'
      'compile:compile the program into ACIR format'
      'execute:execute a circuit to calculate its return value'
      'test:run the tests for this program'
      'fuzz:run the fuzzing harnesses for this program'
      'info:show circuit details including ACIR opcodes and gate counts'
      'lsp:start the Noir LSP server'
      'fmt:format Noir source files in a workspace'
      'export:export functions marked with #[export] attribute'
      'expand:show the result of macro expansion'
      'doc:build documentation for the specified package or workspace'
      'debug:execute a circuit in debug mode'
      'generate-completion-script:generate shell completion script'
      'help:print help for a subcommand'
    )
    _describe -t commands 'nargo command' commands && ret=0
    ;;
  (args)
    local -a common_flags=(
      '(- *)'{-h,--help}'[show help]'
    )

    case ${words[1]} in
      (new)
        _arguments -s -S \
          $common_flags \
          '--name=[project name]:name' \
          '--lib[create a library package]' \
          '--bin[create a binary package]' \
          '--contract[create a contract package]' \
          '1:project path:_files -/' && ret=0
        ;;
      (init)
        _arguments -s -S \
          $common_flags \
          '--name=[project name]:name' \
          '--lib[create a library package]' \
          '--bin[create a binary package]' \
          '--contract[create a contract package]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          $common_flags \
          '--package=[package to check]:package' \
          '--workspace[check all packages in workspace]' \
          '--overwrite[overwrite existing artifacts]' && ret=0
        ;;
      (compile)
        _arguments -s -S \
          $common_flags \
          '--package=[package to compile]:package' \
          '--workspace[compile all packages in workspace]' \
          '--force[force recompilation]' && ret=0
        ;;
      (execute)
        _arguments -s -S \
          $common_flags \
          '--package=[package to execute]:package' \
          '--workspace[execute all packages in workspace]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:witness name' && ret=0
        ;;
      (test)
        _arguments -s -S \
          $common_flags \
          '--package=[package to test]:package' \
          '--workspace[test all packages in workspace]' \
          '--show-output[show program output]' \
          '--exact[only run tests that exactly match the filter]' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:test filter' && ret=0
        ;;
      (fuzz)
        _arguments -s -S \
          $common_flags \
          '--package=[package to fuzz]:package' \
          '--workspace[fuzz all packages in workspace]' \
          '1:fuzz harness filter' && ret=0
        ;;
      (info)
        _arguments -s -S \
          $common_flags \
          '--package=[package to inspect]:package' \
          '--workspace[show info for all packages in workspace]' \
          '--json[output as JSON]' && ret=0
        ;;
      (fmt)
        _arguments -s -S \
          $common_flags \
          '--check[check if files are formatted]' \
          '--package=[package to format]:package' \
          '--workspace[format all packages in workspace]' && ret=0
        ;;
      (export)
        _arguments -s -S \
          $common_flags \
          '--package=[package to export]:package' \
          '--workspace[export all packages in workspace]' && ret=0
        ;;
      (expand)
        _arguments -s -S \
          $common_flags \
          '--package=[package to expand]:package' \
          '--workspace[expand all packages in workspace]' && ret=0
        ;;
      (doc)
        _arguments -s -S \
          $common_flags \
          '--package=[package to build docs for]:package' \
          '--workspace[build docs for all packages]' && ret=0
        ;;
      (debug)
        _arguments -s -S \
          $common_flags \
          '--package=[package to debug]:package' \
          '--oracle-resolver=[oracle resolver URL]:url' \
          '1:witness name' && ret=0
        ;;
      (generate-completion-script)
        _arguments -s -S \
          $common_flags \
          '1:shell:(bash fish zsh elvish powershell)' && ret=0
        ;;
      (lsp)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
