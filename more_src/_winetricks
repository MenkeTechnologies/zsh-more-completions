#compdef winetricks

# Zsh completion for winetricks - Wine configuration helper

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-q --unattended)'{-q,--unattended}'[run unattended (no prompts)]' \
  '--gui=[choose GUI frontend]:gui:(zenity kdialog none)' \
  '--isolate[install each app in a separate Wine prefix]' \
  '--no-isolate[do not install each app in a separate prefix]' \
  '--no-clean[do not remove temporary directories]' \
  '--optin[opt in to update checks]' \
  '--optout[opt out of update checks]' \
  '--force[force installation even if already installed]' \
  '--verify[verify files after download]' \
  '--country=[set country code for download mirrors]:country code' \
  '--self-update[update winetricks itself]' \
  '--update-rollback[rollback last self-update]' \
  '*:verb or package:->verbs' && ret=0

case "$state" in
  verbs)
    local -a verbs
    verbs=(
      # Meta verbs
      'list-all:list all available packages'
      'list-installed:list installed packages'
      'list-cached:list cached installers'
      'list-download:list downloadable packages'
      'list-manual-download:list packages that require manual download'

      # Prefix management
      'prefix:select a Wine prefix'
      'annihilate:completely remove the current Wine prefix'

      # Settings
      'settings:show current settings'
      'sandbox:sandbox the Wine prefix'
      'sound=disabled:disable sound'
      'sound=alsa:use ALSA for sound'
      'sound=pulse:use PulseAudio for sound'
      'videomemorysize=512:set video memory to 512MB'
      'videomemorysize=1024:set video memory to 1024MB'
      'videomemorysize=2048:set video memory to 2048MB'
      'vd=1024x768:set virtual desktop to 1024x768'
      'vd=off:disable virtual desktop'
      'win7:set Windows version to Windows 7'
      'win8:set Windows version to Windows 8'
      'win10:set Windows version to Windows 10'
      'win11:set Windows version to Windows 11'
      'winxp:set Windows version to Windows XP'
      'fontsmooth=rgb:enable RGB font smoothing'
      'fontsmooth=bgr:enable BGR font smoothing'
      'fontsmooth=gray:enable gray font smoothing'
      'fontsmooth=disable:disable font smoothing'
      'heapcheck:enable heap checking'
      'nocrashdialog:disable crash dialogs'
      'csmt=on:enable CSMT'
      'csmt=off:disable CSMT'
      'dxvk:install DXVK'
      'vkd3d:install vkd3d-proton'
      'galliumnine:install Gallium Nine'

      # DLLs / Components
      'corefonts:install Microsoft core fonts'
      'tahoma:install Tahoma font'
      'allfonts:install all available fonts'
      'dotnet48:install .NET Framework 4.8'
      'dotnet40:install .NET Framework 4.0'
      'dotnet35sp1:install .NET Framework 3.5 SP1'
      'dotnet20:install .NET Framework 2.0'
      'vcrun2022:install Visual C++ 2022 runtime'
      'vcrun2019:install Visual C++ 2019 runtime'
      'vcrun2017:install Visual C++ 2017 runtime'
      'vcrun2015:install Visual C++ 2015 runtime'
      'vcrun2013:install Visual C++ 2013 runtime'
      'vcrun2012:install Visual C++ 2012 runtime'
      'vcrun2010:install Visual C++ 2010 runtime'
      'vcrun2008:install Visual C++ 2008 runtime'
      'vcrun2005:install Visual C++ 2005 runtime'
      'vcrun6:install Visual C++ 6 runtime'
      'd3dx9:install d3dx9'
      'd3dx10:install d3dx10'
      'd3dx11_43:install d3dx11_43'
      'd3dcompiler_43:install d3dcompiler_43'
      'd3dcompiler_47:install d3dcompiler_47'
      'xinput:install xinput'
      'xact:install xact (x3daudio)'
      'quartz:install quartz (DirectShow)'
      'wmp9:install Windows Media Player 9'
      'wmp10:install Windows Media Player 10'
      'wmp11:install Windows Media Player 11'
      'mf:install Media Foundation'
      'cmd:install CMD (command prompt)'
      'gdiplus:install GDI+'
      'msxml3:install MSXML 3'
      'msxml6:install MSXML 6'
      'riched20:install riched20'
      'riched30:install riched30'
      'mdac28:install MDAC 2.8'
      'ie8:install Internet Explorer 8'
      'physx:install PhysX'
      'mono:install Wine Mono'
      'gecko:install Wine Gecko'
    )
    _describe -t verbs 'winetricks verb' verbs
    ;;
esac

return ret
