#compdef apkleaks
# Documentation: https://github.com/dwisiswant0/apkleaks
# Reference accessed: 2026-05-30
# apkleaks — dwisiswant0's APK secret-scanner. Decompiles APK via jadx, then
# applies a JSON-defined regex set to surface URIs, endpoints, and embedded
# credentials. Output as plain text (default) or JSON.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file=}'[APK to scan]:apk:_files -g "*.(apk|xapk|aab)"' \
  '(-o --output)'{-o,--output=}'[write results to FILE (random tmp file if omitted)]:file:_files' \
  '(-p --pattern)'{-p,--pattern=}'[custom pattern JSON file]:file:_files -g "*.json"' \
  '(-a --args)'{-a,--args=}'[extra arguments forwarded to jadx]:jadx-args:' \
  '--json[emit results as JSON instead of plain text]' \
  && ret=0

return ret
