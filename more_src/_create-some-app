#compdef create-some-app
# Documentation: https://www.npmjs.com/package/create-some-app
# Reference accessed: 2026-05-23
# Verified: npm view create-some-app bin; npm readme Using the CLI section.

# Zsh completion for create-some-app - configurable Gatsby/Next + Sanity scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[accept defaults]' \
  '(-g --git)'{-g,--git}'[initialize git repository]' \
  '(-i --install)'{-i,--install}'[run npm install after scaffold]' \
  '(-s --setup)'{-s,--setup}'[run post-install setup; requires --git]' \
  '--gatsbyDefaultEnvironment=[Gatsby build environment]:env:(development production envelope)' \
  '--nodeVersion=[Node.js version for .nvmrc]:version:' \
  '--ownersName=[owner display name]:name:' \
  '--projectName=[human-readable project name]:name:' \
  '--projectDescription=[project description]:description:' \
  '--repoOwner=[GitHub repo owner]:owner:' \
  '--sanityAuthToken=[Sanity auth token]:token:' \
  '--sanityProjectId=[Sanity project id]:id:' \
  '--sanityDataset=[Sanity dataset name]:dataset:' \
  '--siteUrl=[public site URL]:url:' \
  ':template:(fullstack-gatsby-sanity fullstack-next-sanity)' && ret=0

return ret
