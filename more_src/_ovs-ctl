#compdef ovs-ctl
# Documentation: https://www.openvswitch.org/support/dist-docs/ovs-ctl.8.txt
# Open vSwitch startup helper script

local ret=1

_arguments -s -S \
  '--system-id=[unique system identifier for database storage]:id:(random)' \
  '--system-type=[set system-type column value]:type' \
  '--system-version=[set system-version column value]:version' \
  '*--external-id=[set external-ids in database (name=value)]:external id' \
  '--delete-bridges[delete all Open vSwitch bridges after startup]' \
  '--delete-transient-ports[remove ports marked as transient]' \
  '--ovs-user=[user/group for daemon execution]:user' \
  '--no-monitor[suppress daemon crash recovery monitoring]' \
  '--daemon-cwd=[working directory for OVS daemons]:dir:_directories' \
  '--no-force-corefiles[disable core dump generation]' \
  '--no-mlockall[disable virtual memory locking]' \
  '--no-self-confinement[disable confinement for daemons]' \
  '--oom-score=[set Linux OOM killer score]:score' \
  '--ulimit-core=[set ulimit core file size]:limit' \
  '--ovsdb-server-priority=[nice level for ovsdb-server]:niceness' \
  '--ovs-vswitchd-priority=[nice level for ovs-vswitchd]:niceness' \
  '--ovsdb-server-wrapper=[run ovsdb-server under a wrapper]:wrapper:(valgrind strace glibc)' \
  '--ovs-vswitchd-wrapper=[run ovs-vswitchd under a wrapper]:wrapper:(valgrind strace glibc)' \
  '--db-file=[override OVS database file location]:file:_files' \
  '--db-sock=[override unix socket for ovsdb-server]:socket:_files' \
  '--db-schema=[override OVS database schema file location]:file:_files' \
  '--extra-dbs=[add extra databases for ovsdb-server to serve]:file:_files' \
  '--no-ovsdb-server[exclude ovsdb-server from start/stop/restart]' \
  '--no-ovs-vswitchd[exclude ovs-vswitchd from start/stop/restart]' \
  '--protocol=[IP protocol for enable-protocol command]:protocol:(gre)' \
  '--sport=[TCP/UDP source port for enable-protocol]:port' \
  '--dport=[TCP/UDP destination port for enable-protocol]:port' \
  '--version[display version information]' \
  '1:command:(start stop restart status version load-kmod force-reload-kmod enable-protocol delete-transient-ports help)' && ret=0

return ret
