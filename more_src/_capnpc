#compdef capnpc

# Zsh completion for capnpc (Cap'n Proto compiler)

_arguments -s -S \
  '(-I --import-path)'{-I,--import-path=}'[add directory to import search path]:import directory:_files -/' \
  '(-o --output)'{-o,--output=}'[output language and optional directory (e.g. c++:output/)]:lang\:dir:' \
  '--src-prefix=[strip prefix from source file paths]:prefix:_files -/' \
  '--no-standard-import[do not add standard import paths]' \
  '--verbose[log informational messages to stderr]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '*:schema file:_files'
