#compdef smoothsurf
# Documentation: https://bio3d.colorado.edu/imod/doc/man/smoothsurf.html
# smoothsurf - smooth a surface defined by a set of model contours

local ret=1

_arguments -s -S \
  '(-i --input)'{-i,-input}'[input model file]:file:_files' \
  '(-ou --output)'{-ou,-output}'[output model file]:file:_files' \
  '(-ob --objects)'{-ob,-objects}'[list of objects to smooth]:objects' \
  '(-n --nz)'{-n,-nz}'[number of sections in Z to include]:sections' \
  '(-d --distance)'{-d,-distance}'[maximum distance from the central point]:distance' \
  '(-c --contorder)'{-c,-contorder}'[order of polynomials fit to contours]:order' \
  '(-su --surforder)'{-su,-surforder}'[order of polynomials fit to the surface]:order' \
  '(-so --sort)'{-so,-sort}'[control whether to sort into surfaces]:value' \
  '(-r --retain)'{-r,-retain}'[do not delete meshes for the smoothed objects]' \
  '(-h --help)'{-h,-help}'[print help output]' \
  '-StandardInput[read parameter entries from standard input]' \
  '*:file:_files' && ret=0

return ret
