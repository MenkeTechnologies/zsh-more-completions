#compdef yozefu

# Zsh completion for yozefu (Kafka TUI tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'consume:consume messages from a topic'
  'produce:produce messages to a topic'
  'topics:list topics'
  'groups:list consumer groups'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[configuration file]:config file:_files' \
  '(-b --brokers)'{-b,--brokers=}'[Kafka broker addresses]:brokers:' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (consume)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --topic)'{-t,--topic=}'[topic name]:topic:' \
          '(-g --group)'{-g,--group=}'[consumer group]:group:' \
          '(-f --filter)'{-f,--filter=}'[filter expression]:filter:' && ret=0
        ;;
      (produce)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-t --topic)'{-t,--topic=}'[topic name]:topic:' \
          '(-k --key)'{-k,--key=}'[message key]:key:' \
          '(-v --value)'{-v,--value=}'[message value]:value:' && ret=0
        ;;
      (*)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
