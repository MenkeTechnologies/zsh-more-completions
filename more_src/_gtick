#compdef gtick
# Documentation: https://man.archlinux.org/search?q=gtick
# Reference accessed: 2026-05-16

# GTick: GTK metronome
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-D[debug level]:n:' \
  '--debug=[debug level]:n:' \
  '*::gtick args:_files' && ret=0
return ret
