#compdef gtick
# Documentation: https://manpages.debian.org/bookworm/gtick/gtick.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# GTick: GTK metronome
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-D[debug level]:n:' \
  '--debug=[debug level]:n:' \
  '*::gtick args:_files' && ret=0
return ret
