#compdef sqlfluff
# Documentation: https://docs.sqlfluff.com/en/stable/reference/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'lint:lint SQL files'
  'fix:fix SQL files'
  'format:autoformat SQL files with stable rules'
  'parse:parse SQL files and output parse tree'
  'render:render templated SQL files'
  'dialects:list available SQL dialects'
  'rules:list available rules'
  'version:show sqlfluff version'
)

local -a dialects=(
  ansi athena bigquery clickhouse databricks db2 duckdb exasol
  greenplum hive impala mariadb materialize mysql oracle postgres
  redshift snowflake soql sparksql sqlite starrocks teradata trino tsql vertica
)

local -a common_flags=(
  '(-d --dialect)'{-d+,--dialect=}'[SQL dialect]:dialect:('"${dialects[*]}"')'
  '(-t --templater)'{-t+,--templater=}'[templater]:templater:(raw jinja python placeholder)'
  '--config=[additional config file]:file:_files'
  '--ignore-local-config[bypass local .sqlfluff files]'
  '(-e --exclude-rules)'{-e+,--exclude-rules=}'[comma-separated list of rules to exclude]:rules'
  '(-r --rules)'{-r+,--rules=}'[comma-separated list of rules to check]:rules'
  '(-i --ignore)'{-i+,--ignore=}'[ignore error families]:families:(parsing templating)'
  '--encoding=[file encoding]:encoding'
  '--disable-noqa[ignore all inline noqa comments]'
  '--disable-noqa-except=[apply only specified rules in noqa]:rules'
  '--warn-unused-ignores[alert on unnecessary noqa comments]'
  '--library-path=[override Jinja templater library path]:path:_directories'
  '--logger=[filter output to logger]:logger:(templater lexer parser linter rules config)'
  '--bench[enable benchmarking output]'
  '--persist-timing=[save timing data to CSV file]:file:_files'
  '--disable-progress-bar[disable the progress bar]'
  '(-p --processes)'{-p+,--processes=}'[number of parallel processes]:number'
  '--recursion-limit=[set Python recursion limit]:limit'
  '*'{-v,--verbose}'[increase verbosity]'
  '(-n --nocolor)'{-n,--nocolor}'[disable color output]'
  '--stdin-filename=[filename for stdin]:name'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -s -S \
  '1:command:->command' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlfluff command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (lint)
        _arguments -s -S \
          $common_flags \
          '(-f --format)'{-f+,--format=}'[output format]:format:(human json yaml sarif github-annotation github-annotation-native none)' \
          '--write-output=[save results to file]:file:_files' \
          '--annotation-level=[github annotation level]:level:(notice warning failure error)' \
          '--nofail[always exit with zero]' \
          '--disregard-sqlfluffignores[ignore .sqlfluffignore]' \
          '*:file:_files' && ret=0
        ;;
      (fix)
        _arguments -s -S \
          $common_flags \
          '(-f --force)'{-f,--force}'[apply fixes immediately (deprecated)]' \
          '--check[confirm before applying fixes]' \
          '(-q --quiet)'{-q,--quiet}'[minimal output]' \
          '(-x --fixed-suffix)'{-x+,--fixed-suffix=}'[suffix for fixed files]:suffix' \
          '--FIX-EVEN-UNPARSABLE[fix files with parse errors]' \
          '--show-lint-violations[display violations]' \
          '--disregard-sqlfluffignores[ignore .sqlfluffignore]' \
          '*:file:_files' && ret=0
        ;;
      (format)
        _arguments -s -S \
          $common_flags \
          '(-x --fixed-suffix)'{-x+,--fixed-suffix=}'[suffix for formatted files]:suffix' \
          '--disregard-sqlfluffignores[ignore .sqlfluffignore]' \
          '*:file:_files' && ret=0
        ;;
      (parse)
        _arguments -s -S \
          $common_flags \
          '(-f --format)'{-f+,--format=}'[output format]:format:(human json yaml none)' \
          '(-c --code-only)'{-c,--code-only}'[output code elements only]' \
          '(-m --include-meta)'{-m,--include-meta}'[include meta segments and positions]' \
          '--write-output=[save results to file]:file:_files' \
          '--parse-statistics[show terminator debug info]' \
          '--nofail[always exit with zero]' \
          '*:file:_files' && ret=0
        ;;
      (render)
        _arguments -s -S \
          $common_flags \
          '*:file:_files' && ret=0
        ;;
      (dialects|rules|version)
        _arguments -s -S \
          '(-n --nocolor)'{-n,--nocolor}'[disable color output]' \
          '*'{-v,--verbose}'[increase verbosity]' \
          '--version[show version]' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
