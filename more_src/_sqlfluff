#compdef sqlfluff
# _sqlfluff — SQL linter and formatter (sqlfluff/sqlfluff)
# upstream: https://github.com/sqlfluff/sqlfluff

_sqlfluff() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_sqlfluff_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            local -a common_flags=(
                '--dialect=[SQL dialect]:dialect:(ansi bigquery clickhouse databricks db2 duckdb exasol hive materialize mysql oracle postgres redshift snowflake soql sparksql sqlite teradata trino tsql)'
                '--rules=[rules to apply]:rules:'
                '--exclude-rules=[rules to exclude]:rules:'
                '--config=[config file]:file:_files'
                '--ignore=[errors to ignore]:errors:(parsing templating)'
                '(-p --processes)'{-p,--processes}'=[parallel processes]:count:'
                '--encoding=[file encoding]:encoding:'
                '--disregard-sqlfluffignore[ignore .sqlfluffignore]'
                '--nocolor[disable color output]'
                '--help[show help]'
            )

            case $words[1] in
                lint)
                    _arguments \
                        $common_flags \
                        '--nofail[always exit 0]' \
                        '(-f --format)'{-f,--format}'=[output format]:format:(human json yaml github-annotation github-annotation-native)' \
                        '--write-output=[write output to file]:file:_files' \
                        '--annotation-level=[annotation level]:level:(notice warning failure)' \
                        '--bench[benchmark the run]' \
                        '--stdin-filename=[filename for stdin]:name:' \
                        '*:file:_files -g "*.sql"' && ret=0 ;;
                fix)
                    _arguments \
                        $common_flags \
                        '--force[skip confirmation]' \
                        '--fixed-suffix=[suffix for fixed files]:suffix:' \
                        '--bench[benchmark the run]' \
                        '--FIX-EVEN-UNPARSABLE[fix even unparsable files]' \
                        '--show-lint-violations[show violations]' \
                        '*:file:_files -g "*.sql"' && ret=0 ;;
                parse)
                    _arguments \
                        $common_flags \
                        '--bench[benchmark the run]' \
                        '--nofail[always exit 0]' \
                        '(-f --format)'{-f,--format}'=[output format]:format:(human json yaml)' \
                        '--profiler[enable profiler]' \
                        '*:file:_files -g "*.sql"' && ret=0 ;;
                render)
                    _arguments \
                        $common_flags \
                        '*:file:_files -g "*.sql"' && ret=0 ;;
                dialects|rules|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sqlfluff_commands] )) ||
_sqlfluff_commands() {
    local -a commands
    commands=(
        'lint:lint SQL files'
        'fix:fix SQL files'
        'parse:parse SQL files'
        'render:render templated SQL files'
        'dialects:list available dialects'
        'rules:list available rules'
        'version:show version'
    )
    _describe -t commands 'sqlfluff command' commands
}

_sqlfluff "$@"
