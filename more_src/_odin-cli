#compdef odin
# Documentation: https://man.archlinux.org/search?q=odin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:compile to executable or shared lib'
  'run:compile and run'
  'check:check semantics'
  'doc:generate documentation'
  'test:test all procedures with @(test)'
  'strip-semicolon:strip optional semicolons'
  'version:show version'
  'help:show help'
  'report:report system info'
  'root:show root path'
  'bug-report:create bug report'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'odin command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|run|check|test)
        _arguments \
          '-file[treat as single-file package]' \
          '-out:-[output path]:file:_files' \
          '-debug[include debug info]' \
          '-disable-assert[disable runtime assert]' \
          '-no-bounds-check[no bounds check]' \
          '-no-type-assert[no type assert]' \
          '-no-crt[no C runtime]' \
          '-no-thread-local[no thread local]' \
          '-no-rpath[no rpath]' \
          '-no-rtti[no RTTI]' \
          '-vet[lint code]' \
          '-vet-shadowing[vet shadowing]' \
          '-vet-style[vet style]' \
          '-vet-tabs[vet tabs]' \
          '-vet-using-stmt[vet using stmt]' \
          '-vet-using-param[vet using param]' \
          '-vet-unused[vet unused]' \
          '-vet-unused-procedures[vet unused procs]' \
          '-vet-unused-variables[vet unused vars]' \
          '-vet-unused-imports[vet unused imports]' \
          '-vet-unused-imports[vet unused imports]' \
          '-vet-cast[vet cast]' \
          '-vet-semicolon[vet semicolon]' \
          '-strict-style[strict style]' \
          '-build-mode:-[build mode]:m:(exe shared dynamic dll obj asm dll-tester static-lib lib)' \
          '-target:-[target]:t:' \
          '-microarch:-[microarch]:m:' \
          '-define:-[k=v define]:d:' \
          '-collection:-[collection name=path]:c:' \
          '-thread-count:-[threads]:n:' \
          '-keep-temp-files[keep temp]' \
          '-disable-red-zone[disable red zone]' \
          '-extra-linker-flags:-[linker flags]:f:' \
          '-extra-assembler-flags:-[asm flags]:f:' \
          '-show-defineables[show defineables]' \
          '-show-system-calls[show syscalls]' \
          '-show-timings[show timings]' \
          '-show-more-timings[show more timings]' \
          '-export-timings:-[export timings]:f:(json csv)' \
          '-export-timings-file:-[timings file]:file:_files' \
          '-show-unused[show unused]' \
          '-show-unused-with-location[show unused locations]' \
          '-print-linker-flags[print linker flags]' \
          '-default-to-nil-allocator[default nil allocator]' \
          '-default-to-panic-allocator[default panic allocator]' \
          '-foreign-error-procedures[foreign error procs]' \
          '-disallow-do[disallow do]' \
          '-error-pos-style:-[error position]:s:(default unix)' \
          '-relocation-mode:-[relocation]:m:(pic dynamic-pic static)' \
          '-resource:-[resource file]:file:_files' \
          '-warnings-as-errors[warnings as errors]' \
          '-terse-errors[terse errors]' \
          '-json-errors[JSON errors]' \
          '-define-package-name[define package name]' \
          '-pdb-name:-[pdb name]:n:' \
          '-print-help[print help]' \
          '-min-link-libs[minimize libs]' \
          '-strict-target-features[strict target features]' \
          '-target-features:-[target features csv]:list:' \
          '-no-rpath[no rpath]' \
          '-min-link-libs[minimize linked libs]' \
          '-cache-dir:-[cache dir]:dir:_files -/' \
          '-default-temp-allocator-size:-[size]:n:' \
          '-no-thread-local[no thread local]' \
          '-disable-default-loops[disable default loops]' \
          '*: :_files -g "*.odin"' && ret=0 ;;
      (doc)
        _arguments \
          '-short[short docs]' \
          '-all-packages[all packages]' \
          '-doc-format[doc format]' \
          '*: :_files' && ret=0 ;;
      (strip-semicolon)
        _arguments '*: :_files -g "*.odin"' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
