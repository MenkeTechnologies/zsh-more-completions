#compdef celestia-appd
# Documentation: https://man.archlinux.org/search?q=celestia-appd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Validator home directory]:directory:_directories' \
  '--chain-id=[Chain identifier]:id:' \
  '--log_level=[CometBFT logging level]:level:' \
  '--log_format=[CometBFT log format]:format:(plain json)' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Run the full node process'
      'init:Initialize validator files'
      'keys:Manage keyring'
      'gentx:Generate a genesis transaction'
      'collect-gentxs:Aggregate gentxs into genesis.json'
      'validate-genesis:Validate genesis.json'
      'add-genesis-account:Add account to genesis.json'
      'tendermint:Tendermint subcommands'
      'tx:Submit transactions'
      'query:Query chain state'
      'export:Export blockchain state'
      'version:Print build tags and versions'
      'config:Interact with client config'
      'debug:Debug subcommands'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
