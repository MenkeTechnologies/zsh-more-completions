#compdef cad
# Documentation: https://www.ccp4.ac.uk/html/cad.html
# cad — combine/edit MTZ reflection data files (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN1[first input MTZ]:file:_files -g "*.mtz"' \
  'HKLIN2[second input MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output MTZ]:file:_files -g "*.mtz"' \
  'LABIN[input data items to select]:labels:' \
  'LABOUT[output data item names]:labels:' \
  'CTYPIN[data types for entries]:types:' \
  'RESOLUTION[resolution limits]:lim:' \
  'SCALE[scaling and B-factor correction]:opt:' \
  'SORT[index sort order]:order:' \
  'SYMMETRY[change output symmetry]:sg:' \
  'OUTLIM[output limits and spacegroup]:opt:' \
  'MONITOR[control header printing]:opt:' \
  'REFMONITOR[print every nth reflection]:n:' \
  'VALM[Missing Number Flag value]:val:' \
  'TITLE[output title]:title:' \
  'HISTORY[add history strings]:str:' \
  'CENTRIC_ONLY[output centric terms only]' \
  'SYSAB_KEEP[retain systematic absences]' \
  'XNAME[crystal name for columns]:name:' \
  'DNAME[dataset name for columns]:name:' \
  'DRENAME[change crystal/dataset names]:name:' \
  'DPNAME[modify project names]:name:' \
  'DCELL[update cell dimensions]:cell:' \
  'DWAVELENGTH[add/change wavelength]:wl:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
