#compdef prettybat
# Documentation: https://github.com/eth-p/bat-extras/blob/master/doc/prettybat.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above — prettybat passes every flag
# through to bat, so completion delegates to _bat.

# Zsh completion for prettybat (bat-extras - format and print with bat)

local curcontext="$curcontext" state line ret=1

if (( $+functions[_bat] )); then
  _bat "$@"
  return
fi

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--paging=[paging mode]:mode:(auto always never)' \
  '--color=[colorize output]:when:(auto always never)' \
  '--theme=[bat theme]:theme:' \
  '--style=[output style]:style:' \
  '--language=[language]:language:' \
  '*:file:_files' && ret=0

return ret
