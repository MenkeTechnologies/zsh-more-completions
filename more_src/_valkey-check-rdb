#compdef valkey-check-rdb
# Documentation: https://man.archlinux.org/search?q=valkey-check-rdb
# Reference accessed: 2026-05-16

# valkey-check-rdb: check Valkey RDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '*:RDB file:_files -g "*.rdb"' && ret=0
return ret
