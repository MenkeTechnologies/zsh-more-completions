#compdef fossa

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug output]' \
  '--config=[config file]:config file:_files' \
  '--endpoint=[FOSSA API endpoint]:url' \
  '--fossa-api-key=[FOSSA API key]:key' \
  '-p+[project name]:project' \
  '--project=[project name]:project' \
  '-r+[project revision]:revision' \
  '--revision=[project revision]:revision' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'analyze:analyze project dependencies'
      'test:check FOSSA scan results for issues'
      'report:generate reports'
      'list-targets:list available analysis targets'
      'container:analyze container images'
      'snippets:manage snippet scanning'
      'init:initialize a .fossa.yml config file'
      'completion:generate shell completion'
    )
    _describe -t commands 'fossa command' commands && ret=0
    ;;
  args)
    case $line[1] in
      analyze)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--branch=[project branch]:branch' \
          '-o+[output results to file]:file:_files' \
          '--output=[output results to file]:file:_files' \
          '--team=[team name]:team' \
          '--policy=[policy name]:policy' \
          '--title=[project title]:title' \
          '--only-targets=[only analyze specified targets]:targets' \
          '--exclude-targets=[exclude specified targets]:targets' \
          '--filter=[filter dependencies]:filter' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--timeout=[timeout in seconds]:seconds' \
          '-o+[output results to file]:file:_files' \
          '--output=[output results to file]:file:_files' \
          '--format=[output format]:format:(json)' && ret=0
        ;;
      report)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(json html markdown csv)' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '1:report type:(attribution licenses dependencies)' && ret=0
        ;;
      container)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(analyze test)' \
          '2:image' && ret=0
        ;;
    esac
    ;;
esac

return ret
