#compdef karabiner karabiner_cli
# _karabiner — Karabiner Elements macOS key remapping CLI alias (Takayama Fumihiko / pqrs.org, Swift/C++); custom argparse
# upstream: https://github.com/pqrs-org/Karabiner-Elements

_karabiner() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--list-current-profile-name[list current profile name]' \
        '--list-profile-names[list profile names]' \
        '--select-profile=+[select profile]:str:' \
        '--copy-current-profile-settings=+[copy from profile name]:str:' \
        '--remove-profile=+[remove profile]:str:' \
        '--set-variables=+[set variables JSON]:str:' \
        '--show-current-profile-json[show current profile json]' \
        '--show-system-extensions-state[show system extensions state]' \
        '--show-driver-state[show driver state]' \
        '--show-hid-system-states[show hid system states]' \
        '--reload[reload settings]' \
        '--service-driver-state=+[service driver state]:s:(activate deactivate)' \
        '--enable-system-extension[enable system extension]' \
        '--disable-system-extension[disable system extension]' \
        '--enable-virtual-hid-device[enable virtual hid device]' \
        '--disable-virtual-hid-device[disable virtual hid device]' \
        '--export=+[export file]:file:_files -g "*.json"' \
        '--import=+[import file]:file:_files -g "*.json"' \
        '*:arg:'
}

_karabiner "$@"
