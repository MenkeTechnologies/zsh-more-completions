#compdef wx-config-3.3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--release[show release version]' \
  '--version-full[show full version]' \
  '--list[list available alternatives]' \
  '--selected-config[show name of current config]' \
  '--host=[host triplet]:host:' \
  '--toolkit=[toolkit]:toolkit:(gtk2 gtk3 gtk4 osx_cocoa qt msw)' \
  '--universal=-[universal]:flag:(yes no)' \
  '--unicode=-[unicode]:flag:(yes no)' \
  '--static=-[static linkage]:flag:(yes no)' \
  '--debug=-[debug build]:flag:(yes no)' \
  '--version=-[version]:version:' \
  '--flavour=[build flavour]:flavour:' \
  '--basename[print library basename]' \
  '--cc[print C compiler]' \
  '--cxx[print C++ compiler]' \
  '--cppflags[print preprocessor flags]' \
  '--cxxflags[print C++ flags]' \
  '--cflags[print C compiler flags]' \
  '--rescomp[print resource compiler]' \
  '--linkdeps[print only static libraries for makefile rules]' \
  '--ld[print linker]' \
  '--utility=[print path to utility]:util:' \
  '--libs[print linker flags for libs]' \
  '--optional-libs[print linker flags for optional libs]' \
  '*:library:(xrc webview stc richtext ribbon propgrid aui gl html qa adv core xml net base std all)' && ret=0

return ret
