#compdef computeMatrix
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/computeMatrix.html
# deepTools: calculate scores per genome region for plotHeatmap/plotProfile

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:((scale-regions\:"stretch/shrink regions to a set length" reference-point\:"signal relative to a reference point"))' \
  '(-R --regionsFileName)'{-R,--regionsFileName}'[BED/GTF file with regions]:file:_files' \
  '(-S --scoreFileName)'{-S,--scoreFileName}'[bigWig file(s) with scores]:file:_files -g "*.bw"' \
  '(-o -out --outFileName)'{-o,-out,--outFileName}'[gzipped matrix output file]:file:_files' \
  '--outFileNameMatrix[tab-separated matrix values file]:file:_files' \
  '--outFileSortedRegions[filtered/sorted regions BED file]:file:_files' \
  '--referencePoint[reference point type]:point:(TSS TES center)' \
  '--nanAfterEnd[discard values after region end]' \
  '(-m --regionBodyLength)'{-m,--regionBodyLength}'[region length in bases]:length:' \
  '--startLabel[label for region start]:label:' \
  '--endLabel[label for region end]:label:' \
  '(-b --beforeRegionStartLength --upstream)'{-b,--beforeRegionStartLength,--upstream}'[upstream distance]:length:' \
  '(-a --afterRegionStartLength --downstream)'{-a,--afterRegionStartLength,--downstream}'[downstream distance]:length:' \
  '--unscaled5prime[unscaled 5prime bases]:length:' \
  '--unscaled3prime[unscaled 3prime bases]:length:' \
  '(-bs --binSize)'{-bs,--binSize}'[bin size in bases]:size:' \
  '--sortRegions[sort mode]:mode:(descend ascend no keep)' \
  '--sortUsing[sort metric]:metric:(mean median max min sum region_length)' \
  '--sortUsingSamples[sample indices for sorting]:samples:' \
  '--averageTypeBins[statistic type for bins]:type:(mean median min max std sum)' \
  '--missingDataAsZero[treat NAs as zeros]' \
  '--skipZeros[exclude zero-only regions]' \
  '--minThreshold[skip regions with values at or below]:n:' \
  '--maxThreshold[skip regions with values at or above]:n:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED file of excluded regions]:file:_files' \
  '--samplesLabel[custom sample labels]:labels:' \
  '--smartLabels[use filenames as labels]' \
  '(-q --quiet)'{-q,--quiet}'[suppress warnings/messages]' \
  '--verbose[verbose output]' \
  '--scale[multiply all values by this number]:n:' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '--metagene[compute on merged exons]' \
  '--transcriptID[GTF transcript feature]:id:' \
  '--exonID[GTF exon feature]:id:' \
  '--transcript_id_designator[region ID key]:key:' && ret=0

return ret
