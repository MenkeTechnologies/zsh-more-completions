#compdef gem5 gem5.opt gem5.fast gem5.debug gem5.prof

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --copyright)'{-c,--copyright}'[show full copyright]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --version-tags)'{-V,--version-tags}'[show simulator version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-d --outdir)'{-d+,--outdir=}'[output directory]:dir:_files -/' \
  '(-r --redirect-stdout)'{-r,--redirect-stdout}'[redirect stdout]' \
  '(-e --redirect-stderr)'{-e,--redirect-stderr}'[redirect stderr]' \
  '--silent-redirect[silent redirect]' \
  '(-D --debug-flags)'{-D+,--debug-flags=}'[set debug flags]:flags:' \
  '(-i --interactive)'{-i,--interactive}'[interactive Python]' \
  '(-p --pdb)'{-p,--pdb}'[break into pdb on error]' \
  '--stdout-file=[stdout file name]:file:' \
  '--stderr-file=[stderr file name]:file:' \
  '(-G --remote-gdb-port)'{-G+,--remote-gdb-port=}'[gdb port]:port:' \
  '(-T --tags)'{-T,--tags}'[show tags]' \
  '--debug-help[debug help]' \
  '--debug-break=[break on tick]:tick:' \
  '--debug-start=[debug start tick]:tick:' \
  '--debug-end=[debug end tick]:tick:' \
  '--debug-file=[debug log file]:file:_files' \
  '--debug-ignore=[ignore SimObject]:obj:' \
  '--list-sim-objects[list SimObjects]' \
  '--no-output-files[do not produce stats files]' \
  '--ipcs[interactive Python startup script]:file:_files' \
  '--init-param=[initial param]:param:' \
  '--simpoint-profile[profile simpoint workloads]' \
  '--simpoint-interval=[profile interval]:n:' \
  '--list-bp-types[list branch predictor types]' \
  '--list-cp-types[list checkpoint types]' \
  '--list-mem-types[list memory types]' \
  '--list-cpu-types[list CPU types]' \
  '--list-hwp-types[list HW prefetcher types]' \
  '--list-indirect-bp-types[list indirect bp types]' \
  '*: :_files' && ret=0

return ret
