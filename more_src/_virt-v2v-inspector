#compdef virt-v2v-inspector
# Documentation: https://libguestfs.org/virt-v2v-inspector.1.html
# inspect a guest before conversion and write XML output

local ret=1

_arguments -s -S \
  '--help[display help]' \
  '(-V --version)'{-V,--version}'[display version number and exit]' \
  '-O[write XML output to file (- for stdout)]:output:_files' \
  '(-v --verbose)'{-v,--verbose}'[activate debugging messages]' \
  '-x[trace libguestfs API calls]' \
  '(-b --bridge)'{-b,--bridge}'[map guest bridge to host network]:bridge' \
  '--colors[use ANSI colour sequences]' \
  '--colours[use ANSI colour sequences]' \
  '--echo-keys[display key input]' \
  '*--key=[encryption key specification]:key' \
  '--keys-from-stdin[read keys from standard input]' \
  '--mac=[remap guest MAC address]:mac' \
  '--machine-readable=[output in machine-parseable format]:format' \
  '(-m --memsize)'{-m,--memsize}'[memory allocation in megabytes]:mb' \
  '(-n --network)'{-n,--network}'[map guest network to host network]:network' \
  '--no-fstrim[skip filesystem trimming]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output messages]' \
  '--root=[root device specification]:root' \
  '--smp=[number of virtual CPUs]:n' \
  '--wrap[enable line wrapping]' \
  '*:guest:' && ret=0

return ret
