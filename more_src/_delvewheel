#compdef delvewheel
# create self-contained Python wheels for Windows by vendoring DLLs

local ret=1

local -a common
common=(
  '--add-path=[additional path(s) to search for DLLs, path-separator-delimited]:paths'
  '--include=[additional DLL(s) to vendor into the wheel, path-separator-delimited]:dlls'
  '--exclude=[DLL(s) to specifically exclude from the wheel, path-separator-delimited]:dlls'
  '--ignore-existing[do not search for or vendor DLLs already in the wheel]'
  '--analyze-existing[analyze and vendor dependencies of DLLs already in the wheel]'
  '--analyze-existing-exes[analyze and vendor dependencies of EXEs in the wheel]'
  '--extract-dir=[directory to store extracted wheel contents for debug use]:dir:_files -/'
  '-v[verbose output]'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(show repair needed replace-needed)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      show)
        _arguments -s -S $common '*:wheel:_files -g "*.whl"' && ret=0
        ;;
      repair)
        _arguments -s -S $common \
          '(-w --wheel-dir)'{-w,--wheel-dir}'+[directory to write the repaired wheel]:dir:_files -/' \
          '--no-mangle=[DLL(s) not to mangle, path-separator-delimited]:dlls' \
          '--no-mangle-all[do not mangle any DLL names]' \
          '--strip[strip DLLs that contain an overlay when name-mangling]' \
          '(-L --lib-sdir)'{-L,--lib-sdir}'+[directory suffix to store vendored DLLs]:suffix' \
          '--namespace-pkg=[namespace package(s) in case-sensitive dot notation]:pkgs' \
          '--include-symbols[include .pdb symbol files with the vendored DLLs]' \
          '--include-imports[include .lib import library files with the vendored DLLs]' \
          '--custom-patch[specify exact location(s) to place the patch]' \
          '*:wheel:_files -g "*.whl"' && ret=0
        ;;
      *)
        _arguments -s -S '-v[verbose output]' '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
