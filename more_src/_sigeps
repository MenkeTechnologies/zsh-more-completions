#compdef sigeps gmx-sigeps
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-sigeps.html
# gmx sigeps: convert c6/12 or c6/cn combinations to and from sigma/epsilon

local ret=1

_arguments -s \
  '-o[xvgr/xmgr file]:file:_files' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-c6[C6]:real:' \
  '-cn[constant for repulsion]:real:' \
  '-pow[power of the repulsion term]:int:' \
  '-sig[sigma]:real:' \
  '-eps[epsilon]:real:' \
  '-A[Buckingham A]:real:' \
  '-B[Buckingham B]:real:' \
  '-C[Buckingham C]:real:' \
  '-qi[qi]:real:' \
  '-qj[qj]:real:' \
  '-sigfac[factor in front of sigma for starting the plot]:real:' && ret=0

return ret
