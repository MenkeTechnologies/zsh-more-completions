#compdef tcpdpriv
# Documentation: https://ita.ee.lbl.gov/html/contrib/tcpdpriv.0.txt
# Eliminate confidential information from packets (trace anonymizer)

local ret=1

_arguments -s -S \
  '-a+[exit after time has expired]:time \[\[hh:\]mm:\]ss:' \
  '-A+[IP address mapping level]:level:(0 1 2 50 99)' \
  '-c+[exit after receiving count packets]:count:' \
  '-C+[IP address classness preservation level]:level:(0 1 2 3 4 32 99)' \
  '-F+[use file as input for the filter expression]:file:_files' \
  '-i+[listen on interface]:interface:_net_interfaces' \
  '-M+[multicast address mapping level]:level:(0 10 20 70 80 90 99)' \
  '-O[do not run the packet-matching code optimizer]' \
  '-p[do not put the interface into promiscuous mode]' \
  '-P+[TCP and UDP port number mapping level]:level:(0 1 99)' \
  '-q[suppress logging of command-line parameters and summary]' \
  '-r+[read packets from inputfile]:pcap file:_files' \
  '-s+[snarf snaplen bytes of data from each packet]:snaplen:' \
  '-T+[TCP port number mapping level]:level:(0 1 99)' \
  '-U+[UDP port number mapping level]:level:(0 1 99)' \
  '-w+[output file]:output file:_files' \
  '*:filter expression:' && ret=0

return ret
