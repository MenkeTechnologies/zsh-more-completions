#compdef cpulimit

# Zsh completion for cpulimit - CPU usage limiter

_arguments -s -S \
  '-p[PID of the process to limit]:pid:_pids' \
  '-e[Name of the process executable to limit]:executable:_process_names' \
  '-P[Absolute path of the process to limit]:path:_files' \
  '-l[CPU usage limit as a percentage]:percentage (0-100):' \
  '-b[Run cpulimit in the background]' \
  '-f[Also limit the foreground process]' \
  '-z[Exit when the targeted process terminates]' \
  '-v[Verbose mode]' \
  '(- *)-h[Show help]'
