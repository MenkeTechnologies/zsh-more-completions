#compdef heroku

local -a _heroku_cmds

_heroku_cmds=(
  'addons:manage add-on resources'
  'apps:manage apps on Heroku'
  'auth:check 2fa status'
  'authorizations:manage OAuth authorizations'
  'autocomplete:display autocomplete installation instructions'
  'buildpacks:manage the buildpacks for an app'
  'certs:manage SSL certificates for an app'
  'ci:run an application test suite on Heroku'
  'clients:manage your OAuth clients'
  'config:manage app config vars'
  'container:manage Heroku container'
  'domains:manage custom domains for an app'
  'drains:manage log drains for an app'
  'features:manage optional features'
  'git:manage local git repository for app'
  'keys:manage ssh keys'
  'labs:manage optional features (experimental)'
  'local:run Heroku app locally'
  'logs:display recent app log output'
  'maintenance:manage maintenance mode for an app'
  'members:manage organization members'
  'notifications:display notifications'
  'orgs:manage organizations'
  'pg:manage PostgreSQL databases'
  'pipelines:manage pipelines'
  'plugins:manage CLI plugins'
  'ps:manage dynos (process types)'
  'redis:manage Redis instances'
  'regions:list available regions for deployment'
  'releases:manage app releases'
  'reviewapps:manage review apps'
  'run:run a one-off process inside a Heroku dyno'
  'sessions:manage OAuth sessions'
  'spaces:manage Heroku Private Spaces'
  'status:display current status of the Heroku platform'
  'teams:manage teams'
  'update:update the Heroku CLI'
  'webhooks:manage webhooks'
)

_arguments -s -S \
  '(-a --app)'{-a,--app}'[app to run command against]:app name:' \
  '(-r --remote)'{-r,--remote}'[git remote of app to use]:remote:' \
  '--json[output in json format]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show CLI version]' \
  '1:command:->cmds' \
  '*:: :->args'

case "$state" in
  cmds)
    _describe -t commands 'heroku command' _heroku_cmds
    ;;
  args)
    case $words[1] in
      apps)
        local -a apps_cmds
        apps_cmds=(
          'create:create a new app'
          'destroy:permanently destroy an app'
          'info:show detailed app information'
          'list:list your apps'
          'open:open the app in a web browser'
          'rename:rename an app'
          'stacks:show the list of available stacks'
          'favorites:list favorited apps'
        )
        _describe -t commands 'apps subcommand' apps_cmds
        ;;
      config)
        local -a config_cmds
        config_cmds=(
          'get:display a config value for an app'
          'set:set one or more config vars'
          'unset:unset one or more config vars'
          'edit:interactively edit config vars'
        )
        _describe -t commands 'config subcommand' config_cmds
        ;;
      ps)
        local -a ps_cmds
        ps_cmds=(
          'scale:scale dyno quantity up or down'
          'restart:restart app dynos'
          'stop:stop app dyno'
          'type:manage dyno sizes'
          'wait:wait for all dynos to be running'
          'autoscale:manage autoscaling'
          'copy:copy a file from a dyno'
          'exec:create an SSH session to a dyno'
          'forward:forward traffic to a dyno'
          'socks:launch a SOCKS proxy into a dyno'
        )
        _describe -t commands 'ps subcommand' ps_cmds
        ;;
      run)
        _arguments \
          '(-a --app)'{-a,--app}'[app to run command against]:app name:' \
          '(-s --size)'{-s,--size}'[dyno size]:size:' \
          '(-e --env)'{-e,--env}'[environment variables to set]:env:' \
          '--no-tty[force the command to not run in a tty]' \
          '--type[process type]:type:' \
          '*:command:_command_names'
        ;;
      addons)
        local -a addons_cmds
        addons_cmds=(
          'attach:attach an existing add-on resource to an app'
          'create:create a new add-on resource'
          'destroy:permanently destroy an add-on resource'
          'detach:detach an existing add-on resource from an app'
          'docs:open an add-on docs in your browser'
          'info:show detailed add-on resource and attachment information'
          'open:open an add-on dashboard in your browser'
          'plans:list all available plans for an add-on service'
          'rename:rename an add-on'
          'services:list all available add-on services'
          'upgrade:change add-on plan'
          'wait:show provisioning status of the add-ons on the app'
        )
        _describe -t commands 'addons subcommand' addons_cmds
        ;;
      pg)
        local -a pg_cmds
        pg_cmds=(
          'backups:manage backups of PostgreSQL databases'
          'copy:copy all data from source db to target'
          'credentials:manage credentials for a database'
          'diagnose:run or view diagnostics report'
          'info:show database info'
          'kill:kill a query'
          'killall:terminates all connections for all credentials'
          'links:manage links between databases'
          'locks:display queries with active locks'
          'maintenance:manage maintenance windows'
          'promote:sets DATABASE as your DATABASE_URL'
          'ps:view active queries with execution time'
          'psql:open a psql shell to the database'
          'pull:pull Heroku database into local or remote database'
          'push:push local or remote database into Heroku database'
          'reset:delete all data in DATABASE'
          'settings:show current database settings'
          'unfollow:stop a replica from following and make it a writeable database'
          'upgrade:upgrade a database'
          'wait:wait for a database to be available'
        )
        _describe -t commands 'pg subcommand' pg_cmds
        ;;
      *)
        _arguments \
          '(-a --app)'{-a,--app}'[app to run command against]:app name:' \
          '(-r --remote)'{-r,--remote}'[git remote of app to use]:remote:'
        ;;
    esac
    ;;
esac
