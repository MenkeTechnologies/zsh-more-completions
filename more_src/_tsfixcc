#compdef tsfixcc
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsfixcc.cpp
# tsfixcc - fix continuity counters in a transport stream file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --circular)'{-c,--circular}'[enforce continuity when file is played repeatedly]' \
  '(-n --no-action --noaction)'{-n,--no-action,--noaction}'[display what would be done but do not modify file]' \
  '--no-replicate-duplicated[do not replicate duplicated input packets on output]' \
  '*:ts file:_files -g "*.ts *.m2ts *.mpg"' && ret=0

return ret
