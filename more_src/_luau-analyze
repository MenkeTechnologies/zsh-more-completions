#compdef luau-analyze
# Documentation: https://github.com/luau-lang/luau/blob/master/CLI/src/Analyze.cpp
# Luau static type analysis and linting

local ret=1

_arguments -s -S \
  '--help[show usage information]' \
  '--formatter=[select error report format]:format:(plain gnu)' \
  '--mode=[set typechecking mode]:mode:(strict nonstrict)' \
  '--annotate[typecheck files and output source with type annotations]' \
  '--timetrace[record compiler timing information into trace.json]' \
  '--fflags=[set comma-separated Luau fast flags]:flags' \
  '--logbase=[set base directory for JSON solver logs]:dir:_files -/' \
  '--solver=[select typechecker solver]:solver:(old new)' \
  '-j+[number of threads for parallel checking]:threads' \
  '*:lua file:_files -g "*.lua"' && ret=0

return ret
