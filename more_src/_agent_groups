#compdef agent_groups
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/agent-groups.html
# Wazuh agent group management tool

local ret=1

_arguments -s -S \
  '(- *)-h[show help message]' \
  '-q[quiet mode]' \
  '-d[debug mode]' \
  '-l[list groups]' \
  '-c[list configuration files]' \
  '-a[add group or assign agent to group]' \
  '-r[remove group or unassign agent]' \
  '-s[show groups of an agent]' \
  '-S[show sync status]' \
  '-g+[specify group id]:group id:' \
  '-i+[specify agent id]:agent id:' \
  '-f[force or replace mode]' \
  '*::arg:_files' && ret=0

return ret
