#compdef servertell

# EMBOSS servertell: show the details of a server configured in
# emboss.default (or wossserver.dat) such as the URL, supported
# fields, supported data formats, methods, types, and status.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-servername=[name of server to display info for]:server:' \
  '-html[format output as HTML]' \
  '-fields[show supported query fields]' \
  '-methods[show supported access methods]' \
  '-formats[show supported data formats]' \
  '-status[show online status]' \
  '-outfile=[output file]:file:_files' \
  '*:server name:' && ret=0

return ret
