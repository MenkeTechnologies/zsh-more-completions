#compdef crux
# Documentation: https://crux.ms/commands/index.html
# Crux mass spectrometry proteomics toolkit.

local ret=1
local context state line
typeset -A opt_args

_crux_cmds=(
  'bullseye:assign high-resolution precursor masses to spectra'
  'tide-index:create a peptide index for tide-search'
  'tide-search:search spectra against a tide peptide index'
  'cascade-search:iterative search across multiple databases'
  'comet:run the Comet database search engine'
  'comet-index:build a Comet fragment ion index'
  'percolator:re-rank PSMs with semi-supervised learning'
  'kojak:cross-linked peptide search'
  'diameter:DIA search'
  'spectral-counts:quantify proteins/peptides by spectral counting'
  'pipeline:run index, search and post-processing in sequence'
  'assign-confidence:assign q-values to PSMs'
  'generate-peptides:enumerate peptides from a protein database'
  'get-ms2-spectrum:extract a single spectrum from an MS2 file'
  'hardklor:determine charge and m/z of features'
  'make-pin:produce a Percolator input (PIN) file'
  'param-medic:estimate search parameters from spectra'
  'predict-peptide-ions:predict fragment ions for a peptide'
  'print-processed-spectra:write preprocessed spectra'
  'psm-convert:convert PSM file formats'
  'subtract-index:remove peptides of one index from another'
  'localize-modification:localize modifications on PSMs'
  'version:print the version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'crux command' _crux_cmds && ret=0
    ;;
  args)
    _arguments -s \
      '--output-dir=[output directory]:dir:_files -/' \
      '--parameter-file=[configuration file with parameters]:file:_files' \
      '--overwrite=[replace existing files]:bool:(T F)' \
      '--fileroot=[prefix for output filenames]:prefix' \
      '--verbosity=[verbosity level 0-60]:level' \
      '*:input:_files' && ret=0
    ;;
esac

return ret
