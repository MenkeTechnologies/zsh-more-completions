#compdef icewm-toolbar
# Documentation: https://man.archlinux.org/search?q=icewm-toolbar
# Reference accessed: 2026-05-16

# icewm-toolbar: helper to manage IceWM toolbar
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::icewm-toolbar args:_files' && ret=0
return ret
