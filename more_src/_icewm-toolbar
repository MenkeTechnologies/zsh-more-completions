#compdef icewm-toolbar
# Documentation: https://ice-wm.org/man/icewm-toolbar.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# icewm-toolbar: helper to manage IceWM toolbar
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::icewm-toolbar args:_files' && ret=0
return ret
