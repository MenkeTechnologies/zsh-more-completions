#compdef c7n-left

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run policies against IaC source'
  'report:generate report from run output'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'c7n-left command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '-p[policy file or directory]:path:_files' \
          '--policy[policy file or directory]:path:_files' \
          '-d[IaC source directory]:directory:_directories' \
          '--directory[IaC source directory]:directory:_directories' \
          '-o[output directory]:directory:_directories' \
          '--output[output directory]:directory:_directories' \
          '--format[output format]:format:(cli json)' \
          '--summary[summary format]:format:(policy resource)' \
          '--filters[resource type filters]:filters:' \
          '--help[show help]' && ret=0
        ;;
      report)
        _arguments -s -S \
          '-d[output directory from run]:directory:_directories' \
          '--directory[output directory from run]:directory:_directories' \
          '--format[report format]:format:(cli json csv)' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
