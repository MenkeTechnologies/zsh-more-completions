#compdef velocyto
# Documentation: https://velocyto.org/velocyto.py/tutorial/cli.html
# velocyto - RNA velocity counting of spliced/unspliced reads

local ret=1
local -a subcmds

subcmds=(
  'run:general RNA velocity analysis (advanced)'
  'run10x:run on 10X Chromium samples'
  'run_smartseq2:run on SmartSeq2 samples'
  'run_dropest:run on DropSeq/InDrops/dropEst output'
  'tools:helper utilities'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'velocyto command' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments -s \
          '(-b --bcfile)'{-b,--bcfile}'=[valid barcodes file]:file:_files' \
          '(-o --outputfolder)'{-o,--outputfolder}'=[output directory]:dir:_files -/' \
          '(-e --sampleid)'{-e,--sampleid}'=[sample identifier]:id:' \
          '(-s --metadatatable)'{-s,--metadatatable}'=[CSV metadata table]:file:_files' \
          '(-m --mask)'{-m,--mask}'=[GTF masking intervals]:file:_files' \
          '(-c --onefilepercell)'{-c,--onefilepercell}'[treat each BAM as a single cell]' \
          '(-l --logic)'{-l,--logic}'=[filtering logic]:logic:(Default SmartSeq2 ValidatedIntrons10X Stricter10X ObservedSpanning10X)' \
          '(-U --without-umi)'{-U,--without-umi}'[UMI-less data; count reads]' \
          '(-u --umi-extension)'{-u,--umi-extension}'=[extend UMI uniqueness]:ext:' \
          '(-M --multimap)'{-M,--multimap}'[include non-unique mappings]' \
          '(-@ --samtools-threads)'{-@,--samtools-threads}'=[BAM sorting threads]:threads:' \
          '--samtools-memory=[MB per sorting thread]:mb:' \
          '(-t --dtype)'{-t,--dtype}'=[loom layer data type]:dtype:' \
          '(-d --dump)'{-d,--dump}'=[debugging output]:dump:' \
          '*'{-v,--verbose}'[increase verbosity]' \
          '*:bam/gtf file:_files' && ret=0
        ;;
      run10x|run_dropest)
        _arguments -s \
          '(-s --metadatatable)'{-s,--metadatatable}'=[CSV metadata table]:file:_files' \
          '(-m --mask)'{-m,--mask}'=[GTF masking intervals]:file:_files' \
          '(-l --logic)'{-l,--logic}'=[filtering logic]:logic:(Default SmartSeq2 ValidatedIntrons10X Stricter10X ObservedSpanning10X)' \
          '(-M --multimap)'{-M,--multimap}'[include non-unique mappings]' \
          '(-@ --samtools-threads)'{-@,--samtools-threads}'=[BAM sorting threads]:threads:' \
          '--samtools-memory=[MB per sorting thread]:mb:' \
          '(-t --dtype)'{-t,--dtype}'=[loom layer data type]:dtype:' \
          '(-d --dump)'{-d,--dump}'=[debugging output]:dump:' \
          '*'{-v,--verbose}'[increase verbosity]' \
          '*:sample folder/gtf:_files' && ret=0
        ;;
      run_smartseq2)
        _arguments -s \
          '(-o --outputfolder)'{-o,--outputfolder}'=[output directory]:dir:_files -/' \
          '(-e --sampleid)'{-e,--sampleid}'=[sample identifier]:id:' \
          '(-m --mask)'{-m,--mask}'=[GTF masking intervals]:file:_files' \
          '(-t --dtype)'{-t,--dtype}'=[loom layer data type]:dtype:' \
          '(-d --dump)'{-d,--dump}'=[debugging output]:dump:' \
          '*'{-v,--verbose}'[increase verbosity]' \
          '*:bam/gtf file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
