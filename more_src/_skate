#compdef skate

# Zsh completion for skate - Charm personal key-value store

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'set:Set a value for a key'
  'get:Get a value for a key'
  'delete:Delete a key'
  'list:List all key-value pairs'
  'list-dbs:List all databases'
  'sync:Sync local data with the Charm Cloud'
  'reset:Delete all data'
  'help:Help about any command'
)

local -a common_flags=(
  '--db=[database name]:database:'
  '--key-delimiter=[key path delimiter]:delimiter:'
  '(-h --help)'{-h,--help}'[help for skate]'
  '--version[version for skate]'
)

_arguments -s -S \
  $common_flags \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments -s -S \
          $common_flags \
          '(-o --output)'{-o,--output}'=[output format]:format:(json plain)' \
          '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
          '(-k --keys-only)'{-k,--keys-only}'[only print keys]' \
          '(-v --values-only)'{-v,--values-only}'[only print values]' && ret=0
        ;;
      get)
        _arguments -s -S \
          $common_flags \
          '(-o --output)'{-o,--output}'=[output format]:format:(json plain)' \
          ':key:' && ret=0
        ;;
      set)
        _arguments -s -S \
          $common_flags \
          ':key:' \
          ':value:' && ret=0
        ;;
      delete)
        _arguments -s -S \
          $common_flags \
          ':key:' && ret=0
        ;;
      sync|reset|list-dbs)
        _arguments -s -S $common_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
