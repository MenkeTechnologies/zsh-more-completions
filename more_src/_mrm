#compdef mrm
# Documentation: https://github.com/leahneukirchen/mblaze
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB - mrm is not a core mblaze
# tool (not listed in mblaze(7)); it appears in user/community tooling as
# a thin wrapper that removes messages from stdin (like mmv for deletion).
# Falling back to message arguments.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:message:_files' && ret=0

return ret
