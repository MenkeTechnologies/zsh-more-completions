#compdef mrm
# Documentation: https://man.archlinux.org/search?q=mrm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--preset=[use a preset]:preset' \
  '--config=[path to config file]:file:_files' \
  '--dir=[working directory]:dir:_files -/' \
  '--interactive[enable interactive mode]' \
  '*:task' && ret=0

return ret
