#compdef repopack
# Documentation: https://github.com/yamadashy/repomix
# Reference accessed: 2026-05-22

# Zsh completion for repopack (now repomix) - pack repository content

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output}'[output file path]:file:_files' \
  '--style[output style]:style:(plain xml markdown)' \
  '--include[include patterns]:patterns' \
  '--ignore[ignore patterns]:patterns' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '--copy[copy output to clipboard]' \
  '--remote[process remote repository URL]:url' \
  '--top-files-len[number of top files to show]:count' \
  '--verbose[enable verbose output]' && ret=0

return ret
