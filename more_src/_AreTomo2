#compdef AreTomo2
# Documentation: https://github.com/czimaginginstitute/AreTomo2
# AreTomo2 - GPU marker-free tomographic alignment and reconstruction

local ret=1

_arguments -s -S \
  '-InMrc[input MRC tilt series]:file:_files' \
  '-OutMrc[output aligned tilt series MRC]:file:_files' \
  '-AlnFile[alignment file to load and apply]:file:_files' \
  '-AngFile[text file of tilt angles (first column)]:file:_files' \
  '-RoiFile[region-of-interest file]:file:_files' \
  '-TmpFile[temporary debug image file]:file:_files' \
  '-LogFile[log file storing alignment data]:file:_files' \
  '-TiltRange[min and max tilt angles]:range' \
  '-TiltAxis[tilt axis angle and refine flag]:axis' \
  '-AlignZ[volume height in pixels for alignment]:z' \
  '-VolZ[reconstruction volume z height]:z' \
  '-OutBin[binning of aligned output tilt series]:bin' \
  '-Gpu[GPU device IDs]:gpus' \
  '-TiltCor[correct tilt-angle offset]:val' \
  '-ReconRange[min/max tilt for 3D reconstruction]:range' \
  '-PixSize[pixel size in Angstrom]:apix' \
  '-Kv[high tension in kV]:kv' \
  '-ImgDose[dose per image in e/A^2]:dose' \
  '-Cs[spherical aberration in mm]:cs' \
  '-AmpContrast[amplitude contrast (default 0.07)]:ac' \
  '-ExtPhase[phase shift guess and search range]:phase' \
  '-FlipVol[save reconstructed volume in xyz order]:val' \
  '-FlipInt[flip intensity (white structure)]:val' \
  '-Sart[SART iterations and projections per update]:sart' \
  '-Wbp[enable weighted back projection]:val' \
  '-Patch[local patch alignment parameters]:patch' \
  '-TiltScheme[tilt acquisition sequence]:scheme' \
  '-OutXF[generate IMOD-compatible XF file]:val' \
  '-Align[set 0 to skip alignment]:val' \
  '-CropVol[crop reconstructed volume dimensions]:crop' \
  '-OutImod[generate IMOD files for Relion4/Warp]:val' \
  '-DarkTol[tolerance for removing dark images]:tol' \
  '-Bft[B-factors for low-pass filter]:bft' \
  '-IntpCor[correct linear-interpolation loss]:val' \
  '*:file:_files' && ret=0

return ret
