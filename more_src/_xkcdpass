#compdef xkcdpass

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --numwords)'{-n,--numwords}'[number of words in passphrase]:number' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter between words]:delimiter' \
  '(-w --wordfile)'{-w,--wordfile}'[path to word list file]:word file:_files' \
  '--min=[minimum word length]:length' \
  '--max=[maximum word length]:length' \
  '(-c --count)'{-c,--count}'[number of passphrases to generate]:count' \
  '(-V --valid-chars)'{-V,--valid-chars}'[regex for valid characters in words]:regex' \
  '(-a --acrostic)'{-a,--acrostic}'[acrostic word to use]:word' \
  '--case=[case transformation]:case:(lower upper capitalize alternating upper-first random)' \
  '--random-delimiters[use random delimiters between words]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output, includes entropy estimate]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' && ret=0

return ret
