#compdef xkcdpass
# Documentation: https://github.com/redacted/XKCD-password-generator
# Reference accessed: 2026-05-21
# Verified: upstream xkcd_password.py argparse definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --wordfile)'{-w,--wordfile}'[path to word list file]:word file:_files' \
  '--min=[minimum word length]:length' \
  '--max=[maximum word length]:length' \
  '(-n --numwords)'{-n,--numwords}'[number of words in passphrase]:number' \
  '(-a --acrostic)'{-a,--acrostic}'[acrostic word to use]:word' \
  '(-i --interactive)'{-i,--interactive}'[interactive selection mode]' \
  '(-v --valid-chars)'{-v,--valid-chars}'[regex for valid characters in words]:regex' \
  '(-V --verbose)'{-V,--verbose}'[report metrics and entropy info]' \
  '(-c --count)'{-c,--count}'[number of passphrases to generate]:count' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter between words]:delimiter' \
  '(-R --random-delimiters)'{-R,--random-delimiters}'[use random delimiters between words]' \
  '(-D --valid-delimiters)'{-D,--valid-delimiters}'[valid delimiter characters]:delimiters' \
  '(-s --separator)'{-s,--separator}'[passphrase output separator]:sep' \
  '(-C --case)'{-C,--case}'[case transformation]:case:(alternating upper lower random capitalize as-is first)' \
  '--allow-weak-rng[allow fallback to weak RNG]' && ret=0

return ret
