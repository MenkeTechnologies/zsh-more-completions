#compdef batdetmask
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/batdetmask.html
# Retrieve and combine the BAT detector quality map for a given time

local ret=1

_arguments -s -S \
  'date=[observation time ISO, Swift sec, or FITS file]:date:' \
  'outfile=[output detector quality map file]:outfile:_files' \
  'keyword=[header keyword to read time from]:keyword:' \
  'detmask=[user quality map to combine, or NONE]:detmask:_files' \
  'outcaldbmask=[return global CALDB quality map]:outcaldbmask:' \
  'outdetmask=[return selected detector mask]:outdetmask:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  '*:file:_files' && ret=0

return ret
