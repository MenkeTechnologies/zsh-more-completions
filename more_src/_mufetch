#compdef mufetch
# Documentation: https://github.com/ashish0kumar/mufetch
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mufetch: neofetch-style CLI for music (Spotify metadata).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'search:search for a track, album or artist'
  'auth:configure Spotify API credentials'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mufetch command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (search)
        _arguments \
          '--type=[content type]:type:(track album artist)' \
          '(-s --size)'{-s,--size}'[image size, 20-50]:size:' \
          '*:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
