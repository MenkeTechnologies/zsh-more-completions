#compdef pbs_rsub
# PBS: create an advance, standing, or job-specific reservation

local ret=1

_arguments -s \
  '-D+[reservation duration]:duration' \
  '-E+[reservation end time]:end time' \
  '-g+[group names to associate with the reservation]:group list' \
  '-G+[groups authorized to submit jobs to this reservation]:auth group list' \
  '-H+[hosts from which jobs can be submitted]:auth host list' \
  '-I+[interactive mode: block waiting for confirmation]:block time' \
  '--job=[create a confirmed job-specific now reservation]:job id' \
  '*-l+[resource request or placement specification]:resource' \
  '-m+[events triggering email notifications]:mail events' \
  '-M+[users to receive reservation email notifications]:mail list' \
  '-N+[name for the reservation]:reservation name' \
  '-q+[destination server where the reservation is created]:destination' \
  '-r+[recurrence rule for standing reservations (iCalendar)]:recurrence rule' \
  '-R+[reservation start time]:start time' \
  '-u+[comma-separated list of user names]:user list' \
  '-U+[users authorized to submit jobs to this reservation]:auth user list' \
  '-W+[additional reservation attributes]:attribute value list' \
  '--hosts=[hosts for maintenance reservations]:host list' \
  '--version[print PBS version information and exit]' && ret=0

return ret
