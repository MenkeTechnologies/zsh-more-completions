#compdef trash-list
# Zsh completion for trash-list (trash-cli)
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--trash-dir[Specify trash directory]:trash directory:_directories' \
  '--trash-dirs[Show trash directories]' \
  '--sort[Sort output]:sort order:(date path none)' \
  '--all-users[List trashed files for all users]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose output]' \
  '(- *)--help[Show help message]' \
  '(- *)--version[Show version]' && ret=0
return ret
