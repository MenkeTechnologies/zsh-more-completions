#compdef cobaya-grid-converge
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: report convergence of grid chains

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--exist[chain must exist]' \
  '--checkpoint[use R-1 stored in checkpoint files rather than getdist output]' \
  '--running[only check running chains]' \
  '--not_running[only check chains that are not running]' \
  '--stuck[find chains with big spread in last update time]' \
  '--converge=[minimum R-1 convergence]:R-1' \
  '--noimportance[original chains only, no importance sampled]' \
  '*--data=[runs including specific data only]:data' \
  '*--paramtag=[runs with specific parameter tag only]:paramtag' \
  '1:grid directory:_files -/' && ret=0

return ret
