#compdef linode linode-cli
# _linode — Linode CLI for managing Linode cloud (linode/linode-cli)
# upstream: https://github.com/linode/linode-cli

_linode() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--text[output in plain text]' \
        '--json[output as JSON]' \
        '--markdown[output as Markdown table]' \
        '--pretty[pretty-print JSON output]' \
        '--no-headers[omit column headers]' \
        '--all[return all results]' \
        '--format=[columns to display]:columns:' \
        '--delimiter=[column delimiter]:delim:' \
        '--page=[page number]:page:' \
        '--page-size=[items per page]:size:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_linode_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            _arguments \
                '--text[plain text output]' \
                '--json[JSON output]' \
                '--pretty[pretty-print JSON]' \
                '--no-headers[omit headers]' \
                '--all[return all results]' \
                '--format=[columns]:columns:' \
                '*:args:' && ret=0 ;;
    esac

    return ret
}

(( $+functions[_linode_commands] )) ||
_linode_commands() {
    local -a commands
    commands=(
        'linodes:manage Linode instances'
        'volumes:manage block storage volumes'
        'nodebalancers:manage NodeBalancers'
        'domains:manage DNS domains'
        'longview:manage Longview clients'
        'account:manage account'
        'events:list events'
        'firewalls:manage firewalls'
        'images:manage images'
        'kernels:list kernels'
        'lke:manage Kubernetes clusters'
        'networking:manage networking'
        'object-storage:manage object storage'
        'profile:manage profile'
        'regions:list regions'
        'ssh-keys:manage SSH keys'
        'stackscripts:manage StackScripts'
        'support:manage support tickets'
        'tags:manage tags'
        'vlans:manage VLANs'
    )
    _describe -t commands 'linode command' commands
}

_linode "$@"
