#compdef matchcat
# _matchcat — match two catalogs by sky position (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from matchcat.c (single-letter getopt-style).

_matchcat() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-r+[match radius (arcsec)]:arcsec:' \
        '1:reference catalog:_files' \
        '2:compare catalog:_files'
}

_matchcat "$@"
