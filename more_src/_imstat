#compdef imstat
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/imstat.html
# MIRIAD: calculate and plot map statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image dataset]:in:_files' \
  'region=[region of interest]:region:' \
  'axes=[axes for statistics]:axes:' \
  'plot=[statistic to display]:plot:(sum mean rms rrms maximum minimum)' \
  'cutoff=[exclusion threshold]:cutoff:' \
  'device=[PGPLOT device]:device:' \
  'options=[plot characteristics]:options:' \
  'beam=[beam parameters]:beam:' \
  'log=[output log file]:log:_files' \
  '*:image:_files' && ret=0

return ret
