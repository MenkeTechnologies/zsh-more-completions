#compdef lsmod-cli rmmod-cli insmod-cli depmod-cli modinfo-cli
# _lsmod-cli — kmod kernel module commands CLI alias (kmod team, C); custom argparse
# upstream: https://github.com/kmod-project/kmod

_lsmod-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[all]' \
        '-A[quick check]' \
        '-b+[basedir]:dir:_files -/' \
        '--basedir=+[basedir]:dir:_files -/' \
        '-e[empty errors]' \
        '-F+[file]:file:_files' \
        '--filesyms=+[file]:file:_files' \
        '-n[no output]' \
        '--dry-run[no output]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-w[wait]' \
        '-r[strict]' \
        '-s[syslog]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-P+[prefix]:str:' \
        '--symbol-prefix=+[prefix]:str:' \
        '-c[show config]' \
        '--config=+[file]:file:_files' \
        '-d+[dir]:dir:_files -/' \
        '-f[force]' \
        '--force[force]' \
        '-F+[field]:str:' \
        '--field=+[field]:str:' \
        '-k[show known fields]' \
        '-l[print license]' \
        '-p[print parameters]' \
        '-0[NUL separator]' \
        '--null[NUL separator]' \
        '*:modules:'
}

_lsmod-cli "$@"
