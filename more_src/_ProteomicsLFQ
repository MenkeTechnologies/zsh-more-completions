#compdef ProteomicsLFQ
# Documentation: https://www.openms.org/documentation/html/TOPP_ProteomicsLFQ.html
# OpenMS: complete label-free quantification workflow for proteomics

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '*-in[input spectrum files (mzML or Bruker .d)]:file:_files' \
  '*-ids[identification files (idXML, mzIdentML)]:file:_files' \
  '-out[output mzTab file]:file:_files' \
  '-in_feat[pre-computed featureXML files]:file:_files -g "*.featureXML"' \
  '-design[experimental design file]:file:_files' \
  '-fasta[protein database (FASTA)]:file:_files' \
  '-out_msstats[MSstats output file]:file:_files' \
  '-out_triqler[Triqler output file]:file:_files' \
  '-out_cxml[consensusXML output file]:file:_files' \
  '-proteinFDR[protein FDR threshold]:double:' \
  '-picked_proteinFDR[use picked protein FDR]' \
  '-psmFDR[PSM-level FDR threshold]:double:' \
  '-FDR_type[sub-protein FDR level]:level:' \
  '-quantification_method[quantification method]:method:(feature_intensity spectral_counting)' \
  '-targeted_only[ID-based quantification only]' \
  '-mass_recalibration[enable mass recalibration]:bool:(true false)' \
  '-transfer_ids[transfer IDs across runs]:mode:' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
