#compdef rank_strings
# Documentation: https://github.com/fireeye/stringsifter
# rank_strings - StringSifter, rank strings by relevance for malware analysis

local ret=1

_arguments -s -S \
  '(-l --limit)'{-l,--limit}'=[limit output to top N ranked strings]:n' \
  '(-m --min-score)'{-m,--min-score}'=[only output strings with score >= value]:score' \
  '(-s --scores)'{-s,--scores}'[include rank scores in the output]' \
  '(-b --batch)'{-b,--batch}'=[folder of strings outputs for batch processing]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
