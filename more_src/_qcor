#compdef qcor qcor++ qcor-cli
# _qcor — ORNL QCOR quantum-classical hybrid compiler frontend for the XACC infrastructure (ORNL-QCI team, C++); custom argparse
# upstream: https://github.com/ORNL-QCI/qcor

_qcor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '-c[compile only]' \
        '-S[emit asm]' \
        '-emit-llvm[emit LLVM IR]' \
        '-emit-mlir[emit MLIR]' \
        '-emit-quasm[emit QuASM]' \
        '-O+[opt level]:l:(0 1 2 3 s z)' \
        '-g[debug info]' \
        '--debug[debug info]' \
        '-print-tokens[print tokens]' \
        '-print-ast[print AST]' \
        '-keep-tmp[keep tmp files]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-qrt=+[runtime]:r:(ftqc nisq)' \
        '-qpu=+[QPU backend]:b:(qpp aer ibm rigetti ionq oqc honeywell quantinuum quassi xasm mlir-qir mock dwave anneal)' \
        '-opt+[opt pass]:str:' \
        '-opt-level=+[level]:l:(0 1 2)' \
        '-shots=+[shots]:n:' \
        '-list-passes[list optimization passes]' \
        '-l+[link library]:str:' \
        '-L+[link dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '-D+[macro]:str:' \
        '-std=+[c++ standard]:s:(c++14 c++17 c++20)' \
        '-no-cuda-quantum[disable cuda-quantum]' \
        '-disable-jit[disable JIT]' \
        '-enable-syntax-handler[enable syntax handler]' \
        '-print-config[print config]' \
        '-tnqvm-backend=+[backend]:str:' \
        '-acc-name=+[accelerator]:str:' \
        '-accelerator=+[accelerator]:str:' \
        '-aer-shots=+[shots]:n:' \
        '-state-vector[use state vector simulator]' \
        '-x[language extension]:l:(c++ cpp qasm openqasm)' \
        '*:source file:_files -g "*.cpp *.cc *.c *.qcor *.qasm *.qpp"'
}

_qcor "$@"
