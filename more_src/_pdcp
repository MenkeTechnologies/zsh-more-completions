#compdef pdcp pdpcp dshbak rpdcp
# _pdcp — pdsh pdcp (parallel scp-style copy; pushes a file to each host in -w list, or pulls with -r; -w hostlist, -W exclude, -g genders group, -x exclude literal, -R rcmd module, -t connect timeout, -u command timeout, -f fanout, -l user, -p preserve mode/times, -r recursive (reverse copy when target is single))
# upstream: https://github.com/chaos/pdsh
# Flags from chaos/pdsh src/pdcp on tip.

_pdcp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d[debug]' \
        '-q[query options]' \
        '-r[recursive / reverse copy]' \
        '-p[preserve mode/times]' \
        '-w+[hosts]:hosts:_hosts' \
        '-W+[exclude]:hosts:_hosts' \
        '-x+[exclude literal]:hosts:_hosts' \
        '-g+[genders group]:group:' \
        '-a[all hosts]' \
        '-R+[rcmd module]:rcmd:(ssh rsh qsh mrsh exec krb4)' \
        '-t+[connect timeout]:seconds:' \
        '-u+[command timeout]:seconds:' \
        '-f+[fanout]:n:' \
        '-l+[remote user]:user:_users' \
        '*:src dst:_files'
}

_pdcp "$@"
