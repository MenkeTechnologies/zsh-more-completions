#compdef pacstall

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-I --install)'{-I,--install}'[install a package]:package name' \
  '(-R --remove)'{-R,--remove}'[remove a package]:package name' \
  '(-S --search)'{-S,--search}'[search for a package]:search term' \
  '(-Up --upgrade)'{-Up,--upgrade}'[upgrade packages]' \
  '(-U --update)'{-U,--update}'[update package list]' \
  '(-L --list)'{-L,--list}'[list installed packages]' \
  '(-Qi --query-info)'{-Qi,--query-info}'[query info about a package]:package name' \
  '(-K --keep)'{-K,--keep}'[keep build files after installation]' \
  '(-D --download)'{-D,--download}'[download package without installing]:package name' \
  '(-T --tree)'{-T,--tree}'[display dependency tree for a package]:package name' \
  '(-P --disable-prompts)'{-P,--disable-prompts}'[disable interactive prompts]' \
  '(-C --change-repo)'{-C,--change-repo}'[change pacscript repository]:repository URL' \
  '(-A --add-repo)'{-A,--add-repo}'[add a pacscript repository]:repository URL' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '--qa[quality assurance test a pacscript]:pacscript file:_files' && ret=0

return ret
