#compdef kubectl-nsenter
# Documentation: https://github.com/pabateman/kubectl-nsenter
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--kubeconfig=[kubernetes client config path]:file:_files' \
  '--context=[override current context from kubeconfig]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[override namespace of current context]:namespace:' \
  '(-c --container)'{-c+,--container=}'[use namespace of specified container]:container:' \
  '(-u --user)'{-u+,--user=}'[username for SSH connection to node]:user:' \
  '(-s --password)'{-s,--password}'[force password prompt for node authentication]' \
  '--ssh-auth-sock=[set SSH-agent socket]:path:_files' \
  '--host=[override node IP address]:host:' \
  '(-p --port)'{-p+,--port=}'[SSH port]:port:' \
  '--ns=[container PID linux namespaces to enter]:ns:' \
  '(-i --interactive)'{-i,--interactive}'[keep SSH session stdin open]' \
  '(-t --tty)'{-t,--tty}'[allocate pseudo-TTY for SSH session]' \
  '(-o --ssh-opt)'{-o+,--ssh-opt=}'[pass option to SSH client]:opt:' \
  '(-j --use-node-name)'{-j,--use-node-name}'[use kubernetes node name for SSH connection]' \
  '*:pod:_default'
