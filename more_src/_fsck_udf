#compdef fsck_udf
# Documentation: https://keith.github.io/xcode-man-pages/fsck_udf.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-D[enable diagnostic output]' \
  '-b+[blocksize]:size:(512 1024 2048 4096)' \
  '-L[use a local label]' \
  '-p[preen mode (automated processing)]' \
  '*:device:_files -g "/dev/(r)disk*"' && ret=0

return ret
