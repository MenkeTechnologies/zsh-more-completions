#compdef fsck_udf

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-D[increase debug level]' \
  '-b+[blocksize]:size:(512 1024 2048 4096)' \
  '-p[preen mode]' \
  '-f[force check]' \
  '-n[do not fix]' \
  '-y[fix without prompting]' \
  '*:device:_files -g "/dev/(r)disk*"' && ret=0

return ret
