#compdef gomplate-cli
# _gomplate-cli — Hairyhenderson Gomplate Go template CLI alias (Dave Henderson, Go); spf13/cobra
# upstream: https://github.com/hairyhenderson/gomplate

_gomplate-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".gomplate.yaml .gomplate.yml"' \
        '-c+[config file]:file:_files -g ".gomplate.yaml .gomplate.yml"' \
        '--datasource=+[datasource alias=url]:list:' \
        '-d+[datasource alias=url]:list:' \
        '--datasource-header=+[datasource header]:list:' \
        '-H+[datasource header]:list:' \
        '--context=+[context alias=url]:list:' \
        '--exec-pipe[pipe template output to commands]' \
        '--file=+[input file]:file:_files' \
        '-f+[input file]:file:_files' \
        '--in=+[inline template]:str:' \
        '-i+[inline template]:str:' \
        '--input-dir=+[input dir]:dir:_files -/' \
        '--exclude=+[exclude glob]:list:' \
        '--include=+[include glob]:list:' \
        '--exclude-processing=+[exclude processing glob]:list:' \
        '--include-processing=+[include processing glob]:list:' \
        '--out=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--output-map=+[output map template]:str:' \
        '--out-file=+[output file template]:str:' \
        '--left-delim=+[left delim]:str:' \
        '--right-delim=+[right delim]:str:' \
        '--plugin=+[plugin name=path]:list:' \
        '--missing-key=+[missing key]:m:(invalid default zero error)' \
        '-T+[template alias=file]:list:' \
        '--template=+[template alias=file]:list:' \
        '--chmod=+[chmod output]:str:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:arg:'
}

_gomplate-cli "$@"
