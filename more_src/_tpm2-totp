#compdef tpm2-totp
# _tpm2-totp — generate TOTP tokens sealed by TPM2 (tpm2-software/tpm2-totp)
# upstream: https://github.com/tpm2-software/tpm2-totp
# Flags from src/tpm2-totp.c (getopt_long).

_tpm2-totp() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-b --banks)'{-b+,--banks=}'[PCR banks (comma-separated)]:banks:(sha1 sha256 sha384 sha512)' \
        '(-N --nvindex)'{-N+,--nvindex=}'[NV index for the secret]:index:' \
        '(-P --password)'{-P+,--password=}'[TPM owner password]:password:' \
        '(-p --pcrs)'{-p+,--pcrs=}'[PCR list (comma-separated)]:pcrs:' \
        '(-t --time)'{-t,--time}'[generate current TOTP only]' \
        '(-T --tcti)'{-T+,--tcti=}'[TCTI configuration string]:tcti:' \
        '(-l --label)'{-l+,--label=}'[label for the URL output]:label:' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1: :->cmd'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize a TPM-sealed TOTP secret'
                'reseal:reseal an existing TOTP secret'
                'recover:recover the secret from the sealed object'
                'calculate:calculate the current TOTP value'
                'show:show the current TOTP value (alias for calculate)'
                'clean:remove sealed TOTP secret from TPM NV'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_tpm2-totp "$@"
