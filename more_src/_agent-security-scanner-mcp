#compdef agent-security-scanner-mcp
# ============================================================================
# agent-security-scanner-mcp - MCP server +
#   CLI for AI coding agent security scanning
#   (JavaScript -> Node, MIT)
#
# Author : SinewaveAI (sinewaveai)
# Upstream: https://github.com/sinewaveai/
#           agent-security-scanner-mcp
# npm    : agent-security-scanner-mcp
#
# `agent-security-scanner-mcp` is a multi-tool
# MCP (Model Context Protocol) server + CLI for
# securing AI coding agent workflows. It provides:
#   - Prompt injection detection (firewall for
#     model-bound instructions)
#   - Package hallucination detection against a 4.3M+
#     package database (cross-checks claimed package
#     names against npm/PyPI/RubyGems/Go/crates.io
#     registries to detect made-up package names that
#     AI agents sometimes invent)
#   - 1000+ vulnerability detection rules with AST +
#     taint analysis
#   - Auto-fix generation + SBOM/CycloneDX export +
#     OSV.dev vulnerability lookup
#   - SARIF output for CI/CD integration
#
# The Bloom filter dep is used for the package-
# hallucination check: 4.3M+ legitimate package
# names are pre-encoded into a Bloom filter that the
# scanner queries in constant time + ~MB-scale RAM
# footprint instead of holding the full set in
# memory.
#
# Usage:
#   agent-security-scanner-mcp [<command>] [args]
#
# Subcommands:
#   init [client]              - set up MCP config
#                                 for a client
#                                 (claude / cursor /
#                                 cline / windsurf /
#                                 zed / aider / ...)
#   init-hooks                 - install Claude Code
#                                 hooks for auto-
#                                 scanning
#   doctor                     - check environment +
#                                 client configs
#                                 (--fix to remediate)
#   demo                       - generate vulnerable
#                                 file + scan
#                                 (--lang js/python/...)
#   report <dir>               - generate HTML
#                                 security report with
#                                 history
#                                 (--threat-model)
#   benchmark                  - run accuracy
#                                 benchmarks
#                                 (--save +
#                                 --compare-latest)
#
# CLI scanning tools:
#   scan-prompt <text>         - scan prompt for
#                                 injection attacks
#   scan-security <file>       - scan file for
#                                 vulnerabilities
#   scan-skill <path>          - scan OpenClaw skill
#                                 (--baseline)
#   scan-clawhub               - batch scan all
#                                 ClawHub skills
#   check-package <n> <e>      - check if package
#                                 exists in ecosystem
#                                 (uses Bloom filter)
#   scan-packages <f> <e>      - scan file imports
#                                 for hallucinated
#                                 packages
#   scan-project <dir>         - scan directory with
#                                 vulnerability grading
#                                 (--include /
#                                 --exclude patterns)
#   scan-diff [base] [target]  - scan git diff for
#                                 new vulnerabilities
#   scan-mcp <path>            - scan MCP server
#                                 source
#   scan-action <t> <v>        - check agent action
#                                 before execution
#   audit                      - audit OpenClaw
#                                 config (--config-path,
#                                 experimental)
#   harden                     - auto-harden OpenClaw
#                                 config (--fix,
#                                 experimental)
#
# SBOM / supply chain:
#   sbom-generate <dir>        - generate CycloneDX
#                                 SBOM
#                                 (--save +
#                                 --output <path>)
#   sbom-vulnerabilities <dir> - scan SBOM against
#                                 OSV.dev
#                                 (--sbom-path <path>)
#   sbom-check-hallucinations <dir>
#                              - check SBOM packages
#                                 against registries
#                                 (Bloom prefilter)
#   sbom-diff <dir>            - compare SBOM against
#                                 baseline
#                                 (--save-baseline)
#   sbom-report <dir>          - generate SBOM audit
#                                 report
#                                 (--format html|json,
#                                 --no-vulnerabilities)
#
# Common options:
#   --verbosity <level>        - minimal | compact
#                                 (default) | full
#                                 (controls per-output
#                                 token count for AI
#                                 agent consumption)
#   --format <type>            - json | sarif (scan-
#                                 security only)
#   --include <pattern>        - include only
#                                 matching files
#                                 (scan-project)
#   --exclude <pattern>        - exclude matching
#                                 files (scan-project)
#   --json                     - JSON output (report)
#   --baseline                 - baseline mode (scan-
#                                 skill)
#   --baseline-path <path>     - baseline file path
#                                 (sbom-diff)
#   --save-baseline            - save current SBOM as
#                                 baseline
#   --no-vulnerabilities       - skip vulnerability
#                                 section in
#                                 sbom-report
#   --sbom-path <path>         - explicit SBOM file
#                                 path
#   --output <path>            - output file path
#                                 (sbom-generate,
#                                 sbom-report)
#   --save                     - save outputs to
#                                 .scanner/
#   --threat-model             - include threat model
#                                 section in report
#   --compare-latest           - compare benchmark
#                                 against latest run
#   --lang <lang>              - language for demo
#                                 (js / python / ts /
#                                 go / ruby / ...)
#   --fix                      - apply remediations
#                                 (doctor / harden)
#   --config-path <path>       - config file path
#                                 (audit)
#   --help, -h                 - print help
#
# Server mode (no args):
#   Starts an MCP server on stdio for integration
#   with Claude / ChatGPT / Cursor / Cline / ...
#
# Environment:
#   SCANNER_PREWARM            - set to 0 to disable
#                                 daemon pre-warm at
#                                 startup
#
# The bloom-filters lane is built on `bloom-filters
# ^3.0.4` (declared at upstream package.json HEAD as
# a direct dep, used in src/tools/check-package.js +
# scripts/build-bloom-filters.js), the canonical Node
# probabilistic-data-structure umbrella by Thomas
# Minier (Folkvir) - github.com/Callidon/bloom-
# filters, 400+ stars.
#
# Folkvir's umbrella covers ~10 probabilistic data
# structure variants under one TypeScript package:
#   - Classic Bloom Filter (Burton Bloom 1970)
#   - Counting Bloom Filter (deletion support via
#     counters)
#   - Partitioned Bloom Filter
#   - Scalable Bloom Filter (auto-grow when full)
#   - Cuckoo Filter (deletion support via fingerprints)
#   - Compressed Cuckoo Filter
#   - Count-Min Sketch (frequency estimation)
#   - HyperLogLog (cardinality estimation)
#   - Quotient Filter (cache-efficient set
#     membership)
#   - Vacuum Filter (cuckoo successor)
#
# This makes bloom-filters the broadest Node
# probabilistic-data-structure umbrella - a Node
# parallel to the broader Rust nursery's probminhash
# / count_min_sketch / cuckoo crates. Other Node
# Bloom-only libraries (jsBloom, bloomfilter,
# bloomf) cover just the classic variant.
#
# agent-security-scanner-mcp uses bloom-filters in
# `check-package` + `sbom-check-hallucinations` to
# query the 4.3M+ pre-built legitimate-package-name
# Bloom filter (built at install time by `scripts/
# build-bloom-filters.js`) at constant time + low
# memory cost. False positives in the Bloom layer
# trigger a slower full-registry HTTP lookup as a
# second-stage verification, so the false-positive
# rate just affects throughput, not correctness.
#
# ----------------------------------------------------------------------------
# AXIS 257 :: Bloom filter probabilistic data structure
#              (set membership with tunable FP rate)
# Round 1471 :: TS-Node slot 3 of 4 :: CLOSES Axis 257
#                                       (250th axis closed
#                                        - MILESTONE)
#
# Cross-language canonical library family for this axis:
#   Rust    : xx-bloomfilter               [R1469 _rust-mdbg]
#   Go      : bits-and-blooms/bloom        [R1470 _btc-heist]
#             (renamed from willf/bloom
#              2021; Lemire's working
#              group)
#   TS/Node : bloom-filters                [R1471 THIS FILE]
#             (Folkvir's probabilistic-DS
#              umbrella)
#
# bloom-filters closes Axis 257 with the
# *broad-probabilistic-DS-umbrella* pattern. The
# three lanes form a clean spectrum of probabilistic-
# DS library scope:
#
#   - Rust (xx-bloomfilter): Bloom-only crate;
#     focused single-DS coverage
#   - Go (bits-and-blooms/bloom): Bloom-only crate
#     (but bits-and-blooms working group also
#     publishes companion crates: bits-and-blooms/
#     bitset, bits-and-blooms/counting_bloom_filter,
#     bits-and-blooms/cuckoo)
#   - Node (bloom-filters): single TypeScript
#     package covering ~10 probabilistic-DS
#     variants under one umbrella
#
# **250th axis closure milestone** at Axis 257.
# Across the 250 closed axes the corpus has built up
# a complete cross-language canonical-library
# reference for:
#   - Compression algorithms: LZ4 / Snappy / Brotli /
#     ZSTD-via-lz4 (Axes 223 + 253 + 251)
#   - Compressed indexes: roaring bitmaps / bloom
#     filters / bloom + cuckoo + count-min via
#     bloom-filters (Axes 250 + 257)
#   - Cryptographic primitives: BLAKE3 / Ed25519 /
#     JWT / Argon2 / bcrypt (Axes 245 + 246 + 241 +
#     244 + 254)
#   - Wire protocols: QUIC / HTTP/2-WS / Postgres /
#     Redis / CBOR / TOML (Axes 249 + 248 + 256 +
#     255 + 247 + 243)
#   - Diffing + parsing: similar / scraper / html5ever /
#     parse5 / x/net/html (Axes 252 + 242)
#
# Every axis closure produces a triple-confluence
# canonical-library reference connecting Rust +
# Go + Node ecosystems via wire-format-compatible
# implementations.
#
# Cross-language interop at the algorithm level - the
# Bloom filter algorithm is identical across xx-
# bloomfilter + bits-and-blooms/bloom + bloom-
# filters. Wire format is NOT standardized between
# implementations.
#
# Axis 257 closes the round 1471 cycle - 250th axis
# closed total (MILESTONE).
# ============================================================================

_agent-security-scanner-mcp() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--verbosity[output verbosity]:level:(minimal compact full)' \
        '--format[output format]:type:(json sarif)' \
        '--include[file include pattern]:pattern:' \
        '--exclude[file exclude pattern]:pattern:' \
        '--json[JSON output (report)]' \
        '--threat-model[include threat model in report]' \
        '--baseline[baseline mode]' \
        '--baseline-path[baseline file path]:file:_files' \
        '--save-baseline[save current SBOM as baseline]' \
        '--no-vulnerabilities[skip vulnerability section]' \
        '--sbom-path[explicit SBOM file path]:file:_files' \
        '--output[output file path]:file:_files' \
        '--save[save outputs to .scanner/]' \
        '--lang[demo language]:lang:(js ts python py go ruby rb java)' \
        '--fix[apply remediations]' \
        '--config-path[config file path]:file:_files' \
        '--compare-latest[compare benchmark to latest run]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_assm_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init|init-hooks|doctor|demo|benchmark|audit|harden)
                    _arguments \
                        '--fix[apply remediations]' \
                        '--lang[demo language]:lang:(js ts python py go ruby rb java)' \
                        '--config-path[config file path]:file:_files' \
                        '--save[save outputs]' \
                        '--compare-latest[compare to latest run]'
                    ;;
                report)
                    _arguments \
                        '--threat-model[include threat model]' \
                        '--json[JSON output]' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:directory:_files -/'
                    ;;
                scan-prompt)
                    _arguments \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:prompt text:'
                    ;;
                scan-security)
                    _arguments \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '--format[output format]:type:(json sarif)' \
                        '1:source file:_files'
                    ;;
                scan-skill|scan-mcp)
                    _arguments \
                        '--baseline[baseline mode]' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:path:_files'
                    ;;
                check-package)
                    _arguments \
                        '1:package name:' \
                        '2:ecosystem:(npm pypi rubygems go cargo maven nuget composer hex luarocks)'
                    ;;
                scan-packages)
                    _arguments \
                        '1:source file:_files' \
                        '2:ecosystem:(npm pypi rubygems go cargo maven nuget composer hex luarocks)'
                    ;;
                scan-project)
                    _arguments \
                        '--include[file include pattern]:pattern:' \
                        '--exclude[file exclude pattern]:pattern:' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:directory:_files -/'
                    ;;
                scan-diff)
                    _arguments \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:base ref:' \
                        '2:target ref:'
                    ;;
                scan-action)
                    _arguments \
                        '1:tool name:' \
                        '2:tool version:'
                    ;;
                sbom-generate)
                    _arguments \
                        '--save[save SBOM to disk]' \
                        '--output[output file path]:file:_files' \
                        '1:directory:_files -/'
                    ;;
                sbom-vulnerabilities|sbom-check-hallucinations)
                    _arguments \
                        '--sbom-path[explicit SBOM file path]:file:_files' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:directory:_files -/'
                    ;;
                sbom-diff)
                    _arguments \
                        '--baseline-path[baseline file path]:file:_files' \
                        '--save-baseline[save current SBOM as baseline]' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:directory:_files -/'
                    ;;
                sbom-report)
                    _arguments \
                        '--format[report format]:format:(html json)' \
                        '--output[output file path]:file:_files' \
                        '--no-vulnerabilities[skip vulnerability section]' \
                        '--verbosity[output verbosity]:level:(minimal compact full)' \
                        '1:directory:_files -/'
                    ;;
                scan-clawhub)
                    _arguments \
                        '--verbosity[output verbosity]:level:(minimal compact full)'
                    ;;
            esac
            ;;
    esac

    return ret
}

_assm_cmds() {
    local -a cmds
    cmds=(
        'init:set up MCP config for a client'
        'init-hooks:install Claude Code hooks for auto-scanning'
        'doctor:check environment + client configs'
        'demo:generate vulnerable file + scan'
        'report:generate HTML security report with history'
        'benchmark:run accuracy benchmarks'
        'scan-prompt:scan prompt for injection attacks'
        'scan-security:scan file for vulnerabilities'
        'scan-skill:scan OpenClaw skill for security threats'
        'scan-clawhub:batch scan all ClawHub skills'
        'check-package:check if package exists in ecosystem'
        'scan-packages:scan file imports for hallucinated packages'
        'scan-project:scan directory for vulnerabilities'
        'scan-diff:scan git diff for new vulnerabilities'
        'scan-mcp:scan MCP server source'
        'scan-action:check agent action before execution'
        'audit:audit OpenClaw config (experimental)'
        'harden:auto-harden OpenClaw config (experimental)'
        'sbom-generate:generate CycloneDX SBOM'
        'sbom-vulnerabilities:scan SBOM against OSV.dev'
        'sbom-check-hallucinations:check SBOM packages against registries'
        'sbom-diff:compare SBOM against baseline'
        'sbom-report:generate SBOM audit report'
    )
    _describe -t commands 'agent-security-scanner-mcp command' cmds
}

_agent-security-scanner-mcp "$@"
