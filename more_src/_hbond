#compdef hbond gmx-hbond
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-hbond.html
# Analyze hydrogen bonds using geometric definitions

local ret=1

_arguments -s -S \
  '-f+[input trajectory or configuration]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-s+[input structure file]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-n+[extra index groups]:index file:_files -g "*.ndx"' \
  '-o+[output index file with bond pairs]:index file:_files -g "*.ndx"' \
  '-num+[hydrogen bond count vs time]:xvg file:_files -g "*.xvg"' \
  '-dist+[distance distribution plot]:xvg file:_files -g "*.xvg"' \
  '-ang+[angular distribution plot]:xvg file:_files -g "*.xvg"' \
  '-dan+[donors/acceptors analyzed per frame]:xvg file:_files -g "*.xvg"' \
  '-b+[first frame ps]:time:' \
  '-e+[last frame ps]:time:' \
  '-dt+[frame sampling interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-fgroup+[trajectory atoms]:selection:' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-sf+[selection file]:file:_files' \
  '-selrpos+[selection reference positions]:position:' \
  '-seltype+[default selection output positions]:position:' \
  '-r+[reference selection]:selection:' \
  '-t+[target selection]:selection:' \
  '-cutoff+[neighbor search distance nm]:value:' \
  '-hbr+[bond distance cutoff nm]:value:' \
  '-hba+[bond angle cutoff degrees]:value:' \
  '-de+[donor elements]:elements:' \
  '-ae+[acceptor elements]:elements:' \
  '-rmpbc[reconstruct molecules per frame]' \
  '-pbc[apply periodic boundaries]' \
  '-m[merge hydrogen bonds by donor/acceptor]' \
  '-pf[frame-by-frame output mode]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
