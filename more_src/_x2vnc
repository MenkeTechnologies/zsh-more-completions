#compdef x2vnc

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-east[server screen is east]' \
  '-west[server screen is west]' \
  '-north[server screen is north]' \
  '-south[server screen is south]' \
  '-from+[X display]:display:' \
  '-passwd+[VNC password file]:file:_files' \
  '-shared[share session]' \
  '-noblank[do not blank screen]' \
  '-resurface[resurface lost mouse]' \
  '-restartonquit[restart on quit]' \
  '-edgewidth+[edge width]:px:' \
  '-hotkey+[hotkey toggle]:key:' \
  '-tunnel[use ssh tunnel]' \
  '-via+[via host]:host:_hosts' \
  '-debug[debug]' \
  '*:vnc_server:_hosts' && ret=0

return ret
