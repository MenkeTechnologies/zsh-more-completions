#compdef linkml-schema-fixer
# _linkml-schema-fixer — apply automatic fixes to a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Subcommands + flags from src/linkml/utils/schema_fixer.py (click group).

_linkml-schema-fixer() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '(- *)'{-V,--version}'[show version]' \
        '(- *)--help[show help]' \
        '1: :_linkml-schema-fixer_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                fix-names)
                    _arguments \
                        '--imports[apply fix to referenced elements from imported modules]' \
                        '--no-imports[do not apply to imports (default)]' \
                        '(-P --preserve-original-using)'{-P+,--preserve-original-using=}'[preserve original name in this slot (e.g. title)]:slot:' \
                        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"' && ret=0 ;;
                implicit-slots)
                    _arguments \
                        '--imports[apply fix to referenced elements from imported modules]' \
                        '--no-imports[do not apply to imports (default)]' \
                        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_linkml-schema-fixer_commands] )) ||
_linkml-schema-fixer_commands() {
    local -a commands
    commands=(
        'fix-names:rename schema elements to canonical conventions (camelCase / snake_case)'
        'implicit-slots:promote implicit slots into explicit definitions'
    )
    _describe -t commands 'linkml-schema-fixer command' commands
}

_linkml-schema-fixer "$@"
