#compdef snort_inline

# snort_inline: legacy inline-mode Snort 2 (drop/replace inside iptables)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[rules file]:file:_files -g "*.(conf|rules)"' \
  '-l[log dir]:dir:_files -/' \
  '-Q[run in inline mode (libipq)]' \
  '-D[run as daemon]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-T[test config and exit]' \
  '*::snort_inline args:_files' && ret=0
return ret
