#compdef matrixMarketToTsv
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert a Matrix Market sparse matrix to tab-separated values

local ret=1

_arguments -s -S \
  '1:input mtx:_files -g "*.mtx"' \
  '2:sample labels list:_files' \
  '3:gene labels list:_files' \
  '4:output tsv:_files -g "*.tsv"' && ret=0

return ret
