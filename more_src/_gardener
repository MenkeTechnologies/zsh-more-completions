#compdef gardenctl
# _gardener — Gardener kubernetes cluster service CLI (SAP + Gardener community, Go); manage Gardener k8s clusters
# upstream: https://github.com/gardener/gardenctl-v2

_gardener() {
    local -a sub=(
        'completion:print shell completion'
        'config:configure gardenctl'
        'env:print env for active cluster'
        'help:show help'
        'kubeconfig:print kubeconfig for cluster'
        'provider-env:print env for provider'
        'rc:print runtime config'
        'resolve:resolve target'
        'rsh:run remote shell'
        'ssh:ssh into shoot node'
        'ssh-patch:patch ssh access'
        'target:set/get target'
        'unset:unset target'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config-name+[config name]:str:' \
        '--config-version+[config version]:str:' \
        '--debug[debug]' \
        '--gardener-version+[gardener API version]:str:' \
        '--garden+[garden cluster]:cluster:' \
        '--project+[project]:project:' \
        '--seed+[seed]:seed:' \
        '--shoot+[shoot]:shoot:' \
        '--namespace+[namespace]:ns:' \
        '--control-plane[target control plane]' \
        '--output+[output format]:fmt:(json yaml)' \
        '-o+[output format]:fmt:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gardenctl subcommand' sub ;;
        args)
            case $words[1] in
                target) _arguments '1:target type:(garden project seed shoot unset)' '*:name:' ;;
                ssh) _arguments \
                    '--interactive[interactive]' \
                    '--public-key-file+[public key]:file:_files' \
                    '*:node:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gardener "$@"
