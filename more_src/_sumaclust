#compdef sumaclust
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/sumaclust.1.html
# SUMACLUST - exact star clustering of genetic sequences

local ret=1

_arguments -s \
  '(-h)-h[print help]' \
  '(-L -a)-l[reference sequence length is the shortest]' \
  '(-l -a)-L[reference sequence length is the largest]' \
  '(-l -L)-a[reference sequence length is the alignment length (default)]' \
  '(-r)-n[score is normalized by reference sequence length (default)]' \
  '(-n)-r[raw score, not normalized]' \
  '-d[score is expressed in distance (default: similarity)]' \
  '-t[score threshold for clustering (default 0.97)]:threshold' \
  '-e[exact option: assign to cluster with highest similarity score]' \
  '-R[max ratio between counts of two sequences for variant detection (default 1.0)]:ratio' \
  '-p[multithreading with N threads using openMP]:threads' \
  '-s[sort by KEY (None for no sorting, or a fasta header key)]:key' \
  '-o[sort in ascending order (default descending)]' \
  "-g[n's are replaced with a's (default: discard sequences with n's)]" \
  '-B[output OTU table in BIOM format to file]:file:_files' \
  '-O[output OTU map (observation map) to file]:file:_files' \
  '-F[output in FASTA format to file instead of stdout]:file:_files' \
  '-f[deactivate FASTA format output]' \
  '*:file:_files' && ret=0

return ret
