local ret=1

_arguments -s -S \
  '-icc[use the Intel icpc compiler]' \
  '-omp[enable OpenMP support]' \
  '-osc[add OSC control]' \
  '-httpd[add HTTP control via libmicrohttpd]' \
  '-arch32[compile 32-bit architecture]' \
  '-arch64[compile 64-bit architecture]' \
  '*:dsp file:_files -g "*.dsp"' && ret=0

return ret
