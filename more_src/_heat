#compdef heat openstack-heat heat-cli
# _heat — OpenStack Heat heat CLI for the OpenStack Orchestration service managing stacks templates resources event-types resource-types snapshots actions hooks software-deployments OS-API integration with HOT YAML templates (openstack team, Python); argparse
# upstream: https://github.com/openstack/python-heatclient

_heat() {
    local -a sub=(
        'stack-list:list stacks'
        'stack-show:show stack detail'
        'stack-create:create new stack'
        'stack-update:update existing stack'
        'stack-delete:delete stack'
        'stack-cancel-update:cancel running update'
        'stack-suspend:suspend stack'
        'stack-resume:resume stack'
        'stack-check:check stack'
        'stack-adopt:adopt existing resources'
        'stack-abandon:abandon stack'
        'stack-snapshot:create snapshot'
        'stack-restore:restore from snapshot'
        'event-list:list events'
        'event-show:show event'
        'resource-list:list resources'
        'resource-show:show resource'
        'resource-metadata:show resource metadata'
        'resource-signal:signal resource'
        'resource-type-list:list resource types'
        'resource-type-show:show resource type'
        'resource-type-template:show resource type template'
        'template-show:show template'
        'template-validate:validate template'
        'hook-poll:poll hooks'
        'hook-clear:clear hooks'
        'software-config-list:list software configs'
        'software-config-create:create software config'
        'deployment-list:list deployments'
        'deployment-create:create deployment'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--insecure[skip TLS verify]' \
        '--os-cacert=+[file]:file:_files -g "*.pem *.crt"' \
        '--os-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--os-key=+[file]:file:_files -g "*.pem *.key"' \
        '--os-auth-url=+[url]:str:' \
        '--os-username=+[user]:str:' \
        '--os-password=+[password]:str:' \
        '--os-project-name=+[name]:str:' \
        '--os-region-name=+[name]:str:' \
        '--os-tenant-name=+[name]:str:' \
        '--os-token=+[token]:str:' \
        '--heat-url=+[url]:str:' \
        '--heat-api-version=+[v]:v:(1 2)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'heat subcommand' sub ;;
        args)
            case $words[1] in
                stack-create|stack-update) _arguments \
                    '-f+[template file]:file:_files -g "*.yaml *.yml *.json *.template"' \
                    '--template-file=+[template file]:file:_files -g "*.yaml *.yml *.json *.template"' \
                    '-u+[template URL]:str:' \
                    '--template-url=+[template URL]:str:' \
                    '-e+[env file]:file:_files -g "*.yaml *.yml"' \
                    '--environment-file=+[env file]:file:_files -g "*.yaml *.yml"' \
                    '-P+[K=V]:str:' \
                    '--parameters=+[K=V]:str:' \
                    '*:stack name:' ;;
            esac
            ;;
    esac
}

_heat "$@"
