#compdef ktimer
# _ktimer — KDE ktimer CLI graphical countdown task scheduling utility queuing one-shot delayed shell command launches with per-task duration repeat ordered execution voice notification at firing for KDE Plasma desktop timed automation (KDE team, C++); Qt argparse
# upstream: https://invent.kde.org/utilities/ktimer

_ktimer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--help-all[show all options]' \
        '--help-qt[show Qt options]' \
        '--help-kde[show KDE options]' \
        '--author[show author]' \
        '--license[show license]' \
        '*::'
}

_ktimer "$@"
