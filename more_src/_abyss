#compdef abyss
# Documentation: https://github.com/bcgsc/abyss
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ABySS: de novo genome assembly (single-machine launcher)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-k --kmer)'{-k,--kmer=}'[k-mer size]:k:' \
  '(-q --threshold)'{-q,--threshold=}'[minimum k-mer count]:n:' \
  '(-e --erode)'{-e,--erode=}'[erode bases at low-coverage tips]:n:' \
  '(-c --coverage)'{-c,--coverage=}'[minimum mean k-mer coverage to keep contig]:n:' \
  '(-s --bubbles)'{-s,--bubbles=}'[remove bubbles shorter than N bp]:n:' \
  '(-b --branches)'{-b,--branches=}'[max branches at junction]:n:' \
  '(-j --threads)'{-j,--threads=}'[number of threads]:n:' \
  '(-d --dot)'{-d,--dot}'[output Graphviz DOT]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--help[show help]' \
  '--version[show version]' \
  '-o[output FASTA prefix]:prefix:' \
  '*:input read files:_files -g "*.(fq|fastq|fa|fasta|gz)"' && ret=0
return ret
