#compdef slither
# Documentation: https://github.com/crytic/slither
# Reference accessed: 2026-05-21
# Verified: slither/__main__.py argparse definitions.

# Zsh completion for slither - Solidity static analysis framework

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--detect=[comma-separated detectors to run]:detectors' \
  '--print=[comma-separated printers to run]:printers' \
  '--include-interfaces[include interfaces in inheritance-graph]' \
  '--list-detectors[list available detectors]' \
  '--list-printers[list available printers]' \
  '--exclude=[comma-separated detectors to exclude]:detectors' \
  '--exclude-dependencies[exclude dependency-related results]' \
  '--exclude-optimization[exclude optimization findings]' \
  '--exclude-informational[exclude informational findings]' \
  '--exclude-low[exclude low impact findings]' \
  '--exclude-medium[exclude medium impact findings]' \
  '--exclude-high[exclude high impact findings]' \
  '--exclude-location[exclude file location from messages]' \
  '--include-detectors=[include specific detectors]:detectors' \
  '--fail-pedantic[fail on any findings]' \
  '--fail-low[fail on low or greater findings]' \
  '--fail-medium[fail on medium or greater findings]' \
  '--fail-high[fail on high findings]' \
  '--fail-none[do not include findings in exit code]' \
  '--no-fail-pedantic[do not include findings in exit code]' \
  '--show-ignored-findings[show all findings including ignored]' \
  '--warn-unused-ignores[warn about unused disable comments]' \
  '--checklist[generate markdown checklist]' \
  '--checklist-limit=[limit results per detector]:n' \
  '--markdown-root=[URL root for markdown highlighting]:url' \
  '--json=[export results as JSON to file (- for stdout)]:file:_files' \
  '--sarif=[export results as SARIF JSON]:file:_files' \
  '--sarif-input=[SARIF input (beta)]:file:_files' \
  '--sarif-triage=[SARIF triage (beta)]:file:_files' \
  '--json-types=[comma-separated result types]:types' \
  '--zip=[export results as zipped JSON]:file:_files' \
  '--zip-type=[zip compression type]:type' \
  '--disable-color[disable output colorization]' \
  '--triage-mode[save results in triage database]' \
  '--triage-database=[triage database file path]:file:_files' \
  '--config-file=[provide config file]:file:_files' \
  '--change-line-prefix=[change line prefix for source code]:prefix' \
  '--solc-ast[provide contract as JSON AST]' \
  '--generate-patches[generate patches]' \
  '--no-fail[do not fail on parsing errors]' \
  '--filter-paths=[regex filter for exclusion]:regex' \
  '--include-paths=[regex filter for inclusion]:regex' \
  '--debug[debug mode]' \
  '--markdown[markdown output]' \
  '--wiki-detectors[wiki detector output]' \
  '--list-detectors-json[list detectors as JSON]' \
  '--legacy-ast[use legacy AST format]' \
  '--skip-assembly[skip assembly analysis]' \
  '--perf[performance profiling]' \
  '--timing[print phase-level timing]' \
  '--disallow-partial[disable partial analyses]' \
  '1:target:_files' \
  && ret=0

return ret
