#compdef slither

# Zsh completion for slither - Solidity static analysis framework

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--solc=[path to solc binary]:path:_files' \
  '--solc-remaps=[solc remappings]:remaps' \
  '--solc-args=[additional solc arguments]:args' \
  '--disable-solc-warnings[disable solc warnings]' \
  '--json=[output results as JSON to file]:file:_files' \
  '--sarif=[output results as SARIF to file]:file:_files' \
  '--zip=[output results as ZIP to file]:file:_files' \
  '--print=[comma-separated list of printers to run]:printers' \
  '--list-printers[list available printers]' \
  '--list-detectors[list available detectors]' \
  '--detect=[comma-separated list of detectors to run]:detectors' \
  '--exclude=[comma-separated list of detectors to exclude]:detectors' \
  '--exclude-dependencies[exclude results from dependencies]' \
  '--exclude-informational[exclude informational findings]' \
  '--exclude-low[exclude low severity findings]' \
  '--exclude-medium[exclude medium severity findings]' \
  '--exclude-high[exclude high severity findings]' \
  '--exclude-optimization[exclude optimization findings]' \
  '--filter-paths=[comma-separated list of paths to filter]:paths' \
  '--markdown-root=[URL root for markdown links]:url' \
  '--compile-force-framework=[force a specific compile framework]:framework:(hardhat foundry brownie dapp embark truffle solc)' \
  '--show-ignored-findings[show findings that were ignored via triage]' \
  '--triage-mode[enable triage mode]' \
  '--config-file=[path to config file]:file:_files' \
  '--etherscan-api-key=[Etherscan API key]:key' \
  '--etherscan-export-directory=[directory for Etherscan exports]:directory:_directories' \
  '1:target:_files' \
  && ret=0

return ret
