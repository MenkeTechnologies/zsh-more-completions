#compdef lxc-stop

# Zsh completion for lxc-stop (stop an LXC container)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --name)'{-n,--name}'[container name]:name:->containers' \
  '(-r --reboot)'{-r,--reboot}'[reboot container]' \
  '(-k --kill)'{-k,--kill}'[kill container]' \
  '--nokill[do not kill after timeout]' \
  '--nolock[do not use lock]' \
  '(-W --nowait)'{-W,--nowait}'[do not wait for shutdown]' \
  '(-t --timeout)'{-t,--timeout}'[seconds to wait before killing]:seconds' \
  '(-P --lxcpath)'{-P,--lxcpath}'[LXC path]:path:_files -/' \
  '(-o --logfile)'{-o,--logfile}'[log file]:file:_files' \
  '(-l --logpriority)'{-l,--logpriority}'[log priority]:priority:(FATAL CRIT ERROR WARN NOTICE INFO DEBUG)' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (containers)
    local -a containers
    containers=(${(f)"$(lxc-ls --running 2>/dev/null)"})
    _describe -t containers 'container' containers && ret=0
    ;;
esac

return ret
