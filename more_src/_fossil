#compdef fossil

# Zsh completion for Fossil DVCS

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:add files to the repository'
  'all:run a command on all repositories'
  'annotate:show line-by-line origin of a file'
  'bisect:binary search for a bug'
  'branch:create, list, or manage branches'
  'cat:print the content of a file'
  'changes:show changed files'
  'checkout:check out a specific version'
  'co:check out a specific version'
  'clean:delete untracked files'
  'clone:clone a repository'
  'close:close a check-out'
  'commit:commit changes'
  'ci:commit changes'
  'delete:delete a file from the repository'
  'diff:show differences'
  'extras:show files not tracked'
  'finfo:show file history'
  'help:show help'
  'info:show repository or checkout info'
  'init:create a new repository'
  'new:create a new repository'
  'ls:list files'
  'merge:merge changes from another branch'
  'mv:move or rename a file'
  'open:open a repository'
  'pull:pull changes from a remote'
  'push:push changes to a remote'
  'rebuild:rebuild repository metadata'
  'remote-url:show or change the default remote URL'
  'rename:rename a file'
  'revert:revert a file to its checked-in state'
  'rm:remove a file from the repository'
  'settings:query or change settings'
  'sql:run SQL commands'
  'stash:manage stashed changes'
  'status:show current checkout status'
  'sync:sync with a remote repository'
  'tag:create, remove, or list tags'
  'timeline:show a timeline of check-ins'
  'ui:start the web interface'
  'undo:undo the most recent operation'
  'unversioned:manage unversioned files'
  'uv:manage unversioned files'
  'update:update to the latest version'
  'version:show fossil version'
  'wiki:manage wiki pages'
)

_arguments -s -S \
  '1:subcommand:->subcommand' \
  '*::args:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'fossil subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '--dotfiles[include dotfiles]' \
          '--ignore[files to ignore]:glob pattern:' \
          '--clean[only add files not already managed]' \
          '*:file:_files' && ret=0
        ;;
      (branch)
        local -a branch_cmds=(
          'new:create a new branch'
          'list:list branches'
          'ls:list branches'
          'current:show current branch'
        )
        _arguments \
          '1:branch command:->branchcmd' && ret=0
        case $state in
          (branchcmd)
            _describe -t branch-commands 'branch command' branch_cmds && ret=0
            ;;
        esac
        ;;
      (cat)
        _arguments \
          '-r[revision]:revision:' \
          '*:file:_files' && ret=0
        ;;
      (changes|status)
        _arguments \
          '--abs-paths[show absolute paths]' \
          '--rel-paths[show relative paths]' \
          '--sha1sum[verify file content using SHA1]' \
          '--header[identify the repository]' \
          '--no-hierarchical[do not group by directory]' \
          '*:file:_files' && ret=0
        ;;
      (checkout|co)
        _arguments \
          '--force[force checkout even if there are unsaved changes]' \
          '--keep[only update the manifest, not the files]' \
          '1:version:' && ret=0
        ;;
      (clean)
        _arguments \
          '--dotfiles[include dotfiles]' \
          '--force[remove files without prompting]' \
          '--dry-run[show what would be deleted]' \
          '--ignore[files to ignore]:glob pattern:' \
          '--temp[only remove temporary files]' \
          '*:file:_files' && ret=0
        ;;
      (clone)
        _arguments \
          '--admin-user[specify admin user name]:username:' \
          '--once[do not remember the URL]' \
          '--private[clone private branches too]' \
          '--ssl-identity[SSL identity]:file:_files' \
          '1:URL:' \
          '2:filename:_files' && ret=0
        ;;
      (commit|ci)
        _arguments \
          '-m[commit message]:message:' \
          '-M[read commit message from file]:file:_files' \
          '--branch[commit to a new branch]:branch name:' \
          '--close[close the branch]' \
          '--dry-run[show what would be committed]' \
          '--allow-empty[allow empty check-ins]' \
          '--allow-fork[allow forking]' \
          '--no-warnings[omit all warnings]' \
          '--nosign[do not sign the commit]' \
          '--private[do not sync after commit]' \
          '--tag[assign a tag to this commit]:tag name:' \
          '*:file:_files' && ret=0
        ;;
      (diff)
        _arguments \
          '--binary[show binary diffs]:file:_files' \
          '--brief[show filenames only]' \
          '--context[context lines]:number:' \
          '--from[source version]:version:' \
          '--to[target version]:version:' \
          '--side-by-side[side-by-side diff]' \
          '--tk[launch a Tk diff viewer]' \
          '--unified[unified diff]' \
          '-c[context lines]:number:' \
          '-i[ignore case]' \
          '-v[verbose]' \
          '-w[ignore whitespace]' \
          '*:file:_files' && ret=0
        ;;
      (extras)
        _arguments \
          '--dotfiles[include dotfiles]' \
          '--ignore[files to ignore]:glob pattern:' \
          '--abs-paths[show absolute paths]' \
          '--rel-paths[show relative paths]' && ret=0
        ;;
      (init|new)
        _arguments \
          '-A[set the admin user]:username:' \
          '--admin-user[set the admin user]:username:' \
          '1:repository file:_files' && ret=0
        ;;
      (ls)
        _arguments \
          '-r[show files from a specific check-in]:version:' \
          '--age[show file ages]' \
          '-v[provide extra information]' && ret=0
        ;;
      (merge)
        _arguments \
          '--cherrypick[cherry-pick a single commit]' \
          '--backout[back out a commit]' \
          '--dry-run[show what would happen]' \
          '--force[force the merge]' \
          '--integrate[close the merged branch]' \
          '-n[dry run]' \
          '-v[verbose]' \
          '1:version:' && ret=0
        ;;
      (open)
        _arguments \
          '--keep[only modify the manifest]' \
          '--force[force open even if already open]' \
          '1:repository file:_files' && ret=0
        ;;
      (pull|push|sync)
        _arguments \
          '--once[do not remember the URL]' \
          '--private[sync private branches]' \
          '1:URL:' && ret=0
        ;;
      (revert)
        _arguments \
          '-r[revert to a specific revision]:revision:' \
          '*:file:_files' && ret=0
        ;;
      (settings)
        local -a settings=(
          'autosync:automatically sync after commit'
          'binary-glob:glob pattern for binary files'
          'case-sensitive:case-sensitive file handling'
          'diff-command:external diff command'
          'editor:text editor command'
          'gdiff-command:external graphical diff command'
          'http-port:HTTP port for the ui command'
          'proxy:HTTP proxy'
        )
        _arguments \
          '--global[set globally]' \
          '1:setting:->setting' \
          '2:value:' && ret=0
        case $state in
          (setting)
            _describe -t settings 'fossil setting' settings && ret=0
            ;;
        esac
        ;;
      (stash)
        local -a stash_cmds=(
          'save:save current changes to stash'
          'snapshot:save current changes but keep working copy'
          'list:list stashed changes'
          'ls:list stashed changes'
          'show:show a stashed change'
          'pop:apply and remove the most recent stash'
          'apply:apply a stash without removing it'
          'drop:remove a stashed change'
          'goto:apply a stash and update working directory'
          'diff:diff a stashed change'
        )
        _arguments \
          '1:stash command:->stashcmd' && ret=0
        case $state in
          (stashcmd)
            _describe -t stash-commands 'stash command' stash_cmds && ret=0
            ;;
        esac
        ;;
      (tag)
        local -a tag_cmds=(
          'add:add a tag'
          'remove:remove a tag'
          'find:find a tag'
          'list:list tags'
          'ls:list tags'
        )
        _arguments \
          '1:tag command:->tagcmd' && ret=0
        case $state in
          (tagcmd)
            _describe -t tag-commands 'tag command' tag_cmds && ret=0
            ;;
        esac
        ;;
      (timeline)
        _arguments \
          '-n[number of entries]:count:' \
          '-t[type (ci, w, t, e)]:type:(ci w t e)' \
          '--oneline[one line per entry]' \
          '-v[verbose]' \
          '-W[width of output]:width:' && ret=0
        ;;
      (ui)
        _arguments \
          '--port[HTTP port]:port:' \
          '--page[start on a specific page]:page:' \
          '--notfound[URL for 404]:URL:' \
          '--localauth[enable local authentication]' \
          '1:repository:_files' && ret=0
        ;;
      (update)
        _arguments \
          '--debug[print debug information]' \
          '--dry-run[show what would happen]' \
          '--force[force update]' \
          '--latest[update to latest version on branch]' \
          '-n[dry run]' \
          '-v[verbose]' \
          '1:version:' && ret=0
        ;;
      (wiki)
        local -a wiki_cmds=(
          'create:create a wiki page'
          'commit:commit wiki changes'
          'export:export a wiki page'
          'list:list wiki pages'
        )
        _arguments \
          '1:wiki command:->wikicmd' && ret=0
        case $state in
          (wikicmd)
            _describe -t wiki-commands 'wiki command' wiki_cmds && ret=0
            ;;
        esac
        ;;
      (help)
        _arguments '1:subcommand:->subcommand' && ret=0
        case $state in
          (subcommand)
            _describe -t subcommands 'fossil subcommand' subcommands && ret=0
            ;;
        esac
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
