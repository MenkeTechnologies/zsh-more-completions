#compdef scale_slice_test
# Documentation: https://man.archlinux.org/search?q=scale_slice_test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:destination width:' \
  '3:destination height:' \
  '4:destination pixel format:' \
  '5::random seed:' && ret=0

return ret
