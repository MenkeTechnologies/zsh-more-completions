#compdef autopkgtest-build-qemu
# _autopkgtest-build-qemu — build QEMU VM image for autopkgtest (Debian/autopkgtest)
# upstream: https://salsa.debian.org/ci-team/autopkgtest
# Flags from autopkgtest-build-qemu(1) man page.

_autopkgtest-build-qemu() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mirror=[Debian-derivative mirror URL]:url:' \
        '--keyring=[keyring for apt repo verification]:file:_files' \
        '(--architecture --arch)--architecture=[dpkg architecture]:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '(--architecture --arch)--arch=[dpkg architecture (alias)]:arch:(amd64 i386 armhf arm64 ppc64el riscv64 s390x)' \
        '--script=[user customization script]:file:_files' \
        '--size=[VM image size]:size:' \
        '--boot=[boot mode (bios/efi)]:mode:(bios efi)' \
        '--efi[build EFI bootable image]' \
        '--apt-proxy=[apt proxy URL]:url:' \
        '*--qemu-options=[extra QEMU options]:opts:' \
        '1:release:(stable testing unstable bookworm trixie jammy noble)' \
        '2:image file:_files -g "*.qcow2"'
}

_autopkgtest-build-qemu "$@"
