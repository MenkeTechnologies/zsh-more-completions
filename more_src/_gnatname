#compdef gnatname
# Documentation: https://man.archlinux.org/search?q=gnatname
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-c+[output config file]:file:_files' \
  '-d+[scanned directory]:dir:_files -/' \
  '-D+[file with list of patterns]:file:_files' \
  '-f+[foreign pattern]:pattern:' \
  '-h[help]' \
  '-P+[project file to update]:file:_files -g "*.gpr"' \
  '-v[verbose]' \
  '-vP+[project verbosity]:level:(0 1 2)' \
  '-x+[exclude pattern]:pattern:' \
  '-X+[scenario var]:var=val:' \
  '*:naming-pattern:' && ret=0

return ret
