#compdef loopsy loopsy_session_list loopsy_context_set loopsy_context_get loopsy_file_transfer
# Documentation: https://man.archlinux.org/search?q=loopsy
# Reference accessed: 2026-05-16

_loopsy() {
    local line state
    local -a commands
    commands=(
        'peers:Manage peer machines'
        'shell:Run a shell session over local socket'
        'phone:Manage paired mobile devices'
    )

    if [[ $service == loopsy_session_list ]]; then
        return
    elif [[ $service == loopsy_context_set ]]; then
        _arguments '1:key:' '2:value:'
        return
    elif [[ $service == loopsy_context_get ]]; then
        _arguments '1:key:'
        return
    elif [[ $service == loopsy_file_transfer ]]; then
        _arguments '1:source:_files' '2:destination:'
        return
    fi

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'loopsy command' commands
            ;;
        args)
            case $line[1] in
                peers)
                    _arguments '1:subcommand:(add)' '2:ip:'
                    ;;
                phone)
                    _arguments '1:subcommand:(revoke)' '2:id:'
                    ;;
            esac
            ;;
    esac
}

_loopsy "$@"
