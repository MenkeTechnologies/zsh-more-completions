#compdef bnc
# Documentation: https://software.rtcm-ntrip.org/export/HEAD/ntrip/trunk/BNC/src/bnchelp.html
# BKG Ntrip Client: real-time GNSS stream client/processor

local ret=1

_arguments -s \
  '--conf[configuration file]:file:_files' \
  '-nw[run in no-window batch mode]' \
  '--file[input file for post-processing mode]:file:_files' \
  '-display[X display for batch-mode plots]:display' \
  '--platform[Qt platform plugin]:platform:(offscreen)' \
  '*--key[override configuration key (key value)]:key' \
  '--version[display BNC version number]' \
  '--help[command-line help]' && ret=0

return ret
