#compdef kotlinc-js
# Documentation: https://kotlinlang.org/docs/compiler-reference.html
# Reference accessed: 2026-05-19
# Verified: kotlinc-js 2.3.21 -help output + upstream compiler reference.

# Removed invented flags not present in kotlinc-js 2.3.21:
# -ir-produce-js, -ir-produce-klib-dir, -ir-produce-klib-file,
# -meta-info, -no-stdlib, -output, -output-postfix, -output-prefix.
# Fixed -target enum to (es5 es2015); added -Wextra, -script,
# -source-map-names-policy, -P, -kotlin-home, -J<opt>.
local -a arguments

arguments=(
  '-api-version[allow using declarations only from the specified version of bundled libraries]:version:'
  '-ir-output-dir[destination directory for generated files]:directory:_directories'
  '-ir-output-name[base name of generated files]:name:'
  '-libraries[paths to Kotlin libraries with .meta.js and .kjsm files]:libraries:_files'
  '-language-version[provide source compatibility with the specified version]:version:'
  '-kotlin-home[path to the home directory of Kotlin compiler]:path:_directories'
  '-main[specify whether the main function should be called]:call:(call noCall)'
  '-module-kind[kind of the JS module generated]:kind:(plain amd commonjs umd es)'
  '-nowarn[generate no warnings]'
  '-opt-in[enable usages of API that requires opt-in]:annotation:'
  '-P[pass an option to a plugin]:plugin option:'
  '-progressive[enable progressive compiler mode]'
  '-script[evaluate the given Kotlin script file]'
  '-source-map[generate source map]'
  '-source-map-base-dirs[base directories for calculating relative paths in source map]:dirs:_directories'
  '-source-map-embed-sources[embed source files into the source map]:mode:(always never inlining)'
  '-source-map-names-policy[mode for mapping generated names to original names]:policy:(no simple-names fully-qualified-names)'
  '-source-map-prefix[add the specified prefix to paths in the source map]:prefix:'
  '-target[generate JS files for specific ECMA version]:version:(es5 es2015)'
  '-verbose[enable verbose logging output]'
  '-version[display compiler version]'
  '-Werror[report an error on any compiler warning]'
  '-Wextra[enable extra checkers for K2]'
  '-X[print a synopsis of advanced options]'
  {-help,-h}'[print a synopsis of standard options]'
  '*-J-[pass an option directly to the JVM]:jvm option:'
  '*:source files:_files -g "*.kt(|s)"'
)

_arguments -s -S $arguments
