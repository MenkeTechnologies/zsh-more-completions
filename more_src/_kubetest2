#compdef kubetest2
# _kubetest2 — Kubernetes e2e test orchestrator (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from pkg/app/cmd.go (pflag).

_kubetest2() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--build[build kubernetes]' \
        '--up[provision the test cluster]' \
        '--down[tear down the test cluster]' \
        '--test=[test type to run (tester name)]:tester:(ginkgo exec node clusterloader2)' \
        '--skip-test-junit-report[skip JUnit reporting for the test step]' \
        '--run-id=[unique identifier for this run]:id:' \
        '--rundir-in-artifacts[place run-specific output in ARTIFACTS]' \
        '*--post-test-cmd=[command after tester (program,arg,...)]:cmd:' \
        '*--pre-test-cmd=[command after deployer but before tester]:cmd:' \
        '1:deployer:(gce gke kind noop)' \
        '*::deployer + tester args:_normal'
}

_kubetest2 "$@"
