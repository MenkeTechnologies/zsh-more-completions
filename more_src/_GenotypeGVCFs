#compdef GenotypeGVCFs
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/GenotypeGVCFs.java
# GATK4: perform joint genotyping on a gVCF or GenomicsDB workspace

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input gVCF, combined gVCF, or GenomicsDB]:file:_files' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[file to which variants should be written]:file:_files' \
  '(-D --dbsnp)'{-D,--dbsnp}'[dbSNP file to populate the ID column]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-all-sites --include-non-variant-sites)'{-all-sites,--include-non-variant-sites}'[include loci found to be non-variant]' \
  '(-keep-combined --keep-combined-raw-annotations)'{-keep-combined,--keep-combined-raw-annotations}'[keep combined raw annotations]' \
  '--only-output-calls-starting-in-intervals[restrict output to sites starting within intervals]' \
  '--force-output-intervals[sites at which to output genotypes even if non-variant]:intervals:_files' \
  '*:options:_files' && ret=0

return ret
