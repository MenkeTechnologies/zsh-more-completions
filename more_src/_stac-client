#compdef stac-client
# Documentation: https://pystac-client.readthedocs.io/en/stable/quickstart.html
# pystac-client CLI for searching STAC APIs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(search collections)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      search)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--bbox=[bounding box (minx miny maxx maxy)]:bbox' \
          '--datetime=[datetime or range (YYYY-MM-DD/YYYY-MM-DD)]:datetime' \
          '*-c[collection(s) to search]:collection' \
          '--query=[property filter (<property><op><value>)]:query' \
          '--max-items=[stop paging after this many items]:n' \
          '--matched[only fetch the total number of matches]' \
          '--save=[save results to file instead of stdout]:file:_files' \
          '1:stac api url:_urls' && ret=0
        ;;
      collections)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--q=[free-text search term]:term' \
          '--bbox=[bounding box (minx miny maxx maxy)]:bbox' \
          '--matched[only fetch the total number of matches]' \
          '1:stac api url:_urls' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
