#compdef dxfinfo
# Documentation: https://qcad.org/en/qcad-command-line-tools
# QCAD: list layers, blocks, or entity counts from DXF/DWG files

local ret=1

_arguments -s -S \
  '(-b -blocklist)'{-b,-blocklist}'[list all block names]' \
  '(-l -layerlist)'{-l,-layerlist}'[list all layer names]' \
  '(-e -entities)'{-e,-entities}'[output number of entities in file]' \
  '(-h -help)'{-h,-help}'[display help information]' \
  '*:DXF/DWG file:_files -g "*.(dxf|dwg|DXF|DWG)"' && ret=0

return ret
