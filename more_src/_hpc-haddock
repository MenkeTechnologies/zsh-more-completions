#compdef hpc-haddock
# Documentation: https://man.archlinux.org/search?q=hpc-haddock
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:hpc file:_files -g "*.hpc"' && ret=0

return ret
