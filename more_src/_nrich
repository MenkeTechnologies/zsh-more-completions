#compdef nrich
# Documentation: https://gitlab.com/shodan-public/nrich
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# nrich: command-line tool to enrich IPs via Shodan InternetDB API.

_arguments -s -S \
  '(-o --output)'{-o+,--output=}'[output format]:format:(shell json ndjson)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':file (use - for stdin):_files'
