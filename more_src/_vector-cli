#compdef vector-cli vector

# Vector: high-perf observability data pipeline
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'validate:validate a configuration'
  'generate:generate a sample config'
  'graph:render config as DOT graph'
  'list:list components'
  'top:terminal-based metrics UI'
  'tap:tap into a running Vector pipeline'
  'test:run unit tests on transforms'
  'config:show effective configuration'
  'vrl:run VRL REPL'
  'completion:emit shell completion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[config file]:file:_files -g "*.(toml|yaml|yml|json)"' \
  '--config=[config file]:file:_files -g "*.(toml|yaml|yml|json)"' \
  '--config-toml=[TOML config file]:file:_files -g "*.toml"' \
  '--config-yaml=[YAML config file]:file:_files -g "*.(yaml|yml)"' \
  '--config-json=[JSON config file]:file:_files -g "*.json"' \
  '--config-dir=[config directory]:dir:_files -/' \
  '-w[watch config (reload on change)]' \
  '--watch-config[watch config (reload on change)]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '--no-graceful-shutdown-limit[disable graceful shutdown limit]' \
  '--graceful-shutdown-limit-secs=[graceful shutdown limit secs]:s:' \
  '-l[log level]:level:(trace debug info warn error off)' \
  '--log-level=[log level]:level:(trace debug info warn error off)' \
  '--color=[color output]:val:(auto always never)' \
  '--allocation-tracing[enable allocation tracing]' \
  '--require-healthy[require healthy startup]' \
  '--threads=[runtime worker threads]:n:' \
  '-t[runtime worker threads]:n:' \
  '--internal-log-rate-limit=[internal log rate limit]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'vector command' commands && ret=0 ;;
esac
return ret
