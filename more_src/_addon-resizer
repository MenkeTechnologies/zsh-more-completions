#compdef addon-resizer pod-nanny
# _addon-resizer — Kubernetes autoscaler addon-resizer (pod-nanny)
# upstream: https://github.com/kubernetes/autoscaler
# Flags from addon-resizer/main.go on tip.

_addon-resizer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cpu=[base CPU resource requirement]:qty:' \
        '--extra-cpu=[CPU added per node]:qty:' \
        '--memory=[base memory resource requirement]:qty:' \
        '--extra-memory=[memory added per node]:qty:' \
        '--storage=[base storage resource requirement]:qty:' \
        '--extra-storage=[storage added per node]:qty:' \
        '--scale-down-delay=[delay before scale-down]:dur:' \
        '--scale-up-delay=[delay before scale-up]:dur:' \
        '--recommendation-offset=[rewrite when within %% of recommended (0-100)]:n:' \
        '--acceptance-offset=[rewrite when deviation %% exceeds this (0-100)]:n:' \
        '--namespace=[ward namespace]:ns:' \
        '--deployment=[deployment being monitored]:name:' \
        '--pod=[pod to watch]:name:' \
        '--container=[container to watch]:name:' \
        '--poll-period=[poll period (ms)]:ms:' \
        '-v[klog verbosity level]:n:'
}

_addon-resizer "$@"
