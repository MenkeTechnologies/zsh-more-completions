#compdef update_lmod_system_cache_files
# Documentation: https://lmod.readthedocs.io/en/latest/130_spider_cache.html
# Lmod admin script: builds the system spider cache (spiderT.lua) for MODULEPATH

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[cache directory to write spider cache into]:cache dir:_files -/' \
  '-t[timestamp file marking last system update]:timestamp file:_files' \
  '*:MODULEPATH:_files -/' && ret=0

return ret
