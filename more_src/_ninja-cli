#compdef ninja-cli
# _ninja-cli — Ninja small fast build system CLI alias (Evan Martin / ninja-build, C++); custom argparse
# upstream: https://github.com/ninja-build/ninja

_ninja-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '-C+[change to dir before building]:dir:_files -/' \
        '-f+[input build file]:file:_files -g "build.ninja"' \
        '-j+[parallel jobs]:n:' \
        '-k+[keep going threshold]:n:' \
        '-l+[load average max]:f:' \
        '-n[dry run]' \
        '-d+[debug mode]:mode:(stats explain keepdepfile keeprsp nostatcache)' \
        '-t+[tool mode]:tool:(browse clean compdb deps graph inputs list missingdeps msvc path query recompact rules targets cleandead deps tool)' \
        '-w+[warning]:str:' \
        '*:target:'
}

_ninja-cli "$@"
