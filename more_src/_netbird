#compdef netbird

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'up:Connect to the NetBird network'
  'down:Disconnect from the NetBird network'
  'status:Show connection status'
  'login:Log in to the NetBird management service'
  'ssh:SSH to a remote peer'
  'routes:Manage routes'
  'version:Show version'
  'service:Manage the NetBird daemon service'
)

local -a global_flags
global_flags=(
  '(- *)--help[show help]'
  '(- *)--version[show version]'
  '--config=[path to config file]:file:_files'
  '--config-path=[path to config directory]:dir:_directories'
  '--daemon-addr=[daemon address]:addr:'
  '--log-level=[log level]:level:(panic fatal error warn info debug trace)'
  '--log-file=[path to log file]:file:_files'
)

_arguments -C \
  $global_flags \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'netbird command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      up)
        _arguments \
          $global_flags \
          '--setup-key=[setup key]:key:' \
          '--management-url=[management server URL]:url:' \
          '--admin-url=[admin panel URL]:url:' \
          '--preshared-key=[preshared key]:key:' \
          '--hostname=[hostname to use]:name:' \
          '--interface-name=[WireGuard interface name]:name:' \
          '--wireguard-port=[WireGuard UDP port]:port:' \
          '--disable-auto-connect[disable auto-connect on startup]' \
          '--dns-resolver-address=[DNS resolver address]:addr:' \
          '--external-ip-map=[external IP mapping]:mapping:' \
          '--disable-client-routes[disable client routes]' \
          '--enable-rosenpass[enable Rosenpass post-quantum security]' && ret=0
        ;;
      down)
        _arguments $global_flags && ret=0
        ;;
      status)
        _arguments \
          $global_flags \
          {-d,--detail}'[show detailed status]' \
          '--json[output in JSON format]' \
          '--yaml[output in YAML format]' \
          '--ipv4[show only IPv4 addresses]' \
          '--filter-by-ips=[filter by IP addresses]:ips:' \
          '--filter-by-names=[filter by peer names]:names:' \
          '--filter-by-status=[filter by connection status]:status:(connected disconnected)' \
          '--daemon-addr=[daemon address]:addr:' && ret=0
        ;;
      login)
        _arguments \
          $global_flags \
          '--setup-key=[setup key]:key:' \
          '--management-url=[management server URL]:url:' \
          '--admin-url=[admin panel URL]:url:' && ret=0
        ;;
      ssh)
        _arguments \
          $global_flags \
          {-p,--port}'=[SSH port]:port:' \
          '1:host:' && ret=0
        ;;
      service)
        local -a service_cmds
        service_cmds=(
          'install:Install the service'
          'uninstall:Uninstall the service'
          'start:Start the service'
          'stop:Stop the service'
        )
        _arguments -C \
          '1:subcommand:->servicecmd' && ret=0
        case "$state" in
          servicecmd)
            _describe -t commands 'service subcommand' service_cmds && ret=0
            ;;
        esac
        ;;
      *)
        _arguments $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
