#compdef pcsc-spy
# Documentation: https://manpages.debian.org/unstable/libpcsclite-dev/pcsc-spy.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcsc-spy: trace PC/SC API calls made by an application
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-d[remove variable parts for diffable output]' \
  '--diffable[remove variable parts for diffable output]' \
  '-n[disable output colorization]' \
  '--nocolor[disable output colorization]' \
  '-t[add thread number before each log line]' \
  '--thread[add thread number before each log line]' \
  '*::pcsc-spy args:_files' && ret=0
return ret
