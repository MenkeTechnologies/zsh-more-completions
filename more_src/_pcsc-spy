#compdef pcsc-spy

# pcsc-spy: log PC/SC API calls made by other PC/SC clients
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[output decoder version]' \
  '-h[show help]' \
  '-v[verbose output]' \
  '-t[show timing]' \
  '-n[do not block]' \
  '*::pcsc-spy args:_files' && ret=0
return ret
