#compdef pcsc-spy
# Documentation: https://pcsclite.apdu.fr/pcsc-spy.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pcsc-spy: trace PC/SC API calls made by an application
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-t[show timestamps]' \
  '-d[diff against previous run]' \
  '-n[execution number]:n:' \
  '-l[log file]:file:_files' \
  '*::pcsc-spy args:_files' && ret=0
return ret
