#compdef bdftogd
# Documentation: https://manpages.debian.org/bookworm/libgd-tools/bdftogd.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bdftogd: libgd tool converting BDF font files to GD format

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:font name:' \
  '2:bdf file:_files -g "*.bdf"' && ret=0

return ret
