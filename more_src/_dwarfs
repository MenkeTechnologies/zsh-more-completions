#compdef dwarfs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '-o+[FUSE/mount options]:options:' \
  '--cache-size+[block cache size]:size:' \
  '--readahead+[readahead size]:size:' \
  '--workers+[number of worker threads]:threads:' \
  '--mlock+[mlock mode]:mode:(none try must)' \
  '--decompress-ratio+[decompression ratio]:ratio:' \
  '--image-offset+[offset into image file]:offset:(auto)' \
  '--enable-nlink[enable nlink support]' \
  '--readonly[mount read-only]' \
  '--debuglevel+[debug level]:level:(error warn info debug trace)' \
  '(-s --single-threaded)'{-s,--single-threaded}'[run single-threaded]' \
  '1:image file:_files' \
  '2:mount point:_files -/' && ret=0

return ret
