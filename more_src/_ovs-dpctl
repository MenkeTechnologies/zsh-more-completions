#compdef ovs-dpctl
# Documentation: https://man7.org/linux/man-pages/man8/ovs-dpctl.8.html
# Reference accessed: 2026-05-16
# Verified: Linux man-pages ovs-dpctl(8). All subcommands and global
# flags match upstream.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add-dp:add datapath'
  'del-dp:delete datapath'
  'add-if:add interface'
  'set-if:set interface options'
  'del-if:remove interface'
  'dump-dps:list datapaths'
  'show:show datapath info'
  'dump-flows:dump flow table'
  'add-flow:add flow'
  'mod-flow:modify flow'
  'add-flows:add flows from file'
  'mod-flows:modify flows from file'
  'del-flow:delete flow'
  'del-flows:delete flows from file'
  'get-flow:get specific flow'
  'cache-get-size:get flow cache size'
  'cache-set-size:set flow cache size'
  'ipf-set-enabled:enable IP fragmentation'
  'ipf-set-disabled:disable IP fragmentation'
  'ipf-set-min-frag:set min frag size'
  'ipf-set-max-nfrags:set max nfrags'
  'ipf-get-status:get IP frag status'
  'dump-conntrack:dump conntrack table'
  'dump-conntrack-exp:dump conntrack expectations'
  'flush-conntrack:flush conntrack'
  'ct-stats-show:show conntrack stats'
  'ct-bkts:show conntrack buckets'
  'ct-set-maxconns:set max connections'
  'ct-get-maxconns:get max connections'
  'ct-get-nconns:get current connection count'
  'ct-enable-tcp-seq-chk:enable TCP seq check'
  'ct-disable-tcp-seq-chk:disable TCP seq check'
  'ct-get-tcp-seq-chk:get TCP seq check state'
  'ct-set-sweep-interval:set sweep interval'
  'ct-get-sweep-interval:get sweep interval'
  'ct-set-limits:set conntrack limits'
  'ct-del-limits:delete conntrack limits'
  'ct-get-limits:get conntrack limits'
)

_arguments -C \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '*'{-v,--verbose=}'[verbosity]:spec:' \
  '--log-file=[log file]:file:_files' \
  '--syslog-target=[syslog target]:host:port:' \
  '--syslog-method=[syslog method]:method:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovs-dpctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (show|mod-flow|del-flow|dump-conntrack)
        _arguments \
          '(-s --statistics)'{-s,--statistics}'[show statistics]' && ret=0
        ;;
      (dump-flows|get-flow|ipf-get-status|ct-stats-show)
        _arguments \
          '(-m --more)'{-m,--more}'[more verbose]' \
          '--names[show names]' \
          '--no-names[no names]' && ret=0
        ;;
    esac
    ;;
esac

return ret
