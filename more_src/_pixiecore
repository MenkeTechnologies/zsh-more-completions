#compdef pixiecore
# _pixiecore — all-in-one network booting tool (danderson/netboot)
# upstream: https://github.com/danderson/netboot
# Subcommands from pixiecore/cli/*.go (cobra).

_pixiecore() {
    local context state state_descr line
    typeset -A opt_args

    local -a server_opts=(
        '(-d --debug)'{-d,--debug}'[log more details]'
        '(-t --log-timestamps)'{-t,--log-timestamps}'[add timestamp to log lines]'
        '(-l --listen-addr)'{-l+,--listen-addr=}'[IPv4 address to listen on]:addr:'
        '(-p --port)'{-p+,--port=}'[HTTP port (default 80)]:port:'
        '--status-port=[HTTP port for status info]:port:'
        '--dhcp-no-bind[handle DHCP without binding to server port]'
        '--ipxe-bios=[iPXE binary for BIOS/UNDI]:file:_files'
        '--ipxe-ipxe=[iPXE binary for chainloading]:file:_files'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'boot:boot a kernel and optional initrds'
                'quick:quick boot using a built-in recipe'
                'api:run the Pixiecore API server'
                'ipv6boot:boot via IPv6'
                'ipv6api:run IPv6 API server'
                'debug:debug network booting'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                boot)
                    _arguments \
                        $server_opts \
                        '--cmdline=[kernel commandline]:cmdline:' \
                        '--bootmsg=[message to print before boot]:msg:' \
                        '1:kernel:_files' \
                        '*:initrd:_files'
                    ;;
                quick)
                    _arguments \
                        $server_opts \
                        '--cmdline=[kernel commandline]:cmdline:' \
                        '--bootmsg=[message to print before boot]:msg:' \
                        '1:recipe:(debian ubuntu fedora centos coreos arch xyz)' \
                        '*:settings:'
                    ;;
                api)
                    _arguments \
                        $server_opts \
                        '--api-request-timeout=[API request timeout]:duration:' \
                        '1:server URL:'
                    ;;
            esac
            ;;
    esac
}

_pixiecore "$@"
