#compdef emmax-kin
# Documentation: https://genome.sph.umich.edu/wiki/EMMAX
# EMMAX kinship matrix computation (Balding-Nichols or IBS)

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose mode]' \
  '-d[precision of kinship values]:digits' \
  '-s[compute IBS kinship matrix]' \
  '-r[randomly fill missing genotypes]' \
  '-x[include non-autosomal chromosomes]' \
  '-S[set random seed]:seed' \
  '-M[maximum memory in GB]:gb' \
  '-m[MAF threshold]:maf' \
  '-c[call rate threshold]:rate' \
  '*:tped prefix:_files' && ret=0

return ret
