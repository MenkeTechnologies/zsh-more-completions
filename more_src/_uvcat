#compdef uvcat
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvcat.html
# MIRIAD uvcat - concatenate and copy uv data

local ret=1

_arguments -s -S \
  'vis=[input uv dataset names]:vis:_files' \
  'select=[uv selection commands]:select' \
  'stokes=[output polarizations]:stokes' \
  'out=[output uv dataset name]:out:_files' \
  'options=[nocal,nopass,nopol,nowide,nochannel,unflagged]:options' \
  '*:visibility data:_files' && ret=0

return ret
