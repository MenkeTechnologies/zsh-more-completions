#compdef dhcrelay6
# Documentation: https://man.archlinux.org/search?q=dhcrelay6
# Reference accessed: 2026-05-16

# dhcrelay6: ISC DHCPv6 relay
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[run in foreground]' \
  '-q[quiet]' \
  '-c[max hops]:n:' \
  '-l[lower interface]:iface:' \
  '-u[upper interface]:iface:' \
  '-I[interface-id option]:id:' \
  '-P[append remote-id option]:str:' \
  '-pf[PID file]:file:_files' \
  '--no-pid[no PID file]' \
  '*:server addr:' && ret=0
return ret
