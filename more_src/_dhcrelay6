#compdef dhcrelay6
# Documentation: https://manpages.debian.org/bookworm/isc-dhcp-relay/dhcrelay.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcrelay6: ISC DHCP relay in DHCPv6 mode (alias for `dhcrelay -6`).
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[run as foreground process]' \
  '-q[quiet mode]' \
  '-c+[maximum hop count]:count' \
  '-I[force use of DHCPv6 Interface-ID option]' \
  '-s+[add subscriber ID option]:subscriber-id' \
  '-l+[lower (client-facing) interface]:iface' \
  '-u+[upper (server-facing) interface]:iface' \
  '-p+[port to listen/transmit on]:port' \
  '-pf+[alternate pid file path]:file:_files' \
  '--no-pid[do not write pid file]' \
  '*:server addr:' && ret=0
return ret
