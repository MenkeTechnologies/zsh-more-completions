#compdef tcpping
# Documentation: https://github.com/deajan/tcpping/blob/master/tcpping
# tcpping - measure latency via the TCP handshake using traceroute

local ret=1

_arguments -s \
  '-d[print timestamp before every result]' \
  '-c[print computer-parsable result line]' \
  '-C[print in fping -C format]' \
  '-w+[wait time in seconds]:seconds' \
  '-r+[repeat interval in seconds]:seconds' \
  '-x+[repeat n times]:count' \
  '-f+[first TTL]:ttl' \
  '-m+[max TTL]:ttl' \
  '-i+[interface passed to traceroute]:interface:_net_interfaces' \
  '-s+[source port passed to traceroute]:port' \
  '-M+[protocol method passed to traceroute]:method:(tcp udp icmp)' \
  '-Z[run traceroute with sudo]' \
  '-z[debug mode; display the actual traceroute command]' \
  '-o[output ping-like statistics]' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '1:host:_hosts' \
  '2:port:_ports' && ret=0

return ret
