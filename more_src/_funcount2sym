#compdef funcount2sym funtrace2viz
# Documentation: source-direct extraction from upstream
# yosefk/funtrace Cargo.toml workspace `members = ["procaddr2sym",
# "funcount2sym", "funtrace2viz"]` + each member's
# `src/main.rs` clap-derive `Cli` struct (where applicable) or
# `env::args()` parsing. The 3rd workspace member procaddr2sym
# has only `src/lib.rs` (no `main.rs`) so it is a LIBRARY crate,
# not a binary - deliberately omitted from the #compdef line.
# Reference accessed: 2026-05-30 via gh api.
# yosefk/funtrace R149 — fast, small C/C++ function call tracer
# for x86-64/Linux supporting clang & gcc, ftrace integration,
# threads, exceptions, and shared libraries. Sister to the
# heavily-covered tracing family (bpftrace/bpftool/uftrace/
# trace-cmd/lttng/perf/dtrace).

case $service in

  funcount2sym)
    # Minimal Rust binary that uses env::args() (NOT clap) per
    # upstream `if args.len() != 2 { fail!("Usage: {}
    # <funcount.txt> # counts with function names printed to
    # stdout, pipe through c++filt if you want to demangle the
    # symbols", args[0]); }` -- single positional, no flags.
    _arguments -s -S \
      '1:funcount.txt file (FUNCOUNT+PROCMAPS+COUNTS format):_files -g "*.txt"'
    ;;

  funtrace2viz)
    # Convert funtrace.raw output to viztracer/vizviewer/Perfetto-
    # compatible JSON. 7 clap-derive flags + 2 positional arguments
    # decoded from `struct Cli { ... }` in funtrace2viz/src/main.rs.
    _arguments -s -S \
      '(-e --executable-file-info)'{-e,--executable-file-info}'[also print static addresses and executable/.so files of decoded functions]' \
      '(-r --raw-timestamps)'{-r,--raw-timestamps}'[print raw timestamps (default subtracts earliest event to start at 0)]' \
      '(-m --max-event-age)'{-m+,--max-event-age=}'[ignore events older than this (cycles) relative to latest event]:cycles:' \
      '(-o --oldest-event-time)'{-o+,--oldest-event-time=}'[ignore events older than this absolute cycle timestamp]:cycle:' \
      '(-d --dry)'{-d,--dry}'[dry run - list samples + threads with basic stats, do not decode to JSON]' \
      '*'{-s+,--samples=}'[ignore samples with indexes outside this list (repeatable)]:sample-idx:' \
      '*'{-t+,--threads=}'[ignore threads with TIDs outside this list (repeatable)]:tid:' \
      '1:funtrace.raw input file:_files -g "*.raw"' \
      '2:output JSON basename (basename.json, basename.1.json...):'
    ;;

esac
