#compdef pslLiftSubrangeBlat
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: lift PSLs from blat subrange alignments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-tSizes=[lift target side using these target sizes]:file:_files' \
  '-qSizes=[lift query side using these query sizes]:file:_files' \
  ':in psl:_files' \
  ':out psl:_files' && ret=0

return ret
