#compdef databend-metactl
# Documentation: https://github.com/databendlabs/databend/blob/main/src/meta/control/src/args.rs
# Databend meta-service control tool: export/import/status of databend-meta clusters

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--log-level=[log level]:level' \
  '--grpc-api-address=[gRPC API address of the meta node]:address' \
  '--raft-dir=[dir to store persisted meta state]:dir:_files -/' \
  '--db=[name of the export/import db file]:file:_files' \
  '--initial-cluster=[initial cluster node_id=endpoint mapping]:node' \
  '--id=[node id]:id' \
  '--export-chunk-size=[number of json strings per export stream item]:size' \
  '1:command:((
    status\:"show cluster status: node info, replication, voters"
    export\:"export metadata from a running node or local raft-dir"
    import\:"import metadata into a new raft-dir from stdin or file"
    filter-tenant\:"filter an exported dump keeping only one tenant"
    keys-layout\:"dump state machine keys grouped by prefix"
    transfer-leader\:"transfer raft leadership to another node"
    trigger-snapshot\:"trigger a state machine snapshot"
    set-feature\:"enable or disable a feature flag"
    list-features\:"list feature flags"
    bench-client-num-conn\:"benchmark client connections"
    watch\:"watch key changes by prefix"
    upsert\:"upsert a key/value pair"
    get\:"get the value of a key"
    lua\:"run a lua script"
    member-list\:"list cluster members"
    metrics\:"show meta service metrics"
    dump-raft-log-wal\:"dump the raft log WAL"
  ))' \
  '*::arg:->args' && ret=0

return ret
