#compdef suztot
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/stretching_moveout_resamp/suztot.c
# Resample from depth to time

local ret=1

_arguments -s -S \
  'nt=[number of time samples in output]:nt' \
  'dt=[time sampling interval]:dt' \
  'ft=[first time sample]:ft' \
  'z=[depths corresponding to interval velocities in v]:z' \
  'v=[interval velocities corresponding to depths in z]:v' \
  'vfile=[binary file containing velocities v(z)]:vfile:_files' \
  'verbose=[>0 to print depth sampling information]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
