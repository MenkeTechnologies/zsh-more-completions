#compdef xlsclients
# _xlsclients — X.Org xlsclients list X11 client applications running on display (X.Org team, C); custom argparse
# upstream: https://gitlab.freedesktop.org/xorg/app/xlsclients

_xlsclients() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-display+[X display]:display:' \
        '-a[show all screens]' \
        '-l[long format]' \
        '-m+[max length]:n:'
}

_xlsclients "$@"
