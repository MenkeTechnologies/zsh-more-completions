#compdef otbcli_SampleExtraction
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_SampleExtraction.html
# Orfeo ToolBox: extract pixel values at sample positions from an image

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[support image]:image:_files' \
  '-vec[vector data file with sampling positions]:vector:_files' \
  '-out[output vector data file of sample values]:output:_files' \
  '-outfield[naming method for output fields]:method:(prefix list)' \
  '-outfield.prefix.name[prefix to form field names]:name:' \
  '-outfield.list.names[full list of output field names]:names:' \
  '-field[field carrying the class name]:name:' \
  '-layer[layer index to read]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
