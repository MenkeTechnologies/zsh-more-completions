#compdef elastic-package

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build packages'
  'check:lint + build a package'
  'lint:validate package contents and README'
  'format:format package JSON/YAML'
  'test:run package tests'
  'install:install a package in Kibana'
  'uninstall:uninstall a package from Kibana'
  'create:scaffold a new package or data stream'
  'changelog:manage package changelog entries'
  'clean:remove build artifacts and stack resources'
  'modify:apply improvements/best-practices'
  'stack:manage Elastic stack docker instances'
  'service:manage observed services for tests'
  'dump:extract resources from a stack'
  'export:export dashboards/pipelines from Kibana'
  'edit:open dashboards for editing'
  'benchmark:run pipeline/rally/streams/system benchmarks'
  'report:generate benchmark reports'
  'status:show package deployment status'
  'profiles:manage configuration profiles'
  'links:manage linked file references'
  'find:locate packages matching criteria'
  'foreach:run a subcommand across many packages'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --profile)'{-p+,--profile=}'[profile to use]:profile:' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--check-update[check for updates]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'elastic-package command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (test)
        _arguments \
          '*::sub:(asset pipeline static system script policy)' \
          '(-d --defer-cleanup)'{-d+,--defer-cleanup=}'[defer cleanup]:duration:' \
          '--report-format=[report format]:format:(human xUnit junit)' \
          '--report-output=[report output target]:target:(stdout file)' \
          '--coverage[generate coverage report]' \
          '--data-streams=[comma-separated data streams]:streams:' \
          '--variant=[test variant]:variant:' \
          '--no-provision[skip provisioning]' && ret=0 ;;
      (build)
        _arguments \
          '--zip[build zip file]' \
          '--sign[sign built package]' \
          '--key-id=[GPG key id for signing]:key:' && ret=0 ;;
      (install)
        _arguments \
          '--zip=[zip file path]:file:_files -g "*.zip"' \
          '--root[install with root privileges]' && ret=0 ;;
      (stack)
        local -a stack_subs=(
          'up:start the local stack'
          'down:stop the local stack'
          'status:show stack status'
          'update:update images'
          'shellinit:emit env vars for the stack'
          'dump:dump stack data'
        )
        _describe -t stcmds 'stack subcommand' stack_subs && ret=0
        _arguments \
          '(-V --version)'{-V+,--version=}'[stack version]:version:' \
          '--services=[comma-separated services]:list:' && ret=0 ;;
      (service)
        _arguments '*::sub:(up down)' && ret=0 ;;
      (create)
        _arguments '*::sub:(package data-stream)' && ret=0 ;;
      (changelog)
        _arguments '*::sub:(add fix)' && ret=0 ;;
      (profiles)
        _arguments '*::sub:(create list delete use)' && ret=0 ;;
      (export)
        _arguments \
          '*::sub:(dashboards transforms ingest-pipelines)' \
          '--id=[object id]:id:' \
          '--data-stream=[data stream name]:ds:' && ret=0 ;;
      (dump)
        _arguments \
          '*::sub:(agent-policies installed-objects)' \
          '--output=[output dir]:dir:_files -/' && ret=0 ;;
      (benchmark)
        _arguments '*::sub:(pipeline rally stream system)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
