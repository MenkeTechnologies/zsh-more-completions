#compdef haxedoc dox
# _haxedoc — Haxe Project haxedoc CLI Haxe documentation generator integrating with the dox library reading the Haxe compiler XML AST emitting cross-referenced HTML JSON Markdown API reference per-class per-method type-signature-resolution rich-search-index for Haxe-cpp Haxe-js Haxe-php Haxe-cs targets (Haxe Foundation team, Haxe); custom argparse
# upstream: https://haxe.org/

_haxedoc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[input xml]:file:_files -g "*.xml"' \
        '--input=+[file]:file:_files -g "*.xml"' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-t+[theme]:str:' \
        '--theme=+[theme]:str:' \
        '--title=+[title]:str:' \
        '--toplevel-package=+[name]:str:' \
        '--include=+[pattern]:str:' \
        '--exclude=+[pattern]:str:' \
        '--keep-field-order[keep field order]' \
        '--no-folders[do not generate folders]' \
        '--platform=+[p]:p:(cpp cs java js neko php python lua flash hl)' \
        '--macro=+[expr]:str:' \
        '--include-private[include private]' \
        '--no-resolve[do not resolve type references]' \
        '--no-mappings[do not add file mappings]' \
        '--unfold-vars[unfold vars]' \
        '-r+[resource]:dir:_files -/' \
        '--resource=+[dir]:dir:_files -/' \
        '*::'
}

_haxedoc "$@"
