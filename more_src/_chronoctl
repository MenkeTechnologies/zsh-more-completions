#compdef chronoctl
# Documentation: https://docs.chronosphere.io/tooling/chronoctl
# Reference accessed: 2026-05-23
# Verified: Chronosphere chronoctl docs (apply, auth, resource CRUD).

# Zsh completion for chronoctl - Chronosphere Observability Platform CLI

local curcontext="$curcontext" state line ret=1
local -a resources

resources=(
  'dashboards:Chronosphere dashboards'
  'monitors:monitors'
  'collections:collections'
  'buckets:buckets'
  'teams:teams'
  'notifiers:notifiers'
  'recording-rules:recording rules'
  'rollup-rules:rollup rules'
  'drop-rules:drop rules'
  'muting-rules:muting rules'
  'notification-policies:notification policies'
  'service-accounts:service accounts'
  'derived-metrics:derived metrics'
  'derived-labels:derived labels'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json jsonl yaml)' \
  '--timeout[request timeout seconds]:seconds:' \
  '(-d --dry-run)'{-d,--dry-run}'[simulate changes]' \
  '--no-strict[allow unknown manifest fields]' \
  '--api-token[API token]:token:' \
  '--api-token-filename[token file]:file:_files' \
  '--org-name[organization name]:org:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'chronoctl command' \
      'apply[apply manifest file]' \
      'auth[authenticate session]' \
      'completion[generate shell completion]' \
      'help[show help]' \
      'version[show version]' \
      'rule-evaluations[rule evaluations]' \
      'metric-usages-by-metric-name[metric usage by name]' \
      'metric-usages-by-label-name[metric usage by label]' && ret=0
    ;;
  args)
    case $line[1] in
      (apply)
        _arguments '(-f --file)'{-f+,--file=}'[manifest file]:file:_files' && ret=0
        ;;
      (auth)
        _values 'auth command' \
          'login[login]' \
          'logout[logout]' \
          'whoami[whoami]' \
          'list-users[list users]' \
          'print-session-id[print session id]' \
          'set-default-org[set default org]' && ret=0
        ;;
      (*)
        _arguments '1:resource:->res' '*:: :->sub' && ret=0
        ;;
    esac
    ;;
  res)
    _describe -t resources resource resources && ret=0
    ;;
  sub)
    _values 'resource action' create delete list read scaffold update && ret=0
    ;;
esac

return ret
