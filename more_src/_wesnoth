#compdef wesnoth

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--all-translations)--all-translations[show all translations]' \
  '(-c --campaign)'{-c,--campaign}'+[campaign]:id:' \
  '(--campaign-difficulty)--campaign-difficulty=+[difficulty]:n:' \
  '(--campaign-scenario)--campaign-scenario=+[start scenario]:id:' \
  '(--clock)--clock[show in-game clock]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(--debug-lua)--debug-lua[debug Lua]' \
  '(-D --debug-strict-lua)'{-D,--debug-strict-lua}'[strict Lua]' \
  '(--editor)--editor[start map editor]:file:_files -g "*.{map,cfg}"' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(--fps)--fps[show FPS]' \
  '(--gunzip)--gunzip=+[gunzip file]:file:_files -g "*.{gz,bz2,xz}"' \
  '(--gzip)--gzip=+[gzip file]:file:_files' \
  '(-l --load)'{-l,--load}'+[load saved game]:file:_files' \
  '(--language)--language=+[language]:locale:' \
  '(--log-error)--log-error=+[error log level]:domain:' \
  '(--log-warning)--log-warning=+[warning log level]:domain:' \
  '(--log-info)--log-info=+[info log level]:domain:' \
  '(--log-debug)--log-debug=+[debug log level]:domain:' \
  '(--logdomains)--logdomains[list log domains]' \
  '(--max-fps)--max-fps=+[max FPS]:n:' \
  '(--multiplayer)--multiplayer[start multiplayer game]' \
  '(--scenario)--scenario=+[scenario]:id:' \
  '(-r --resolution)'{-r,--resolution}'+[resolution WxH]:WxH:' \
  '(--report)--report[generate problem report]' \
  '(--rng-seed)--rng-seed=+[RNG seed]:n:' \
  '(--render-image)--render-image=+[render image]:file:_files' \
  '(--screenshot)--screenshot[take screenshot]' \
  '(--server)--server=+[server host]:host:_hosts' \
  '(--strict-validation)--strict-validation[strict validation]' \
  '(--username)--username=+[username]:user:' \
  '(--password)--password=+[password]:pw:' \
  '(--validcache)--validcache[validate cache]' \
  '(-w --windowed)'{-w,--windowed}'[windowed]' \
  '(--with-replay)--with-replay[record replay]' && ret=0

return ret
