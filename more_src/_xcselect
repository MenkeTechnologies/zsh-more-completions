#compdef xcselect
# _xcselect — xcselect Xcode version chooser; wraps xcode-select with interactive picker for installed versions
# upstream: community shim around xcode-select

_xcselect() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-l --list)'{-l,--list}'[list installed Xcode versions]' \
        '(-p --print-path)'{-p,--print-path}'[print active developer dir]' \
        '(-r --reset)'{-r,--reset}'[reset to system default]' \
        '(-s --set)'{-s,--set}'+[set version]:version:' \
        '(-i --install)'{-i,--install}'[trigger install of CLT]' \
        '*:Xcode app:_files -g "*.app"'
}

_xcselect "$@"
