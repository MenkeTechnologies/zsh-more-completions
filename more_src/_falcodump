#compdef falcodump
# Documentation: https://www.wireshark.org/docs/man-pages/falcodump.html
# Dump log data to a file using a Falco source plugin

local ret=1

_arguments -s -S \
  '--help[display program arguments and plugin configuration options]' \
  '--version[show the program version]' \
  '--plugin-api-version[display the Falco plugin API version]' \
  '--extcap-interfaces[list available interfaces]' \
  '--extcap-interface=[specify which interface to use]:interface:' \
  '--extcap-dlts[list DLTs for the specified interface]' \
  '--extcap-config[show configuration options for specified interface]' \
  '--extcap-capture-filter=[valid Sysdig / Falco filter]:filter:' \
  '--capture[begin capturing from the specified source and write to FIFO]' \
  '--fifo=[save captured packet to file or send through pipe]:path:_files' \
  '--plugin-source=[capture from the specified location]:source:' \
  '--log-level=[configure logging verbosity]:level:' \
  '--log-file=[file for logging in addition to console output]:path:_files' \
  '--include-capture-processes=[include syscalls for capture processes]:value:(TRUE FALSE)' \
  '--include-switch-calls=[include switch calls]:value:(TRUE FALSE)' \
  '--cloudtrail-s3downloadconcurrency=[background goroutines to download S3 files]:number:' \
  '--cloudtrail-s3interval=[download logs over specified timeframe]:timeframe:' \
  '--cloudtrail-s3accountlist=[account IDs for organization CloudTrail buckets]:ids:' \
  '--cloudtrail-sqsdelete=[delete SQS messages immediately after receiving]:value:(true false)' \
  '--cloudtrail-useasync=[enable async extraction optimization]:value:(true false)' \
  '--cloudtrail-uses3sns=[expect SNS messages to originate from S3]:value:(true false)' \
  '--cloudtrail-aws-region=[override the AWS region setting]:region:' \
  '--cloudtrail-aws-profile=[override the AWS shared configuration profile]:profile:' \
  '--cloudtrail-aws-config=[override AWS shared configuration filepath]:path:_files' \
  '--cloudtrail-aws-credentials=[override AWS shared credentials filepath]:path:_files' && ret=0

return ret
