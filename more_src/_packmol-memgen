#compdef packmol-memgen
# Documentation: https://ambermd.org/AmberTools.php
# build membrane-protein-lipid-bilayer systems for Amber

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pdb[input protein PDB file]:file:_files -g "*.pdb"' \
  '--lipids[lipid composition, e.g. POPC:CHL1]:lipids:' \
  '--ratio[lipid ratio, e.g. 9:1]:ratio:' \
  '--dist[distance to box edge in X and Y axis (Angstrom)]:dist:' \
  '--dist_wat[water-layer distance in Z axis (Angstrom)]:dist:' \
  '--preoriented[input protein is already oriented for the membrane]' \
  '--salt[add salt ions to the water layer]' \
  '--salt_c[salt cation type, e.g. Na+]:cation:' \
  '--salt_a[salt anion type, e.g. Cl-]:anion:' \
  '--saltcon[salt concentration in molar]:conc:' \
  '--notprotonate[skip protonation of the input PDB]' \
  '--nottrim[do not trim the input receptor coordinates]' \
  '--parametrize[generate parameterized files for the bilayer system]' && ret=0

return ret
