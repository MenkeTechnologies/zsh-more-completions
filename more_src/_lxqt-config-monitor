#compdef lxqt-config-monitor
# Documentation: https://github.com/lxqt/lxqt-config/blob/master/lxqt-config-monitor/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --loadlast)'{-l,--loadlast}'[load last settings]' && ret=0

return ret
