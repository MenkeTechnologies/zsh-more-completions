#compdef prettierd
# Documentation: https://github.com/fsouza/prettierd
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: prettierd reads file content on stdin and takes the filename as its
# single positional argument (e.g. `cat file.ts | prettierd file.ts`); it does
# not expose the full prettier flag surface.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:filename:_files' && ret=0

return ret
