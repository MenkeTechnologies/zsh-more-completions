#compdef prettierd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--arrow-parens=[arrow function parentheses]:style:(always avoid)' \
  '--bracket-same-line[put > on same line in HTML/JSX]' \
  '--bracket-spacing[print spaces between brackets in object literals]' \
  '--no-bracket-spacing[no spaces between brackets]' \
  '--end-of-line=[line ending style]:eol:(lf crlf cr auto)' \
  '--html-whitespace-sensitivity=[HTML whitespace sensitivity]:sensitivity:(css strict ignore)' \
  '--jsx-single-quote[use single quotes in JSX]' \
  '--parser=[parser to use]:parser:(babel babel-flow babel-ts flow typescript espree meriyah acorn css less scss html angular vue graphql markdown mdx yaml json json5 json-stringify)' \
  '--print-width=[line width]:width' \
  '--prose-wrap=[prose wrapping]:wrap:(always never preserve)' \
  '--quote-props=[quote object properties]:style:(as-needed consistent preserve)' \
  '--no-semi[do not print semicolons]' \
  '--semi[print semicolons]' \
  '--single-attribute-per-line[enforce single attribute per line in HTML/JSX]' \
  '--single-quote[use single quotes]' \
  '--tab-width=[tab width]:width' \
  '--trailing-comma=[trailing commas]:style:(all es5 none)' \
  '--use-tabs[indent with tabs]' \
  '--stdin-filepath=[path for stdin]:filepath:_files' \
  '--cache[only format changed files]' \
  '--cache-location=[path to cache file]:cache file:_files' \
  '--cache-strategy=[cache strategy]:strategy:(metadata content)' \
  '--check[check if files are formatted]' \
  '(-l --list-different)'{-l,--list-different}'[list files that differ from formatting]' \
  '--config=[config file]:config file:_files' \
  '--no-config[do not look for config file]' \
  '--ignore-path=[ignore file]:ignore file:_files' \
  '--no-error-on-unmatched-pattern[no errors for unmatched patterns]' \
  '--write[write formatted files in-place]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
