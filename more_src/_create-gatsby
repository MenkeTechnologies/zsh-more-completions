# Zsh completion for create-gatsby - Gatsby site scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-y[skip prompts and use defaults]' \
  '-ts[use TypeScript template]' \
  ':site directory:_directories' && ret=0

return ret
