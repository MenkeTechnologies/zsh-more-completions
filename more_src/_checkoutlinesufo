#compdef checkoutlinesufo
# _checkoutlinesufo — Adobe afdko checkoutlinesufo CLI for validating UFO source font outlines reporting overlaps tiny segments coincident points wrong direction paths and self-intersections (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_checkoutlinesufo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-e[do not fix]' \
        '--error[do not fix]' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-i+[ignore csv]:str:' \
        '--include=+[csv glyph names]:str:' \
        '-x+[exclude csv glyph names]:str:' \
        '--exclude=+[csv glyph names]:str:' \
        '-d[dry run]' \
        '--dry-run[dry run]' \
        '-f[overwrite]' \
        '--force[overwrite]' \
        '-r[remove overlap only]' \
        '--remove-overlap[remove overlap only]' \
        '-D[direction only]' \
        '--direction[direction only]' \
        '-s[smoothness check]' \
        '--smoothness[smoothness check]' \
        '--all-layers[check all layers]' \
        '--reverse-direction[reverse direction]' \
        '--clear-hashmap[clear hashmap]' \
        '*:UFO font:_files -g "*.ufo *.ufoz"'
}

_checkoutlinesufo "$@"
