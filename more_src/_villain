#compdef villain
# Documentation: https://github.com/t3l3machus/Villain
# Reference accessed: 2026-05-21
# Verified: upstream README usage block:
#   villain [-h] [-p PORT] [-x HOAX_PORT] [-n NETCAT_PORT]
#           [-f FILE_SMUGGLER_PORT] [-i] [-c CERTFILE] [-k KEYFILE]
#           [-u] [-q]
# Removed from prior file: --reverse-tcp-port (upstream is --netcat-port),
# --insecure long form for -i, --update for -u (upstream README shows
# short forms only without --long aliases), --version (-v not present
# in upstream usage block; only short/long pairs for -h/--help shown).

_arguments -s \
    '(-h --help)'{-h,--help}'[show this help message and exit]' \
    '-p+[main listener port (Team server, default 6501)]:port:_ports' \
    '-x+[HoaxShell server port]:port:_ports' \
    '-n+[netcat reverse multi-handler port]:port:_ports' \
    '-f+[HTTP file smuggler server port]:port:_ports' \
    '-i[allow unverified Villain clients to connect (insecure)]' \
    '-c+[path to your SSL certificate (HoaxShell https)]:cert file:_files' \
    '-k+[path to the private key for your certificate]:key file:_files' \
    '-u[try to fetch the latest commits from main on GitHub]' \
    '-q[suppress banner on startup (quiet)]'
