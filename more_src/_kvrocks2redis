#compdef kvrocks2redis
# Documentation: https://kvrocks.apache.org/docs/kvrocks2redis/
# Sync Apache Kvrocks data to Redis (apache/kvrocks)

local ret=1

_arguments -s -S \
  '-h[print this help message]' \
  '-v[print version information]' \
  '-c+[config file (default ./kvrocks2redis.conf)]:config file:_files' && ret=0

return ret
