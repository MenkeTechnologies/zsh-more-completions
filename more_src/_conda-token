#compdef conda-token
# Documentation: https://github.com/Anaconda/conda-token
# conda-token: configure conda to access Anaconda private repositories via a token

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--system[write to the system .condarc file]' \
  '--env[write to the active conda environment .condarc file]' \
  '--file=[write to the given file]:file:_files' \
  '--version[show the conda-token version and exit]' \
  '1:command:(set list remove)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      set)
        _arguments -s -S \
          '--include-archive-channels=[add archived channels to default_channels]:channel:' \
          '--no-ssl-verify[force disabling SSL verification]' \
          '--enable-signature-verification[enable conda package signature verification]' \
          '1:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
