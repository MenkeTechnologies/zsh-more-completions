#compdef showmount
# _showmount — OpenBSD showmount (query mountd(8) RPC service on a host; default lists clients with mounts, -a lists host:dirpath pairs, -d lists exported directories, -e dumps exports list, -3 uses mount v3)
# upstream: https://github.com/openbsd/src (usr.bin/showmount)
# Flags from usr.bin/showmount/showmount.8 on tip.

_showmount() {
    _arguments \
        '-3[use mount protocol v3]' \
        '-a[list host:dirpath pairs]' \
        '-d[list directories that have been remotely mounted]' \
        '-e[show exports list]' \
        '1:host:_hosts'
}

_showmount "$@"
