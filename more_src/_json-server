#compdef json-server

# Zsh completion for json-server - fake REST API with zero coding

_arguments -s -S \
  '(-p --port)'{-p+,--port=}'[set port]:port:' \
  '(-H --host)'{-H+,--host=}'[set host]:host:' \
  '(-w --watch)'{-w,--watch}'[watch file for changes]' \
  '(-s --static)'{-s+,--static=}'[set static files directory]:directory:_files -/' \
  '--read-only[allow only GET requests]' \
  '--no-cors[disable CORS]' \
  '--no-gzip[disable gzip content-encoding]' \
  '(-S --snapshots)'{-S+,--snapshots=}'[set snapshots directory]:directory:_files -/' \
  '(-d --delay)'{-d+,--delay=}'[add delay to responses (ms)]:milliseconds:' \
  '(-i --id)'{-i+,--id=}'[set database id property]:property name:' \
  '--foreignKeySuffix=[set foreign key suffix]:suffix:' \
  '(-q --quiet)'{-q,--quiet}'[suppress log messages]' \
  '(-r --routes)'{-r+,--routes=}'[path to routes file]:routes file:_files -g "*.json"' \
  '--middlewares=[path to middleware file]:file:_files -g "*.{js,cjs,mjs}"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:db file:_files -g "*.json"'
