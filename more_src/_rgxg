#compdef rgxg
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/rgxg.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rgxg: ReGular eXpression Generator. Subcommand-based CLI.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'alternation:generate a regex matching any of the given patterns'
  'cidr:generate a regex matching all addresses of the given CIDR block'
  'escape:generate a regex that matches the given string by escaping metacharacters'
  'range:generate a regex matching the number range between FIRST and LAST'
  'help:describe usage of rgxg or a specific subcommand'
  'version:print the rgxg version'
)

_arguments -C \
  '(- *)-h[display help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd) _describe -t commands 'rgxg subcommand' commands && ret=0 ;;
  (args)
    case $line[1] in
      (alternation)
        _arguments \
          '-N[omit outer parentheses]' \
          '-h[help]' \
          '*:pattern:' && ret=0 ;;
      (cidr)
        _arguments \
          '-N[omit outer parentheses]' \
          '-l[match only IPv6 addresses with lowercase letters]' \
          '-U[match only IPv6 addresses with uppercase letters]' \
          '-u[exclude IPv6 zero compression]' \
          '-s[exclude IPv6 mixed notation]' \
          '-h[help]' \
          '*:CIDR block:' && ret=0 ;;
      (range)
        _arguments \
          '-b[numeric base (2-32)]:base:' \
          '-N[omit outer parentheses]' \
          '-l[only lowercase letters (for bases > 10)]' \
          '-U[only uppercase letters (for bases > 10)]' \
          '-z[match only numbers with leading zeros]' \
          '-Z[match variable-length leading zeros]' \
          '-m[set minimum matched number length]:length:' \
          '-h[help]' \
          '*:FIRST [LAST]:' && ret=0 ;;
      (escape)
        _arguments '-h[help]' '*:string:' && ret=0 ;;
      (help) _describe -t commands 'subcommand' commands && ret=0 ;;
    esac ;;
esac

return ret
