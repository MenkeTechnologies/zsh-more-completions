#compdef beanstool
# Documentation: https://github.com/src-d/beanstool
# beanstool - dependency-free beanstalkd admin tool

local ret=1
local -a cmds

cmds=(
  'bury:move jobs from ready state to buried'
  'kick:move jobs from buried back to ready state'
  'delete:remove a job from a queue'
  'peek:view a job from a queue'
  'put:add a job into a tube'
  'stats:display statistics for all tubes'
  'tail:monitor a tube and display its contents'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'beanstool command' cmds && ret=0 ;;
esac

return ret
