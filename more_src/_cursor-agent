#compdef cursor-agent agent

local curcontext="$curcontext" state state_descr line
typeset -A opt_args

local -a subcommands
subcommands=(
    'install-shell-integration:install shell integration to ~/.zshrc'
    'uninstall-shell-integration:remove shell integration from ~/.zshrc'
    'login:authenticate with Cursor'
    'logout:sign out and clear stored authentication'
    'mcp:manage MCP servers'
    'status:view authentication status'
    'whoami:view authentication status'
    'models:list available models for this account'
    'about:display version, system, and account information'
    'update:update Cursor Agent to the latest version'
    'create-chat:create a new empty chat and return its ID'
    'generate-rule:generate a new Cursor rule with interactive prompts'
    'rule:generate a new Cursor rule with interactive prompts'
    'agent:start the Cursor Agent'
    'ls:resume a chat session'
    'resume:resume the latest chat session'
    'help:display help for command'
)

_arguments -s -S \
    '(-v --version)'{-v,--version}'[output the version number]' \
    '--api-key=[API key for authentication]:api key:' \
    '*-H+[add custom header (Name\: Value)]:header:' \
    '*--header=[add custom header (Name\: Value)]:header:' \
    '(-p --print)'{-p,--print}'[print responses to console for scripts or non-interactive use]' \
    '--output-format=[output format (only with --print)]:format:(text json stream-json)' \
    '--stream-partial-output[stream partial output as individual text deltas]' \
    '(-c --cloud)'{-c,--cloud}'[start in cloud mode]' \
    '--mode=[execution mode]:mode:(plan ask)' \
    '--plan[start in plan mode (shorthand for --mode=plan)]' \
    '--resume[select session to resume]:chat id:' \
    '--continue[continue previous session]' \
    '--model=[model to use]:model:' \
    '--list-models[list available models and exit]' \
    '(-f --force)'{-f,--force}'[force allow commands unless explicitly denied]' \
    '--yolo[alias for --force (Run Everything)]' \
    '--sandbox=[explicitly enable or disable sandbox]:mode:(enabled disabled)' \
    '--approve-mcps[automatically approve all MCP servers]' \
    '--trust[trust the current workspace without prompting (only with --print)]' \
    '--workspace=[workspace directory]:directory:_directories' \
    '(-w --worktree)'{-w,--worktree}'[start in isolated git worktree]:name:' \
    '--worktree-base=[branch or ref to base new worktree on]:ref:' \
    '--skip-worktree-setup[skip running worktree setup scripts from .cursor/worktrees.json]' \
    '(-h --help)'{-h,--help}'[display help for command]' \
    '(-)1:subcommand:->subcmd' \
    '(-)*::arguments:->args'

if (( ${state[(I)args]} )); then
    case $words[1] in
        subcmd)
            _describe -t subcommands 'cursor-agent subcommand' subcommands
            ;;
        mcp)
            _arguments \
                '(-h --help)'{-h,--help}'[display help for command]' \
                '1:MCP subcommand:(login list list-tools enable disable)' \
                '2:identifier for MCP server:_message'
            ;;
        help)
            if (( CURRENT == 3 )); then
                compadd \
                    install-shell-integration uninstall-shell-integration login logout mcp status whoami \
                    models about update create-chat generate-rule rule agent ls resume
            else
                _default
            fi
            ;;
        *)
            _default
            ;;
    esac
fi
