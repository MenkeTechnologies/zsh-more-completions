#compdef gspladd
# Documentation: https://raw.githubusercontent.com/GENIE-MC/Generator/master/src/Apps/gSplineAdd.cxx
# gspladd - GENIE utility to merge XML cross-section spline files

local ret=1

_arguments -s -S \
  '-f[input XML cross-section files (comma separated)]:files:_files' \
  '-d[input directories to look for XML cross-section files (comma separated)]:dirs:_files -/' \
  '-o[output XML filename]:outfile:_files' \
  '--message-thresholds[XML file customizing message stream thresholds]:xml:_files' \
  '*: :_files' && ret=0

return ret
