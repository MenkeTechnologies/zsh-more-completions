#compdef img2pdf
# Zsh completion for img2pdf
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-o --output)'{-o,--output}'[output PDF file]:file:_files -g "*.pdf"' \
  '--pagesize[page size]:size:' \
  '--imgsize[image size on page]:size:' \
  '--border[border size]:size:' \
  '--fit[image fit mode]:mode:(into fill exact shrink)' \
  '--rotation[rotation mode]:rotation:(auto none ifvalid 0 90 180 270)' \
  '--auto-orient[auto orient based on EXIF data]' \
  '--engine[PDF engine]:engine:(internal pikepdf pdfrw)' \
  '--first-frame-only[use only the first frame of multi-frame images]' \
  '--pillow-limit-break[remove Pillow image size limits]' \
  '--title[PDF title]:text:' \
  '--author[PDF author]:text:' \
  '--creator[PDF creator]:text:' \
  '--producer[PDF producer]:text:' \
  '--creationdate[PDF creation date]:date:' \
  '--moddate[PDF modification date]:date:' \
  '--subject[PDF subject]:text:' \
  '--keywords[PDF keywords]:text:' \
  '--viewer-panes[initial viewer panes]:panes:(thumbs outlines attachments)' \
  '--viewer-initial-page[initial page number]:N:' \
  '--viewer-magnification[viewer magnification]:mode:(fit width custom)' \
  '--viewer-page-layout[page layout]:layout:(single onecolumn twocolumnright twocolumnleft)' \
  '--viewer-fit-window[fit viewer window to page]' \
  '--viewer-center-window[center viewer window]' \
  '--viewer-fullscreen[open in fullscreen mode]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '*:image file:_files -g "*.{png,jpg,jpeg,gif,tiff,tif,bmp,webp}"' && ret=0
return ret
