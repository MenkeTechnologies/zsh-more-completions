#compdef create-next-app

# Zsh completion for create-next-app

_create-next-app() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--ts[initialize as a TypeScript project]' \
    '--typescript[initialize as a TypeScript project]' \
    '--js[initialize as a JavaScript project]' \
    '--javascript[initialize as a JavaScript project]' \
    '--tailwind[initialize with Tailwind CSS config]' \
    '--eslint[initialize with ESLint config]' \
    '--app[initialize with App Router]' \
    '--src-dir[initialize inside a src/ directory]' \
    '--import-alias=[configure the default import alias]:alias:' \
    '--use-npm[use npm as the package manager]' \
    '--use-yarn[use yarn as the package manager]' \
    '--use-pnpm[use pnpm as the package manager]' \
    '--use-bun[use bun as the package manager]' \
    '(-e --example)'{-e,--example}'[use an example]:example name or URL:' \
    '--example-path=[path inside a GitHub repo]:path:' \
    '--reset-preferences[reset stored preferences]' \
    '--skip-install[skip installing packages]' \
    '--empty[initialize an empty project]' \
    '--turbopack[enable Turbopack]' \
    '--yes[use default options]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '(-v --version)'{-v,--version}'[output version number]' \
    '1:project directory:_files -/' \
    && ret=0

  return ret
}

_create-next-app "$@"
