#compdef fmodcomm
# Modify the text of commentary keywords in a FITS file header

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "template=[template text to match]:" \
  "newtext=[replacement text]:" \
  "keytype=[commentary keyword type]:type:(COMMENT HISTORY)" \
  "firstmatch=[modify first match only]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
