#compdef qlaunch
# Documentation: https://materialsproject.github.io/fireworks/fireworks.scripts.html
# FireWorks queue launcher (submit jobs to a batch queue)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-rh --remote_host)'{-rh,--remote_host}'[remote host to exec qlaunch]:host:_hosts' \
  '(-rc --remote_config_dir)'{-rc,--remote_config_dir}'[remote config dir location]:dir:' \
  '(-ru --remote_user)'{-ru,--remote_user}'[username to login to remote host]:user:' \
  '(-rp --remote_password)'{-rp,--remote_password}'[password for remote host]:password:' \
  '(-rsh --remote_shell)'{-rsh,--remote_shell}'[shell command to use on remote host]:shell:' \
  '(-rkf --remote_keyfile)'{-rkf,--remote_keyfile}'[SSH keyfile for connecting to remote hosts]:file:_files' \
  '(-rs --remote_setup)'{-rs,--remote_setup}'[setup the remote config dir]' \
  '(-d --daemon)'{-d,--daemon}'[daemon mode, repeated every x seconds]:secs:' \
  '--launch_dir=[directory to launch the job / rapid-fire]:dir:_files -/' \
  '--logdir=[path to a directory for logging]:dir:_files -/' \
  '--loglvl=[level to print log messages]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(-s --silencer)'{-s,--silencer}'[shortcut to mute log messages]' \
  '(-r --reserve)'{-r,--reserve}'[reserve a fw]' \
  '(-l --launchpad_file)'{-l,--launchpad_file}'[path to launchpad file]:file:_files' \
  '(-w --fworker_file)'{-w,--fworker_file}'[path to fworker file]:file:_files' \
  '(-q --queueadapter_file)'{-q,--queueadapter_file}'[path to queueadapter file]:file:_files' \
  '(-c --config_dir)'{-c,--config_dir}'[path to a directory containing the config file]:dir:_files -/' \
  '(-fm --fill_mode)'{-fm,--fill_mode}'[launch queue submissions even when nothing to run]' \
  '1:command:(singleshot rapidfire)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      singleshot)
        _arguments -s \
          '(-f --fw_id)'{-f,--fw_id}'[specific fw_id to run in reservation mode]:fw_id:' && ret=0
        ;;
      rapidfire)
        _arguments -s \
          '(-m --maxjobs_queue)'{-m,--maxjobs_queue}'[maximum jobs to keep in queue for this user]:n:' \
          '(-b --maxjobs_block)'{-b,--maxjobs_block}'[maximum jobs to put in a block]:n:' \
          '--nlaunches=[number of launches (int or infinite)]:n:' \
          '--timeout=[timeout in secs after which to quit]:secs:' \
          '--sleep=[sleep time between loops]:secs:' && ret=0
        ;;
    esac
    ;;
esac

return ret
