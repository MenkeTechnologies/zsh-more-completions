#compdef optimade-validator
# Documentation: https://www.optimade.org/optimade-python-tools/latest/concepts/validation/
# Validate an OPTIMADE API implementation against the specification

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-v,--verbosity}'[increase output verbosity (repeatable)]' \
  '(-j --json)'{-j,--json}'[print only a JSON summary of results]' \
  '(-t --as-type)'{-t,--as-type}'=[validate request URL as the given entry type]:type:(structure reference info links)' \
  '--index[treat implementation as an Index meta-database]' \
  '--skip-optional[skip tests of optional features]' \
  '--fail-fast[exit on the first test failure]' \
  '(-m --minimal)'{-m,--minimal}'[run only a minimal test set]' \
  '--page_limit=[alter the requested page limit for some tests]:limit' \
  '--headers=[additional HTTP headers as a JSON object]:headers' \
  '*:base url:_urls' && ret=0

return ret
