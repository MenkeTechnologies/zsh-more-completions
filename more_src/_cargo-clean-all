#compdef cargo-clean-all
# _cargo-clean-all — bulk-clean nested Cargo project target dirs (dnlmlr/cargo-clean-all)
# upstream: https://github.com/dnlmlr/cargo-clean-all
# Flags from src/main.rs (clap).

_cargo-clean-all() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-y --yes)'{-y,--yes}'[no confirmation prompt]' \
        '(-s --keep-size)'{-s+,--keep-size=}'[ignore projects smaller than SIZE]:size:' \
        '(-d --keep-days)'{-d+,--keep-days=}'[ignore projects modified within DAYS]:days:' \
        '--dry-run[list reclaimable space without deleting]' \
        '(-t --threads)'{-t+,--threads=}'[scanning thread count (0=auto)]:n:' \
        '(-v --verbose)'{-v,--verbose}'[show access errors]' \
        '(-i --interactive)'{-i,--interactive}'[interactive project selection]' \
        '*--ignore=[directories to mark un-cleanable]:dir:_files -/' \
        '(-e --keep-executable)'{-e,--keep-executable}'[move executables out of target before clean]' \
        '*--skip=[directories to skip scanning entirely]:dir:_files -/' \
        '--depth=[max subdir depth for target/ search (0=unlimited)]:n:' \
        '--keep-empty-target[keep empty target dirs]' \
        '1:root dir:_files -/'
}

_cargo-clean-all "$@"
