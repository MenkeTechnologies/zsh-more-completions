#compdef mapscrn
# _mapscrn — kbd kbd-tools mapscrn CLI loading a screen output character map trans translation file onto the active Linux console converting application-emitted bytes through a translation table for non-ASCII font rendering on raw VT consoles (kbd team, C); getopt
# upstream: https://kbd-project.org/

_mapscrn() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-o+[saveto file]:file:_files -g "*.trans"' \
        '*:translation map file:_files -g "*.trans *.map *.gz"'
}

_mapscrn "$@"
