#compdef nydus-image
# _nydus-image — Nydus image builder/inspector (dragonflyoss/nydus)
# upstream: https://github.com/dragonflyoss/nydus
# Subcommands from src/bin/nydus-image/main.rs (clap).

_nydus-image() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:build a Nydus RAFS image from source'
                'merge:merge multiple Nydus bootstraps'
                'check:check/inspect a Nydus image'
                'inspect:interactive Nydus image inspector'
                'stat:print image statistics'
                'compact:compact blobs to reduce duplication'
                'unpack:unpack a Nydus image to a tarball/dir'
                'export:export image as OCI/Stargz/etc'
                'optimize:re-order data for better prefetch'
                'chunkdict:manage chunk dictionaries'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                chunkdict) _arguments '1:sub:(generate save)' ;;
            esac
            ;;
    esac
}

_nydus-image "$@"
