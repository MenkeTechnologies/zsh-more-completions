#compdef openvas-cli openvas openvasd
# _openvas-cli — Greenbone OpenVAS openvas-cli CLI command-line frontend wrapping the Greenbone Vulnerability Manager OpenVAS open-source vulnerability scanner GVM Greenbone Community Edition platform CLI providing scan task target port-list config schedule alert filter credential note override permission report result tag user role group asset agent license host operating-system tls-certificate ticket help (Greenbone Networks team Jan-Oliver Wagner Tim Brown, C); custom argparse
# upstream: https://www.greenbone.net/

_openvas-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "openvas.conf openvasd.conf *.conf"' \
        '--config-file=+[file]:file:_files -g "openvas.conf openvasd.conf *.conf"' \
        '-l+[log dir]:dir:_files -/' \
        '--log=+[dir]:dir:_files -/' \
        '-d[run as daemon]' \
        '--daemon[run as daemon]' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-a+[listen addr]:_hosts' \
        '--listen=+[addr]:_hosts' \
        '--mqtt-broker-address=+[addr]:_hosts' \
        '--mqtt-broker-port=+[port]:n:' \
        '--mqtt-server-url=+[url]:str:' \
        '--scan-id=+[id]:str:' \
        '--scanner-name=+[name]:str:' \
        '-u+[user]:_users' \
        '--unix-socket=+[path]:_files' \
        '-K[stop scan]' \
        '--stop-scan=+[id]:str:' \
        '-x[finish scan]' \
        '--scan-stop=+[id]:str:' \
        '--update-vt-info[update VT info]' \
        '-s+[script dir]:dir:_files -/' \
        '--scripts-dir=+[dir]:dir:_files -/' \
        '--include-folders=+[dirs]:str:' \
        '--exclude-folders=+[dirs]:str:' \
        '--print-specs[print specs]' \
        '--debug-tls=+[level]:n:' \
        '--debug-mode=+[level]:n:' \
        '--ssh-private-key=+[file]:file:_files' \
        '--ssh-public-key=+[file]:file:_files' \
        '--cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--cert-key=+[file]:file:_files -g "*.pem *.key"' \
        '*:target:'
}

_openvas-cli "$@"
