#compdef gridsome

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:scaffold a new site'
  'config:inspect or set config'
  'info:print environment info'
  'develop:start dev server'
  'build:build for production'
  'explore:explore GraphQL data'
)

_arguments -C \
  '(-v --version)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'gridsome subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (create) _arguments '1:name:' '2:starter:' && ret=0 ;;
      (config)
        _arguments -s \
          '(-g --get)'{-g,--get}'=[key]:key:' \
          '(-s --set)'{-s,--set}'=[key]:key:' \
          '(-d --delete)'{-d,--delete}'=[key]:key:' \
          '--json[output JSON]' \
          '*:value:' && ret=0 ;;
      (develop)
        _arguments -s \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '(-h --host)'{-h,--host}'=[host]:host:_hosts' \
          '(-s --https)'{-s,--https}'[HTTPS]' && ret=0 ;;
      (explore)
        _arguments -s \
          '(-p --port)'{-p,--port}'=[port]:port:' \
          '(-h --host)'{-h,--host}'=[host]:host:_hosts' && ret=0 ;;
    esac
    ;;
esac

return ret
