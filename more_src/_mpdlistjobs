#compdef mpdlistjobs
# Documentation: https://man.archlinux.org/search?q=mpdlistjobs
# Reference accessed: 2026-05-16

# mpdlistjobs: list running MPI jobs in MPD
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdlistjobs args:_files' && ret=0
return ret
