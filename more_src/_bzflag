#compdef bzflag
# Documentation: https://linux.die.net/man/6/bzflag
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-3dfx[force 3dfx mode]' \
  '-no3dfx[disable 3dfx mode]' \
  '-anonymous[connect anonymously]' \
  '-callsign+[set callsign]:name:' \
  '-config+[config file]:file:_files' \
  '-configdir+[config directory]:dir:_files -/' \
  '-d+[debug level]:level:' \
  '-date+[start date]:date:' \
  '-directory+[data directory]:dir:_files -/' \
  '-echo[echo debug output]' \
  '-eyesep+[stereo eye separation]:sep:' \
  '-focal+[stereo focal distance]:dist:' \
  '-geometry+[window geometry]:WxH+X+Y:' \
  '-help[show help]' \
  '-list+[list server URL]:url:' \
  '-locale+[locale]:locale:' \
  '-motd+[show motd from URL]:url:' \
  '-multisample[enable multisampling]' \
  '-mute[disable sound]' \
  '-nomouse[do not grab mouse]' \
  '-notime[no time display]' \
  '-particles[enable particles]' \
  '-password+[password]:pw:' \
  '-port+[server port]:port:' \
  '-replay+[replay file]:file:_files -g "*.bzf"' \
  '-server+[server host]:host:_hosts' \
  '-show-collision-grid[debug collision grid]' \
  '-show-coords[show coordinates]' \
  '-solo[solo play]' \
  '-stat[show stats]' \
  '-team+[team]:team:(red green blue purple rogue observer)' \
  '-time+[start time]:time:' \
  '-view+[view mode]:mode:(normal stereo three triple stacked)' \
  '-window+[windowed]:WxH:' \
  '-zbuffer[enable z-buffer]' && ret=0

return ret
