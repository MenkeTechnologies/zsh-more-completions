#compdef virt-host-validate
# _virt-host-validate — libvirt virt-host-validate (run a host-readiness checklist for KVM/QEMU/LXC/Xen/bhyve virtualization; positional argument selects backend; --version, --help, --quiet only failures; covers CPU virtualization extensions, IOMMU, hugepages, cgroup support, SELinux)
# upstream: https://gitlab.com/libvirt/libvirt (tools/virt-host-validate.c)
# Flags from libvirt tools/virt-host-validate.c on tip.

_virt-host-validate() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-q[quiet (only failures)]' \
        '--quiet[quiet (only failures)]' \
        '1:backend:(qemu kvm lxc bhyve xen ch)'
}

_virt-host-validate "$@"
