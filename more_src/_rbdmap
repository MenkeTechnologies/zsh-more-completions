#compdef rbdmap
# Documentation: https://docs.ceph.com/en/latest/man/8/rbdmap/
# Map and unmap RBD images listed in the rbdmap configuration file.

local ret=1

_arguments -s -S \
  '1:command:((
    map\:"map RBD images listed in the config file"
    unmap\:"unmap images listed in the config file"
    unmap-all\:"unmap all currently mapped RBD images"
  ))' && ret=0

return ret
