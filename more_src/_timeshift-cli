#compdef timeshift

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--gui[start GUI]' \
  '--check[check for snapshots]' \
  '--create[create snapshot]' \
  '--list[list snapshots]' \
  '--list-devices[list devices]' \
  '--restore[restore snapshot]' \
  '--delete[delete snapshot]' \
  '--delete-all[delete all]' \
  '--snapshot=[snapshot name]:n:' \
  '--snapshot-device=[snapshot device]:d:' \
  '--target=[target device]:d:' \
  '--mounts=[mounts csv]:list:' \
  '--btrfs[BTRFS mode]' \
  '--rsync[rsync mode]' \
  '--scripted[non-interactive]' \
  '--yes[yes]' \
  '--comments=[snapshot comment]:c:' \
  '--tags=[tag]:t:(O B H D W M N)' \
  '--debug[debug]' \
  '--verbose[verbose]' \
  '*: :' && ret=0

return ret
