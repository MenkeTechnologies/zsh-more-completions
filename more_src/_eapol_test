#compdef eapol_test
# _eapol_test — wpa_supplicant eapol_test (standalone EAP exchange tester: simulates a wpa_supplicant client talking RADIUS to a server so EAP methods (TLS/PEAP/TTLS/MSCHAPv2/EAP-pwd/AKA) can be validated end-to-end without a real WPA stack; -c config file, -a auth server, -p port, -s shared secret, -t timeout, -A nas-identifier, -n max iterations, -N attr=val extra RADIUS attribute)
# upstream: https://w1.fi/cgit/hostap (wpa_supplicant/eapol_test.c)
# Flags from w1.fi/hostap wpa_supplicant/eapol_test.c on tip.

_eapol_test() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[config file]:file:_files' \
        '-a+[auth server]:host:_hosts' \
        '-p+[auth port]:port:' \
        '-s+[shared secret]:secret:' \
        '-t+[timeout seconds]:seconds:' \
        '-A+[NAS identifier]:nas:' \
        '-n+[max iterations]:n:' \
        '*-N+[radius attr name=value]:attr:' \
        '-r+[reauth count]:n:' \
        '-S+[server identifier]:server:' \
        '-w+[wait between attempts]:seconds:' \
        '-W[wait for connection]' \
        '-M+[MAC address]:mac:'
}

_eapol_test "$@"
