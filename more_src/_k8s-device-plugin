#compdef k8s-device-plugin
# Documentation: https://man.archlinux.org/search?q=k8s-device-plugin
# Reference accessed: 2026-05-16

# k8s-device-plugin (NVIDIA): expose GPUs as k8s extended resources
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--mig-strategy=[MIG strategy]:strategy:(none single mixed)' \
  '--fail-on-init-error=[fail on init error]:bool:(true false)' \
  '--device-list-strategy=[device list strategy]:strategy:(envvar volume-mounts)' \
  '--device-id-strategy=[device id strategy]:strategy:(index uuid)' \
  '--nvidia-driver-root=[NVIDIA driver root]:path:' \
  '--pass-device-specs=[pass device specs]:bool:(true false)' \
  '--gds-enabled[enable GDS]' \
  '--mofed-enabled[enable MOFED]' \
  '--config-file=[config file]:file:_files' \
  '--cdi-annotation-prefix=[CDI annotation prefix]:prefix:' \
  '--nvidia-ctk-path=[nvidia-ctk binary path]:file:_files' \
  '--container-driver-root=[container driver root]:path:' \
  '*::k8s-device-plugin args:_files' && ret=0
return ret
