#compdef mcy
# Documentation: https://github.com/YosysHQ/mcy/blob/main/README.md
# Mutation Cover with Yosys

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(init reset run status list task source gui dash purge)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s \
          '-j+[number of concurrent jobs]:jobs' && ret=0
        ;;
      list)
        _arguments -s \
          '--details[detailed output]' && ret=0
        ;;
      task)
        _arguments -s \
          '-v[show command output on console]' \
          '-k[keep task directory after completion]' && ret=0
        ;;
    esac
    ;;
esac

return ret
