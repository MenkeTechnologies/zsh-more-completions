#compdef evtx_dump
# Documentation: https://github.com/omerbenamram/evtx
# Parser for the Windows EVTX event log binary format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output format]:format:(xml json jsonl)' \
  '-f[output file path]:file:_files' \
  '-t[number of threads]:threads' \
  '--wevt-cache[use provider binary templates for offline rendering]:cache:_files' \
  '*:evtx file:_files' && ret=0

return ret
