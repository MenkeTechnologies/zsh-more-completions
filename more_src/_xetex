#compdef xetex xelatex
# _xetex — TeX Live xetex / xelatex (Unicode-native TeX engine using OpenType/TrueType fonts via HarfBuzz; outputs xdv (then PDF via xdvipdfmx) by default; shares most CLI with pdftex)
# upstream: https://tug.org/svn/texlive (Build/source/texk/web2c/xetexdir)
# Flags from web2c xetexdir/xetex.web on tip.

_xetex() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-fmt+[format name]:fmt:' \
        '-interaction+[error mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
        '-output-driver+[xdvipdfmx-style driver]:driver:' \
        '-output-directory+[output dir]:dir:_files -/' \
        '-jobname+[job name]:name:' \
        '-no-pdf[stop after .xdv (skip PDF)]' \
        '-synctex+[synctex level]:level:(-1 0 1)' \
        '-file-line-error[file:line:msg errors]' \
        '-no-file-line-error[plain errors]' \
        '-shell-escape[enable \\write18]' \
        '-no-shell-escape[disable \\write18]' \
        '-shell-restricted[restricted \\write18]' \
        '-recorder[create .fls]' \
        '-papersize+[paper size]:size:(a4 a5 letter legal executive ledger)' \
        '-etex[e-TeX extensions]' \
        '-ini[ini phase]' \
        '-progname+[program name]:name:' \
        '-translate-file+[input translation file]:file:_files' \
        '-8bit[8-bit clean]' \
        '*:tex file:_files -g "*.(tex|ltx|latex)"'
}

_xetex "$@"
