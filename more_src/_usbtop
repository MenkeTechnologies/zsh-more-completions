#compdef usbtop
# Documentation: https://man.archlinux.org/search?q=usbtop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-b --bus)'{-b,--bus}'=[filter by USB bus]:bus number' \
  '--no-curses[disable curses interface, print to stdout]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
