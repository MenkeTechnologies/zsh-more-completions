#compdef innfeed
# Documentation: man innfeed(8)
# Source: InterNetNews/inn innfeed/main.c — stream-mode NNTP article feeder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[article spool top directory]:dir:_files -/' \
    '-b+[backlog/lock files directory]:dir:_files -/' \
    '-c+[config file]:file:_files' \
    '-C[check config file and exit]' \
    '-d+[logging level]:level:_default' \
    '-e+[max backlog file size in bytes]:bytes:_default' \
    '(- *)-h[help]' \
    '-l+[redirect stderr/stdout to file]:file:_files' \
    '-m[log info on missing articles]' \
    '-M[turn off mmap usage]' \
    '-o+[max bytes of article data in memory]:bytes:_default' \
    '-p+[pid file]:file:_files' \
    '-s+[subprocess providing article info]:cmd:_command_names -e' \
    '-S+[status file name]:file:_files' \
    '(- *)-v[print version]' \
    '-x[process backlog files only, ignore stdin]' \
    '-y[add peers dynamically from innd]' \
    '-z[fork a backlog-only child]' \
    '*:input file:_files' \
    && ret=0

return ret
