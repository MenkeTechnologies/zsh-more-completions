#compdef condor_watch_q
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_watch_q.html
# track the status of jobs over time without repeated condor_q calls

local ret=1

_arguments -s -S \
  '-help[display the help message and exit]' \
  '-debug[send debugging information to stderr]' \
  '*-users[specify which users jobs to track]:user:_users' \
  '*-clusters[specify which ClusterIds to track]:cluster_id' \
  '-larger-than[track all ClusterIds greater than or equal to given id]:cluster_id' \
  '*-files[specify which job event logs to track jobs from]:file:_files' \
  '*-batches[track jobs with the specified JobBatchName]:batch_name' \
  '-collector[collector to query to locate the schedd]:collector:_hosts' \
  '-schedd[schedd to discover which active jobs to track]:schedd' \
  '-exit[specify exit conditions GROUPER,JOB_STATUS\[,EXIT_STATUS\]]:condition' \
  '-exit-on-key-press[enable exit via key press]' \
  '-no-exit-on-key-press[disable exit via key press]' \
  '-interval[refresh interval in seconds]:seconds' \
  '-groupby[group tracked jobs]:by:(batch log cluster)' \
  '-display-exited[display rows of jobs that have all exited]' \
  '-no-display-exited[do not display rows of jobs that have all exited]' \
  '-exited-row-decay[time before an exited row is no longer displayed]:time' \
  '-decay-start-at-read[start decay timers at event read time]' \
  '-no-decay-start-at-read[start decay timers at event write time]' \
  '-table[enable the table]' \
  '-no-table[disable the table]' \
  '-progress[enable the progress bar]' \
  '-no-progress[disable the progress bar]' \
  '-row-progress[enable the per-row progress bar]' \
  '-no-row-progress[disable the per-row progress bar]' \
  '-summary[enable the summary line]' \
  '-no-summary[disable the summary line]' \
  '-summary-type[display totals or percentages on summary line]:type:(totals percentages)' \
  '-updated-at[enable the last time updated line]' \
  '-no-updated-at[disable the last time updated line]' \
  '-abbreviate[enable abbreviating path components]' \
  '-no-abbreviate[disable abbreviating path components]' \
  '-color[enable colored output]' \
  '-no-color[disable colored output]' \
  '-refresh[enable refreshing output]' \
  '-no-refresh[disable refreshing output]' && ret=0

return ret
