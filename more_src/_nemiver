#compdef nemiver
# Documentation: https://man.archlinux.org/search?q=nemiver
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--display)--display=[X display]:display:' \
  '(--load-core)--load-core=[core file]:file:_files' \
  '(--attach)--attach=[attach to PID]:pid:_pids' \
  '(--remote)--remote=[connect remote target]:host\:port:' \
  '(--gdb-binary)--gdb-binary=[gdb binary]:file:_files' \
  '(--solib-prefix)--solib-prefix=[shared lib prefix]:dir:_files -/' \
  '(--just-load)--just-load[just load, do not run]' \
  '(--executable)--executable=[program to debug]:file:_files' \
  '(--debug)--debug[print debug info]' \
  '(--source-dirs)--source-dirs=[source directories]:dirs:' \
  '(--log-debugger-output)--log-debugger-output[log debugger output]' \
  '(--show-version)--show-version[print version]' \
  '*:program:_files' && ret=0

return ret
