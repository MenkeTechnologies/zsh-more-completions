#compdef kernelshark

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'=[input trace file]:file:_files -g "*.dat"' \
  '(-a --applet)'{-a,--applet}'=[KernelShark applet]:applet:' \
  '(-p --plugin)'{-p,--plugin}'=[plugin to load]:plugin:_files' \
  '(-s --session)'{-s,--session}'=[session file]:session file:_files' \
  '--cpu=[filter by CPU]:cpu:' \
  '--event=[filter by event]:event:' \
  '--task=[filter by task]:task:' \
  '*:trace file:_files' && ret=0

return ret
