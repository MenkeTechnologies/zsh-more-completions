#compdef kernelshark
# Documentation: https://manpages.debian.org/unstable/kernelshark/kernelshark.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-i+[input trace file]:file:_files -g "*.dat"' \
  '*:trace file:_files' && ret=0

return ret
