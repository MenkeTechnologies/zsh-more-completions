#compdef avro avro-tools-cli
# _avro — Apache Avro data serialization avro-tools CLI alias (Apache Software Foundation, Java); custom argparse
# upstream: https://github.com/apache/avro

_avro() {
    local -a sub=(
        'cat:cat avro files'
        'compile:compile schema/IDL'
        'concat:concat avro files'
        'fragtojson:convert avro frag to JSON'
        'fromjson:convert JSON to Avro'
        'fromtext:convert text to Avro'
        'getmeta:print file metadata'
        'getschema:print file schema'
        'idl:convert Avro IDL to schema'
        'idl2schemata:extract schemata from IDL'
        'induce:induce schema from data'
        'jsontofrag:convert JSON to Avro fragment'
        'random:generate random data'
        'recodec:recodec compression'
        'repair:repair avro file'
        'rpcprotocol:get RPC protocol'
        'rpcreceive:RPC receive'
        'rpcsend:RPC send'
        'tether:tethered mapreduce'
        'tojson:convert Avro to JSON'
        'totext:convert Avro to text'
        'totrevni:convert to Trevni'
        'trevni_meta:Trevni file metadata'
        'trevni_random:Trevni random'
        'trevni_tojson:Trevni to JSON'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'avro subcommand' sub ;;
        args)
            case $words[1] in
                cat|getmeta|getschema|tojson|totext|totrevni|recodec|repair|fragtojson) _arguments \
                    '*:file:_files -g "*.avro *.json"' ;;
                fromjson|jsontofrag) _arguments \
                    '--schema-file=+[schema file]:file:_files -g "*.avsc"' \
                    '--codec=+[codec]:c:(null deflate snappy bzip2 xz zstandard)' \
                    '*:file:_files' ;;
                fromtext) _arguments \
                    '--codec=+[codec]:c:(null deflate snappy bzip2 xz zstandard)' \
                    '*:file:_files' ;;
                compile) _arguments \
                    '1:type:(protocol schema)' \
                    '*:input:_files -g "*.avpr *.avsc *.json"' ;;
                idl|idl2schemata) _arguments \
                    '*:file:_files -g "*.avdl"' ;;
                random) _arguments \
                    '--schema-file=+[schema file]:file:_files -g "*.avsc"' \
                    '--codec=+[codec]:c:(null deflate snappy bzip2 xz zstandard)' \
                    '--count=+[count]:n:' \
                    '--seed=+[seed]:n:' \
                    '*:output:_files' ;;
                concat) _arguments '*:file:_files -g "*.avro"' ;;
                induce) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_avro "$@"
