#compdef condor_rmdir
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_rmdir.html
# Windows tool to recursively remove a directory and its contents

local ret=1

_arguments -s -S \
  '/HELP[print usage information]' \
  '/?[print usage information]' \
  '/VERBOSE[print detailed output]' \
  '/DIAGNOSTIC[print internal flow of control information]' \
  '/PATH\:[remove the directory given by path]:path:_files -/' \
  '/S[include subdirectories in those removed]' \
  '/C[continue even if access is denied]' \
  '/Q[print error output only]' \
  '/NODEL[do not remove directories]' \
  '*:directory:_files -/' && ret=0

return ret
