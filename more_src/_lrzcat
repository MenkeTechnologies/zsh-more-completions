#compdef lrzcat
# Documentation: https://man.archlinux.org/man/lrzip.1
# lrzcat — decompress an lrzip file to standard output (lrzip -d -o -)

local ret=1

_arguments -s -S \
  '(-h -? --help)'{-h,--help}'[display options summary]' \
  '(-V --version)'{-V,--version}'[print version number]' \
  '(-c --check)'{-c,--check}'[verify decompressed file via MD5 hash]' \
  '(-i --info)'{-i,--info}'[display compressed file metadata]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-Q --very-quiet)'{-Q,--very-quiet}'[eliminate all output except errors]' \
  '(-t --test)'{-t,--test}'[verify compressed file integrity]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-p --threads)'{-p+,--threads=}'[override CPU thread count]:threads' \
  '(-N --nice-level)'{-N+,--nice-level=}'[set process priority]:nice' \
  '(-m --maxram)'{-m+,--maxram=}'[maximum RAM in hundreds of MB]:size' \
  '*:lrzip file:_files -g "*.lrz"' && ret=0

return ret
