#compdef wgetpaste

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-l[list available services and languages]' \
  '-s+[set pastebin service]:service:(bpaste codepad dpaste gists)' \
  '-S+[set the URL for a custom service]:url' \
  '-e+[set default expiration]:expiration' \
  '-n[use nick in paste description]' \
  '-N+[override nick]:nick' \
  '-d+[set description]:description' \
  '-L+[set language for syntax highlighting]:language' \
  '-u+[URL to fetch content from]:url' \
  '-c+[set command to use for pasting]:command' \
  '-C[do not display confirmation]' \
  '-i[read from stdin]' \
  '-r[convert tabs to spaces]' \
  '-t+[set number of spaces for tab replacement]:num' \
  '-x[set command and run in a subshell]:command' \
  '-X[display URL only]' \
  '-E[enable escape sequences]' \
  '-g[enable globbing]' \
  '*:file:_files' && ret=0

return ret
