#compdef wgetpaste
# Documentation: https://github.com/zlin/wgetpaste
# Reference accessed: 2026-05-21
# Verified: upstream wgetpaste usage() function in the script at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --language)'{-l+,--language=}'[set syntax highlighting language]:language:' \
  '(-d --description)'{-d+,--description=}'[set paste description/title]:description:' \
  '(-n --nick)'{-n+,--nick=}'[set author nick]:nick:' \
  '(-s --service)'{-s+,--service=}'[choose pastebin service]:service:' \
  '(-e --expiration)'{-e+,--expiration=}'[set expiration]:expiration:' \
  '(-S --list-services)'{-S,--list-services}'[list available services]' \
  '(-L --list-languages)'{-L,--list-languages}'[list languages for current service]' \
  '(-E --list-expiration)'{-E,--list-expiration}'[list expiration options]' \
  '(-u --tinyurl)'{-u+,--tinyurl=}'[convert URL to tinyurl]:url:' \
  '(-c --command)'{-c+,--command=}'[paste command and its output]:command:' \
  '(-i --info)'{-i,--info}'[append system info to paste]' \
  '(-I --info-only)'{-I,--info-only}'[paste system info only]' \
  '(-x --xcut)'{-x,--xcut}'[read paste from X clipboard]' \
  '(-X --xpaste)'{-X,--xpaste}'[write URL to X primary selection]' \
  '(-C --xclippaste)'{-C,--xclippaste}'[write URL to X clipboard]' \
  '(-N --no-ansi)'{-N,--no-ansi}'[strip ANSI color codes]' \
  '(-A --ansi)'{-A,--ansi}'[preserve ANSI color codes]' \
  '(-r --raw)'{-r,--raw}'[show raw paste URL]' \
  '(-t --tee)'{-t,--tee}'[display content being pasted]' \
  '(-q --quiet)'{-q,--quiet}'[output URL only]' \
  '(-v --verbose)'{-v,--verbose}'[show wget errors]' \
  '--debug[very verbose mode]' \
  '(-g --ignore-configs)'{-g,--ignore-configs}'[skip configuration files]' \
  '--completions[shell completion output]' \
  '*:file:_files' && ret=0

return ret
