#compdef grub-glue-efi
# _grub-glue-efi — GRUB grub-glue-efi (combine a 32-bit and a 64-bit GRUB EFI binary into a single Apple-style fat EFI binary; -3 32-bit input, -6 64-bit input, -o output combined file, --version, --help; useful on Apple T1/T2 hardware where the firmware expects fat binaries)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-glue-efi.c on tip.

_grub-glue-efi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-3+[32-bit binary]:file:_files' \
        '-6+[64-bit binary]:file:_files' \
        '-o+[output]:file:_files'
}

_grub-glue-efi "$@"
