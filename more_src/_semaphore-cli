#compdef sem
# _semaphore-cli — Semaphore CI sem CLI (Rendered Text / Semaphore, Ruby); manage Semaphore projects + workflows
# upstream: https://github.com/semaphoreci/cli

_semaphore-cli() {
    local -a sub=(
        'attach:attach to a running job'
        'completion:print shell completion'
        'connect:connect to org'
        'context:context commands'
        'create:create resources'
        'debug:debug a job'
        'delete:delete resources'
        'edit:edit a resource'
        'get:get resources'
        'help:show help'
        'init:initialize semaphore project'
        'list:list resources'
        'logs:fetch job logs'
        'port-forward:port forward to a job'
        'rebuild:rebuild a workflow'
        'stop:stop a job/workflow'
        'switch:switch organization'
        'sync:sync local + cloud workflows'
        'token:token commands'
        'update:update resources'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--verbose[verbose]' \
        '--organization+[organization]:org:' \
        '--project-name+[project name]:name:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sem subcommand' sub ;;
        args)
            case $words[1] in
                get|list|create|edit|delete|update) _arguments \
                    '1:resource:(project secret notification dashboard workflow agent_type job pipeline self_hosted_agent_type)' \
                    '*:name:' ;;
                connect) _arguments '*:org:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_semaphore-cli "$@"
