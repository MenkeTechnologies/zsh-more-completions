#compdef koord-runtime-proxy
# _koord-runtime-proxy — Koordinator CRI proxy that injects QoS/SLO hooks (koordinator-sh/koordinator)
# upstream: https://github.com/koordinator-sh/koordinator
# Flags from cmd/koord-runtime-proxy/main.go on tip.

_koord-runtime-proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--koord-runtimeproxy-endpoint=[koord-runtime-proxy CRI listen endpoint]:uri:' \
        '--remote-runtime-service-endpoint=[backend CRI endpoint (containerd/dockershim)]:uri:' \
        '--backend-runtime-mode=[backend CRI runtime mode]:mode:(Containerd Docker)' \
        '--runtime-hook-server-key=[label key identifying RuntimeHookServer pods]:key:' \
        '--runtime-hook-server-val=[label value identifying RuntimeHookServer pods]:val:' \
        '-v[klog verbosity level]:n:'
}

_koord-runtime-proxy "$@"
