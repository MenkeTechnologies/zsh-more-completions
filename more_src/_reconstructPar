#compdef reconstructPar
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/reconstructPar.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# OpenFOAM reconstructPar: reconstruct parallel case decomposition
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show short help]' \
  '-help-full[show full help]' \
  '-help-man[show full help in manpage format]' \
  '-help-notes[show help notes]' \
  '-doc[display documentation in browser]' \
  '-doc-source[display source code in browser]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-allRegions[reconstruct all regions]' \
  '-constant[include constant/ directory in times list]' \
  '-withZero[include 0/ directory in times list]' \
  '-noZero[exclude 0/ directory from times list]' \
  '-noFields[skip field reconstruction]' \
  '-noLagrangian[skip Lagrangian positions and fields]' \
  '-noSets[skip cellSets/faceSets/pointSets]' \
  '-noFunctionObjects[do not execute function objects]' \
  '-fields[fields to reconstruct]:list:' \
  '-lagrangianFields[Lagrangian fields to reconstruct]:list:' \
  '-newTimes[only reconstruct times that do not yet exist]' \
  '-time[time ranges to process]:range:' \
  '-latestTime[only reconstruct the latest time]' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '-lib[load additional library]:name:' \
  '-debug-switch[set a debug switch]:name=val:' \
  '-info-switch[set an info switch]:name=val:' \
  '-opt-switch[set an optimisation switch]:name=val:' \
  '*::reconstructPar args:_files' && ret=0
return ret
