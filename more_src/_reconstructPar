#compdef reconstructPar
# Documentation: https://man.archlinux.org/search?q=reconstructPar
# Reference accessed: 2026-05-16

# OpenFOAM reconstructPar: reconstruct parallel case decomposition
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-case[case directory]:dir:_files -/' \
  '-region[mesh region]:region:' \
  '-allRegions[reconstruct all regions]' \
  '-noFields[do not reconstruct fields]' \
  '-noLagrangian[skip Lagrangian fields]' \
  '-noSets[skip sets]' \
  '-fields[list of fields to reconstruct]:list:' \
  '-lagrangianFields[list of Lagrangian fields]:list:' \
  '-newTimes[only reconstruct new times]' \
  '-time[time range start[:end]]:range:' \
  '-latestTime[only reconstruct latest time]' \
  '-noZero[do not reconstruct time 0]' \
  '-cellSet[only reconstruct cell set]:set:' \
  '-faceSet[only reconstruct face set]:set:' \
  '-pointSet[only reconstruct point set]:set:' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '*::reconstructPar args:_files' && ret=0
return ret
