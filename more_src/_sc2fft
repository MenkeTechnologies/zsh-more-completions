#compdef sc2fft
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss54.html
# SMURF SC2FFT - Fourier Transform SCUBA-2 time-series data

local ret=1

_arguments -C \
  'IN=[input data files for transformation]:NDF file:_files' \
  'OUT=[transformed output files]:NDF file:_files' \
  'OUTFILES=[text file listing output NDF names]:file:_files' \
  'INVERSE=[execute inverse FFT transformation]:flag:(TRUE FALSE)' \
  'POLAR=[apply polar representation to FFT results]:flag:(TRUE FALSE)' \
  'POWER=[generate power spectral density output]:flag:(TRUE FALSE)' \
  'AVPSPEC=[compute average power spectral density]:flag:(TRUE FALSE)' \
  'AVPSPECTHRESH=[n-sigma noise threshold for quality bolometers]:thresh:' \
  'WEIGHTAVPSPEC=[inverse-noise-squared weighting]:flag:(TRUE FALSE)' \
  'ZEROBAD=[replace bad values with zeros]:flag:(TRUE FALSE)' \
  'BBM=[bad bolometer mask files]:NDF file:_files' \
  'FLAT=[apply flatfield correction]:flag:(TRUE FALSE)' \
  'FLATMETH=[flatfield calculation method]:method:(POLYNOMIAL TABLE)' \
  'FLATORDER=[polynomial order for flatfield]:order:' \
  'FLATSNR=[signal-to-noise threshold for responsivity]:snr:' \
  'FLATUSENEXT=[use adjacent flatfield calibrations]:flag:(TRUE FALSE)' \
  'RESIST=[bolometer resistor configuration]:config:' \
  'RESPMASK=[responsivity-based masking]:flag:(TRUE FALSE)' \
  'MSG_FILTER=[message verbosity control]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:NDF file:_files' && ret=0

return ret
