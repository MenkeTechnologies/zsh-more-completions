#compdef r8tohdf
# Documentation: https://manpages.debian.org/testing/hdf4-tools/r8tohdf.1.en.html
# Convert raw 8-bit raster images to HDF RIS8 format

local ret=1

_arguments -s \
  '-p+[name of the palette file]:palette file:_files' \
  '(-c -i -r)-c[compress output with run-length encoding]' \
  '(-c -i -r)-i[compress output with IMCOMP method]' \
  '(-c -i -r)-r[no compression (default)]' \
  '*:raw raster image:_files' && ret=0

return ret
