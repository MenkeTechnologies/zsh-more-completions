# ============================================================================
#  _remake — remake: Make-like declarative workflows in R (Rich FitzJohn)
#
#  Source-direct extraction from
#    https://github.com/richfitz/remake/blob/master/R/main.R
#    https://cran.r-project.org/package=optparse (Trevor L. Davis's
#    optparse package, a port of Python's optparse to R)
#
#  Maintained by Rich FitzJohn (richfitz/remake), Imperial College
#  London epidemiology team.  341 GH stars.  remake brings MAKE-LIKE
#  DECLARATIVE WORKFLOWS to R — define targets and dependencies in a
#  YAML `remake.yml` file, and `remake` runs the necessary R functions
#  to bring outputs up-to-date.  Used in computational epidemiology,
#  statistical workflows, and reproducible-research pipelines.
#  Sister tools: drake (R workflow framework, replaced by targets),
#  targets (R 2nd-gen pipeline tool), GNU Make (in corpus via _make),
#  snakemake (Python workflow, IN CORPUS via _snakemake), nextflow
#  (Groovy pipeline, IN CORPUS via _nextflow), bpipe (Groovy pipeline,
#  R376), ProjectTemplate (R), drake's `make()`.
#
#  CLI library taxonomy update: 1st R language entry — Trevor L.
#  Davis's **optparse** CRAN package (cran.r-project.org/package=optparse).
#  R is a FIRST-TIME addition to the cross-language CLI library
#  taxonomy.
#
#  R `optparse` is Trevor L. Davis's port of Python 2's `optparse`
#  module (the predecessor to argparse) — provides Python-style
#  `OptionParser` + `make_option` pattern adapted to R idioms.
#  Distributed via CRAN (`install.packages("optparse")`).  Used by
#  remake (Make-like R workflows by Rich FitzJohn, 341 stars), tens
#  of thousands of bioinformatics R scripts (DESeq2 QC pipelines,
#  Seurat workflows, ssGSEA2.0 by Broad Institute, vast-tools
#  splicing analysis, nf-core/atacseq, Mendeley API examples, ngsTools
#  population genomics, alfred replication-timing, EasyMicrobiome,
#  GRoSS selection scans, PanExplorer, svaba structural variants,
#  multicenter-sepsis ICU, MARINa master regulators), epidemiology
#  modeling (MRC-IDE, Imperial), academic R pipeline scripts.  R has
#  multiple CLI libraries available: `optparse` (port of Python 2's
#  optparse), `argparse` (port of Python's argparse via Python 3 RPy2
#  bridge — different package), `argparser` (David Au's pure-R
#  argparse alternative), and `docopt` (R port of docopt) — but
#  `optparse` is by far the most widely used in R bioinformatics
#  and statistics workflows.
#
#  R optparse API:
#    library(optparse)
#
#    option_list <- list(
#      make_option(c("-i", "--input"),
#                  type="character",
#                  default=NULL,
#                  help="Input file path",
#                  dest="input_file"),
#      make_option(c("-o", "--output"),
#                  type="character",
#                  default="out.txt",
#                  help="Output file path (default %default)"),
#      make_option(c("-n", "--count"),
#                  type="integer",
#                  default=10,
#                  help="Count of items (default %default)"),
#      make_option(c("-v", "--verbose"),
#                  type="logical",
#                  default=FALSE,
#                  action="store_true",
#                  help="Verbose output"),
#      make_option("--method",
#                  type="character",
#                  default="default",
#                  help="Method to use (one of: default, fast, slow)")
#    )
#
#    parser <- OptionParser(option_list=option_list,
#                           usage="usage: %prog [options] inputs...",
#                           description="Process some inputs.",
#                           epilogue="See manual for details.")
#
#    args <- parse_args(parser, positional_arguments=TRUE)
#    # args$options is the named list of parsed options
#    # args$args is the vector of positional arguments
#
#    if (is.null(args$options$input_file)) {
#      print_help(parser)
#      stop("--input/-i is required")
#    }
#
#  R optparse distinctive features:
#    - PORT OF PYTHON 2's `optparse` MODULE — adapts the same API
#      semantics (OptionParser, make_option, action="store_true",
#      help with %default/%prog interpolation) to R idioms
#    - `make_option(c("-s", "--long"), type=..., default=..., help=...,
#      action=..., dest=...)` — R-native CONSTRUCTOR function for
#      each option; returns an `optparse_option` S4 object
#    - `c("-s", "--long")` for SHORT + LONG alias VECTOR (R's `c()`
#      combine function; can also be c("--long-only") with no short)
#    - `type=` R type string: `"character"` (string), `"integer"`,
#      `"double"`/`"numeric"` (real), `"logical"` (boolean) — drives
#      R type coercion during parse
#    - `default=` R-native default value (NULL, character, integer,
#      logical, etc.)
#    - `help="text with %default and %prog interpolation"` — supports
#      Python-style format placeholders (`%default` is replaced with
#      the option's default value, `%prog` with program name)
#    - `dest="alt_name"` — alternate name for the result list key
#      (e.g. `--list-targets` becomes accessible as `$list_targets`
#      via R's auto-name-mangling but `dest="list_targets"` makes it
#      explicit)
#    - `action="store"` (default — store value), `"store_true"` (set
#      to TRUE), `"store_false"` (set to FALSE), `"callback"` (call
#      a function)
#    - `OptionParser(option_list=..., usage="usage: %prog [opts]",
#      description="...", epilogue="...", add_help_option=TRUE)` —
#      parser CONSTRUCTOR returning an `OptionParser` S4 object
#    - `parse_args(parser, args=commandArgs(TRUE), positional_arguments=
#      FALSE)` — PARSER ENTRY POINT; returns either named list (when
#      positional_arguments=FALSE) or list with `$options` + `$args`
#      (when positional_arguments=TRUE)
#    - `args=commandArgs(TRUE)` — R STDLIB way to get command-line
#      args (returns character vector after `--args`)
#    - `print_help(parser)` — generate formatted help text
#    - `print_usage(parser)` — short usage line
#    - AUTO-INJECTED `--help`/`-h` (unless `add_help_option=FALSE`)
#    - AUTO-INJECTED `--version`/`-v` when `version=` provided
#    - S4 OBJECT MODEL — uses R's S4 object system internally for
#      `OptionParser` and `optparse_option` objects
#    - `add_option(parser, ...)` — IMPERATIVE alternative to
#      `option_list=`: build options incrementally
#  Distinct from R270 Python argparse (Python class hierarchy with
#  ArgumentParser/add_argument — R optparse is the OLDER Python 2
#  optparse-style, not Python 3 argparse-style), R277 Python click
#  (decorator-driven), R278 Python typer (type-annotation-driven),
#  R345 Python cyclopts (modern type-hint-driven), R352 Python docopt
#  (help-text-as-schema — R also has docopt CRAN package separately),
#  R281 Perl Getopt::Long (Perl `=s`/`=i`/`!`/`+` suffix syntax —
#  closest spec-format analog).  R optparse's approach: PORT OF
#  PYTHON 2's `optparse` MODULE adapted to R idioms + `make_option`
#  CONSTRUCTOR FUNCTION for each option + `c("-s", "--long")` R
#  VECTOR for aliases + `type=` R TYPE STRING + `help="%default %prog"`
#  PYTHON-STYLE INTERPOLATION + `action="store"/"store_true"/etc.`
#  Python-argparse-style + `OptionParser(option_list=, usage=,
#  description=, epilogue=)` PARSER OBJECT + `parse_args(parser,
#  positional_arguments=TRUE)` returning `$options` + `$args` LIST +
#  S4 OBJECT MODEL + `commandArgs(TRUE)` R STDLIB args fetching —
#  corpus's **first documented R-port-of-Python-2-optparse CLI
#  library**.  Brings cross-language CLI library taxonomy variant
#  count to 125; R language added to the documented-CLI-language set.
#
#  Surface (verbatim from `R/main.R` `remake_main_options()`):
#
#  Options:
#    -f, --file FILE              remake file to load (default: remake.yml)
#                                 (dest=remake_file)
#    -q, --quiet                  Run quietly (logical action=store_true)
#    -l, --list-targets           List names of valid targets and exit
#                                 (logical action=store_true,
#                                 dest=list_targets)
#    -s, --script                 Print R script to standard output
#                                 (logical action=store_true)
#        --script-file FILE       Print R script to file
#                                 (dest=script_file)
#        --install-missing-packages
#                                 Install missing packages
#                                 (logical action=store_true)
#    -v, --version                Version information
#                                 (logical action=store_true)
#
#  Auto-injected by R optparse:
#    -h, --help                   Show help (auto-added unless
#                                 add_help_option=FALSE)
#
#  Positional:
#    TARGET...                    Targets to build (default target
#                                 used if none given); errors if any
#                                 positional arg starts with `--`
#                                 (parsed via positional_arguments=TRUE)
#
#  Examples:
#    remake                       Build default target from remake.yml
#    remake target1 target2       Build specific targets
#    remake --list-targets        List all valid targets
#    remake -f Makefile.yml ...   Use alternate remake file
#    remake -s > script.R         Generate R script from remake.yml
#    remake --version             Show remake package version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also R optparse users):
#    - r / Rscript / R (IN CORPUS — R interpreter and script runner;
#      use hand-rolled CLI parsing in C, not optparse)
#    - littler (IN CORPUS via _r — Dirk Eddelbuettel's r script
#      runner; uses its own getopt-based CLI not optparse)
#    - radian (modern R console — written in Python NOT R, so doesn't
#      use R optparse)
#    - vast-tools (vastgroup/vast-tools 94 stars — vertebrate
#      transcript splicing analysis, FUTURE candidate)
#    - EasyMicrobiome (YongxinLiu 152 stars — microbiome workflow,
#      research scripts not packaged binaries)
#    - ssGSEA2.0 (broadinstitute/ssGSEA2.0 327 stars — Broad Institute
#      Gene Set Enrichment Analysis, FUTURE candidate)
#    - nf-core/atacseq (Nextflow ATAC-seq pipeline with R scripts —
#      _nf-core IN CORPUS; the R scripts are pipeline components
#      not standalone binaries)
#    - facets-suite (mskcc — cancer genomics, FUTURE candidate)
#    - flair / drimseq / wbs / FIDDLE / grohmm / SCALEX (research
#      bioinformatics scripts, not packaged user-facing binaries)
# ============================================================================

_remake() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-f --file)'{-f,--file}'=[remake file to load (default: remake.yml)]:file:_files -g "*.yml"' \
    '(-q --quiet)'{-q,--quiet}'[run quietly]' \
    '(-l --list-targets)'{-l,--list-targets}'[list names of valid targets and exit]' \
    '(-s --script)'{-s,--script}'[print R script to standard output]' \
    '--script-file=[print R script to file]:file:_files -g "*.R"' \
    '--install-missing-packages[install missing R packages]' \
    '(-v --version)'{-v,--version}'[show version information]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*:target:'
}

_remake "$@"
