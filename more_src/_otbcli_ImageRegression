#compdef otbcli_ImageRegression
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ImageRegression.html
# Orfeo ToolBox: predict values from an image using a regression model

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input image to predict]:image:_files' \
  '-mask[mask restricting prediction to nonzero pixels]:image:_files' \
  '-model[regression model file]:model:_files' \
  '-imstat[XML statistics file for centering and reducing]:file:_files' \
  '-out[output image of predicted values]:output:_files' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
