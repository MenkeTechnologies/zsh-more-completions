#compdef dng_validate
# Documentation: https://github.com/aizvorski/dng_sdk/blob/master/documents/doxygen/dng_validate.dox
# Adobe DNG SDK: parse and validate DNG/TIFF-EP files against the DNG spec

local ret=1

_arguments -s -S \
  '-v[verbose: write parsed tag structure to stdout]' \
  '-d+[verbose with max lines of data per tag]:lines' \
  '-f[use floating-point math]' \
  '-b4[four-channel demosaic output]' \
  '-s+[select CFA index (zero-based)]:CFA index' \
  '-q+[bin during demosaic to target width]:target binned width' \
  '-cs1[output color space sRGB]' \
  '-cs2[output color space Adobe RGB]' \
  '-cs3[output color space ProPhoto RGB]' \
  '-cs4[output color space ColorMatch]' \
  '-cs5[output grayscale gamma 1.8]' \
  '-cs6[output grayscale gamma 2.2]' \
  '-16[output 16-bit-per-component images]' \
  '-1+[write stage 1 unprocessed raw to file]:file:_files' \
  '-2+[write stage 2 linearized data to file]:file:_files' \
  '-3+[write stage 3 demosaiced data to file]:file:_files' \
  '-tif+[write final rendered image as TIFF]:file:_files' \
  '-dng+[reserialize parsed DNG to file]:file:_files' \
  '*:DNG file:_files -g "*.(dng|DNG|tif|tiff)"' && ret=0

return ret
