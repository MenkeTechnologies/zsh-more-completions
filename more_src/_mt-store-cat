#compdef mt-store-cat
# Print metrictank chunks stored in Cassandra

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-archive=[archive to fetch for given metric]:archive' \
  '-cassandra-addrs=[cassandra host addresses]:addrs' \
  '-cassandra-auth[enable cassandra authentication]' \
  '-cassandra-ca-path=[cassandra CA certificate path]:_files' \
  '-cassandra-consistency=[write consistency level]:level' \
  '-cassandra-create-keyspace[enable keyspace/tables creation]' \
  '-cassandra-disable-initial-host-lookup[skip host info retrieval]' \
  '-cassandra-host-selection-policy=[host selection policy]:policy' \
  '-cassandra-host-verification[host verification when using SSL]' \
  '-cassandra-keyspace=[keyspace for metric data]:keyspace' \
  '-cassandra-omit-read-timeout=[omit reads older than this]:dur' \
  '-cassandra-password=[authentication password]:password' \
  '-cassandra-read-concurrency=[max concurrent reads]:n' \
  '-cassandra-read-queue-size=[max outstanding reads]:n' \
  '-cassandra-retries=[query retry count]:n' \
  '-cassandra-schema-file=[schema file path]:_files' \
  '-cassandra-ssl[enable SSL connection]' \
  '-cassandra-timeout=[cassandra timeout]:dur' \
  '-cassandra-username=[authentication username]:user' \
  '-config=[configuration file path]:_files' \
  '-cql-protocol-version=[CQL protocol version]:n' \
  '-fix=[fix data to this interval]:interval' \
  '-from=[get data from, inclusive]:from' \
  '-groupTTL=[group chunks in TTL buckets]:unit:(s m h d)' \
  '-index-archive-table=[archive table name]:table' \
  '-index-init-load-concurrency=[partitions to load concurrently]:n' \
  '-index-schema-file=[index schema file]:_files' \
  '-index-table=[index table name]:table' \
  '-index-timeout=[cassandra request timeout]:dur' \
  '-print-ts[print timestamps instead of formatted dates]' \
  '-time-zone=[timezone for interpreting from/to]:tz' \
  '-to=[get data until, exclusive]:to' \
  '-verbose[verbose output]' \
  '-version[print version string]' \
  '-window-factor=[compaction window size relative to TTL]:n' && ret=0

return ret
