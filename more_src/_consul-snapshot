#compdef consul-snapshot
# Documentation: https://man.archlinux.org/search?q=consul-snapshot
# Reference accessed: 2026-05-16

# consul-snapshot: take/save/restore Consul snapshots
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
case consul-snapshot in
  consul-snapshot)
    commands=(
      'agent:run snapshot agent'
      'restore:restore a snapshot'
      'save:save a snapshot'
      'inspect:inspect a snapshot'
      'help:show help'
      'version:show version'
    )
    ;;
  consul-replicate)
    commands=(
      'help:show help'
      'version:show version'
    )
    ;;
esac
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-config=[config file]:file:_files' \
  '-http-addr=[Consul HTTP addr]:addr:' \
  '-token=[ACL token]:token:' \
  '-ca-file=[CA file]:file:_files' \
  '-ca-path=[CA path]:dir:_files -/' \
  '-client-cert=[client cert]:file:_files' \
  '-client-key=[client key]:file:_files' \
  '-datacenter=[Consul DC]:dc:' \
  '-namespace=[Consul namespace]:ns:' \
  '-tls-server-name=[TLS server name]:host:' \
  '-stale[allow stale reads]' \
  '-log-level=[log level]:level:(trace debug info warn err)' \
  '-log-file=[log file]:file:_files' \
  '-syslog[log to syslog]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'consul-snapshot command' commands && ret=0 ;;
esac
return ret
