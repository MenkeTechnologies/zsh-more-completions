#compdef lvmlockctl

# lvmlockctl: control runtime state of lvmlockd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-q[quit lvmlockd]' \
  '-i[dump info / state]' \
  '-d[dump debug log]' \
  '-w[wait/quiesce locks]' \
  '-r[force drop locks]:vgname:' \
  '-E[stop lockspace]:vgname:' \
  '-S[run sanlock subcommand]:cmd:' \
  '*::lvmlockctl args:_files' && ret=0
return ret
