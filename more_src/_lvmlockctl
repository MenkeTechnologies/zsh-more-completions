#compdef lvmlockctl

# lvmlockctl: control lvmlockd locks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-q --quit)'{-q,--quit}'[tell lvmlockd to exit]' \
  '(-i --info)'{-i,--info}'[show lock daemon info]' \
  '(-d --dump)'{-d,--dump}'[dump full state]' \
  '(-w --wait)'{-w,--wait=}'[wait for completion]:sec:' \
  '(-f --force)'{-f,--force=}'[force action]:val:' \
  '(-r --refresh)'{-r,--refresh=}'[refresh]:val:' \
  '(-k --kill)'{-k,--kill=}'[kill a VG]:vg:' \
  '(-D --drop)'{-D,--drop=}'[drop locks for VG]:vg:' \
  '(-E --gl-enable)'{-E,--gl-enable=}'[enable global lock on VG]:vg:' \
  '(-X --gl-disable)'{-X,--gl-disable=}'[disable global lock on VG]:vg:' \
  '(-S --stop-lockspaces)'{-S,--stop-lockspaces}'[stop lockspaces]' \
  '*::lvmlockctl args:_files' && ret=0
return ret
