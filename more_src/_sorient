#compdef sorient gmx-sorient
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-sorient.html
# gmx sorient: analyze solvent orientation around solutes

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-s[structure+mass database]:file:_files' \
  '-n[index file]:file:_files' \
  '-o[distribution of cos(theta_1) output]:file:_files' \
  '-no[distribution of cos(theta_2) output]:file:_files' \
  '-ro[angular averages vs distance]:file:_files' \
  '-co[cumulative distribution output]:file:_files' \
  '-rc[solvent radial distribution]:file:_files' \
  '-b[start time for frame reading]:time:' \
  '-e[end time for frame reading]:time:' \
  '-dt[frame selection interval]:time:' \
  '-w[view output files]' \
  '-xvg[plot format]:format:(xmgrace xmgr none)' \
  '-com[use center of mass as reference]' \
  '-v23[use vector between atoms 2 and 3]' \
  '-rmin[minimum distance cutoff]:real:' \
  '-rmax[maximum distance cutoff]:real:' \
  '-cbin[cosine histogram bin width]:real:' \
  '-rbin[radial histogram bin width]:real:' \
  '-pbc[account for periodic boundary conditions]' && ret=0

return ret
