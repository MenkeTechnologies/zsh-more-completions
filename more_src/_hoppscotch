#compdef hoppscotch hopp hoppctl hoppscotch-cli hopp-cli
# _hoppscotch — Hoppscotch hopp CLI for the Hoppscotch open-source API testing tool running collections environments tests headlessly producing JUnit-style reports with HTTP REST GraphQL WebSocket gRPC support (hoppscotch team, TypeScript); commander.js
# upstream: https://github.com/hoppscotch/hoppscotch

_hoppscotch() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'whoami:show current user'
        'test:run tests'
        'send:send request'
        'list:list collections'
        'pull:pull collection from cloud'
        'push:push collection to cloud'
        'open:open in browser'
        'init:initialize project'
        'config:show or edit config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--cwd=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hoppscotch subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '--env=+[file]:file:_files -g "*.json *.yaml *.yml"' \
                    '-e+[file]:file:_files -g "*.json *.yaml *.yml"' \
                    '--reporter=+[r]:r:(cli junit json html)' \
                    '--reporter-junit-export=+[file]:file:_files -g "*.xml"' \
                    '--delay=+[ms]:n:' \
                    '--bail[bail on failure]' \
                    '--insecure[insecure TLS]' \
                    '*:collection file:_files -g "*.json *.har"' ;;
                send) _arguments \
                    '--method=+[m]:m:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
                    '--header=+[csv]:str:' \
                    '--data=+[json]:str:' \
                    '--auth=+[type]:t:(basic bearer apikey oauth2)' \
                    '*:URL:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_hoppscotch "$@"
