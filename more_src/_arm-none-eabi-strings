#compdef arm-none-eabi-strings
# _arm-none-eabi-strings — Arm Limited arm-none-eabi-strings CLI for the bare-metal ARM cross-strings utility printing printable character sequences from binary or ELF object files for firmware string discovery default minimum length 4 (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-strings() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a[scan all sections]' \
        '--all[scan all sections]' \
        '-d[only scan data sections]' \
        '--data[only scan data sections]' \
        '-f[print filename]' \
        '--print-file-name[print filename]' \
        '-n+[min length]:n:' \
        '--bytes=+[min length]:n:' \
        '-t+[radix]:r:(d o x)' \
        '--radix=+[radix]:r:(d o x)' \
        '-T+[bfd-target]:str:' \
        '--target=+[bfd-target]:str:' \
        '-w[include whitespace]' \
        '--include-all-whitespace[include whitespace]' \
        '-s[separator]:str:' \
        '--output-separator=+[sep]:str:' \
        '-e+[encoding]:e:(s S b l B L)' \
        '--encoding=+[encoding]:e:(s S b l B L)' \
        '*:input files:_files'
}

_arm-none-eabi-strings "$@"
