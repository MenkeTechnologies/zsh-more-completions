#compdef esm-fold
# Documentation: https://github.com/facebookresearch/esm#esmfold
# ESMFold structure prediction from a FASTA file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --fasta)'{-i,--fasta}'=[path to input FASTA file]:file:_files' \
  '(-o --pdb)'{-o,--pdb}'=[path to output PDB directory]:dir:_files -/' \
  '--num-recycles=[number of recycling iterations]:n:' \
  '--max-tokens-per-batch=[maximum tokens per GPU forward pass]:n:' \
  '--chunk-size=[axial attention chunk size to reduce memory]:n:(128 64 32)' \
  '--cpu-only[CPU-only processing]' \
  '--cpu-offload[offload parameters to CPU to reduce GPU memory]' && ret=0

return ret
