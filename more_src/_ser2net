#compdef ser2net

# Zsh completion for ser2net (serial port to network proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[Use the specified config file]:config file:_files' \
  '-C+[Specify a config line on the command line]:config line' \
  '-p+[Set the admin port]:control port' \
  '-P+[Write PID to the specified file]:pid file:_files' \
  '-n[Do not fork (stay in foreground)]' \
  '-d[Enable debug mode (implies -n)]' \
  '-b[Handle incoming connections from SerialBridge]' \
  '-l[Increase debug level]' \
  '-v[Display version and exit]' \
  '-s[Specify the default signature]:signature' \
  '-u[Disable UUCP-style locking]' \
  '-t+[UUCP lock directory]:directory:_files -/' && ret=0

return ret
