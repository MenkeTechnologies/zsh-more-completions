#compdef codes_split_file
# Documentation: https://confluence.ecmwf.int/display/ECC/codes_split_file
# Source: ecmwf/eccodes tools/codes_split_file.cc — split GRIB/BUFR file into N chunks (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-v[verbose]' \
    '1:nchunks (-1 = per message):_default' \
    '2:input file:_files' \
    && ret=0

return ret
