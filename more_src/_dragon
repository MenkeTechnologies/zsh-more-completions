#compdef dragon dragon-drag-and-drop
# _dragon — mwh/dragon (CLI window for drag-and-drop interop with X11/Wayland; positional args become draggable items, -x exit after drop, -k keep running, -t target accepts drops, -a accept drops only from a single source, -X exec command for each dropped file, -p print drop target)
# upstream: https://github.com/mwh/dragon
# Flags from dragon main.c on tip.

_dragon() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-x[exit after first drop]' \
        '-k[keep window after drop]' \
        '-t[target mode (accept drops)]' \
        '-a[accept single source only]' \
        '-X+[exec on each dropped file]:command:_command_names -e' \
        '-p[print dropped path]' \
        '-A[icon-only mode]' \
        '-I[no icons]' \
        '-T+[title]:title:' \
        '*:file:_files'
}

_dragon "$@"
