#compdef arachni_rpcd
# Documentation: https://github.com/Arachni/arachni/wiki/RPC-server
# Arachni RPC Dispatcher daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output this message]' \
  '--version[show version information]' \
  '--address=[hostname or IP address to bind to]:address' \
  '--external-address=[hostname or IP address to advertise]:address' \
  '--port=[port to listen to]:port' \
  '--port-range=[port range for spawned RPC instances]:range' \
  '--pool-size=[how many Instances to have available]:size' \
  '--reroute-to-logfile[reroute all output to log-files]' \
  '--verbose[show verbose output]' \
  '--debug=[show debugging information]:level:(1 2 3)' \
  '--only-positives[only output positive results]' \
  '--neighbour=[URL of a neighbouring Dispatcher]:url' \
  '--weight=[weight of this node]:float' \
  '--pipe-id=[identifier for the attached bandwidth pipe]:id' \
  '--nickname=[nickname for this Dispatcher]:name' \
  '--ssl-ca=[location of the CA certificate (.pem)]:file:_files' \
  '--server-ssl-private-key=[location of the server SSL private key]:file:_files' \
  '--server-ssl-certificate=[location of the server SSL certificate]:file:_files' \
  '--client-ssl-private-key=[location of the client SSL private key]:file:_files' \
  '--client-ssl-certificate=[location of the client SSL certificate]:file:_files' && ret=0

return ret
