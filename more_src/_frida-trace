#compdef frida-trace

# Zsh completion for frida-trace - function tracing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-D+[connect to device with the given ID]:device ID' \
  '--device=[connect to device with the given ID]:device ID' \
  '-U[connect to USB device]' \
  '--usb[connect to USB device]' \
  '-R[connect to remote frida-server]' \
  '--remote[connect to remote frida-server]' \
  '-H+[connect to remote frida-server on host]:host' \
  '--host=[connect to remote frida-server on host]:host' \
  '-f+[spawn FILE]:target:_files' \
  '--file=[spawn FILE]:target:_files' \
  '-F[attach to frontmost application]' \
  '--attach-frontmost[attach to frontmost application]' \
  '-n+[attach to NAME]:process name' \
  '--attach-name=[attach to NAME]:process name' \
  '-p+[attach to PID]:pid' \
  '--attach-pid=[attach to PID]:pid' \
  '*-i+[include function GLOB]:function pattern' \
  '*--include=[include function GLOB]:function pattern' \
  '*-x+[exclude function GLOB]:function pattern' \
  '*--exclude=[exclude function GLOB]:function pattern' \
  '*-I+[include module GLOB]:module pattern' \
  '*--include-module=[include module GLOB]:module pattern' \
  '*-X+[exclude module GLOB]:module pattern' \
  '*--exclude-module=[exclude module GLOB]:module pattern' \
  '*-a+[include Objective-C method GLOB]:method pattern' \
  '*-T+[include Swift function GLOB]:function pattern' \
  '*-m+[include Objective-C method GLOB]:method pattern' \
  '*-M+[exclude Objective-C method GLOB]:method pattern' \
  '*-j+[include Java method]:method' \
  '*-J+[exclude Java method]:method' \
  '-S+[load handler script]:script:_files -g "*.js"' \
  '--init-session=[load handler script]:script:_files -g "*.js"' \
  '-P+[load PARAMETERS]:params file:_files -g "*.json"' \
  '--parameters=[load PARAMETERS]:params file:_files -g "*.json"' \
  '-o+[output to FILE]:file:_files' \
  '--output=[output to FILE]:file:_files' \
  '-d[decorate thread ID]' \
  '--decorate[decorate thread ID]' \
  '-q[be quiet]' \
  '--quiet[be quiet]' \
  '--no-pause[do not pause after spawn]' \
  '*:target' && ret=0

return ret
