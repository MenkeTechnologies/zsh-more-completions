#compdef readme-generator-for-helm readme-generator
# Documentation: https://github.com/bitnami/readme-generator-for-helm
# Auto-generate Helm chart README parameter tables from values.yaml

local ret=1

_arguments -s -S \
  '(-v --values)'{-v,--values}'=[path to the values.yaml file]:file:_files' \
  '(-r --readme)'{-r,--readme}'=[path to the README.md file]:file:_files' \
  '(-c --config)'{-c,--config}'=[path to the config file]:file:_files' \
  '(-s --schema)'{-s,--schema}'=[path for the OpenAPI Schema output file]:file:_files' \
  '--version[show readme generator version]' \
  '(-h --help)'{-h,--help}'[display help for command]' && ret=0

return ret
