#compdef s6-envuidgid
# Documentation: https://skarnet.org/software/s6/s6-envuidgid.html
# Reference accessed: 2026-05-30
# s6-envuidgid — set UID/GID/GIDLIST env vars from an account name, then exec a program.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-u -g -B)-u[interpret <account> as a user name]' \
  '(-u -g -B)-g[interpret <account> as a group name]' \
  '(-u -g -B)-B[interpret <account> as user\:group]' \
  '-n[numerical fallback (try literal numeric values if account not found)]' \
  '-i[insist: exit 1 with error if account is unknown]' \
  '-D+[default values if account is unknown (uid\:gid\:gidlist)]:defaults:' \
  '1:account (user, group, or user\:group depending on -u/-g/-B):' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
