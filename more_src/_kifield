#compdef kifield
# _kifield — Devbisme kifield CLI for inserting extracting symbol fields between KiCad schematic source files and CSV/ODS/XLS/XLSX spreadsheets enabling bulk bill-of-materials manufacturer-part-number datasheet field editing (devbisme team, Python); argparse
# upstream: https://github.com/devbisme/kifield

_kifield() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-e+[extract from]:file:_files -g "*.kicad_sch *.sch *.csv *.ods *.xls *.xlsx"' \
        '--extract=+[extract from]:file:_files -g "*.kicad_sch *.sch *.csv *.ods *.xls *.xlsx"' \
        '-i+[insert into]:file:_files -g "*.kicad_sch *.sch *.csv *.ods *.xls *.xlsx"' \
        '--insert=+[insert into]:file:_files -g "*.kicad_sch *.sch *.csv *.ods *.xls *.xlsx"' \
        '-x+[exclude field]:str:' \
        '--exclude=+[exclude field]:str:' \
        '-n+[include field]:str:' \
        '--include=+[include field]:str:' \
        '-r+[recursion subschematic]:b:(true false)' \
        '--recurse=+[recursion subschematic]:b:(true false)' \
        '-g+[group ref]:str:' \
        '--group=+[group ref]:str:' \
        '-w[overwrite]' \
        '--overwrite[overwrite]' \
        '-b[backup]' \
        '--backup[backup]' \
        '--field=+[field name]:str:' \
        '*:files:_files'
}

_kifield "$@"
