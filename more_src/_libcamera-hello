#compdef libcamera-hello

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2)' \
  '--list-cameras[list available cameras]' \
  '--camera=[camera index]:index:' \
  '(-t --timeout)'{-t,--timeout}'=[time to run in ms]:milliseconds:' \
  '--width=[capture width]:width:' \
  '--height=[capture height]:height:' \
  '--viewfinder-width=[viewfinder width]:width:' \
  '--viewfinder-height=[viewfinder height]:height:' \
  '--nopreview[do not show preview window]' \
  '--preview=[preview type]:type:(qt drm)' \
  '--fullscreen[fullscreen preview]' \
  '--info-text=[info text overlay]:text:' \
  '--hdr=[HDR mode]:mode:(off auto sensor)' \
  '--hflip[horizontal flip]' \
  '--vflip[vertical flip]' \
  '--rotation=[image rotation]:degrees:(0 180)' \
  '--roi=[region of interest]:roi:' \
  '--shutter=[shutter time in microseconds]:us:' \
  '--gain=[analogue gain]:gain:' \
  '--metering=[metering mode]:mode:(centre spot average custom)' \
  '--exposure=[exposure mode]:mode:(normal short long custom)' \
  '--ev=[EV compensation]:ev:' \
  '--awb=[AWB mode]:mode:(auto incandescent tungsten fluorescent indoor daylight cloudy custom)' \
  '--awbgains=[AWB gains]:gains:' \
  '--brightness=[brightness]:value:' \
  '--contrast=[contrast]:value:' \
  '--saturation=[saturation]:value:' \
  '--sharpness=[sharpness]:value:' \
  '--denoise=[denoise mode]:mode:(off cdn fast hq)' \
  '--framerate=[framerate]:fps:' \
  '--tuning-file=[camera tuning file]:file:_files' \
  '*:file:_files' && ret=0

return ret
