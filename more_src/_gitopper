#compdef gitopper
# Documentation: https://github.com/miekg/gitopper
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-c,--config}'[configuration file]:config file:_files' \
  '--listen[listen address]:address:' \
  '--debug[enable debug logging]' \
  '*:file:_files' && ret=0

return ret
