#compdef tuf
# _tuf — repository-side CLI for The Update Framework (theupdateframework/go-tuf)
# upstream: https://github.com/theupdateframework/go-tuf
# Subcommands from examples/cli/tuf/cmd/ (cobra).

_tuf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'initialize a TUF repository'
                i:'initialize a TUF repository'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_tuf "$@"
