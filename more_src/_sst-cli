#compdef sst

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize an SST app'
  'dev:run development environment'
  'deploy:deploy your app'
  'remove:remove your app'
  'refresh:refresh stack state'
  'unlock:unlock the lock state'
  'cancel:cancel running update'
  'shell:run command with linked resources'
  'secret:secret commands'
  'install:install required dependencies'
  'add:add a provider/plugin'
  'state:state commands'
  'console:open SST Console'
  'tunnel:tunnel commands'
  'cert:cert commands'
  'completion:generate shell completion'
  'completions:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--stage=[stage]:s:' \
  '*--config=[config file]:file:_files' \
  '*--print-logs[print logs]' \
  '*--no-color[no color]' \
  '*--non-interactive[non-interactive]' \
  '*--profile=[AWS profile]:p:' \
  '*--region=[AWS region]:r:' \
  '*--verbose[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sst command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy|dev|remove|refresh)
        _arguments \
          '*--target=[target]:t:' \
          '*--continue[continue on error]' \
          '*: :' && ret=0 ;;
      (secret)
        _arguments \
          '1:subcommand:(set get list remove load)' \
          '*: :' && ret=0 ;;
      (state)
        _arguments \
          '1:subcommand:(export import edit migrate remove reset upload show)' \
          '*: :' && ret=0 ;;
      (cert)
        _arguments \
          '1:subcommand:(install uninstall)' \
          '*: :' && ret=0 ;;
      (tunnel)
        _arguments \
          '1:subcommand:(start stop install uninstall)' \
          '*: :' && ret=0 ;;
      (completion|completions)
        _arguments '1:shell:(bash zsh fish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
