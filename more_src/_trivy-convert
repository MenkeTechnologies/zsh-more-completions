#compdef trivy-convert
# _trivy-convert — Aqua Trivy report format converter subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-convert() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--format=+[output format]:fmt:(table json sarif template cyclonedx spdx spdx-json github cosign-vuln)' \
        '-f+[output format]:fmt:(table json sarif template cyclonedx spdx spdx-json github cosign-vuln)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--list-all-pkgs[list all packages]' \
        '--ignore-unfixed[ignore unfixed]' \
        '--exit-code=+[exit code]:n:' \
        '--report=+[report mode]:r:(all summary)' \
        '--ignorefile=+[ignore file]:file:_files' \
        '--include-non-failures[include non failures]' \
        '*:json-report:_files -g "*.json"'
}

_trivy-convert "$@"
