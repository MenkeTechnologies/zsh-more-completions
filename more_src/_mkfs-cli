#compdef mkfs-cli
# _mkfs-cli — util-linux mkfs filesystem creation dispatcher CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_mkfs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-t+[fstype]:t:(ext2 ext3 ext4 btrfs xfs vfat fat exfat ntfs reiserfs jfs minix bfs cramfs hfs hfsplus f2fs udf ntfs3 erofs squashfs)' \
        '-c[check bad blocks before creating]' \
        '-l+[bad blocks list file]:file:_files' \
        '-v[verbose]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_mkfs-cli "$@"
