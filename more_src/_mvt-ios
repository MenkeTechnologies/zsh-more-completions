#compdef mvt-ios

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:show version'
  'decrypt-backup:decrypt iOS backup'
  'extract-key:extract decryption key'
  'check-backup:scan backup for IOCs'
  'check-fs:scan filesystem dump for IOCs'
  'check-iocs:check IOC files'
  'download-iocs:download IOC indicators'
)

_arguments -C \
  '--disable-update-check[disable version check]' \
  '--disable-indicator-update-check[disable indicator update check]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'mvt-ios subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (decrypt-backup)
        _arguments -s \
          '(-d --destination)'{-d,--destination}'=[destination path]:dir:_files -/' \
          '(-p --password)'{-p,--password}'=[password]:pw:' \
          '(-k --key-file)'{-k,--key-file}'=[key file]:file:_files' \
          '(-H --hashes)'{-H,--hashes}'[generate hashes]' \
          '*:backup path:_files -/' && ret=0 ;;
      (extract-key)
        _arguments -s \
          '(-p --password)'{-p,--password}'=[password]:pw:' \
          '(-k --key-file)'{-k,--key-file}'=[output key file]:file:_files' \
          '*:backup path:_files -/' && ret=0 ;;
      (check-backup|check-fs)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-o --output)'{-o,--output}'=[output path]:dir:_files -/' \
          '(-f --fast)'{-f,--fast}'[fast scan]' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-m --module)'{-m,--module}'=[module name]:module:' \
          '(-H --hashes)'{-H,--hashes}'[generate hashes]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*:path:_files -/' && ret=0 ;;
      (check-iocs)
        _arguments -s \
          '*'{-i,--iocs}'=[IOCs file]:file:_files' \
          '(-l --list-modules)'{-l,--list-modules}'[list modules]' \
          '(-m --module)'{-m,--module}'=[module name]:module:' \
          '*:folder:_files -/' && ret=0 ;;
    esac
    ;;
esac

return ret
