#compdef libftdi-config
# Documentation: https://man.archlinux.org/search?q=libftdi-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '*:library:' && ret=0

return ret
