#compdef libftdi-config
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/libftdi-config.1.html
# Reference accessed: 2026-05-19
# Verified: `libftdi-config --help` from installed binary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '*:library:' && ret=0

return ret
