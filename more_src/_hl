#compdef hl
# Documentation: https://github.com/pamburus/hl
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# pamburus/hl: JSON/logfmt log viewer (flags from src/cli.rs Opt)

local ret=1
_arguments -s -S \
  '*--config=[config file]:file:_files' \
  '-s[sort chronologically]' \
  '-F[follow / live streams]' \
  '--tail=[preload lines in follow mode]:n:' \
  '--sync-interval-ms=[follow poll ms]:ms:' \
  '--paging=[pager mode]:mode:(auto always never)' \
  '-P[disable pager]' \
  '-l+,--level=[minimum log level]:level:' \
  '--since+[filter timestamp lower bound]:time:' \
  '--until+[filter timestamp upper bound]:time:' \
  '*-f+,--filter=*[field filter expression]:filter:' \
  '*-q+,--query=*[boolean query]:query:' \
  '--color=[ANSI color policy]:when:(auto always never)' \
  '-C[force color]' \
  '--theme=[color theme name]:theme:' \
  '-r,--raw[emit raw JSON lines]' \
  '--raw-fields[raw field values]' \
  '*-h+,--hide=*[hide fields by key]:key:' \
  '--flatten=[object flattening]:mode:(never always)' \
  '-t+,--time-format=[strftime format]:format:' \
  '-Z+,--time-zone=[IANA zone]:tz:' \
  '-L,--local[use local timezone]' \
  '-e,--hide-empty-fields' \
  '-E,--show-empty-fields' \
  '-x+,--expansion=[field expansion]:mode:(never inline auto always)' \
  '-o+,--output=[output file]:file:_files' \
  '--delimiter=[log entry delimiter]:delim:(auto cr lf crlf newline nul)' \
  '--shell-completions=[emit completion script]:shell:(bash elvish fish powershell zsh)' \
  '--man-page[print man page]' \
  '--list-themes=-[list themes optional tag filter]' \
  '*--help=-[built-in help verbosity]:verb:(short long)' \
  '*::input files:_files' && ret=0
return ret
