#compdef ucg
# Documentation: https://github.com/gvansickle/ucg/blob/master/README.md
# ucg - UniversalCodeGrep, fast grep-like code searcher

local ret=1

_arguments -s -S \
  '(-? --help)'{-?,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[display program version]' \
  '--usage[show brief usage information]' \
  '(--help-types --list-file-types)'{--help-types,--list-file-types}'[list all supported file types]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case distinctions in pattern]' \
  '--smart-case[ignore case if pattern is all lowercase]' \
  '--nosmart-case[disable smart-case matching]' \
  '(-Q --literal)'{-Q,--literal}'[treat all pattern characters as literal]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[match a complete word only]' \
  '--column[display column of first match]' \
  '--nocolumn[omit column information]' \
  '(--color --colour)'{--color,--colour}'[display output with ANSI colors]' \
  '(--nocolor --nocolour)'{--nocolor,--nocolour}'[display output without ANSI colors]' \
  '--ignore-dir=[exclude directory by name]:name:_files -/' \
  '--noignore-dir=[include directory by name]:name:_files -/' \
  '*--exclude=[skip files matching glob]:glob:' \
  '*--ignore=[skip files matching glob]:glob:' \
  '*--ignore-file=[skip files matching filter]:filter:' \
  '*--include=[search only files matching glob]:glob:' \
  '(-k --known-types)'{-k,--known-types}'[search only recognized file types]' \
  '(-n --no-recurse)'{-n,--no-recurse}'[do not traverse subdirectories]' \
  '(-r -R --recurse)'{-r,-R,--recurse}'[traverse subdirectories]' \
  '*--type=[include or exclude a file type]:type:' \
  '*--type-add=[add filters to a file type]:spec:' \
  '*--type-del=[remove a file type definition]:type:' \
  '*--type-set=[replace a file type definition]:spec:' \
  '--dirjobs=[number of directory traversal threads]:num:' \
  '(-j --jobs)'{-j,--jobs}'=[number of scanner threads]:num:' \
  '--noenv[ignore .ucgrc configuration files]' \
  '1:pattern:' \
  '*:file:_files' && ret=0

return ret
