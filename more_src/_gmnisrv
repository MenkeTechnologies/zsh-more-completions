#compdef gmnisrv
# _gmnisrv — gmnisrv Gemini protocol server (C); minimal gemini:// server with TLS, CGI, autoindex, regex routes
# upstream: https://git.sr.ht/~sircmpwn/gmnisrv

_gmnisrv() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-C+[config file]:file:_files' \
        '-d[daemon mode]' \
        '*:cmd:'
}

_gmnisrv "$@"
