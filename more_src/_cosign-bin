#compdef cosign
# _cosign-bin — Sigstore cosign artifact signing (Sigstore project, Go); sign + verify container images, blobs, attestations
# upstream: https://github.com/sigstore/cosign

_cosign-bin() {
    local -a sub=(
        'attach:attach signatures/sboms to image'
        'attest:create + sign a SLSA in-toto attestation'
        'attest-blob:attest a blob'
        'clean:remove signatures'
        'completion:print shell completion'
        'copy:copy signatures'
        'download:download signatures'
        'generate:generate signing payload'
        'generate-key-pair:generate key pair'
        'import-key-pair:import key pair'
        'initialize:initialize cosign root'
        'load:load signatures'
        'login:login to registry'
        'manifest:manifest commands'
        'piv-tool:PIV/YubiKey utility'
        'public-key:export public key'
        'save:save signatures to dir'
        'sign:sign a container image'
        'sign-blob:sign a blob'
        'tree:show signatures tree'
        'triangulate:print signature image name'
        'trust-root:manage trust root'
        'upload:upload signatures'
        'verify:verify signatures on image'
        'verify-attestation:verify attestation'
        'verify-blob:verify blob signature'
        'verify-blob-attestation:verify blob attestation'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-d[debug]' \
        '--output-file+[output file]:file:_files' \
        '--timeout+[request timeout]:duration:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cosign subcommand' sub ;;
        args)
            case $words[1] in
                sign) _arguments \
                    '--key+[private key]:file:_files' \
                    '--cert+[cert]:file:_files' \
                    '--cert-chain+[cert chain]:file:_files' \
                    '--certificate-identity+[cert identity]:str:' \
                    '--certificate-identity-regexp+[cert identity regex]:str:' \
                    '--certificate-oidc-issuer+[cert OIDC issuer]:str:' \
                    '--certificate-oidc-issuer-regexp+[cert OIDC issuer regex]:str:' \
                    '--annotation+[annotation]:k=v:' \
                    '--allow-insecure-registry[allow HTTP]' \
                    '--allow-http-registry[allow HTTP registry]' \
                    '--registry-username+[reg user]:str:' \
                    '--registry-password+[reg pass]:str:' \
                    '--registry-token+[reg token]:str:' \
                    '--upload[upload signatures]' \
                    '--yes[skip prompts]' \
                    '--fulcio-url+[Fulcio URL]:url:_urls' \
                    '--rekor-url+[Rekor URL]:url:_urls' \
                    '--oidc-issuer+[OIDC issuer]:url:_urls' \
                    '--oidc-client-id+[OIDC client id]:str:' \
                    '--identity-token+[identity token]:str:' \
                    '--output-certificate+[output cert file]:file:_files' \
                    '--output-signature+[output signature file]:file:_files' \
                    '--output-payload+[output payload]:file:_files' \
                    '--tlog-upload+[upload to transparency log]:bool:' \
                    '*:image:' ;;
                verify) _arguments \
                    '--key+[public key]:file:_files' \
                    '--certificate+[cert]:file:_files' \
                    '--certificate-identity+[cert identity]:str:' \
                    '--certificate-identity-regexp+[cert identity regex]:str:' \
                    '--certificate-oidc-issuer+[cert OIDC issuer]:str:' \
                    '--certificate-oidc-issuer-regexp+[cert OIDC issuer regex]:str:' \
                    '--annotations+[annotations]:str:' \
                    '--allow-insecure-registry[allow HTTP]' \
                    '--rekor-url+[Rekor URL]:url:_urls' \
                    '--output+[output format]:fmt:(text json)' \
                    '*:image:' ;;
                generate-key-pair) _arguments '--output-key-prefix+[output prefix]:str:' '--kms+[KMS URI]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_cosign-bin "$@"
