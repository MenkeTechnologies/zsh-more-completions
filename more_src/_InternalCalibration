#compdef InternalCalibration
# Documentation: https://www.openms.org/documentation/html/TOPP_InternalCalibration.html
# OpenMS: calibrates m/z values internally using known reference masses

local ret=1

_arguments -s -S \
  '(-help)--help[show options]' \
  '--helphelp[show all options including advanced]' \
  '-in[input peak file (mzML)]:file:_files -g "*.mzML"' \
  '-out[output file (mzML)]:file:_files' \
  '-rscript_executable[path to Rscript executable]:file:_files' \
  '-ppm_match_tolerance[tolerance for finding calibrants (ppm)]:double:' \
  '-cal:id_in[peptide identifications for calibration]:file:_files' \
  '-cal:lock_in[reference m/z values file (CSV)]:file:_files' \
  '-cal:lock_out[output file for matched calibration peaks]:file:_files' \
  '-cal:lock_fail_out[output file for unmatched lock masses]:file:_files' \
  '-cal:lock_require_mono[require monoisotopic lock masses only]' \
  '-cal:lock_require_iso[require lock masses with +1 isotope]' \
  '-cal:model_type[calibration function type]:model:(linear linear_weighted quadratic quadratic_weighted)' \
  '*-ms_level[target MS levels]:int:' \
  '-RT_chunking[retention time window in seconds]:double:' \
  '-RANSAC:enabled[enable outlier removal via RANSAC]' \
  '-RANSAC:threshold[RANSAC inlier threshold]:double:' \
  '-RANSAC:pc_inliers[minimum inlier percentage]:int:' \
  '-RANSAC:iter[maximum iterations]:int:' \
  '-goodness:median[median ppm error threshold]:double:' \
  '-goodness:MAD[median absolute deviation threshold]:double:' \
  '-quality_control:models[output model parameters table (CSV)]:file:_files' \
  '-quality_control:models_plot[model parameters plot (PNG)]:file:_files' \
  '-quality_control:residuals[pre/post calibration errors table (CSV)]:file:_files' \
  '-quality_control:residuals_plot[residuals plot (PNG)]:file:_files' \
  '-ini[load TOPP INI configuration file]:file:_files -g "*.ini"' \
  '-write_ini[write default configuration file]:file:_files' \
  '-threads[number of threads (0 = all cores)]:int:' \
  '-log[log file name]:file:_files' \
  '-debug[debug level]:int:' \
  '--force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '-no_progress[disable progress logging]' && ret=0

return ret
