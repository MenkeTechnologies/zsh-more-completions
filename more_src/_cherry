#compdef cherry cherry-cljs

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile ClojureScript files to ES6 modules'
  'run:compile and run a .cljs file'
  'watch:watch and recompile on change'
  'repl:start an interactive REPL'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cherry command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile)
        _arguments \
          '(-d --output-dir)'{-d+,--output-dir=}'[output directory]:dir:_files -/' \
          '--source-maps[generate source maps]' \
          '--no-source-maps[disable source maps]' \
          '--imports=[import map JSON]:file:_files -g "*.json"' \
          '--elide-imports[do not emit import statements]' \
          '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
      (run)
        _arguments \
          '--imports=[import map JSON]:file:_files -g "*.json"' \
          '--main=[main function]:fn:' \
          '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
      (watch)
        _arguments \
          '(-d --output-dir)'{-d+,--output-dir=}'[output directory]:dir:_files -/' \
          '--imports=[import map JSON]:file:_files -g "*.json"' \
          '*::path:_files' && ret=0 ;;
    esac ;;
esac

return ret
