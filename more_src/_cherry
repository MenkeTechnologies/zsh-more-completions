#compdef cherry cherry-cljs
# Documentation: https://github.com/squint-cljs/cherry/blob/main/src/cherry/internal/cli.cljs
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above (squint-cljs/cherry CLI parser).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:compile and run a .cljs file'
  'compile:compile .cljs file(s) to ES6 modules'
  'help:print help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-e+[evaluate expression]:expr:' \
  '--show[print compiled expression]' \
  '--no-run[do not run compiled expression]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cherry command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile|run)
        _arguments \
          '--output-dir=[output directory for JS files]:dir:_files -/' \
          '--extension=[default JS file extension]:ext:' \
          '--elide-imports[do not include imports]' \
          '--elide-exports[do not include exports]' \
          '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
    esac ;;
esac

return ret
