#compdef multiBigwigSummary
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/multiBigwigSummary.html
# deepTools: compute average scores for multiple bigWig files over genomic regions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:((bins\:"analyze equally-sized genome bins" BED-file\:"analyze regions from a BED file"))' \
  '(-b --bwfiles)'{-b,--bwfiles}'[bigWig files]:bw:_files -g "*.bw"' \
  '(-o --out --outFileName)'{-o,--out,--outFileName}'[output .npz file]:file:_files' \
  '--BED[BED file defining analysis regions]:file:_files' \
  '(-l --labels)'{-l,--labels}'[custom sample labels]:labels:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '--chromosomesToSkip[chromosomes to exclude]:chroms:' \
  '(-bs --binSize)'{-bs,--binSize}'[window size in bases]:size:' \
  '(-n --distanceBetweenBins)'{-n,--distanceBetweenBins}'[gap between bins]:n:' \
  '(-r --region)'{-r,--region}'[limit to genome region]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[exclude regions (BED/GTF)]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--outRawCounts[tab-delimited raw scores file]:file:_files' \
  '--metagene[use merged exons instead of full span]' \
  '--transcriptID[GTF transcript feature type]:id:' \
  '--exonID[GTF exon feature type]:id:' \
  '--transcript_id_designator[custom region identifier key]:key:' && ret=0

return ret
