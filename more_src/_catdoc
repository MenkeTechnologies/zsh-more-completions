#compdef catdoc

# Zsh completion for catdoc - Microsoft Word to text converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-a[process all files as one]' \
  '-b[use langstrings for guess]' \
  '-d+[set input charset]:charset' \
  '-f[output only text from frames]' \
  '-l[list character substitution charsets]' \
  '-m+[max line width (default 76)]:width' \
  '-s+[set source charset]:charset' \
  '-t[output as text]' \
  '-u[output unknown characters as \\xHH]' \
  '-w[output as LaTeX]' \
  '-x[output as extended LaTeX]' \
  '*:files:_files -g "*.{doc,DOC}"'
