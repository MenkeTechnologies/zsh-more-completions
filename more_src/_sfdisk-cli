#compdef sfdisk-cli
# _sfdisk-cli — util-linux sfdisk script-friendly partition manipulator CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_sfdisk-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A+[mark partition active]:str:' \
        '--activate=+[mark partition active]:str:' \
        '--backup[backup partition table]' \
        '--backup-file=+[file]:file:_files' \
        '--bytes[show size in bytes]' \
        '--color=+[mode]:c:(auto never always)' \
        '-d[dump partition table to file]' \
        '--dump[dump partition table to file]' \
        '--delete[delete all or specified partitions]' \
        '--disk-id=+[id]:str:' \
        '-F[free space layout]' \
        '--list-free[free space layout]' \
        '-f[force]' \
        '--force[force]' \
        '-g+[show geometry]:str:' \
        '--show-geometry=+[show geometry]:str:' \
        '-J[json output]' \
        '--json[json output]' \
        '-l[list partitions]' \
        '--list[list partitions]' \
        '-n[no act]' \
        '--no-act[no act]' \
        '--no-reread[do not reread partition table]' \
        '--no-tell-kernel[do not tell kernel]' \
        '-O+[backup file]:file:_files' \
        '--backup-pt-sectors=+[backup file]:file:_files' \
        '-o+[output cols]:str:' \
        '--output=+[output cols]:str:' \
        '-q[suppress messages]' \
        '--quiet[suppress messages]' \
        '-R[reread partition table]' \
        '--reread[reread partition table]' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-s+[show size]:str:' \
        '--show-size=+[show size]:str:' \
        '-T[show parts types]' \
        '--list-types[show parts types]' \
        '-u+[unit]:u:(S cylinders sectors)' \
        '--unit=+[unit]:u:(S cylinders sectors)' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[wipe mode]:w:(auto always never)' \
        '--wipe=+[wipe mode]:w:(auto always never)' \
        '-W+[wipe mode partitions]:w:(auto always never)' \
        '--wipe-partitions=+[wipe mode partitions]:w:(auto always never)' \
        '-X+[disklabel type]:t:(dos gpt sgi sun mbr)' \
        '--label=+[disklabel type]:t:(dos gpt sgi sun mbr)' \
        '-Y+[disklabel type]:t:(dos gpt sgi sun mbr)' \
        '--label-nested=+[disklabel type]:t:(dos gpt sgi sun mbr)' \
        '-G[gpt list]' \
        '--list-gpt[gpt list]' \
        '--show-pt-geometry[show pt geometry]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_sfdisk-cli "$@"
