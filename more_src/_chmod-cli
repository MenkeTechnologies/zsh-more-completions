#compdef chmod-cli
# _chmod-cli — GNU coreutils chmod change file mode bits CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_chmod-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[report changes]' \
        '--changes[report changes]' \
        '-f[suppress most errors]' \
        '--silent[suppress most errors]' \
        '--quiet[suppress most errors]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-preserve-root[no preserve root]' \
        '--preserve-root[preserve root]' \
        '--reference=+[reference file]:file:_files' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '*:mode files:_files'
}

_chmod-cli "$@"
