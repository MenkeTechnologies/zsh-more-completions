#compdef hamster
# Documentation: https://github.com/pyrocko/pyrocko/blob/master/src/apps/hamster.py
# pyrocko: simple seismic datalogger for the school seismometer

local ret=1

_arguments -s -S \
  '--port=[device name of the serial port to be used]:port' \
  '--baudrate=[baudrate for serial port]:baudrate' \
  '--timeout=[serial port timeout in seconds]:seconds' \
  '--filelength=[approx file length in seconds]:seconds' \
  '--network=[network name]:network' \
  '--station=[station name]:station' \
  '--location=[location name]:location' \
  '--channel=[channel name]:channel' \
  '--blocksize=[block size for time synchronization]:size' \
  '--lookback=[number of previous blocks to consider]:n' \
  '--debug[enable debugging output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:datadir:_files -/' && ret=0

return ret
