#compdef selenium
# Documentation: source-direct extraction from upstream
# SeleniumHQ/selenium
#   java/src/org/openqa/selenium/grid/Main.java:
#     ServiceLoader<CliCommand> dispatch + the 10 CliCommand
#     implementations discovered via META-INF/services and the
#     Main's `loadCommands()` helper.
#   Per-command `getName()` + `getDescription()` decoded source-
#   direct from each impl class:
#     commands/Standalone.java          -> "standalone"
#     commands/Hub.java                 -> "hub"
#     commands/InfoCommand.java         -> "info"
#     commands/CompletionCommand.java   -> "completion"
#     commands/EventBusCommand.java     -> "event-bus"
#     distributor/httpd/DistributorServer.java -> "distributor"
#     node/httpd/NodeServer.java        -> "node"
#     router/httpd/RouterServer.java    -> "router"
#     sessionmap/httpd/SessionMapServer.java        -> "sessions"
#     sessionqueue/httpd/NewSessionQueueServer.java -> "sessionqueue"
# Reference accessed: 2026-05-30 via gh api.
# SeleniumHQ R183 — follow-up to R182's hunt-skip on "Selenium
# Grid (Main.java) has 8+ subcommands - deserves its own state-
# machine round".  Adds top-level state-machine dispatch for
# all 10 CliCommand impls registered in Selenium 4 Grid.
# Sister tool to the heavily-covered WebDriver family
# (chromedriver/geckodriver/safaridriver covered via stock zsh;
# msedgedriver inherits chromedriver's flag vocabulary per
# R182 hunt-skip).
#
# Note: upstream ships its own `selenium completion zsh`
# generator that emits a tool-version-specific completion file.
# This static completion provides a baseline subcommand-
# dispatch that doesn't require running the generator.  Users
# who want the full per-flag completion at their installed
# version's exact flag surface should run:
#   selenium completion zsh > ~/.local/share/zsh/site-functions/_selenium
# and let that completion override this one (it will, since the
# generator places its output earlier in fpath).

local -a subcmds=(
  'standalone:the selenium server, running everything in-process'
  'hub:a grid hub, composed of sessions, distributor, and router'
  'distributor:adds this server as the distributor in a selenium grid'
  'router:creates a router to front the selenium grid'
  'node:adds this server as a Node in the Selenium Grid'
  'sessions:adds this server as the session map in a selenium grid'
  'sessionqueue:adds this server as the new session queue in a selenium grid'
  'event-bus:standalone instance of the event bus'
  'info:prints information for commands and topics'
  'completion:generate shell autocompletions'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '--version[print version and exit]' \
  '1: :->cmd' \
  '*:: :->sub'

case $state in
  cmd)
    _describe -t commands 'selenium subcommand' subcmds
    ;;
  sub)
    case $words[1] in
      completion)
        # The completion sub takes a shell name positional.
        # Decoded source-direct from CompletionCommand.java's
        # arg-parse logic (zsh + bash supported in 4.x; fish
        # added in 4.18+).
        _arguments \
          '1:shell:(bash zsh fish)'
        ;;
      info)
        # info <topic> prints a topic page.  Topic list decoded
        # source-direct from java/src/org/openqa/selenium/grid/
        # commands/*.txt files: config, distributor, info,
        # kubernetes, security, sessionmaps, tracing.
        _arguments \
          '1:topic:(config distributor info kubernetes security sessionmaps tracing)'
        ;;
      standalone|hub|distributor|router|node|sessions|sessionqueue|event-bus)
        # All 8 server-style commands share a large common
        # config surface via @ConfigValue annotations across
        # the grid/config classes.  Common subset documented
        # here.  Run `selenium <cmd> --help` for the full
        # tool-version-specific list, or use upstream's
        # `selenium completion zsh` to regenerate a richer
        # completion at install time.
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[print command help and exit]' \
          '--config=[load a TOML configuration file]:file:_files -g "*.toml"' \
          '--host=[server bind hostname]:host:_hosts' \
          '--port=[server listen port (standalone default 4444)]:port:' \
          '--external-url=[full external URL the grid will report (proto://host:port)]:url:' \
          '--log-level=[log level (FINE FINER FINEST FATAL ERROR WARNING INFO CONFIG)]:level:(FINE FINER FINEST FATAL ERROR WARNING INFO CONFIG)' \
          '--http-logs[enable HTTP wire logging]' \
          '--allow-cors[allow CORS preflight requests]' \
          '--username=[basic-auth username for the grid endpoints]:user:_users' \
          '--password=[basic-auth password for the grid endpoints]:password:' \
          '--bind-bus[bind the local event-bus]' \
          '--publish-events=[event-bus publish endpoint (tcp://host:port)]:addr:' \
          '--subscribe-events=[event-bus subscribe endpoint (tcp://host:port)]:addr:' \
          '--bind-host[bind to the named host (default true)]:bool:(true false)' \
          '--session-timeout=[session inactivity timeout in seconds]:sec:' \
          '--draining=[mark this server as draining]' \
          '--detect-drivers=[auto-detect locally-installed browser drivers (default true)]:bool:(true false)'
        ;;
    esac
    ;;
esac
