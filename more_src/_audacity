#compdef audacity

# Zsh completion for audacity - Audacity audio editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[block size for display]:block size' \
  '--blocksize=[block size for display]:block size' \
  '-s[set sample rate]:sample rate:(8000 11025 16000 22050 44100 48000 88200 96000 176400 192000)' \
  '*:file:_files -g "*.{wav,mp3,ogg,flac,aiff,aif,wma,aac,m4a,ac3,au,mid,midi,amr,opus,wv,ape}"' && ret=0

return ret
