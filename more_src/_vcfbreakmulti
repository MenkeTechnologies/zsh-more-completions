#compdef vcfbreakmulti
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfbreakmulti.md
# Break multi-allelic VCF records into multiple lines, preserving allele-specific INFO

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
