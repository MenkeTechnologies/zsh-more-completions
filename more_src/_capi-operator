#compdef capi-operator cluster-api-operator
# _capi-operator — Cluster API Operator (CAPI lifecycle/provider operator)
# upstream: https://github.com/kubernetes-sigs/cluster-api-operator
# Flags from cmd/main.go InitFlags() on tip.

_capi-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--watch-filter=[watch-filter label value]:value:' \
        '--watch-configsecret=[watch ConfigMap-backed secret changes]:bool:(true false)' \
        '--watch-configmap=[watch ConfigMap changes for providers]:bool:(true false)' \
        '--namespace=[restrict operator to a single namespace]:ns:' \
        '--profiler-address=[pprof bind host\:port]:host\:port:' \
        '--contention-profiling=[enable lock contention profiling]:bool:(true false)' \
        '--concurrency=[per-provider concurrent reconciles]:n:' \
        '--manager-concurrency=[manager-wide concurrent reconciles]:n:' \
        '--sync-period=[informer resync period]:dur:' \
        '--webhook-port=[webhook server bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_capi-operator "$@"
