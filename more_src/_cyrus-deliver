#compdef cyrus-deliver
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/deliver.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org deliver(8) reference manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-deliver: deliver mail to a Cyrus mailbox
local curcontext="$curcontext" ret=1
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '-d[ignored (mail(1) compatibility)]' \
  '(-r --return-path -f)'{-r+,--return-path=}'[insert Return-Path header]:address:' \
  '(-r --return-path -f)-f+[insert Return-Path header]:address:' \
  '(-m --mailbox)'{-m+,--mailbox=}'[deliver to mailbox]:mailbox:' \
  '(-a --auth-id)'{-a+,--auth-id=}'[authorization id of sender]:authid:' \
  '(-q --ignore-quota)'{-q,--ignore-quota}'[deliver even over quota]' \
  '(-l --lmtp)'{-l,--lmtp}'[accept LMTP protocol on stdin]' \
  '*:recipient:' && ret=0
return ret
