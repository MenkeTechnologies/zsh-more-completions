# _carbon-cli2 — Google Carbon Lang carbon-cli2 CLI command-line frontend wrapping the Carbon experimental successor to C++ open-source written in C++ originally Chandler Carruth at Google now Carbon-Lang community an experimental successor to C++ Carbon-Language-by-Google-team-as-an-experimental-successor-to-C-plus-plus modern API design clear feature coverage memory safety generics CIR Carbon IR interop with C++ template subset Bazel-based build C++-Interoperability-by-default Type-Safe-Generics IR CIR Modular MLIR Bazel-Build clang LLVM-backend C-plus-plus2 Modular Carbon-Modular-Design Carbon-Toolchain syntax checked build run REPL doc explorer prelude lex parse semir compile gen-ir codegen explorer-debug print-token-tree print-parse-tree print-sem-ir lex-only parse-only check-only no-codegen verbose dump (Google Chandler Carruth Carbon Lang community team, C++); custom argparse
# upstream: https://github.com/carbon-language/carbon-lang

_carbon-cli2() {
    local -a sub=(
        'build:Build a Carbon project'
        'check:Type check sources'
        'codegen:Generate code'
        'compile:Full compile (check + codegen)'
        'doc:Generate documentation'
        'explorer:Run Carbon explorer'
        'format:Format Carbon code'
        'help:show help'
        'install:Install Carbon toolchain'
        'lex:Lexer pass'
        'parse:Parser pass'
        'pre-lower:Pre-lower pass'
        'repl:Open Carbon REPL'
        'run:Build and run'
        'semir:SemIR pass'
        'test:Run tests'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--prelude=+[name]:str:' \
        '--prelude-path=+[dir]:dir:_files -/' \
        '--include-dir=+[dir]:dir:_files -/' \
        '*--include-dir=+[dir]:dir:_files -/' \
        '-I+[dir]:dir:_files -/' \
        '*-I+[dir]:dir:_files -/' \
        '--source-root=+[dir]:dir:_files -/' \
        '--xcompile=+[args]:str:' \
        '*--xcompile=+[args]:str:' \
        '--print-token-tree[print token tree]' \
        '--print-parse-tree[print parse tree]' \
        '--print-sem-ir[print SemIR]' \
        '--print-sem-ir-yaml=+[file]:file:_files' \
        '--print-stats[print stats]' \
        '--print-cir[print CIR]' \
        '--print-llvm-ir[print LLVM IR]' \
        '--print-asm[print asm]' \
        '--phase=+[p]:p:(lex parse semir-import semir codegen)' \
        '--lex-only[lex only]' \
        '--parse-only[parse only]' \
        '--check-only[check only]' \
        '--no-codegen[no codegen]' \
        '--dump-llvm-ir=+[file]:file:_files' \
        '--codegen-mode=+[m]:m:(jit emit asm obj llvm-ir mlir)' \
        '--target=+[t]:str:' \
        '--target-arch=+[arch]:str:' \
        '--target-cpu=+[cpu]:str:' \
        '--target-features=+[features]:str:' \
        '--target-triple=+[triple]:str:' \
        '--linker=+[name]:str:' \
        '--no-link[no link]' \
        '-o+[output]:file:_files' \
        '--output=+[file]:file:_files' \
        '--input-format=+[f]:f:(carbon ascii-protobuf-text-format binary-protobuf-text-format)' \
        '-O+[level]:n:(0 1 2 3)' \
        '-O0[no optimize]' \
        '-O1[O1]' \
        '-O2[O2]' \
        '-O3[O3]' \
        '-g[debug info]' \
        '--debug[debug]' \
        '--treat-warnings-as-errors[werror]' \
        '--werror[warn as error]' \
        '--no-warnings[no warnings]' \
        '--ignore-fail-prefix=+[prefix]:str:' \
        '--explorer-debug[explorer debug]' \
        '--max-error-count=+[N]:n:' \
        '--color=+[c]:c:(auto always never)' \
        '--diagnostic-format=+[fmt]:f:(text json yaml)' \
        '--print-stack-on-error[print stack on error]' \
        '--no-prelude[no prelude]' \
        '--module=+[name]:str:' \
        '--exclude=+[file]:_files' \
        '*--exclude=+[file]:_files' \
        '--ffi[enable FFI]' \
        '--no-ffi[no FFI]' \
        '--cpp-include-dir=+[dir]:dir:_files -/' \
        '*--cpp-include-dir=+[dir]:dir:_files -/' \
        '--cpp-args=+[args]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'carbon subcommand' sub ;;
        args)
            case $words[1] in
                build|check|codegen|compile|lex|parse|semir|run|explorer|format|repl|doc|test|pre-lower) _arguments '*:carbon file:_files -g "*.carbon"' ;;
            esac
            ;;
    esac
}

_carbon-cli2 "$@"
