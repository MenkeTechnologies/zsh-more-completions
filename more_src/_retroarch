#compdef retroarch

# Zsh completion for retroarch - emulator frontend

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-L --libretro)'{-L,--libretro}'[specify libretro core path]:core:_files' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '--appendconfig[append extra config files]:config file:_files' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--log-file[set log output file]:log file:_files' \
  '--host[connect to netplay host]:hostname' \
  '--port[specify port for netplay]:port' \
  '--stateslot[set save state slot]:slot' \
  '--nick[set netplay nickname]:nickname' \
  '--menu[start directly in menu]' \
  '--features[print available features]' \
  '--subsystem[specify content subsystem]:subsystem name' \
  '(-e --entryslot)'{-e,--entryslot}'[specify subsystem entry slot]:slot' \
  '(-s --save)'{-s,--save}'[specify save state path]:savestate:_files' \
  '--record[record video to file]:file:_files' \
  '--recordconfig[specify recording config]:config file:_files' \
  '--max-frames[set maximum frames to run]:count' \
  '--bsv-movie-record[record BSV movie to file]:file:_files' \
  '--bsv-movie-playback[play back a BSV movie]:file:_files' \
  '--ips[apply an IPS patch]:patch file:_files' \
  '--bps[apply a BPS patch]:patch file:_files' \
  '--ups[apply a UPS patch]:patch file:_files' \
  '--no-patch[disable automatic patch application]' \
  '--set-shader[set a shader on startup]:shader file:_files' \
  '--accessibility[enable accessibility features]' \
  '--load-menu-on-error[load menu on core error]' \
  '*:content file:_files'
