#compdef retroarch

# completions for retroarch - RetroArch emulator frontend

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-L --libretro)'{-L,--libretro}'[path to libretro core]:core:_files -g "*.{so,dylib,dll}"' \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '--appendconfig[append extra config files]:config file:_files' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '--windowed[start in windowed mode]' \
  '--size[set window size]:size (WxH)' \
  '--aspectratio[set aspect ratio]:aspect ratio' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '--log-file[log to file]:log file:_files' \
  '--host[netplay host address]:host:_hosts' \
  '--port[netplay port]:port' \
  '--stateslot[save state slot]:slot' \
  '--nick[netplay nickname]:nickname' \
  '--menu[start in menu]' \
  '--features[print available features]' \
  '--subsystem[set subsystem]:subsystem' \
  '(-e --entryslot)'{-e,--entryslot}'[disc slot entry]:slot' \
  '(-s --save)'{-s,--save}'[path to savestate]:save path:_files' \
  '(-S --savesize)'{-S,--savesize}'[save state size]:size' \
  '--record[record video to file]:file:_files' \
  '--recordconfig[record config file]:config file:_files' \
  '--max-frames[max frames to run]:frames' \
  '--max-frames-ss[take screenshot at max frames]' \
  '--bsv-movie-record[record BSV movie]:file:_files' \
  '--bsv-movie-playback[play BSV movie]:file:_files' \
  '--ips[apply IPS patch]:patch file:_files -g "*.ips"' \
  '--bps[apply BPS patch]:patch file:_files -g "*.bps"' \
  '--ups[apply UPS patch]:patch file:_files -g "*.ups"' \
  '--no-patch[disable automatic patching]' \
  '--set-shader[set shader]:shader file:_files' \
  '--accessibility[enable accessibility features]' \
  '--load-menu-on-error[load menu on core load error]' \
  '*:content file:_files'
