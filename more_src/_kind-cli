#compdef kind
# _kind-cli — kind k8s in Docker (kubernetes-sigs, Go); run local k8s clusters using Docker containers as nodes
# upstream: https://github.com/kubernetes-sigs/kind

_kind-cli() {
    local -a sub=(
        'build:build kind node images'
        'completion:print shell completion'
        'create:create a cluster'
        'delete:delete clusters'
        'export:export logs or kubeconfig'
        'get:get clusters/nodes/kubeconfig'
        'help:show help'
        'load:load images into cluster'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-q[silent]' \
        '--quiet[silent]' \
        '-v+[verbosity]:n:' \
        '--loglevel+[log level]:level:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kind subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:create what:(cluster)' \
                    '--name+[cluster name]:name:' \
                    '--config+[config file]:file:_files' \
                    '--image+[node image]:image:' \
                    '--retain[retain nodes on failure]' \
                    '--wait+[wait duration]:duration:' \
                    '--kubeconfig+[kubeconfig path]:file:_files' ;;
                delete) _arguments \
                    '1:delete what:(cluster clusters)' \
                    '--name+[cluster name]:name:' \
                    '--kubeconfig+[kubeconfig]:file:_files' ;;
                get) _arguments \
                    '1:get what:(clusters kubeconfig nodes)' \
                    '--name+[cluster name]:name:' \
                    '--internal[internal kubeconfig]' \
                    '--kubeconfig+[kubeconfig]:file:_files' ;;
                load) _arguments \
                    '1:load what:(docker-image image-archive)' \
                    '--name+[cluster name]:name:' \
                    '--nodes+[nodes]:nodes:' \
                    '*:image:' ;;
                export) _arguments \
                    '1:export what:(kubeconfig logs)' \
                    '--name+[cluster name]:name:' \
                    '--kubeconfig+[kubeconfig]:file:_files' \
                    '*:dir:_files -/' ;;
                build) _arguments \
                    '1:build what:(node-image)' \
                    '--base-image+[base image]:image:' \
                    '--image+[image]:image:' \
                    '--type+[build type]:type:(docker)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kind-cli "$@"
