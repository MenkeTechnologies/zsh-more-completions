#compdef weeder
# Documentation: https://man.archlinux.org/search?q=weeder
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config[configuration file]:config file:_files' \
  '--hie-directory[directory containing HIE files]:directory:_directories' \
  '--no-default-fields[do not use default fields]' \
  '--json[output in JSON format]' && ret=0

return ret
