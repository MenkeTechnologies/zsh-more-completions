#compdef anchore-cli
# Documentation: https://github.com/anchore/anchore-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:account commands'
  'analysis-archive:archive analysis results'
  'enterprise:enterprise-only commands'
  'evaluate:evaluate an image against a policy'
  'event:event log commands'
  'image:image management (add/list/del/get/content/vuln/import)'
  'policy:policy bundle management'
  'query:query the Anchore engine'
  'registry:registry credential management'
  'repo:repository commands'
  'subscription:subscription management'
  'system:system status / configuration'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[show debug output]' \
  '--json[output JSON]' \
  '--yaml[output YAML]' \
  '--api-version=[Anchore API version]:version:' \
  '(-u --u)'{-u+,--u=}'[Anchore engine username]:user:' \
  '(-p --p)'{-p+,--p=}'[Anchore engine password]:pass:' \
  '--url=[Anchore engine URL]:url:' \
  '--hub-url=[Anchore Hub URL]:url:' \
  '--insecure[skip TLS verification]' \
  '--ssl-cert=[client SSL cert]:file:_files' \
  '--ssl-key=[client SSL key]:file:_files' \
  '--ssl-ca=[CA bundle]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'anchore-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (image)
        local -a img_subs=(
          'add:add an image for analysis'
          'list:list known images'
          'get:get image metadata'
          'content:show image content (files/packages/etc.)'
          'metadata:show image metadata types'
          'vuln:show vulnerabilities for an image'
          'del:delete an image'
          'wait:wait until analysis completes'
          'import:import a SBOM/sbom-export'
        )
        _describe -t imcmds 'image subcommand' img_subs && ret=0 ;;
      (policy)
        _arguments '*::sub:(add list get activate del describe hub)' && ret=0 ;;
      (evaluate)
        _arguments \
          '*::sub:(check)' \
          '--policy=[policy id]:id:' \
          '--tag=[image tag]:tag:' \
          '--detail[show detailed eval]' \
          '--history[include history]' && ret=0 ;;
      (account)
        _arguments '*::sub:(add list get del enable disable user whoami)' && ret=0 ;;
      (subscription)
        _arguments '*::sub:(activate deactivate del list update)' && ret=0 ;;
      (registry)
        _arguments '*::sub:(add list get del update)' && ret=0 ;;
      (repo)
        _arguments '*::sub:(add list get del watch unwatch)' && ret=0 ;;
      (query)
        _arguments '*::sub:(images-by-package images-by-vulnerability)' && ret=0 ;;
      (system)
        _arguments '*::sub:(status feeds errorcodes wait)' && ret=0 ;;
      (event)
        _arguments '*::sub:(list get del)' && ret=0 ;;
      (analysis-archive)
        _arguments '*::sub:(images add del list rules)' && ret=0 ;;
    esac ;;
esac

return ret
