#compdef csv-import
# Documentation: https://orc.apache.org/docs/cpp-tools.html
# csv-import - import CSV files into ORC format

local ret=1

_arguments -s -S \
  '--delimiter=[delimiter in the input CSV file (default ,)]:delimiter' \
  '--stripe=[stripe size (default 128MB)]:size' \
  '--block=[compression block size (default 64KB)]:size' \
  '--batch=[rows per batch (default 1024)]:size' \
  ':ORC schema:' \
  ':input CSV file:_files' \
  ':output ORC file:_files' && ret=0

return ret
