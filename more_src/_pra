# pra: AI-based PR review helper (pstaylor-patrick/utility-scripts/ai/pra.sh)

_pra() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-c --claude -d --deepseek -x --codex)'{-c,--claude}'[Use Claude Code CLI for AI operations]' \
    '(-c --claude -d --deepseek -x --codex)'{-d,--deepseek}'[Use DeepSeek API for AI operations (default)]' \
    '(-c --claude -d --deepseek -x --codex)'{-x,--codex}'[Use OpenAI Codex for AI operations]' \
    '--completion=[print shell completion script]:shell:(bash zsh)' \
    '--fix[After generating the report, ask AI to apply the recommended improvements]' \
    '1:base branch:__pra_branches' && ret=0

  return ret
}

__pra_branches() {
  local -a branches
  if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads refs/remotes 2>/dev/null | grep -vE '^origin/HEAD$' | LC_ALL=C sort -u)"})
    _describe 'branch' branches
  fi
}

_pra "$@"
