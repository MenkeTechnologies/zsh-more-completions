#compdef vvdecapp vvdec
# _vvdec — Fraunhofer HHI VVdeC vvdecapp fast and efficient VVC H.266 decoder implementation (fraunhoferhhi team, C++); getopt
# upstream: https://github.com/fraunhoferhhi/vvdec

_vvdec() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:n:' \
        '--verbose=+[verbosity]:n:' \
        '-b+[input bitstream]:file:_files -g "*.266 *.vvc *.bin *.h266"' \
        '--bitstream=+[input bitstream]:file:_files -g "*.266 *.vvc *.bin *.h266"' \
        '-i+[input bitstream]:file:_files -g "*.266 *.vvc *.bin *.h266"' \
        '--input=+[input bitstream]:file:_files -g "*.266 *.vvc *.bin *.h266"' \
        '-o+[output YUV]:file:_files -g "*.yuv *.y4m"' \
        '--output=+[output YUV]:file:_files -g "*.yuv *.y4m"' \
        '-f+[frames]:n:' \
        '--frames=+[frames]:n:' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-ec[error concealment]' \
        '--ec[error concealment]' \
        '--no-progress[no progress]' \
        '-l+[loop count]:n:' \
        '--loop=+[loop count]:n:' \
        '-mc+[md5 check]:b:(0 1)' \
        '-y4m[Y4M output]' \
        '-mscm[mixed sample chroma mode]'
}

_vvdec "$@"
