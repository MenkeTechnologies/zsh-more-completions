#compdef PTBatcherGUI
# Documentation: https://man.archlinux.org/search?q=PTBatcherGUI
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-b[batch mode]' \
  '-s[run silently]' \
  '-p[only parallel mode]' \
  '-o+[output file]:file:_files' \
  '*:project_or_dir:_files' && ret=0

return ret
