#compdef magus magus.py
# Documentation: https://github.com/vlasmirnov/MAGUS
# MAGUS - multiple sequence alignment using graph clustering

local ret=1

_arguments -s -S \
  '-i[input file of unaligned sequences]:file:_files' \
  '-o[output alignment path]:file:_files' \
  '-d[working directory for intermediate files]:dir:_files -/' \
  '-s[directory of subalignment files to merge]:dir:_files -/' \
  '-t[guide tree method]:method:(fasttree parttree clustal random)' \
  '--maxnumsubsets[desired number of subsets]:n' \
  '--maxsubsetsize[threshold to stop decomposing]:n' \
  '-r[number of MAFFT backbones]:n' \
  '-m[maximum backbone size]:n' \
  '-b[directory or file list of user-provided backbones]:path:_files' \
  '--graphtracemethod[graph trace method]:method:(minclusters fm mwtgreedy rg mwtsearch)' \
  '-c[constraint that merged alignment induces all subalignments]:bool:(true false)' \
  '*:file:_files' && ret=0

return ret
