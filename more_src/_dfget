#compdef dfget
# _dfget — Dragonfly P2P CLI downloader (dragonflyoss/client)
# upstream: https://github.com/dragonflyoss/client
# Flags from dragonfly-client/src/bin/dfget/main.rs (clap).

_dfget() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--transfer-from-dfdaemon[transfer file from local dfdaemon]' \
        '--overwrite[overwrite existing output file]' \
        '--force-hard-link[force hard-link instead of copy]' \
        '--content-for-calculating-task-id=[content used to derive task ID]:content:' \
        '(-O --output)'{-O+,--output=}'[output path]:file:_files' \
        '(-r --recursive)'{-r,--recursive}'[download recursively]' \
        '--timeout=[download timeout]:duration:' \
        '--digest=[expected digest]:algo:value:' \
        '(-p --priority)'{-p+,--priority=}'[task priority (0-20)]:n:' \
        '--piece-length=[piece length]:bytes:' \
        '--application=[application name]:name:' \
        '--tag=[task tag]:tag:' \
        '*'{-H+,--header=}'[HTTP header (key: value)]:header:' \
        '*--filtered-query-param=[query param to strip from task ID]:param:' \
        '(-I --include-files)'{-I+,--include-files=}'[glob of files to include]:glob:' \
        '--disable-back-to-source[do not fall back to source on miss]' \
        '1:URL or local file:'
}

_dfget "$@"
