#compdef flent
# Documentation: https://man.archlinux.org/search?q=flent
# Reference accessed: 2026-05-16

_arguments -s \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-D --data-dir)'{-D,--data-dir}'=[data dir]:dir:_files -/' \
  '*'{-i,--input}'=[input file]:file:_files' \
  '(-f --format)'{-f,--format}'=[format]:fmt:(plot csv org_table stats metadata summary default)' \
  '(-p --plot)'{-p,--plot}'=[plot]:plot:' \
  '(-t --title-extra)'{-t,--title-extra}'=[title]:title:' \
  '(-n --note)'{-n,--note}'=[note]:note:' \
  '(-r --rcfile)'{-r,--rcfile}'=[RC file]:file:_files' \
  '(-x --extended-metadata)'{-x,--extended-metadata}'[extended metadata]' \
  '*--remote-metadata=[host]:host:_hosts' \
  '--gui[open GUI]' \
  '--new-gui-instance[new GUI]' \
  '--gui-no-defer[no defer]' \
  '*'{-b,--batch}'=[batch name]:name:' \
  '*'{-B,--batch-file}'=[batch file]:file:_files' \
  '*--batch-override=[key=value]:override:' \
  '--batch-dry-run[dry run]' \
  '--batch-verbose[verbose]' \
  '--batch-no-shuffle[no shuffle]' \
  '--batch-no-timestamp[no timestamp]' \
  '--batch-repetitions=[count]:n:' \
  '--batch-title=[title]:title:' \
  '--batch-resume=[dir]:dir:_files -/' \
  '*'{-H,--host}'=[host]:host:_hosts' \
  '*--local-bind=[IP]:ip:' \
  '*--remote-host=[idx=host]:spec:' \
  '(-l --length)'{-l,--length}'=[length sec]:n:' \
  '(-s --step-size)'{-s,--step-size}'=[step]:s:' \
  '(-d --delay)'{-d,--delay}'=[delay sec]:n:' \
  '(-4 --ipv4)'{-4,--ipv4}'[IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[IPv6]' \
  '--socket-timeout=[seconds]:n:' \
  '*--send-size=[size]:size:' \
  '--test-payload=[payload]:file:_files' \
  '*--test-parameter=[key=value]:param:' \
  '--swap-up-down[swap up/down]' \
  '--socket-stats[socket stats]' \
  '*--marking-name=[name=hex]:marking:' \
  '*--label-x=[x label]:str:' \
  '*--label-y=[y label]:str:' \
  '(-I --invert-latency-y)'{-I,--invert-latency-y}'[invert Y]' \
  '(-z --zero-y)'{-z,--zero-y}'[zero Y]' \
  '--log-scale-y=[mode]:mode:(log2 log10)' \
  '*--norm-factor=[factor]:f:' \
  '--data-cutoff=[F1,F2]:cutoff:' \
  '*--bounds-x=[F1,F2]:bounds:' \
  '*--bounds-y=[F1,F2]:bounds:' \
  '(-S --scale-mode)'{-S,--scale-mode}'[scale mode]' \
  '--concatenate[concatenate]' \
  '--absolute-time[absolute time]' \
  '--subplot-combine[subplot combine]' \
  '--skip-missing-series[skip missing]' \
  '--no-print-n[no print N]' \
  '--no-annotation[no annotation]' \
  '(--figure-note --fig-note)'{--figure-note,--fig-note}'=[note]:str:' \
  '--no-title[no title]' \
  '--override-title=[title]:title:' \
  '--no-labels[no labels]' \
  '--no-markers[no markers]' \
  '--no-legend[no legend]' \
  '--horizontal-legend[horizontal]' \
  '--legend-title=[title]:title:' \
  '--legend-placement=[placement]:placement:' \
  '--legend-columns=[cols]:n:' \
  '--reverse-legend[reverse]' \
  '--filter-legend[filter]' \
  '*--replace-legend=[src=dest]:replace:' \
  '*--filter-regexp=[regex]:regex:' \
  '*--override-label=[label]:label:' \
  '*--filter-series=[series]:series:' \
  '*--split-group=[group]:group:' \
  '--colours=[list]:list:' \
  '--override-colour-mode=[mode]:mode:' \
  '--override-group-by=[group]:group:' \
  '--combine-save-dir=[dir]:dir:_files -/' \
  '(--figure-width --fig-width)'{--figure-width,--fig-width}'=[width]:f:' \
  '(--figure-height --fig-height)'{--figure-height,--fig-height}'=[height]:f:' \
  '(--figure-dpi --fig-dpi)'{--figure-dpi,--fig-dpi}'=[dpi]:f:' \
  '--fallback-layout[fallback]' \
  '--no-matplotlibrc[no matplotlibrc]' \
  '--no-hover-highlight[no hover]' \
  '*--scale-data=[scale]:str:' \
  '--control-host=[host]:host:_hosts' \
  '--control-local-bind=[IP]:ip:' \
  '--netperf-control-port=[port]:port:' \
  '--ditg-control-port=[port]:port:' \
  '--ditg-control-secret=[secret]:secret:' \
  '*--http-getter-urllist=[file]:file:_files' \
  '--http-getter-dns-servers=[DNS]:ip:' \
  '--http-getter-timeout=[ms]:n:' \
  '--http-getter-workers=[n]:n:' \
  '--irtt-sampling-interval=[ms]:n:' \
  '(-L --log-file)'{-L,--log-file}'=[log file]:file:_files' \
  '--cache-file=[cache]:file:_files' \
  '--list-tests[list tests]' \
  '--list-plots[list plots]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--debug-error[debug errors]' \
  '*:host or test:'
