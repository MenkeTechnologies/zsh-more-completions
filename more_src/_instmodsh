#compdef instmodsh
# Documentation: https://man.archlinux.org/search?q=instmodsh
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help]'
    '-m[Module name]:module:'
    '-l[List installed modules]'
    '-p[Show packlist for module]:module:'
    '-v[Validate installed module]:module:'
)

_arguments -s -S $arguments
