#compdef notesmd-cli
# Documentation: https://github.com/Yakitrak/notesmd-cli
# notesmd-cli (community Obsidian CLI) - interact with Obsidian vaults from the terminal

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'add-vault:register a directory as an Obsidian vault'
      'av:register a directory as an Obsidian vault'
      'remove-vault:remove a vault from configuration'
      'rv:remove a vault from configuration'
      'list-vaults:display all registered vaults'
      'lv:display all registered vaults'
      'set-default-vault:define default vault and open type'
      'open:open given note name in Obsidian or editor'
      'daily:create or open today daily note'
      'search:fuzzy search notes in vault'
      'search-content:find notes containing a specific term'
      'list:display vault contents'
      'print:output note contents'
      'create:create note directly on disk'
      'move:rename or move note with link updates'
      'delete:remove a note'
      'frontmatter:view and modify YAML frontmatter'
      'fm:view and modify YAML frontmatter'
    )
    _describe -t commands 'notesmd-cli command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      open|move)
        _arguments -s \
          '--vault=[target vault]:vault:' \
          '--section=[link to section]:section:' \
          '(-e --editor)'{-e,--editor}'[open in text editor]' \
          '--open[open after move]' && ret=0
        ;;
      daily|create)
        _arguments -s \
          '--vault=[target vault]:vault:' \
          '--content=[note content]:content:' \
          '--overwrite[overwrite existing note]' \
          '--append[append to existing note]' \
          '--open[open after create]' \
          '(-e --editor)'{-e,--editor}'[open in text editor]' && ret=0
        ;;
      search|search-content)
        _arguments -s \
          '--vault=[target vault]:vault:' \
          '(-e --editor)'{-e,--editor}'[open in text editor]' \
          '--no-interactive[non-interactive output]' \
          '--format=[output format]:format:(json)' \
          '--page=[page number]:page:' \
          '--page-size=[results per page]:size:' && ret=0
        ;;
      list-vaults|lv)
        _arguments -s \
          '--json[output as JSON]' \
          '--path-only[show only paths]' \
          '--default[show only default vault]' && ret=0
        ;;
      add-vault|av)
        _arguments -s '--set-default[set as default vault]' && ret=0
        ;;
      set-default-vault)
        _arguments -s '--open-type=[default open type]:type:' && ret=0
        ;;
      frontmatter|fm)
        _arguments -s \
          '--vault=[target vault]:vault:' \
          '--print[print frontmatter]' \
          '--edit[edit frontmatter]' \
          '--delete[delete a key]' \
          '--key=[frontmatter key]:key:' \
          '--value=[frontmatter value]:value:' && ret=0
        ;;
      *)
        _arguments -s '--vault=[target vault]:vault:' && ret=0
        ;;
    esac
    ;;
esac

return ret
