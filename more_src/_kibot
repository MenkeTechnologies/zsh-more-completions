#compdef kibot
# _kibot — Salvador E Tropea kibot CLI for automating KiCad PCB ERC DRC schematic-print Gerber drill files BOM 3D-render compress IBOM iBoM HTML interactive-BoM panelize variants step diff (INTI-CMNB team, Python); argparse
# upstream: https://github.com/INTI-CMNB/KiBot

_kibot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b+[board file]:file:_files -g "*.kicad_pcb"' \
        '--board-file=+[board file]:file:_files -g "*.kicad_pcb"' \
        '-e+[schematic file]:file:_files -g "*.kicad_sch *.sch"' \
        '--schematic=+[schematic file]:file:_files -g "*.kicad_sch *.sch"' \
        '-c+[plot config]:file:_files -g "*.kibot.yaml *.yml *.yaml"' \
        '--plot-config=+[plot config]:file:_files -g "*.kibot.yaml *.yml *.yaml"' \
        '-d+[output dir]:dir:_files -/' \
        '--out-dir=+[output dir]:dir:_files -/' \
        '-s+[skip pre-flight]:str:' \
        '--skip-pre=+[skip pre-flight]:str:' \
        '-V+[variant]:str:' \
        '--variant=+[variant]:str:' \
        '--cli-order[output in CLI order]' \
        '--list[list outputs]' \
        '--list-variants[list variants]' \
        '--list-filters[list filters]' \
        '--example[generate example config]' \
        '--copy-options[copy options]' \
        '--copy-and-expand[copy and expand]' \
        '--copy-and-expand-all[copy and expand all]' \
        '--global-redef=+[name=value]:str:' \
        '--no-warn-pcb-deps[no warn pcb deps]' \
        '--no-warn-board-cache[no warn board cache]' \
        '--ignore-unknown-options[ignore unknown options]' \
        '--no-warn-3d[no warn 3D]' \
        '--no-warn-drc[no warn DRC]' \
        '--no-warn-erc[no warn ERC]' \
        '*:output target:'
}

_kibot "$@"
