#compdef rsem-gff3-to-gtf
# Documentation: https://github.com/deweylab/RSEM/blob/master/rsem-gff3-to-gtf
# RSEM: convert a GFF3 annotation file to GTF format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--make-genes-as-transcripts[make each gene a transcript]' \
  '--RNA-patterns=[types of RNAs to extract (e.g. mRNA,rRNA)]:patterns' \
  '--extract-sequences=[extract embedded reference sequences to file]:output fa:_files' \
  '1:input GFF3 file:_files -g "*.(gff3|gff)"' \
  '2:output GTF file:_files' && ret=0

return ret
