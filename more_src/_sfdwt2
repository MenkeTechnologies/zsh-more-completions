#compdef sfdwt2
# Documentation: https://ahay.org/RSF/sfdwt2.html
# Madagascar: 1-D digital wavelet transform (another version)

local ret=1

_arguments -s \
  'adj=[if y, do adjoint transform (y/n)]:bool:(y n)' \
  'inv=[if y, do inverse transform (y/n)]:bool:(y n)' \
  'unit=[if y, use unitary scaling (y/n)]:bool:(y n)' \
  'type=[wavelet type]:type:(haar linear biorthogonal)' \
  '*:rsf file:_files' && ret=0

return ret
