#compdef nsq_to_nsq

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-version[show version]' \
  '*-topic=[source NSQ topic (repeatable)]:topic:' \
  '*-destination-topic=[destination topic (repeatable)]:topic:' \
  '-channel=[NSQ channel]:channel:' \
  '*-nsqd-tcp-address=[nsqd TCP address (repeatable)]:address:' \
  '*-lookupd-http-address=[lookupd HTTP address (repeatable)]:address:' \
  '*-destination-nsqd-tcp-address=[destination nsqd TCP address (repeatable)]:address:' \
  '-mode=[connection mode]:mode:(round-robin multicast hostpool epsilon-greedy)' \
  '-status-every=[duration to log status]:duration:' \
  '-max-in-flight=[max in-flight messages]:n:' \
  '-max-backoff-duration=[max backoff duration]:duration:' \
  '-require-json-field=[require JSON field for filter]:field:' \
  '-require-json-value=[required JSON value]:value:' \
  '-whitelist-json-field=[whitelisted JSON field]:field:' \
  '-consumer-opt=[consumer config option]:opt:' \
  '-producer-opt=[producer config option]:opt:' \
  '-log-level=[log verbosity]:level:(debug info warn error fatal)' \
  '-log-prefix=[log message prefix]:prefix:' && ret=0

return ret
