#compdef devtools devtools-cli
# _devtools — Hadley Wickham R devtools developer toolkit CLI alias (Hadley Wickham / RStudio, R); custom argparse
# upstream: https://github.com/r-lib/devtools

_devtools() {
    local -a sub=(
        'load:load a package'
        'install:install package from source'
        'install-github:install from GitHub'
        'install-cran:install from CRAN'
        'install-bioc:install from Bioconductor'
        'install-deps:install package dependencies'
        'document:run roxygen2'
        'test:run tests'
        'check:run R CMD check'
        'build:build a package'
        'clean:clean package'
        'release:release a package to CRAN'
        'submit-cran:submit to CRAN'
        'spell-check:spell check'
        'use:use package wizards'
        'create:create new package'
        'lint:lint package'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-doc[no doc]' \
        '--no-test[no test]' \
        '--no-clean[no clean]' \
        '--no-vignettes[no vignettes]' \
        '--no-manual[no manual]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'devtools subcommand' sub ;;
        args)
            case $words[1] in
                install|install-github|install-cran|install-bioc) _arguments \
                    '--upgrade=+[upgrade]:u:(default ask always never)' \
                    '--build[build before install]' \
                    '--force[force]' \
                    '--dependencies=+[deps]:d:(TRUE FALSE NA Imports Suggests)' \
                    '*:package:' ;;
                test) _arguments \
                    '--filter=+[test filter]:str:' \
                    '--reporter=+[reporter]:r:(default summary minimal location progress junit teamcity check fail)' \
                    '--package=+[package]:str:' \
                    '*:arg:' ;;
                check) _arguments \
                    '--cran[CRAN policy]' \
                    '--remote[remote check]' \
                    '--error-on=+[error level]:l:(never error warning note)' \
                    '--args=+[args to R CMD check]:str:' \
                    '*:arg:' ;;
                document|build|clean|release|submit-cran|lint|spell-check|load) _arguments \
                    '*:path:_files -/' ;;
                create) _arguments \
                    '1:name:' \
                    '--rstudio[rstudio project]' \
                    '--check[check]' \
                    '--description=+[description list]:str:' ;;
                use) _arguments \
                    '1:wizard:(git github testthat readme news vignette code-of-conduct license r ci coverage roxygen mit gpl3 lgpl apl_2 cc0 ccby ccby_nc git_ignore gitlab makefile package-doc rcpp release_issue spell_check tibble)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_devtools "$@"
