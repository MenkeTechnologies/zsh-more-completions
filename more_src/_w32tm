#compdef w32tm
# Documentation: https://ss64.com/nt/w32tm.html
# Windows Time service diagnostic and configuration tool

local ret=1

_arguments -s \
  '/register[register the time service and add default config]' \
  '/unregister[unregister the time service and remove config]' \
  '/monitor[monitor time differences for a domain/computers]' \
  '/ntte[convert NT system time to readable format]' \
  '/ntpte[convert NTP time to readable format]' \
  '/resync[resynchronize the clock as soon as possible]' \
  '/stripchart[display a strip chart of offset to another computer]' \
  '/config[adjust the configuration of target]' \
  '/tz[display the current time zone settings]' \
  '/dumpreg[display values associated with a registry key]' \
  '/query[display Windows Time service information]' \
  '/debug[enable or disable the local private log]' \
  '/leapseconds[display the status of leap seconds]' && ret=0

return ret
