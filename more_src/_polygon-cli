#compdef polygon-cli polycli
# Documentation: https://github.com/0xPolygon/polygon-cli (cmd/root.go cobra rootCmd)
# Reference accessed: 2026-05-29
# Polygon CLI (polycli) — blockchain dev/test/run toolkit.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'abi:work with Ethereum contract ABI files'
  'cdk:CDK (Chain Development Kit) commands'
  'dbbench:benchmark backing data stores'
  'dumpblocks:dump blocks in a range'
  'ecrecover:recover the public key/address from a signature'
  'enr:parse/print Ethereum Node Records'
  'fixnoncegap:resolve a stuck nonce queue'
  'fork:simulate a chain fork'
  'fund:bulk-fund accounts'
  'hash:compute various hashes'
  'loadtest:generate transaction load on an EVM chain'
  'metricstodash:convert Prometheus metrics to Grafana dashboards'
  'mnemonic:generate BIP39 mnemonics and addresses'
  'monitor:terminal-based chain monitor'
  'monitorv2:next-gen chain monitor'
  'nodekey:generate/inspect Ethereum node keys'
  'p2p:devp2p tooling'
  'parseethwallet:parse Ethereum encrypted wallet'
  'parsebatchl2data:parse zkEVM/CDK L2 batch data'
  'plot:plot chain metrics'
  'pos:Polygon PoS commands'
  'publish:publish artifacts'
  'report:generate operational reports'
  'retest:replay tests from RETESTETH JSON'
  'rpcfuzz:fuzz JSON-RPC endpoints'
  'signer:cryptographic signing helpers'
  'ulxly:Unified LXLY bridge utilities'
  'wallet:wallet utilities (generate, inspect)'
  'wrapcontract:wrap a contract for deployment'
  'foldtrace:fold an EVM execution trace'
  'dockerlogger:Docker logger driver'
  'contract:contract helpers (deploy, call)'
  'version:show version'
  'completion:generate shell completion'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file (default $HOME/.polygon-cli.yaml)]:file:_files' \
  '(-v --verbosity)'{-v,--verbosity=}'[log level 0 (silent) to 700 (trace); default 500 (info)]:n:' \
  '--pretty-logs[console formatting instead of JSON]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'polygon-cli subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac
    ;;
esac

return ret
