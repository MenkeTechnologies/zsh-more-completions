#compdef bash-it
# _bash-it — Bash-it bash-it CLI for managing the community Bash framework enabling disabling aliases plugins completions themes update reload reset migrate configuration (bash-it team, Bash); getopt
# upstream: https://github.com/Bash-it/bash-it

_bash-it() {
    local -a sub=(
        'help:show help'
        'show:show enabled items'
        'list:list available items'
        'enable:enable component'
        'disable:disable component'
        'reload:reload bash-it'
        'restart:restart bash-it'
        'doctor:run diagnostics'
        'preview:preview theme'
        'profile:profile operations'
        'reset:reset bash-it'
        'search:search items'
        'update:update bash-it'
        'version:show version'
        'migrate:migrate from old layout'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--force[force]' \
        '--silent[silent]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bash-it subcommand' sub ;;
        args)
            case $words[1] in
                show|enable|disable|list) _arguments \
                    '1:component:(aliases plugins completions themes lib all)' \
                    '*:component name:' ;;
                update) _arguments \
                    '1:channel:(stable dev master main)' ;;
                profile) _arguments \
                    '1:action:(save load rm list)' \
                    '*:profile name:' ;;
            esac
            ;;
    esac
}

_bash-it "$@"
