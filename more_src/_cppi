#compdef cppi
# Documentation: https://www.gnu.org/software/cppi/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# GNU cppi: indent C preprocessor directives to reflect their nesting

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-a --ansi)'{-a,--ansi}'[fail with diagnostic if input contains non-ANSI directive]' \
  '(-l --list-files)'{-l,--list-files}'[do not indent, just list files that need indenting]' \
  '(-m --max-string-length)'{-m+,--max-string-length=}'[max length of unbroken string literal]:length:' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:file:_files' && ret=0

return ret
