#compdef cppi

# Zsh completion for cppi
# Upstream: Indent C preprocessor directives to reflect their nesting
# Conservative fallback — run `cppi --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
