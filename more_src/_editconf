#compdef editconf gmx-editconf
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-editconf.html
# Convert generic structure formats and edit box dimensions and coordinates

local ret=1

_arguments -s -S \
  '-f+[input structure file]:structure file:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-bf+[generic data file for B-factors]:data file:_files' \
  '-o+[output structure file]:structure file:_files -g "*.(gro|g96|pdb)"' \
  '-mead+[output coordinate file for MEAD]:file:_files -g "*.pqr"' \
  '-bt+[box type]:type:(triclinic cubic dodecahedron octahedron)' \
  '-box+[box vector lengths a,b,c]:vector:' \
  '-angles+[angles between box vectors]:vector:' \
  '-d+[distance between solute and box]:distance:' \
  '-center+[shift geometric center to coordinates]:vector:' \
  '-aligncenter+[center of rotation for alignment]:vector:' \
  '-align+[align principal axis to target vector]:vector:' \
  '-translate+[translation vector]:vector:' \
  '-rotate+[rotation around X Y Z in degrees]:vector:' \
  '-scale+[scaling factor]:vector:' \
  '-density+[target density via scaling g/L]:value:' \
  '-resnr+[renumber residues from number]:number:' \
  '-rvdw+[default Van der Waals radius nm]:value:' \
  '-label+[add chain identifier to residues]:label:' \
  '-w[view output files]' \
  '-ndef[select from default index groups]' \
  '-c[center molecule in box]' \
  '-princ[orient along principal axes]' \
  '-pbc[remove periodicity]' \
  '-grasp[store charge in B-factor, radius in occupancy]' \
  '-sig56[use rmin/2 instead of sigma/2]' \
  '-vdwread[read Van der Waals radii from file]' \
  '-atom[force per-atom B-factor attachment]' \
  '-legend[create B-factor legend]' \
  '-conect[add CONECT records to PDB]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
