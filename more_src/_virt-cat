#compdef virt-cat
# _virt-cat — libguestfs virt-cat (cat a file inside a libvirt VM image; -a disk, -d domain, -c libvirt URI, -m mount spec, --format disk format; positional argument is the in-guest path; sibling tools virt-ls/virt-tar-in/virt-tar-out share this surface)
# upstream: https://github.com/libguestfs/libguestfs (cat)
# Flags from libguestfs cat/cat.ml on tip.

_virt-cat() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)' \
        '*:in-guest path:'
}

_virt-cat "$@"
