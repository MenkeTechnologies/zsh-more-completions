#compdef pypeit_obslog
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Construct an observing log for a set of files from a spectrograph

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '(-r --root)'{-r,--root}'[root to search for data files]:root:_files' \
  '(-k --keys)'{-k,--keys}'[list pypeit metadata keys instead of producing the log]' \
  '(-c --columns)'{-c,--columns}'[comma-separated list of columns to include]:columns' \
  '(-b --bad_frames)'{-b,--bad_frames}'[clean output of bad frames]' \
  '(-t --bad_types)'{-t,--bad_types}'[how to treat untyped frames]:type:(keep rm only)' \
  '(-g --groupings)'{-g,--groupings}'[only determine the frame type]' \
  '(-i --interact)'{-i,--interact}'[start embedded IPython session with table]' \
  '(-s --sort)'{-s,--sort}'[metadata keyword to sort the output table]:keyword' \
  '(-e --extension)'{-e,--extension}'[file extension to use]:ext' \
  '(-d --output_path)'{-d,--output_path}'[path to top-level output directory]:dir:_files -/' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite any existing files/directories]' \
  '(-f --file)'{-f,--file}'[name for the ascii output file]:file:_files' \
  '(-G --gui)'{-G,--gui}'[view the obs log in a GUI]' \
  '*:spectrograph:' && ret=0

return ret
