#compdef pachctl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'version:print Pachyderm version information'
  'buildinfo:print Go build info'
  'exit:exit the pachctl shell'
  'shell:run the pachyderm shell'
  'port-forward:forward a port from local to pachd'
  'completion:print or install terminal completion code'
  'delete:delete an existing Pachyderm resource'
  'squash:squash an existing Pachyderm resource'
  'create:create a new instance of a Pachyderm resource'
  'update:change the properties of an existing Pachyderm resource'
  'inspect:show detailed information about a Pachyderm resource'
  'list:print a list of Pachyderm resources of a specific type'
  'start:start a Pachyderm resource'
  'finish:finish a Pachyderm resource'
  'find:find a file addition, modification, or deletion in a commit'
  'wait:wait for the side-effects of a Pachyderm resource to propagate'
  'subscribe:wait for notifications of changes to a Pachyderm resource'
  'put:insert data into Pachyderm'
  'copy:copy a Pachyderm resource'
  'get:get the raw data represented by a Pachyderm resource'
  'glob:print a list of resources matching a glob pattern'
  'diff:show differences between two Pachyderm resources'
  'stop:cancel an ongoing task'
  'restart:cancel and restart an ongoing task'
  'resume:resume a stopped task'
  'run:manually run a Pachyderm resource'
  'edit:edit the value of an existing Pachyderm resource'
  'draw:draw an ASCII representation of an existing Pachyderm resource'
  'validate:validate the specification of a Pachyderm resource'
  'rerun:manually rerun a Pachyderm resource'
  'auth:auth-related commands'
  'admin:admin commands'
  'config:local pachctl config'
  'debug:debug commands'
  'enterprise:enterprise commands'
  'license:license commands'
  'identity:identity commands'
  'transaction:transaction commands'
  'logs:logs commands'
  'metadata:metadata commands'
  'snapshot:snapshot commands'
  'task:task commands'
  'delete-all:delete everything'
  'help:show help'
)

local -a resources
resources=(
  'repo:repository'
  'branch:branch'
  'commit:commit'
  'file:file'
  'pipeline:pipeline'
  'job:job'
  'datum:datum'
  'project:project'
  'cluster:cluster'
  'context:context'
  'enterprise:enterprise key'
  'idp-connector:identity provider connector'
  'oidc-client:OIDC client'
  'role-binding:role binding'
  'secret:secret'
  'transaction:transaction'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[output verbose logs]' \
  '--no-color[turn off colors]' \
  '--rpc-timeout=[RPC deadline duration]:duration:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pachctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create|delete|update|inspect|list|start|finish|wait|subscribe|put|copy|get|glob|diff|stop|restart|resume|run|edit|draw|validate|rerun)
        _describe -t resources 'resource' resources && ret=0
        ;;
      (auth)
        _values 'auth action' \
          'activate' 'deactivate' 'login' 'logout' 'whoami' \
          'check' 'set' 'get' 'use-auth-token' 'get-auth-token' 'get-robot-token' \
          'rotate-root-token' 'revoke-auth-token' && ret=0
        ;;
      (admin)
        _values 'admin action' \
          'inspect-cluster' 'extract' 'restore' && ret=0
        ;;
      (config)
        _values 'config action' \
          'get' 'set' 'list' 'delete' 'update' 'import-kube' && ret=0
        ;;
      (enterprise)
        _values 'enterprise action' \
          'activate' 'deactivate' 'get-state' 'register' 'unregister' \
          'heartbeat' 'pause' 'unpause' 'pause-status' && ret=0
        ;;
      (license)
        _values 'license action' \
          'activate' 'deactivate' 'get-state' 'add-cluster' 'update-cluster' \
          'delete-cluster' 'list-clusters' && ret=0
        ;;
      (identity)
        _values 'identity action' \
          'set-config' 'get-config' \
          'create-idp-connector' 'list-idp-connector' 'get-idp-connector' \
          'update-idp-connector' 'delete-idp-connector' \
          'create-oidc-client' 'list-oidc-client' 'get-oidc-client' \
          'update-oidc-client' 'delete-oidc-client' && ret=0
        ;;
      (transaction)
        _values 'transaction action' \
          'list' 'start' 'finish' 'stop' 'delete' 'inspect' 'resume' && ret=0
        ;;
      (debug)
        _values 'debug action' \
          'dump' 'profile' 'binary' 'pprof' 'analyze' 'cores' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' && ret=0
        ;;
      (snapshot)
        _values 'snapshot action' \
          'create' 'list' 'restore' 'delete' && ret=0
        ;;
      (task)
        _values 'task action' \
          'list' 'inspect' && ret=0
        ;;
    esac
    ;;
esac

return ret
