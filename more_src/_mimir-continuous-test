#compdef mimir-continuous-test
# Documentation: https://grafana.com/docs/mimir/latest/manage/tools/mimir-continuous-test/
# Grafana Mimir continuous-test - continuously run smoke tests against a Mimir cluster

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-tests.write-endpoint=[base endpoint of the write path]:url:_urls' \
  '-tests.read-endpoint=[base endpoint of the read path]:url:_urls' \
  '-tests.tenant-id=[tenant ID to use for tests]:tenant:' \
  '-tests.bearer-token=[bearer token for authentication]:token:' \
  '-tests.basic-auth-user=[username for basic auth]:user:' \
  '-tests.basic-auth-password=[password for basic auth]:password:' \
  '-tests.smoke-test[run the test once and exit immediately]' \
  '-server.metrics-port=[port of the Prometheus metrics endpoint]:port:' \
  '*:arg:_default' && ret=0

return ret
