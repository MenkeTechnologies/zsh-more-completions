#compdef shiny
# _shiny — Posit/RStudio Shiny R web-framework CLI for running Shiny apps modules dashboards reactive expressions and deploying to Shiny Server Connect or shinyapps.io (rstudio team, R); R argparse
# upstream: https://github.com/rstudio/shiny

_shiny() {
    local -a sub=(
        'run:run a Shiny app'
        'create:create new Shiny app'
        'runExample:run a built-in example'
        'showcase:open showcase mode'
        'gadget:run a Shiny gadget'
        'deploy:deploy app'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'shiny subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--launch-browser=+[b]:b:(true false)' \
                    '--display-mode=+[m]:m:(auto normal showcase)' \
                    '--workerId=+[id]:str:' \
                    '--quiet[quiet]' \
                    '*:app dir or appR:_files' ;;
                create) _arguments \
                    '--template=+[t]:t:(default modules navbarPage navbarPage_dataExplorer reactivity-essentials)' \
                    '--from=+[src]:str:' \
                    '*:app dir:_files -/' ;;
                runExample) _arguments \
                    '*:example:(01_hello 02_text 03_reactivity 04_mpg 05_sliders 06_tabsets 07_widgets 08_html 09_upload 10_download 11_timer)' ;;
                deploy) _arguments \
                    '--account=+[name]:str:' \
                    '--server=+[server]:str:' \
                    '--app-name=+[name]:str:' \
                    '--app-title=+[title]:str:' \
                    '*:app dir:_files -/' ;;
            esac
            ;;
    esac
}

_shiny "$@"
