#compdef sirtsetup
# Documentation: https://bio3d.colorado.edu/imod/doc/man/sirtsetup.html
# Produce command files for iterative (SIRT) reconstruction in parallel

local ret=1

_arguments -s \
  '(-h -help)'{-h,-help}'[show help]' \
  '(-co -CommandFile)'{-co,-CommandFile}'[Command file for reconstruction, which can be entered with...]:file:_files' \
  '(-naming -na -NamingStyle)'{-naming,-na,-NamingStyle}'[0 if image files have descriptive extensions like...]:value' \
  '(-nu -NumberOfProcessors)'{-nu,-NumberOfProcessors}'[Use this option to specify the number of machines that you]:value' \
  '(-ra -ChunksPerProcessor)'{-ra,-ChunksPerProcessor}'[Use this option to set the number of chunks per processor;...]:value' \
  '(-st -StartFromZero)'{-st,-StartFromZero}'[Do an initial reconstruction, numbered 00, even if it or...]' \
  '(-re -ResumeFromIteration)'{-re,-ResumeFromIteration}'[Resume from the given iteration rather than from the last...]:value' \
  '(-it -i -IterationsToRun)'{-it,-i,-IterationsToRun}'[Set the number of iterations to run. If this option is not]:value' \
  '(-le -l -LeaveIterations)'{-le,-l,-LeaveIterations}'[Leave reconstructions at the listed iterations, which are...]:value' \
  '(-sk -SkipVertSliceOutput)'{-sk,-SkipVertSliceOutput}'[Do not make the vertical slice output files that are needed...]' \
  '(-cl -CleanUpPastStart)'{-cl,-CleanUpPastStart}'[Remove all existing reconstructions past the starting point...]' \
  '(-su -SubareaSize)'{-su,-SubareaSize}'[Size in X and Y of a subarea to use from the aligned stack,...]:value' \
  '(-yo -y -YOffsetOfSubarea)'{-yo,-y,-YOffsetOfSubarea}'[Offset in Y from center of aligned image to center of...]:value' \
  '(-sc -ScaleToInteger)'{-sc,-ScaleToInteger}'[Scale each retained reconstruction to integers, with the...]:value' \
  '(-tr -TrimvolOptions)'{-tr,-TrimvolOptions}'[Run Trimvol on each retained reconstruction with the given]:value' \
  '(-fl -FlatFilterFraction)'{-fl,-FlatFilterFraction}'[Set the fraction of a flat filter function to apply in the...]:value' \
  '(-rd -RadiusAndSigma)'{-rd,-RadiusAndSigma}'[Set the radius and falloff for the high-frequency cutoff of...]:value' \
  '-FalloffIsTrueSigma[option is not entered)]' \
  '(-falloff -fa -FalloffIsTrueSigma)'{-falloff,-fa,-FalloffIsTrueSigma}'[Use the falloff value entered with the -RadiusAndSigma...]' \
  '(-cs -ConstrainSign)'{-cs,-ConstrainSign}'[Enter 1 or -1 to constrain the reconstruction to positive or]' \
  '(-ch -SeparateRecChunks)'{-ch,-SeparateRecChunks}'[Write reconstructions in chunks to separate files and...]' \
  '(-pc -p -SeparateProjChunks)'{-pc,-p,-SeparateProjChunks}'[Write reprojections in chunks to separate files instead of]' \
  '(-bo -b -BoundaryPixels)'{-bo,-b,-BoundaryPixels}'[Set the number of boundary pixels saved in separate files...]:value' \
  '(-mo -m -OutputMode)'{-mo,-m,-OutputMode}'[Set the mode of the output files. The default is 2 because]:value' \
  '(-te -TestMode)'{-te,-TestMode}'[Run in a test mode. A value of 1 will leave the reprojection]:value' \
  '-StandardInput[read parameters from standard input]' \
  '-usage[print usage]' \
  '*:file:_files' && ret=0

return ret
