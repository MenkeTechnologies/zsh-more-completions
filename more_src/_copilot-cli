#compdef copilot

# Zsh completion for AWS Copilot CLI - ECS/Fargate deployment tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create a new application or workload'
  'docs:open Copilot documentation'
  'app:manage applications'
  'env:manage environments'
  'svc:manage services'
  'job:manage jobs'
  'task:manage one-off tasks'
  'pipeline:manage CI/CD pipelines'
  'deploy:deploy a service, job, or environment'
  'secret:manage secrets'
  'storage:manage storage resources'
  'version:show version'
  'completion:generate shell completions'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'copilot command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      init)
        _arguments \
          '(-a --app)'{-a+,--app=}'[application name]:name:' \
          '(-n --name)'{-n+,--name=}'[workload name]:name:' \
          '(-t --type)'{-t+,--type=}'[workload type]:type:(Load\ Balanced\ Web\ Service Backend\ Service Request-Driven\ Web\ Service Worker\ Service Static\ Site Scheduled\ Job)' \
          '(-d --dockerfile)'{-d+,--dockerfile=}'[Dockerfile path]:dockerfile:_files' \
          '--image=[container image]:image:' \
          '--port=[container port]:port:' \
          '--deploy[deploy after initializing]' \
          '--tag=[image tag]:tag:'
        ;;
      deploy)
        _arguments \
          '(-n --name)'{-n+,--name=}'[workload name]:name:' \
          '(-e --env)'{-e+,--env=}'[environment name]:env:' \
          '--tag=[image tag]:tag:' \
          '--resource-tags=[resource tags]:tags:' \
          '--force[force a new deployment]'
        ;;
      svc)
        local -a svc_cmds=(
          'init:create a new service'
          'ls:list services'
          'show:show service details'
          'status:show service status'
          'logs:show service logs'
          'deploy:deploy a service'
          'delete:delete a service'
          'exec:execute a command in a running container'
          'pause:pause a service'
          'resume:resume a paused service'
          'override:override generated infrastructure'
        )
        _describe -t commands 'svc command' svc_cmds && ret=0
        ;;
      env)
        local -a env_cmds=(
          'init:create a new environment'
          'ls:list environments'
          'show:show environment details'
          'deploy:deploy an environment'
          'delete:delete an environment'
          'override:override generated infrastructure'
        )
        _describe -t commands 'env command' env_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
