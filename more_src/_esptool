#compdef esptool esptool.py

# Zsh completion for esptool - ESP8266/ESP32 ROM bootloader utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'load_ram:download an image to RAM and execute'
  'dump_mem:dump arbitrary memory to file'
  'read_mem:read arbitrary memory location'
  'write_mem:write to arbitrary memory location'
  'write_flash:write binary data to flash'
  'run:run application code in flash'
  'image_info:dump headers from a binary file'
  'make_image:create an application image from binary files'
  'elf2image:create a flash image from an ELF file'
  'read_mac:read MAC address from OTP ROM'
  'chip_id:read chip ID from OTP ROM'
  'flash_id:read SPI flash manufacturer and device ID'
  'read_flash_status:read SPI flash status register'
  'write_flash_status:write SPI flash status register'
  'read_flash:read SPI flash content'
  'verify_flash:verify binary data against flash'
  'erase_flash:perform chip erase of SPI flash'
  'erase_region:erase a region of flash'
  'merge_bin:merge multiple raw binary files into a single file'
  'get_security_info:get some security-related data'
  'version:print esptool version'
)

_arguments -s -S \
  '--chip=[target chip type]:chip:(auto esp8266 esp32 esp32s2 esp32s3 esp32c3 esp32c2 esp32c6 esp32h2)' \
  '(-p --port)'{-p+,--port=}'[serial port]:port:_files -g "/dev/tty*"' \
  '(-b --baud)'{-b+,--baud=}'[serial port baud rate]:baud:(115200 230400 460800 921600 1500000)' \
  '--before=[what to do before connecting]:action:(default_reset usb_reset no_reset no_reset_no_sync)' \
  '--after=[what to do after running]:action:(hard_reset soft_reset no_reset no_reset_stub)' \
  '--no-stub[disable stub loader]' \
  '--trace[enable trace-level logging of interactions]' \
  '--override-vddsdio=[override VDDSDIO setting]:voltage:(1.8V 1.9V OFF)' \
  '--connect-attempts=[number of connection attempts]:attempts:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'esptool command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      write_flash)
        _arguments \
          '--flash_freq=[SPI flash frequency]:freq:(keep 40m 26m 20m 80m)' \
          '--flash_mode=[SPI flash mode]:mode:(keep qio qout dio dout)' \
          '--flash_size=[SPI flash size]:size:(keep detect 256KB 512KB 1MB 2MB 4MB 8MB 16MB 32MB 64MB 128MB)' \
          '--no-progress[suppress progress output]' \
          '--verify[verify after flashing]' \
          '--compress[compress data in transfer]' \
          '--no-compress[disable compression]' \
          '*:address and file:_files'
        ;;
      read_flash)
        _arguments \
          '1:address:' \
          '2:size:' \
          '3:output file:_files'
        ;;
      erase_region)
        _arguments \
          '1:address:' \
          '2:size:'
        ;;
      elf2image)
        _arguments \
          '--output=[output filename]:file:_files' \
          '--flash_freq=[SPI flash frequency]:freq:(40m 26m 20m 80m)' \
          '--flash_mode=[SPI flash mode]:mode:(qio qout dio dout)' \
          '--flash_size=[SPI flash size]:size:(256KB 512KB 1MB 2MB 4MB 8MB 16MB 32MB 64MB 128MB)' \
          '*:input ELF file:_files'
        ;;
      merge_bin)
        _arguments \
          '--output=[output filename]:file:_files' \
          '--flash_freq=[SPI flash frequency]:freq:(keep 40m 26m 20m 80m)' \
          '--flash_mode=[SPI flash mode]:mode:(keep qio qout dio dout)' \
          '--flash_size=[SPI flash size]:size:(keep detect 256KB 512KB 1MB 2MB 4MB 8MB 16MB 32MB 64MB 128MB)' \
          '--fill-flash-size=[pad output to flash size]:size:(256KB 512KB 1MB 2MB 4MB 8MB 16MB 32MB 64MB 128MB)' \
          '*:address and file:_files'
        ;;
    esac
    ;;
esac

return ret
