#compdef bedextract
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/set-operations/bedextract.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/bedextract/src/ExtractRows.cpp
# Reference accessed: 2026-05-27
# Verified: upstream ExtractRows.cpp argument parsing

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--version[show program version and citation info]' \
  '(--list-chr --listchr)--list-chr[list all unique chromosomes found in input BED]' \
  '(--list-chr --listchr)--listchr[list all unique chromosomes (alias of --list-chr)]' \
  '*:bed/starch file:_files -g "*.(bed|bed.gz|starch)(-.)"' && ret=0

return ret
