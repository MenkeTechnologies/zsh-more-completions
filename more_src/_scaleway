#compdef scaleway
# _scaleway — Scaleway CLI for managing Scaleway cloud (scaleway/scaleway-cli)
# upstream: https://github.com/scaleway/scaleway-cli

_scaleway() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--access-key=[Scaleway access key]:key:' \
        '--secret-key=[Scaleway secret key]:key:' \
        '--profile=[config profile to use]:profile:' \
        '(-o --output)'{-o,--output}'=[output format]:format:(json human template wide)' \
        '(-D --debug)'{-D,--debug}'[enable debug mode]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_scaleway_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init|config|autocomplete|version|help) ;;
                *)
                    _arguments \
                        '--access-key=[access key]:key:' \
                        '--secret-key=[secret key]:key:' \
                        '--profile=[profile]:profile:' \
                        '(-o --output)'{-o,--output}'=[output format]:format:(json human template wide)' \
                        '(-D --debug)'{-D,--debug}'[debug]' \
                        '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_scaleway_commands] )) ||
_scaleway_commands() {
    local -a commands
    commands=(
        'instance:manage instances'
        'k8s:manage Kubernetes Kapsule'
        'rdb:manage databases'
        'vpc:manage VPC'
        'dns:manage DNS'
        'lb:manage load balancers'
        'iot:manage IoT Hub'
        'registry:manage container registry'
        'baremetal:manage bare metal servers'
        'apple-silicon:manage Apple Silicon servers'
        'init:initialize CLI configuration'
        'config:manage CLI configuration'
        'autocomplete:install shell autocomplete'
        'version:show version'
        'help:show help'
    )
    _describe -t commands 'scaleway command' commands
}

_scaleway "$@"
