#compdef fivetran-cli fivetran
# _fivetran-cli — Fivetran fivetran-cli CLI command-line frontend wrapping the Fivetran fully-managed data integration platform REST API managing connectors destinations groups users roles webhooks dbt-transformations transformations log-fetching alerts notifications setup sync historical-resync metadata-API column-block (Fivetran team, Go); cobra
# upstream: https://www.fivetran.com/

_fivetran-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'group:group management'
        'connector:connector management'
        'destination:destination management'
        'transformation:transformation management'
        'dbt:dbt project management'
        'user:user management'
        'role:role management'
        'webhook:webhook management'
        'metadata:metadata operations'
        'alerts:alert management'
        'history:historical resync'
        'log:log fetch'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--region=+[r]:r:(us eu ap)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fivetran-cli subcommand' sub ;;
        args)
            case $words[1] in
                group|connector|destination|transformation|dbt|user|role|webhook) _arguments '1:op:(list show get create update delete sync resync pause resume)' '*:id:' ;;
            esac
            ;;
    esac
}

_fivetran-cli "$@"
