#compdef target-fs
# Documentation: https://github.com/fox-it/dissect.target/blob/main/dissect/target/tools/fs.py
# dissect.target fs tool - browse and list a target filesystem

local ret=1

_arguments -s -S \
  '-l[long listing format]' \
  '(-a --all)'{-a,--all}'[ignored but included for proper argument parsing]' \
  '(-h --human-readable)'{-h,--human-readable}'[human readable sizes]' \
  '(-R --recursive)'{-R,--recursive}'[recursively list subdirectories encountered]' \
  '-c[show time when file status was last changed]' \
  '-u[show time of last access]' \
  '(-L --dereference)'{-L,--dereference}'[follow symlinks]' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '1:target:_files' \
  '2:path:_files' && ret=0

return ret
