#compdef pdtest
# Documentation: https://github.com/xiaoyeli/superlu_dist/blob/master/TEST/pdtest.c
# SuperLU_DIST double-precision testing driver

local ret=1

_arguments -s -S \
  '-h[print help and exit]' \
  '-r[number of process rows]:nprow' \
  '-c[number of process columns]:npcol' \
  '-n[matrix dimension]:n' \
  '-x[granularity of relaxed supernodes (SUPERLU_RELAX)]:relax' \
  '-m[maximum size of supernode (SUPERLU_MAXSUP)]:maxsup' \
  '-b[estimated fill ratio (SUPERLU_FILL)]:fill' \
  '-g[min GEMM size to offload to GPU (SUPERLU_N_GEMM)]:ngemm' \
  '-s[number of right-hand sides]:nrhs' \
  '-f[sparse matrix file to test]:file:_files' \
  '*:file:_files' && ret=0

return ret
