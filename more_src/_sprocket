#compdef sprocket

# Zsh completion for sprocket / wdl-gauntlet (stjude-rust-labs/sprocket).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--arena[lint mode instead of syntax errors]' \
  '(-c --config-file)'{-c,--config-file=}'[config TOML]:file:_files' \
  '--no-config[ignore configuration files]' \
  '--no-errors[hide per-error details]' \
  '--bless[overwrite expected diagnostics]' \
  '--update[refresh pinned repo commits]' \
  '--keep[keep temporary clone directories]' \
  '--show-warnings[include warnings in report]' \
  '(-v --verbose)'{-v,--verbose}'[info logging]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-q --quiet)'{-q,--quiet}'[errors-only logging]' \
  '(-t --trace)'{-t,--trace}'[trace logging]' \
  '--log-all-modules[apply log level to all crates]' \
  '*:GitHub repo (org/name):'
