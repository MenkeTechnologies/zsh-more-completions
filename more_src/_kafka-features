#compdef kafka-features

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--describe[Describe finalized and supported features]'
    '--upgrade[Upgrade one or more features]'
    '--downgrade[Downgrade one or more features]'
    '--feature[Feature to upgrade/downgrade in format name=level]:feature:'
    '--dry-run[Perform a dry-run of the operation]'
    '--release-version[Release version for feature upgrade/downgrade]:version:'
)

_arguments -s -S $arguments
