#compdef kafka-features
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/FeatureCommand.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'describe:describe one or more feature flags'
  'upgrade:upgrade one or more feature flags'
  'downgrade:downgrade one or more feature flags'
  'disable:disable one or more feature flags'
  'version-mapping:look up the corresponding metadata version'
  'feature-dependencies:print the dependencies of a feature version'
)

_arguments -C \
  '--bootstrap-server[Server to connect to]:host\:port:' \
  '--bootstrap-controller[Controller to connect to]:host\:port:' \
  '--command-config[Admin Client config property file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kafka-features command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (upgrade|downgrade|disable)
        _arguments \
          '*--feature[Feature to set in format name=level]:feature:' \
          '--release-version[Release version for the feature operation]:version:' \
          '--metadata[New metadata version]:version:' \
          '--dry-run[Perform a dry-run of the operation]' \
          '--unsafe[Allow a downgrade that may lose metadata]' && ret=0 ;;
      (version-mapping)
        _arguments \
          '--release-version[Release version to map]:version:' && ret=0 ;;
      (feature-dependencies)
        _arguments \
          '*--feature[Feature in format name=level]:feature:' && ret=0 ;;
    esac ;;
esac

return ret
