#compdef torchserve
# Documentation: https://docs.pytorch.org/serve/server.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '--start[start TorchServe]' \
  '--stop[stop TorchServe]' \
  '--ts-config=[config properties file]:file:_files' \
  '--model-store=[model store dir]:dir:_files -/' \
  '--workflow-store=[workflow store dir]:dir:_files -/' \
  '*--models=[model name=path]:model:' \
  '--log-config=[log config]:file:_files' \
  '--ncs[no config snapshots]' \
  '--no-config-snapshots[no config snapshots]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
