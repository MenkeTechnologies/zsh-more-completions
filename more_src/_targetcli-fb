#compdef targetcli

# targetcli: Linux SCSI target (LIO) interactive admin shell
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'ls:list configuration tree'
  'help:show help'
  'cd:change configuration node'
  'pwd:show current path'
  'set:set parameter at current node'
  'get:get parameter at current node'
  'sessions:list iSCSI sessions'
  'saveconfig:save running config to file'
  'restoreconfig:restore config from file'
  'exit:exit shell'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-c[run a config snippet then exit]:cmd:' \
  '--cmd=[run a config snippet then exit]:cmd:' \
  '-b[batch mode (machine-readable output)]' \
  '--batch[batch mode (machine-readable output)]' \
  '-f[set output format]:format:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'targetcli command' commands && ret=0 ;;
esac
return ret
