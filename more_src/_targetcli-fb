#compdef targetcli-fb

# targetcli-fb: free-branch fork of targetcli (Red Hat/Fedora-maintained)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-b[batch mode]:command:' \
  '--batch[batch mode]:command:' \
  '-c[read config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '*::targetcli-fb command path:_files' && ret=0
return ret
