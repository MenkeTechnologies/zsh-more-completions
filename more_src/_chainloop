#compdef chainloop

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authentication'
  'workflow:workflow management'
  'artifact:artifacts'
  'organization:organization'
  'completion:shell completion'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--control-plane=[control plane URL]:url:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'chainloop command' commands && ret=0
    ;;
  (args)
    _arguments '*:subcommand or args: _default' && ret=0
    ;;
esac

return ret
