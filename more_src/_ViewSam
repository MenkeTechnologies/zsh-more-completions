#compdef ViewSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/ViewSam.java
# Picard: print records from a SAM/BAM/CRAM to standard output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM file or GA4GH url]:file:_files' \
  '--ALIGNMENT_STATUS=[which reads to print by alignment status]:s:(Aligned Unaligned All)' \
  '--PF_STATUS=[which reads to print by PF status]:s:(PF NonPF All)' \
  '--HEADER_ONLY=[print the SAM header only]:b:(true false)' \
  '--RECORDS_ONLY=[print alignment records only]:b:(true false)' \
  '--INTERVAL_LIST=[restrict output to these intervals]:file:_files' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
