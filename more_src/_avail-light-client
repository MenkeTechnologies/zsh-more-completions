#compdef avail-light-client
# ---------------------------------------------------------------------------
# avail-light-client — Avail Network p2p Light Client (Rust, 643★ org-level)
#
# upstream: https://github.com/availproject/avail-light
# project: Polygon Avail / availproject — modular data availability layer
# license: Apache-2.0
#
# Source-direct completion: every flag below is verbatim from
# client/src/cli.rs `CliOpts` clap-derive struct on the avail-light tip.
#
# Direct deps from Cargo.toml (workspace + client):
#   opentelemetry            = "0.27.1"     ← canonical Rust OpenTelemetry
#                                             implementation (this axis)
#   tracing-opentelemetry                    (bridge tracing → otlp)
#   tracing, tracing-subscriber              (the canonical Rust telemetry
#                                             facade by the tokio team)
#   libp2p                                   (p2p layer)
#   clap (derive), tokio, serde, color-eyre
#   tikv-jemallocator                        (non-msvc, perf allocator)
#
# avail-light-client uses OpenTelemetry OTLP exporters via the `telemetry::otlp`
# module to emit Avail-specific metrics (block counters, peer counts, sync
# state) into any OTLP-compatible backend (Jaeger, Tempo, Honeycomb, etc.)
# alongside structured tracing via tracing-subscriber.
#
# === AXIS 161 OPENER — distributed-tracing observability ecosystem ===
# Axis position: Rust=216 OPENS Axis 161 at slot 1/0/0.  Canonical Rust
# observability implementation is the OpenTelemetry Rust SIG's `opentelemetry`
# crate family + the tokio team's `tracing` facade.  This axis stands for the
# OpenTelemetry CNCF-graduated specification implementation across languages
# — each lane has a CNCF-blessed SDK.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=216   ← THIS FILE              (axis 161 OPENS, slot 1/0/0)
#   Go=216     ← next round              (axis 161 continues, slot 2/0/0)
#   TS-Node=216 ← round after            (axis 161 CLOSES at triple-216, slot 1/1/1)
# ---------------------------------------------------------------------------

_avail-light-client() {
    _arguments -s -S \
        '(-c --config)'{-c,--config=}'[path to the YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
        '(-i --identity)'{-i,--identity=}'[path to the TOML identity file (default identity.toml)]:file:_files -g "*.toml"' \
        '--app-id=[AppID for application client]:app id:' \
        '(-n --network)'{-n,--network=}'[testnet or devnet selection]:network:(local testnet mainnet hex turing maine)' \
        '--clean[run a clean light client, deleting existing avail_path folder]' \
        '--network-mode=[network mode]:mode:(both p2p_only rpc_only)' \
        '--avail-path=[path to avail_path where RocksDB stores its data]:path:_files -/' \
        '(-f --finality-sync-enable)'{-f,--finality-sync-enable}'[enable finality sync]' \
        '(-p --port)'{-p,--port=}'[P2P port]:port:_ports' \
        '(-w --webrtc-port)'{-w,--webrtc-port=}'[P2P WebRTC port]:port:_ports' \
        '--http-server-port=[HTTP port]:port:_ports' \
        '--ws-transport-enable[enable websocket transport]' \
        '--verbosity=[log level]:level:(error warn info debug trace)' \
        '--avail-passphrase=[Avail secret seed phrase password]:passphrase:' \
        '--avail-suri=[Avail secret URI, overrides parameter from identity file]:suri:' \
        '--seed=[seed string for libp2p keypair generation]:seed:' \
        '--private-key=[ed25519 private key for libp2p keypair generation]:hex:' \
        '--logs-json[set logs format to JSON]' \
        '--client-alias=[client alias for use in logs and metrics]:alias:' \
        '--operator-address=[address of the Light Client operator]:address:' \
        '--tracking-service-enable[enable light client tracking service]' \
        '--tracking-service-address=[tracking service address]:address:' \
        '--tracking-service-ping-interval=[tracking service ping interval in seconds]:seconds:' \
        '--no-update[disable client self-update check]' \
        '--p2p-client-restart-interval=[p2p client restart interval in seconds]:seconds:' \
        '--auto-nat-mode=[AutoNAT behaviour mode (default disabled)]:mode:(enabled disabled)' \
        '--operation-mode=[Kademlia operation mode]:mode:(client server)' \
        '--local-test-mode[run as local test mode (testing only)]' \
        '--address-blacklist=[comma-separated address patterns to filter out when adding peers]:patterns:' \
        '--external-address=[external P2P address (e.g. /ip4/1.1.1.1/tcp/37000)]:multiaddr:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_avail-light-client "$@"
