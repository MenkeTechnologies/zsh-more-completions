#compdef netavark
# Documentation: https://man.archlinux.org/search?q=netavark
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'setup:configure network namespace'
  'teardown:undo network configuration'
  'update:update network configuration'
  'firewall-reload:reload firewall config'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --file)'{-f+,--file=}'[input config file (- for stdin)]:file:_files' \
  '(-c --config)'{-c+,--config=}'[netavark config dir]:dir:_files -/' \
  '(-r --rootless)'{-r,--rootless}'[run rootless]' \
  '--aardvark-binary=[aardvark-dns binary]:cmd:_command_names' \
  '--plugin-directory=[plugin search directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'netavark command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup|teardown|update) _arguments '*:network namespace:' && ret=0 ;;
    esac ;;
esac

return ret
