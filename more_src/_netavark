#compdef netavark
# Documentation: https://github.com/containers/netavark/blob/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: clap CLI subcommands and global flags in src/main.rs.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a network config'
  'setup:configure given network namespace'
  'update:update network DNS servers'
  'teardown:undo configuration applied via setup'
  'version:display netavark info'
  'dhcp-proxy:start dhcp-proxy'
  'firewalld-reload:listen for firewalld reload events'
  'firewall-reload:re-apply firewall rules for all networks'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --file)'{-f+,--file=}'[input config file (- for stdin)]:file:_files' \
  '--firewall-driver=[firewall driver]:driver' \
  '(-c --config)'{-c+,--config=}'[aardvark config dir]:dir:_files -/' \
  '(-r --rootless)'{-r,--rootless}'[run rootless]' \
  '--aardvark-binary=[aardvark-dns binary]:cmd:_command_names' \
  '*--plugin-directory=[plugin search directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'netavark command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup|teardown|update) _arguments '*:network namespace:' && ret=0 ;;
    esac ;;
esac

return ret
