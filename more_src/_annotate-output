#compdef annotate-output
# Documentation: https://manpages.debian.org/annotate-output
# Source: debian/devscripts scripts/annotate-output.sh — prefix stdout/stderr lines with timestamps and stream tag (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--raw-date-format=-[date format string for "date -u"]:format:_default' \
    '*:program and args:_command_names -e' \
    && ret=0

return ret
