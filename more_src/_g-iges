#compdef g-iges
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=g-iges&sektion=1
# BRL-CAD geometry database to IGES converter

local ret=1

_arguments -s \
  '-f[generate BREP IGES with Manifold Solid BREP objects]' \
  '-t[create IGES with trimmed NURBs (planar only)]' \
  '-m[produce one IGES file per region]' \
  '-v[enable debugging output]' \
  '-s[output facets as planar NURBs in BREP objects]' \
  '-x[librt debug flag]:flag' \
  '-X[NMG debug flag]:flag' \
  '-a[absolute tessellation tolerance]:tolerance' \
  '-r[relative tessellation tolerance]:tolerance' \
  '-n[normal tessellation tolerance]:tolerance' \
  '-o[output file or directory]:output:_files' \
  '-P[number of processors to use]:cpus' \
  '1:database:_files -g "*.g"' \
  '*:object:_default' && ret=0

return ret
