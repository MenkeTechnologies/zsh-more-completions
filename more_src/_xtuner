#compdef xtuner
# _xtuner — InternLM xtuner LLM fine-tuning toolkit supporting LoRA QLoRA full SFT DPO ORPO PPO and visual instruction tuning for LLaVA InternVL Mini-Gemini (InternLM team, Python); argparse
# upstream: https://github.com/InternLM/xtuner

_xtuner() {
    local -a sub=(
        'list-cfg:list configs'
        'copy-cfg:copy config'
        'log-dataset:log dataset'
        'check-custom-dataset:check custom dataset'
        'train:train model'
        'test:test model'
        'chat:chat with model'
        'mmbench:MMBench eval'
        'convert:convert format'
        'preprocess:preprocess data'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xtuner subcommand' sub ;;
        args)
            case $words[1] in
                train|test) _arguments \
                    '--work-dir=+[dir]:dir:_files -/' \
                    '--deepspeed=+[stage]:s:(deepspeed_zero1 deepspeed_zero2 deepspeed_zero2_offload deepspeed_zero3 deepspeed_zero3_offload)' \
                    '--seed=+[N]:n:' \
                    '--resume=+[checkpoint]:file:_files' \
                    '--launcher=+[l]:l:(none pytorch slurm mpi)' \
                    '--no-validate[no validate]' \
                    '--auto-scale-lr[auto scale lr]' \
                    '--cfg-options=+[options]:str:' \
                    '*:config:_files -g "*.py"' ;;
                chat) _arguments \
                    '--adapter=+[adapter dir]:dir:_files -/' \
                    '--bits=+[bits]:b:(4 8)' \
                    '--temperature=+[F]:f:' \
                    '--top-k=+[N]:n:' \
                    '--top-p=+[F]:f:' \
                    '--repetition-penalty=+[F]:f:' \
                    '--seed=+[N]:n:' \
                    '--system=+[prompt]:str:' \
                    '--prompt-template=+[t]:t:(internlm internlm2 internlm2_chat llama2_chat code_llama_chat moss baichuan baichuan2 mistral mixtral qwen yi llava deepseek_coder deepseek_v3)' \
                    '*:model:' ;;
                convert) _arguments \
                    '1:action:(pth_to_hf hf_to_pth merge split)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_xtuner "$@"
