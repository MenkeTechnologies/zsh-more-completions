#compdef VBoxControl

# VBoxControl: VirtualBox guest-side control tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'getversion:show version'
  'guestproperty:manage guest properties'
  'sharedfolder:manage shared folders'
  'help:show help'
  'usage:show usage'
  'writecoredump:write core dump'
  'writelog:write to host log'
  'takesnapshot:take a snapshot'
  'savestate:save VM state'
  'vmrun:run a VM operation'
  'ls:list guests'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'VBoxControl command' commands && ret=0 ;;
esac
return ret
