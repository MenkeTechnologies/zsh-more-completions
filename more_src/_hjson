#compdef hjson hjson-go

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-c[output compact JSON]' \
  '-j[output JSON]' \
  '-h[Hjson output]' \
  '-q[output quoted strings]' \
  '-bracesSameLine[braces on same line]' \
  '-omitRootBraces[omit root braces]' \
  '-quoteAlways[always quote]' \
  '-allowMinusZero[allow -0]' \
  '-bail[bail on first error]' \
  '-indent+[indent string]:s:' \
  '-eol+[end of line]:s:(lf crlf)' \
  '-comments+[preserve comments]:b:(true false)' \
  '-preserveKeyOrder+[preserve key order]:b:(true false)' \
  '*: :_files -g "*.hjson *.json"' && ret=0

return ret
