#compdef hjson hjson-cli
# Documentation: https://github.com/hjson/hjson-go
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

# hjson-cli flags from hjson/hjson-go/v4
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-c[output as JSON]' \
  '-j[output as formatted JSON]' \
  '-bracesSameLine[print braces on the same line]' \
  '-omitRootBraces[omit braces at the root]' \
  '-quoteAlways[always quote string values]' \
  '-preserveKeyOrder[preserve key order in objects/maps]' \
  '-indentBy+[indent string]:s:' \
  '*: :_files -g "*.(hjson|json)"' && ret=0

return ret
