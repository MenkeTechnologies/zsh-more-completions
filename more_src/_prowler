#compdef prowler

# Zsh completion for prowler - Cloud security scanner and compliance tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'aws:Scan AWS account'
  'azure:Scan Azure subscription'
  'gcp:Scan GCP project'
  'kubernetes:Scan Kubernetes cluster'
  'dashboard:Launch the Prowler dashboard'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-banner[hide the banner]' \
  '--only-logs[only output logs, no progress bars]' \
  '--log-level=[set log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--log-file=[output log to file]:file:_files' \
  '(-M --output-modes)'{-M,--output-modes}'[output modes]:modes' \
  '(-F --output-filename)'{-F,--output-filename}'[custom output filename]:filename' \
  '(-o --output-directory)'{-o,--output-directory}'[output directory]:dir:_directories' \
  '--severity=[filter findings by severity]:severity:(critical high medium low informational)' \
  '(-C --compliance)'{-C,--compliance}'[compliance framework to check]:framework' \
  '(-c --checks)'{-c,--checks}'[specific checks to execute]:checks' \
  '(-S --services)'{-S,--services}'[specific services to scan]:services' \
  '--categories=[filter by categories]:categories' \
  '--list-checks[list all available checks]' \
  '--list-services[list all available services]' \
  '--list-compliance[list all available compliance frameworks]' \
  '--config-file=[custom configuration file]:file:_files' \
  '--mutelist-file=[mutelist file path]:file:_files' \
  '1:provider:->provider' \
  '*::arg:->args' && ret=0

case $state in
  provider)
    _describe -t subcommands 'cloud provider' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      aws)
        _arguments \
          '--profile=[AWS profile name]:profile' \
          '--region=[AWS region]:region' \
          '--role=[ARN of IAM role to assume]:role-arn' \
          '--session-duration=[assumed role session duration]:seconds' \
          '--resource-arn=[ARN of specific resource to scan]:arn' && ret=0
        ;;
      azure)
        _arguments \
          '--subscription-ids=[Azure subscription IDs]:ids' \
          '--az-cli-auth[use Azure CLI authentication]' \
          '--sp-env-auth[use service principal env authentication]' \
          '--browser-auth[use browser authentication]' \
          '--managed-identity-auth[use managed identity authentication]' && ret=0
        ;;
      gcp)
        _arguments \
          '--project-ids=[GCP project IDs]:ids' \
          '--credentials-file=[path to credentials file]:file:_files' && ret=0
        ;;
      kubernetes)
        _arguments \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--context=[Kubernetes context]:context' \
          '--namespace=[namespace to scan]:namespace' && ret=0
        ;;
    esac
    ;;
esac

return ret
