#compdef diff2html

_diff2html() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '(-s --style)'{-s,--style}'[diff style]:style:(line side)' \
        '(-f --format)'{-f,--format}'[output format]:format:(html json)' \
        '(-d --diff)'{-d,--diff}'[diff file path]:diff file:_files' \
        '--input=[input source]:source:(file command stdin)' \
        '--output=[output destination]:destination:(preview stdout)' \
        '(-F --file)'{-F,--file}'[output file path]:output file:_files' \
        '--summary=[file summary display mode]:mode:(open closed hidden)' \
        '--title=[page title]:title:' \
        '--diffy=[use diffy for sharing]:mode:(new)' \
        '--htmlWrapperTemplate=[custom HTML wrapper template]:template file:_files' \
        '*--ignore=[space change handling]:mode:' \
        '*--match=[regex to match files]:pattern:' \
        '--diffMaxChanges=[max number of changes to display]:count:' \
        '--diffMaxLineLength=[max line length to process]:length:' \
        '--renderNothingWhenEmpty[render nothing when diff is empty]' \
        '--maxLineSizeInBlockForComparison=[max line size for comparison in blocks]:size:' \
        '--maxLineLengthHighlight=[max line length for syntax highlighting]:length:' \
        '--synchronisedScroll=[enable synchronized scrolling]:enabled:(true false)' \
        '--highlight=[enable syntax highlighting]:enabled:(true false)' \
        '--colorScheme=[color scheme]:scheme:(auto dark light)' \
        '*:diff arguments:' && ret=0

    return ret
}

_diff2html "$@"
