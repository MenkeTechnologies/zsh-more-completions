#compdef qmove
# _qmove-pbs — PBS qmove (move a queued PBS job between queues or PBS servers; positional argument is the destination queue (queue, queue@server, or @server) then jobIDs; -W extension data forwarded to the new queue; the receiving queue must accept the job's resource specification or qmove fails)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qmove.c on tip.

_qmove-pbs() {
    _arguments \
        '-W+[wait spec]:wait:' \
        '1:destination queue:' \
        '*:jobID:'
}

_qmove-pbs "$@"
