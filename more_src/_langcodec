(( $+functions[_langcodec_commands] )) ||
_langcodec_commands() {
    local commands; commands=(
'convert:Convert localization files between formats' \
'edit:Edit localization files in-place' \
'diff:Compare two localization files and report added/removed/changed keys by language' \
'sync:Sync existing entries from a source file into a target file.' \
'view:View localization files' \
'merge:Merge multiple localization files into one output file with automatic format detection and conversion' \
'normalize:Normalize localization files' \
'stats:Show translation coverage and per-status counts' \
'translate:Translate source entries into a target language using Mentra-backed providers' \
'annotate:Generate translator-facing localization comments from source usage with a Mentra agent' \
'tolgee:Sync xcstrings catalogs with Tolgee using langcodec.toml or .tolgeerc.json mappings' \
'browse:Interactive TUI browser for localization files.' \
'debug:Debug\: Read a localization file and output as JSON' \
'completions:Generate shell completion script and print to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'langcodec commands' commands "$@"
}
