#compdef dagster-cloud
# Documentation: https://docs.dagster.io/api/clis/dagster-cloud-cli/dagster-cloud-cli-reference
# Dagster+ (dagster-cloud) command line interface

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --organization)'{-o,--organization}'=[Dagster+ organization name]:org:' \
  '(-d --deployment)'{-d,--deployment}'=[deployment name]:deployment:' \
  '(-u --user-token)'{-u,--user-token}'=[Dagster+ user token]:token:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'serverless:manage serverless deployments'
      'deployment:manage deployments and code locations'
      'branch-deployment:manage branch deployments'
      'workspace:manage the workspace'
    )
    _describe -t commands 'dagster-cloud command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      serverless)
        local -a sub
        sub=(
          'deploy:deploy code using a Docker image'
          'deploy-python-executable:deploy a Python executable'
        )
        _describe -t subcommands 'serverless subcommand' sub && ret=0
        ;;
      deployment)
        local -a sub
        sub=('add-location:add a code location to a deployment')
        _describe -t subcommands 'deployment subcommand' sub && ret=0
        ;;
      branch-deployment)
        local -a sub
        sub=('create-or-update:create or update a branch deployment')
        _describe -t subcommands 'branch-deployment subcommand' sub && ret=0
        ;;
      *)
        ret=0
        ;;
    esac
    ;;
esac

return ret
