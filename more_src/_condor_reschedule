#compdef condor_reschedule
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_reschedule.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_reschedule: tell the schedd to immediately start a new negotiation cycle.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[host/schedd name]:name:' \
  '-addr[address (sinful)]:sinful:' \
  '-constraint[constraint expression]:expr:' \
  '-all[all machines in pool]' \
  '*::condor_reschedule args:_files' && ret=0
return ret
