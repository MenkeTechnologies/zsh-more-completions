#compdef condor_reschedule
# Documentation: https://man.archlinux.org/search?q=condor_reschedule
# Reference accessed: 2026-05-16

# condor_reschedule: tell schedd to immediately start a new negotiation cycle
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-name[schedd]:name:' \
  '-addr[address]:sinful:' \
  '-debug[debug]' \
  '-all[all schedds]' \
  '-constraint[constraint]:expr:' \
  '*::condor_reschedule args:_files' && ret=0
return ret
