#compdef saya
# Documentation: source-direct extraction from upstream
# dojoengine/saya bin/persistent/src/ (clap v4 derive):
#   main.rs lines 30-44 (Cli + Subcommands enum: 2 variants
#     `Sovereign(Sovereign)` and `Start(Start)`)
#   persistent.rs lines 36-80 (Start Parser struct: 14
#     direct fields + HintsConfiguration flatten + Celestia-
#     Configuration flatten)
#   persistent.rs lines 82-98 (CelestiaConfiguration: 4
#     fields with `validate_non_empty` value_parser on
#     namespace)
#   persistent.rs lines 100-111 (HintsConfiguration: 3 bool
#     fields with `default_value_t = false`)
#   sovereign.rs lines 31-41 (Sovereign nested struct with
#     its own Subcommands enum containing single Start
#     variant)
#   sovereign.rs lines 43-77 (sovereign-mode Start struct:
#     10 direct fields + GenesisOptions flatten)
#   sovereign.rs lines 79-86 (validate_non_empty value_parser
#     function returning Result<String, String>)
#   sovereign.rs lines 88-95 (GenesisOptions with
#     `long = "genesis.first-block-number"` dotted-prefix
#     CLI flag)
# Reference accessed: 2026-05-30 via gh api.
#
# saya is the **Dojo proving orchestrator** — produces
# Cairo execution proofs for Starknet appchain rollups
# (Dojo "worlds" deployed as L3 sovereign or persistent
# L2-settled chains).  Completes the Dojo Engine cluster:
# sozo (R250 manages worlds), katana (devnet, in corpus),
# torii (R251 indexer), saya (R252 prover orchestrator).
# Major validity-rollup tooling — saya integrates with the
# Atlantic prover service + Celestia data-availability +
# Piltover settlement contract.
#
# Critical extraction note: saya uses **2 deployment modes
# as top-level subcommands**:
#   `saya sovereign start ...`  — sovereign rollup
#     (Celestia DA only; no settlement layer; standalone
#      proof chain)
#   `saya start ...`            — persistent L3 mode
#     (settles proofs on a "base layer" Starknet via
#      Piltover; full pipeline including layout bridge)
# Note: `sovereign` is a GROUP that ONLY contains `start`
# — `saya sovereign` alone is incomplete; the user MUST
# follow with `start`.  Documents the **subcommand-as-
# group-namespace** pattern where a parent subcommand
# has only one child but provides organizational
# grouping in `--help`.  Distinct from a typical 1-deep
# subcommand structure where every leaf is reachable
# directly.
#
# Critical extraction note: saya uses
# **`#[allow(clippy::large_enum_variant)]`** at
# main.rs:36 on the Subcommands enum.  Opposite of R250
# sozo's `Box<XxxArgs>` pattern — saya just SUPPRESSES
# the clippy lint instead of wrapping variants in Box.
# This is the **corpus's first documented `#[allow(clippy::
# large_enum_variant)]` lint-suppression alternative to
# Box wrapping**.  Sozo's 21-variant enum benefited from
# Box (each variant just 8 bytes); saya's 2-variant enum
# has fewer values to allocate so the size penalty is
# tolerable.  Documents the **trade-off**: Box adds
# indirection (heap allocation + pointer chase) but
# bounds enum size; allow-lint accepts wasted memory in
# exchange for stack-only allocation.  For small-variant-
# count enums (2-3 variants), allow-lint is often the
# right choice.
#
# Critical extraction note: saya uses **`#[clap(long, env)]`
# WITHOUT explicit env name** at EVERY env-aware flag.
# clap auto-derives the env var name from the field name
# (e.g. `rollup_rpc` → `ROLLUP_RPC`).  This is the corpus's
# **first documented `env` clap attribute used WITHOUT a
# value** — clap derive's auto-derivation rule: take the
# field name, convert to SCREAMING_SNAKE_CASE.  Distinct
# from R250 sozo's explicit `env = "DOJO_MANIFEST_PATH"`
# (different name from field) and R251 torii's explicit
# `env = "DOJO_WORLD_ADDRESS"`.  saya uses the auto-derived
# names because they happen to match the convention.  The
# exception is `GENESIS_FIRST_BLOCK_NUMBER` at sovereign.rs:92
# which uses explicit `env = "GENESIS_FIRST_BLOCK_NUMBER"`
# to match the **dotted-prefix CLI flag** `genesis.first-
# block-number` (the CLI flag and env var conventions
# diverge: CLI uses dots + dashes, env uses underscores).
#
# Critical extraction note: saya uses
# **`validate_non_empty`** at persistent.rs:96 +
# sovereign.rs:66 (the value_parser for `celestia_namespace`)
# defined at sovereign.rs:79-86.  This is a string-trim+
# empty-check validator returning `Result<String, String>`
# rather than `Result<String, anyhow::Error>` like R248
# cairo-coverage.  Documents the **simpler String-error
# value_parser pattern** — clap accepts any
# `Fn(&str) -> Result<T, E> where E: Display`, so a tuple
# error type (String here) works fine.  4th documented
# parser-level validation pattern: (1) R231 ferrishot
# bpaf guard, (2) R247 sncast NonZero* type-system, (3)
# R248 cairo-coverage anyhow::ensure! validators, (4)
# R252 saya plain-String validator.
#
# Critical extraction note: saya's persistent mode has
# **3 cross-flag implication rules** enforced AT RUNTIME
# (NOT via clap's `requires` / `conflicts_with`):
#   1. EITHER `--layout-bridge-program` + `--atlantic-key`
#      OR `--mock-layout-bridge-program-hash` MUST be
#      provided (else bail at persistent.rs:167-169 with
#      "invalid config" error)
#   2. `--settlement-integrity-address` MUST be provided
#      UNLESS `--mock-layout-bridge-program-hash` is used
#      (bails at persistent.rs:241-244)
#   3. `--celestia-rpc` + `--celestia-token` must come
#      together (one without the other falls back to Noop
#      DA backend silently at persistent.rs:208-222)
# Documents the **runtime cross-flag validation pattern**
# — saya chose runtime bail over clap's declarative
# `requires`/`conflicts_with` because the logic is multi-
# variable (any-of + unless-of combinations) which is
# awkward to express declaratively.  Distinct from R248
# cairo-coverage's `requires = "unstable"` which IS
# declarative.

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'sovereign:run + manage Saya in sovereign mode (Celestia DA only; no settlement layer)'
  'start:start Saya in persistent L3 mode (proofs settled on a "base layer" Starknet via Piltover)'
)

local -a sovereign_subs=(
  'start:start Saya in sovereign mode'
)

# `saya start` (persistent L3 mode) flags decoded
# source-direct from Start Parser at persistent.rs lines
# 36-80 + HintsConfiguration lines 100-111 +
# CelestiaConfiguration lines 82-98.
local -a start_persistent_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--rollup-rpc=[Rollup network Starknet JSON-RPC URL v0.7.1 (env: ROLLUP_RPC)]:url:'
  '--settlement-rpc=[Settlement network Starknet JSON-RPC URL v0.7.1 (env: SETTLEMENT_RPC)]:url:'
  '--mock-snos-from-pie[mock the SNOS proof by extracting the output from the PIE]'
  '--layout-bridge-program=[path to the compiled Cairo verifier program (env: LAYOUT_BRIDGE_PROGRAM)]:file:_files'
  '--atlantic-key=[Atlantic prover API key (env: ATLANTIC_KEY)]:key:'
  '--settlement-integrity-address=[settlement network integrity contract address (env: SETTLEMENT_INTEGRITY_ADDRESS)]:felt:'
  '--mock-layout-bridge-program-hash=[generate mock layout bridge proof + skip on-chain fact registration (env: MOCK_LAYOUT_BRIDGE_PROGRAM_HASH)]:felt:'
  '--settlement-piltover-address=[settlement network piltover contract address (env: SETTLEMENT_PILTOVER_ADDRESS; required)]:felt:'
  '--settlement-account-address=[settlement network account contract address (env: SETTLEMENT_ACCOUNT_ADDRESS; required)]:felt:'
  '--settlement-account-private-key=[settlement network account private key (env: SETTLEMENT_ACCOUNT_PRIVATE_KEY; required)]:felt:'
  '--db-dir=[path to the database directory (env: DB_DIR)]:dir:_files -/'
  '--blocks-processed-in-parallel=[number of blocks processed in parallel evenly distributed between stages (env: BLOCKS_PROCESSED_IN_PARALLEL; default: 60)]:n:'
  '--debug-mode[enable debug mode for OS hints generation (env: DEBUG_MODE)]'
  '--full-output[generate full output for OS hints (env: FULL_OUTPUT)]'
  '--use-kzg-da[use KZG data availability for OS hints (env: USE_KZG_DA)]'
  '--celestia-rpc=[Celestia RPC endpoint URL (env: CELESTIA_RPC; pairs with --celestia-token; absence = Noop DA backend)]:url:'
  '--celestia-token=[Celestia RPC node auth token (env: CELESTIA_TOKEN; pairs with --celestia-rpc)]:token:'
  '--celestia-key-name=[Celestia key name (env: CELESTIA_KEY_NAME)]:name:'
  '--celestia-namespace=[Celestia namespace (env: CELESTIA_NAMESPACE; default: sayaproofs; non-empty validated)]:namespace:'
)

# `saya sovereign start` flags decoded source-direct from
# sovereign.rs Start struct at lines 43-77 + GenesisOptions
# at lines 88-95.
local -a start_sovereign_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--starknet-rpc=[Starknet JSON-RPC URL v0.7.1 (env: STARKNET_RPC; required)]:url:'
  '--mock-snos-from-pie[mock the SNOS proof by extracting the output from the PIE]'
  '--atlantic-key=[Atlantic prover API key (env: ATLANTIC_KEY; required)]:key:'
  '--celestia-rpc=[Celestia RPC endpoint URL (env: CELESTIA_RPC; required)]:url:'
  '--celestia-token=[Celestia RPC node auth token (env: CELESTIA_TOKEN; required)]:token:'
  '--celestia-key-name=[Celestia key name (env: CELESTIA_KEY_NAME)]:name:'
  '--celestia-namespace=[Celestia namespace (env: CELESTIA_NAMESPACE; default: sayaproofs; non-empty validated)]:namespace:'
  '--genesis.first-block-number=[genesis first block number (env: GENESIS_FIRST_BLOCK_NUMBER; DOTTED-PREFIX CLI flag)]:n:'
  '--blocks-processed-in-parallel=[number of blocks to process in parallel (env: BLOCKS_PROCESSED_IN_PARALLEL; required)]:n:'
  '--db-dir=[path to the database directory (env: DB_DIR)]:dir:_files -/'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version (from crate metadata via clap(about, version))]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'saya subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      sovereign)
        # `saya sovereign` is just a namespace; the only
        # leaf is `start` (sovereign.rs:38-41 Subcommands
        # enum with single Start variant).
        if (( CURRENT == 2 )); then
          _describe -t sovereign-subs 'sovereign verb' sovereign_subs && ret=0
        else
          case $words[2] in
            start)
              _arguments $start_sovereign_flags && ret=0
              ;;
          esac
        fi
        ;;
      start)
        _arguments $start_persistent_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
