#compdef wayst

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --title)'{-t,--title}'+[window title]:title:' \
  '(-T --title-format)'{-T,--title-format}'+[title format]:fmt:' \
  '(-a --app-id)'{-a,--app-id}'+[application id / wm class]:id:' \
  '(-g --geometry)'{-g,--geometry}'+[window geometry WxH+X+Y]:geom:' \
  '(-f --font)'{-f,--font}'+[primary font]:font:' \
  '(-S --font-size)'{-S,--font-size}'+[font point size]:size:' \
  '(-D --term)'{-D,--term}'+[$TERM value]:term:(xterm-256color wayst xterm tmux-256color)' \
  '(-l --locale)'{-l,--locale}'+[locale]:locale:' \
  '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
  '(-x --execute)'{-x,--execute}'[execute remaining args as command]' \
  '(-e --command)'{-e,--command}'+[run command]:cmd:_command_names' \
  '--bg-color=[background color]:color:' \
  '--fg-color=[foreground color]:color:' \
  '--colorscheme=[colorscheme]:scheme:' \
  '--no-flash[disable visual bell]' \
  '--bell-flash=[bell flash color]:color:' \
  '--enable-sgr-pixels[enable SGR pixel reporting]' \
  '--no-dynamic-title[disable dynamic title updates]' \
  '--dynamic-title=[allow dynamic title updates]:flag:(on off)' \
  '--scrollback=[scrollback buffer size in lines]:lines:' \
  '--padding=[padding in pixels]:px:' \
  '--blink-interval=[cursor blink interval ms]:ms:' \
  '--debug-gfx[debug GPU rendering]' \
  '*:command:_command_names' && ret=0

return ret
