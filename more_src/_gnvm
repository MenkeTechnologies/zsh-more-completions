#compdef gnvm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install one or more Node.js versions'
  'uninstall:uninstall a Node.js version'
  'use:switch to a locally-installed Node.js version'
  'update:update the latest Node.js version'
  'ls:list local or remote Node.js versions'
  'list:list local or remote Node.js versions'
  'search:search/print remote Node.js versions'
  'session:set the version for the current shell session'
  'reg:set/remove NODE_HOME in env'
  'npm:manage NPM versions'
  'config:get/set .gnvmrc configuration'
  'node-version:show global or latest version'
  'version:show gnvm version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnvm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '-g[set the installed version globally]' \
          '*::versions:(latest global)' && ret=0 ;;
      (ls|list)
        _arguments \
          '-l[list local versions]' \
          '-r[list remote versions]' \
          '-d[describe versions]' \
          '--limit=[limit number of rows for remote]:n:' && ret=0 ;;
      (search)
        _arguments \
          '*::query:' && ret=0 ;;
      (config)
        _arguments \
          '*::key_value:' && ret=0 ;;
      (npm)
        _arguments \
          '*::sub:(latest sync update install)' && ret=0 ;;
      (reg)
        _arguments \
          '*::sub:(get set rm)' && ret=0 ;;
      (session)
        _arguments \
          '*::version:' && ret=0 ;;
      (use|uninstall)
        _arguments \
          '*::version:(latest)' && ret=0 ;;
    esac ;;
esac

return ret
