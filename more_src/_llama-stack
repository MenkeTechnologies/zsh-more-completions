#compdef llama-stack llama

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'stack:build, configure and run Llama Stack distributions'
  'model:manage local Llama models'
  'download:download model weights'
  'verify-download:verify downloaded model weights'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'llama command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (stack)
        _arguments \
          '*::sub:(build configure list-providers list-stacks list-apis run)' \
          '--template=[distribution template]:template:(starter ollama dev tgi together fireworks vllm bedrock cerebras nvidia groq passthrough remote-vllm meta-reference-gpu meta-reference-quantized-gpu)' \
          '--image-type=[image type]:type:(conda venv container)' \
          '--image-name=[custom image name]:name:' \
          '--config=[config file]:file:_files -g "*.{yaml,yml}"' \
          '--port=[server port]:port:' \
          '--run[run after build]' \
          '--list-templates[list available templates]' \
          '--env=[env override KEY=value]:kv:' \
          '--no-pull[skip pulling images]' && ret=0 ;;
      (model)
        _arguments \
          '*::sub:(list describe prompt-format remove verify-download)' \
          '--model-id=[model id]:model:' && ret=0 ;;
      (download)
        _arguments \
          '--source=[model source]:source:(meta huggingface)' \
          '--model-id=[model id]:model:' \
          '--meta-url=[Meta presigned URL]:url:' \
          '--hf-token=[Hugging Face token]:token:' \
          '--ignore-patterns=[hf ignore globs]:patterns:' && ret=0 ;;
    esac ;;
esac

return ret
