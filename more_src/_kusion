#compdef kusion

# Zsh completion for KusionStack CLI (kusion)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--profile=[name of profile to capture]:profile:(none cpu heap)' \
  '--profile-output=[name of the file to write the profile to]:file:_files' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'init:initialize the scaffolding for a new Kusion project'
      'generate:generate and print the resulting Spec resources'
      'preview:preview resource changes within the stack'
      'apply:apply operational intent to multiple runtimes'
      'destroy:destroy resources within the stack'
      'workspace:manage logical targets for stack deployment'
      'project:manage Kusion projects'
      'stack:manage stacks within a project'
      'mod:manage Kusion modules'
      'release:manage Kusion release files'
      'resource:observe information about Kusion resources'
      'config:interact with the Kusion CLI configuration'
      'version:print version information'
    )
    _describe -t commands 'command' commands
    ;;
  args)
    case $line[1] in
      workspace|project|stack|mod|release|resource|config)
        local -a subcommands
        case $line[1] in
          workspace) subcommands=('create' 'delete' 'list' 'show' 'update') ;;
          project) subcommands=('create' 'list') ;;
          stack) subcommands=('create' 'list' 'show') ;;
          mod) subcommands=('add' 'init' 'list' 'push') ;;
          release) subcommands=('list' 'show' 'unlock') ;;
          resource) subcommands=('graph' 'list' 'show') ;;
          config) subcommands=('get' 'list' 'set' 'unset') ;;
        esac
        _arguments "1: :(${subcommands[*]})" && ret=0
        ;;
    esac
    ;;
esac

return ret
