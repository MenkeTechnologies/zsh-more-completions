#compdef freecad-daily

# FreeCAD daily: nightly build of FreeCAD parametric CAD
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --console)'{-c,--console}'[start without GUI]' \
  '(-t --run-test)'{-t,--run-test=}'[run unit test]:test:' \
  '(-l --log-file)'{-l,--log-file=}'[log to file]:file:_files' \
  '(-u --user-cfg)'{-u,--user-cfg=}'[user config file]:file:_files' \
  '(-s --system-cfg)'{-s,--system-cfg=}'[system config file]:file:_files' \
  '(-M --module-path)'{-M,--module-path=}'[additional module path]:dir:_files -/' \
  '(-P --python-path)'{-P,--python-path=}'[additional Python path]:dir:_files -/' \
  '(-p --pass)'{-p,--pass}'[pass remaining args to script]' \
  '(-r --response-file)'{-r,--response-file=}'[read args from file]:file:_files' \
  '--single-instance[single-instance mode]' \
  '--write-log[write log file]' \
  '--keep-deprecated-paths[keep deprecated module paths]' \
  '--disable-modules[modules to disable]:list:' \
  '*:FreeCAD file:_files -g "*.(FCStd|fcstd|FCStd1|step|stp|iges|igs|brep|stl)"' && ret=0
return ret
