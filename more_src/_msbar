#compdef msbar
# Documentation: https://man.archlinux.org/search?q=msbar
# Reference accessed: 2026-05-16

# EMBOSS msbar: mutate sequence(s) - simulate point mutations / indels
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-count=[number of mutations per sequence]:n:' \
  '-point=[point-mutation operation]:op:(0 1 2 3 4 5)' \
  '-block=[block-mutation operation]:op:(0 1 2 3 4 5)' \
  '-codon=[codon-mutation operation]:op:(0 1 2 3 4 5)' \
  '-inframe[restrict block operations to keep reading frame]' \
  '-minimum=[minimum length of block]:n:' \
  '-maximum=[maximum length of block]:n:' \
  '-outseq=[mutated sequence output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
