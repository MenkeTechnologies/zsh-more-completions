#compdef astrometry-engine
# Documentation: https://astrometry.net/doc/readme.html
# Documentation: https://github.com/dstndstn/astrometry.net/blob/main/solver/engine-main.c
# Reference accessed: 2026-05-27
# Verified: upstream solver/engine-main.c myopts[] (dstndstn/astrometry.net)

# Zsh completion for astrometry-engine (astrometry.net solver engine)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message]' \
  '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
  '(-c --config)'{-c+,--config=}'[use this config file (default astrometry.cfg)]:config:_files' \
  '(-d --base-dir)'{-d+,--base-dir=}'[set base directory of all output filenames]:directory:_files -/' \
  '(-C --cancel)'{-C+,--cancel=}'[quit solving if this file appears]:file:_files' \
  '(-s --solved)'{-s+,--solved=}'[write to this file when a field is solved]:file:_files' \
  '(-E --to-stderr)'{-E,--to-stderr}'[send log message to stderr]' \
  '(-f --inputs-from)'{-f+,--inputs-from=}'[read input filenames from file ("-" for stdin)]:file:_files' \
  '*'{-i+,--index=}'[use the given index file(s)]:index:_files' \
  '(-I --index-dir)'{-I+,--index-dir=}'[search for index files in directory]:directory:_files -/' \
  '(-p --in-parallel)'{-p,--in-parallel}'[run the index files in parallel]' \
  '(-D --data-log)'{-D+,--data-log=}'[log data to the given filename]:file:_files' \
  '(-j --job-id)'{-j+,--job-id=}'[ignored; allows process to contain job id]:jobid:' \
  '*:axy input:_files -g "*.(axy|xyls|fits|FITS)"' && ret=0

return ret
