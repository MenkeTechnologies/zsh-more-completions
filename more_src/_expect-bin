#compdef expect
# _expect-bin — Expect Tcl extension for automating interactive programs (Don Libes, NIST); script CLI program interactions
# upstream: https://core.tcl-lang.org/expect

_expect-bin() {
    _arguments \
        '-c+[command]:cmd:' \
        '-d[debug mode]' \
        '-D+[enable interactive debugger]:n:' \
        '-f+[script file]:file:_files -g "*.exp"' \
        '-i[interactive]' \
        '-N[do not read .expect.rc system rc]' \
        '-n[do not read .expectrc user rc]' \
        '-v[show version]' \
        '-b[buffered mode]' \
        '*:script:_files'
}

_expect-bin "$@"
