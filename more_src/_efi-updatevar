#compdef efi-updatevar
# Documentation: https://manpages.debian.org/unstable/efitools/efi-updatevar.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream efitools man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-a[append value instead of replace]' \
  '-e[use EFI Signature List unsigned update]' \
  '-b+[add hash of binary]:file:_files' \
  '-f+[key file (.esl/.auth)]:file:_files -g "*.esl *.auth"' \
  '-c+[x509 certificate]:file:_files -g "*.crt *.pem *.cer"' \
  '-g+[GUID for certificate]:guid:' \
  '-k+[secret key file]:file:_files -g "*.key *.pem"' \
  '-d+[delete signature list (or single entry within list)]:spec:' \
  '--engine=[use engine for private key]:engine:' \
  '1:variable:(PK KEK db dbx MokList MokListX SbatLevel)' && ret=0

return ret
