#compdef freeorion
# Documentation: https://www.freeorion.org/index.php/Main_Page
# Reference accessed: 2026-05-16

# FreeOrion: 4X turn-based space empire strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--auto-quit[quit after autoplay]' \
  '--connect=[connect to host]:host:_hosts' \
  '--default-pause-game-on-start[pause on start]' \
  '--full-screen[fullscreen]' \
  '--load=[load save game]:file:_files' \
  '--multiplayer-on[start in multiplayer]' \
  '--quickstart[quickstart single-player]' \
  '--resource.path=[resource dir]:dir:_files -/' \
  '--save.path=[save dir]:dir:_files -/' \
  '--server.python.AI.disable=[disable Python AI]:bool:(true false)' \
  '--video.fullscreen.height.windowed=[windowed height]:n:' \
  '--video.fullscreen.width.windowed=[windowed width]:n:' \
  '--ai-pause[pause AI]' \
  '*::freeorion args:_files' && ret=0
return ret
