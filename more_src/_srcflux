#compdef srcflux
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/srcflux.html
# Calculate net count rates and fluxes of sources in a Chandra observation

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input Chandra event file]:file:_files' \
  'pos=[RA and DEC position of the source]:pos:' \
  'outroot=[the output root file name including directory]:root:' \
  'bands=[energy bands and characteristic energy value]:bands:' \
  'regions=[algorithm to create default source/background regions]:regions:' \
  'srcreg=[stack of source regions]:srcreg:' \
  'bkgreg=[stack of background regions]:bkgreg:' \
  'bkgresp=[create background ARF and RMF]:bkgresp:(yes no)' \
  'psfmethod=[method to compute PSF fraction in regions]:psfmethod:' \
  'psffile=[PSF image file(s) for psfmethod=psffile]:file:_files' \
  'conf=[confidence interval]:conf:' \
  'binsize=[image bin size]:binsize:' \
  'rmffile=[input RMF files]:file:_files' \
  'arffile=[input ARF files]:file:_files' \
  'model=[Sherpa model expression for the source spectrum]:model:' \
  'paramvals=[model parameters]:paramvals:' \
  'absmodel=[the absorption model component]:absmodel:' \
  'absparams=[the absorption model component parameter values]:absparams:' \
  'abund=[XSPEC solar abundances]:abund:' \
  'pluginfile=[Python plugin script file name]:file:_files' \
  'fovfile=[Field Of View (FOV) file]:file:_files' \
  'asolfile=[stack of Aspect Solution Files]:file:_files' \
  'mskfile=[mask file name]:file:_files' \
  'bpixfile=[badpixel file name]:file:_files' \
  'dtffile=[dead time factors file (HRC only)]:file:_files' \
  'ecffile=[PSF Calibration file]:file:_files' \
  'marx_root=[directory where MARX is installed]:dir:_files -/' \
  'parallel=[run code in parallel]:parallel:(yes no)' \
  'nproc=[number of processors to use]:nproc:' \
  'tmpdir=[directory for temporary files]:dir:_files -/' \
  'random_seed=[initial random seed for PSF simulations]:seed:' \
  'clobber=[overwrite existing files]:clobber:(yes no)' \
  'verbose=[amount of tool chatter]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
