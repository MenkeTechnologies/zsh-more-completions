# kio-fuse: KIO FUSE bridge daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[show debug output and do not daemonize]' \
  '-f[foreground - skip D-Bus activation for testing]' && ret=0
return ret
