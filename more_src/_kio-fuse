#compdef kio-fuse
# Documentation: https://github.com/KDE/kio-fuse/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# DBus-activated FUSE daemon with a very sparse CLI surface (only -d
# and -f are documented in the README).

# kio-fuse: KIO FUSE bridge daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[show debug output and do not daemonize]' \
  '-f[foreground - skip D-Bus activation for testing]' && ret=0
return ret
