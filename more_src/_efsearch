#compdef efsearch
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/efsearch.txt
# Search for periodicities by folding over a period range and maximizing chi-square

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'cfile1=[input filename for first time series]:file:_files' \
  'window=[xronos window file for data screening]:window file:_files' \
  'epochfo=[format for epoch input]:format:(1 2 3)' \
  'sepoch=[epoch value for phase zero]:epoch:' \
  'perfo=[period format]:format:(1 2)' \
  'dper=[center of trial period range]:period:' \
  'dpdot=[period derivative value]:value:' \
  'nphase=[number of phase bins per period]:count:' \
  'nbint=[number of newbins per interval]:count:' \
  'dres=[spacing between contiguous periods]:resolution:' \
  'nper=[number of periods to search over]:count:' \
  'outfile=[output FITS filename]:output file:_files' \
  'plot=[plot chi-square versus period]:flag:(yes no)' \
  'plotdev=[plot device]:device:(/xw /ps /tek /vt)' \
  'tchat=[terminal verbosity level]:level:' \
  'lchat=[log file verbosity level]:level:' \
  'logname=[log filename]:log file:_files' \
  'clobber=[overwrite pre-existing output files]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
