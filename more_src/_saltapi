#compdef salt-api saltapi
# _saltapi — VMware/SaltStack salt-api REST API daemon exposing SaltStack functionality over HTTP (saltstack team, Python); argparse
# upstream: https://github.com/saltstack/salt

_saltapi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '-l+[log level]:l:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-level=+[log level]:l:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-file=+[log file]:file:_files' \
        '--log-file-level=+[level]:l:(all garbage trace debug profile info warning error critical quiet)' \
        '--versions-report[print versions]' \
        '-d[run in daemon mode]' \
        '--daemon[run in daemon mode]' \
        '--pid-file=+[pid file]:file:_files' \
        '-u+[user]:user:_users' \
        '--user=+[user]:user:_users' \
        '--hard-crash[crash on errors]' \
        '--skip-grains[skip grains]' \
        '--no-parse-args[no parse args]'
}

_saltapi "$@"
