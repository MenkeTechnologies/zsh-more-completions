#compdef vap
# Documentation: http://psrchive.sourceforge.net/manuals/vap/
# PSRCHIVE: output tables of parameters and derived values.

local ret=1

_arguments -s -S \
  '-h[show full list of options]' \
  '-c+[space-separated list of header parameters]:params:' \
  '-n[remove the column headings]' \
  '-r[display derived info like signal-to-noise]' \
  '*:archive:_files' && ret=0

return ret
