#compdef qt-cmake-create
# Documentation: https://doc.qt.io/qt-6/cmake-build-from-command-line.html
# Reference accessed: 2026-05-20
# Verified: `qt-cmake-create --help` output and Qt docs at URL above.
# qt-cmake-create generates a CMakeLists.txt template for a Qt project
# from the source directory passed as its sole positional argument.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:source directory:_files -/' && ret=0

return ret
