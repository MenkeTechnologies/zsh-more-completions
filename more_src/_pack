#compdef pack

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:generate an app image from source'
  'builder:operations on builders'
  'buildpack:operations on buildpacks'
  'completion:generate shell completion'
  'config:configure pack settings'
  'extension:operations on extensions'
  'inspect:inspect a builder/buildpack/image'
  'manifest:manage image manifest lists'
  'rebase:rebase an app image with a new run image'
  'report:generate a diagnostic report'
  'sbom:operations on SBOMs'
  'stack:stack helpers (deprecated)'
  'version:show pack version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--force-color[force color output]' \
  '--no-color[disable color]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--timestamps[include timestamps in logs]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pack subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (builder)
        _values 'builder action' 'create' 'inspect' 'suggest' && ret=0
        ;;
      (buildpack)
        _values 'buildpack action' \
          'inspect' 'new' 'package' 'pull' 'register' 'yank' && ret=0
        ;;
      (manifest)
        _values 'manifest action' \
          'add' 'annotate' 'create' 'inspect' 'push' 'remove' 'rm' && ret=0
        ;;
      (config)
        _values 'config action' \
          'default-builder' 'lifecycle-image' 'experimental' 'pull-policy' \
          'registries' 'run-image-mirrors' 'trusted-builders' && ret=0
        ;;
      (extension)
        _values 'extension action' 'inspect' 'package' 'pull' 'register' 'yank' && ret=0
        ;;
      (sbom)
        _values 'sbom action' 'download' && ret=0
        ;;
      (stack)
        _values 'stack action' 'suggest' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
