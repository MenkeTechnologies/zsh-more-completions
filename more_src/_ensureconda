#compdef ensureconda
# Documentation: https://github.com/conda-incubator/ensureconda/blob/main/README.md
# ensureconda: ensure a conda/mamba executable is installed, installing one if needed

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mamba[search for mamba]' \
  '--no-mamba[do not search for mamba]' \
  '--micromamba[search for micromamba, install if not present]' \
  '--no-micromamba[do not search for micromamba]' \
  '--conda[search for conda]' \
  '--no-conda[do not search for conda]' \
  '--conda-exe[search for conda.exe/conda-standalone, install if not present]' \
  '--no-conda-exe[do not search for conda.exe/conda-standalone]' \
  '--no-install[do not install conda/mamba if none discovered]' \
  '--min-conda-version=[minimum version of conda to accept]:version:' \
  '--min-mamba-version=[minimum version of mamba/micromamba to accept]:version:' && ret=0

return ret
