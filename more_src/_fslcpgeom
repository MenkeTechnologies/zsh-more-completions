#compdef fslcpgeom
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# fslcpgeom - copy image geometry from source to destination header

local ret=1

_arguments -s -S \
  '-d[do not copy image dimensions]' \
  '1:source image:_files' \
  '2:destination image:_files' && ret=0

return ret
