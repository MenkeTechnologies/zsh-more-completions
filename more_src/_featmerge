#compdef featmerge
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/featmerge.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS featmerge: merge two overlapping feature tables
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-afeatures=[first feature table]:USA:_files' \
  '-bfeatures=[second feature table]:USA:_files' \
  '-outfeat=[merged feature output file]:file:_files' \
  '-offormat=[output format]:format:(gff3 gff2 embl swiss pir refseqp)' \
  '*:feature USA:_files' && ret=0
return ret
