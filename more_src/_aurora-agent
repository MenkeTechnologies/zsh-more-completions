#compdef aurora-agent
# Documentation: https://aurora-agent-manual.nextron-systems.com/en/latest/usage/installation.html
# Aurora Agent - Nextron Sigma-based EDR agent

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install[install Aurora as a service]' \
  '--uninstall[remove the Aurora agent service]' \
  '--dashboard[install Aurora with GUI dashboard]' \
  '--status[display current agent status information]' \
  '--trace[detailed trace output with status information]' \
  '--activate-responses[enable response actions]' \
  '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
  '--json[output as JSON structs for machine ingestion]' \
  '--udp-target=[relay logs to a UDP target host:port]:host\:port' \
  '--tcp-target=[relay logs to a TCP target host:port]:host\:port' \
  '--logfile=[log file location]:file:_files' \
  '--log-size=[log rotation threshold in bytes]:bytes' \
  '--log-rotate=[number of retained log rotations]:n' \
  '--process-excludes=[file of regexes for processes to exclude]:file:_files' \
  '*:arg:_files' && ret=0

return ret
