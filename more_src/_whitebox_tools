#compdef whitebox_tools whitebox-tools
# Documentation: https://jblindsay.github.io/ghrg/WhiteboxTools/interacting_through_command_line.html
# WhiteboxTools advanced geospatial data analysis command-line runner

local ret=1

local -a _wbt_tools
_wbt_tools=(
  Aspect Slope Hillshade FillDepressions BreachDepressions
  D8Pointer D8FlowAccumulation WatershedHydrology FeaturePreservingSmoothing
  LidarInfo LidarTINGridding DevFromMeanElev ExtendVectorLines
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-l --license)'{-l,--license}'[print the whitebox-tools license]' \
  '(--cd --wd)'{--cd=,--wd=}'[change working directory; used with --run]:directory:_files -/' \
  '(-r --run)'{-r,--run=}'[run a tool; used with --cd]:tool:('"${_wbt_tools[*]}"')' \
  '--listtools=[list available tools, with descriptions; keywords may be used]:keyword:' \
  '--toolbox=[print the toolbox associated with a tool]:tool:('"${_wbt_tools[*]}"')' \
  '--toolhelp=[print the help associated with a tool]:tool:('"${_wbt_tools[*]}"')' \
  '--toolparameters=[print the parameters (json) for a specific tool]:tool:('"${_wbt_tools[*]}"')' \
  '--viewcode=[open the source code of a tool in a web browser]:tool:('"${_wbt_tools[*]}"')' \
  '-v[verbose mode; print tool output]' \
  '--version[print version information]' \
  '*:input:_files' && ret=0

return ret
