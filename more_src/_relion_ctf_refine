#compdef relion_ctf_refine
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: per-particle defocus, beamtilt, aberration and anisotropic mag refinement

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input STAR file containing the particles]:file:_files' \
  '--o=[output directory, e.g. CtfRefine/job041/]:dir:_files -/' \
  '--ctf_pad=[use larger box for CTF then downscale]:value' \
  '--diag[write out diagnostic data (slower)]' \
  '--fit_defocus[refine per-particle defocus values]' \
  '--fit_bfacs[estimate CTF B-factors]' \
  '--fit_beamtilt[refine beamtilt]' \
  '--fit_aberr[estimate symmetric aberrations]' \
  '--fit_aniso[estimate anisotropic magnification]' \
  '--j=[number of (OMP) threads]:value' \
  '--min_MG=[first micrograph index]:value' \
  '--max_MG=[last micrograph index (default all)]:value' \
  '--debug[write debugging data]' \
  '--verb=[verbosity]:value' \
  '*:file:_files' && ret=0

return ret
