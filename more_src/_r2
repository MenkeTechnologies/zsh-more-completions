#compdef r2 radare2

# Zsh completion for radare2 (r2)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[set architecture to assemble/disassemble]:arch:' \
  '-b+[set cpu register size (16, 32, 64)]:bits:(16 32 64)' \
  '-B+[set base address for PIE binaries]:baddr:' \
  '-c+[execute radare command]:command:' \
  '-d[debug the executable]' \
  '-e+[evaluate config var]:key=value:' \
  '-f+[set block size]:blocksize:' \
  '-F+[force to use that bin plugin]:format:' \
  '-i+[run script file]:script:_files' \
  '-k+[set asm.os (kernel)]:kernel:(linux windows darwin freebsd netbsd openbsd)' \
  '-l+[load plugin file]:plugin:_files' \
  '-m+[map file at given address]:addr:' \
  '-n[do not run any analysis]' \
  '-N[do not load user settings and scripts]' \
  '-p+[use project]:project:' \
  '-q[quiet mode (no prompt) and quit after -i]' \
  '-Q[quiet mode (no prompt) and quit faster]' \
  '-s+[initial seek]:addr:' \
  '-S[start r2 in sandbox mode]' \
  '(-)-v[show radare2 version]' \
  '-w[open file in write mode]' \
  '-z[search for strings in data sections]' \
  '-0[print \x00 after init and every command]' \
  '*:file:_files' && ret=0

return ret
