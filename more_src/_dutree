#compdef dutree

# Zsh completion for dutree - Disk usage tree viewer

_arguments \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-d --depth)'{-d,--depth}'[maximum depth to display]:depth:' \
  '*'{-e,--exclude}'[exclude matching pattern]:pattern:' \
  '(-x --exclude-hidden)'{-x,--exclude-hidden}'[exclude hidden files]' \
  '(-s --summary)'{-s,--summary}'[show only the total for each argument]' \
  '(-a --aggr)'{-a,--aggr}'[aggregate entries smaller than size]:size:' \
  '(-f --follow)'{-f,--follow}'[follow symbolic links]' \
  '(-b --bytes)'{-b,--bytes}'[display sizes in bytes]' \
  '(-c --no-colors)'{-c,--no-colors}'[disable colorized output]' \
  '--skip-total[skip the total line]' \
  '*:path:_files'
