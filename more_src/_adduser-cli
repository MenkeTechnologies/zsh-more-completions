#compdef adduser-cli addgroup-cli
# _adduser-cli — Debian adduser/addgroup convenient interactive user/group commands CLI alias (debian team, Perl); custom argparse
# upstream: https://salsa.debian.org/debian/adduser

_adduser-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--conf=+[config file]:file:_files' \
        '--allow-bad-names[allow bad names]' \
        '--allow-all-names[allow all names]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '--force-badname[force bad name]' \
        '--no-create-home[no create home]' \
        '--system[create system user]' \
        '--shell=+[shell]:str:' \
        '--gid=+[gid]:n:' \
        '--ingroup=+[group]:_groups' \
        '--add-extra-groups[add extra groups]' \
        '--uid=+[uid]:n:' \
        '--firstuid=+[uid]:n:' \
        '--lastuid=+[uid]:n:' \
        '--firstgid=+[gid]:n:' \
        '--lastgid=+[gid]:n:' \
        '--disabled-password[no set password]' \
        '--disabled-login[no enable login]' \
        '--encrypt-home[encrypt home]' \
        '--gecos=+[gecos]:str:' \
        '--group[treat as group]' \
        '--home=+[home dir]:dir:_files -/' \
        '--no-create-home[no create home]' \
        '--allow-conflict-with-sudoers[allow conflict]' \
        '*:user/group:_users'
}

_adduser-cli "$@"
