#compdef sumo-bandstats
# Documentation: https://smtg-bham.github.io/sumo/sumo-bandstats.html
# sumo effective mass and band statistics tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filenames)'{-f,--filenames}'[one or more vasprun.xml files to plot]:files:_files' \
  '(-n --nonparabolic)'{-n,--nonparabolic}'[use a nonparabolic model to fit the effective masses]' \
  '(-s --sample-points)'{-s,--sample-points}'[number of k-points to sample in fitting]:points:' && ret=0

return ret
