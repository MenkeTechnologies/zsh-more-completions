#compdef rbd

# Zsh completion for rbd - RADOS Block Device management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new image'
  'clone:clone an image snapshot'
  'flatten:flatten a cloned image'
  'resize:resize an image'
  'rm:delete an image'
  'trash:manage images in trash'
  'ls:list images in a pool'
  'du:show image disk usage'
  'info:show information about an image'
  'diff:print extents that differ'
  'export:export image to a file'
  'import:import image from a file'
  'copy:copy image'
  'deep-copy:deep copy image'
  'rename:rename image'
  'snap:manage image snapshots'
  'map:map an image to a block device'
  'unmap:unmap a block device'
  'showmapped:show mapped block devices'
  'device:manage mapped devices'
  'feature:manage image features'
  'lock:manage image locks'
  'mirror:manage image mirroring'
  'group:manage image groups'
  'bench:run benchmarks'
  'status:show image status'
  'config:manage image-level config overrides'
  'namespace:manage namespaces'
  'pool:manage pool-level settings'
  'perf:manage image performance counters'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '--id=[client id]:id' \
  '(-n --name)'{-n,--name}'[client name]:name' \
  '-c[ceph configuration file]:file:_files' \
  '--keyring=[keyring file]:file:_files' \
  '-m[monitor addresses]:address' \
  '(-p --pool)'{-p,--pool}'[pool name]:pool' \
  '--namespace=[namespace]:namespace' \
  '--image=[image name]:image' \
  '--dest-pool=[destination pool name]:pool' \
  '--image-format=[image format]:format:(1 2)' \
  '--image-feature=[image feature]:feature:(layering striping exclusive-lock object-map fast-diff deep-flatten journaling)' \
  '--image-shared[allow multiple clients to use image simultaneously]' \
  '--stripe-unit=[stripe unit size]:size' \
  '--stripe-count=[number of objects in a stripe]:count' \
  '--data-pool=[data pool for erasure-coded images]:pool' \
  '--pretty-format[pretty format output]' \
  '--no-progress[do not show progress bar]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rbd command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --size)'{-s,--size}'[image size in MB]:size' \
          '--object-size=[object size]:size' \
          '--image-feature=[image feature]:feature:(layering striping exclusive-lock object-map fast-diff deep-flatten journaling)' \
          '--image-shared[allow multiple clients]' \
          '--stripe-unit=[stripe unit size]:size' \
          '--stripe-count=[stripe count]:count' \
          '--data-pool=[EC data pool]:pool' \
          '--thick-provision[allocate all space upfront]' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (rm)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--no-progress[do not show progress]' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (ls)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-l --long)'{-l,--long}'[long listing format]' \
          '--format=[output format]:format:(plain json xml)' \
          '1:pool name' && ret=0
        ;;
      (info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(plain json xml)' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (resize)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-s --size)'{-s,--size}'[new image size in MB]:size' \
          '--allow-shrink[allow shrinking]' \
          '--no-progress[do not show progress]' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (export)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--no-progress[do not show progress]' \
          '--export-format=[export format]:format:(1 2)' \
          '1:source image (pool/image)' \
          '2:destination file:_files' && ret=0
        ;;
      (import)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--no-progress[do not show progress]' \
          '--dest-pool=[destination pool]:pool' \
          '--image-format=[image format]:format:(1 2)' \
          '--export-format=[export format]:format:(1 2)' \
          '1:source file:_files' \
          '2:destination image' && ret=0
        ;;
      (copy|deep-copy)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--no-progress[do not show progress]' \
          '1:source image (pool/image)' \
          '2:destination image (pool/image)' && ret=0
        ;;
      (rename)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:source image (pool/image)' \
          '2:destination image (pool/image)' && ret=0
        ;;
      (map)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-o[map options]:options' \
          '--read-only[map read-only]' \
          '--exclusive[disable automatic exclusive lock transitions]' \
          '1:image spec (pool/image@snap)' && ret=0
        ;;
      (unmap)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-o[unmap options]:options' \
          '1:device or image:_files -g "/dev/rbd*"' && ret=0
        ;;
      (showmapped)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(plain json xml)' && ret=0
        ;;
      (du)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(plain json xml)' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (bench)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--io-type=[IO type]:type:(read write readwrite rw)' \
          '--io-size=[IO size]:size' \
          '--io-threads=[number of IO threads]:count' \
          '--io-total=[total IO size]:size' \
          '--io-pattern=[IO pattern]:pattern:(seq rand)' \
          '1:image spec (pool/image)' && ret=0
        ;;
      (snap)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:subcommand:(create rm ls protect unprotect rollback purge rename)' \
          '2:image spec (pool/image@snap)' && ret=0
        ;;
      (clone)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--image-feature=[image feature]:feature:(layering striping exclusive-lock object-map fast-diff deep-flatten journaling)' \
          '1:parent snapshot (pool/image@snap)' \
          '2:child image (pool/image)' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(plain json xml)' \
          '1:image spec (pool/image)' && ret=0
        ;;
    esac
    ;;
esac

return ret
