#compdef mongo-connector
# Documentation: https://rueckstiess.github.io/mtools/
# real-time sync pipeline from a MongoDB cluster to target systems

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--version[show version]' \
  '(-m --main)'{-m,--main}'=[main address, a host:port pair (mongos for sharded clusters)]:address:_hosts' \
  '(-o --oplog-ts)'{-o,--oplog-ts}'=[file storing oplog progress timestamps]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '(-w --logfile)'{-w,--logfile}'=[log all output to the specified file]:file:_files' \
  '--stdout[log all output to STDOUT rather than a logfile]' \
  '--no-dump[do not read entire namespace if oplog-ts points to empty file]' \
  '--only-dump[do not read the oplog after namespaces dumped]' \
  '--batch-size=[update oplog-ts file every N documents]:n' \
  '(-i --fields)'{-i,--fields}'=[comma-separated fields to export into new document]:fields' \
  '(-e --exclude_fields)'{-e,--exclude_fields}'=[comma-separated fields to exclude]:fields' \
  '(-n --namespace-set)'{-n,--namespace-set}'=[namespaces to consider]:namespaces' \
  '(-x --exclude-namespace-set)'{-x,--exclude-namespace-set}'=[namespaces to exclude]:namespaces' \
  '(-g --dest-namespace-set)'{-g,--dest-namespace-set}'=[destination namespace mapping]:namespaces' \
  '--gridfs-set=[GridFS namespaces to consider]:namespaces' \
  '(-d --doc-manager)'{-d,--doc-manager}'=[path to doc manager file]:file:_files' \
  '(-t --target-url)'{-t,--target-url}'=[URL to each target system]:url' \
  '(-u --unique-key)'{-u,--unique-key}'=[MongoDB field serving as unique key for target]:field' \
  '--auto-commit-interval=[seconds between Doc Manager commits]:seconds' \
  '(-a --admin-username)'{-a,--admin-username}'=[username of admin user for authentication]:user' \
  '(-p --password)'{-p,--password}'=[password for authentication]:password' \
  '(-f --password-file)'{-f,--password-file}'=[file storing password for authentication]:file:_files' \
  '(-c --config-file)'{-c,--config-file}'=[JSON file to load configurations from]:file:_files' \
  '--ssl-certfile=[path to certificate for local connection to MongoDB]:file:_files' \
  '--ssl-keyfile=[path to private key for SSL certificate]:file:_files' \
  '--ssl-ca-certs=[path to concatenated CA certificates]:file:_files' \
  '--ssl-certificate-policy=[policy for validating SSL certificates]:policy:(required optional ignored)' \
  '(-s --enable-syslog)'{-s,--enable-syslog}'[enable syslog logging]' \
  '--syslog-host=[syslog host address or Unix socket path]:host' \
  '--syslog-facility=[syslog facility designation]:facility' \
  '--logfile-when=[rotation interval type]:when' \
  '--logfile-interval=[rotation intervals before rotation occurs]:n' \
  '--logfile-backups=[number of log files to keep after rotation]:n' \
  '--log-format=[custom log file format]:format' \
  '--continue-on-error[continue upserting documents during dump despite errors]' \
  '--tz-aware[make all dates and times timezone-aware]' && ret=0

return ret
