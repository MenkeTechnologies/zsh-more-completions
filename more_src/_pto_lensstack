#compdef pto_lensstack
# Documentation: https://wiki.panotools.org/Pto_lensstack
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pto_lensstack: modify lens/stack assignment in Hugin .pto projects
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto filename]:file:_files -g "*.pto"' \
  '--new-lens=[assign a new lens to image list (i0,i1,...)]:images:' \
  '--new-stack=[assign a new stack to image list (i0,i1,...)]:images:' \
  '--change-lens=[modify lens assignments for image list (i0,i1,...)]:images:' \
  '--change-stack=[modify stack assignments for image list (i0,i1,...)]:images:' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
