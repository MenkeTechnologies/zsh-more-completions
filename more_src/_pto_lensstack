#compdef pto_lensstack

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output project file]:file:_files -g "*.pto"' \
  '-n+[image number, format i1,i2,...]:list:' \
  '-c[copy lens]' \
  '-a[assign new lens]' \
  '-s[break into stack]' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
