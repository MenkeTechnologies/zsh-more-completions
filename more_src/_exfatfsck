#compdef exfatfsck fsck.exfat
# _exfatfsck — Andrew Nayenko exfat-utils exfatfsck CLI for the FUSE-based exFAT file-system consistency checker validating boot region cluster heap allocation file directory entries upcase table optional repair (relan team, C); getopt
# upstream: https://github.com/relan/exfat

_exfatfsck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-r[repair]' \
        '--repair[repair]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '-n[no confirm]' \
        '--no[no confirm]' \
        '-p[preen mode]' \
        '--preen[preen mode]' \
        '-a[auto repair]' \
        '--auto-repair[auto repair]' \
        '*:device:_files'
}

_exfatfsck "$@"
