#compdef guile
# Documentation: guile --help (GNU Guile Scheme)
# Source: GNU Guile Scheme interpreter / extension language.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '-s+[load source code from FILE and exit]:file:_files -g "*.(scm|ss)"' \
    '-c+[evaluate expression and exit]:expr:' \
    '*-L+[add directory to module load path]:dir:_files -/' \
    '*-C+[add directory for compiled files]:dir:_files -/' \
    '*-x+[add load extension]:extension:' \
    '*-l+[load source code from FILE]:file:_files' \
    '-e+[apply FUNCTION to command-line args]:function:' \
    '--language=[input language]:lang:(scheme elisp ecmascript brainfuck)' \
    '-ds[do -s script at this point]' \
    '(--debug --no-debug)--debug[debugging VM engine]' \
    '(--debug --no-debug)--no-debug[normal VM engine]' \
    '(--auto-compile --no-auto-compile --fresh-auto-compile)--auto-compile[compile sources automatically]' \
    '(--auto-compile --no-auto-compile --fresh-auto-compile)--no-auto-compile[disable auto-compile]' \
    '(--auto-compile --no-auto-compile --fresh-auto-compile)--fresh-auto-compile[invalidate auto-compile cache]' \
    '--listen=-[REPL listen port or path]::port:' \
    '--statprof=-[profile using statprof]::style:' \
    '-q[inhibit user init file]' \
    '--use-srfi=[load SRFI numbers (CSV)]:numbers:' \
    '(--r6rs --r7rs)--r6rs[Guile R6RS environment]' \
    '(--r6rs --r7rs)--r7rs[Guile R7RS environment]' \
    '*:scheme file:_files -g "*.(scm|ss)"' \
    && ret=0

return ret
