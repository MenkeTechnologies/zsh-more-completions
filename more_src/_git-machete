#compdef git-machete

_git-machete() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        {-h,--help}'[Print help information]'
        {-v,--verbose}'[Log the executed git commands]'
        '--debug[Log detailed diagnostic info]'
    )

    _arguments -C \
        $global_opts \
        '(-): :->command' \
        '(-)*:: :->option-or-argument' && ret=0

    case $state in
        (command)
            local -a commands
            commands=(
                'add:Add a branch to the tree of branch dependencies'
                'advance:Fast-forward merge into the current branch from its downstream'
                'anno:Manage custom annotations'
                'clean:Remove unmanaged branches'
                'completion:Generate shell completion scripts'
                'delete-unmanaged:Delete branches not present in the branch layout file'
                'diff:Diff current working directory against the fork point'
                'discover:Automatically discover the tree of branch dependencies'
                'edit:Edit the branch layout file'
                'file:Display the location of the branch layout file'
                'fork-point:Display or override the fork point of a branch'
                'github:GitHub integration subcommands'
                'go:Check out the branch relative to the current branch'
                'help:Display help for a command'
                'is-managed:Check if a branch is managed'
                'list:List branches matching a category'
                'log:Log the part of history specific to the given branch'
                'reapply:Rebase the current branch onto its fork point'
                'show:Show the branch relative to the current branch'
                'slide-out:Slide out the current branch from the dependency tree'
                'squash:Squash the unique history of the current branch'
                'status:Display the tree of branch dependencies'
                'traverse:Walk through the branches and rebase/push/pull each one'
                'update:Rebase the current branch onto its upstream'
                'version:Display the version'
            )
            _describe -t commands 'git-machete command' commands && ret=0
            ;;
        (option-or-argument)
            curcontext=${curcontext%:*:*}:git-machete-$words[1]:
            case $words[1] in
                (status)
                    _arguments -s -S \
                        $global_opts \
                        {-L,--list-commits}'[List commits introduced on each branch]' \
                        {-l,--list-commits-with-hashes}'[List commits with hashes introduced on each branch]' \
                        '--color[Colorize output]:color:(auto always never)' \
                        '--no-detect-squash-merges[Do not detect squash merges]' && ret=0
                    ;;
                (traverse)
                    _arguments -s -S \
                        $global_opts \
                        {-F,--fetch}'[Fetch from the remote before traversing]' \
                        {-l,--list-commits}'[List commits during traversal]' \
                        {-M,--merge}'[Merge instead of rebase]' \
                        '--no-detect-squash-merges[Do not detect squash merges]' \
                        '--no-edit-merge[Do not open editor during merge]' \
                        '--no-interactive-rebase[Do not use interactive rebase]' \
                        '--push[Push branches after updating]' \
                        '--push-untracked[Push untracked branches as well]' \
                        '--start-from[Where to start traversal]:start:(here root first-root)' \
                        '--return-to[Where to return after traversal]:return:(here nearest-remaining stay)' \
                        {-w,--whole}'[Traverse the entire tree]' \
                        {-y,--yes}'[Answer yes to all questions]' && ret=0
                    ;;
                (discover)
                    _arguments -s -S \
                        $global_opts \
                        '--checked-out-since[Only consider branches checked out since the given date]:date:' \
                        {-l,--list-commits}'[List commits during discovery]' \
                        '--roots[Comma-separated list of root branches]:roots:' && ret=0
                    ;;
                (slide-out)
                    _arguments -s -S \
                        $global_opts \
                        '--delete[Delete the slid-out branch]' \
                        '--down-fork-point[Override fork point of the downstream branch]:revision:' \
                        {-M,--merge}'[Merge instead of rebase]' \
                        '--no-edit-merge[Do not open editor during merge]' \
                        '--no-interactive-rebase[Do not use interactive rebase]' \
                        '-n[Do not ask for confirmation]' \
                        '*:branch:' && ret=0
                    ;;
                (go)
                    _arguments -s -S \
                        $global_opts \
                        '1:direction:(up down next prev root first last)' && ret=0
                    ;;
                (show)
                    _arguments -s -S \
                        $global_opts \
                        '1:direction:(up down next prev root first last current)' && ret=0
                    ;;
                (list)
                    _arguments -s -S \
                        $global_opts \
                        '1:category:(addable childless managed slidable slidable-after unmanaged with-overridden-fork-point)' && ret=0
                    ;;
                (add)
                    _arguments -s -S \
                        $global_opts \
                        '--onto[Specify the upstream branch]:branch:' \
                        '--as-root[Add the branch as a root]' \
                        '--yes[Do not ask for confirmation]' \
                        ':branch:' && ret=0
                    ;;
                (diff)
                    _arguments -s -S \
                        $global_opts \
                        '--stat[Show diffstat instead of full diff]' \
                        ':branch:' && ret=0
                    ;;
                (fork-point)
                    _arguments -s -S \
                        $global_opts \
                        '--inferred[Display the inferred fork point]' \
                        '--override-to[Override the fork point]:revision:' \
                        '--override-to-inferred[Override to the inferred fork point]' \
                        '--override-to-parent[Override to the parent branch]' \
                        '--unset-override[Unset the fork point override]' \
                        ':branch:' && ret=0
                    ;;
                (clean)
                    _arguments -s -S \
                        $global_opts \
                        '--checkout-my-github-prs[Check out open GitHub PRs by me]' \
                        '--delete-unmanaged[Delete unmanaged branches]' \
                        {-y,--yes}'[Do not ask for confirmation]' && ret=0
                    ;;
                (update)
                    _arguments -s -S \
                        $global_opts \
                        {-M,--merge}'[Merge instead of rebase]' \
                        '--no-edit-merge[Do not open editor during merge]' \
                        '--no-interactive-rebase[Do not use interactive rebase]' \
                        {-f,--fork-point}'[Override fork point]:revision:' && ret=0
                    ;;
                (advance|anno|completion|delete-unmanaged|edit|file|github|help|is-managed|log|reapply|squash|version)
                    _arguments -s -S $global_opts '*:arg:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_git-machete "$@"
