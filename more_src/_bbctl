# WHAT IT IS
#   bbctl is "a tool for running self-hosted bridges with the Beeper Matrix
#   server" — Beeper's official Go CLI for managing 3rd-party-network-to-
#   Matrix bridges hosted alongside a Beeper account.  It authenticates with
#   the Beeper homeserver (production or staging), generates appservice
#   registration files for both 3rd-party and official Beeper bridges,
#   manages the lifecycle of self-hosted bridge processes (download +
#   compile + run + local-dev override), proxies appservice websocket
#   traffic to a local HTTP server, and exposes whoami/logout/delete admin
#   operations.  Authentication uses either Beeper Desktop's existing login,
#   email magic-link, or username+password.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/bbctl/main.go urfave/cli/v2 app +
#                       cmd/bbctl/*.go per-Command Flags blocks)
#   bbctl [GLOBAL OPTIONS] <command> [command options]
#
#   Global flags:
#     -e, --env <ENV>            Beeper environment (env BEEPER_ENV,
#                                default "prod")
#     -c, --config <PATH>        Path to config (env BBCTL_CONFIG, default
#                                $XDG_CONFIG_HOME/bbctl/config.json)
#     --color <WHEN>             enable/disable colors and hyperlinks
#                                (always | never | auto;  env BBCTL_COLOR,
#                                default "auto")
#
#   Commands & aliases  (Aliases verbatim from each Command.Aliases slice):
#     login (l)                  Log into the Beeper server
#                                  --email <EMAIL>      account email
#                                  --no-desktop         skip Beeper Desktop
#                                                       login lookup
#     login-password (p)         Log in with username+password
#                                  -u, --username <U>
#                                  -p, --password <P>
#     logout                     Log out from the Beeper server
#                                  -f, --force          drop token even on
#                                                       failed logout API
#     register (r) <BRIDGE>      Register 3rd party bridge, print appservice
#                                registration file
#                                  -a, --address <URL>  push-event https URL
#                                                       (omit for websocket)
#                                  -o, --output <FILE>  save reg file
#                                  -j, --json           emit raw JSON
#                                  -g, --get            only get existing,
#                                                       don't create
#                                  -f, --force          allow non-sh- prefix
#                                  --no-state           skip state update
#     delete (d) <BRIDGE>        Delete bridge and rooms on Beeper server
#                                  -l, --local-dev      also delete local db
#                                                       and config
#                                  -f, --force          force delete
#     whoami (w)                 Get info about yourself
#                                  -r, --raw            raw JSON instead of
#                                                       pretty-print
#     config (c) <BRIDGE>        Generate config for an official Beeper bridge
#                                  -t, --type <T>       bridge type
#                                  -p, --param <K=V>    config option
#                                                       (repeatable)
#                                  -o, --output <FILE>  save config file
#                                  -f, --force          allow non-sh- prefix
#                                  --no-state           skip state update
#     run <BRIDGE>               Run an official Beeper bridge
#                                  -t, --type <T>       bridge type
#                                  -p, --param <K=V>    config option
#                                                       (repeatable)
#                                  -n, --no-update      don't update bridge
#                                  -l, --local-dev      use CWD bridge
#                                  --compile            clone + compile
#                                  -c, --config-file <FILE>
#                                                       config save path
#                                  --no-override-config keep existing config
#                                  --custom-startup-command <CMD>
#                                                       custom startup script
#                                  -f, --force          allow non-sh- prefix
#                                  --no-state           skip state update
#     proxy (x)                  Proxy appservice websocket to local HTTP
#                                  -r, --registration <FILE>
#                                                       reg file with
#                                                       as_token, hs_token,
#                                                       local appservice URL
#
# AXIS / CORPUS POSITION
#   Direct dependency on maunium.net/go/mautrix v0.26.3 declared in go.mod
#   — the canonical Go Matrix client library maintained by Tulir Asokan
#   (tulir / mautrix.net), under the github.com/mautrix/go GitHub mirror.
#   Used in cmd/bbctl/main.go via:
#     mautrix.DefaultUserAgent = fmt.Sprintf("bbctl/%s ...", Version, ...)
#     client, err := mautrix.NewClient(homeserverURL, userID, accessToken)
#   Verified via:
#     gh api repos/beeper/bridge-manager/contents/go.mod
#       → maunium.net/go/mautrix v0.26.3
#   This entry is the Go=113 leader bump that continues Axis 58
#   (Matrix Federated Chat Protocol Library) opened at R821 with
#   Rust=matrix-sdk 0.16 (arcuru/chaz).
#
#   No completion for `bbctl` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bbctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-e --env)'{-e+,--env=}'[Beeper environment (env BEEPER_ENV, default prod)]:env:(prod staging dev)' \
        '(-c --config)'{-c+,--config=}'[config file path (env BBCTL_CONFIG)]:config file:_files -g "*.json"' \
        '--color=[enable/disable colors and hyperlinks (env BBCTL_COLOR)]:when:(auto always never)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_bbctl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login|l)              _bbctl_login            && ret=0 ;;
                login-password|p)     _bbctl_login_password   && ret=0 ;;
                logout)               _bbctl_logout           && ret=0 ;;
                register|r)           _bbctl_register         && ret=0 ;;
                delete|d)             _bbctl_delete           && ret=0 ;;
                whoami|w)             _bbctl_whoami           && ret=0 ;;
                config|c)             _bbctl_config           && ret=0 ;;
                run)                  _bbctl_run              && ret=0 ;;
                proxy|x)              _bbctl_proxy            && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_bbctl_commands] )) ||
_bbctl_commands() {
    local -a commands
    commands=(
        'login:log into the Beeper server'
        'l:log into the Beeper server'
        'login-password:log in with username and password'
        'p:log in with username and password'
        'logout:log out from the Beeper server'
        'register:register a 3rd party bridge and print the appservice registration file'
        'r:register a 3rd party bridge'
        'delete:delete a bridge and all associated rooms on the Beeper servers'
        'd:delete a bridge'
        'whoami:get info about yourself'
        'w:get info about yourself'
        'config:generate a config for an official Beeper bridge'
        'c:generate a config for an official Beeper bridge'
        'run:run an official Beeper bridge'
        'proxy:proxy appservice websocket to a local appservice HTTP server'
        'x:proxy appservice websocket to a local appservice HTTP server'
    )
    _describe -t commands 'bbctl command' commands
}

(( $+functions[_bbctl_login] )) ||
_bbctl_login() {
    _arguments \
        '--email=[Beeper account email to log in with]:email:' \
        '--no-desktop[skip checking for an existing Beeper Desktop login]' \
        '(- *)'{-h,--help}'[help for login]'
}

(( $+functions[_bbctl_login_password] )) ||
_bbctl_login_password() {
    _arguments \
        '(-u --username)'{-u+,--username=}'[Beeper username to log in as]:username:' \
        '(-p --password)'{-p+,--password=}'[Beeper password to log in with]:password:' \
        '(- *)'{-h,--help}'[help for login-password]'
}

(( $+functions[_bbctl_logout] )) ||
_bbctl_logout() {
    _arguments \
        '(-f --force)'{-f,--force}'[remove access token even if logout API call fails]' \
        '(- *)'{-h,--help}'[help for logout]'
}

(( $+functions[_bbctl_register] )) ||
_bbctl_register() {
    _arguments \
        '(-a --address)'{-a+,--address=}'[https URL where the Beeper server will push events (omit for websocket)]:address url:_urls' \
        '(-o --output)'{-o+,--output=}'[path to save generated registration file to]:output file:_files' \
        '(-j --json)'{-j,--json}'[return all data as JSON instead of YAML]' \
        '(-g --get)'{-g,--get}'[only get existing registration, do not create]' \
        '(-f --force)'{-f,--force}'[force register a bridge without the sh- prefix (dangerous)]' \
        '--no-state[do not send a bridge state update (dangerous)]' \
        '(- *)'{-h,--help}'[help for register]' \
        ':bridge name:'
}

(( $+functions[_bbctl_delete] )) ||
_bbctl_delete() {
    _arguments \
        '(-l --local-dev)'{-l,--local-dev}'[also delete bridge database/config from current working directory]' \
        '(-f --force)'{-f,--force}'[force delete even if not self-hosted or does not exist]' \
        '(- *)'{-h,--help}'[help for delete]' \
        ':bridge name:'
}

(( $+functions[_bbctl_whoami] )) ||
_bbctl_whoami() {
    _arguments \
        '(-r --raw)'{-r,--raw}'[raw JSON output instead of pretty-printed bridge status]' \
        '(- *)'{-h,--help}'[help for whoami]'
}

(( $+functions[_bbctl_config] )) ||
_bbctl_config() {
    _arguments \
        '(-t --type)'{-t+,--type=}'[the type of bridge being registered]:bridge type:' \
        '*'{-p+,--param=}'[set a bridge-specific config option (repeatable, key=value format)]:key=value:' \
        '(-o --output)'{-o+,--output=}'[path to save generated config file to]:output file:_files' \
        '(-f --force)'{-f,--force}'[force register a bridge without the sh- prefix (dangerous)]' \
        '--no-state[do not send a bridge state update (dangerous)]' \
        '(- *)'{-h,--help}'[help for config]' \
        ':bridge name:'
}

(( $+functions[_bbctl_run] )) ||
_bbctl_run() {
    _arguments \
        '(-t --type)'{-t+,--type=}'[the type of bridge to run]:bridge type:' \
        '*'{-p+,--param=}'[set a bridge-specific config option (repeatable, key=value format)]:key=value:' \
        '(-n --no-update)'{-n,--no-update}'[do not update the bridge even if out of date]' \
        '(-l --local-dev)'{-l,--local-dev}'[run the bridge in current working directory (developer mode)]' \
        '--compile[clone bridge repo and compile locally instead of downloading CI binary]' \
        '(-c --config-file)'{-c+,--config-file=}'[file name to save config to (mostly for local-dev)]:config file:_files' \
        '--no-override-config[do not override existing config file (default true with --local-dev)]' \
        '--custom-startup-command=[custom binary or script for startup (disables update checks)]:startup command:' \
        '(-f --force)'{-f,--force}'[force register a bridge without the sh- prefix (dangerous)]' \
        '--no-state[do not send a bridge state update (dangerous)]' \
        '(- *)'{-h,--help}'[help for run]' \
        ':bridge name:'
}

(( $+functions[_bbctl_proxy] )) ||
_bbctl_proxy() {
    _arguments \
        '(-r --registration)'{-r+,--registration=}'[path to registration file (as_token/hs_token/local appservice URL)]:registration file:_files -g "*.(yaml|yml|json)"' \
        '(- *)'{-h,--help}'[help for proxy]'
}

_bbctl "$@"
