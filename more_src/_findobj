#compdef findobj
# Documentation: http://www.starlink.ac.uk/docs/sun139.htx/sun139.html
# CCDPACK: Locate and centroid image features

local ret=1

_arguments -s -S \
  'IN=[input images to be searched]:in:_files' \
  'OUTLIST=[output position list files]:outlist:_files' \
  'MINPIX=[minimum pixels in a detection]:minpix:' \
  'AUTOTHRESH=[determine threshold automatically]:autothresh:(TRUE FALSE)' \
  'BINFRAC=[fraction of histogram bins to populate]:binfrac:' \
  'LOGFILE=[log file name]:logfile:_files' \
  'LOGTO=[where to write log information]:logto:(TERMINAL LOGFILE BOTH NEITHER)' \
  'NAMELIST=[file to record output list names]:namelist:_files' \
  'NSIGMA=[detection threshold in sigma]:nsigma:' \
  'OVERRIDE=[continue despite errors]:override:(TRUE FALSE)' \
  'OVERSAMP=[oversampling factor]:oversamp:' \
  'PERCENTILE=[background percentile point]:percentile:' \
  'THRESH=[detection threshold value]:thresh:' \
  'TOUCH=[touch image edges allowed]:touch:(TRUE FALSE)' \
  'USEPER=[use a percentile for the threshold]:useper:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
