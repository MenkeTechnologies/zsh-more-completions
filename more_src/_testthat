#compdef testthat testthat-cli
# _testthat — Hadley Wickham testthat R unit testing framework CLI alias (Hadley Wickham / r-lib, R); custom argparse via R wrapper
# upstream: https://github.com/r-lib/testthat

_testthat() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--path=+[test path]:dir:_files -/' \
        '-p+[test path]:dir:_files -/' \
        '--filter=+[test filter regex]:str:' \
        '-f+[test filter regex]:str:' \
        '--reporter=+[reporter]:r:(default summary minimal location progress junit teamcity check fail stop silent)' \
        '-r+[reporter]:r:(default summary minimal location progress junit teamcity check fail stop silent)' \
        '--package=+[package]:str:' \
        '--env=+[environment]:str:' \
        '--stop-on-failure[stop on failure]' \
        '--stop-on-warning[stop on warning]' \
        '--load-helpers[load helpers]' \
        '--no-helpers[no helpers]' \
        '--load-package=+[load package]:str:' \
        '--rng-version=+[RNG version]:str:' \
        '--seed=+[seed]:n:' \
        '*:test-file:_files -g "test-*.R *.R"'
}

_testthat "$@"
