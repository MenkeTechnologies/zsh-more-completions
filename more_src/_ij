#compdef ij
# Documentation: https://github.com/hypre-space/hypre/blob/master/src/test/ij.c
# hypre IJ linear-system interface test driver (BoomerAMG / Krylov solvers)

local ret=1

_arguments -s -S \
  '-help[print usage and exit]' \
  '-fromfile[read parcsr matrix from text file]:file:_files' \
  '-frombinfile[read parcsr matrix from binary file]:file:_files' \
  '-laplacian[build 7pt 3D Laplacian]' \
  '-9pt[build 9pt 2D Laplacian]' \
  '-27pt[build 27pt 3D Laplacian]' \
  '-125pt[build 125pt 3D Laplacian]' \
  '-difconv[build convection-diffusion operator]' \
  '-rotate[build rotated 7pt anisotropic operator]' \
  '-n[problem size per direction]:nx ny nz' \
  '-P[processor topology]:Px Py Pz' \
  '-c[anisotropy coefficients]:cx cy cz' \
  '-a[convection coefficients]:ax ay az' \
  '-rhsfromfile[read rhs from text file]:file:_files' \
  '-rhsrand[generate random rhs]' \
  '-rhsone[set rhs to all ones]' \
  '-rhszero[set rhs to all zeros]' \
  '-xisone[set initial solution to all ones]' \
  '-solver[solver id]:id' \
  '-tol[relative convergence tolerance]:tol' \
  '-atol[absolute convergence tolerance]:atol' \
  '-max_iter[maximum number of iterations]:n' \
  '-k[Krylov dimension / GMRES restart]:dim' \
  '-w[AMG relaxation weight]:weight' \
  '-th[AMG strength threshold]:theta' \
  '-interptype[AMG interpolation type]:type' \
  '-agg_nl[number of aggressive coarsening levels]:n' \
  '-hmis[use HMIS coarsening]' \
  '-pmis[use PMIS coarsening]' \
  '-cljp[use CLJP coarsening]' \
  '-falgout[use Falgout coarsening]' \
  '-ruge[use Ruge coarsening]' \
  '-rlx[AMG relaxation type]:type' \
  '-ns[number of relaxation sweeps]:n' \
  '-mu[AMG cycle type (1=V,2=W)]:mu' \
  '-ilu_type[ILU smoother type]:type' \
  '-mxrs[max row sum]:val' \
  '-dt[pseudo time-step / shift]:dt' \
  '-test_ij[test IJ matrix/vector interface]' \
  '*:file:_files' && ret=0

return ret
