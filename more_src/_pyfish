#compdef pyfish
# _pyfish — simple CLI UI for UCI chess engines (bugsduggan/pyfish)
# upstream: https://github.com/bugsduggan/pyfish
# Flags from pyfish.py (argparse).

_pyfish() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--debug[print all engine output]' \
        '(-i --interactive)'{-i+,--interactive=}'[play interactively (white or black)]:side:(w b)' \
        '(-b --book)'{-b+,--book=}'[Polyglot book file]:file:_files -g "*.bin"' \
        '(-e --engine)'{-e+,--engine=}'[UCI engine binary]:file:_files' \
        '(-d --display)'{-d,--display}'[display board state]' \
        '*:move:'
}

_pyfish "$@"
