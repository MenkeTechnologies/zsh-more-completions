#compdef sumo-phonon-bandplot
# Documentation: https://smtg-bham.github.io/sumo/sumo-phonon-bandplot.html
# sumo phonon band structure plotting tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f,--filename}'[FORCE_SETS, FORCE_CONSTANTS, or band.yaml file]:file:_files' \
  '(-p --prefix)'{-p,--prefix}'[prefix for generated output files]:prefix:' \
  '(-d --directory)'{-d,--directory}'[output directory for files]:dir:_files -/' \
  '(-q --qmesh)'{-q,--qmesh}'[q-mesh for phonon DOS]:qmesh:' \
  '(-b --born)'{-b,--born}'[born effective charge file path]:file:_files' \
  '(-e --eigenvectors)'{-e,--eigenvectors}'[write phonon eigenvectors to YAML]' \
  '--dim=[supercell matrix dimensions]:dim:' \
  '--poscar=[path to POSCAR file]:file:_files' \
  '--primitive-axis=[conventional-to-primitive transformation matrix]:matrix:' \
  '--primitive-auto[auto-determine primitive cell transformation]' \
  '--symprec=[symmetry-finding tolerance]:tol:' \
  '(-u --units)'{-u,--units}'[frequency units]:units:(THz cm-1 eV meV)' \
  '--spg=[space group number or symbol]:spg:' \
  '--density=[k-point density along path]:density:' \
  '--seekpath[use seekpath for high-symmetry path]' \
  '--pymatgen[use pymatgen for high-symmetry path]' \
  '--cartesian[use cartesian k-point coordinates]' \
  '--kpoints=[custom k-point list specification]:kpoints:' \
  '--labels=[labels for k-points]:labels:' \
  '--height=[graph height]:height:' \
  '--width=[graph width]:width:' \
  '--ymin=[minimum y-axis energy value]:ymin:' \
  '--ymax=[maximum y-axis energy value]:ymax:' \
  '--style=[matplotlib style specifications]:style:' \
  '--no-base-style[disable default sumo styling]' \
  '--config=[color configuration file]:file:_files' \
  '--format=[image format]:format:(pdf svg jpg png)' \
  '--dpi=[pixel density for output]:dpi:' \
  '--font=[font specification]:font:' \
  '--dos=[phonopy phonon DOS data file]:file:_files' \
  '--to-json=[output JSON file for band data]:file:_files' \
  '--from-json=[overlay band data from JSON files]:file:_files' \
  '--to-web=[output JSON for phononwebsite]:file:_files' \
  '--legend=[legend labels for plots]:legend:' && ret=0

return ret
