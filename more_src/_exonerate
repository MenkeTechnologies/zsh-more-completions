#compdef exonerate
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/exonerate.1.html
# generic tool for pairwise sequence comparison

local ret=1

_arguments -s -S \
  '(-q --query)'{-q,--query}'[query sequences (FASTA file)]:file:_files' \
  '(-t --target)'{-t,--target}'[target sequences (FASTA file)]:file:_files' \
  '(-Q --querytype)'{-Q,--querytype}'[query type to use]:type:(dna protein)' \
  '(-T --targettype)'{-T,--targettype}'[target type to use]:type:(dna protein)' \
  '(-m --model)'{-m,--model}'[alignment model to use]:model:(ungapped affine:local affine:global est2genome ner protein2dna protein2genome coding2coding coding2genome cdna2genome genome2genome)' \
  '(-s --score)'{-s,--score}'[overall score threshold]:score:' \
  '(-n --bestn)'{-n,--bestn}'[report the best N results for each query]:n:' \
  '(-V --verbose)'{-V,--verbose}'[show information about what is going on]:level:' \
  '--showalignment[show the alignments in human readable form]:bool:(TRUE FALSE)' \
  '--showvulgar[show the alignments in vulgar format]:bool:(TRUE FALSE)' \
  '--showcigar[show the alignments in cigar format]:bool:(TRUE FALSE)' \
  '--showsugar[display sugar output for ungapped alignments]:bool:(TRUE FALSE)' \
  '--showquerygff[report GFF output for features on the query]:bool:(TRUE FALSE)' \
  '--showtargetgff[report GFF output for features on the target]:bool:(TRUE FALSE)' \
  '--ryo[roll-your-own output format]:format:' \
  '(-g --gappedextension)'{-g,--gappedextension}'[perform a gapped extension stage]:bool:(TRUE FALSE)' \
  '*:file:_files' && ret=0

return ret
