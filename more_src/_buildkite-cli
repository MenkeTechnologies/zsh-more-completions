#compdef bk
# _buildkite-cli — Buildkite CLI (buildkite/cli)
# upstream: https://github.com/buildkite/cli

_buildkite-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--debug[enable debug output]' \
        '--no-color[disable color output]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_buildkite_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                configure|version) ;;
                build)
                    _arguments \
                        '--debug[debug output]' \
                        '--no-color[no color]' \
                        '*:args:' && ret=0 ;;
                use)
                    _arguments \
                        '*:pipeline:' && ret=0 ;;
                tool|cluster|api)
                    _arguments \
                        '--debug[debug output]' \
                        '--no-color[no color]' \
                        '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_buildkite_commands] )) ||
_buildkite_commands() {
    local -a commands
    commands=(
        'configure:configure Buildkite CLI'
        'build:manage builds'
        'use:set the default pipeline'
        'tool:tool commands'
        'cluster:manage clusters'
        'api:make Buildkite API requests'
    )
    _describe -t commands 'bk command' commands
}

_buildkite-cli "$@"
