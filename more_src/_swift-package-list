#compdef swift-package-list
# Documentation: https://github.com/FelixHerrmann/swift-package-list
# swift-package-list - extract the Swift package dependencies of an Xcode project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '--custom-derived-data-path=[alternate DerivedData location]:dir:_files -/' \
  '--custom-source-packages-path=[alternate SourcePackages folder]:dir:_files -/' \
  '*--custom-packages-file-path=[file with custom packages in JSON-output format]:file:_files' \
  '--output-type=[output format for the package list]:type:(stdout json plist settings-bundle pdf)' \
  '--output-path=[path where the package-list file is stored]:dir:_files -/' \
  '--custom-file-name=[override default filename]:name:' \
  '--package-order=[order of listed packages]:order:(source name-ascending name-descending identity-ascending identity-descending)' \
  '--requires-license[skip packages without license files]' \
  '*--ignore-package=[skip a package with the specified identity]:identity:' \
  '1:project:_files -g "*.(xcodeproj|xcworkspace)" -g "(Package|Project|Dependencies).swift"' && ret=0

return ret
