#compdef bro zeek
# Documentation: https://docs.zeek.org/en/master/quickstart.html
# Reference accessed: 2026-05-16
# Verified: upstream Zeek quickstart guide. `bro` was renamed to `zeek`
# in Zeek 3.0; both names share the same binary on systems where the
# legacy alias is installed.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# bro/zeek: network security monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-i --iface)'{-i+,--iface=}'[capture from network interface]:interface:' \
  '(-r --readfile)'{-r+,--readfile=}'[read from pcap/tcpdump file]:file:_files' \
  '(-C --no-checksums)'{-C,--no-checksums}'[ignore checksum errors]' \
  '(-b --bare-mode)'{-b,--bare-mode}'[do not load scripts from base/]' \
  '(-e --exec)'{-e+,--exec=}'[augment loaded policies with code]:code:' \
  '(-f --filter)'{-f+,--filter=}'[BPF capture filter]:filter:' \
  '*:script:_files -g "*.(zeek|bro)(-.)"' && ret=0
return ret
