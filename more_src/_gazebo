#compdef gazebo gzserver gzclient
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/gzserver.1.html
# Documentation: https://classic.gazebosim.org/tutorials?tut=quick_start
# Reference accessed: 2026-05-27
# Verified: upstream gzserver(1) manpage (Gazebo Classic)

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[produce help message]'
  '(- *)'{-v,--version}'[output version information]'
  '--verbose[increase messages written to the terminal]'
  '(-u --pause)'{-u,--pause}'[start the server in a paused state]'
  '(-e --physics)'{-e,--physics}'+[specify physics engine]:engine:(ode bullet dart simbody)'
  '(-p --play)'{-p,--play}'+[play a log file]:logfile:_files'
  '(-r --record)'{-r,--record}'[record state data]'
  '--record_encoding=[compression encoding for log data]:format:(zlib bz2 txt)'
  '--record_path=[absolute path to store state data]:path:_files -/'
  '--record_period=[recording period in seconds]:seconds:'
  '--record_filter=[recording filter (wildcard or regex)]:pattern:'
  '--record_resources[record model meshes and materials]'
  '--seed=[start with a given random number seed]:seed:'
  '--iters=[number of iterations to simulate]:iterations:'
  '--minimal_comms[reduce TCP/IP traffic output by gzserver]'
  '(-s --server-plugin)'{-s,--server-plugin}'+[load a plugin]:plugin:_files'
  '(-o --profile)'{-o,--profile}'+[physics preset profile name from world file]:profile:'
  '*:world file:_files -g "*.world"'
)

_arguments -s -S $arguments
