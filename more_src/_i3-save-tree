#compdef i3-save-tree
# Documentation: https://man.archlinux.org/man/extra/i3-wm/i3-save-tree.1.en
# Reference accessed: 2026-05-16
# Verified: i3-save-tree(1) Arch manpage from i3-wm package.
# Only --workspace and --output documented upstream.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --help/--version flags.

# i3-save-tree: dump i3 layout JSON for restore
local curcontext="$curcontext" ret=1
_arguments -C \
  '--workspace=[workspace name or number]:ws:' \
  '--output=[output name]:output:' && ret=0
return ret
