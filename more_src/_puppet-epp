#compdef puppet-epp
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/epp.md
# puppet epp - render, dump and validate Embedded Puppet (EPP) templates

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '-e+[inline epp source from the command line]:source:' \
  '--format=[dump result format]:format:(old pn json)' \
  '--header[show a file name header between files]' \
  '--no-header[do not show a file name header]' \
  '--pretty[pretty print output (pn or json only)]' \
  '--validate[validate the parsed result]' \
  '--no-validate[do not validate the parsed result]' \
  '--facts=[yaml or json file of facts]:file:_files' \
  '--node=[node name for which facts are obtained]:node:_hosts' \
  '--values=[Hash in Puppet DSL form passed to template]:values:' \
  '--values_file=[pp or yaml file producing a hash of values]:file:_files' \
  '--continue_on_error[continue after errors are reported]' \
  '--no-continue_on_error[stop after errors are reported]' \
  '1:action:(dump render validate)' \
  '*::template:_files' && ret=0

return ret
