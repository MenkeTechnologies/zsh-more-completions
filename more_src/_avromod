#compdef avromod
# Documentation: https://github.com/apache/avro/blob/main/lang/c/src/avromod.c
# avromod - recodec/reblock an Avro data file (input stdin if omitted)

local ret=1

_arguments -s -S \
  '(-c --codec)'{-c,--codec=}'[compression codec (default null)]:codec:(null deflate snappy lzma zstandard bzip2)' \
  '(-b --block-size)'{-b,--block-size=}'[block size for output]:size' \
  ':input Avro file:_files' \
  ':output Avro file:_files' && ret=0

return ret
