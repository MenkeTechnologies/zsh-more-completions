#compdef cockpit-pcp
# Documentation: https://man.archlinux.org/search?q=cockpit-pcp
# Reference accessed: 2026-05-16

# cockpit-pcp: Cockpit performance data adapter for PCP
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*::extra args:_files' && ret=0
return ret
