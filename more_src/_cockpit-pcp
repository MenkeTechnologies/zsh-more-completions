# cockpit-pcp: Cockpit performance data adapter for PCP (internal helper).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*::extra args:_files' && ret=0
return ret
