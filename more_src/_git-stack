#compdef git-stack

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color=[colorize output]:when:(auto always never)' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'stack:show the current stack'
      'sync:sync stack with upstream'
      'reword:edit commit messages'
      'amend:amend the current commit'
      'run:run a command on each commit'
      'rebase:rebase the stack'
      'next:move to the next commit'
      'prev:move to the previous commit'
      'alias:manage git aliases'
    )
    _describe -t commands 'git-stack command' commands && ret=0
    ;;
  args)
    case $line[1] in
      sync)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--pull[pull upstream changes]' \
          '--rebase[rebase onto upstream]' \
          '--stash[stash changes before sync]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
