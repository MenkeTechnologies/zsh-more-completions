#compdef cody-agent
# Documentation: https://github.com/sourcegraph/cody
# Reference accessed: 2026-05-23
# Verified: npx @sourcegraph/cody-agent --help.

# Zsh completion for cody-agent - Sourcegraph Cody headless agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'cody-agent command' \
      'server[start Cody agent server]' \
      'jsonrpc[JSON-RPC via stdin/stdout]' \
      'cody-bench[evaluate Cody autocomplete]' \
      'chat[chat with codebase context]' \
      'auth[authenticate with Sourcegraph]' && ret=0
    ;;
  args)
    case $line[1] in
      server)
        _arguments '--port[listen port]:port:' && ret=0
        ;;
      chat)
        _arguments \
          '(-m --message)'{-m+,--message=}'[message to send]:message:' \
          '--endpoint[Sourcegraph instance URL]:url:' \
          '--access-token[Sourcegraph access token]:token:' \
          '(-C --dir)'{-C+,--dir=}'[working directory]:directory:_directories' \
          '--model[chat model]:model:' \
          '--context-repo[repository context]:repo:' \
          '--context-file[local context files]:file:_files' \
          '--show-context[show context in reply]' \
          '--silent[disable streaming reply]' \
          '--debug[enable debug logging]' && ret=0
        ;;
      auth)
        _arguments -C \
          '1:subcommand:->auth_cmds' \
          '*:: :->auth_args' && ret=0
        case $state in
          auth_cmds)
            _values 'cody-agent auth command' \
              'login[log in to Sourcegraph]' \
              'logout[log out]' \
              'whoami[print active account]' \
              'accounts[print all accounts]' \
              'settings-path[print settings path]' && ret=0
            ;;
          auth_args)
            case $line[2] in
              login)
                _arguments '--web[authenticate via browser]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      cody-bench)
        _arguments \
          '--workspace[workspace directory]:directory:_directories' \
          '--test-count[autocomplete request count]:count:' \
          '--max-file-test-count[max requests per file]:count:' \
          '--evaluation-config[evaluation config JSON]:file:_files' \
          '--snapshot-directory[snapshot output directory]:directory:_directories' && ret=0
        ;;
      jsonrpc)
        _arguments \
          '--recording-directory[recording directory]:directory:_directories' \
          '--recording-mode[recording mode]:mode:' \
          '--recording-name[recording name]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
