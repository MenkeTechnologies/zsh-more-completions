#compdef nsqlookupd
# Documentation: https://nsq.io/components/nsqlookupd.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '-broadcast-address=[address of this lookupd]:address:'
  '-config=[path to config file]:file:_files'
  '-http-address=[address for HTTP clients]:address:'
  '-inactive-producer-timeout=[time before producer ping considered stale]:duration:'
  '-log-level=[log level]:level:(debug info warn error fatal)'
  '-log-prefix=[log message prefix]:prefix:'
  '-tcp-address=[address for TCP clients]:address:'
  '-tombstone-lifetime=[time tombstoned producers remain in lookup data]:duration:'
  '-verbose[deprecated; use -log-level]'
  '-version[print version string]'
)

_arguments -s -S $arguments
