#compdef nsqlookupd
# Documentation: https://man.archlinux.org/search?q=nsqlookupd
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--broadcast-address=[address to broadcast to clients]:address:'
  '--http-address=[address to listen on for HTTP]:address:'
  '--inactive-producer-timeout=[duration of time before tombstoning inactive producer]:duration:'
  '--log-level=[log level]:level:(debug info warn error fatal)'
  '--log-prefix=[log message prefix]:prefix:'
  '--tcp-address=[address to listen on for TCP]:address:'
  '--tombstone-lifetime=[duration of time tombstoned producers remain]:duration:'
  '--verbose[enable verbose logging]'
  '--version[show version]'
)

_arguments -s -S $arguments
