#compdef varnamelen
# Documentation: https://github.com/blizzy78/varnamelen
# checks that the length of a variable name matches its usage scope

local ret=1

_arguments -s -S \
  '-V[print version and exit]' \
  '-c=[display offending line with this many lines of context]:n:' \
  '-checkReceiver[check method receiver names]' \
  '-checkReturn[check named return values]' \
  '-checkTypeParam[check type parameter names]' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-debug=[debug flags, any subset of fpstv]:flags:' \
  '-fix[apply all suggested fixes]' \
  '-flags[print analyzer flags in JSON]' \
  '-ignoreChanRecvOk[ignore ok variables from channel receive operations]' \
  '-ignoreDecls=[comma-separated list of ignored variable declarations]:decls:' \
  '-ignoreMapIndexOk[ignore ok variables from map index operations]' \
  '-ignoreNames=[comma-separated list of ignored variable names]:names:' \
  '-ignoreTypeAssertOk[ignore ok variables from type assertions]' \
  '-json[emit JSON output]' \
  '-maxDistance=[maximum number of lines of variable usage scope considered short]:n:' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-minNameLength=[minimum length of variable name considered long]:n:' \
  '-trace=[write trace log to file]:file:_files' \
  '*:packages:_files' && ret=0

return ret
