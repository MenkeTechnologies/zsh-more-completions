#compdef ctr-enc
# Documentation: https://github.com/containerd/imgcrypt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ctr-enc: containerd CLI extension for encrypted images (imgcrypt).

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'image:image management (encrypt/decrypt/pull/tag/push/rm)'
  'images:image management (alias)'
  'i:image management (alias)'
  'run:run a container'
  'completion:emit shell completion'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[debug logging]' \
  '--address=[containerd socket address]:addr' \
  '-a+[containerd socket address]:addr' \
  '--namespace=[containerd namespace]:ns' \
  '-n+[containerd namespace]:ns' \
  '--connect-timeout=[connect timeout]:duration' \
  '--timeout=[command timeout]:duration' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'ctr-enc command' commands && ret=0 ;;
esac
return ret
