#compdef debug-cql

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h+[host]:host:_hosts' \
  '-p+[port]:port:' \
  '-u+[username]:user:_users' \
  '-w+[password]:password:' \
  {-k+,--keyspace=}'[keyspace]:keyspace:' \
  '-e+[execute statement]:cql:' \
  '-f+[execute file]:file:_files -g "*.cql"' \
  '--ssl[use SSL]' \
  '--debug[enable debug mode]' \
  '--no-color[disable colored output]' \
  '*:CQL file:_files -g "*.cql"' && ret=0

return ret
