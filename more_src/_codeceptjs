#compdef codeceptjs
# _codeceptjs — supercharged end-to-end testing framework for Node (codeceptjs/CodeceptJS)
# upstream: https://github.com/codeceptjs/CodeceptJS
# Subcommands from bin/codecept.js (commander).

_codeceptjs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'create dummy config in current dir'
                migrate:'migrate json config to js config'
                shell:'interactive shell (alias sh)'
                sh:'interactive shell'
                list:'list all I actions (alias l)'
                l:'list all I actions'
                def:'generate TypeScript definitions for I actions'
                gherkin:init:'prepare CodeceptJS to run feature files'
                bdd:init:'prepare CodeceptJS for BDD'
                gherkin:steps:'print all defined gherkin steps'
                bdd:steps:'print all defined gherkin steps'
                gherkin:snippets:'generate step definitions from steps'
                bdd:snippets:'generate step definitions from steps'
                generate:test:'generate an empty test (alias gt)'
                gt:'generate an empty test'
                generate:pageobject:'generate an empty page object (alias gpo)'
                gpo:'generate an empty page object'
                generate:object:'generate an empty support object (alias go)'
                go:'generate an empty support object'
                generate:helper:'generate a new helper (alias gh)'
                gh:'generate a new helper'
                run:'execute tests'
                run-rerun:'execute tests with rerun'
                run-workers:'execute tests in parallel workers'
                run-multiple:'execute multiple test suites'
                info:'show codeceptjs info'
                dry-run:'execute tests without running them'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run|run-rerun|dry-run)
                    _arguments \
                        '--steps[show step-by-step execution]' \
                        '--debug[output additional information]' \
                        '--verbose[output internal logging information]' \
                        '(-o --override)'{-o+,--override=}'[override current config options]:value:' \
                        '--profile=[configuration profile to use]:profile:' \
                        '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
                        '--features[run only *.feature files]' \
                        '--tests[run only JS test files]' \
                        '(-p --plugins)'{-p+,--plugins=}'[enable plugins (comma-separated k=v)]:plugins:' \
                        '(-g --grep)'{-g+,--grep=}'[only run tests matching pattern]:pattern:' \
                        '(-f --fgrep)'{-f+,--fgrep=}'[only run tests containing string]:string:' \
                        '(-i --invert)'{-i,--invert}'[invert --grep and --fgrep matches]' \
                        '(-R --reporter)'{-R+,--reporter=}'[reporter to use]:name:' \
                        '(-O --reporter-options)'{-O+,--reporter-options=}'[reporter-specific options]:opts:' \
                        '(-b --bail)'{-b,--bail}'[bail after first failure]' \
                        '*:test path:_files' ;;
                run-workers)
                    _arguments '1:workers:' '*:test path:_files' ;;
                init|migrate|list|l|def|gherkin:init|bdd:init|gherkin:steps|bdd:steps|gherkin:snippets|bdd:snippets|generate:test|gt|generate:pageobject|gpo|generate:object|go|generate:helper|gh|info|shell|sh)
                    _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_codeceptjs "$@"
