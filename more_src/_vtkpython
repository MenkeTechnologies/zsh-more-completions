#compdef vtkpython
# Documentation: https://manpages.debian.org/testing/python3-vtk9/vtkpython-9.0.1.en.html
# Python interpreter with the VTK Visualization Toolkit modules preloaded

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '(-V --version)'{-V,--version}'[print the Python version number and exit]' \
  '-b[issue warnings about str/bytes comparisons (-bb for errors)]' \
  '-B[do not write .pyc files on import]' \
  '-c+[program passed in as string (terminates option list)]:command:' \
  '-d[debug output from parser]' \
  '-E[ignore PYTHON* environment variables]' \
  '-i[inspect interactively after running script]' \
  '-I[isolate Python from user environment (implies -E and -s)]' \
  '-m+[run library module as a script (terminates option list)]:module:' \
  '-O[remove assert and __debug__-dependent statements]' \
  '-OO[remove -O changes and also discard docstrings]' \
  '-q[do not print version and copyright on interactive startup]' \
  '-s[do not add user site directory to sys.path]' \
  '-S[do not imply import site on initialization]' \
  '-u[force stdout and stderr streams to be unbuffered]' \
  '-v[verbose (trace import statements)]' \
  '-W+[warning control: action:message:category:module:lineno]:warning:' \
  '-x[skip first line of source]' \
  '-X+[set implementation-specific option]:option:(faulthandler oldparser showrefcount tracemalloc importtime dev utf8 pycache_prefix)' \
  '--check-hash-based-pycs=[control validation of hash-based .pyc files]:mode:(always default never)' \
  '*:script:_files -g "*.py"' && ret=0

return ret
