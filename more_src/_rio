#compdef rio

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-e --command)'{-e,--command}'[command to run]:command:_command_names -e' \
  '--working-dir=[start in specified directory]:directory:_directories' \
  '--config=[path to config file]:config file:_files' \
  '*:program and arguments:_command_names -e' && ret=0

return ret
