#compdef gdal_contour

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b+[input band]:band:' \
  '-a+[attribute name for elevation]:name:' \
  '-amin+[min elevation attribute]:name:' \
  '-amax+[max elevation attribute]:name:' \
  '-3d[generate 3D vector layer]' \
  '-inodata[ignore nodata]' \
  '-snodata+[source nodata]:value:' \
  '-f+[output format]:format:' \
  '-i+[contour interval]:value:' \
  '-off+[contour offset]:value:' \
  '*-fl+[contour level]:value:' \
  '-e+[exponential interval]:base:' \
  '-nln+[output layer name]:name:' \
  '-p[create polygons not lines]' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-q[quiet]' \
  '1:input raster file:_files -g "*.(tif|tiff|nc|hdf|img|jp2|vrt)"' \
  '2:output vector file:_files -g "*.(shp|geojson|gpkg|kml)"' && ret=0

return ret
