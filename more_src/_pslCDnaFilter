#compdef pslCDnaFilter
# UCSC kent: filter cDNA alignments in psl format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-algoHelp[explain the filtering algorithm]' \
  '-localNearBest=[local near-best in genome filtering]:frac:' \
  '-globalNearBest=[global near-best in genome filtering]:frac:' \
  '-ignoreNs[don'\''t include Ns in coverage calculation]' \
  '-ignoreIntrons[don'\''t favor alignments with introns]' \
  '-minId=[minimum fraction identity]:frac:' \
  '-minCover=[minimum fraction of query covered]:frac:' \
  '-minSpan=[minimum fraction of target span]:frac:' \
  '-minQSize=[drop queries shorter than this]:n:' \
  '-maxAligns=[maximum number of alignments per query]:n:' \
  '-maxAlignsDrop=[drop queries with more than this many alignments]:n:' \
  '-minAlnSize=[minimum alignment size]:n:' \
  '-minNonRepSize=[minimum non-repeat bases]:n:' \
  '-maxRepMatch=[maximum fraction of repeat matches]:frac:' \
  '-repsAsMatch[count repeat matches as matches]' \
  '-polyASizes=[file of poly-A tail sizes]:file:_files' \
  '-usePolyTHead[use poly-T head as well as poly-A tail]' \
  '-hapRegions=[haplotype pseudo-autosomal regions PSL]:file:_files' \
  '-bestOverlap[filter overlapping by keeping best]' \
  '-dropped=[output dropped PSLs to file]:file:_files' \
  '-weirdOverlapped=[output weird overlapping PSLs to file]:file:_files' \
  '-filterWeirdOverlapped[drop weird overlapping alignments]' \
  '-noValidate[don'\''t validate input PSLs]' \
  '-uniqueMapped[keep only uniquely mapped queries]' \
  '-decayMinCover[lower minCover for short queries]' \
  '-blackList=[file of accessions to drop]:file:_files' \
  '-statsOut=[output filtering statistics to file]:file:_files' \
  '*:psl file:_files' && ret=0

return ret
