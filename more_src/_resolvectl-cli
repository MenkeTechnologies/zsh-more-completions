#compdef resolvectl
# _resolvectl-cli — systemd-resolved control client (replacement for systemd-resolve); query DNS, set per-link servers
# upstream: https://github.com/systemd/systemd

_resolvectl-cli() {
    local -a sub=(
        'query:query a host'
        'service:query a SRV record'
        'openpgp:query a OPENPGPKEY record'
        'tlsa:query a TLSA record'
        'status:show status'
        'statistics:show statistics'
        'reset-statistics:reset statistics'
        'flush-caches:flush DNS caches'
        'reset-server-features:reset server feature levels'
        'dns:set per-link DNS servers'
        'domain:set per-link search domains'
        'default-route:set default route per link'
        'llmnr:set LLMNR mode per link'
        'mdns:set mDNS mode per link'
        'dnssec:set DNSSEC mode per link'
        'dnsovertls:set DNS-over-TLS mode per link'
        'nta:set NTA domains per link'
        'revert:revert per-link config'
        'log-level:get/set log level'
        'monitor:monitor DNS lookups'
        'show-cache:show DNS cache contents'
        'show-server-state:show server state'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '(-4)-4[IPv4 only]' \
        '(-6)-6[IPv6 only]' \
        '(-i --interface)'{-i,--interface}'+[interface]:iface:_net_interfaces' \
        '(-p --protocol)'{-p,--protocol}'+[protocol]:proto:(dns llmnr mdns)' \
        '(-t --type)'{-t,--type}'+[record type]:type:(A AAAA MX TXT SRV ANY)' \
        '(-c --class)'{-c,--class}'+[record class]:class:(IN)' \
        '--service-address+[show only addresses]:bool:(yes no)' \
        '--service-txt+[show TXT]:bool:(yes no)' \
        '--cname+[follow CNAME]:bool:(yes no)' \
        '--validate+[DNSSEC validate]:bool:(yes no)' \
        '--synthesize+[synthesize hosts]:bool:(yes no)' \
        '--cache+[allow caching]:bool:(yes no)' \
        '--zone+[allow zone]:bool:(yes no)' \
        '--trust-anchor+[trust anchor]:bool:(yes no)' \
        '--network+[allow network]:bool:(yes no)' \
        '--search+[allow search domains]:bool:(yes no)' \
        '--raw+[raw output]:type:(payload packet)' \
        '--legend+[show legend]:bool:(yes no)' \
        '--json+[json mode]:mode:(pretty short off)' \
        '--no-pager[no pager]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'resolvectl subcommand' sub ;;
        args)
            case $words[1] in
                query|service|openpgp|tlsa) _arguments '*:hostname:_hosts' ;;
                status|statistics|flush-caches|reset-statistics|reset-server-features|revert) _arguments '*:link:_net_interfaces' ;;
                dns|domain|default-route|llmnr|mdns|dnssec|dnsovertls|nta) _arguments '1:link:_net_interfaces' '*:value:' ;;
            esac
            ;;
    esac
}

_resolvectl-cli "$@"
