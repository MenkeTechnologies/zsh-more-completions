#compdef arangosync
# Documentation: https://docs.arangodb.com/3.11/deploy/arangosync/
# ArangoDB datacenter-to-datacenter (DC2DC) replication control CLI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--master.endpoint=[endpoints of the sync masters]:endpoint:' \
  '--auth.user=[username for authentication]:user:' \
  '--auth.password=[password for authentication]:password:' \
  '1:command:(configure start stop abort get set reset)' \
  '2:subcommand:(sync tasks masters workers outgoing message)' && ret=0

return ret
