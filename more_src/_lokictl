#compdef lokictl
# CLI controller for Lokinet overlay network

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config[config file path]:file:_files' \
  '--rpc[RPC URL]:url:' \
  'status[show connection status]' \
  'exit[manage exit nodes]' \
  'map[map address to exit]' \
  'unmap[unmap address]' \
  'add[add SNApp mapping]' \
  'del[remove SNApp mapping]' \
  'list[list current mappings]' \
  && return 0
