#compdef git-branch-stash
# Documentation: https://github.com/gitext-rs/git-branch-stash/blob/main/src/args.rs
# git-branch-stash - stash and restore what each of your branches points at

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--color=[color output]:when:(always never auto)' \
  '(-m --message)'{-m,--message}'=[annotate the snapshot with the given message]:message:' \
  '1:command:(push list clear drop pop apply stacks)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      push)
        _arguments -s \
          '(-m --message)'{-m,--message}'=[annotate the snapshot with the given message]:message:' \
          '1:stack:' && ret=0
        ;;
      list|clear|drop|pop|apply)
        _arguments -s '1:stack:' && ret=0
        ;;
      stacks)
        ret=0
        ;;
    esac
    ;;
esac

return ret
