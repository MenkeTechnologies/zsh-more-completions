    _arguments -s -S \
        '--port=[live-server listen port]:port:' \
        '--open=[open browser (default true)]:bool:(true false)' \
        '--content=[additional content directory to mount at /]:dir:_files -/' \
        '--hot=[enable live-reload hot-watching (default true)]:bool:(true false)' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:animation file:_files -g "*.js"'
}

