#compdef spamdb
# _spamdb — OpenBSD spamdb (manipulate the spamd greylisting database in /var/db/spamd: list, whitelist, delete; greytrapping helpers -T/-t/-G to manage SPAMTRAP/TRAPPED/GREY entries)
# upstream: https://github.com/openbsd/src (usr.sbin/spamdb)
# Flags from usr.sbin/spamdb/spamdb.8 on tip.

_spamdb() {
    _arguments \
        '-a[add or update entries for keys]' \
        '-d[delete entries for keys]' \
        '-G[treat keys as GREY entries (with -d)]' \
        '-T[treat keys as SPAMTRAP entries (with -a or -d)]' \
        '-t[treat keys as TRAPPED entries (with -a or -d)]' \
        '*:key:_hosts'
}

_spamdb "$@"
