#compdef edac-ctl

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'register-labels:register DIMM labels'
  'mainboard:print mainboard info'
  'status:show EDAC status'
  'delay:delay setup'
  'load:load EDAC drivers'
  'unload:unload EDAC drivers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--labels-file)--labels-file=+[labels file]:file:_files' \
  '(--label-template)--label-template=+[label template]:tpl:' \
  '(--mainboard)--mainboard=+[mainboard]:name:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'edac-ctl command' commands && ret=0 ;;
esac

return ret
