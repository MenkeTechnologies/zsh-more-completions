#compdef bareos-bconsole bconsole
# Documentation: https://github.com/bareos/bareos/blob/master/core/src/console/console.cc
# Reference accessed: 2026-05-16
# Verified: upstream Bareos 25 console.cc CLI11 option registration.
# Removed from prior file: bogus man.archlinux.org search URL.

# bareos-bconsole: Bareos interactive admin console
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration file or directory]:path:_files' \
  '(-D --director)'{-D+,--director=}'[specify director]:director:' \
  '(-l --list-directors)'{-l,--list-directors}'[list defined directors]' \
  '(-p --pam-credentials-filename)'{-p+,--pam-credentials-filename=}'[PAM credentials file]:file:_files' \
  '-o[force sending PAM credentials unencrypted]' \
  '(-s --no-signals)'{-s,--no-signals}'[disable signal handlers]' \
  '(-t --test-config)'{-t,--test-config}'[read configuration and exit]' \
  '(-u --timeout)'{-u+,--timeout=}'[command execution timeout in seconds]:seconds:' \
  '(--xc --export-config)'{--xc,--export-config}'[print configuration resources and exit]' \
  '(--xs --export-schema)'{--xs,--export-schema}'[print configuration schema as JSON and exit]' && ret=0
return ret
