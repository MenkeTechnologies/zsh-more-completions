#compdef hipify-perl

# hipify-perl: AMD ROCm HIPification tool (perl-based)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-print-stats[print conversion stats]' \
  '-print-stats-csv[print CSV stats]' \
  '-no-output[do not write hipified output]' \
  '-inplace[modify input files in place]' \
  '*:file:_files -g "*.(cu|cuh|c|h|cc|cpp|cxx|hpp)"' && ret=0
return ret
