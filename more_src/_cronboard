#compdef cronboard
# Documentation: https://github.com/antoniorodr/cronboard
# Reference accessed: 2026-05-17
# Verified: antoniorodr/cronboard upstream — Textual-based TUI
# dashboard for managing local/remote cron jobs. Pure TUI app with
# no meaningful CLI flag surface; only --help and --version.
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0
return ret
