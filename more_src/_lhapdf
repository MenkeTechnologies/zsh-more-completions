#compdef lhapdf
# Documentation: https://www.lhapdf.org/
# lhapdf - manage LHAPDF parton distribution function data files

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '--listdir[directory containing the lhapdf.index list file]:dir:_files -/' \
  '--pdfdir[directory for installation of PDF set data]:dir:_files -/' \
  '*--source[prepend a path or URL used as a source of data files]:source:' \
  '--quiet[suppress normal messages]' \
  '--verbose[output debug messages]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'lhapdf command' \
      'list[list available PDF sets]' \
      'ls[list available PDF sets]' \
      'show[show detailed metadata for installed PDF sets]' \
      'update[download and install a new PDF set index file]' \
      'install[download and install new PDF set data files]' \
      'get[download and install new PDF set data files]' \
      'upgrade[download newer replacement PDF set data files]' \
      'help[show usage instructions]' && ret=0
    ;;
  args)
    case $line[1] in
      list|ls)
        _arguments \
          '--installed[show only installed PDF sets]' \
          '--outdated[show installed but outdated PDF sets]' \
          '--codes[show ID codes alongside set names]' \
          '*:pattern:' && ret=0
        ;;
      install|get)
        _arguments \
          '--dryrun[preview downloads without executing]' \
          '--upgrade[force reinstall of already-installed sets]' \
          '--keep[retain downloaded tarball files after extraction]' \
          '*:pattern:' && ret=0
        ;;
      upgrade)
        _arguments \
          '--dryrun[preview without downloading]' \
          '--keep[preserve downloaded tarballs]' \
          '*:pattern:' && ret=0
        ;;
      show)
        _arguments '*:pattern:' && ret=0
        ;;
    esac
    ;;
esac

return ret
