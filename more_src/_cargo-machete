#compdef cargo-machete
# Documentation: https://man.archlinux.org/search?q=cargo-machete
# Reference accessed: 2026-05-16

_cargo-machete() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    '--with-metadata[Use cargo metadata for analysis]' \
    '--fix[Remove unused dependencies]' \
    '--skip-target-dir[Skip target directory analysis]' \
    '--manifest-path[Path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '--ignore[Crate names to ignore]:crates:' \
    '*:path:_directories'
}

_cargo-machete "$@"
