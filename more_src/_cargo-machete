#compdef cargo-machete
# Documentation: https://github.com/bnjbvr/cargo-machete (src/main.rs argh-based MacheteArgs)
# Reference accessed: 2026-05-29
# cargo-machete — find unused Rust dependencies in a Cargo project (uses argh, not clap).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[print version]' \
  '--with-metadata[use cargo-metadata for dependency name resolution (useful for renamed deps)]' \
  '--skip-target-dir[do not analyze anything inside target/ directories]' \
  '--fix[rewrite Cargo.toml files to remove unused dependencies]' \
  '--no-ignore[also search in ignored files (.gitignore, .ignore, etc.)]' \
  '*:path:_directories' \
  && ret=0

return ret
