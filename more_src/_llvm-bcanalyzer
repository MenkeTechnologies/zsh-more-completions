#compdef llvm-bcanalyzer
# _llvm-bcanalyzer — LLVM bitcode analyzer (LLVM project, C++); dump bitcode block/record stats and codes
# upstream: https://github.com/llvm/llvm-project

_llvm-bcanalyzer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--dump[dump records]' \
        '--show-binary-blobs[show binary blobs]' \
        '--block-info-dump[dump block info]' \
        '--dump-blockinfo[dump block info]' \
        '--no-histogram[no histogram]' \
        '--non-symbolic[non symbolic]' \
        '--operands[show operands]' \
        '*:file:_files -g "*.bc"'
}

_llvm-bcanalyzer "$@"
