#compdef sccache-cli2 sccache2
# _sccache-cli2 — Mozilla sccache-cli2 CLI command-line frontend wrapping the sccache Shared Compilation Cache compiler caching tool from Mozilla open-source written in Rust originally Ted Mielczarek now Mozilla mostly compatible with ccache but supports caching to a shared storage cloud service GCS Azure S3 OSS Memcached Redis local-disk compiles Rust C C++ Cargo Cuda nvcc Embedded distributed-compilation Linux macOS Windows compiler-args cache cache-dir cache-size show-stats zero-stats start-server stop-server show-adv-stats package-toml debug dist-status (Mozilla Ted Mielczarek team, Rust); clap
# upstream: https://github.com/mozilla/sccache

_sccache-cli2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-c[clear cache]' \
        '--clear-cache[clear cache]' \
        '-s[show stats]' \
        '--show-stats[show stats]' \
        '--show-adv-stats[show advanced stats]' \
        '--start-server[start server]' \
        '--stop-server[stop server]' \
        '-z[zero stats]' \
        '--zero-stats[zero stats]' \
        '--stats-format=+[fmt]:f:(text json)' \
        '--dist-auth[dist auth]' \
        '--dist-status[dist status]' \
        '--package-toml=+[file]:file:_files -g "*.toml"' \
        '--no-color[no color]' \
        '--color[force color]' \
        '*:cmd:_command_names'
}

_sccache-cli2 "$@"
