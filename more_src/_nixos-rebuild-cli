#compdef nixos-rebuild
# Documentation: https://man.archlinux.org/search?q=nixos-rebuild
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'switch:build, activate, set as boot default'
  'boot:build and set as boot default'
  'test:build and activate without making boot default'
  'build:build only'
  'build-vm:build VM script'
  'build-vm-with-bootloader:build VM with bootloader'
  'edit:edit configuration'
  'repl:open Nix repl'
  'dry-build:show what would be built'
  'dry-activate:show what would be activated'
  'list-generations:list generations'
  'rollback:rollback to previous generation'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--upgrade[upgrade nixos channel]' \
  '*--upgrade-all[upgrade all channels]' \
  '*--install-bootloader[install bootloader]' \
  '*--no-build-nix[do not build nix]' \
  '*--fast[fast mode]' \
  '*--rollback[rollback]' \
  '*--profile-name=[profile name]:n:' \
  '*-p+[profile name]:n:' \
  '*--specialisation=[specialisation]:s:' \
  '*-s+[specialisation]:s:' \
  '*--target-host=[target host]:host:_hosts' \
  '*--build-host=[build host]:host:_hosts' \
  '*--use-substitutes[use binary cache]' \
  '*--flake=[flake URI]:flake:' \
  '*--no-flake[disable flake]' \
  '*--builders=[remote builders csv]:list:' \
  '*-I+[Nix path]:p:' \
  '*--option=[Nix option k=v]:v:' \
  '*--max-jobs=[max jobs]:n:' \
  '*-j+[max jobs]:n:' \
  '*--cores=[cores]:n:' \
  '*--keep-going[keep going on errors]' \
  '*-k[keep going]' \
  '*--keep-failed[keep failed builds]' \
  '*-K[keep failed]' \
  '*--show-trace[show trace]' \
  '*--quiet[quiet]' \
  '*--verbose[verbose]' \
  '*-v[verbose]' \
  '*--print-build-logs[print build logs]' \
  '*-L[print build logs]' \
  '*--builders-use-substitutes[builders use substitutes]' \
  '*--substituters=[substituters csv]:list:' \
  '*--no-channel-copy[no channel copy]' \
  '*--repair[repair derivations]' \
  '*--include-outputs[include outputs]' \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action) _describe -t actions 'nixos-rebuild action' actions && ret=0 ;;
  (args) _files ;;
esac

return ret
