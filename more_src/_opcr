#compdef opcr
# Documentation: https://man.archlinux.org/search?q=opcr
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'build:build OCI policy bundle from Rego'
      'pull:pull policy bundle from registry'
      'push:push policy bundle to registry'
      'save:save policy bundle to archive'
      'tag:tag a policy bundle reference'
      'help:help'
    )
    _describe -t commands 'opcr command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
