#compdef opcr policy
# Documentation: https://github.com/opcr-io/policy
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# opcr-io/policy CLI (binary is named "policy"; opcr is the project)
local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--debug[enable debug output]' \
  '(-v --verbosity)'{-v,--verbosity}'[increase output detail]' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'build:compile policies into OCI images'
      'images:list locally stored policy images'
      'push:upload policies to a registry'
      'pull:download policies from a registry'
      'login:authenticate with a registry'
      'logout:remove registry authentication'
      'save:export a policy as a local tarball'
      'tag:add a tag to an existing policy'
      'rm:delete a policy from local storage'
      'inspect:show detailed policy information'
      'repl:interactive OPA query shell using loaded policies'
      'templates:manage and apply policy templates'
      'version:show version'
    )
    _describe -t commands 'policy command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
