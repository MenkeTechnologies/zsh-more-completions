#compdef gctoolbox
# Documentation: https://github.com/Spiritdude/GCodeToolbox
# GCodeToolbox: manipulate .gcode files (info/slice/cat/render)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--output=[output result (default stdout)]:output:_files' \
  '--slicer=[define slicer (default slic3r)]:slicer:' \
  '--sequence=[sequence type]:sequence:(concurrent complete)' \
  '--printer=[reference printer profile]:printer:' \
  '--printerX=[build width in mm (default 200)]:width:' \
  '--printerY=[build depth in mm (default 200)]:depth:' \
  '--printerZ=[build height in mm (default 200)]:height:' \
  '--printerMargin=[margin to platform perimeter in mm]:margin:' \
  '--printerHeadX=[head width in mm (default 16)]:headx:' \
  '--printerHeadY=[head depth in mm (default 16)]:heady:' \
  '--printerHeadZ=[head height in mm (default 50)]:headz:' \
  '--cols=[columns when concatenating]:cols:' \
  '--objectSpacing=[distance between items in mm]:spacing:' \
  '--fanSpeed=[fan speed 0-255]:speed:' \
  '--temperature=[extruder temperature]:temp:' \
  '--conf=[configuration file]:conf:_files' \
  '--fileList=[file with list of files]:filelist:_files' \
  '--renderView=[render view]:view:(top front)' \
  '1:command:(info slice cat render)' \
  '*:gcode/stl file:_files -g "*.(gcode|gco|stl|STL)"' && ret=0

return ret
