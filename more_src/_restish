#compdef restish

# Zsh completion for restish - REST API client (overwrite previous)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:manage API configurations'
  'head:make a HEAD request'
  'get:make a GET request'
  'post:make a POST request'
  'put:make a PUT request'
  'patch:make a PATCH request'
  'delete:make a DELETE request'
  'options:make an OPTIONS request'
  'edit:edit a resource'
  'links:list resource links'
  'pager:browse paginated results'
  'cert:manage client certificates'
)

_arguments -s -S \
  '(-f --output-format)'{-f+,--output-format=}'[output format]:format:(auto json yaml table)' \
  '(-r --raw)'{-r,--raw}'[raw output without formatting]' \
  '(-s --server)'{-s+,--server=}'[override server URL]:url:' \
  '(-H --header)'{-H+,--header=}'[set request header]:header:' \
  '(-q --query)'{-q+,--query=}'[set query parameter]:param=value:' \
  '--no-paginate[disable automatic pagination]' \
  '--rsh-no-cache[disable response caching]' \
  '--rsh-profile=[use specified profile]:profile:' \
  '--rsh-verbose[verbose output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'restish command' commands && ret=0
    ;;
esac

return ret
