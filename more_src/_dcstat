#compdef dcstat dcstat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/dcstat.py — manual sys.argv parsing, no argparse)
# Reference accessed: 2026-05-29
# dcstat — directory entry (dcache) statistics (REFS/SLOW/MISS/HIT%) by interval (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:interval (seconds, default 1):' \
  '2:count (number of iterations, default unlimited):' \
  && ret=0

return ret
