#compdef saml2aws

# Zsh completion for saml2aws (SAML to AWS STS)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:configure the credentials'
  'exec:execute a command with AWS credentials'
  'list-roles:list available roles'
  'login:log in and retrieve AWS credentials'
  'script:emit a script to export credentials'
  'console:open the AWS console in a browser'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[enable verbose logging]' \
  '(-i --provider)'{-i,--provider}'[identity provider]:provider:(ADFS Ping JumpCloud Okta OneLogin KeyCloak GoogleApps Shibboleth AzureAD Browser)' \
  '(-a --idp-account)'{-a,--idp-account}'[IDP account name]:account:' \
  '--idp-provider[IDP provider]:provider:' \
  '(-p --profile)'{-p,--profile}'[AWS profile]:profile:' \
  '--url[IDP entry URL]:url:_urls' \
  '--username[username]:username:' \
  '--password[password]:password:' \
  '--mfa-token[MFA token]:token:' \
  '--role[ARN of role to assume]:arn:' \
  '--skip-verify[skip TLS certificate verification]' \
  '--session-duration[session duration in seconds]:seconds:' \
  '--disable-keychain[disable keychain storage]' \
  '--region[AWS region]:region:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'saml2aws command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (exec)
        _arguments \
          '--exec-profile[AWS profile]:profile:' \
          '*:command:_command_names -e' && ret=0
        ;;
      (login)
        _arguments \
          '--force[force login]' \
          '--credential-process[output credential process JSON]' \
          '--cache-saml[cache SAML response]' \
          '--cache-file[SAML cache file]:file:_files' \
          '--skip-prompt[skip prompts]' && ret=0
        ;;
      (script)
        _arguments \
          '--shell[shell type]:shell:(bash powershell fish env)' && ret=0
        ;;
    esac
    ;;
esac

return ret
