#compdef immich

# Zsh completion for Immich CLI - self-hosted photo management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'upload:upload assets to Immich'
  'login:login to Immich server'
  'logout:logout from Immich server'
  'server-info:display server information'
  'session:display session information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'immich command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      upload)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[recursive upload]' \
          '(-i --ignore)'{-i+,--ignore=}'[glob patterns to ignore]:pattern:' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '--skip-hash[skip hash check]' \
          '--delete[delete local file after upload]' \
          '--album[automatically create albums]' \
          '--album-name=[album name]:name:' \
          '(-c --concurrency)'{-c+,--concurrency=}'[concurrent uploads]:count:' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:files or directories:_files'
        ;;
      login)
        _arguments \
          '1:server URL:' \
          '2:API key:'
        ;;
    esac
    ;;
esac

return ret
