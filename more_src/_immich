#compdef immich
# Documentation: https://docs.immich.app/features/command-line-interface/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# immich CLI — official upload/management tool for self-hosted Immich servers.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:login using URL and API key (alias of login-key)'
  'login-key:login using URL and API key'
  'logout:remove stored credentials'
  'server-info:display server information'
  'upload:upload assets'
)

_arguments -s -S -C \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --config-directory)'{-d+,--config-directory=}'[configuration directory]:directory:_directories' \
  '(-u --url)'{-u+,--url=}'[Immich server URL]:url:' \
  '(-k --key)'{-k+,--key=}'[API key]:key:' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  (command)
    _describe -t commands 'immich command' commands && ret=0
    ;;
  (args)
    case "${words[1]}" in
      (login|login-key)
        _arguments \
          '1:server URL:' \
          '2:API key:' && ret=0
        ;;
      (upload)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[include subdirectories]' \
          '(-i --ignore)'{-i+,--ignore=}'[glob pattern to exclude]:pattern:' \
          '(-h --skip-hash)'{-h,--skip-hash}'[skip hashing before upload]' \
          '(-H --include-hidden)'{-H,--include-hidden}'[include hidden folders]' \
          '(-a --album)'{-a,--album}'[auto-create albums by folder name]' \
          '(-A --album-name)'{-A+,--album-name=}'[upload all to specified album]:album:' \
          '(-n --dry-run)'{-n,--dry-run}'[preview actions without executing]' \
          '(-c --concurrency)'{-c+,--concurrency=}'[simultaneous uploads]:count:' \
          '(-j --json-output)'{-j,--json-output}'[output detailed info as JSON]' \
          '--delete[remove local files after upload]' \
          '--delete-duplicates[remove duplicate local files]' \
          '--no-progress[hide progress indicators]' \
          '--watch[monitor and auto-upload changes]' \
          '*:files or directories:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
