#compdef unblob
# Documentation: https://github.com/onekey-sec/unblob (python/unblob/cli.py click decorators)
# Reference accessed: 2026-05-29
# Unblob — accurate, fast, easy-to-use extraction suite for firmware images (Onekey).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show unblob version]' \
  '(-e --extract-dir)'{-e,--extract-dir=}'[directory to extract files to (created if missing)]:dir:_directories' \
  '(-f --force)'{-f,--force}'[force extraction even if outputs already exist]' \
  '(-d --depth)'{-d,--depth=}'[recursion depth for containers]:n:' \
  '(-n --randomness-depth)'{-n,--randomness-depth=}'[entropy calculation depth for unknown files]:n:' \
  '*'{-P,--plugins-path=}'[load plugins from path]:path:_files -/' \
  '*'{-S,--skip-magic=}'[skip processing files with given magic prefix]:magic:' \
  '*--skip-extension=[skip processing files with given extension]:ext:' \
  '--clear-skip-magics[clear unblob default skip magic list]' \
  '(-p --process-num)'{-p,--process-num=}'[number of worker processes for parallel processing]:n:' \
  '--report=[file to store extraction metadata as JSON]:file:_files' \
  '--log=[file to save text logs (default unblob.log)]:file:_files' \
  '(-s --skip-extraction)'{-s,--skip-extraction}'[only carve chunks, skip further extraction]' \
  '--no-sandbox[disable Landlock sandboxing (debug)]' \
  '(-k --keep-extracted-chunks)'{-k,--keep-extracted-chunks}'[keep extracted intermediate chunks]' \
  '--delete-extracted-files[delete fully-extracted intermediate files]' \
  '--carve-suffix=[suffix appended to carve directory name]:suffix:' \
  '--extract-suffix=[suffix appended to extraction directory name]:suffix:' \
  '--show-external-dependencies[list external commands unblob requires]' \
  '--build-handlers-doc[generate handlers markdown documentation]' \
  '-v[increase verbosity (stackable)]' \
  '*:firmware file:_files' && ret=0

return ret
