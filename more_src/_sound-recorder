#compdef sound-recorder
# Documentation: https://man.cx/sound-recorder
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sound-recorder: record samples from line input to a file via OSS soundcard

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[channels (1=mono, 2=stereo)]:channels:(1 2)' \
  '-s[sample rate in Hz]:rate:' \
  '-b[bits per sample]:bits:(8 16)' \
  '-k[overwrite existing destination files]' \
  '-P[priority threaded recording]' \
  '-A[DSP device]:device:_files -g "/dev/dsp*"' \
  '-e[shell command to execute after recording]:command:' \
  '-S[recording duration limit (mm:ss)]:duration:' \
  '-f[output format]:format:(wav pcm cdr ima3 ima4 ima5)' \
  '-q[suppress time counter display]' \
  '*:output file:_files' && ret=0
return ret
