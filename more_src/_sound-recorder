#compdef sound-recorder
# Documentation: https://man.archlinux.org/search?q=sound-recorder
# Reference accessed: 2026-05-16

# sound-recorder: command-line audio recorder (GNOME)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[device]:device:' \
  '-r[sample rate]:rate:' \
  '-c[channels]:n:' \
  '-b[bits per sample]:bits:(8 16 24 32)' \
  '-f[output file]:file:_files -g "*.(wav|ogg|flac|mp3)"' \
  '-t[record for N seconds]:seconds:' \
  '*::sound-recorder args:_files' && ret=0
return ret
