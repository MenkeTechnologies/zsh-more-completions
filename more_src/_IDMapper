#compdef IDMapper
# OpenMS TOPP: map peptide/protein identifications to features

local ret=1

_arguments -s -S \
  '-id[protein/peptide identifications file]:id file:_files' \
  '-in[feature/consensus map file]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-out_type[output file type]:type:' \
  '-rt_tolerance[RT tolerance in seconds]:tolerance:' \
  '-mz_tolerance[m/z tolerance]:tolerance:' \
  '-mz_measure[unit for mz_tolerance]:unit:(ppm Da)' \
  '-mz_reference[source of m/z values]:source:(precursor peptide)' \
  '-ignore_charge[assign ID regardless of charge state match]' \
  '-feature:use_centroid_rt[use feature centroid RT]' \
  '-feature:use_centroid_mz[use feature centroid m/z]' \
  '-consensus:use_subelements[match using sub-feature RT and m/z]' \
  '-consensus:annotate_ids_with_subelements[store sub-feature map index in peptide ID]' \
  '-spectra:in[MS run file for annotating unidentified spectra]:mzml file:_files' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
