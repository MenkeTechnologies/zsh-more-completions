_lapdev-cli() {
    case "$service" in
        lapdev-cli)
            _lapdev_cli_main "$@"
            ;;
        lapdev-ws|lapdev-guest-agent|lapdev-kube-manager)
            _lapdev_daemon_main "$@"
            ;;
    esac
}

_lapdev_cli_main() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
        '--log-dir=[directory for lapdev-cli log files]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ld_cmds=(
                'login:authenticate with Lapdev (browser-based OAuth)'
                'logout:sign out (delete token from OS keychain)'
                'whoami:show current session info'
                'devbox:devbox commands'
            )
            _describe -t commands 'lapdev-cli command' _ld_cmds && ret=0
            ;;
        args)
            case $words[1] in
                login)
                    _arguments \
                        '--device-name=[device name (defaults to hostname)]:name:' \
                        '--api-host=[Lapdev API host e.g. app.lap.dev]:host:' \
                        '--api-url=[Lapdev API host (alias of --api-host)]:host:' && ret=0
                    ;;
                logout|whoami)
                    _arguments \
                        '--api-host=[Lapdev API host]:host:' \
                        '--api-url=[Lapdev API host (alias)]:host:' && ret=0
                    ;;
                devbox)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'devbox sub-command' \
                          '(connect\:"connect to Lapdev devbox + establish port forwarding tunnels")' && ret=0
                    else
                        _arguments \
                            '--api-host=[Lapdev API host]:host:' \
                            '--api-url=[Lapdev API host (alias)]:host:' && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_lapdev_daemon_main() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--config=[path to config file]:config:_files' \
        '--bind=[bind address]:addr:' \
        '--port=[bind port]:port:' \
        '--log-level=[log level]:level:(trace debug info warn error)'
}

_lapdev-cli "$@"
