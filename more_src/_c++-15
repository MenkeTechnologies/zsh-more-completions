#compdef c++-15

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-pass-exit-codes[exit with highest error code from a phase]' \
  '(- *)--help[show help]' \
  '--target-help[show target-specific options]' \
  '*--help=[show specific option types]:type:(common optimizers params target warnings)' \
  '(- *)--version[show version]' \
  '-dumpspecs[show built-in spec strings]' \
  '-dumpversion[show compiler version]' \
  '-dumpmachine[show target machine]' \
  '*-D+[define macro]:macro[=value]:' \
  '*-U+[undefine macro]:macro:' \
  '*-I+[add include directory]:dir:_files -/' \
  '*-L+[add library directory]:dir:_files -/' \
  '*-l+[link library]:lib:' \
  '-o+[output file]:file:_files' \
  '-c[compile only]' \
  '-S[assembly only]' \
  '-E[preprocess only]' \
  '-g[generate debug info]' \
  '-O+[optimization level]:level:(0 1 2 3 s g fast)' \
  '-Wall[enable all warnings]' \
  '-Wextra[enable extra warnings]' \
  '-Werror[treat warnings as errors]' \
  '-pedantic[strict standards]' \
  '-std=[language standard]:std:' \
  '-shared[generate shared object]' \
  '-static[link statically]' \
  '-pthread[enable pthread support]' \
  '-fPIC[position-independent code]' \
  '-fopenmp[enable OpenMP]' \
  '-march=[target architecture]:arch:' \
  '-mtune=[tune for architecture]:arch:' \
  '-v[verbose]' \
  '*:source file:_files -g "*.(c|cc|cpp|cxx|h|hpp|hxx|s|S|o|a)"' && ret=0

return ret
