#compdef todoist
# Documentation: https://github.com/sachaos/todoist
# Reference accessed: 2026-05-21
# Verified: upstream README global options + subcommand flags.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--color[colorize output]' \
  '--csv[output as CSV]' \
  '--debug[output logs]' \
  '--header[output with header]' \
  '--namespace[show parent task like namespace]' \
  '--indent[show children indented]' \
  '--project-namespace[show parent project like namespace]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'list:show all tasks (l)'
      'show:show task detail'
      'add:add a task (a)'
      'modify:modify a task (m)'
      'close:close a task (c)'
      'reopen:reopen a closed task'
      'delete:delete a task (d)'
      'completed-list:show completed tasks (c-l/cl, premium)'
      'labels:show all labels'
      'projects:show all projects'
      'sections:manage sections'
      'karma:show karma'
      'sync:sync cache (s)'
      'quick:quick add a task (q)'
    )
    _describe -t commands 'todoist command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      list|l)
        _arguments -s -S \
          '(-f --filter)'{-f,--filter}'[filter expression]:filter:' \
          '(-p --priority)'{-p,--priority}'[sort by priority]' \
          '(-r --remote)'{-r,--remote}'[run filter on Todoist servers]' \
          '--limit=[cap results]:n:' && ret=0
        ;;
      add|a)
        _arguments -s -S \
          '(-p --priority)'{-p,--priority}'[priority 1-4]:priority:(1 2 3 4)' \
          '(-L --label-names)'{-L,--label-names}'[label names]:labels:' \
          '(-P --project-id)'{-P,--project-id}'[project ID]:id:' \
          '(-N --project-name)'{-N,--project-name}'[project name]:name:' \
          '(-d --date)'{-d,--date}'[due date]:date:' \
          '(-r --reminder)'{-r,--reminder}'[reminder]:reminder:' \
          '--section-id=[section ID]:id:' \
          '--section-name=[section name]:name:' \
          '--description=[description]:desc:' \
          '--deadline=[deadline YYYY-MM-DD]:date:' && ret=0
        ;;
      modify|m)
        _arguments -s -S \
          '(-c --content)'{-c,--content}'[content]:content:' \
          '(-p --priority)'{-p,--priority}'[priority 1-4]:priority:(1 2 3 4)' \
          '(-L --label-names)'{-L,--label-names}'[label names]:labels:' \
          '(-P --project-id)'{-P,--project-id}'[project ID]:id:' \
          '(-N --project-name)'{-N,--project-name}'[project name]:name:' \
          '(-d --date)'{-d,--date}'[due date]:date:' \
          '--section-id=[section ID]:id:' \
          '--section-name=[section name]:name:' \
          '--description=[description]:desc:' \
          '--deadline=[deadline YYYY-MM-DD]:date:' && ret=0
        ;;
      show)
        _arguments -s -S \
          '(-o --browse)'{-o,--browse}'[open URLs when contained]' && ret=0
        ;;
    esac
    ;;
esac
return ret
