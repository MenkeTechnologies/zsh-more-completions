#compdef argv0
# _argv0 — DJB ucspi-tcp argv0 (exec program with argv[0] forced to realname; useful for daemontools run-scripts where the underlying program inspects argv[0])
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: argv0.c on tip; positional only.

_argv0() {
    _arguments \
        '1:realname:' \
        '2:program:_command_names -e' \
        '*::args:'
}

_argv0 "$@"
