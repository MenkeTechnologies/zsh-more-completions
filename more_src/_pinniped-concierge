#compdef pinniped-concierge
# _pinniped-concierge — Pinniped Concierge cluster-side identity server (vmware-tanzu/pinniped)
# upstream: https://github.com/vmware-tanzu/pinniped
# Flags from internal/concierge/server/server.go addCommandlineFlagsToCommand() on tip.

_pinniped-concierge() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c,--config=}'[Concierge configuration file]:file:_files -g "*.(yml|yaml)(-.)"' \
        '--downward-api-path=[directory containing Kubernetes Downward API files]:dir:_files -/' \
        '-v[klog verbosity level]:n:'
}

_pinniped-concierge "$@"
