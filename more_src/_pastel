#compdef pastel

# Zsh completion for pastel - command-line tool to generate, convert, and manipulate colors

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'color:Display an overview of a given color'
  'list:Print a list of available color names'
  'pick:Print a list of colors that have been picked interactively'
  'random:Generate a list of random colors'
  'distinct:Generate a list of visually distinct colors'
  'mix:Mix two colors in the given color space'
  'colorize:Colorize words in a text'
  'paint:Paint a character with foreground and background color'
  'gradient:Generate a gradient from one color to another'
  'format:Convert a color to the given format'
  'saturate:Increase the saturation of a color by the given amount'
  'desaturate:Decrease the saturation of a color by the given amount'
  'lighten:Lighten the color by the amount'
  'darken:Darken the color by the amount'
  'rotate:Rotate the hue of a color'
  'complement:Get the complementary color'
  'gray:Generate a gray tone from a number between 0.0 and 1.0'
  'to-gray:Completely desaturate a color'
  'textcolor:Get a readable text color for the given background'
  'sort-by:Sort colors by the given property'
  'unique:Remove duplicate colors from a list'
  'count:Count the number of colors'
  'convert:Convert a color to the given format'
  'set:Set properties of a color'
  'help:Print help'
)

_arguments -s -S \
  '(-m --color-mode)'{-m,--color-mode}'[color mode for output]:mode:(24bit 8bit ansi off)' \
  '(-f --force-color)'{-f,--force-color}'[always emit colored output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      format|convert)
        _arguments \
          ':format:(hex html rgb hsl hsv lch lab grey ansi ansi-stream)' \
          '*:color:' && ret=0
        ;;
      mix|gradient)
        _arguments \
          '--colorspace[color space for mixing]:cs:(Lab LCh HSL sRGB)' \
          '--number[number of colors in gradient]:N:' \
          '*:color:' && ret=0
        ;;
      sort-by)
        _arguments \
          ':field:(hue chroma lightness saturation value red green blue luma random)' \
          '--reverse[sort in reverse order]' \
          '*:color:' && ret=0
        ;;
      saturate|desaturate|lighten|darken|rotate)
        _arguments \
          ':amount:' \
          '*:color:' && ret=0
        ;;
      random)
        _arguments \
          '-n[number of random colors]:N:' \
          '--strategy[strategy for random colors]:strategy:(vivid pastel dark light)' \
          && ret=0
        ;;
      distinct)
        _arguments \
          ':count:' \
          '--metric[distance metric]:metric:(CIE76 CIEDE2000)' \
          '--print-minimal-distance[print the minimal distance between colors]' \
          && ret=0
        ;;
      list)
        _arguments \
          '--sort[sort colors by]:key:(name hue chroma lightness saturation value red green blue luma random)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
