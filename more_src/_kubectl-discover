#compdef kubectl-discover
# kubectl-discover (krew plugin): discover available API resources
# https://github.com/kebab-mai-haddi/kubectl-discover

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--cached[use cached discovery information]' \
  '--api-group=[filter by API group]:group' \
  '--verbs=[filter by supported verbs]:verb' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table wide name)' \
  '--no-headers[do not print headers]' \
  '*:search term'
