#compdef nebula-console

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(-addr -address)'{-addr=,-address=}'[graphd host]:host:_hosts' \
  '(-P -port)'{-P=,-port=}'[graphd port]:port:' \
  '(-u -user)'{-u=,-user=}'[username]:user:_users' \
  '(-p -password)'{-p=,-password=}'[password]:password:' \
  '(-t -timeout)'{-t=,-timeout=}'[connection timeout in ms]:ms:' \
  '(-e -eval)'{-e=,-eval=}'[execute single nGQL statement and exit]:stmt:' \
  '(-f -file)'{-f=,-file=}'[execute nGQL from file and exit]:file:_files' \
  '-enable_ssl[enable TLS]' \
  '-ssl_root_ca_path=[CA cert path]:file:_files' \
  '-ssl_cert_path=[client cert path]:file:_files' \
  '-ssl_private_key_path=[client key path]:file:_files' \
  '-ssl_insecure_skip_verify[skip TLS verification]'
