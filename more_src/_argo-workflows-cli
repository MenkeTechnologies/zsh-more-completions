#compdef argo-workflows-cli
# _argo-workflows-cli — Argo Workflows Kubernetes-native workflow engine CLI alias (argoproj team, Go); cobra
# upstream: https://github.com/argoproj/argo-workflows

_argo-workflows-cli() {
    local -a sub=(
        'archive:archive commands'
        'auth:auth commands'
        'auth token:get auth token'
        'cluster-template:cluster workflow templates'
        'cluster-template create:create cluster template'
        'cluster-template get:get cluster template'
        'cluster-template list:list cluster templates'
        'cluster-template delete:delete cluster template'
        'cluster-template update:update cluster template'
        'completion:generate completion'
        'cp:copy artifacts'
        'cron:cron workflows'
        'cron create:create cron workflow'
        'cron delete:delete cron workflow'
        'cron get:get cron workflow'
        'cron list:list cron workflows'
        'cron suspend:suspend cron'
        'cron resume:resume cron'
        'cron update:update cron workflow'
        'cron lint:lint cron workflow'
        'delete:delete workflow'
        'executor-plugin:plugin commands'
        'get:get workflow'
        'lint:lint workflow file'
        'list:list workflows'
        'logs:show logs'
        'node:node commands'
        'node set:set node status'
        'plugin:plugin commands'
        'plugin list:list plugins'
        'plugin install:install plugin'
        'plugin uninstall:uninstall plugin'
        'resubmit:resubmit workflow'
        'resume:resume workflow'
        'retry:retry workflow'
        'server:start API server'
        'stop:stop workflow'
        'submit:submit workflow'
        'suspend:suspend workflow'
        'template:workflow templates'
        'template create:create template'
        'template delete:delete template'
        'template get:get template'
        'template list:list templates'
        'template lint:lint template'
        'template update:update template'
        'terminate:terminate workflow'
        'version:show version'
        'wait:wait for completion'
        'watch:watch workflow'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--context=+[context]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--user=+[user]:_users' \
        '--token=+[token]:str:' \
        '--insecure-skip-tls-verify[skip tls verify]' \
        '--cluster=+[cluster]:str:' \
        '--server=+[server URL]:url:_urls' \
        '--argo-base-href=+[href]:str:' \
        '--secure=+[bool]:b:(true false)' \
        '--instanceid=+[id]:str:' \
        '--gloglevel=+[level]:n:' \
        '--loglevel=+[level]:l:(debug info warn error)' \
        '-o+[output format]:f:(json yaml name wide short tsv)' \
        '--output=+[output format]:f:(json yaml name wide short tsv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'argo subcommand' sub ;;
        args)
            case $words[1] in
                submit|lint|template|template:create|template:lint|cron|cron:create|cron:lint) _arguments \
                    '--from=+[from]:str:' \
                    '--name=+[name]:str:' \
                    '--generate-name=+[prefix]:str:' \
                    '--entrypoint=+[entrypoint]:str:' \
                    '--parameter=+[name=value]:str:' \
                    '-p+[name=value]:str:' \
                    '--parameter-file=+[file]:file:_files' \
                    '-f+[file]:file:_files' \
                    '--labels=+[labels]:str:' \
                    '-l+[labels]:str:' \
                    '--namespace=+[namespace]:str:' \
                    '--node-field-selector=+[selector]:str:' \
                    '--strict[strict]' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--wait[wait]' \
                    '--dry-run[dry run]' \
                    '--server-dry-run[server dry run]' \
                    '*:file:_files -g "*.{yaml,yml,json}"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-workflows-cli "$@"
