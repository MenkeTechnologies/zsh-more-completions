#compdef CrosscheckFingerprints
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/fingerprint/CrosscheckFingerprints.java
# Picard: checks that all data in the set of input files appear to come from the same individual

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*'{-I,--INPUT}'=[input files or lists of files to compare]:file:_files' \
  '--INPUT_INDEX_MAP=[map input files to index files]:file:_files' \
  '--REQUIRE_INDEX_FILES=[require presence of index files]:b:(true false)' \
  '--INPUT_SAMPLE_MAP=[map input sample names to comparison names]:file:_files' \
  '--INPUT_SAMPLE_FILE_MAP=[map comparison samples to source files]:file:_files' \
  '*'{-SI,--SECOND_INPUT}'=[second set of input files to compare]:file:_files' \
  '--SECOND_INPUT_INDEX_MAP=[map second input files to index files]:file:_files' \
  '--SECOND_INPUT_SAMPLE_MAP=[map second input sample names]:file:_files' \
  '--SAMPLE_INDIVIDUAL_MAP=[associate samples with individuals]:file:_files' \
  '--CROSSCHECK_MODE=[comparison strategy]:m:(CHECK_SAME_SAMPLE CHECK_ALL_OTHERS)' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output metrics file]:file:_files' \
  '(-MO --MATRIX_OUTPUT)'{-MO,--MATRIX_OUTPUT}'=[output matrix of LOD scores]:file:_files' \
  '(-H --HAPLOTYPE_MAP)'{-H,--HAPLOTYPE_MAP}'=[file of SNPs in high-LD blocks for fingerprinting]:file:_files' \
  '(-LOD --LOD_THRESHOLD)'{-LOD,--LOD_THRESHOLD}'=[match/mismatch threshold]:n:' \
  '--CROSSCHECK_BY=[basic comparison unit]:c:(READGROUP LIBRARY SAMPLE FILE)' \
  '--NUM_THREADS=[number of threads]:n:' \
  '--CALCULATE_TUMOR_AWARE_RESULTS=[enable tumor-aware LOD calculations]:b:(true false)' \
  '--ALLOW_DUPLICATE_READS=[permit duplicate reads]:b:(true false)' \
  '--GENOTYPING_ERROR_RATE=[assumed genotyping error rate]:n:' \
  '--OUTPUT_ERRORS_ONLY=[report only unexpected groups]:b:(true false)' \
  '--EXPECT_ALL_GROUPS_TO_MATCH=[expect all groups to match]:b:(true false)' \
  '--EXIT_CODE_WHEN_MISMATCH=[return code on mismatch]:n:' \
  '--EXIT_CODE_WHEN_NO_VALID_CHECKS=[return code when no valid checks]:n:' \
  '--LOSS_OF_HET_RATE=[loss of heterozygosity rate in tumor]:n:' \
  '--TEST_INPUT_READABILITY=[check readability of input files]:b:(true false)' \
  '(-R --REFERENCE_SEQUENCE)'{-R,--REFERENCE_SEQUENCE}'=[reference sequence file]:file:_files' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
