#compdef clusterpediactl
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'apply:apply a resource configuration'
  'delete:delete a resource'
  'get:get resources across clusters'
  'describe:describe a resource'
  'create:create a resource'
  'edit:edit a resource'
  'plugin:manage clusterpedia kubectl plugins'
  'version:show version information'
  'help:show help for a command'
)
_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:kubeconfig:_files' \
  '--cluster=[specify target cluster]:cluster:' \
  '--all-clusters[operate across all clusters]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0
case $state in
  command)
    _describe -t commands 'clusterpediactl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      get)
        local -a get_resources=(
          'resources:get synchronized resources'
          'clustersyncresources:get cluster sync resource configurations'
          'pediaclusters:get registered pedia clusters'
        )
        _arguments -s -S -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '--cluster=[specify target cluster]:cluster:' \
          '--all-clusters[get from all clusters]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(json yaml wide)' \
          '1:resource:->get_resource' && ret=0
        case $state in
          get_resource)
            _describe -t get-resources 'resource type' get_resources && ret=0
            ;;
        esac
        ;;
      apply)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --filename)'{-f,--filename}'=[file to apply]:file:_files' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource type:' \
          '2:resource name:' && ret=0
        ;;
      describe)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--cluster=[specify target cluster]:cluster:' \
          '1:resource type:' \
          '2:resource name:' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --filename)'{-f,--filename}'=[file to create from]:file:_files' && ret=0
        ;;
      edit)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:resource type:' \
          '2:resource name:' && ret=0
        ;;
      plugin)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:(apply delete get describe create edit plugin version)' && ret=0
        ;;
    esac
    ;;
esac
return ret
