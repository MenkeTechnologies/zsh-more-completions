#compdef flip-link
# Documentation: https://man.archlinux.org/search?q=flip-link
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1:path to Flip-Link script:_files' \
  '*::linker arguments: _default'
