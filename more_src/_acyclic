#compdef acyclic
# Documentation: man acyclic(1) (graphviz)
# Source: GraphViz acyclic — make a directed graph acyclic by reversing edges.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n[no output; return value reflects acyclicity]' \
    '-v[print whether graph is acyclic / cyclic / undirected]' \
    '-o+[output file]:file:_files' \
    '(- *)-?[show usage]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
