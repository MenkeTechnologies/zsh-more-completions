#compdef zcbor
# Documentation: https://github.com/NordicSemiconductor/zcbor/blob/main/README.md
# zcbor - CBOR code generation and data validation/conversion from CDDL

local ret=1
local context state line
typeset -A opt_args

_zcbor_cmds() {
  local -a cmds
  cmds=(
    'code:generate C code from a CDDL description'
    'validate:validate a data file against a CDDL description'
    'convert:validate and convert data between CBOR/YAML/JSON/C'
    'migrate:migrate generated code to a newer zcbor version'
  )
  _describe -t commands 'zcbor command' cmds
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :_zcbor_cmds' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $line[1] in
      code)
        _arguments -s -S \
          '*'{-c,--cddl}'[CDDL schema file]:file:_files' \
          '*'{-t,--entry-types}'[types to expose in the generated API]:types:' \
          '(-d --decode)'{-d,--decode}'[generate decoding code]' \
          '(-e --encode)'{-e,--encode}'[generate encoding code]' \
          '--output-cmake=[path for generated CMake file]:file:_files' \
          {--output-c,--oc}'=[path for generated C source file]:file:_files' \
          {--output-h,--oh}'=[path for generated header file]:file:_files' \
          {--output-h-types,--oht}'=[path for types header file]:file:_files' \
          '--copy-sources[copy non-generated zcbor source files to output]' \
          {--default-max-qty,--dq}'=[default maximum number of repetitions]:qty:' \
          '(-b --default-bit-size)'{-b,--default-bit-size}'[default integer bit width]:bits:(8 16 32 64)' \
          '--include-prefix=[path prefix for include statements]:prefix:' \
          '(-s --short-names)'{-s,--short-names}'[shorten generated struct member names]' \
          '--time-header[add current timestamp to generated files]' \
          '--git-sha-header[add zcbor git SHA to generated files]' \
          '--file-header=[custom header comment string or file]:header:' \
          '--defines[generate defines for magic numbers]' \
          '--no-prelude[exclude the standard CDDL prelude]' \
          '--unordered-maps[generate code for maps with unknown element order]' \
          '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
          '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '*'{-c,--cddl}'[CDDL schema file]:file:_files' \
          '(-i --input)'{-i,--input}'[input data file]:file:_files' \
          '(-t --entry-type)'{-t,--entry-type}'[CDDL type to validate against]:type:' \
          '--input-as=[input data format]:format:(yaml json cbor cborhex)' \
          {--default-max-qty,--dq}'=[default maximum number of repetitions]:qty:' \
          '--yaml-compatibility[convert CBOR-only values to YAML-compatible form]' \
          '--no-prelude[exclude the standard CDDL prelude]' \
          '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
          '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '*'{-c,--cddl}'[CDDL schema file]:file:_files' \
          '(-i --input)'{-i,--input}'[input data file]:file:_files' \
          '(-t --entry-type)'{-t,--entry-type}'[CDDL type for validation]:type:' \
          '(-o --output)'{-o,--output}'[output data file]:file:_files' \
          '--input-as=[input data format]:format:(yaml json cbor cborhex)' \
          '--output-as=[output data format]:format:(yaml json cbor cborhex c_code)' \
          '--c-code-var-name=[variable name for C code output]:name:' \
          '--c-code-columns=[bytes per line in C array]:columns:' \
          {--default-max-qty,--dq}'=[default maximum number of repetitions]:qty:' \
          '--yaml-compatibility[enable CBOR-YAML/JSON compatibility conversions]' \
          '--output-canonical[use canonical CBOR encoding for output]' \
          '--no-prelude[exclude the standard CDDL prelude]' \
          '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
          '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' && ret=0
        ;;
    esac
    ;;
esac

return ret
