#compdef flif
# Documentation: https://github.com/FLIF-hub/FLIF/blob/master/doc/flif.1
# FLIF: encode/decode/transcode Free Lossless Image Format files

local ret=1

_arguments -s -S \
  '(-e --encode)'{-e,--encode}'[encode image to FLIF]' \
  '(-d --decode)'{-d,--decode}'[decode FLIF to another format]' \
  '(-t --transcode)'{-t,--transcode}'[transcode FLIF to FLIF with new settings]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite existing output]' \
  '(-c --no-crc)'{-c,--no-crc}'[do not add CRC check]' \
  '(-p --no-color-profile)'{-p,--no-color-profile}'[strip color profile]' \
  '(-m --no-metadata)'{-m,--no-metadata}'[strip Exif/XMP metadata]' \
  '(-k --keep-palette)'{-k,--keep-palette}'[preserve PNG palette]' \
  '(-q --quality)'{-q+,--quality=}'[quality percent for progressive decode]:percent' \
  '(-s --scale)'{-s+,--scale=}'[decode scaled-down by power-of-two factor]:factor' \
  '(-r --resize)'{-r+,--resize=}'[decode to fit dimensions]:WxH' \
  '(-i --identify)'{-i,--identify}'[show header info without decoding]' \
  '(-E --effort)'{-E+,--effort=}'[compression effort 0-100]:effort' \
  '(-I --interlace)'{-I,--interlace}'[force interlaced/progressive]' \
  '(-N --no-interlace)'{-N,--no-interlace}'[force non-interlaced]' \
  '(-Q --lossy)'{-Q+,--lossy=}'[lossy encoding at quality]:quality' \
  '(-U --adaptive)'{-U,--adaptive}'[adaptive lossy via saliency map]' \
  '(-K --keep-invisible-rgb)'{-K,--keep-invisible-rgb}'[keep RGB of transparent pixels]' \
  '(-P --max-palette-size)'{-P+,--max-palette-size=}'[color palette threshold]:size' \
  '(-A --force-color-buckets)'{-A,--force-color-buckets}'[enable color bucket transform]' \
  '(-B --no-color-buckets)'{-B,--no-color-buckets}'[disable color bucket transform]' \
  '(-C --no-channel-compact)'{-C,--no-channel-compact}'[disable channel compaction]' \
  '(-Y --no-ycocg)'{-Y,--no-ycocg}'[disable YCoCg color transform]' \
  '(-W --no-subtract-green)'{-W,--no-subtract-green}'[disable green channel subtraction]' \
  '(-G --guess)'{-G+,--guess=}'[pixel prediction methods]:methods' \
  '(-H --invisible-guess)'{-H+,--invisible-guess=}'[prediction for invisible pixels]:method' \
  '(-J --chroma-subsample)'{-J,--chroma-subsample}'[JPEG-like 4:2:0 chroma subsampling]' \
  '(-R --maniac-repeats)'{-R+,--maniac-repeats=}'[MANIAC tree learning iterations]:n' \
  '(-T --maniac-threshold)'{-T+,--maniac-threshold=}'[MANIAC split threshold in bits]:bits' \
  '(-D --maniac-divisor)'{-D+,--maniac-divisor=}'[MANIAC counter divisor]:n' \
  '(-M --maniac-min-size)'{-M+,--maniac-min-size=}'[MANIAC pruning threshold]:n' \
  '(-X --chance-cutoff)'{-X+,--chance-cutoff=}'[entropy coding chance limits]:n' \
  '(-Z --chance-alpha)'{-Z+,--chance-alpha=}'[chance adaptation rate]:n' \
  '(-F --frame-delay)'{-F+,--frame-delay=}'[animation frame duration ms]:ms' \
  '(-L --max-frame-lookback)'{-L+,--max-frame-lookback=}'[max frames to reference]:n' \
  '(-S --no-frame-shape)'{-S,--no-frame-shape}'[disable frame shape transform]' \
  '*:file:_files' && ret=0

return ret
