# ironic-rootwrap: oslo.rootwrap privileged operations helper
# Usage: ironic-rootwrap CONFIG_FILE COMMAND [ARGS...]
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:config file:_files' \
  '*:::command:_normal' && ret=0
return ret
