#compdef teamd
# _teamd — libteam teamd (userspace daemon orchestrating the kernel team driver for runner-based link aggregation: roundrobin/activebackup/loadbalance/lacp/broadcast/random; -c JSON config or -f file, -d daemonize, -g debug)
# upstream: https://github.com/jpirko/libteam
# Flags from libteam teamd/teamd.c on tip.

_teamd() {
    _arguments \
        '-d[daemonize]' \
        '-D[force JSON-as-debug]' \
        '-g[debug messages]' \
        '-k[kill running teamd for the same team]' \
        '-l+[list runners]' \
        '-N[no network activity (load-test runners)]' \
        '-r+[run for N seconds then quit]:seconds:' \
        '-t+[team interface name]:teamdev:' \
        '-c+[JSON config]:json:' \
        '-f+[JSON config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-Z+[zmq socket addr]:zmqsock:' \
        '-U+[unix socket path]:file:_files' \
        '-D+[dbus enabled]'
}

_teamd "$@"
