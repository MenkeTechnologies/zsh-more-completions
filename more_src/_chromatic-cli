#compdef chromatic-cli
# Documentation: https://www.chromatic.com/docs/cli
# Reference accessed: 2026-05-23
# Verified: npx chromatic --help (chromatic-cli bin).

# Zsh completion for chromatic-cli - Chromatic visual testing CLI

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-t --project-token)'{-t,--project-token=}'[Chromatic project token]:token:'   '(-b --build-script-name)'{-b,--build-script-name=}'[Storybook build npm script]:script:'   '--build-command=[Storybook build command]:command:'   '(-o --output-dir)'{-o,--output-dir=}'[Storybook output directory]:dir:_directories'   '(-d --storybook-build-dir)'{-d,--storybook-build-dir=}'[prebuilt Storybook directory]:dir:_directories'   '--auto-accept-changes[auto-accept visual changes]'   '--branch-name=[override branch name]:branch:'   '--ci[mark build as CI]'   '(-c --config-file)'{-c,--config-file=}'[config file path]:file:_files'   '--exit-once-uploaded[exit after publish]'   '--exit-zero-on-changes[exit 0 on visual changes]'   '--only-changed[run TurboSnap on changed stories]'   '--debug[debug logging]'   '*::args:' && ret=0

return ret
