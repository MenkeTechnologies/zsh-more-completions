#compdef afl-vcrash
# Documentation: https://github.com/rc0r/afl-utils
# Verify that afl-fuzz crash samples actually crash the target (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --filelist)'{-f,--filelist}'=[write non-crashing sample file names into a file]:file:_files' \
  '(-j --threads)'{-j,--threads}'=[number of threads for parallel verification]:threads' \
  '(-q --quiet)'{-q,--quiet}'[suppress output of non-crashing sample file names]' \
  '(-r --remove)'{-r,--remove}'[remove crash samples that do not lead to crashes]' \
  '(-t --timeout)'{-t,--timeout}'=[timeout in seconds before killing verification]:seconds' \
  '1:collection dir:_files -/' \
  '*:target command:_files' && ret=0

return ret
