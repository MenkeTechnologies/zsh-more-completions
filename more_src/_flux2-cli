#compdef flux2-cli fluxcd
# _flux2-cli — Flux v2 GitOps toolkit for Kubernetes CLI alias (fluxcd team, Go); cobra
# upstream: https://github.com/fluxcd/flux2

_flux2-cli() {
    local -a sub=(
        'bootstrap:bootstrap commands'
        'bootstrap github:bootstrap from GitHub'
        'bootstrap gitlab:bootstrap from GitLab'
        'bootstrap bitbucket-server:bootstrap from Bitbucket Server'
        'bootstrap git:bootstrap from generic git'
        'check:check status'
        'check pre:pre-bootstrap check'
        'completion:generate completion'
        'create:create resources'
        'create kustomization:create kustomization'
        'create source:create source'
        'create source git:create git source'
        'create source helm:create helm source'
        'create source bucket:create bucket source'
        'create source oci:create oci source'
        'create helmrelease:create helm release'
        'create alert:create alert'
        'create alertprovider:create alert provider'
        'create receiver:create receiver'
        'create image:create image policy/repository'
        'create image policy:create image policy'
        'create image repository:create image repository'
        'create image update:create image update'
        'create tenant:create tenant'
        'create secret:create secret'
        'create secret git:create git secret'
        'create secret helm:create helm secret'
        'create secret oci:create oci secret'
        'create secret tls:create TLS secret'
        'delete:delete resources'
        'delete kustomization:delete kustomization'
        'delete source git:delete git source'
        'delete source helm:delete helm source'
        'delete source bucket:delete bucket source'
        'delete source oci:delete oci source'
        'delete helmrelease:delete helm release'
        'delete alert:delete alert'
        'delete alertprovider:delete alert provider'
        'delete receiver:delete receiver'
        'delete image:delete image resources'
        'export:export resources to YAML'
        'export kustomization:export kustomization'
        'export source:export source'
        'export helmrelease:export helm release'
        'export alert:export alert'
        'get:get resources'
        'get kustomizations:get kustomizations'
        'get sources:get sources'
        'get sources git:get git sources'
        'get sources helm:get helm sources'
        'get sources bucket:get bucket sources'
        'get sources oci:get oci sources'
        'get helmreleases:get helm releases'
        'get alerts:get alerts'
        'get alertproviders:get alert providers'
        'get receivers:get receivers'
        'get images:get image resources'
        'install:install Flux components'
        'logs:show controller logs'
        'reconcile:trigger reconcile'
        'reconcile kustomization:reconcile kustomization'
        'reconcile source:reconcile source'
        'reconcile helmrelease:reconcile helm release'
        'reconcile alert:reconcile alert'
        'reconcile receiver:reconcile receiver'
        'resume:resume suspended resources'
        'suspend:suspend resources'
        'stats:show stats'
        'tree:show tree of objects'
        'trace:trace an object'
        'uninstall:uninstall Flux'
        'version:show version'
        'help:show help'
        'diff:diff manifests'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--context=+[context]:str:' \
        '--kubeconfig=+[file]:file:_files' \
        '--cluster=+[cluster]:str:' \
        '--server=+[server]:str:' \
        '--token=+[token]:str:' \
        '--user=+[user]:_users' \
        '--insecure-skip-tls-verify[skip tls verify]' \
        '--timeout=+[duration]:str:' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flux subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                bootstrap:github) _arguments \
                    '--owner=+[owner]:str:' \
                    '--repository=+[repo]:str:' \
                    '--branch=+[branch]:str:' \
                    '--hostname=+[hostname]:host:_hosts' \
                    '--interval=+[duration]:str:' \
                    '--path=+[path]:str:' \
                    '--personal[personal repo]' \
                    '--private[private repo]' \
                    '--token-auth[token auth]' \
                    '--ssh-key-algorithm=+[algo]:a:(rsa ecdsa ed25519)' \
                    '--ssh-rsa-bits=+[bits]:n:' \
                    '--ssh-ecdsa-curve=+[curve]:c:(p256 p384 p521)' \
                    '--read-write-key[read-write key]' \
                    '--team=+[team]:str:' \
                    '--reconcile[reconcile]' ;;
            esac
            ;;
    esac
}

_flux2-cli "$@"
