#compdef type-coverage

_arguments -s -S \
  '--detail[show detailed type information]' \
  '--at-least[set minimum coverage percentage]:percentage:' \
  '--strict[enable strict mode]' \
  '(-p --project)'{-p,--project}'[path to tsconfig.json]:tsconfig path:_files -g "*.json"' \
  '--ignore-catch[ignore catch clause parameters]' \
  '--cache[enable caching for faster subsequent runs]' \
  '--ignore-files[glob pattern of files to ignore]:pattern:' \
  '--ignore-unread[ignore unread type any]' \
  '--show-relative-path[show relative file paths in output]' \
  '--history-if-not-ci[save history only when not in CI]' \
  '--no-detail-when-failed[suppress details when coverage target not met]' \
  '--update[update the coverage badge in README]' \
  '--ignore-nested[ignore nested any types]' \
  '--ignore-as-assertion[ignore as assertion expressions]' \
  '--ignore-type-assertion[ignore type assertion expressions]' \
  '--ignore-non-null-assertion[ignore non-null assertion expressions]' \
  '--ignore-object[ignore object types]' \
  '--ignore-empty-type[ignore empty type declarations]' \
  '--is[set minimum coverage percentage and fail if not met]:percentage:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:files:_files -g "*.{ts,tsx}"'
