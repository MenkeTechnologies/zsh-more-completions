#compdef grails-shell-cli
# Documentation: https://man.archlinux.org/search?q=grails-shell-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose output]' \
  '--config=[config file]:file:_files' && ret=0

return ret
