#compdef drbdadm drbdmeta drbdsetup
# Documentation: https://man.archlinux.org/search?q=drbdadm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

case $service in
  (drbdadm)
    commands=(
      'attach:attach to lower-level device'
      'detach:detach from lower-level device'
      'connect:connect to peer'
      'disconnect:disconnect from peer'
      'syncer:set syncer parameters'
      'up:run attach + connect'
      'down:run disconnect + detach'
      'primary:make resource primary'
      'secondary:make resource secondary'
      'invalidate:invalidate local data'
      'invalidate-remote:invalidate remote data'
      'pause-sync:pause synchronization'
      'resume-sync:resume synchronization'
      'verify:start online verify'
      'wait-connect:wait for connection'
      'wait-con-int:wait for connection (int)'
      'role:show resource role'
      'cstate:show connection state'
      'dstate:show disk states'
      'status:show status'
      'dump:dump configuration'
      'dump-md:dump metadata'
      'create-md:create metadata'
      'wipe-md:wipe metadata'
      'apply-al:apply activity log'
      'adjust:adjust to config'
      'resize:resize device'
      'check-resize:check device size'
      'new-current-uuid:set new UUID'
      'forget-peer:forget peer'
      'show-gi:show generation IDs'
      'get-gi:get generation IDs'
      'wait-sync:wait for sync done'
      'help:show help'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-d --dry-run)'{-d,--dry-run}'[dry run]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-c --config-file)'{-c+,--config-file=}'[config file]:file:_files -g "*.conf"' \
      '(-t --config-to-test)'{-t+,--config-to-test=}'[test config]:file:_files' \
      '*'{-D,--dry-run}'[dry run]' \
      '(--peer)--peer=[peer]:p:' \
      '(--node-id)--node-id=[node id]:n:' \
      '(-s --drbdsetup)'{-s+,--drbdsetup=}'[drbdsetup path]:file:_files' \
      '(-m --drbdmeta)'{-m+,--drbdmeta=}'[drbdmeta path]:file:_files' \
      '(--stacked)--stacked[stacked]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd) _describe -t cmds 'drbdadm command' commands && ret=0 ;;
      (args) _arguments '*: :' && ret=0 ;;
    esac ;;
  (drbdmeta)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--ignore-sanity-checks[ignore sanity checks]' \
      '--node-id=[node id]:n:' \
      '--peer-max-bio-size=[max bio size]:n:' \
      '--al-stripes=[AL stripes]:n:' \
      '--al-stripe-size-kB=[AL stripe size kB]:n:' \
      '*: :_files' && ret=0 ;;
  (drbdsetup)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '*: :_files' && ret=0 ;;
esac

return ret
