#compdef alphapept
# Documentation: https://github.com/MannLabs/alphapept/blob/master/README.md
# AlphaPept: Python-based proteomics search and quantification pipeline

local ret=1

_arguments -s -S \
  '1:command:((
    database\:"create a database from a fasta file"
    import\:"import and convert raw data to .ms_data.hdf"
    features\:"find features in a .ms_data.hdf file"
    search\:"search and identify features in a .ms_data.hdf file"
    recalibrate\:"recalibrate a .ms_data.hdf file"
    score\:"score PSMs from a .ms_data.hdf file"
    align\:"align multiple .ms_data.hdf files"
    match\:"match-between-runs analysis on multiple files"
    quantify\:"quantify and compare multiple .ms_data.hdf files"
    export\:"export protein table as .csv"
    workflow\:"run the complete AlphaPept workflow"
    gui\:"start the graphical user interface"
  ))' \
  '*::arg:_files' && ret=0

return ret
