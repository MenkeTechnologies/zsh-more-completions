#compdef cf-runagent
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-runagent.html
# Source: cfengine/core cf-runagent/cf-runagent.c — trigger cf-agent runs on remote hosts via cf-serverd.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-b --background)'{-b+,--background=}'[parallelize connections (default 50)]:n:_default' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-n --dry-run)'{-n,--dry-run}'[dry-run, no changes]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-f --file)'{-f+,--file=}'[alternative input file]:file:_files' \
    '(-D --define-class)'{-D+,--define-class=}'[classes to send to remote agent]:classes:_default' \
    '(-s --select-class)'{-s+,--select-class=}'[classes used to select remote agents]:classes:_default' \
    '(-I --inform)'{-I,--inform}'[print basic info about system changes]' \
    '(-o --remote-options)'{-o+,--remote-options=}'[remote options (deprecated)]:opts:_default' \
    '(-x --diagnostic)'{-x,--diagnostic}'[diagnostic (deprecated)]' \
    '(-H --hail)'{-H+,--hail=}'[hail comma-separated hosts]:hosts:_default' \
    '(-i --interactive)'{-i,--interactive}'[enable interactive key trust mode]' \
    '(-t --timeout)'{-t+,--timeout=}'[connection timeout (seconds)]:seconds:_default' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps]' \
    '--ignore-preferred-augments[skip def_preferred.json]' \
    '*--log-modules=[detailed debug logging for module]:module:_default' \
    '--remote-bundles=[bundles to execute on remote agent]:bundles:_default' \
    && ret=0

return ret
