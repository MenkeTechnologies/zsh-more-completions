#compdef getmail_mbox
# Documentation: https://github.com/getmail6/getmail6/blob/master/docs/getmail_mbox.1
# Source: getmail6/getmail6 getmail_mbox — deliver stdin to mbox file (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    {-v,--verbose}'[verbose]' \
    '1:mbox path:_files' \
    && ret=0

return ret
