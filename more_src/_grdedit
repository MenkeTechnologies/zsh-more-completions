#compdef grdedit
# Documentation: https://docs.generic-mapping-tools.org/latest/grdedit.html
# Source: GenericMappingTools/gmt classic-mode grdedit — edit grid header / metadata / coordinates.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[adjust x_inc/y_inc to match domain]' \
    '-C+[control command-history storage]:opts:_default' \
    '-D+[set netCDF names/units/metadata]:opts:_default' \
    '-E+[rotate/flip/transpose grid]:opts:_default' \
    '-G+[output grid file]:file:_files' \
    '-J+[projection (CF-1 georef)]:proj:_default' \
    '-L+[adjust longitude for geographic grids]:opts:_default' \
    '-N+[ASCII/binary node-value replacement file]:file:_files' \
    '-R+[new region west/east/south/north]:region:_default' \
    '-S+[shift grid longitudinally (global geo)]:opts:_default' \
    '-T[toggle gridline ↔ pixel registration]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
