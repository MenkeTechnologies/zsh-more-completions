#compdef x64dbg
# _x64dbg — x64dbg open-source Windows debugger (Mr. eXoDia and contributors); native Windows 64/32-bit debugger with scripting
# upstream: https://github.com/x64dbg/x64dbg

_x64dbg() {
    _arguments \
        '/H[show help]' \
        '/V[show version]' \
        '/EXIT[exit after script]' \
        '/SCRIPT+[script file]:file:_files' \
        '/CMD+[command]:cmd:' \
        '/PID+[attach PID]:pid:_pids' \
        '/DBG[enable debug log]' \
        '*:executable:_files'
}

_x64dbg "$@"
