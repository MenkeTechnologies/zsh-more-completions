#compdef quickspec
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/quickspec.html
# Quickly create a SUMA surface spec file

local ret=1

_arguments -s \
  '*-tn[surface type and name]:type and name' \
  '*-tsn[surface type, state and name]:spec' \
  '*-tsnad[type, state, name, anatomical, domain parent]:spec' \
  '*-tsnadm[tsnad plus node marker file]:spec' \
  '*-tsnadl[tsnad plus label dataset]:spec' \
  '-spec[name of output spec file]:file:_files' \
  '(-h -help)-h[display help]' \
  '(-h -help)-help[display help]' && ret=0

return ret
