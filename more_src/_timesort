#compdef timesort
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss66.html
# SMURF: re-order the time slices in a raw ACSIS data cube into increasing time.

local ret=1

_arguments -s -S \
  'IN=[input NDFs with raw time series]:ndf:_files' \
  'OUT=[output NDFs for sorted data]:ndf:_files' \
  'OUTFILES=[text file listing output NDFs]:file:_files' \
  'NOUT=[output: total NDFs created]:n:' \
  'DETECTORS=[detector names to include/exclude]:detectors:' \
  'DETPURGE=[remove detectors with no good data]:flag:(TRUE FALSE)' \
  'GENVAR=[fill Variance from Tsys values]:flag:(TRUE FALSE)' \
  'LIMITTYPE=[units for SIZELIMIT]:type:(SPECTRA SLICES FILESIZE)' \
  'SIZELIMIT=[max size per output NDF]:size:' \
  'MERGE=[merge NDFs rather than sort independently]:flag:(TRUE FALSE)' \
  'SPECBND=[handling for differing spectral bounds]:method:' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
