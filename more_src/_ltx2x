#compdef ltx2x
# Documentation: https://ctan.org/pkg/ltx2x
# Documentation: https://ctan.math.utah.edu/ctan/tex-archive/support/ltx2x/ltx2x.html
# Reference accessed: 2026-05-27
# Verified: upstream ltx2x.html "Calling LTX2X" usage table (Peter Wilson)

# Zsh completion for ltx2x (LaTeX-to-X auto-tagger).
# Usage: ltx2x [options] input-file output-file

_arguments -s -S \
  '-c[include LaTeX comments in output]' \
  '-f+[command table file]:command table:_files -g "*.ct(-.)"' \
  '-p+[pretty-print with maximum characters per line]:max chars per line:' \
  '-w[collapse contiguous whitespace to single space]' \
  '-D+[directory separator character]:char:' \
  '-P+[path separator characters]:chars:' \
  '-S[enable source-level debugger for EXPRESS-A code]' \
  '-i+[interpreter debug verbosity 1-9]:level:(1 2 3 4 5 6 7 8 9)' \
  '-l+[ltx2x program debug verbosity 1-9]:level:(1 2 3 4 5 6 7 8 9)' \
  '-t[command table processing diagnostics]' \
  '-y+[parser diagnostic level]:level:' \
  '-C[disable interpreter debug during code generation]' \
  '-E[disable interpreter debug during execution]' \
  '1:input file:_files -g "*.(tex|ltx|TEX|LTX)(-.)"' \
  '2:output file:_files'
