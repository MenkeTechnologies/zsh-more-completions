#compdef oxker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d[show timestamps in logs]' \
  '--timestamp[show timestamps in logs]' \
  '-r[remove all containers on exit]' \
  '--remove[remove all containers on exit]' \
  '-g[show all containers including stopped]' \
  '--gui[show all containers including stopped]' \
  '-s+[docker socket path]:socket:_files' \
  '--host=[docker socket path]:socket:_files' \
  '-c+[color of container name]:color:(red green yellow blue magenta cyan white)' \
  '--color=[color of container name]:color:(red green yellow blue magenta cyan white)' \
  '-u+[update interval in ms]:ms:' \
  '--update=[update interval in ms]:ms:' && ret=0

return ret
