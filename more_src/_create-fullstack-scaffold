# Zsh completion for create-fullstack-scaffold - type-safe fullstack app generator

local curcontext="$curcontext" state line ret=1

_arguments -C   '--preset=[production preset]:preset:(fullstack-admin todo-app ecommerce xbrowser-marketplace forum cli-only minimal saas)'   '--dry-run[preview scaffold without writing files]'   '--no-install[skip dependency installation]'   '--output-dir=[output directory]:directory:_directories'   '--current-dir[scaffold into current directory]'   '--help[show help]'   ':project name:' && ret=0

return ret
