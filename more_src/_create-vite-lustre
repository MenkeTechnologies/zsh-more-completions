# Zsh completion for create-vite-lustre - Vite + Lustre + Gleam scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--rolldown[use experimental Rolldown bundler]' \
  '--immediate[run dev mode after scaffold finishes]' \
  '--overwrite[overwrite all files in target directory]' \
  '--template=[Vite template name]:template:(react)' \
  '--bin-gleam=[path to gleam binary]:path:' \
  '--bin-pm=[package manager binary]:manager:(bun npm pnpm yarn)' \
  '--bin-timeout=[command timeout in ms]:ms:' \
  '--log-level=[log level]:level:(info debug trace none)' \
  '--log-time[include date/time in logs]' \
  '--dir-cwd=[root directory for scaffold]:directory:_directories' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
