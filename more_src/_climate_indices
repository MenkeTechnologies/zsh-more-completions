#compdef climate_indices process_climate_indices
# Documentation: https://climate-indices.readthedocs.io/en/latest/
# climate_indices - compute climate indices (SPI, SPEI, PNP, PET, Palmers)

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--index=[indices to compute]:index:(spi spei pnp scaled pet palmers all)' \
  '--periodicity=[process input as monthly or daily values]:periodicity:(monthly daily)' \
  '*--scales=[timestep scales for PNP/SPI/SPEI computation]:scales:' \
  '--calibration_start_year=[initial year of calibration period]:year:' \
  '--calibration_end_year=[final year of calibration period]:year:' \
  '--netcdf_precip=[precipitation NetCDF input file]:file:_files -g "*.nc"' \
  '--var_name_precip=[precipitation variable name]:name:' \
  '--netcdf_temp=[temperature NetCDF input file]:file:_files -g "*.nc"' \
  '--var_name_temp=[temperature variable name]:name:' \
  '--netcdf_pet=[PET NetCDF input file]:file:_files -g "*.nc"' \
  '--var_name_pet=[PET variable name]:name:' \
  '--netcdf_awc=[available water capacity NetCDF input file]:file:_files -g "*.nc"' \
  '--var_name_awc=[available water capacity variable name]:name:' \
  '--output_file_base=[base output file path and name]:base:_files' \
  '--multiprocessing=[multiprocessing mode]:mode:(single all_but_one all)' \
  '--chunksizes=[output file chunksizes]:chunksizes:(none input)' && ret=0

return ret
