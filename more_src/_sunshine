#compdef sunshine

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to config file]:config file:_files' \
  '--creds=[username and password]:username password' \
  '--port=[web UI port]:port' \
  '--name=[hostname to use]:name' \
  '--min-log-level=[minimum log level]:level:(verbose debug info warning error fatal none)' \
  && ret=0

return ret
