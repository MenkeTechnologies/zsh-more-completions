#compdef mimirtool

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'acl:generate auth headers'
  'alertmanager:Mimir Alertmanager operations'
  'analyze:analyze Prometheus/Grafana usage'
  'backfill:backfill blocks into Mimir'
  'bucket-validation:validate object storage'
  'config:configuration tooling'
  'remote-read:remote-read API operations'
  'rules:Mimir ruler operations'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--address=[Mimir address]:url:' \
  '--user=[Mimir user]:user:_users' \
  '--key=[Mimir API key]:key:' \
  '--id=[Mimir tenant id]:id:' \
  '--auth-token=[bearer token]:token:' \
  '*--extra-headers=[extra HTTP header]:header:' \
  '--tls-ca-path=[TLS CA path]:file:_files' \
  '--tls-cert-path=[TLS cert path]:file:_files' \
  '--tls-key-path=[TLS key path]:file:_files' \
  '--tls-insecure-skip-verify[skip TLS verify]' \
  '--enable-experimental-functions[enable experimental PromQL functions]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mimirtool subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (acl)
        _values 'acl action' 'generate-header' && ret=0
        ;;
      (alertmanager)
        _values 'alertmanager action' \
          'get' 'load' 'delete' 'migrate-utf8' 'verify' 'render' && ret=0
        ;;
      (analyze)
        _values 'analyze action' \
          'grafana' 'ruler' 'dashboard' 'rule-file' 'prometheus' && ret=0
        ;;
      (rules)
        _values 'rules action' \
          'list' 'print' 'get' 'delete' 'load' 'delete-namespace' \
          'lint' 'prepare' 'check' 'diff' 'sync' && ret=0
        ;;
      (remote-read)
        _values 'remote-read action' 'stats' 'dump' 'export' && ret=0
        ;;
      (config)
        _values 'config action' 'convert' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' && ret=0
        ;;
    esac
    ;;
esac

return ret
