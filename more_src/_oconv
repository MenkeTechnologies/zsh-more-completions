#compdef oconv
# Documentation: https://floyd.lbl.gov/radiance/man_html/oconv.1.html
# Radiance octree compiler

local ret=1

_arguments -s \
  '-i[add scene input to existing octree]:octree:_files' \
  '-b[specify bounding cube: xmin ymin zmin size]:xmin' \
  '-n[maximum surface set size per voxel]:objlim' \
  '-r[maximum octree resolution]:maxres' \
  '-f[produce a frozen octree]' \
  '-w[suppress warning messages]' \
  '*:scene:_files' && ret=0

return ret
