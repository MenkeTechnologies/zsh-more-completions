#compdef oc-mirror
# Documentation: https://man.archlinux.org/search?q=oc-mirror
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--v1[run legacy oc-mirror v1 binary]' \
  '--v2[run supported oc-mirror v2 code path]' \
  '--cpu-prof[write cpu.prof in cwd]' \
  '--mem-prof[write mem.prof in cwd]' \
  '1:: :((version))' \
  '*:args:_default'
