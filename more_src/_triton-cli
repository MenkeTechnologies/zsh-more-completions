#compdef triton-cli
# Documentation: https://github.com/triton-inference-server/triton_cli
# Triton CLI to create, deploy and profile Triton Inference Server models

local ret=1
local -a state line
local curcontext="$curcontext"

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'import:add a model to the model repository'
      'remove:remove a model from the repository'
      'start:start the Triton Inference Server'
      'stop:stop the running Triton server'
      'status:show Triton server status'
      'infer:run an inference query'
      'profile:benchmark model performance with GenAI-Perf'
      'metrics:show server metrics'
      'config:show or set model configuration'
      'list:list models in the repository'
    )
    _describe -t commands 'triton command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      import)
        _arguments -s -S \
          '(-m --model)'{-m,--model}'=[model name or alias]:model:' \
          '--source=[model location hf:<id> or local:<path>]:source:' \
          '--backend=[inference backend]:backend:(vllm tensorrtllm)' \
          '--repo=[model repository path]:dir:_files -/' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(-m --model)'{-m,--model}'=[model name or all]:model:' \
          '--repo=[model repository path]:dir:_files -/' && ret=0
        ;;
      start)
        _arguments -s -S \
          '--image=[container image URI]:image:' \
          '--frontend=[API frontend type]:frontend:(openai)' \
          '--openai-chat-template-tokenizer=[tokenizer for chat API]:tokenizer:' \
          '--repo=[model repository path]:dir:_files -/' \
          '--mode=[launch mode]:mode:(local docker)' && ret=0
        ;;
      infer)
        _arguments -s -S \
          '(-m --model)'{-m,--model}'=[target model]:model:' \
          '--prompt=[input text for generation]:prompt:' \
          '(-u --url)'{-u,--url}'=[server URL]:url:' && ret=0
        ;;
      profile)
        _arguments -s -S \
          '(-m --model)'{-m,--model}'=[target model]:model:' \
          '--backend=[backend type]:backend:(vllm tensorrtllm)' \
          '--endpoint-type=[API variant]:type:(chat completions kserve)' \
          '(-u --url)'{-u,--url}'=[server URL]:url:' \
          '--streaming[enable streaming mode]' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
