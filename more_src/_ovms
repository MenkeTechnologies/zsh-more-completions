#compdef ovms
# Documentation: https://docs.openvino.ai/2025/model-server/ovms_docs_parameters.html
# OpenVINO Model Server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config_path=[JSON configuration file path]:file:_files' \
  '--model_name=[name to expose the model via gRPC and REST]:name:' \
  '--model_path=[model directory or cloud storage path]:path:_files -/' \
  '--port=[gRPC server port]:port:' \
  '--rest_port=[REST/HTTP server port]:port:' \
  '--grpc_bind_address=[gRPC bind interface address]:addr:' \
  '--rest_bind_address=[REST bind interface address]:addr:' \
  '--grpc_workers=[number of gRPC server instances]:num:' \
  '--rest_workers=[number of HTTP threads]:num:' \
  '--grpc_max_threads=[max gRPC threads]:num:' \
  '--grpc_memory_quota=[gRPC buffer allocation quota]:bytes:' \
  '--grpc_channel_arguments=[gRPC server arguments]:args:' \
  '--batch_size=[batch size integer or auto]:size:' \
  '--shape=[input shape auto, tuple or dict]:shape:' \
  '--layout=[tensor layout target:source]:layout:' \
  '--model_version_policy=[which model versions to serve]:policy:' \
  '--nireq=[internal request queue size]:num:' \
  '--target_device=[inference device]:device:(CPU GPU MULTI HETERO AUTO NPU)' \
  '--plugin_config=[device plugin parameters JSON]:json:' \
  '--precision=[target precision conversion]:precision:(fp32 fp16 int8 uint8)' \
  '--mean=[preprocessing mean value]:mean:' \
  '--scale=[preprocessing scale divisor]:scale:' \
  '--color_format=[image color format]:format:(RGB BGR GRAY NV12 NV12_2 I420 I420_3)' \
  '--cpu_extension=[custom layers library path]:path:_files' \
  '--cache_dir=[model cache storage location]:dir:_files -/' \
  '--file_system_poll_wait_seconds=[config change detection interval]:sec:' \
  '--metrics_enable[enable metrics endpoint]' \
  '--metrics_list=[comma-separated metric names]:list:' \
  '--log_level=[logging level]:level:(DEBUG INFO ERROR)' \
  '--log_path=[log file path]:path:_files' \
  '--allow_credentials[enable CORS credentials]' \
  '--allowed_headers=[CORS allowed headers]:headers:' \
  '--allowed_methods=[CORS allowed methods]:methods:' \
  '--allowed_origins=[CORS allowed origins]:origins:' \
  '--api_key_file=[API key file for v3 endpoints]:path:_files' \
  '--allowed_local_media_path=[directory for local image inclusion]:dir:_files -/' \
  '--allowed_media_domains=[permitted media URL sources]:domains:' && ret=0

return ret
