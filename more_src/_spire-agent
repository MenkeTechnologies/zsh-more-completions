#compdef spire-agent

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run the SPIRE agent'
  'api:workload API helpers'
  'healthcheck:check agent health'
  'validate:validate an agent config file'
  'logger:adjust runtime log level'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'spire-agent command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '-config=[config file]:file:_files -g "*.conf"' \
          '-trustDomain=[trust domain]:domain:' \
          '-serverAddress=[SPIRE server address]:address:_hosts' \
          '-serverPort=[SPIRE server port]:port:' \
          '-dataDir=[data dir]:dir:_files -/' \
          '-logFile=[log file]:file:_files' \
          '-logFormat=[log format]:format:(text json)' \
          '-logLevel=[log level]:level:(debug info warn error)' \
          '-logSourceLocation[include source file/line]' \
          '-socketPath=[workload API socket path]:file:_files' \
          '-adminSocketPath=[admin socket path]:file:_files' \
          '-trustBundle=[trust bundle file]:file:_files' \
          '-trustBundleUrl=[trust bundle URL]:url:' \
          '-joinToken=[node join token]:token:' \
          '-expandEnv[expand env vars in config]' && ret=0 ;;
      (api)
        local -a api_subs=(
          'fetch:fetch SVIDs from workload API'
          'validate:validate a JWT-SVID'
          'watch:watch for X509-SVID updates'
        )
        _describe -t apicmds 'api subcommand' api_subs && ret=0
        _arguments \
          '-socketPath=[workload API socket]:file:_files' \
          '-write=[output directory]:dir:_files -/' \
          '-spiffeID=[expected SPIFFE ID]:id:' \
          '-audience=[JWT audience(s) (comma-separated)]:audience:' \
          '-svid=[JWT-SVID to validate]:svid:' \
          '-timeout=[wait timeout]:duration:' \
          '-format=[output format]:format:(pem spiffe json)' && ret=0 ;;
      (healthcheck)
        _arguments \
          '-shallow[shallow check]' \
          '-verbose[verbose output]' \
          '-socketPath=[workload API socket]:file:_files' && ret=0 ;;
      (logger)
        _arguments '*::sub:(get set reset)' && ret=0 ;;
      (validate)
        _arguments '-config=[config file]:file:_files -g "*.conf"' && ret=0 ;;
    esac ;;
esac

return ret
