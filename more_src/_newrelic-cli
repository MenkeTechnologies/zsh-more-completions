#compdef newrelic-cli newrelic

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agent:agent commands'
  'apiAccess:manage API access keys'
  'apm:APM commands'
  'changeTracking:track deployments'
  'completion:generate shell completion'
  'config:manage CLI config'
  'decode:decode New Relic IDs'
  'diagnose:run diagnostics'
  'documentation:open docs'
  'edge:edge commands'
  'entity:entity commands'
  'events:create custom events'
  'install:install agents and integrations'
  'nerdgraph:run NerdGraph queries'
  'nerdstorage:nerdstorage commands'
  'nrql:run NRQL queries'
  'profile:manage CLI profiles'
  'reporting:reporting commands'
  'synthetics:synthetics commands'
  'utils:utility commands'
  'version:print version'
  'workload:workload commands'
)

_arguments -C \
  '(-a --accountId)'{-a,--accountId}'=[account ID]:id:' \
  '--debug[debug logging]' \
  '--format=[output format]:format:(JSON Text YAML)' \
  '--plain[plain text output]' \
  '--profile=[profile name]:name:' \
  '--trace[trace logging]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'newrelic-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (profile)
        _values 'profile action' add default delete list && ret=0
        ;;
      (config)
        _values 'config action' get list reset set && ret=0
        ;;
      (nrql)
        _values 'nrql action' history query && ret=0
        ;;
      (apm)
        _values 'apm action' application deployment && ret=0
        ;;
      (entity)
        _values 'entity action' search tags deployment && ret=0
        ;;
      (install)
        _arguments \
          '(-y --assumeYes)'{-y,--assumeYes}'[assume yes]' \
          '--localRecipes=[local recipes path]:dir:_files -/' \
          '*'{-n,--recipe}'=[recipe]:name:' \
          '(-c --recipePath)'{-c,--recipePath}'=[recipe path]:path:_files' \
          '*--tag=[tag]:tag:' \
          '(-t --testMode)'{-t,--testMode}'[test mode]' && ret=0
        ;;
    esac
    ;;
esac

return ret
