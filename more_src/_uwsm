#compdef uwsm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'select:select default compositor Desktop Entry'
  'start:start compositor and graphical session'
  'finalize:notify systemd user manager that startup finished'
  'stop:stop graphical session and compositor'
  'app:application unit launcher'
  'check:perform state checks'
  'aux:technical helpers (internal)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'uwsm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '(-S --silent)'{-S,--silent}'[silent output]' \
          '(-D --debug)'{-D,--debug}'[debug output]' \
          '-o[only populate user units]' \
          '-N[non-blocking mode]' \
          '-F[finalize after start]' \
          '-a[acquire desktop session id]' \
          '-d[do not block (detach)]' \
          '*::compositor_or_desktop_entry:' && ret=0 ;;
      (stop)
        _arguments \
          '-D[debug output]' \
          '-S[silent output]' \
          '-a[wait for session removal]' && ret=0 ;;
      (app)
        _arguments \
          '(-s --slice)'{-s+,--slice=}'[systemd slice]:slice:(a-app b-background s-session)' \
          '(-t --type)'{-t+,--type=}'[unit type]:type:(scope service)' \
          '(-a --app-name)'{-a+,--app-name=}'[explicit app name]:name:' \
          '(-u --unit-name)'{-u+,--unit-name=}'[explicit systemd unit name]:name:' \
          '(-d --description)'{-d+,--description=}'[unit description]:text:' \
          '*-D+[unit properties]:property:' \
          '*::command:_command_names' && ret=0 ;;
      (check)
        _arguments \
          '*::sub:(may-start is-active is-running)' \
          '-q[quiet]' \
          '-v[verbose]' \
          '-i[ignore user services check]' \
          '-g[ignore graphical-session-pre.target check]' \
          '-S[silent]' && ret=0 ;;
      (select)
        _arguments \
          '-l[list available desktop entries]' && ret=0 ;;
      (finalize)
        _arguments \
          '*::env_vars:' && ret=0 ;;
      (aux)
        _arguments '*::sub:(prepare-env cleanup-env app)' && ret=0 ;;
    esac ;;
esac

return ret
