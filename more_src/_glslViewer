#compdef glslViewer
# Documentation: https://github.com/patriciogonzalezvivo/glslViewer
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for glslViewer (patriciogonzalezvivo/glslViewer)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--fullscreen[fullscreen]' \
  '--window[geometry]:WxH' \
  '--msaa[samples]:n' \
  '--fxaa[FXAA]' \
  '*:shader or asset:_files' && ret=0

return ret
