#compdef glslViewer
# Documentation: https://man.archlinux.org/search?q=glslViewer
# Reference accessed: 2026-05-16

# Zsh completion for glslViewer (patriciogonzalezvivo/glslViewer)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--fullscreen[fullscreen]' \
  '--window[geometry]:WxH' \
  '--msaa[samples]:n' \
  '--fxaa[FXAA]' \
  '*:shader or asset:_files' && ret=0

return ret
