#compdef kafka-jmx

local -a arguments

arguments=(
    '--jmx-url[JMX URL to connect to]:url:'
    '--date-format[Date format for reporting]:format:'
    '--object-name[JMX object name to query]:name:'
    '--attributes[Attributes to query]:attributes:'
    '--reporting-interval[Interval in ms at which to print metrics]:ms:'
    '--one-time[Report once and exit]'
)

_arguments -s -S $arguments
