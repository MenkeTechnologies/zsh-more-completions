#compdef olsrd
# _olsrd — olsr.org olsrd (Optimized Link State Routing daemon used in mesh networks; -f config file, -d debug level, -nofork stay foreground, -iface ifname start with one interface, -ipv6 force IPv6 mode, -delgw clear default gateway, -plugin path load plugin, -P pidfile, -v verbose, -hint set timestamp hint; reads /etc/olsrd/olsrd.conf for full interface + algo + plugin config)
# upstream: http://www.olsr.org/
# Flags from olsr.org olsrd src/main.c on tip.

_olsrd() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-f+[config file]:file:_files' \
        '-d+[debug level]:level:' \
        '-nofork[foreground]' \
        '-iface+[interface]:interface:_net_interfaces' \
        '-ipv6[force IPv6]' \
        '-delgw[clear default gateway]' \
        '-plugin+[plugin path]:file:_files -g "*.so"' \
        '-P+[pidfile]:file:_files' \
        '-hint+[timestamp hint]:hint:'
}

_olsrd "$@"
