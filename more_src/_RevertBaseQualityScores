#compdef RevertBaseQualityScores
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/RevertBaseQualityScores.java
# Revert Quality Scores in a SAM/BAM/CRAM file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'=[output SAM/BAM/CRAM file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
