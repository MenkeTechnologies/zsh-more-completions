#compdef growxy
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Grow an image into the planes of a data cube

local ret=1

_arguments -s -S \
  'IMAGE=[image to be grown into cube]:image:_files' \
  'CUBE=[data cube to grow image into]:cube:_files' \
  'TSTART=[first plane in cube for this operation]:tstart:' \
  'TEND=[last plane in cube for this operation]:tend:' \
  'NEW=[force creation of a new cube]:new:(TRUE FALSE)' \
  'TSIZE=[third dimension of new cube]:tsize:' \
  '*:NDF data file:_files' && ret=0

return ret
