#compdef bioradtopgm
# Documentation: man bioradtopgm (Netpbm)
# Source: convert a Bio-Rad confocal image file to a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-image[image number to extract]:N:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:Bio-Rad image data file:_files' \
    && ret=0

return ret
