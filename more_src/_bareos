#compdef bareos
# _bareos — Bareos enterprise backup-and-restore CLI alias (bareos team, C++); custom argparse
# upstream: https://github.com/bareos/bareos

_bareos() {
    local -a sub=(
        'bconsole:bareos console client'
        'bareos-dir:director daemon'
        'bareos-fd:file daemon'
        'bareos-sd:storage daemon'
        'bcopy:copy bareos volume to another volume'
        'bextract:extract files from bareos volume'
        'bls:list bareos volume contents'
        'bregex:test bareos regex'
        'bscan:scan bareos volume to recover catalog'
        'bsmtp:bareos mail client'
        'btestls:test bareos ls regex'
        'btraceback:bareos traceback helper'
        'bwild:test bareos wild matching'
        'bareos-dbcheck:check catalog database'
        'bareos-dbcopy:copy catalog database'
        'create_bareos_database:create catalog db'
        'drop_bareos_database:drop catalog db'
        'update_bareos_tables:update catalog tables'
        'grant_bareos_privileges:grant catalog privileges'
        'make_bareos_tables:make catalog tables'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d+[debug level]:n:' \
        '-T[set traceback]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bareos subcommand' sub ;;
        args)
            case $words[1] in
                bconsole) _arguments \
                    '-c+[config file]:file:_files -g "bconsole.conf"' \
                    '-D+[director]:str:' \
                    '-l[list directors]' \
                    '-n[no conio]' \
                    '-s[no signals]' \
                    '-u+[timeout seconds]:n:' \
                    '-p+[password]:str:' \
                    '-t[test config]' ;;
                bareos-dir|bareos-fd|bareos-sd) _arguments \
                    '-c+[config file]:file:_files' \
                    '-d+[debug level]:n:' \
                    '-f[foreground]' \
                    '-g+[group]:_groups' \
                    '-m[mark debug]' \
                    '-p[print config]' \
                    '-s[no signals]' \
                    '-t[test config]' \
                    '-u+[user]:_users' \
                    '-v[verbose]' ;;
                bls|bextract|bcopy|bscan) _arguments \
                    '-c+[config file]:file:_files' \
                    '-d+[debug level]:n:' \
                    '-V+[volumes]:str:' \
                    '*:device or path:_files' ;;
            esac
            ;;
    esac
}

_bareos "$@"
