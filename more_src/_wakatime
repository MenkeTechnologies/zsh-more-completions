#compdef wakatime-cli
# Documentation: https://github.com/wakatime/wakatime-cli (cmd/root.go)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_wakatime() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments \
        '--ai-line-changes=[number of lines added/removed by AI]:lines:' \
        '--alternate-branch=[alternate branch name]:branch:' \
        '--alternate-language=[alternate language name]:language:' \
        '--alternate-project=[alternate project name]:project:' \
        '--api-url=[API base URL]:url:' \
        '--category=[category]:category:(coding "ai coding" building indexing debugging learning notes meeting planning researching communicating supporting advising "running tests" "writing tests" "manual testing" "writing docs" "code reviewing" browsing translating designing)' \
        '--config=[config file path]:file:_files' \
        '--internal-config=[internal config file path]:file:_files' \
        '--config-read=[print value for the given config key]:key:' \
        '--config-section=[config section]:section:' \
        '--config-write=[write value to a config key]:key=value:' \
        '--cursorpos=[cursor position in current file]:position:' \
        '--disable-offline[disable offline time logging]' \
        '--entity=[absolute path to file/url/domain/app]:entity:_files' \
        '--entity-type=[entity type]:type:(file domain url app)' \
        '*--exclude=[exclude filename pattern (POSIX regex)]:pattern:' \
        '--exclude-unknown-project[ignore activity when project cannot be detected]' \
        '--extra-heartbeats[read extra heartbeats from STDIN as JSON]' \
        '--file-experts[print top developer for the given entity]' \
        '--guess-language[detect language from file contents]' \
        '--heartbeat-rate-limit-seconds=[seconds between heartbeat syncs]:seconds:' \
        '--hide-branch-names=[obfuscate branch names]:patterns:' \
        '--hide-file-names=[obfuscate file names]:patterns:' \
        '--hide-project-folder[send file path relative to project folder]' \
        '--hide-project-names=[obfuscate project names]:patterns:' \
        '--hostname=[local machine name]:hostname:_hosts' \
        '--human-line-changes=[lines added/removed by humans]:lines:' \
        '*--include=[include filename pattern]:pattern:' \
        '--include-only-with-project-file[only track folders with .wakatime-project]' \
        '--is-unsaved-entity[track files that do not exist on disk]' \
        '--key=[WakaTime API key]:key:' \
        '--language=[language override]:language:' \
        '--lineno=[current line number]:line:' \
        '--lines-in-file=[total lines in file]:lines:' \
        '--local-file=[absolute path to local file]:file:_files' \
        '--log-file=[log file path]:file:_files' \
        '--log-to-stdout[log to stdout]' \
        '--metrics[collect metrics usage]' \
        '--no-ssl-verify[disable SSL certificate verification]' \
        '--offline-count[print number of offline heartbeats and exit]' \
        '--output=[output format]:format:(text json raw-json)' \
        '--plugin=[plugin name and version]:plugin:' \
        '--print-offline-heartbeats=[print offline heartbeats to stdout]:count:' \
        '--project=[project name]:project:' \
        '--project-folder=[workspace path]:dir:_directories' \
        '--proxy=[proxy URL]:url:' \
        '--send-diagnostics-on-errors[send diagnostics on non-crash errors]' \
        '--ssl-certs-file=[CA certs file override]:file:_files' \
        '--sync-ai-activity[parse AI transcript logs and send heartbeats]' \
        '--sync-ai-disabled[disable parsing AI transcript logs]' \
        '--sync-offline-activity=[offline activity to sync]:count:' \
        '--time=[Unix epoch timestamp]:time:' \
        '--timeout=[connection timeout (seconds)]:seconds:' \
        '--today[display total coding activity for today]' \
        '--today-hide-categories=[hide categories in --today output]:value:' \
        '--today-goal=[print time for goal id today]:goal_id:' \
        '--verbose[turn on debug messages]' \
        '--version[print version]' \
        '--write[heartbeat triggered from writing to file]' \
        '(-h --help)'{-h,--help}'[show help]'
}

_wakatime "$@"
