#compdef wakatime-cli

_wakatime() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments \
        '--entity[Absolute path to file or app]:file:_files' \
        '--key[Your WakaTime API key]:key:' \
        '--write[When set, file is being modified]' \
        '--plugin[Plugin name and version]:plugin:' \
        '--time[UNIX epoch timestamp]:time:' \
        '--lineno[Current line number]:line:' \
        '--cursorpos[Current cursor position]:position:' \
        '--lines-in-file[Total lines in the file]:lines:' \
        '--entity-type[Entity type]:type:(file app domain)' \
        '--category[Category]:category:(coding building indexing debugging browsing running-tests writing-tests manual-testing writing-docs communicating code-reviewing researching learning designing)' \
        '--project[Project name]:project:' \
        '--alternate-project[Alternate project name]:project:' \
        '--language[Language override]:language:' \
        '--local-file[Absolute path to local file]:file:_files' \
        '--hostname[Computer hostname]:hostname:_hosts' \
        '--disable-offline[Disable offline queueing]' \
        '--hide-file-names[Obfuscate file names]' \
        '--hide-project-names[Obfuscate project names]' \
        '--hide-branch-names[Obfuscate branch names]' \
        '--exclude[Exclude file pattern]:pattern:' \
        '--include[Include file pattern]:pattern:' \
        '--include-only-with-project-file[Only send heartbeats when .wakatime-project exists]' \
        '--extra-heartbeats[Read extra heartbeats from stdin as JSON]' \
        '--log-file[Path to log file]:file:_files' \
        '--log-to-stdout[Log to stdout]' \
        '--api-url[API base URL]:url:' \
        '--timeout[Connection timeout in seconds]:seconds:' \
        '--sync-offline-activity[Sync offline activity]:count:' \
        '--today[Display total coding activity for today]' \
        '--config-section[Set config section]:section:' \
        '--config-read[Read config value]:key:' \
        '--config-write[Write config value]:key=value:' \
        '--version[Display version]' \
        '(-h --help)'{-h,--help}'[Show help]' \
        '--verbose[Turn on debug messages]'
}

_wakatime "$@"
