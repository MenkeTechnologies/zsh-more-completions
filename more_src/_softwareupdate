#compdef softwareupdate
# Documentation: https://ss64.com/mac/softwareupdate.html
# Reference accessed: 2026-05-21
# Verified: macOS softwareupdate(8) flag reference.
# Note: --safari-only is documented but no longer functional on
# modern macOS (Safari updates merged into OS). Retained for legacy.
# Added --install-rosetta per upstream docs (Apple silicon only).

local -a arguments

arguments=(
    '-l[List all available updates]'
    '--list[List all available updates]'
    '-d[Download only]'
    '--download[Download only]'
    '-i[Install updates]:update name or flag:(--all --recommended --os-only -a -r)'
    '--install[Install updates]:update name or flag:(--all --recommended --os-only -a -r)'
    '-a[Install all available updates]'
    '--all[Install all available updates]'
    '-R[Install only recommended updates]'
    '--recommended[Install only recommended updates]'
    '--os-only[Install only macOS updates]'
    '--safari-only[Install only Safari updates]'
    '-r[Install only restart-required updates]'
    '--restart[Install only restart-required updates]'
    '--no-scan[Use cached scan results]'
    '--verbose[Verbose output]'
    '--force[Force update installation]'
    '--agree-to-license[Agree to license agreement]'
    '--product-types[Limit to product types]:product types'
    '--products[Limit to product keys]:product keys'
    '--fetch-full-installer[Download full macOS installer]'
    '--full-installer-version[Version for full installer]:version'
    '--list-full-installers[List available full macOS installers]'
    '--install-rosetta[Install Rosetta on Apple silicon]'
    '--schedule[Manage automatic update schedule]:schedule:(on off)'
    '--background[Trigger background scan and update]'
    '--history[Show update install history]'
    '--dump-state[Dump software update internal state]'
    '--ignore[Manage ignored updates]:update name'
    '--reset-ignored[Reset list of ignored updates]'
    '(- *)--help[Show help]'
)

_arguments -s -S $arguments
