#compdef cliam
# Documentation: https://github.com/securisec/cliam
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# securisec/cliam - cloud agnostic IAM permissions enumerator (cobra).
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'aws:enumerate AWS credentials for their permissions'
  'azure:enumerate Azure credentials for their permissions'
  'gcp:enumerate GCP service account permissions'
  'firebase:enumerate Firebase permissions'
  'completion:generate shell completion script'
  'help:help about any command'
  'version:show version and build info'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--max-threads=[max threads]:n:' \
  '--request-timeout=[request timeout (seconds)]:n:' \
  '--save-output[save output to file on success]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'cliam command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (aws)
        _values 'aws subcommand' \
          'enumerate[enumerate AWS permissions]' \
          'service-group[enumerate by service group]' && ret=0 ;;
      (gcp)
        _values 'gcp subcommand' \
          'bruteforce[enumerate all GCP permissions]' \
          'enumerate[enumerate specified GCP permissions]' \
          'rest[GCP permissions via REST API]' && ret=0 ;;
      (azure)
        _values 'azure subcommand' \
          'access-token[print Azure access token]' \
          'enumerate[enumerate Azure permissions]' \
          'service[enumerate Azure service]' \
          'subscriptions[list Azure subscriptions]' && ret=0 ;;
      (completion)
        _values 'shell' bash zsh fish powershell && ret=0 ;;
    esac
    ;;
esac

return ret
