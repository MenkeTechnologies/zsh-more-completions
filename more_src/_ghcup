#compdef ghcup

# Zsh completion for ghcup - Haskell toolchain installer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-c --cache)'{-c,--cache}'[cache downloads]' \
  '(-n --no-verify)'{-n,--no-verify}'[skip verification]' \
  '--keep=[keep build directories]:keep:(always errors never)' \
  '--downloader=[downloader to use]:downloader:(curl wget)' \
  '--no-network[disable network access]' \
  '--offline[offline mode]' \
  '--gpu=[set gpu flag]:gpu' \
  '-s[URL source override]:url' \
  '--url-source=[URL source override]:url' \
  '--metadata-caching=[metadata caching]:caching:(true false)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install a tool'
      'set:set currently active version'
      'rm:remove an installed version'
      'list:list available/installed versions'
      'upgrade:upgrade ghcup itself'
      'compile:compile a tool from source'
      'whereis:find a tool binary path'
      'prefetch:prefetch metadata and downloads'
      'gc:garbage collection'
      'run:run a command with specific tool versions'
      'debug-info:show debug info'
      'tool-requirements:show tool requirements'
      'changelog:show changelog'
      'config:show or set config'
      'nuke:completely remove ghcup and installed tools'
      'tui:start terminal UI'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments \
          '1:tool:(ghc cabal hls stack)' \
          '2:version:' \
          '(-f --force)'{-f,--force}'[force reinstall]' \
          '(-p --platform)'{-p,--platform}'[platform override]:platform' \
          '--isolate=[install to isolated directory]:dir:_directories' \
          '--set[set as active after install]' && ret=0
        ;;
      set)
        _arguments \
          '1:tool:(ghc cabal hls stack)' \
          '2:version:' && ret=0
        ;;
      rm)
        _arguments \
          '1:tool:(ghc cabal hls stack)' \
          '2:version:' && ret=0
        ;;
      list)
        _arguments \
          '(-t --tool)'{-t,--tool}'[filter by tool]:tool:(ghc cabal hls stack)' \
          '(-c --criteria)'{-c,--criteria}'[filter criteria]:criteria:(installed set available)' \
          '(-r --raw-format)'{-r,--raw-format}'[raw output format]' \
          '--show-requirements[show requirements]' && ret=0
        ;;
      compile)
        _arguments \
          '1:tool:(ghc cabal hls)' \
          '--version=[version to compile]:version' \
          '--git-ref=[git ref to build from]:ref' \
          '--jobs=[number of jobs]:jobs' \
          '--build-config=[build config file]:file:_files' \
          '--set[set as active after compilation]' && ret=0
        ;;
      run)
        _arguments \
          '--ghc=[GHC version]:version' \
          '--cabal=[Cabal version]:version' \
          '--hls=[HLS version]:version' \
          '--stack=[Stack version]:version' \
          '--install[install missing tools]' \
          '--:' \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
