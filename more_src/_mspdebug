#compdef mspdebug
# _mspdebug — Daniel Beer mspdebug CLI for the open-source debugger and flash-programmer for the TI MSP430 supporting MSP-FET MSP430.dll FET-Pro430 olimex tilib uif rf2500 simulator running GDB server REPL flash load (dlbeer team, C); getopt
# upstream: https://github.com/dlbeer/mspdebug

_mspdebug() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[device]:str:' \
        '--device=+[device]:str:' \
        '-U+[USB device]:str:' \
        '--usb-list[list USB devices]' \
        '-j+[JTAG device]:str:' \
        '-s+[serial dev]:file:_files -g "/dev/tty*"' \
        '--serial=+[serial dev]:file:_files -g "/dev/tty*"' \
        '-n[no rc file]' \
        '--no-rc[no rc file]' \
        '-R[reset target]' \
        '--reset[reset target]' \
        '-F[force fuse]' \
        '--force-id=+[id]:str:' \
        '--allow-fw-update[allow firmware update]' \
        '-S+[script]:file:_files' \
        '--script=+[script]:file:_files' \
        '-C+[config]:file:_files' \
        '--config=+[config]:file:_files' \
        '*:driver command:(sim rf2500 uif olimex olimex-iso olimex-v1 olimex-iso-v1 ti3410 tilib gdbc bsl flash-bsl pif loadbsl rom-bsl bus-pirate)'
}

_mspdebug "$@"
