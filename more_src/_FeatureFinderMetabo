#compdef FeatureFinderMetabo
# OpenMS TOPP: detect metabolite features in centroided LC-MS data

local ret=1

_arguments -s -S \
  '-in[input centroided mzML file]:input file:_files' \
  '-out[output featureXML file]:output file:_files' \
  '-out_chrom[output mzML file with chromatograms]:file:_files' \
  '-faims_merge_features[merge FAIMS features at different compensation voltages]' \
  '-algorithm:common:noise_threshold_int[intensity threshold for noise filtering]:value:' \
  '-algorithm:common:chrom_peak_snr[minimum signal-to-noise ratio]:value:' \
  '-algorithm:common:chrom_fwhm[expected chromatographic peak width (s)]:value:' \
  '-algorithm:mtd:mass_error_ppm[allowed mass deviation]:ppm:' \
  '-algorithm:mtd:quant_method[quantification method]:method:(area median max_height)' \
  '-algorithm:mtd:trace_termination_criterion[extension termination mode]:mode:' \
  '-algorithm:mtd:min_trace_length[minimum trace duration (s)]:value:' \
  '-algorithm:mtd:max_trace_length[maximum trace duration (s)]:value:' \
  '-algorithm:epd:enabled[enable isobaric trace splitting]:bool:' \
  '-algorithm:epd:width_filtering[peak width filtering mode]:mode:' \
  '-algorithm:epd:min_fwhm[minimum peak width (s)]:value:' \
  '-algorithm:epd:max_fwhm[maximum peak width (s)]:value:' \
  '-algorithm:ffm:charge_lower_bound[minimum charge state]:n:' \
  '-algorithm:ffm:charge_upper_bound[maximum charge state]:n:' \
  '-algorithm:ffm:isotope_filtering_model[isotope scoring model]:model:' \
  '-algorithm:ffm:report_convex_hulls[include convex hulls in output]:bool:' \
  '-algorithm:ffm:remove_single_traces[exclude unassembled traces]:bool:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
