#compdef centrimo
# Documentation: https://meme-suite.org/meme/doc/centrimo.html
# MEME Suite: identify positionally enriched motifs (local motif enrichment)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--o=[output directory (default centrimo_out), fail if exists]:dir:_files -/' \
  '--oc=[output directory (default centrimo_out), overwrite if exists]:dir:_files -/' \
  '--neg=[control sequence file]:file:_files' \
  '--seqlen=[expected sequence length]:length:' \
  '--score=[minimum motif match score]:S:' \
  '--use-lo-fraction[set score threshold as fraction of max log-odds]' \
  '--use-pvalues[set score threshold as a p-value]' \
  '--norc[do not score the reverse complement strand]' \
  '--sep[score the reverse complement as a separate motif]' \
  '--flip[reflect reverse-strand matches across sequence center]' \
  '--optimize-score[search for the best score threshold]' \
  '--maxreg=[maximum region size to consider]:max region:' \
  '--minreg=[minimum region size to consider]:min region:' \
  '--local[compute enrichment of all regions, not just central]' \
  '--cd[measure enrichment by central distance]' \
  '--ethresh=[E-value threshold for reporting]:thresh:' \
  '--noseq[do not store per-sequence match positions]' \
  '*:sequence/motif file:_files' && ret=0

return ret
