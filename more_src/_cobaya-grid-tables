#compdef cobaya-grid-tables
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: make LaTeX/PDF parameter tables from a grid

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--limit=[sigmas of quoted confidence intervals]:sigmas' \
  '--all_limits[show all confidence limits]' \
  '--bestfitonly[only quote best-fit values]' \
  '--nobestfit[do not quote best-fit values]' \
  '--no_delta_chisq[do not show delta chi-squared]' \
  '--delta_chisq_paramtag=[parameter tag for best-fit chi-squared differences]:paramtag' \
  '--changes_from_datatag=[fractional sigma shifts vs a data combination tag]:datatag' \
  '--changes_from_paramtag=[fractional sigma shifts vs a parameter combination tag]:paramtag' \
  '*--changes_adding_data=[fractional sigma shifts when adding given data]:data' \
  '*--changes_replacing=[sigma shifts replacing data]:data' \
  '--changes_only[only include results in the changes_replacing set]' \
  '--systematic_average[combine two chains and quote the combination]' \
  '--shift_sigma_indep[shifts relative to independent data sigma]' \
  '--shift_sigma_subset[shifts relative to subset data sigma]' \
  '--paramNameFile=[.paramnames file for custom labels]:file:_files' \
  '--paramList=[.paramnames file listing parameters to include]:file:_files' \
  '--blockEndParams=[semicolon-separated parameters marking block ends]:params' \
  '--columns=[number of columns]:columns' \
  '*--compare=[data tags to compare]:datatag' \
  '--titles=[titles for compare plots]:titles' \
  '--forpaper[format for paper]' \
  '--separate_tex[output separate tex files]' \
  '--header_tex=[custom LaTeX header file]:file:_files' \
  '--height=[page height]:height' \
  '--width=[page width]:width' \
  '--converge=[minimum R-1 convergence]:R-1' \
  '1:grid directory:_files -/' \
  '2:latex filename:_files -g "*.tex"' && ret=0

return ret
