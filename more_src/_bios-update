#compdef bios-update
# Documentation: https://man.archlinux.org/search?q=bios-update
# Reference accessed: 2026-05-16

# bios-update: vendor-specific BIOS image flasher
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--check[check BIOS integrity]' \
  '--update[update BIOS]:file:_files' \
  '--force[force the update]' \
  '*::bios-update args:_files' && ret=0
return ret
