#compdef ergo ergo-node ergo-launcher
# _ergo-node — Ergo Platform Foundation ergo reference node for the Autolykos PoW Ergo blockchain with eUTXO smart contracts (ergoplatform team, Scala); custom argparse
# upstream: https://github.com/ergoplatform/ergo

_ergo-node() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '--mainnet[mainnet]' \
        '--testnet[testnet]' \
        '--devnet[devnet]' \
        '--rpcuser=+[rpc user]:user:_users' \
        '--rpcpass=+[rpc password]:str:' \
        '--rpcbind=+[bind address]:str:' \
        '--rpcport=+[rpc port]:port:_ports' \
        '--api-key-hash=+[api key hash]:str:' \
        '--network-bind-address=+[bind addr]:str:' \
        '--declared-address=+[declared addr]:str:' \
        '--peers=+[peers csv]:str:' \
        '--bootnodes=+[bootnodes csv]:str:' \
        '--mining-key=+[mining key]:str:' \
        '--mining[enable mining]' \
        '--mining-pubkey=+[mining pubkey]:str:' \
        '--start-mining[start mining]' \
        '--mining-cpu-threads=+[N]:n:' \
        '--no-mining[disable mining]' \
        '--mode=+[node mode]:m:(full utxo digest fullnode lightnode)' \
        '--state-type=+[type]:t:(utxo digest)' \
        '--blocks-to-keep=+[N]:n:' \
        '--pop-pow-bootstrap[pop-pow bootstrap]' \
        '--popow-bootstrap[popow bootstrap]' \
        '--utxo-bootstrap[utxo bootstrap]' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '-d+[data dir]:dir:_files -/' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--log-level=+[level]:l:(TRACE DEBUG INFO WARN ERROR)' \
        '--rest-api-port=+[api port]:port:_ports' \
        '--rest-api-bind-address=+[api bind]:str:' \
        '--public-keys=+[node public keys]:str:' \
        '--store-tx-info=+[bool]:b:(true false)' \
        '--check-pow[check pow]' \
        '--keep-versions=+[N]:n:' \
        '--reemission-amount=+[amount]:n:'
}

_ergo-node "$@"
