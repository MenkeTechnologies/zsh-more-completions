#compdef beegfs-ctl
# Documentation: https://man.archlinux.org/search?q=beegfs-ctl
# Reference accessed: 2026-05-16

# beegfs-ctl: BeeGFS management/admin tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--listnodes[list nodes]' \
  '--listtargets[list targets]' \
  '--listmirrorgroups[list mirror groups]' \
  '--getentryinfo[show file/entry info]' \
  '--setpattern[set stripe pattern]' \
  '--setattr[set attributes]' \
  '--migrate[migrate stripe targets]' \
  '--quota[show quota info]' \
  '--storagepools[storage pool management]' \
  '--getquota[get quota]' \
  '--setquota[set quota]' \
  '--listquotapools[list quota pools]' \
  '--genericdebug[generic debug command]' \
  '--mirrormd[mirror metadata service]' \
  '--addmirrorgroup[add a mirror group]' \
  '--removemirrorgroup[remove a mirror group]' \
  '--addmirroredbuddyresync[start mirrored buddy resync]' \
  '--addnomirroredbuddyresync[stop mirrored buddy resync]' \
  '--reverselookup[reverse lookup of nodes]' \
  '*::beegfs-ctl args:_files' && ret=0
return ret
