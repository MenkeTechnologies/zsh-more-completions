#compdef enum4linux-ng

_arguments -s \
  '-A[run all simple checks]' \
  '-As[run all checks (slow)]' \
  '-U[user enumeration]' \
  '-G[group enumeration]' \
  '-Gm[detailed group enumeration]' \
  '-S[share enumeration]' \
  '-C[services via RPC]' \
  '-P[password policy]' \
  '-O[OS info]' \
  '-L[LDAP info]' \
  '-I[printer info]' \
  '-N[NetBIOS info]' \
  '-d[detailed enumeration]' \
  '-v[verbose]' \
  '--keep[keep raw output]' \
  '--local-auth[local authentication]' \
  '-R[RID enumeration]:bulk size:' \
  '-w[domain]:domain:' \
  '-u[username]:user:' \
  '-p[password]:password:' \
  '-K[Kerberos ticket file]:file:_files' \
  '-H[NT hash]:hash:' \
  '-k[user list]:users:' \
  '-r[RID ranges]:ranges:' \
  '-s[shares wordlist]:file:_files' \
  '-t[timeout seconds]:s:' \
  '-oJ[JSON output]:file:_files' \
  '-oY[YAML output]:file:_files' \
  '-oA[both JSON and YAML]:file:_files' \
  '*:host:_hosts'
