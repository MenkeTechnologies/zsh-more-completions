_clam_profiles() {
    local -a profiles
    profiles=(${(f)"$(clam list --names 2>/dev/null)"})
    _describe -t profiles 'profile' profiles
}

if [ "$funcstack[1]" = "_clam" ]; then
    _clam "$@"
else
    compdef _clam clam
fi
