#compdef clam
# Source: cargo binstall clam-cli@0.1.0
# Probed via: completions zsh
# Repository: https://github.com/jose2kk/clam

autoload -U is-at-least

_clam() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_clam_commands" \
"*::: :->clam" \
&& ret=0
    case $state in
    (clam)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:clam-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'--inherit[Symlink global Claude Code config (~/.claude/) into the profile]' \
'-h[Print help]' \
'--help[Print help]' \
':name:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'--json[]' \
'--names[Print only profile names, one per line (for shell scripts)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':name:_clam_profiles' \
&& ret=0
;;
(current)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'--force[]' \
'-h[Print help]' \
'--help[Print help]' \
':name:_clam_profiles' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
'--profile=[Use a specific profile (without switching active)]:PROFILE:_clam_profiles' \
'-h[Print help]' \
'--help[Print help]' \
'*::args -- Command and arguments to run (default\: claude):_default' \
&& ret=0
;;
(env)
_arguments "${_arguments_options[@]}" : \
'--json[]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash zsh fish)' \
&& ret=0
;;
(repair)
_arguments "${_arguments_options[@]}" : \
'--profile=[Repair only a specific profile]:PROFILE:_clam_profiles' \
'--dry-run[Show the plan without making changes]' \
'--force[Skip the confirmation prompt]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_clam__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:clam-help-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(use)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(current)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(run)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(env)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(repair)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_clam_commands] )) ||
_clam_commands() {
    local commands; commands=(
'add:Create a new profile' \
'list:List all profiles' \
'use:Switch active profile' \
'current:Print active profile name' \
'remove:Remove a profile' \
'status:Show active profile status' \
'run:Launch a command with profile environment' \
'env:Print shell environment exports for eval' \
'completions:Generate shell completions' \
'repair:Repair profiles that share session data with the global ~/.claude/ (legacy profiles created before per-profile isolation of projects/todos)' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'clam commands' commands "$@"
}
