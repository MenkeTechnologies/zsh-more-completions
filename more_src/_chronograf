#compdef chronograf

# Zsh completion for Chronograf (InfluxDB dashboard)

_chronograf() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '--host=[address to bind to]:host:_hosts' \
    '--port=[port to bind to]:port:' \
    '-b+[path to BoltDB file]:bolt file:_files' \
    '--bolt-path=[path to BoltDB file]:bolt file:_files' \
    '-c+[path to Canned layouts]:canned path:_files -/' \
    '--canned-path=[path to Canned layouts]:canned path:_files -/' \
    '--resources-path=[path to chronograf resources]:resources path:_files -/' \
    '--basepath=[URL path prefix]:path prefix:' \
    '--status-feed-url=[URL for the news feed]:URL:' \
    '-t+[secret token for auth]:token:' \
    '--token-secret=[secret token for auth]:token:' \
    '--auth-duration=[auth token validity duration]:duration:' \
    '--github-client-id=[GitHub OAuth client ID]:ID:' \
    '--github-client-secret=[GitHub OAuth client secret]:secret:' \
    '--github-organization=[restrict to GitHub org]:org:' \
    '--google-client-id=[Google OAuth client ID]:ID:' \
    '--google-client-secret=[Google OAuth client secret]:secret:' \
    '--google-domains=[restrict to Google domains]:domains:' \
    '--heroku-client-id=[Heroku OAuth client ID]:ID:' \
    '--heroku-secret=[Heroku OAuth secret]:secret:' \
    '--heroku-organization=[restrict to Heroku org]:org:' \
    '--generic-name=[name for OAuth2 provider]:name:' \
    '--generic-client-id=[generic OAuth client ID]:ID:' \
    '--generic-client-secret=[generic OAuth client secret]:secret:' \
    '--generic-scopes=[generic OAuth scopes]:scopes:' \
    '--generic-domains=[generic OAuth domains]:domains:' \
    '--generic-auth-url=[generic OAuth auth URL]:URL:' \
    '--generic-token-url=[generic OAuth token URL]:URL:' \
    '--generic-api-url=[generic OAuth API URL]:URL:' \
    '--public-url=[public URL for OAuth redirects]:URL:' \
    '--tls-certificate=[TLS certificate]:certificate file:_files' \
    '--tls-private-key=[TLS private key]:key file:_files' \
    '-r[report usage stats]' \
    '--reporting-disabled[disable usage reporting]' \
    '-l+[log level]:log level:(debug info warn error)' \
    '--log-level=[log level]:log level:(debug info warn error)' \
    '-d[run server with debug mode]' \
    '--develop[run server with debug mode]' \
    '-v[print version]' \
    '--version[print version]' \
    '-h[display help]' \
    '--help[display help]' \
    && ret=0

  return ret
}

_chronograf "$@"
