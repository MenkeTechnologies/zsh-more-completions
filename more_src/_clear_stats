#compdef clear_stats
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/clear-stats.html
# Wazuh statistics reset tool

local ret=1

_arguments -s -S \
  '(- *)-h[show help message]' \
  '-a[clear all average stats]' \
  '-d[clear daily averages]' \
  '-w[clear weekly averages]' \
  '*::arg:_files' && ret=0

return ret
