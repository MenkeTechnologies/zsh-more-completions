#compdef cargo-profiler
# Documentation: https://crates.io/crates/cargo-profiler
# profile Rust binaries with callgrind and cachegrind

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--bin[path to the binary to profile]:binary:_files' \
  '--release[profile the release build]' \
  '-n[number of functions to display]:count' \
  '--sort[sort data by a metric column]:metric' \
  '--keep[keep the callgrind/cachegrind output files]' \
  '1:profiler:(callgrind cachegrind)' \
  '*::arg:_default' && ret=0

return ret
