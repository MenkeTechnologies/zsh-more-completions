#compdef eye
# Documentation: https://github.com/astromatic/eye/blob/master/src/main.c
# EyE - Enhance Your Extraction: train and run a retina to filter astronomical images

local ret=1

_arguments -s -S \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump a default configuration file]' \
  '-dd[dump an extended default configuration file]' \
  '-c+[use the given configuration file]:config file:_files' \
  '-i+[input image(s)]:input image:_files -g "*.(fits|fit|FITS|FIT|fz)"' \
  '-o+[output image(s)]:output image:_files -g "*.(fits|fit|FITS|FIT|fz)"' \
  '*:argument:_files' && ret=0

return ret
