#compdef solanum solanum-ircd
# _solanum — Solanum IRC server daemon (solanum-ircd/solanum)
# upstream: https://github.com/solanum-ircd/solanum
# Flags from ircd/ircd.c (lgetopt myopts[]).

_solanum() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version and exit]' \
        '-configfile=[ircd.conf file path]:file:_files -g "*.conf"' \
        '-logfile=[ircd.log file path]:file:_files -g "*.log"' \
        '-pidfile=[PID file path]:file:_files' \
        '-banfile=[ban.db file path]:file:_files' \
        '-motdfile=[ircd.motd file path]:file:_files' \
        '-opermotdfile=[opers.motd file path]:file:_files' \
        '-foreground[run in foreground (no daemonize)]' \
        '-conftest[validate config and exit]'
}

_solanum "$@"
