#compdef privatebin
# Documentation: https://github.com/gearnode/privatebin/blob/master/doc/privatebin.1.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a paste'
  'show:show a paste'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '(-b --bin)'{-b+,--bin=}'[privatebin instance name]:name' \
  '(-c --config)'{-c+,--config=}'[configuration file path]:file:_files' \
  '*'{-H+,--header=}'[extra HTTP header field]:key=value' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json "")' \
  '--proxy=[proxy URL (http, https, socks5)]:url' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'privatebin command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--burn-after-reading[delete the paste after reading]' \
          '--expire=[paste time to live]:time' \
          '--formatter=[text formatter]:formatter:(plaintext markdown syntaxhighlighting)' \
          '--open-discussion[enable discussion on the paste]' \
          '--password=[add password to the paste]:password' \
          '--gzip[gzip the paste data]' \
          '--attachment[create the paste as an attachment]' \
          '--filename=[file to read instead of stdin]:file:_files' \
          '*:message' && ret=0
        ;;
      (show)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--confirm-burn[confirm opening burn-after-reading paste]' \
          '--insecure[allow reading paste from untrusted instance]' \
          '--password=[paste password]:password' \
          '1:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
