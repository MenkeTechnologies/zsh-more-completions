#compdef luac5.5
# Documentation: https://www.lua.org/manual/5.5/manual.html#7
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-l[list bytecode (use -l -l for full listing)]' \
  '-o+[output to file]:file:_files' \
  '-p[parse only]' \
  '-s[strip debug information]' \
  '-v[show version information]' \
  '*:source file:_files -g "*.lua"' && ret=0

return ret
