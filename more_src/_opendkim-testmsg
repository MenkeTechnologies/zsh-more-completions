#compdef opendkim-testmsg

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-k --key)'{-k,--key}'+[private key file]:file:_files' \
  '(-s --selector)'{-s,--selector}'+[selector]:selector:' \
  '(-D --domain)'{-D,--domain}'+[signing domain]:domain:' \
  '*:file:_files' && ret=0

return ret
