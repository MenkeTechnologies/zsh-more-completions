#compdef patrol patrol-cli
# _patrol — LeanCode patrol CLI command-line frontend for the Patrol Flutter Dart integration test framework supporting native automation patrolBinding patrolWidgetTester running iOS Android tests via Apple-XCUITest-Espresso bridging device-selection android-emulator simulator-management Flutter-driver-test (LeanCode team, Dart); pflag
# upstream: https://patrol.leancode.co/

_patrol() {
    local -a sub=(
        'develop:run tests in dev mode hot-restart'
        'test:run integration tests'
        'build:build the test bundles'
        'doctor:check installation'
        'devices:list connected devices'
        'analyze:analyze patrol test source'
        'update:update patrol CLI'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-file=+[file]:file:_files -g "patrol.yaml *.yaml *.yml"' \
        '-t+[target]:str:' \
        '--target=+[file]:file:_files -g "*.dart"' \
        '-d+[device]:str:' \
        '--device=+[id]:str:' \
        '--flavor=+[name]:str:' \
        '--release[release mode]' \
        '--profile[profile mode]' \
        '--debug[debug mode]' \
        '--dart-define=+[k=v]:str:' \
        '--dart-define-from-file=+[file]:file:_files' \
        '--exclude-tags=+[list]:str:' \
        '--include-tags=+[list]:str:' \
        '--tags=+[list]:str:' \
        '--label=+[label]:str:' \
        '--no-uninstall[no uninstall apps]' \
        '--keep-app[keep app installed]' \
        '--clear-state[clear state before tests]' \
        '--coverage[enable coverage]' \
        '--reporter=+[r]:r:(json yaml html xml)' \
        '--report-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'patrol subcommand' sub ;;
        args)
            case $words[1] in
                test|develop) _arguments '*:dart test file:_files -g "*.dart"' ;;
            esac
            ;;
    esac
}

_patrol "$@"
