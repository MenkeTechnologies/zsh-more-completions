#compdef margin
# Documentation: https://github.com/UCSC-nanopore-cgl/margin
# Margin read haplotyping, phasing and polishing tool

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-a --logLevel)'{-a,--logLevel}'=[logging verbosity]:level:(critical info debug)' \
  '(-t --threads)'{-t,--threads}'=[number of concurrent threads]:int:' \
  '(-o --outputBase)'{-o,--outputBase}'=[output file prefix]:prefix:' \
  '(-r --region)'{-r,--region}'=[genomic region e.g. chr19:1000000-2000000]:region:' \
  '--skipHaplotypeBAM[suppress haplotagged BAM output]' \
  '--skipPhasedVcf[suppress phased VCF and phaseset BED output]' \
  '1:subcommand:(phase polish)' \
  '*::args:_files' && ret=0

return ret
