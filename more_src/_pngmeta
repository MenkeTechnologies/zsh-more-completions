#compdef pngmeta
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/pngmeta.1.html
# extract metadata from Portable Network Graphics (PNG) image files

local ret=1

_arguments -s \
  '--soif[format output using (Harvest) SOIF format]' \
  '--html[format output in HTML as a descriptive list]' \
  '--xrdf[format output in RDF/XML]' \
  '--all[output all image info even if not usually printed]' \
  '--quiet[suppress the banner for plain text output]' \
  '--uri=[set the URI used for SOIF and XML/RDF outputs]:uri' \
  '--help[show usage information]' \
  '--version[display program and library version numbers]' \
  '*:png file:_files -g "*.(png|PNG)"' && ret=0

return ret
