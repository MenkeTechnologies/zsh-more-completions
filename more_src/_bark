#compdef bark bark-cli
# _bark — Suno AI Bark generative TTS CLI alias (Suno Inc., Python); custom argparse
# upstream: https://github.com/suno-ai/bark

_bark() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--text=+[text to synthesize]:str:' \
        '-t+[text to synthesize]:str:' \
        '--prompt=+[history voice preset]:str:' \
        '-p+[history voice preset]:str:' \
        '--history_prompt=+[history voice preset]:str:' \
        '--output=+[output file]:file:_files -g "*.wav *.mp3"' \
        '-o+[output file]:file:_files -g "*.wav *.mp3"' \
        '--text_temp=+[text temperature]:f:' \
        '--waveform_temp=+[waveform temperature]:f:' \
        '--text_use_gpu[text use GPU]' \
        '--coarse_use_gpu[coarse use GPU]' \
        '--fine_use_gpu[fine use GPU]' \
        '--codec_use_gpu[codec use GPU]' \
        '--text_use_small[use small text model]' \
        '--coarse_use_small[use small coarse model]' \
        '--fine_use_small[use small fine model]' \
        '--seed=+[seed]:n:' \
        '--silent[silent]' \
        '--server[run server]' \
        '--port=+[server port]:port:' \
        '--host=+[server host]:host:_hosts' \
        '*:arg:'
}

_bark "$@"
