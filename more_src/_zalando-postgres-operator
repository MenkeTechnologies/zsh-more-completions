#compdef zalando-postgres-operator postgres-operator
# _zalando-postgres-operator — Zalando Postgres Operator
# upstream: https://github.com/zalando/postgres-operator
# Flags from cmd/main.go init() on tip; most config comes via CONFIG_MAP_NAME env + ConfigMap.

_zalando-postgres-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster)]:file:_files' \
        '--outofcluster=[run operator outside the cluster]:bool:(true false)' \
        '--nodatabaseaccess=[disable all DB access from the operator side]:bool:(true false)' \
        '--noteamsapi=[disable all access to the teams API]:bool:(true false)' \
        '--kubeqps=[K8s API requests per second]:n:' \
        '--kubeburst=[K8s API requests burst limit]:n:'
}

_zalando-postgres-operator "$@"
