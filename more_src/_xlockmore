  '-nice+[nice priority]:n:' \
  '-no-finger[disable finger]' \
  '-allowaccess[allow access]' \
  '-allowroot[allow root]' \
  '-enablesaver[enable saver]' \
  '-grabmouse[grab mouse]' \
  '-grabserver[grab server]' \
  '-install[install colormap]' \
  '-mono[monochrome mode]' \
  '-mousemotion[mouse motion]' \
  '-nolock[no lock]' \
  '-nomonomotion[no monomotion]' \
  '-remote[allow remote keys]' \
  '-resetsaver[reset screensaver]' \
  '-sound[enable sound]' \
  '-timeelapsed[show elapsed time]' \
  '-usefirst[use first password]' \
  '-verbose[verbose]' \
  '-wireframe[wireframe]' \
  '-bg+[background color]:color:' \
  '-fg+[foreground color]:color:' \
  '-bitmap+[bitmap file]:file:_files' \
  '-bsfont+[bigsmall font]:font:' \
