  '-delay+[mode delay]:ms:' \
  '-description[describe mode]' \
  '-erasedelay+[erase delay]:ms:' \
  '-erasemode+[erase mode]:mode:' \
  '-erasetime+[erase time]:sec:' \
  '-font+[message font]:font:' \
  '-info+[info string]:str:' \
  '-invalid+[invalid string]:str:' \
  '-lockdelay+[lock delay sec]:sec:' \
  '-locktime+[lock time]:sec:' \
  '-modelist[list modes]' \
  '-mousenum[show mouse count]' \
