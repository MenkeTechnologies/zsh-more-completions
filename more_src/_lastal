#compdef lastal
# Documentation: https://gitlab.com/mcfrith/last/-/raw/main/doc/lastal.rst
# Find local alignments between query sequences and a LAST database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show all options and their default settings, and exit]' \
  '(-V --version)'{-V,--version}'[show version information, and exit]' \
  '-v[be verbose about lastal operations]' \
  '-2[specify paired query sequences]' \
  '-f+[choose the output format]:name:' \
  '-D+[report alignments expected by chance at most once per LENGTH query letters]:length:' \
  '-H+[report alignments expected by chance at most this many times]:expect:' \
  '-E+[maximum expected alignments per square giga]:expect:' \
  '-r+[match score]:score:' \
  '-q+[mismatch cost]:cost:' \
  '-p+[specify a match/mismatch score matrix]:name:' \
  '-X+[how to score matches/mismatches involving N or X]:number:' \
  '-a+[gap existence cost]:cost:' \
  '-b+[gap extension cost]:cost:' \
  '-A+[insertion existence cost]:cost:' \
  '-B+[insertion extension cost]:cost:' \
  '-c+[generalized affine gap costs parameter]:cost:' \
  '-F+[align DNA queries to protein reference sequences]:list:' \
  '-z+[maximum score drop for gapped alignments]:drop:' \
  '-x+[maximum score drop for first pass of two-pass gapped alignment]:drop:' \
  '-y+[maximum score drop for gapless alignments]:drop:' \
  '-d+[minimum score for gapless alignments]:score:' \
  '-e+[minimum alignment score]:score:' \
  '-m+[maximum multiplicity for initial matches]:multiplicity:' \
  '-l+[minimum length for initial matches]:length:' \
  '-L+[maximum length for initial matches]:length:' \
  '-k+[look for initial matches only at every STEP-th position]:step:' \
  '-W+[look for initial matches only at minimum positions in any window]:size:' \
  '-P+[number of parallel threads]:threads:' \
  '-K+[omit alignments contained in LIMIT or more other alignments]:limit:' \
  '-C+[discard gapless alignments before extension based on coverage]:limit:' \
  '-s+[specify which query strand should be used]:strand:' \
  '--reverse[reverse (but do not complement) each query sequence before analyzing]' \
  '-S+[specify how to use the substitution score matrix for reverse strands]:number:' \
  '-i+[process the query sequences in batches of at most this many bytes]:bytes:' \
  '-M[find minimum-difference alignments, faster but cruder]' \
  '-T+[type of alignment: 0=local, 1=overlap]:number:' \
  '-n+[maximum number of gapless alignments per query position]:count:' \
  '-N+[stop after finding COUNT alignments per query strand]:count:' \
  '-R+[specify lowercase-marking of repeats, by two digits]:digits:' \
  '-U+[maximum repeat unit length for simple repeats]:length:' \
  '-u+[specify treatment of lowercase letters when extending alignments]:number:' \
  '-w+[offset distance threshold for avoiding catastrophic repeat extensions]:distance:' \
  '-G+[specify the genetic code for translating DNA to protein]:genetic-code:' \
  '-t+[parameter for converting between scores and probability ratios]:temperature:' \
  '-g+[parameter affecting gamma-centroid and LAMA alignment]:gamma:' \
  '-j+[output type]:number:' \
  '-J+[score type: 0=ordinary score, 1=full score]:number:' \
  '-Q+[specify how to read the query sequences]:name:' \
  '--split[cut alignments down to a unique best alignment for each query part]' \
  '--splice[similar to --split, but favors intron/exon splicing patterns]' \
  '*:database and query:_files' && ret=0

return ret
