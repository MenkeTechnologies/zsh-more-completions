#compdef 3dXClustSim
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dXClustSim.html
# Cluster threshold simulation for the ETAC method

local ret=1

_arguments -s \
  '-inset[input mask and simulation data files]:*:files:_files' \
  '-insdat[data files in .sdat format]:*:files:_files' \
  '-NN[neighborhood connectivity]:nn:(1 2 3)' \
  '-sid[spatial index dimension]:sid:(1 2)' \
  '-hpow[H power values from 0 1 2]:hpow' \
  '-ncase[multiple processing cases with labels]:cases' \
  '-pthr[voxel-wise p-value thresholds]:thresholds' \
  '-FPR[global false positive rate goal 2-9]:fpr' \
  '-multiFPR[results across multiple FPR goals]' \
  '-minclust[minimum cluster size in voxels]:size' \
  '-local[local voxel-wise ETAC computations]' \
  '-global[global volume-wise ETAC computations]' \
  '-nolocal[skip local computations]' \
  '-noglobal[skip global computations]' \
  '-splitfrac[partition simulations 0.2-0.8]:frac' \
  '-prefix[output file prefix]:prefix' \
  '-verb[verbose output]' \
  '-quiet[suppress output messages]' && ret=0

return ret
