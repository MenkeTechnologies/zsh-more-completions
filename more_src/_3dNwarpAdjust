#compdef 3dNwarpAdjust
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dNwarpAdjust.html
# AFNI: adjust a collection of 3D warps to remove the mean warp

local ret=1

_arguments -s -S \
  '*-nwarp[input 3D warp datasets (min 5)]:warp:_files' \
  '*-source[3D datasets to be warped]:dataset:_files' \
  '-prefix[output prefix for the mean dataset]:prefix:' \
  '*:warp:_files' && ret=0

return ret
