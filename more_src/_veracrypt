#compdef veracrypt

# Zsh completion for veracrypt - disk encryption software

_arguments -s -S \
  '(-a --auto-mount)'{-a,--auto-mount}'=[auto-mount all device-hosted volumes or specified devices]:devices:' \
  '--backup-headers[backup volume headers]' \
  '(-c --create)'{-c,--create}'=[create a new volume]:volume file:_files' \
  '(-C --change)'{-C,--change}'=[change password or keyfiles of a volume]:volume file:_files' \
  '(-d --dismount)'{-d,--dismount}'=[dismount a volume]:volume file:_files' \
  '--dismount-all[dismount all mounted volumes]' \
  '(-e --encryption)'{-e,--encryption}'=[encryption algorithm]:algorithm:(AES Serpent Twofish Camellia Kuznyechik AES-Twofish AES-Twofish-Serpent Serpent-AES Serpent-Twofish-AES Twofish-Serpent Kuznyechik-AES Kuznyechik-Twofish Kuznyechik-AES-Twofish Kuznyechik-Serpent-Camellia)' \
  '--explore[open mounted volume in file manager]' \
  '--filesystem=[filesystem type for new volumes]:filesystem:(none FAT exFAT NTFS Ext2 Ext3 Ext4 Btrfs)' \
  '(-f --force)'{-f,--force}'[force mount, dismount or overwrite]' \
  '(-h --hash)'{-h,--hash}'=[hash algorithm]:algorithm:(SHA-512 SHA-256 Whirlpool RIPEMD-160 Streebog)' \
  '--help[display help]' \
  '(-k --keyfiles)'{-k,--keyfiles}'=[keyfiles or directories]:keyfiles:_files' \
  '(-l --list)'{-l,--list}'=[list mounted volumes]:volume file:_files' \
  '(-m --mount)'{-m,--mount}'=[mount a volume]:volume file:_files' \
  '--new-keyfiles=[new keyfiles for password change]:keyfiles:_files' \
  '--new-password=[new password for password change]:password:' \
  '--non-interactive[do not interact with the user]' \
  '(-p --password)'{-p,--password}'=[password]:password:' \
  '--pim=[personal iterations multiplier]:pim:' \
  '--protect-hidden=[protect hidden volume when mounting outer]:protect:(yes no)' \
  '--protection-password=[password for hidden volume protection]:password:' \
  '--random-source=[use file as random data source]:file:_files' \
  '--restore-headers[restore volume headers from backup]' \
  '--size=[size of new volume]:size:' \
  '--slot=[volume slot number]:slot:' \
  '(-t --text)'{-t,--text}'[use text user interface]' \
  '--token-lib=[PKCS#11 security token library path]:library:_files' \
  '--token-pin=[security token PIN]:pin:' \
  '--truecrypt[mount a TrueCrypt volume]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--version[display version information]' \
  '--volume-type=[type of volume to create]:type:(normal hidden)' \
  '*:volume file:_files'
