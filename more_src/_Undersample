#compdef Undersample
# Documentation: https://step.esa.int/main/wp-content/help/versions/9.0.0/snap-toolboxes/org.esa.s1tbx.s1tbx.op.utilities.ui/operators/UnderSampleOp.html
# ESA SNAP gpt Undersample operator - downsample image by sub-sampling or kernel filtering

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PunderSamplingMethod=[sub-sampling or kernel filtering]:method' \
  '-PsubSamplingInX=[downsampling rate in range direction]:rate' \
  '-PsubSamplingInY=[downsampling rate in azimuth direction]:rate' \
  '-PfilterSize=[lowpass filter size]:size' \
  '-PoutputImageBy=[method for determining output image dimension]:method' \
  '-PoutputImageRows=[row size of the downsampled image]:rows' \
  '-PoutputImageColumns=[column size of the downsampled image]:columns' \
  '-PwidthRatio=[ratio of downsampled to source image width]:ratio' \
  '-PheightRatio=[ratio of downsampled to source image height]:ratio' \
  '-PrangeSpacing=[range pixel spacing of the downsampled image]:spacing' \
  '-PazimuthSpacing=[azimuth pixel spacing of the downsampled image]:spacing' \
  '*:graph xml:_files' && ret=0

return ret
