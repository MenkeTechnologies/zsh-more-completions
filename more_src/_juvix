#compdef juvix
# _juvix — Heliax Anoma Juvix dependently-typed functional language for zero-knowledge applications (anoma team, Haskell); optparse-applicative
# upstream: https://github.com/anoma/juvix

_juvix() {
    local -a sub=(
        'compile:compile to native or VampIR'
        'eval:evaluate a Juvix file'
        'typecheck:typecheck without compilation'
        'repl:start interactive repl'
        'format:format source files'
        'doctor:check setup'
        'init:create a new project'
        'clean:clean build outputs'
        'dev:developer subcommands'
        'html:generate HTML documentation'
        'markdown:render markdown to HTML'
        'dependencies:dependency subcommands'
        'tree:show import tree'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--no-colors[disable color]' \
        '--show-name-ids[show name ids]' \
        '--only-errors[errors only]' \
        '--target=+[target]:t:(native wasm32-wasi geb vampir core asm reg tree nockma anoma cairo riscv32 risc0)' \
        '--internal-build-dir=+[build dir]:dir:_files -/' \
        '--global[use global config]' \
        '--log-level=+[level]:l:(debug info warning error)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'juvix subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--target=+[target]:t:(native wasm32-wasi geb vampir core asm reg tree nockma anoma cairo riscv32 risc0)' \
                    '-t+[target]:t:(native wasm32-wasi geb vampir core asm reg tree nockma anoma cairo riscv32 risc0)' \
                    '--debug[debug mode]' \
                    '-g[debug mode]' \
                    '--optimize-level=+[level]:n:' \
                    '-O+[level]:n:' \
                    '--inlining-depth=+[depth]:n:' \
                    '*:file:_files -g "*.juvix"' ;;
                eval|typecheck|format|html|markdown|tree) _arguments \
                    '*:file:_files -g "*.juvix"' ;;
                dev) _arguments '1:dev cmd:(parse scope highlight internal core tree asm geb anoma migrate-juvix-yaml runtime profile vampir nockma cairo to-runtime-from-yaml display-root)' ;;
                init) _arguments \
                    '--name=+[name]:str:' \
                    '*:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_juvix "$@"
