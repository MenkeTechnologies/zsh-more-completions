#compdef paperwork paperwork-cli paperwork-shell
# Documentation: https://gitlab.gnome.org/World/OpenPaperwork/paperwork
# Reference accessed: 2026-05-16
# Verified: upstream OpenPaperwork/paperwork (paperwork-shell). Plugin-
# based subcommand dispatcher; per-command flags listed in upstream
# source.
# Removed from prior file: bogus man.archlinux.org search URL.

# paperwork: personal document manager (CLI subcommand shell)
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'sync:synchronize document index with work directory'
  'show:show document content (--pages)'
  'search:search documents (-l --limit)'
  'scanner:scanner subcommands list/get/set'
  'scan:scan a new document (-d --doc_id)'
  'reset:reset a document (-p --pages)'
  'rename:rename a document'
  'ocr:OCR a document (-p --pages)'
  'move:move a document'
  'label:label subcommands list/show/add/remove/delete'
  'import:import files (-d --doc_id)'
  'extra_text:get/set extra text'
  'export:export document(s) (-p --pages -f --filters -o --out)'
  'edit:edit document pages (-m --modifiers)'
  'delete:delete a document'
  'config:config subcommands get/put/show/list_types'
  'plugins:plugin subcommands list/add/remove/reset/show'
  'about:show about info'
  'chkworkdir:check work directory'
  'copy:copy a document'
  'https:HTTPS-related subcommands'
)
_arguments -C \
  '--help[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'paperwork command' commands && ret=0 ;;
esac
return ret
