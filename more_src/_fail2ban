#compdef fail2ban-client

# Zsh completion for fail2ban-client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start server and jails'
  'restart:restart server'
  'reload:reload configuration'
  'stop:stop all jails and server'
  'status:get current status'
  'ping:test if server is alive'
  'set:set property'
  'get:get property'
  'unban:unban IP address'
  'banned:list banned IPs'
  'flushlogs:flush server log files'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  '(-c --conf)'{-c+,--conf=}'[config directory]:directory:_files -/' \
  '(-d --dump)'{-d,--dump}'[dump config]' \
  '(-p --pidfile)'{-p+,--pidfile=}'[PID file]:pid file:_files' \
  '(-s --socket)'{-s+,--socket=}'[socket path]:socket file:_files' \
  '(-x --force)'{-x,--force}'[force execution]' \
  '(-b --backend)'{-b+,--backend=}'[backend]:backend:(auto pyinotify gamin polling systemd)' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '--loglevel=[set log level]:level:(CRITICAL ERROR WARNING NOTICE INFO DEBUG TRACEDEBUG HEAVYDEBUG)' \
  '--logtarget=[set log target]:target:(STDOUT STDERR SYSLOG)' \
  '--syslogsocket=[set syslog socket]:socket:(auto)' \
  '--test[test configuration]' \
  '--async[send commands asynchronously]' \
  '--timeout=[timeout for server response]:seconds:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'fail2ban-client command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      status)
        _arguments '1:jail name:' && ret=0
        ;;
      set|get)
        _arguments '1:jail name:' '2:property:' && ret=0
        ;;
      unban)
        _arguments '*:IP address:' && ret=0
        ;;
      start|stop|restart|reload)
        _arguments '1:jail name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
