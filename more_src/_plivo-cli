#compdef plivo-cli plivo
# _plivo-cli — Plivo plivo-cli CLI command-line frontend wrapping the Plivo Communications Platform REST API managing accounts messages calls verifications numbers applications endpoints conferences recordings media subaccounts pricing CNAM-lookup PHLO Premium-Routes virtual-number sms-mms verify identity (Plivo team, Go); cobra
# upstream: https://www.plivo.com/

_plivo-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'message:message operations'
        'call:call operations'
        'verify:verify operations'
        'number:number operations'
        'application:application operations'
        'endpoint:endpoint operations'
        'conference:conference operations'
        'recording:recording operations'
        'media:media operations'
        'subaccount:subaccount operations'
        'pricing:pricing operations'
        'cnam:CNAM lookup'
        'phlo:PHLO flow operations'
        'identity:identity operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--auth-id=+[id]:str:' \
        '--auth-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'plivo-cli subcommand' sub ;;
        args)
            case $words[1] in
                message|call|verify|number|application|endpoint|conference|recording|media|subaccount|cnam|phlo|identity) _arguments '1:op:(list get create update delete send hangup transfer)' '*:id:' ;;
            esac
            ;;
    esac
}

_plivo-cli "$@"
