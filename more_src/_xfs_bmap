#compdef xfs_bmap
# _xfs_bmap — xfsprogs xfs_bmap (print extent block mappings for a file; -a includes attribute fork, -d data fork (default), -e shows extent-flags, -l show shared blocks, -n max extents to print, -p shows offset in page-cache units, -v verbose with hex offsets)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs bmap/bmap.c on tip.

_xfs_bmap() {
    _arguments \
        '-a[show attribute fork]' \
        '-d[show data fork (default)]' \
        '-e[print extent flags]' \
        '-l[show shared blocks]' \
        '-n+[max extents]:n:' \
        '-p[print offset in page-cache units]' \
        '-v[verbose]' \
        '*:file:_files'
}

_xfs_bmap "$@"
