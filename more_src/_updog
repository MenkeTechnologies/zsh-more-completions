#compdef updog
# Documentation: https://man.archlinux.org/search?q=updog
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[directory to serve]:directory:_directories' \
  '-p+[port to serve on]:port' \
  '--password=[password for authentication]:password' \
  '--ssl[enable SSL]' && ret=0

return ret
