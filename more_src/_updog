#compdef updog
# Documentation: https://github.com/sc0tfree/updog
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --directory)'{-d,--directory}'+[root directory to serve]:directory:_directories' \
  '(-b --bind)'{-b,--bind}'+[bind to specific address]:address:' \
  '(-p --port)'{-p,--port}'+[port to serve on]:port' \
  '--password=[password for authentication]:password' \
  '--ssl[enable SSL with ad-hoc certificate]' \
  '--ssl-cert=[path to custom SSL certificate]:cert:_files' \
  '--ssl-key=[path to custom SSL private key]:key:_files' \
  '--cors[enable CORS headers]' \
  '--hide-base-path[hide full directory path]' && ret=0

return ret
