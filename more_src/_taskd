#compdef taskd

# Zsh completion for taskd (Taskwarrior server daemon)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:Initialize a server instance'
  'config:Manage server configuration'
  'server:Run the server'
  'add:Add an organization or user'
  'remove:Remove an organization or user'
  'suspend:Suspend an organization or user'
  'resume:Resume a suspended organization or user'
  'status:Show server status'
  'diagnostics:Print diagnostic information'
  'help:Show help'
)

_arguments -s -S -C \
  '--data=[Set data directory]:data dir:_files -/' \
  '--quiet[Minimal output]' \
  '--debug[Enable debug mode]' \
  '--force[Force operation without confirmation]' \
  '--daemon[Run as a daemon]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'taskd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments '--data=[Set data directory]:data dir:_files -/' && ret=0
        ;;
      config)
        _arguments \
          '--data=[Set data directory]:data dir:_files -/' \
          '--force[Force setting the value]' \
          ':name' ':value' && ret=0
        ;;
      add|remove|suspend|resume)
        _arguments \
          '--data=[Set data directory]:data dir:_files -/' \
          ':type:(org user)' ':name' && ret=0
        ;;
      server)
        _arguments \
          '--data=[Set data directory]:data dir:_files -/' \
          '--daemon[Run as a daemon]' && ret=0
        ;;
    esac
    ;;
esac

return ret
