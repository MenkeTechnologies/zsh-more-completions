#compdef taskd
# Documentation: https://github.com/GothenburgBitFactory/taskserver/blob/master/doc/man/taskd.1.in
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for taskd (Taskwarrior server daemon)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:one-time initialization of the Taskserver instance'
  'config:modify the taskd configuration'
  'server:start the server in daemon or TTY mode'
  'add:add organizations, groups, and users'
  'remove:remove organizations, groups, and users'
  'suspend:suspend organizations, groups, and users'
  'resume:resume suspended organizations, groups, and users'
  'diagnostics:display diagnostic information'
  'validate:parse a JSON string or file'
  'client:send a Taskserver request to host and port'
  'help:show syntax help for a command'
)

_arguments -s -S -C \
  '--data=[data root location]:data dir:_files -/' \
  '--quiet[suppress verbose output]' \
  '--debug[show debugging information]' \
  '--force[do not ask for confirmation]' \
  '--daemon[run server in daemon mode]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'taskd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      init)
        _arguments '--data=[data root]:dir:_files -/' && ret=0
        ;;
      config)
        _arguments \
          '--data=[data root]:dir:_files -/' \
          '--force[force setting the value]' \
          ':name:' ':value:' && ret=0
        ;;
      add|remove|suspend|resume)
        _arguments \
          '--data=[data root]:dir:_files -/' \
          ':type:(org group user)' ':name:' && ret=0
        ;;
      server)
        _arguments \
          '--data=[data root]:dir:_files -/' \
          '--daemon[run as a daemon]' && ret=0
        ;;
      validate)
        _arguments '*::json:_files' && ret=0
        ;;
      client)
        _arguments ':host:' ':port:' '*::message:' && ret=0
        ;;
    esac
    ;;
esac

return ret
