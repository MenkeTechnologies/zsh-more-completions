# Reference accessed: 2026-05-30 via gh api.
#
# cyber is the **Cyber programming language** by
# fubark — embedded dynamic scripting language
# (similar to Lua but with Zig influence).  Pivots
# from Nim parseopt (R287 nimpretty) into the **Zig
# language tooling cluster**.  Sister to zig
# (compiler), zigup (version manager), zls (language
# server).  **MAJOR MILESTONE**: corpus's **first
# documented Zig CLI** — adds Zig to the cross-
# language CLI taxonomy (27 library variants now).
#
# Critical extraction note: cyber uses **Zig's stdlib
# `std.process.argsAlloc`** at `const args = try std
# .process.argsAlloc(alloc)` — corpus's **first
# documented Zig CLI**.  Zig has NO dedicated CLI
# parsing library in the stdlib — only the low-level
# `argsAlloc` / `argsFree` functions that return the
# argv as `[][]const u8` (slice of string slices).
# All higher-level parsing is HAND-ROLLED or via
# third-party libraries (zig-clap is popular).  cyber
# uses the LOWEST-LEVEL approach — manual while-loop
# parsing.  Extends the **cross-language CLI taxonomy**
# to TWENTY-SEVEN library variants: Rust (6), Go (4),
# Python (3), Crystal OptionParser (R269), Haskell
# optparse-applicative (R270), OCaml Cmdliner (R271),
# C POSIX getopt (R272), Java picocli (R276), Kotlin
# clikt (R277), Scala decline (R278), Dart args
# (R279), Ruby OptionParser (R280), Perl Getopt::Long
# (R281), PHP Symfony Console (R282), Swift
# ArgumentParser (R283), F# Argu (R284), Lua argparse
# (R285), C# System.CommandLine (R286), Nim parseopt
# (R287), **Zig std.process.argsAlloc** (R288 — NEW).
# **MAJOR PATTERN MILESTONE**: 27 cross-language CLI
# library variants documented.
#
# Critical extraction note: cyber uses **ALLOCATOR-
# BASED argv** at main.zig:46-47 — `std.process
# .argsAlloc(alloc)` takes an allocator parameter and
# the caller must `std.process.argsFree(alloc, args)`
# to release memory.  Documents the **explicit-
# allocator CLI pattern** — UNIQUE to Zig.  Every
# other language in the corpus's taxonomy has
# automatic memory management for argv (Rust's
# `std::env::args()` returns an iterator with
# lifetime tied to the program; Go's `os.Args` is a
# slice owned by the runtime; etc.).  Zig requires
# the developer to pass an allocator and free the
# result.  Documents Zig's **allocator-as-first-class-
# parameter** design philosophy — corpus's **first
# documented allocator-parameter CLI pattern**.
#
# Critical extraction note: cyber uses **`defer` for
# cleanup** at main.zig:47 — `defer std.process
# .argsFree(alloc, args)` schedules the cleanup call
# to run at scope exit.  Documents Zig's **defer
# statement** — similar to Go's `defer` (R263 lazygit)
# but at the language level.  Combined with the
# allocator-based argv, this is Zig's RAII-like
# resource management.  Distinct from C's manual
# `free()` (R272 blink — easy to forget) and from
# Rust's `Drop` trait (automatic).
#
# Critical extraction note: cyber uses **`std.mem.eql
# (u8, arg, "-v")`** for string comparison at
# main.zig:56-71 — Zig has NO operator overloading,
# so slice equality requires the stdlib `std.mem.eql`
# function call with the type parameter (`u8` for
# byte slices).  Documents the **explicit-type-
# parameter equality** pattern — distinct from
# clap derive's `match arg.as_str()` (R273 irust),
# Crystal's `==` (R269 shards), Lua's `==` (R285
# luacheck).  Zig's verbosity is intentional — no
# hidden operations.  Corpus's **first documented
# `std.mem.eql` slice-equality CLI pattern**.
#
# Critical extraction note: cyber uses **manual
# `while (i < args.len) : (i += 1)`** at main.zig:53
# — Zig's `while` loop with **CONTINUATION
# EXPRESSION** (the `: (i += 1)` part).  Equivalent
# to a C-style `for (i = 1; i < args.len; i++)`.
# Documents Zig's **while-with-continuation-expression
# syntax** — similar to C's for loop but using `while`
# keyword.  Plus the manual index counter allows
# `break;` to exit early (used at main.zig:96 to
# stop flag parsing after first positional).
# Documents the **manual-iterator CLI parsing** —
# corpus's first explicit-index while-loop CLI
# parsing.
#
# Critical extraction note: cyber uses **SILENT
# ACCEPTANCE of unknown flags** at main.zig:79-80 —
# the comment reads "Ignore unrecognized options so
# a script can use them."  Unknown flags are SILENTLY
# DROPPED (not added to a positional list, not
# errored).  Documents the **silent-unknown-flag
# pattern** for SCRIPT FORWARDING — distinct from
# R273 irust's `unknown_args` Vec collection (warns
# to stderr) and from clap derive's strict-unknown
# default (errors out).  Useful when a CLI wraps an
# underlying interpreter that needs to see its own
# flags.  Corpus's **first documented silent-unknown-
# flag forwarding** for embedded interpreter
# scenarios.
#
# Critical extraction note: cyber uses **mixed flag/
# subcommand parsing with `break;`** at main.zig:81-
# 105 — the same `while` loop handles BOTH flags
# (`-v`, `-r`, etc.) AND subcommands (`compile`,
# `fmt`, etc.).  When the first positional arg is
# encountered AND it's NOT a known subcommand, cyber
# sets `cmd = .eval` (default eval mode), saves the
# arg as `arg0`, and `break`s out of the parsing
# loop.  Documents the **mixed-flag/subcommand parsing
# with break-on-positional** pattern — distinct from
# clap derive's separate subcommand parsing (R247+)
# and from Click's `@click.group` (R266).  Zig's
# approach is the most MANUAL but also the most
# FLEXIBLE — the developer controls when to stop
# parsing.  Corpus's **first documented break-on-
# positional parsing**.

local curcontext="$curcontext" state line ret=1

# 6 subcommands decoded source-direct from Command
# enum at main.zig:139-146.
local -a subcommands=(
  'compile:compile and dump the code'
  'fmt:reformat the source code (TODO; calls panic)'
  'help:print usage'
  'version:print version number'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help (manual writeHelp proc)]' \
  '-v[verbose output]' \
  '-r[refetch url imports and cached assets]' \
  '(-vm -cc -tcc -jit)-vm[compile to bytecode (DEFAULT; fast build, slow perf)]' \
  '(-vm -cc -tcc -jit)-cc[compile to C with optimizations (slow build, fast perf; experimental)]' \
  '(-vm -cc -tcc -jit)-tcc[compile to C with builtin TinyC (mid build, mid perf; experimental)]' \
  '(-vm -cc -tcc -jit)-jit[compile to machine code based on bytecode (fast build, mid perf; experimental)]' \
  '-stats[dump stats (trace build only)]' \
  '1: :->subcmd_or_source' \
  '*::args:->args' && ret=0

case $state in
  subcmd_or_source)
    # cyber's first positional may be a subcommand
    # OR a source file (eval mode).  Offer both.
    _alternative \
      'subcommands:cyber subcommand:_describe -t subcommands "subcommand" subcommands' \
      'sources:Cyber source file:_files -g "*.cy"' && ret=0
    ;;
  args)
    case $words[1] in
      compile|fmt)
        _arguments \
          '1:source file:_files -g "*.cy"' \
          '*::args:_default' && ret=0
        ;;
      *)
        # eval mode (default when first arg is a file)
        _files -g "*.cy" && ret=0
        ;;
    esac
    ;;
esac

return ret
