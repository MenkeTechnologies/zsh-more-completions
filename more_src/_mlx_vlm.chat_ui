#compdef mlx_vlm.chat_ui
# Documentation: https://github.com/Blaizzy/mlx-vlm/blob/main/docs/usage.md
# MLX-VLM: launch a Gradio chat interface for a vision-language model

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model=[model identifier or path]:model:' && ret=0

return ret
