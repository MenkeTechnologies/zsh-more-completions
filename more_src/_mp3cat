#compdef mp3cat
# Documentation: https://github.com/dmulholl/mp3cat
# mp3cat - join/concatenate MP3 files without re-encoding

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display help text and exit]' \
  '(-v --version)'{-v,--version}'[display the version number]' \
  '(-o --out)'{-o,--out}'+[output filepath]:file:_files' \
  '(-d --dir)'{-d,--dir}'+[directory of files to merge]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[overwrite an existing output file]' \
  '(-q --quiet)'{-q,--quiet}'[run in quiet mode]' \
  '*:mp3 file:_files -g "*.mp3"' && ret=0

return ret
