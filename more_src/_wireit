local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '--watch[enable watch mode (event-based by default)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*::extra args after --:_default' \
    && ret=0

return ret
