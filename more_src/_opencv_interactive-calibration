#compdef opencv_interactive-calibration
# Documentation: https://docs.opencv.org/4.x/d7/d21/tutorial_interactive_calibration.html
# opencv_interactive-calibration — interactive camera calibration application

local ret=1

_arguments -s -S \
  '-v=[get video from filename]:file:_files' \
  '-ci=[get video from camera with specified id]:id' \
  '-flip=[vertical flip of input frames]:flip:(true false)' \
  '-t=[calibration pattern]:pattern:(circles chessboard dualCircles chAruco symcircles)' \
  '-sz=[distance between nearest centers of circles or squares]:distance' \
  '-dst=[distance between white and black parts of dualCircles]:distance' \
  '-w=[width of pattern in corners or circles]:width' \
  '-h=[height of pattern in corners or circles]:height' \
  '-of=[output file name]:file:_files' \
  '-ft=[auto tuning of calibration flags]:tune:(true false)' \
  '-vis=[captured boards visualization]:vis:(grid window)' \
  '-d=[delay between captures in seconds]:delay' \
  '-pf=[advanced application parameters file]:file:_files' \
  '-force_reopen=[forcefully reopen camera on errors]:reopen:(true false)' \
  '-save_frames=[save frames that contribute to calibration]:save:(true false)' \
  '-zoom=[zoom factor applied to the preview image]:zoom' && ret=0

return ret
