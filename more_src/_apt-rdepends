#compdef apt-rdepends

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d[generate output in dotty format]' \
  '--dotty[generate output in dotty format]' \
  '-r[show reverse dependencies]' \
  '--reverse[show reverse dependencies]' \
  '-f+[only follow dependencies of specified type]:type' \
  '--follow=[only follow dependencies of specified type]:type' \
  '-s+[only show packages in specified state]:state' \
  '--state-follow=[only show packages in specified state]:state' \
  '-p[print package state]' \
  '--print-state[print package state]' \
  '--build-depends[show build dependencies]' \
  '--component=[limit to specific component]:component:(main contrib non-free)' \
  '*:package:_deb_packages avail' && ret=0

return ret
