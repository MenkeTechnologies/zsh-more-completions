#compdef mesos-agent mesos-slave

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--work_dir=[work directory (required)]:dir:_files -/' \
  '--master=[master URL or zk://]:master:' \
  '--ip=[bind IP]:addr:' \
  '--port=[bind port]:port:' \
  '--hostname=[hostname]:host:_hosts' \
  '--attributes=[attributes]:attrs:' \
  '--resources=[resources]:res:' \
  '--isolation=[isolation modules]:list:' \
  '--containerizers=[containerizers]:list:' \
  '--default_container_image=[default container image]:image:' \
  '--executor_environment_variables=[executor env]:json:' \
  '--executor_registration_timeout=[executor registration timeout]:duration:' \
  '--executor_shutdown_grace_period=[executor shutdown grace]:duration:' \
  '--launcher=[launcher type]:launcher:(linux posix)' \
  '--launcher_dir=[launcher binaries dir]:dir:_files -/' \
  '--switch_user[change task uid]' \
  '--no-switch_user[do not change uid]' \
  '--registration_backoff_factor=[registration backoff]:duration:' \
  '--credential=[credential file]:file:_files' \
  '--default_role=[default role]:role:' \
  '--gc_delay=[GC delay]:duration:' \
  '--gc_disk_headroom=[GC disk headroom]:fraction:' \
  '--frameworks_home=[frameworks home]:dir:_files -/' \
  '--fetcher_cache_dir=[fetcher cache dir]:dir:_files -/' \
  '--fetcher_cache_size=[fetcher cache size]:bytes:' \
  '--cgroups_root=[cgroups root]:path:' \
  '--cgroups_hierarchy=[cgroups hierarchy]:path:' \
  '--docker=[docker binary path]:path:_command_names -e' \
  '--docker_socket=[docker socket]:path:_files' \
  '--docker_registry=[docker registry]:url:' \
  '--docker_remove_delay=[docker remove delay]:duration:' \
  '--http_credentials=[HTTP credentials file]:file:_files' \
  '--http_authenticators=[HTTP authenticators]:list:' \
  '--authenticatee=[authenticatee module]:name:' \
  '--authentication_backoff_factor=[auth backoff factor]:duration:' \
  '--log_dir=[log directory]:dir:_files -/' \
  '--logging_level=[log level]:level:(INFO WARNING ERROR)' \
  '--logbufsecs=[log buffer seconds]:secs:' \
  '--recover=[recovery mode]:mode:(reconnect cleanup)' \
  '--recovery_timeout=[recovery timeout]:duration:' \
  '--strict=[strict mode]:flag:(true false)' \
  '--ssl=[enable SSL]:flag:(true false)' \
  '--systemd_enable_support=[systemd support]:flag:(true false)' \
  '--cqos=[cQoS controllers]:list:' && ret=0

return ret
