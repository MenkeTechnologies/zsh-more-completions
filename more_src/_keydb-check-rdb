#compdef keydb-check-rdb
# Documentation: https://man.archlinux.org/search?q=keydb-check-rdb
# Reference accessed: 2026-05-16

# keydb-check-rdb: RDB integrity check
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '*:RDB file:_files -g "*.rdb"' && ret=0
return ret
