#compdef keydb-check-rdb
# Documentation: https://github.com/Snapchat/KeyDB/blob/main/src/redis-check-rdb.cpp
# Reference accessed: 2026-05-19
# Verified: upstream redis-check-rdb.cpp prints "Usage: %s <rdb-file-name>"
# and accepts exactly one positional argument; it has no --help flag.
# Corrected from prior file: removed fabricated --help option.

# keydb-check-rdb: RDB integrity check (single rdb-file argument)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:RDB file:_files' && ret=0
return ret
