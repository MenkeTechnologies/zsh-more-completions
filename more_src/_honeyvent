#compdef honeyvent

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --writekey)'{-k+,--writekey=}'[Honeycomb write key]:key:' \
  '(-d --dataset)'{-d+,--dataset=}'[dataset name]:dataset:' \
  '(-t --time)'{-t+,--time=}'[event timestamp (RFC3339)]:time:' \
  '(-S --sample-rate)'{-S+,--sample-rate=}'[sample rate]:n:' \
  '(-T --tags)*'{-T+,--tags=}'[tag key:value]:tag:' \
  '*'{-n+,--name=}'[field name]:name:' \
  '*'{-v+,--value=}'[field value]:value:' \
  '--api_host=[Honeycomb API host]:url:' \
  '--api-host=[Honeycomb API host]:url:' \
  '--debug[debug output]' && ret=0

return ret
