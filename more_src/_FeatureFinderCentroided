#compdef FeatureFinderCentroided
# OpenMS TOPP: detect two-dimensional features in centroided LC-MS data

local ret=1

_arguments -s -S \
  '-in[input mzML file]:input file:_files' \
  '-out[output featureXML file]:output file:_files' \
  '-seeds[user-specified seed list (featureXML)]:file:_files' \
  '-faims_merge_features[merge FAIMS features at different compensation voltages]:bool:' \
  '-algorithm:intensity:bins[scoring bins for peak intensity significance]:n:' \
  '-algorithm:mass_trace:mz_tolerance[mass trace m/z tolerance]:value:' \
  '-algorithm:isotopic_pattern:charge_low[lowest charge to consider]:n:' \
  '-algorithm:isotopic_pattern:charge_high[highest charge to consider]:n:' \
  '-algorithm:seed:min_score[minimum seed score]:value:' \
  '-algorithm:feature:min_score[minimum overall feature quality]:value:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
