#compdef wig2bed
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/file-management/conversion/wig2bed.html
# convert WIG signal data to sorted BED (bedops)

local ret=1

_arguments -s -S \
  '--keep-header[preserve header data as BED elements named _header]' \
  '--zero-indexed[input WIG data uses zero-based indexing]' \
  '--multisplit[split multiple WIG sections into separate elements]:id' \
  '--do-not-sort[disable automatic sorting of converted output]' \
  '--max-mem[limit sort memory usage]:mem' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
