#compdef vokoscreen
# Documentation: https://man.archlinux.org/search?q=vokoscreen
# Reference accessed: 2026-05-16

# vokoScreen: Qt screen recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*::vokoscreen args:_files' && ret=0
return ret
