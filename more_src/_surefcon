#compdef surefcon
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/convolution_correlation/surefcon.c
# SUREFCON - Convolution of forward and reverse refraction shots

local ret=1

_arguments -s -S \
  'sufile=[file with SU trace to use as reverse shot]:f:_files' \
  'xy=[number of traces offset from 1st trace in sufile]:n:' \
  '*:SU file:_files' && ret=0

return ret
