#compdef otftotfm
# Documentation: otftotfm --help (lcdf-typetools)
# Source: lcdf-typetools otftotfm — generate TeX font metrics from an OpenType font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --script)'{-s,--script=}'[script[.lang] for features (default latn)]:script:' \
    '*'{-f,--feature=}'[activate OpenType feature]:feat:' \
    '*--lf=[activate letter-only feature]:feat:' \
    '*--letter-feature=[activate letter-only feature]:feat:' \
    '*--subs-filter=[substitute only chars matching PAT]:pat:' \
    '*--include-subs=[include substitution chars]:pat:' \
    '*--exclude-subs=[exclude substitution chars]:pat:' \
    '--clear-subs[clear included/excluded substitutions]' \
    '(-E --extend)'{-E,--extend=}'[widen characters by factor F]:F:' \
    '(-S --slant)'{-S,--slant=}'[oblique characters by AMT]:amt:' \
    '(-L --letterspacing)'{-L,--letterspacing=}'[letter-space by AMT units]:amt:' \
    '--math-spacing=-[math letterspacing]::skewch:' \
    '(-k --min-kern)'{-k,--min-kern=}'[omit kerns below absolute N]:n:' \
    '--space-factor=[scale wordspace by F]:f:' \
    '--design-size=[font design size]:size:' \
    '--fixed-width[set fixed width (no space stretch)]' \
    '--italic-angle=[italic angle (for accents)]:angle:' \
    '--x-height=[x-height in units]:amt:' \
    '(-e --encoding)'{-e,--encoding=}'[DVIPS base encoding file]:file:_files' \
    '--boundary-char=[set boundary character]:char:' \
    '--altselector-char=[set alternate selector char]:char:' \
    '--altselector-feature=[activate feature for altselector]:feat:' \
    '*--alternates-filter=[include only alternates matching PAT]:pat:' \
    '*--include-alternates=[include alternates]:pat:' \
    '*--exclude-alternates=[exclude alternates]:pat:' \
    '--clear-alternates[clear included/excluded alternates]' \
    '*--ligkern=[add a ligature or kern command]:command:' \
    '*--position=[add a POSITION command]:command:' \
    '*--unicoding=[add a UNICODING command]:command:' \
    '--no-encoding-commands[ignore encoding LIGKERN/UNICODINGs]' \
    '--no-default-ligkern[do not include default LIGKERNs]' \
    '--coding-scheme=[output coding scheme]:scheme:' \
    '--warn-missing[warn about unsupported chars]' \
    '--literal-encoding=[use DVIPS encoding verbatim]:file:_files' \
    '--base-encodings=[output may refer to base fonts named in FILE]:file:_files' \
    '(-a --automatic)'{-a,--automatic}'[install in TeX Directory Structure]' \
    '(-v --vendor)'{-v,--vendor=}'[TDS font vendor (default lcdftools)]:name:' \
    '--map-file=[map file output]:file:_files' \
    '--tfm-directory=[directory for TFM output]:dir:_files -/' \
    '--pl-directory=[directory for PL output]:dir:_files -/' \
    '--vf-directory=[directory for VF output]:dir:_files -/' \
    '--vpl-directory=[directory for VPL output]:dir:_files -/' \
    '--type1-directory=[directory for Type1 PFA/PFB output]:dir:_files -/' \
    '--type42-directory=[directory for Type42 output]:dir:_files -/' \
    '--encoding-directory=[directory for ENC output]:dir:_files -/' \
    '--truetype-directory=[directory for TTF output]:dir:_files -/' \
    '--opentype-directory=[directory for OTF output]:dir:_files -/' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:OpenType font file:_files -g "*.{otf,ttf}"' \
    '2:font name:' \
    && ret=0

return ret
