_pending-dns() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--dbs.redis=[Redis connection URL]:url:' \
        '--log.level=[log level (default trace)]:level:(trace debug info warn error fatal)' \
        '--api.host=[REST API bind address (default 127.0.0.1)]:host:' \
        '--api.port=[REST API port (default 5080)]:port:' \
        '--dns.host=[authoritative DNS bind address (default 127.0.0.1)]:host:' \
        '--dns.port=[authoritative DNS port (default 5053)]:port:' \
        '1: :->cmd' && ret=0

    case $state in
        cmd)
            local -a _pd_cmds=(
                'help:show usage help'
                'version:show version'
            )
            _describe -t commands 'pending-dns command' _pd_cmds && ret=0
            ;;
    esac

    return ret
}

_pending-dns "$@"
