#compdef kubectl-mayastor
# Documentation: https://github.com/openebs/mayastor-extensions/blob/develop/k8s/plugin/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-r --rest)'{-r+,--rest=}'[REST endpoint]:url:' \
  '(-k --kube-config-path)'{-k+,--kube-config-path=}'[kubeconfig path]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[mayastor namespace]:namespace:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(yaml json)' \
  '(-t --timeout)'{-t+,--timeout=}'[REST operation timeout]:duration:' \
  '(-j --jaeger)'{-j+,--jaeger=}'[Jaeger tracing endpoint]:url:' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'get:get resources'
      'scale:scale resources'
      'set:set resource properties'
      'cordon:cordon resources'
      'uncordon:uncordon resources'
      'drain:drain resources'
      'label:label resources'
      'dump:collect system diagnostics'
      'upgrade:upgrade the deployment'
      'delete:delete resources'
    )
    _describe -t commands 'kubectl-mayastor command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
