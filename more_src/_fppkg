#compdef fppkg
# Documentation: fppkg --help (Free Pascal package manager)
# Source: install / list / build Free Pascal packages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'update:update packages list'
    'list:list available and installed packages'
    'build:build package'
    'compile:compile package'
    'install:install package'
    'uninstall:uninstall package'
    'clean:clean package'
    'archive:create package archive'
    'download:download package'
    'convertmk:convert Makefile.fpc to fpmake.pp'
    'info:show package info'
    'fixbroken:recompile broken packages'
    'listsettings:show fppkg settings'
)

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-C --config-file)'{-C+,--config-file=}'[configuration file]:file:_files' \
    '(-c --config)'{-c+,--config=}'[compiler config to use]:config:' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-d --debug)'{-d,--debug}'[debug output]' \
    '(-f --force)'{-f,--force}'[force install over existing]' \
    '(-r --recovery)'{-r,--recovery}'[recovery mode (internal fpmkunit)]' \
    '(-b --broken)'{-b,--broken}'[do not stop on broken packages]' \
    '(-l --showlocation)'{-l,--showlocation}'[show install location]' \
    '(-o --options)'{-o+,--options=}'[extra compiler options]:options:' \
    '-n[do not read default configuration files]' \
    '(-p --prefix)'{-p+,--prefix=}'[install prefix]:dir:_files -/' \
    '(-s --skipbroken)'{-s,--skipbroken}'[skip rebuild of dependents after install]' \
    '(-i --installlocation)'{-i+,--installlocation=}'[install destination repository]:name:' \
    '--compiler=[compiler executable]:exe:_command_names -e' \
    '--cpu=[target CPU]:cpu:' \
    '--os=[target OS]:os:' \
    '1:action:->verbs' \
    '*:package:' \
    && ret=0

case $state in
    verbs) _describe -t verbs action verbs && ret=0 ;;
esac

return ret
