#compdef gatk4
# Documentation: https://gatk.broadinstitute.org/hc/en-us/articles/360037503591-User-Guide
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# GATK 4: Broad Institute Genome Analysis Toolkit (Picard + GATK merged)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'HaplotypeCaller:call SNPs and indels via local de novo assembly'
  'Mutect2:somatic SNV+indel caller'
  'GenotypeGVCFs:joint genotyping from gVCFs'
  'CombineGVCFs:combine multiple gVCFs'
  'VariantFiltration:filter variant calls'
  'SelectVariants:select subset of variants'
  'BaseRecalibrator:calculate covariates for BQSR'
  'ApplyBQSR:apply base quality score recalibration'
  'AnalyzeCovariates:produce QC plots for BQSR'
  'MarkDuplicates:mark duplicate reads (was Picard)'
  'SortSam:sort BAM by coordinate or query name'
  'MergeBamAlignment:merge uBAM with aligned BAM'
  'ValidateSamFile:validate BAM/SAM file'
  'CollectMultipleMetrics:run multiple Picard metric tools'
  'CollectWgsMetrics:WGS coverage metrics'
  'CollectInsertSizeMetrics:insert size distribution'
  'CountReads:count reads in BAM'
  'CountVariants:count variant records'
  'IndexFeatureFile:index VCF/BED for random access'
  'CreateSequenceDictionary:create .dict for FASTA reference'
  'PrintReads:print/extract subset of reads'
  'GatherVcfs:concatenate VCFs from same samples'
  'MergeVcfs:merge VCFs (more general)'
  'CalculateGenotypePosteriors:Bayesian genotype refinement'
  'CNNScoreVariants:CNN-based variant filter scoring'
)

_arguments -C \
  '--help[show help]' \
  '--list[list available tools]' \
  '--version[show version]' \
  '--java-options[pass JVM options]:opts:' \
  '--tmp-dir[temporary directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'GATK tool' commands && ret=0 ;;
esac

return ret
