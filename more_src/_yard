#compdef yard
# Documentation: https://github.com/lsegal/yard/blob/main/lib/yard/cli/yardoc.rb
# Reference accessed: 2026-05-21
# Verified: upstream YARD CLI source (yardoc.rb, server.rb) at the URL above.

# Zsh completion for yard (YARD Ruby documentation tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'doc:generate documentation'
      'graph:graph class diagram using Graphviz'
      'server:run a local documentation server'
      'gems:build YARD index for gems'
      'diff:object diff between two gems or .yardoc files'
      'stats:print documentation statistics'
      'list:list objects in documentation'
      'config:view or edit YARD configuration'
      'display:display an object'
      'ri:view documentation in the console (like ri)'
      'help:show help for a command'
      'markups:list available markup types'
    )
    _describe -t commands 'yard command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      doc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output-dir}'=[output directory]:directory:_directories' \
          {-b,--db}'=[yardoc database file]:file:_files' \
          '--single-db[store objects in a single db]' \
          '--no-single-db[do not store objects in a single db]' \
          {-n,--no-output}'[only generate .yardoc database]' \
          {-c,--use-cache}'=[use cached .yardoc db]:file:_files' \
          '--no-cache[clear .yardoc db before parsing]' \
          '--no-save[do not save parsed data to yardoc db]' \
          '--exclude=[regex to exclude files]:regex:' \
          '--fail-on-warning[exit non-zero on warnings]' \
          '--one-file[generate single-file output]' \
          '--list[list objects to stdout (implies -n)]' \
          '--no-public[hide public methods]' \
          '--protected[show protected methods]' \
          '--private[show private methods]' \
          '--no-private[hide @private-tagged objects]' \
          '--api=[generate docs for a given @api tag]:api:' \
          '--no-api[show objects without an @api tag]' \
          '--hide-api=[hide given @api tag from documentation]:api:' \
          '--embed-mixins[embed mixin methods in class docs]' \
          '--embed-mixin=[embed mixin methods from a module]:module:' \
          '--no-highlight[do not highlight source code]' \
          '--default-return=[default return type]:type:' \
          '--hide-void-return[hide void return values]' \
          '--query=[only show objects matching query]:query:' \
          '--title=[HTML doc title]:title:' \
          {-r,--readme,--main}'=[readme file]:file:_files' \
          '--files=[extra comma-separated static files]:files:' \
          '--asset=[file or dir to copy to output]:from\:to:' \
          {-m,--markup}'=[markup type]:type:(markdown textile rdoc ruby text html none)' \
          {-M,--markup-provider}'=[override markup provider]:provider:' \
          '--charset=[character set for parsing]:enc:' \
          {-t,--template}'=[template to use]:template:' \
          {-p,--template-path}'=[additional template path]:path:_directories' \
          {-f,--format}'=[output format]:format:(html text dot)' \
          '--no-stats[do not print statistics]' \
          '--no-progress[do not show progress bar]' \
          '--locale=[locale for documentation]:locale:' \
          '--po-dir=[directory for PO files]:directory:_directories' \
          '*--tag=[register a free-form @tag]:TAG\:TITLE:' \
          '*--type-tag=[tag with optional types field]:TAG\:TITLE:' \
          '*--type-name-tag=[tag with optional types and a name field]:TAG\:TITLE:' \
          '*--name-tag=[tag with a name field]:TAG\:TITLE:' \
          '*--title-tag=[tag with first line as title]:TAG\:TITLE:' \
          '*--hide-tag=[hide a previously defined tag]:TAG:' \
          '*--transitive-tag=[mark a tag as transitive]:TAG:' \
          '*--non-transitive-tag=[mark a tag as non-transitive]:TAG:' \
          '*:files:_files -g "*.rb"' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-m,--multi-library}'[serve docs for multiple libraries]' \
          {-c,--cache}'[cache documentation to document root]' \
          {-r,--reload}'[reparse library code on each request]' \
          {-g,--gems}'[serve docs for installed gems]' \
          {-G,--gemfile}'=[Gemfile to use]:file:_files' \
          {-t,--template-path}'=[additional template path]:path:_directories' \
          {-d,--daemon}'[daemonize the server]' \
          {-B,--bind}'=[bind host address]:host:' \
          {-p,--port}'=[port]:port:' \
          '--docroot=[document root]:dir:_directories' \
          {-a,--adapter}'=[server adapter]:adapter:' \
          {-s,--server}'=[server type]:type:' \
          '--fork[fork when serving requests]' \
          {-e,--load}'=[file to load before serving]:file:_files' \
          {-b,--db}'=[yardoc database file]:file:_files' && ret=0
        ;;
      graph)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dependencies[show dependencies]' \
          '--full[show full class hierarchy]' \
          {-n,--no-output}'[do not output to stdout]' \
          {-f,--file}'=[output file]:file:_files' && ret=0
        ;;
      gems)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:gem or yardoc file:_files' && ret=0
        ;;
      stats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--list-undoc[list undocumented objects]' \
          '--compact[compact output]' \
          '--no-public[exclude public objects]' \
          '--protected[show protected objects]' \
          '--private[show private objects]' \
          '--no-private[exclude private objects]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--query=[search query]:query:' && ret=0
        ;;
      config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--list[list all configuration]' \
          '--reset[reset configuration]' \
          '--append[append to a list-valued item]' && ret=0
        ;;
      ri)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-T,--no-pager}'[no pager]' \
          {-b,--db}'=[yardoc db]:file:_files' && ret=0
        ;;
      help)
        local -a cmds=(doc graph server gems diff stats list config display ri markups)
        _describe -t commands 'yard command' cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
