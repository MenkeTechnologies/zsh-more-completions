#compdef yard

# Zsh completion for yard (YARD Ruby documentation tool)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'doc:generate documentation'
      'graph:generate class diagram'
      'server:start a local documentation server'
      'gems:build documentation for installed gems'
      'diff:show diff between gem versions'
      'stats:show documentation statistics'
      'list:list objects in documentation'
      'config:view or edit YARD configuration'
      'display:display an object'
      'help:show help for a command'
      'markups:list available markup types'
    )
    _describe -t commands 'yard command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      doc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output-dir}'=[output directory]:directory:_directories' \
          {-b,--db}'=[yardoc database file]:file:_files' \
          '--yardopts=[path to .yardopts file]:file:_files' \
          {-e,--load}'=[Ruby file to load before parsing]:file:_files' \
          {-n,--no-output}'[only generate .yardoc database]' \
          '--title=[title for generated documentation]:title' \
          {-r,--readme}'=[readme file]:file:_files' \
          '--files=[additional files to include]:files' \
          '--exclude=[regex to exclude files]:regex' \
          {-p,--plugin}'=[load a YARD plugin]:plugin' \
          '--no-save[do not save .yardoc database]' \
          '--use-cache[use cached .yardoc database]' \
          '--no-cache[clear and rebuild .yardoc database]' \
          '--no-private[hide private methods]' \
          '--protected[show protected methods]' \
          '--no-public[hide public methods]' \
          '--embed-mixins[embed mixin methods]' \
          '--no-highlight[do not highlight source code]' \
          '--default-return=[default return type when not specified]:type' \
          '--hide-void-return[hide void return values]' \
          '--markup=[markup type]:type:(markdown textile rdoc ruby text html none)' \
          '--markup-provider=[override markup provider]:provider' \
          '--safe[safe mode, no dynamic code execution]' \
          '--template=[template to use]:template' \
          '--template-path=[additional template path]:path:_directories' \
          '--format=[output format]:format:(html text dot)' \
          '--no-stats[do not print statistics]' \
          '--no-progress[do not show progress bar]' \
          '--locale=[locale for documentation]:locale' \
          '--po-dir=[directory for PO files]:directory:_directories' \
          {-t,--tag}'=[define a custom tag]:tag' \
          '--api=[filter by API tag]:name' \
          '*:files:_files -g "*.rb"' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-p,--port}'=[port number]:port' \
          {-a,--address}'=[bind address]:address' \
          {-d,--daemon}'[run as daemon]' \
          {-r,--reload}'[auto-reload on source changes]' \
          {-g,--gems}'[serve documentation for installed gems]' \
          {-G,--gemfile}'=[Gemfile to use]:file:_files' \
          {-t,--template-path}'=[additional template path]:path:_directories' \
          '--adapter=[server adapter to use]:adapter' && ret=0
        ;;
      graph)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dependencies[show dependencies]' \
          '--full[show full class hierarchy]' \
          {-n,--no-output}'[do not output to stdout]' \
          {-f,--file}'=[output file]:file:_files' && ret=0
        ;;
      gems)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--old}'=[old version]:version' \
          {-n,--new}'=[new version]:version' \
          {-a,--all}'[show all objects]' \
          '--gem=[gem name]:gem' && ret=0
        ;;
      stats)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--list-undoc[list undocumented objects]' \
          '--compact[compact output]' \
          '--no-undoc[exclude undocumented objects]' \
          '--no-private[exclude private objects]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--query=[search query]:query' && ret=0
        ;;
      help)
        local -a cmds=(doc graph server gems diff stats list config display markups)
        _describe -t commands 'yard command' cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
