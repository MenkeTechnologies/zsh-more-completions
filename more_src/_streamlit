#compdef streamlit

# Streamlit CLI completion

_streamlit_subcommands() {
  local -a subcmds=(
    'run:Run a Streamlit app'
    'hello:Run the Streamlit hello demo'
    'config:Manage Streamlit configuration'
    'cache:Manage the Streamlit cache'
    'docs:Open Streamlit docs in browser'
    'version:Print the Streamlit version'
    'activate:Activate Streamlit'
  )
  _describe -t commands 'streamlit subcommand' subcmds
}

_streamlit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_streamlit_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--server.port=[server port]:port' \
            '--server.address=[server address]:address' \
            '--server.headless=[run headless]:headless:(true false)' \
            '--server.runOnSave=[rerun on file save]:run on save:(true false)' \
            '--theme.base=[base theme]:theme:(light dark)' \
            '--theme.primaryColor=[primary color]:color' \
            '--browser.serverAddress=[browser server address]:address' \
            '--logger.level=[log level]:level:(error warning info debug)' \
            '--client.showErrorDetails=[show error details]:show:(true false)' \
            '1:script file:_files -g "*.py"' \
            '*:args:'
          ;;
        hello)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        config)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(show)'
          ;;
        cache)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(clear)'
          ;;
        docs)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        version)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        activate)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_streamlit "$@"
