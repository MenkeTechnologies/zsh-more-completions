#compdef condor_userprio
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_userprio.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-debug[debug output]:level:' \
  '-inputfile[read priority data from file]:file:_files' \
  '-name[negotiator name]:negotiator:' \
  '-pool[central manager host[:port]]:pool:' \
  '-delete[remove submitter from accounting]:submitter:' \
  '-resetall[zero out all submitter usage]' \
  '-resetusage[zero out a submitter usage]:submitter:' \
  '-setaccum[set accumulated usage]:submitter value:' \
  '-setbegin[set usage start time]:submitter value:' \
  '-setlast[set last usage time]:submitter value:' \
  '-setfactor[set priority factor]:submitter value:' \
  '-setprio[set real priority value]:submitter value:' \
  '-setceiling[set max CPU core allocation]:submitter value:' \
  '-setfloor[set min CPU core allocation]:submitter value:' \
  '-activefrom[show submitters since date]:month day year:' \
  '-all[display all fields]' \
  '-allusers[include inactive submitters]' \
  '-collector[query from collector]' \
  '-negotiator[query from negotiator]' \
  '-autoformat[format output]:attributes:' \
  '-af[format output]:attributes:' \
  '-constraint[filter by expression]:expr:' \
  '-flat[flat group display]' \
  '-hierarchical[hierarchical group display]' \
  '-groupid[group id display]' \
  '-grouporder[group order display]' \
  '-grouprollup[group rollup display]' \
  '-long[long ClassAd output]' \
  '-legacy[legacy ClassAd output]' \
  '-modular[modular ClassAd output]' \
  '-priority[priority field selection]' \
  '-usage[usage field selection]' \
  '-quotas[quotas field selection]' \
  '-surplus[surplus field selection]' \
  '-most[most useful fields (default)]' \
  '*:submitter:_users' && ret=0
return ret
