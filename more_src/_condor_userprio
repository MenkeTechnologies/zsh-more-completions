#compdef condor_userprio
# Documentation: https://man.archlinux.org/search?q=condor_userprio
# Reference accessed: 2026-05-16

# condor_userprio: show / modify user priorities
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-pool[pool]:pool:' \
  '-name[negotiator name]:name:' \
  '-all[show all info]' \
  '-allusers[show all users]' \
  '-getreslist[get resource list]:user:_users' \
  '-usage[show usage]' \
  '-grouporder[group order]' \
  '-grouprorder[reverse group order]' \
  '-flat[no group hierarchy]' \
  '-hierarchical[group hierarchy]' \
  '-most[show most useful (default)]' \
  '-resetusage[reset usage]:user:_users' \
  '-resetall[reset all users]' \
  '-delete[delete record]:user:_users' \
  '-setprio[set priority factor]:user value:' \
  '-setaccum[set accumulated usage]:user value:' \
  '-setbegin[set begin usage time]:user time:' \
  '-setlast[set last usage time]:user time:' \
  '-setfactor[set priority factor]:user value:' \
  '-l[long format]' \
  '-attributes[attributes]:list:' \
  '-format[printf format]:format attr:' \
  '-autoformat[autoformat]:list:' \
  '*::condor_userprio args:_files' && ret=0
return ret
