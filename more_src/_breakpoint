_breakpoint() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_breakpoint_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                start|wait)
                    _arguments \
                        '--config=[path to configuration file]:config:_files' && ret=0 ;;
                hold)
                    _arguments \
                        '--for=[how much to extend the breakpoint by (default 30m)]:duration:' \
                        '--duration=[alias of --for]:duration:' \
                        '--while-connected[keep holding while connections active]' \
                        '--stop[stop the breakpoint server after holding]' && ret=0 ;;
                extend)
                    _arguments \
                        '--for=[how much to extend the breakpoint by (default 30m)]:duration:' \
                        '--duration=[alias of --for]:duration:' && ret=0 ;;
                attach)
                    _arguments \
                        '--endpoint=[address of the server]:endpoint:' \
                        '--target=[where to connect to]:target:' && ret=0 ;;
                resume|status)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_breakpoint_commands] )) ||
_breakpoint_commands() {
    local -a commands
    commands=(
        'start:start breakpoint in the background'
        'wait:block for the duration of the breakpoint'
        'status:get the current status of breakpoint'
        'hold:hold until breakpoint is finished or for a duration'
        'extend:extend the breakpoint duration'
        'resume:resume the workflow execution'
        'attach:attach to a running breakpoint'
    )
    _describe -t commands 'breakpoint command' commands
}

_breakpoint "$@"
