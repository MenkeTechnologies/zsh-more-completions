#compdef atc
# Documentation: man atc(6)
# Source: openbsd/src games/atc/main.c — air traffic controller game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '(-f -g)-f+[game file]:file:_files' \
    '(-f -g)-g+[game file (alias)]:file:_files' \
    '-l[list available games]' \
    '-p[print path of the game file]' \
    '-q[quiet — no audio bell]' \
    '-r+[random seed]:seed:_default' \
    '(-s -t)-s[show top scores]' \
    '(-s -t)-t[show top scores (alias)]' \
    && ret=0

return ret
