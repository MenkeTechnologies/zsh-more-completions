#compdef cryptsetup
# _cryptsetup-bin — cryptsetup LUKS / dm-crypt management; format/open/close encrypted block devices on Linux
# upstream: https://gitlab.com/cryptsetup/cryptsetup

_cryptsetup-bin() {
    local -a sub=(
        'open:open device (luksOpen, plainOpen, ...)'
        'close:close device'
        'status:show device status'
        'resize:resize active device'
        'refresh:refresh active device'
        'luksFormat:format LUKS device'
        'luksOpen:open LUKS device'
        'luksClose:close LUKS device'
        'luksSuspend:suspend LUKS device'
        'luksResume:resume LUKS device'
        'luksAddKey:add LUKS key slot'
        'luksRemoveKey:remove LUKS key slot'
        'luksChangeKey:change key in slot'
        'luksConvertKey:convert key in slot'
        'luksKillSlot:kill specific key slot'
        'luksUUID:print or change LUKS UUID'
        'luksHeaderBackup:backup LUKS header'
        'luksHeaderRestore:restore LUKS header'
        'luksDump:dump LUKS header'
        'isLuks:check if device is LUKS'
        'erase:erase all keyslots'
        'plainOpen:open plain device'
        'loopaesOpen:open loop-AES device'
        'tcryptDump:dump TCRYPT header'
        'tcryptOpen:open TCRYPT device'
        'bitlkDump:dump BitLocker header'
        'bitlkOpen:open BitLocker device'
        'fvault2Dump:dump FileVault2 header'
        'fvault2Open:open FileVault2 device'
        'reencrypt:reencrypt LUKS device'
        'token:manage LUKS2 tokens'
        'config:set persistent device config'
        'convert:convert LUKS1<->LUKS2'
        'benchmark:benchmark ciphers/PBKDF'
        'repair:repair LUKS metadata'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(--debug)--debug[debug log]' \
        '(--debug-json)--debug-json[debug json]' \
        '(-q --batch-mode)'{-q,--batch-mode}'[no prompts]' \
        '(-y --verify-passphrase)'{-y,--verify-passphrase}'[verify passphrase]' \
        '(-c --cipher)'{-c,--cipher}'+[cipher spec]:cipher:' \
        '(-h --hash)'{-h,--hash}'+[hash spec]:hash:' \
        '(-s --key-size)'{-s,--key-size}'+[key size bits]:n:' \
        '(--iter-time)--iter-time+[PBKDF iter time ms]:n:' \
        '(--key-slot)--key-slot+[key slot]:n:' \
        '(--key-file)--key-file+[key file]:file:_files' \
        '(--header)--header+[detached header]:file:_files' \
        '(--master-key-file)--master-key-file+[master key file]:file:_files' \
        '(--type)--type+[LUKS type]:type:(luks1 luks2 plain loopaes tcrypt bitlk fvault2)' \
        '(--label)--label+[LUKS2 label]:label:' \
        '(--subsystem)--subsystem+[LUKS2 subsystem]:str:' \
        '(--pbkdf)--pbkdf+[PBKDF]:pbkdf:(argon2i argon2id pbkdf2)' \
        '(--token-id)--token-id+[token id]:n:' \
        '(--token-only)--token-only[only use tokens]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cryptsetup subcommand' sub ;;
        args)
            _arguments \
                '1:device:_files -g "/dev/*"' \
                '2:name:'
            ;;
    esac
}

_cryptsetup-bin "$@"
