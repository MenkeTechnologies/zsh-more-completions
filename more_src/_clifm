#compdef clifm

# Zsh completion for clifm (CLI file manager)

_arguments -s -S \
  '(-a --show-hidden)'{-a,--show-hidden}'[show hidden files]' \
  '(-A --no-hidden)'{-A,--no-hidden}'[do not show hidden files]' \
  '(-b --bookmarks-file)'{-b,--bookmarks-file}'[bookmarks file]:file:_files' \
  '(-c --config-file)'{-c,--config-file}'[config file]:file:_files' \
  '(-D --config-dir)'{-D,--config-dir}'[config directory]:dir:_files -/' \
  '(-e --no-eln)'{-e,--no-eln}'[do not show ELN]' \
  '(-f --dirs-first)'{-f,--dirs-first}'[list directories first]' \
  '(-F --no-dirs-first)'{-F,--no-dirs-first}'[do not list directories first]' \
  '(-g --pager)'{-g,--pager}'[enable pager]' \
  '(-G --no-pager)'{-G,--no-pager}'[disable pager]' \
  '(-i --no-case)'{-i,--no-case}'[case insensitive listing]' \
  '(-I --case-sensitive)'{-I,--case-sensitive}'[case sensitive listing]' \
  '(-k --keybindings-file)'{-k,--keybindings-file}'[keybindings file]:file:_files' \
  '(-l --long-view)'{-l,--long-view}'[long view listing]' \
  '(-L --follow-symlinks)'{-L,--follow-symlinks}'[follow symbolic links]' \
  '(-o --only-dirs)'{-o,--only-dirs}'[list only directories]' \
  '(-p --path)'{-p,--path}'[starting path]:path:_files -/' \
  '(-P --profile)'{-P,--profile}'[profile name]:profile:' \
  '(-r --no-refresh)'{-r,--no-refresh}'[do not refresh the screen]' \
  '(-s --splash)'{-s,--splash}'[print splash screen]' \
  '(-S --stealth-mode)'{-S,--stealth-mode}'[stealth mode]' \
  '(-t --disk-usage)'{-t,--disk-usage}'[show disk usage]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --workspace)'{-w,--workspace}'[starting workspace]:workspace:(1 2 3 4 5 6 7 8)' \
  '(-x --no-ext-cmds)'{-x,--no-ext-cmds}'[disallow external commands]' \
  '(-y --light-mode)'{-y,--light-mode}'[light mode]' \
  '(-z --sort)'{-z,--sort}'[sort method]:method:(none name size atime btime ctime mtime owner group extension inode blocks links)' \
  '--color-scheme[color scheme]:scheme:' \
  '--cwd-in-title[show CWD in terminal title]' \
  '--icons[show file icons]' \
  '--no-icons[do not show file icons]' \
  '--open[open with this application]:app:_command_names' \
  '--opener[default file opener]:opener:_command_names' \
  '--print-sel[print selection and exit]' \
  '--rl-vi-mode[readline vi editing mode]' \
  '--sel-file[selection file]:file:_files' \
  '--share-selbox[share selection box]' \
  '--trash-as-rm[use trash as rm]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:directory:_files -/' && return 0
