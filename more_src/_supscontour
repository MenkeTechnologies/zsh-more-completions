#compdef supscontour
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/graphics/psplot/supscontour.c
# PostScript contour plot of SU data via pscontour

local ret=1

_arguments -s -S \
  'n2=[number of traces in the data set]:ntraces' \
  'ntr=[alias for n2]:ntraces' \
  'd1=[sampling interval in the fast dimension]:d1' \
  'd2=[sampling interval in the slow dimension]:d2' \
  'f1=[first sample in the fast dimension]:f1' \
  'f2=[first sample in the slow dimension]:f2' \
  'key=[header key word with x2 information]:key' \
  'verbose=[print useful information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
