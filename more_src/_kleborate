#compdef kleborate
# kleborate — Klebsiella genomic typing tool for species, MLST, and virulence/resistance

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[show version and exit]' \
  '(-a --assemblies)'{-a,--assemblies}'[input assembly FASTA files]:*:FASTA files:_files' \
  '(-o --outfile)'{-o,--outfile}'[output results file]:output file:_files' \
  '(-p --preset)'{-p,--preset}'[module preset]:preset:(kpsc kosc escherichia)' \
  '--all[turn on all modules]' \
  '--list_modules[list available modules]' \
  '--kaptive_k[type K (capsule) loci with Kaptive]' \
  '--kaptive_o[type O (LPS) loci with Kaptive]' \
  '--min_identity[minimum percent identity for BLAST hits]:percent' \
  '--min_coverage[minimum percent coverage for BLAST hits]:percent' \
  '--min_spurious_identity[minimum identity for spurious hits]:percent' \
  '--min_spurious_coverage[minimum coverage for spurious hits]:percent' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  && ret=0

return ret
