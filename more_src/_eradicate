#compdef eradicate
# Documentation: https://github.com/myint/eradicate
# eradicate - removes commented-out code from Python files

local ret=1

_arguments -s -S \
  '(-i --in-place)'{-i,--in-place}'[make changes to files instead of printing diffs]' \
  '(-r --recursive)'{-r,--recursive}'[drill down directories recursively]' \
  '(-a --aggressive)'{-a,--aggressive}'[make more aggressive changes; may produce false positives]' \
  '(-e --error)'{-e,--error}'[exit code based on result of check]' \
  '--version[show version and exit]' \
  '--whitelist=[overwrite default whitelist of comment beginnings]:whitelist:' \
  '--whitelist-extend=[extend default whitelist of comment beginnings]:whitelist:' \
  '*:file:_files -g "*.py"' && ret=0

return ret
