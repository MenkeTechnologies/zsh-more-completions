#compdef cargo-fuzz

# Zsh completion for cargo-fuzz (Rust fuzzing with libFuzzer)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Initialize cargo-fuzz for a project'
      'add:Add a new fuzz target'
      'run:Run a fuzz target'
      'cmin:Corpus minimization'
      'tmin:Test case minimization'
      'list:List all fuzz targets'
      'fmt:Format fuzz target source files'
      'coverage:Generate code coverage for a fuzz target'
    )
    _describe -t commands 'cargo-fuzz command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '-h[Print help]'
      '--help[Print help]'
      '--manifest-path=[Path to Cargo.toml]:file:_files'
      '--fuzz-dir=[Path to the fuzz directory]:dir:_directories'
    )

    case ${words[1]} in
      init)
        _arguments -s -S \
          $common_flags \
          '-t+[Name of the first fuzz target to create]:name' \
          '--target=[Name of the first fuzz target to create]:name' \
          '--fuzzing-workspace[Create a separate fuzzing workspace]' && ret=0
        ;;
      add)
        _arguments -s -S \
          $common_flags \
          '1:target name' && ret=0
        ;;
      run)
        _arguments -s -S \
          $common_flags \
          '-j+[Number of parallel jobs]:jobs' \
          '--jobs=[Number of parallel jobs]:jobs' \
          '--release[Build in release mode with debug info]' \
          '--dev[Build in dev mode]' \
          '--features=[Features to compile]:features' \
          '--all-features[Activate all features]' \
          '--no-default-features[Do not activate default features]' \
          '--target=[Target triple]:target' \
          '--sanitizer=[Sanitizer to use]:sanitizer:(address leak memory thread none)' \
          '-O[Build with optimizations and debug assertions]' \
          '--build-std[Build the standard library with coverage]' \
          '--careful-mode[Abort on ASAN/MSAN violations during build]' \
          '-s+[Seed for the random number generator]:seed' \
          '--seed=[Seed for the random number generator]:seed' \
          '-D+[Corpus output directory]:dir:_directories' \
          '--corpus=[Corpus output directory]:dir:_directories' \
          '--runs=[Number of runs to perform]:runs' \
          '--max-len=[Maximum length of input]:bytes' \
          '--max-total-time=[Maximum total time for fuzzing in seconds]:seconds' \
          '--timeout=[Timeout for each run in seconds]:seconds' \
          '--no-cfg-fuzzing[Do not set cfg=fuzzing]' \
          '--no-trace-compares[Do not use value profile]' \
          '--strip-dead-code[Strip dead code]' \
          '1:target name' \
          '*:corpus dirs:_directories' && ret=0
        ;;
      cmin)
        _arguments -s -S \
          $common_flags \
          '--release[Build in release mode with debug info]' \
          '--dev[Build in dev mode]' \
          '--features=[Features to compile]:features' \
          '--all-features[Activate all features]' \
          '--no-default-features[Do not activate default features]' \
          '--target=[Target triple]:target' \
          '--sanitizer=[Sanitizer to use]:sanitizer:(address leak memory thread none)' \
          '-O[Build with optimizations and debug assertions]' \
          '1:target name' \
          '*:corpus dirs:_directories' && ret=0
        ;;
      tmin)
        _arguments -s -S \
          $common_flags \
          '--release[Build in release mode with debug info]' \
          '--dev[Build in dev mode]' \
          '--features=[Features to compile]:features' \
          '--all-features[Activate all features]' \
          '--no-default-features[Do not activate default features]' \
          '--target=[Target triple]:target' \
          '--sanitizer=[Sanitizer to use]:sanitizer:(address leak memory thread none)' \
          '-O[Build with optimizations and debug assertions]' \
          '--runs=[Number of attempts to minimize]:runs' \
          '1:target name' \
          '2:test case:_files' && ret=0
        ;;
      list)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      fmt)
        _arguments -s -S \
          $common_flags && ret=0
        ;;
      coverage)
        _arguments -s -S \
          $common_flags \
          '--release[Build in release mode with debug info]' \
          '--dev[Build in dev mode]' \
          '--features=[Features to compile]:features' \
          '--all-features[Activate all features]' \
          '--no-default-features[Do not activate default features]' \
          '--target=[Target triple]:target' \
          '--sanitizer=[Sanitizer to use]:sanitizer:(address leak memory thread none)' \
          '-O[Build with optimizations and debug assertions]' \
          '-s+[Seed for the random number generator]:seed' \
          '--seed=[Seed for the random number generator]:seed' \
          '1:target name' \
          '*:corpus dirs:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
