#compdef csshX
# Documentation: https://github.com/brockgr/csshx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (GetOptions in csshX Perl source).
# Cluster SSH for macOS. Flag list mirrors GetOptions() in the csshX perl script.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --man)'{-m,--man}'[show manual]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*'{-c+,--config=}'[config file]:file:_files' \
  '(-l --login)'{-l+,--login=}'[remote login user]:user:_users' \
  '--ssh=[ssh binary]:ssh:_files' \
  '--ssh_args=[extra ssh args]:args:' \
  '*--hosts=[hosts file]:file:_files' \
  '(-x --tile_x)'{-x+,--tile_x=}'[tiles per row]:n:' \
  '(-y --tile_y)'{-y+,--tile_y=}'[tiles per column]:n:' \
  '--screen=[target screen index]:n:' \
  '--space=[target space]:n:' \
  '--ping_test[enable ping reachability test]' \
  '--ping[enable ping reachability test]' \
  '--ping_timeout=[ping timeout seconds]:secs:' \
  '--session_max=[max simultaneous sessions]:n:' \
  '--remote_command=[command to run on each host]:cmd:' \
  '--no_growl[disable Growl notifications]' \
  '--master_settings_set=[Terminal master settings set]:name:' \
  '--mss=[Terminal master settings set]:name:' \
  '--slave_settings_set=[Terminal slave settings set]:name:' \
  '--sss=[Terminal slave settings set]:name:' \
  '(-i --interleave)'{-i+,--interleave=}'[interleave columns]:n:' \
  '--sorthosts[sort hosts before launch]' \
  '--list_clusters[list cluster definitions]' \
  '--bash_env[force bash env load]' \
  '--debug[debug output (repeatable)]' \
  '*:host:_hosts'
