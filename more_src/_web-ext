#compdef web-ext

# Zsh completion for web-ext - Mozilla CLI for Firefox web extensions

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run a web extension in a browser'
  'build:package a web extension as an XPI archive'
  'sign:sign a web extension for distribution'
  'lint:validate a web extension source directory'
  'docs:open the documentation in your default browser'
  'dump-config:dump the resolved configuration as JSON'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show the version]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '(-s --source-dir)'{-s,--source-dir}'[extension source directory]:directory:_files -/' \
  '(-a --artifacts-dir)'{-a,--artifacts-dir}'[directory to store artifacts]:directory:_files -/' \
  '(-i --ignore-files)'{-i,--ignore-files}'[glob patterns to ignore]:pattern:' \
  '--no-config-discovery[disable loading web-ext-config from parent dirs]' \
  '--config[JSON config file]:file:_files -g "*.(json|js|cjs)"' \
  '--config-discovery[enable loading of config files in parent directories]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'web-ext command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '(-f --firefox)'{-f,--firefox}'[path or alias of Firefox executable]:path:_files' \
          '(-p --firefox-profile)'{-p,--firefox-profile}'[path or name of profile to use]:profile:' \
          '--profile-create-if-missing[create profile if it does not exist]' \
          '--keep-profile-changes[keep profile changes between runs]' \
          '--no-reload[disable automatic reloading]' \
          '--pre-install[pre-install the extension]' \
          '--pref[set a Firefox preference]:preference:' \
          '--start-url[URL to open in a new tab]:url:' \
          '--browser-console[open the browser console]' \
          '--devtools[open DevTools for the extension]' \
          '--target[target to run in]:target:(firefox-desktop firefox-android chromium)' \
          '--args[additional CLI arguments to pass to Firefox]:args:' \
          '--chromium-binary[path to the Chromium binary]:file:_files' \
          '--chromium-profile[path to a Chromium profile]:profile:_files -/' \
          '--adb-bin[path to the adb binary]:file:_files' \
          '--adb-host[host for adb]:host:' \
          '--adb-port[port for adb]:port:' \
          '--adb-device[device ID for adb]:device:' \
          '--android-app[Android app package]:package:' \
          '--watch-file[file to watch for changes]:file:_files' \
          '--watch-ignored[glob patterns to ignore while watching]:pattern:' && ret=0
        ;;
      (build)
        _arguments \
          '(-o --overwrite-dest)'{-o,--overwrite-dest}'[overwrite existing artifacts]' \
          '--as-needed[rebuild on source changes]' \
          '-n[output filename]:filename:' \
          '--filename[output filename]:filename:' && ret=0
        ;;
      (sign)
        _arguments \
          '--api-key[AMO issuer]:key:' \
          '--api-secret[AMO secret]:secret:' \
          '--api-url-prefix[AMO signing API URL]:url:' \
          '--api-proxy[HTTP(S) proxy to use]:proxy:' \
          '--amo-base-url[AMO base URL for logged-in flows]:url:' \
          '--id[add-on ID]:id:' \
          '--channel[release channel]:channel:(listed unlisted)' \
          '--timeout[API timeout in milliseconds]:ms:' \
          '--approval-timeout[approval timeout]:ms:' \
          '--upload-source-code[source code archive to upload]:file:_files' \
          '--use-submission-api[use the new submission API]' && ret=0
        ;;
      (lint)
        _arguments \
          '(-o --output)'{-o,--output}'[output format]:format:(text json)' \
          '--metadata[output metadata]' \
          '--pretty[prettify json output]' \
          '--privileged[validate as a privileged extension]' \
          '--warnings-as-errors[treat warnings as errors]' \
          '--self-hosted[validate for self-hosted extensions]' \
          '--boring[do not use colorful output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
