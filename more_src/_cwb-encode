#compdef cwb-encode
# Documentation: https://cwb.sourceforge.io/documentation.php
# Encode a corpus into the IMS Corpus Workbench binary format

local ret=1

_arguments -s -S \
  '-h[show help page]' \
  '-p[change name of default p-attribute from word to att]:att' \
  '*-P[declare additional p-attribute]:att' \
  '*-S[declare s-attribute without annotations]:att' \
  '*-V[declare s-attribute with annotations]:att' \
  '*-0[declare null s-attribute (discards tags)]:att' \
  '*-f[read input from file]:file:_files' \
  '*-t[verticalised text input file (alias for -f)]:file:_files' \
  '-F[read all *.vrt or *.vrt.gz files in directory]:dir:_files -/' \
  '-d[directory for data files created by cwb-encode]:dir:_files -/' \
  '-R[create registry entry listing all encoded attributes]:file:_files' \
  '-U[insert string for missing columns]:str' \
  '-B[strip leading/trailing blanks from input lines and annotations]' \
  '-x[XML-aware (replace XML entities, ignore comments)]' \
  '-s[skip empty lines in input data]' \
  '-b[number of buckets in lexicon hash tables]:n' \
  '-c[specify corpus character set]:charset' \
  '-C[clean strings, replacing invalid bytes with ?]' \
  '-v[verbose mode (show progress messages)]' \
  '-q[quiet mode (suppresses most warnings)]' \
  '-D[debug mode]' \
  '*:input file:_files' && ret=0

return ret
