#compdef caput
# Documentation: https://docs.epics-controls.org/en/latest/
# Source: epics-base/epics-base modules/ca/src/tools/caput.c — EPICS Channel Access put tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show EPICS/CA versions]' \
    '-w+[CA timeout (seconds)]:sec:_default' \
    '-c[asynchronous put with ca_put_callback]' \
    '-p+[CA priority (0=lowest)]:prio:_default' \
    '-t[terse mode (written value only)]' \
    '-l[long mode: name timestamp value stat sevr]' \
    '-n[force interpretation of values as numbers]' \
    '-s[force interpretation of values as strings]' \
    '-S[put string as char array (long string)]' \
    '-a[put array]' \
    '-F+[alternate output field separator]:sep:_default' \
    '1:PV name:_default' \
    '*:value:_default' \
    && ret=0

return ret
