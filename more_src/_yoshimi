#compdef yoshimi
# Documentation: https://man.archlinux.org/man/yoshimi.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (yoshimi manpage).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --alsa-midi)'{-a,--alsa-midi=}'[ALSA MIDI input device]:dev:' \
  '(-A --alsa-audio)'{-A,--alsa-audio=}'[ALSA audio output device]:dev:' \
  '(-b --buffersize)'{-b,--buffersize=}'[internal buffer size]:size:' \
  '(-c --no-cmdline)'{-c,--no-cmdline}'[deactivate cmdline]' \
  '(-C --cmdline)'{-C,--cmdline}'[activate cmdline]' \
  '(-D --define-root)'{-D,--define-root}'[set bank root directory]' \
  '(-i --no-gui)'{-i,--no-gui}'[deactivate GUI]' \
  '(-I --gui)'{-I,--gui}'[activate GUI]' \
  '(-j --jack-midi)'{-j,--jack-midi=}'[JACK MIDI input device]:dev:' \
  '(-J --jack-audio)'{-J,--jack-audio=}'[connect to JACK server]:srv:' \
  '(-k --autostart-jack)'{-k,--autostart-jack}'[initialize JACK server automatically]' \
  '(-K --auto-connect)'{-K,--auto-connect}'[auto-connect to JACK server]' \
  '(-l --load)'{-l,--load=}'[load .xmz patch file]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument=}'[load .xiz instrument]:file:_files -g "*.xiz"' \
  '(-M --load-midilearn)'{-M,--load-midilearn=}'[load .xly midi learn file]:file:_files -g "*.xly"' \
  '(-N --name-tag)'{-N,--name-tag=}'[client name tag]:tag:' \
  '(-o --oscilsize)'{-o,--oscilsize=}'[AddSynth oscillator size]:size:' \
  '(-R --samplerate)'{-R,--samplerate=}'[ALSA sample rate]:rate:' \
  '(-S --state)'{-S,--state=}'[restore saved state]:file:_files' \
  '(-u --jack-session-file)'{-u,--jack-session-file=}'[JACK session file]:file:_files' \
  '(-U --jack-session-uuid)'{-U,--jack-session-uuid=}'[JACK session UUID]:uuid:' \
  '*:patch:_files' && ret=0

return ret
