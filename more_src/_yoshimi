#compdef yoshimi

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --alsa-audio)'{-A,--alsa-audio}'+[ALSA audio device]:dev:' \
  '(-a --alsa-midi)'{-a,--alsa-midi}'+[ALSA midi source]:src:' \
  '(-J --jack-audio)'{-J,--jack-audio}'+[JACK server]:srv:' \
  '(-j --jack-midi)'{-j,--jack-midi}'+[JACK midi]:src:' \
  '(-k --autoconnect)'{-k,--autoconnect}'[auto connect JACK audio]' \
  '(-K --auto-connect-midi)'{-K,--auto-connect-midi}'[auto connect JACK midi]' \
  '(-S --state)'{-S,--state}'+[state file]:file:_files -g "*.state"' \
  '(-l --load)'{-l,--load}'+[load patch]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument}'+[load instrument]:file:_files -g "*.xiz"' \
  '(-M --midi-learn)'{-M,--midi-learn}'+[midi learn file]:file:_files' \
  '(-N --name-tag)'{-N,--name-tag}'+[name tag]:tag:' \
  '(-I --no-gui)'{-I,--no-gui}'[disable GUI]' \
  '(-c --no-cmdline)'{-c,--no-cmdline}'[disable cmdline]' \
  '(-i --no-splash)'{-i,--no-splash}'[no splash]' \
  '(-D --define-root)'{-D,--define-root}'+[define root]:root:' \
  '(-R --sample-rate)'{-R,--sample-rate}'+[sample rate]:rate:(22050 44100 48000 96000)' \
  '(-B --buffer-size)'{-B,--buffer-size}'+[buffer size]:n:' \
  '(-O --oscilsize)'{-O,--oscilsize}'+[oscil size]:n:' \
  '*:patch:_files' && ret=0

return ret
