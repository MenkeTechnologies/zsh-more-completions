#compdef hny honeycomb-io
# _hny — Honeycomb hny CLI (Honeycomb.io, Go); spf13/cobra
# upstream: https://github.com/honeycombio/honeycomb-cli

_hny() {
    local -a sub=(
        'auth:authenticate / inspect token'
        'dataset:manage datasets'
        'query:run / fetch queries'
        'event:emit one-off event'
        'trace:emit/inspect traces'
        'board:manage boards'
        'derived-column:manage derived columns'
        'slo:manage SLOs'
        'trigger:manage triggers'
        'environment:manage environments'
        'team:manage teams'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-host=+[honeycomb API host]:host:_hosts' \
        '--api-key=+[honeycomb API key]:str:' \
        '-k+[honeycomb API key]:str:' \
        '--environment=+[environment]:str:' \
        '-e+[environment]:str:' \
        '--config=+[config file]:file:_files' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hny subcommand' sub ;;
        args)
            case $words[1] in
                dataset|board|trigger|slo|environment|team|derived-column) _arguments \
                    '1:cmd:(list get create update delete)' \
                    '*:arg:' ;;
                query) _arguments \
                    '1:cmd:(get list run create delete)' \
                    '--dataset=+[dataset]:str:' \
                    '-d+[dataset]:str:' \
                    '--file=+[query json file]:file:_files -g "*.json"' \
                    '*:arg:' ;;
                event) _arguments \
                    '--dataset=+[dataset]:str:' \
                    '-d+[dataset]:str:' \
                    '--data=+[data json]:str:' \
                    '--from-file=+[from file]:file:_files' ;;
                trace) _arguments \
                    '1:cmd:(get inspect emit)' \
                    '--trace-id=+[trace id]:str:' \
                    '--dataset=+[dataset]:str:' ;;
                auth) _arguments \
                    '1:cmd:(login whoami logout)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hny "$@"
