#compdef 3dTcorr1D
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTcorr1D.html
# AFNI: correlate a 3D+time dataset with 1D time series

local ret=1

_arguments -s -S \
  '-pearson[Pearson correlation (default)]' \
  '-spearman[Spearman rank correlation]' \
  '-quadrant[quadrant correlation]' \
  '-ktaub[Kendall tau_b]' \
  '-dot[dot product instead of correlation]' \
  '-Fisher[apply Fisher (arctanh) transform]' \
  '-prefix[output dataset prefix (default Tcorr1D)]:prefix:' \
  '-mask[process only nonzero voxels in mask]:mset:_files' \
  '-float[save results in float (default)]' \
  '-short[save results in scaled short format]' \
  '*:file:_files' && ret=0

return ret
