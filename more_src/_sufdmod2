#compdef sufdmod2
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/sufdmod2.c
# Finite-difference modeling (2nd order) for acoustic wave equation

local ret=1

_arguments -s -S \
  'nx=[number of x samples (2nd dimension)]:nx' \
  'nz=[number of z samples (1st dimension)]:nz' \
  'xs=[x coordinates of source, or file with coordinate pairs]:xs' \
  'zs=[z coordinates of source]:zs' \
  'tmax=[maximum time]:tmax' \
  'sstrength=[strength of source]:sstrength' \
  'pw=[point source; =1 horizontal plane wave source]:pw:(0 1)' \
  'pwt=[amplitude taper on line source ends (grid points)]:pwt' \
  'mono=[Ricker wavelet source; =1 single frequency source]:mono:(0 1)' \
  'nt=[number of time samples]:nt' \
  'mt=[time steps per output time step]:mt' \
  'dx=[x sampling interval]:dx' \
  'fx=[first x sample]:fx' \
  'dz=[z sampling interval]:dz' \
  'fz=[first z sample]:fz' \
  'fmax=[maximum source frequency]:fmax' \
  'fpeak=[peak frequency in Ricker wavelet]:fpeak' \
  'dfile=[density file input]:dfile:_files' \
  'vsx=[x coordinate of vertical seismogram line]:vsx' \
  'hsz=[z coordinate of horizontal seismogram line]:hsz' \
  'vsfile=[vertical seismogram output file]:vsfile:_files' \
  'hsfile=[horizontal seismogram output file]:hsfile:_files' \
  'ssfile=[source point seismogram output file]:ssfile:_files' \
  'verbose=[=1 diagnostic messages; =2 more detail]:verbose:(0 1 2)' \
  'abs=[absorbing boundaries (top, left, bottom, right)]:abs' \
  '*:vfile:_files' && ret=0

return ret
