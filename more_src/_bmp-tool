#compdef bmp-tool blackmagic-tool bmptool
# _bmp-tool — 1bitsquared Black Magic Probe bmp-tool CLI helper for the Black Magic Probe firmware updater serial-line console controller switching between BMP boot mode application mode firmware upgrade DFU SWD reset (blackmagic-debug team, Python); argparse
# upstream: https://github.com/blackmagic-debug/blackmagic

_bmp-tool() {
    local -a sub=(
        'update:update BMP firmware'
        'switch-bootloader:switch to bootloader'
        'switch-application:switch back to application'
        'serial:open serial console'
        'list:list connected BMPs'
        'info:show probe info'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[serial number]:str:' \
        '--serial=+[serial number]:str:' \
        '-p+[probe device]:str:' \
        '--probe=+[probe device]:str:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bmp-tool subcommand' sub ;;
        args)
            case $words[1] in
                update) _arguments \
                    '*:firmware file:_files -g "*.bin *.hex *.elf *.dfu"' ;;
                serial) _arguments \
                    '--baud=+[baud]:n:' ;;
            esac
            ;;
    esac
}

_bmp-tool "$@"
