#compdef wrcinfo
# _libwrc — libyal Windows Resource Compiler stream (.res / PE .rsrc section) parser; prints MUI / version-info / message-table / string-table resource trees
# upstream: https://github.com/libyal/libwrc

_libwrc() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-l+[language identifier]:lcid:' \
        '-X[exclusive]' \
        '*:resource file:_files -g "*.(res|mui|exe|dll)"'
}

_libwrc "$@"
