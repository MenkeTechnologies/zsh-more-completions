#compdef cuebreakpoints

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input-format)'{-i+,--input-format=}'[input file format]:format:(cue toc)' \
  '(--append-gaps --prepend-gaps --split-gaps)--append-gaps[append pregaps to previous track]' \
  '(--append-gaps --prepend-gaps --split-gaps)--prepend-gaps[prepend pregaps to track]' \
  '(--append-gaps --prepend-gaps --split-gaps)--split-gaps[split at start/end of pregap]' \
  '*:cue_or_toc:_files -g "*.{cue,toc}"' && ret=0

return ret
