#compdef celldetect
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/celldetect.html
# Use a sliding cell to search for sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input image or event file for source detection]:file:_files' \
  'psffile=[image of the PSF size for adjusting detect cells]:file:_files' \
  'expstk=[exposure map stack/file]:file:_files' \
  'outfile=[output source list file]:file:_files' \
  'regfile=[ASCII region file output]:file:_files' \
  'clobber=[overwrite existing output files]:clobber:(yes no)' \
  'thresh=[signal-to-noise threshold for source detection]:thresh:' \
  'snr_diminution=[evaluate diminished-SNR cells on finer grid]:snr_diminution:' \
  'findpeaks=[locate local maxima of contiguous detections]:findpeaks:(yes no)' \
  'centroid=[compute source centroid positions]:centroid:(yes no)' \
  'ellsigma=[size in sigmas for elliptical source regions]:ellsigma:' \
  'expratio=[suppress entries for low exposure ratio sources]:expratio:' \
  'fixedcell=[fixed detect cell size in pixels]:fixedcell:' \
  'xoffset=[X-axis offset for off-axis angle calculation]:xoffset:' \
  'yoffset=[Y-axis offset for off-axis angle calculation]:yoffset:' \
  'cellfile=[output stack of cell size images]:file:_files' \
  'maxlogicalwindow=[maximum axis length before internal rebinning]:maxlogicalwindow:' \
  'bkgfile=[predetermined background image file]:file:_files' \
  'bkgvalue=[fixed background value in counts per pixel]:bkgvalue:' \
  'bkgerrvalue=[error in background map or value estimate]:bkgerrvalue:' \
  'convolve=[use convolution library instead of sliding cells]:convolve:(yes no)' \
  'snrfile=[signal-to-noise ratio map output file]:file:_files' \
  'verbose=[verbosity level for log output]:verbose:(0 1 2 3 4 5)' \
  'log=[write log to file instead of stderr]:log:(yes no)' && ret=0

return ret
