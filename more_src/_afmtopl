#compdef afmtopl
# Documentation: https://man.archlinux.org/search?q=afmtopl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-charcode-format)-charcode-format=+[char code format]:fmt:(decimal octal hex)' \
  '(-no-encfile-comments)-no-encfile-comments[no encoding file comments]' \
  '(-no-kern-comments)-no-kern-comments[no kern comments]' \
  '1:afm file:_files -g "*.afm"' \
  '2:encoding file:_files -g "*.enc"' \
  '3:pl file:_files -g "*.pl"' && ret=0

return ret
