#compdef pltotf tftopl
# Documentation: pltotf --help / tftopl --help (TeX Live 2026)
# Source: TeX PL (property list) <-> TFM (TeX font metric) translators.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-charcode-format=[character code output format (tftopl)]:type:(octal ascii)' \
    '(- *)-help[show help]' \
    '-verbose[display progress reports]' \
    '(- *)-version[show version]' \
    '1:PL or TFM file:_files -g "*.{pl,tfm}"' \
    '2:output TFM or PL file:_files' \
    && ret=0

return ret
