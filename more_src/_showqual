#compdef showqual
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss191.html
# KAPPA: displays the quality names defined in an NDF

local ret=1

_arguments -s \
  'NDF=[NDF whose quality names are listed]:ndf:_files -g "*.sdf"' \
  'COUNT=[display pixel counts for each quality]:bool:(TRUE FALSE)' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
