#compdef ix

# Zsh completion for ix - command line pastebin (ix.io)

_arguments -s -S \
  '-i+[set paste ID for editing]:paste ID:' \
  '-d+[delete paste]:paste ID:' \
  '-n+[set number of lines]:lines:' \
  '-l[list pastes]' \
  '-L[list pastes with details]' \
  '-u+[set username]:username:' \
  '-p[read from stdin]' \
  '*:files:_files'
