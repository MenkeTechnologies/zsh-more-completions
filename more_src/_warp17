#compdef warp17
# Documentation: https://github.com/Juniper/warp17/blob/master/README.md
# WARP17 stateful L1-L7 traffic generator (DPDK)

local ret=1

_arguments -s \
  '-c[hex bitmask of physical cores the application will use]:coremask' \
  '-n[number of memory channels to use]:channels' \
  '-m[total memory available to the application (MB)]:megabytes' \
  '-w[PCI device to whitelist]:pci_addr' \
  '--version[print version and exit]' \
  '--help[print help and exit]' \
  '--qmap[<port>.<hexmask> cores controlling a physical port]:qmap' \
  '--qmap-default[default qmap policy]:policy:(max-c max-q)' \
  '--tcb-pool-sz[TCP control block pool size (x1024)]:size' \
  '--ucb-pool-sz[UDP control block pool size (x1024)]:size' \
  '--mbuf-pool-sz[packet pool size (x1024)]:size' \
  '--mbuf-sz[packet fragment (mbuf) size in bytes]:bytes' \
  '--mbuf-hdr-pool-sz[packet headers pool size (x1024)]:size' \
  '--mpool-any-sock[create memory pools from any available memory]' \
  '--ring-if-pairs[number of in-memory ring-based interface pairs]:count' \
  '--kni-ifs[number of KNI interfaces]:count' \
  '--cmd-file=[CLI command file executed at startup]:file:_files' \
  '*:arg:_files' && ret=0

return ret
