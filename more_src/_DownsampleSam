#compdef DownsampleSam
# Documentation: https://raw.githubusercontent.com/broadinstitute/picard/master/src/main/java/picard/sam/DownsampleSam.java
# Picard: randomly down-sample a SAM/BAM/CRAM file to a fraction of reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-I --INPUT)'{-I,--INPUT}'=[input SAM/BAM file to downsample]:file:_files' \
  '(-O --OUTPUT)'{-O,--OUTPUT}'=[output downsampled file]:file:_files' \
  '(-S --STRATEGY)'{-S,--STRATEGY}'=[downsampling strategy]:s:(HighAccuracy ConstantMemory Chained)' \
  '(-R --RANDOM_SEED)'{-R,--RANDOM_SEED}'=[random seed for deterministic results]:n:' \
  '(-P --PROBABILITY)'{-P,--PROBABILITY}'=[probability of keeping a read (0-1)]:p:' \
  '(-A --ACCURACY)'{-A,--ACCURACY}'=[accuracy target]:a:' \
  '(-M --METRICS_FILE)'{-M,--METRICS_FILE}'=[QualityYieldMetrics output file]:file:_files' \
  '--REFERENCE_SEQUENCE=[reference sequence file]:file:_files' \
  '--TMP_DIR=[temporary storage directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[SAM validation stringency]:s:(STRICT LENIENT SILENT)' \
  '--CREATE_INDEX=[create index for output]:b:(true false)' \
  '--VERBOSITY=[logging verbosity]:v:(ERROR WARNING INFO DEBUG)' && ret=0

return ret
