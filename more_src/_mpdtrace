#compdef mpdtrace
# Documentation: https://man.archlinux.org/search?q=mpdtrace
# Reference accessed: 2026-05-16

# mpdtrace: list MPD ring members
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '-v[verbose]' \
  '-f[hosts file]:file:_files' \
  '*::mpdtrace args:_files' && ret=0
return ret
