#compdef whatip
# Documentation: https://github.com/Cryptex-github/whatip
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream README documents only positional IP argument; no flags listed.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '1:IP address:' \
  '*:file:_files' && ret=0
return ret
