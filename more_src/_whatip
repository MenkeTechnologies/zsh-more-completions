#compdef whatip
# Documentation: https://github.com/Cryptex-github/whatip
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-4[show IPv4 address only]' \
  '-6[show IPv6 address only]' \
  '-j[output as JSON]' \
  '-s[show short output]' \
  '--all[show all available information]' \
  '--geo[show geolocation information]' \
  '--dns[show DNS information]' \
  '--provider=[use specific lookup provider]:provider'
