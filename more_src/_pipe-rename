#compdef pipe-rename renamer

# Zsh completion for pipe-rename - rename files using your favorite editor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' \
  '(-p --pretty)'{-p,--pretty}'[pretty print the rename plan]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-u --undo)'{-u,--undo}'[undo the last rename operation]' \
  '*:files:_files'
