#compdef adonis
# _adonisjs — AdonisJS Node.js MVC framework CLI (Harminder Virk); Laravel-inspired Node framework with Lucid ORM
# upstream: https://github.com/adonisjs/core

_adonisjs() {
    local -a sub=(
        'serve:start dev server (HMR)'
        'build:build for production'
        'configure:configure a package'
        'eject:eject stubs'
        'list:list available commands'
        'make:make scaffolds'
        'manifest:generate ace manifest'
        'migration:database migrations'
        'db:database commands'
        'queue:queue commands'
        'repl:run REPL'
        'route:list routes'
        'test:run tests'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--env+[env file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'adonis subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--watch[watch and restart]' \
                    '--polling[use polling]' \
                    '--hmr[enable HMR]' \
                    '--clear[clear screen]' \
                    '--no-clear[no clear screen]' \
                    '--assets[build assets]' \
                    '--no-assets[skip assets]' \
                    '--assets-args+[asset bundler args]:args:' ;;
                build) _arguments \
                    '--production[production build]' \
                    '--ignore-ts-errors[ignore TS errors]' \
                    '--no-assets[skip assets]' \
                    '--assets-args+[asset bundler args]:args:' ;;
                make) _arguments '1:scaffold:(controller middleware model migration provider service exception command listener event mail validator factory seeder view test)' '*:name:' ;;
                migration) _arguments '1:cmd:(run rollback refresh reset status fresh make)' ;;
                db) _arguments '1:db cmd:(seed truncate wipe)' ;;
                route) _arguments '--reverse[reverse listing]' '--json[JSON output]' '--middleware[show middleware]' ;;
            esac
            ;;
    esac
}

_adonisjs "$@"
