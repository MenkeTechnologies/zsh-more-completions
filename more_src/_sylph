#compdef sylph
# Documentation: https://sylph-docs.github.io/
# Fast and precise species-level metagenomic profiling with ANI

local ret=1
local curcontext="$curcontext" state line
typeset -A opt_args

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'sylph command' \
      'sketch[create sketches of genomes and reads]' \
      'profile[abundance profiling against reference sketches]' \
      'query[containment query against reference sketches]' \
      'inspect[inspect a sketch file]' && ret=0
    ;;
  args)
    case $line[1] in
      sketch)
        _arguments -s \
          '(-o --out-name-db)'{-o,--out-name-db}'[output database file name]:name:_files' \
          '(-d --sample-output-directory)'{-d,--sample-output-directory}'[sample output directory]:dir:_files -/' \
          '--individual-records[treat each record individually]' \
          '--reads=[read files]:reads:_files' \
          '(-g --genomes)'{-g,--genomes}'[genome files]:genomes:_files' \
          '--list=[file listing inputs]:file:_files' \
          '--rl=[read list file]:file:_files' \
          '--gl=[genome list file]:file:_files' \
          '--l1=[list of first paired reads]:file:_files' \
          '--l2=[list of second paired reads]:file:_files' \
          '--lS=[list of sample names]:file:_files' \
          '(-S --sample-names)'{-S,--sample-names}'[sample names]:names:' \
          '(-1 --first-pairs)'{-1,--first-pairs}'[first paired-end read files]:reads:_files' \
          '(-2 --second-pairs)'{-2,--second-pairs}'[second paired-end read files]:reads:_files' \
          '(-k --k)'{-k,--k}'[k-mer size]:k:(21 31)' \
          '(-c --c)'{-c,--c}'[subsampling compression factor]:c:' \
          '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
          '--ram-barrier=[ram usage barrier in GB]:gb:' \
          '--min-spacing=[minimum spacing between k-mers]:n:' \
          '--fpr=[false positive rate]:fpr:' \
          '--no-dedup[disable read deduplication]' \
          '--disable-profiling[disable profiling-specific sketching]' \
          '--trace[trace logging]' \
          '--debug[debug logging]' \
          '*:file:_files'
        ;;
      profile|query)
        _arguments -s \
          '(-l --list)'{-l,--list}'[file listing inputs]:file:_files' \
          '(-r --reads)'{-r,--reads}'[read files or sketches]:reads:_files' \
          '(-1 --first-pairs)'{-1,--first-pairs}'[first paired-end read files]:reads:_files' \
          '(-2 --second-pairs)'{-2,--second-pairs}'[second paired-end read files]:reads:_files' \
          '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
          '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
          '(-s --sample-threads)'{-s,--sample-threads}'[threads per sample]:threads:' \
          '(-m --minimum-ani)'{-m,--minimum-ani}'[minimum ANI to report]:ani:' \
          '(-M --min-number-kmers)'{-M,--min-number-kmers}'[minimum number of k-mers]:n:' \
          '--min-count-correct=[min count for coverage correction]:n:' \
          '(-u --estimate-unknown)'{-u,--estimate-unknown}'[estimate unknown sequence fraction]' \
          '--estimate-read-counts[estimate read counts]' \
          '(-I --read-seq-id)'{-I,--read-seq-id}'[read sequence identity]:id:' \
          '(-R --redundancy-threshold)'{-R,--redundancy-threshold}'[redundancy threshold]:thr:' \
          '(-k --k)'{-k,--k}'[k-mer size]:k:(21 31)' \
          '(-c --c)'{-c,--c}'[subsampling compression factor]:c:' \
          '--individual-records[treat each record individually]' \
          '--min-spacing=[minimum spacing between k-mers]:n:' \
          '--log-reassignments[log read reassignments]' \
          '--trace[trace logging]' \
          '--debug[debug logging]' \
          '*:file:_files'
        ;;
      inspect)
        _arguments -s \
          '(-o --output-file)'{-o,--output-file}'[output file]:file:_files' \
          '*:sketch:_files'
        ;;
    esac
    ;;
esac

return ret
