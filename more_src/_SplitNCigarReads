#compdef SplitNCigarReads
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/rnaseq/SplitNCigarReads.java
# Split Reads with N in Cigar

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--refactor-cigar-string -fixNDN)'{--refactor-cigar-string,-fixNDN}'[refactor cigar string with NDN elements to one element]:value:' \
  '(--skip-mapping-quality-transform -skip-mq-transform)'{--skip-mapping-quality-transform,-skip-mq-transform}'[skip the 255 -> 60 MQ read transform]' \
  '--max-reads-in-memory=[max reads allowed to be kept in memory at a time by the BAM writer]:value:' \
  '--max-mismatches-in-overhang=[max number of mismatches allowed in the overhang]:value:' \
  '--max-bases-in-overhang=[max number of bases allowed in the overhang]:value:' \
  '--do-not-fix-overhangs[do not have the walker soft-clip overhanging sections of the reads]' \
  '--process-secondary-alignments[have the walker split secondary alignments (will still repair MC tag without it)]' \
  '*:argument:_files' && ret=0

return ret
