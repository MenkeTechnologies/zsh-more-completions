#compdef migra

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--unsafe[allow generation of drop statements]' \
  '--schema=[restrict to a specific schema]:schema:' \
  '--exclude_schema=[exclude a specific schema]:schema:' \
  '--create-extensions-only[only output CREATE EXTENSION statements]' \
  '--ignore-extension-versions[ignore extension version differences]' \
  '--with-privileges[also output GRANT/REVOKE differences]' \
  '--force-utf8[force UTF-8 output encoding]' \
  '*::dburl:' && ret=0

return ret
