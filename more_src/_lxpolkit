#compdef lxpolkit
# Documentation: https://man.archlinux.org/search?q=lxpolkit
# Reference accessed: 2026-05-16

# lxpolkit: LXDE/LXQt PolicyKit authentication agent (daemon, no args)
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)--version[print version]' && ret=0

return ret
