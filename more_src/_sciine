#compdef sciine
# Documentation: https://github.com/jdum/asciinema-scene
# sciine - toolbox to edit asciinema screencasts

local ret=1
local curcontext="$curcontext" state line

local -a io
io=(
  '(-i --input)'{-i,--input}'=[input cast file]:file:_files'
  '(-o --output)'{-o,--output}'=[output cast file]:file:_files'
)
local -a se
se=(
  '(-s --start)'{-s,--start}'=[start timecode]:start'
  '(-e --end)'{-e,--end}'=[end timecode]:end'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'sciine command' \
      'status[print information about the content (duration, ...)]' \
      'header[print the header field of the content]' \
      'show[print detail of frames, from START to END]' \
      'copy[copy content between START and END timecodes]' \
      'cut[cut content between START and END timecodes]' \
      'speed[change the speed of the screen cast]' \
      'minimum[set minimum duration of each frame]' \
      'maximum[set maximum duration of each frame]' \
      'quantize[set the duration of frames in a duration range]' \
      'include[include the content of a .cast file at a timecode]' \
      'insert[insert a frame at the TIMECODE position]' \
      'replace[replace the text of a frame from TIMECODE]' \
      'delete[delete the frame with timecode >= TIMECODE]' \
      'text-delete[delete frames matching the text regex]' \
      'text-replace[replace text in frames matching the regex]' \
      'text-merge[merge successive frames matching the regex]' && ret=0
    ;;
  args)
    case $line[1] in
      status|header)
        _arguments -s '(-i --input)'{-i,--input}'=[input cast file]:file:_files' && ret=0
        ;;
      show)
        _arguments -s $se \
          '(-l --lines)'{-l,--lines}'=[max lines]:lines' \
          '(-p --precise)'{-p,--precise}'[precise output]' \
          '(-t --text)'{-t,--text}'[text output]' \
          '(-i --input)'{-i,--input}'=[input cast file]:file:_files' && ret=0
        ;;
      copy)
        _arguments -s $se $io && ret=0
        ;;
      cut)
        _arguments -s $se $io \
          '(-a --adjust)'{-a,--adjust}'[adjust timecodes]' && ret=0
        ;;
      speed|minimum|maximum|quantize|text-delete|text-replace|text-merge)
        _arguments -s $se $io '*:arg' && ret=0
        ;;
      include|replace|delete)
        _arguments -s $io '*:arg' && ret=0
        ;;
      insert)
        _arguments -s $io \
          '(-b --line-break)'{-b,--line-break}'[insert a line break]' \
          '*:arg' && ret=0
        ;;
    esac
    ;;
esac

return ret
