#compdef pwninit
# Documentation: https://github.com/io12/pwninit
# Source: src/opts.rs (structopt definitions, generates clap args)
# Reference accessed: 2026-05-30
# pwninit — CTF binary-exploit challenge initializer. Auto-detects the
# challenge binary + libc + linker in cwd, runs patchelf on the binary,
# and emits a pwntools solve-script template.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--bin=[explicit binary to pwn (overrides auto-detect)]:file:_files' \
  '--libc=[explicit challenge libc (overrides auto-detect)]:file:_files -g "*libc*"' \
  '--ld=[explicit linker to preload the libc with]:file:_files -g "*ld*"' \
  '--template-path=[path to custom pwntools solve-script template]:file:_files -g "*.py"' \
  '--template-bin-name=[binary-variable name in template (default exe)]:name:' \
  '--template-libc-name=[libc-variable name in template (default libc)]:name:' \
  '--template-ld-name=[linker-variable name in template (default ld)]:name:' \
  '--no-patch-bin[disable patchelf on the binary]' \
  '--no-template[disable generating the solve-script template]' \
  && ret=0

return ret
