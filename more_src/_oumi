#compdef oumi
# _oumi — train, evaluate, deploy open LLMs / VLMs (oumi-ai/oumi)
# upstream: https://github.com/oumi-ai/oumi
# Subcommands from src/oumi/cli/main.py (typer).

_oumi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--install-completion[install shell completion]' \
        '--show-completion[show installed shell completion]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_oumi_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                train|eval|evaluate|tune|infer|judge|quantize|synth)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[oumi YAML config file]:file:_files -g "*.(yaml|yml)"' \
                        '--list[list available built-in configs and exit]' \
                        '*::extra config overrides:' && ret=0 ;;
                fetch)
                    _arguments \
                        '1:config name or path:' \
                        '2:output path (optional):_files' && ret=0 ;;
                analyze)
                    _arguments \
                        '1: :(dataset model trace)' \
                        '*:analyze args:' && ret=0 ;;
                launch)
                    _arguments \
                        '1: :(up run down stop cancel status logs which)' \
                        '*:launch args:' && ret=0 ;;
                deploy)
                    _arguments \
                        '1: :(up upload create-endpoint list list-models list-hardware status start stop test delete delete-model)' \
                        '*:deploy args:' && ret=0 ;;
                distributed)
                    _arguments \
                        '1: :(accelerate torchrun)' \
                        '*:launcher args:' && ret=0 ;;
                cache)
                    _arguments \
                        '1: :(ls get card rm)' \
                        '*:cache args:' && ret=0 ;;
                env|completions) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_oumi_commands] )) ||
_oumi_commands() {
    local -a commands
    commands=(
        'train:train or fine-tune a model from a YAML config'
        'evaluate:evaluate a model (alias: eval)'
        'eval:evaluate a model (alias of evaluate)'
        'tune:hyperparameter tuning'
        'infer:run inference (optionally interactive)'
        'judge:judge a conversations or dataset file with an LLM judge'
        'quantize:quantize a trained model'
        'synth:synthesize a dataset'
        'fetch:fetch an oumi config from the registry'
        'analyze:analyze datasets / models / traces'
        'launch:launch / manage jobs on a cluster'
        'deploy:upload models and manage inference endpoints'
        'distributed:wrap accelerate / torchrun for distributed runs'
        'cache:manage the local oumi cache (models, datasets)'
        'env:print oumi environment information'
        'completions:emit shell completion script'
    )
    _describe -t commands 'oumi command' commands
}

_oumi "$@"
