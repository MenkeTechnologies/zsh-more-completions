#compdef witr
# Documentation: https://man.archlinux.org/search?q=witr
# Reference accessed: 2026-05-16

# Zsh completion for witr terminal journal / note capture

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-c+[HTTP public URL]:url' \
  '-p+[HTTP listen port]:port'
