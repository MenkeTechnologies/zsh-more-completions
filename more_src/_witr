#compdef witr
# Documentation: https://github.com/pranshuparmar/witr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for witr terminal journal / note capture

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-c+[HTTP public URL]:url' \
  '-p+[HTTP listen port]:port'
