#compdef zentao
# Documentation: https://github.com/easysoft/zentao-cli
# Reference accessed: 2026-05-22
# Verified: upstream README and CLI usage at the URL above.

# Zsh completion for zentao - ZenTao project management CLI

local curcontext="$curcontext" state line ret=1

_zentao_globals() {
  _arguments \
    '--pick[fields to display]:fields:' \
    '--filter[filter expression]:expr:' \
    '--search[search text]:text:' \
    '--search-fields[fields to search]:fields:' \
    '--sort[sort order]:order:' \
    '--format[output format]:format:(json markdown)' \
    '--json[JSON output (alias)]' \
    '--insecure[ignore TLS certificate errors]'
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'zentao command' \
      'login[login to ZenTao server]' \
      'help[show help]' \
      'config[manage CLI configuration]' \
      'add-skill[install ZenTao skill for AI agents]' \
      'add-mcp[configure MCP server for AI agents]' \
      'mcp[start MCP server]' \
      'product[manage products]' \
      'bug[manage bugs]' \
      'story[manage stories/requirements]' \
      'task[manage tasks]' \
      'execution[manage executions]' \
      'project[manage projects]' \
      'program[manage programs]' \
      'build[manage builds]' \
      'release[manage releases]' \
      'testcase[manage test cases]' \
      'testsuite[manage test suites]' \
      'testrun[manage test runs]' \
      'doc[manage documents]' \
      'repo[manage repositories]' \
      'user[manage users]' \
      'dept[manage departments]' \
      'todo[manage todos]' \
      'risk[manage risks]' && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments \
          '(-s --zentao-url)'{-s,--zentao-url}'[ZenTao server URL]:url:' \
          '(-u --zentao-account)'{-u,--zentao-account}'[account name]:user:' \
          '(-p --zentao-password)'{-p,--zentao-password}'[password]:password:' \
          '--insecure[ignore TLS certificate errors]' && ret=0
        ;;
      help)
        _arguments '2:module:' && ret=0
        ;;
      config|product|bug|story|task|execution|project|program|build|release|testcase|testsuite|testrun|doc|repo|user|dept|todo|risk)
        _zentao_globals && ret=0
        ;;
    esac
    ;;
esac

return ret
