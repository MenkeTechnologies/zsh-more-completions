#compdef casr-afl
# Documentation: https://github.com/ispras/casr/blob/master/docs/usage.md
# Triage crashes found by AFL++/Sharpfuzz with CASR

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-l --log-level)'{-l,--log-level}'=[logging level]:level:(info debug)' \
  '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs' \
  '(-t --timeout)'{-t,--timeout}'=[timeout for target execution in seconds]:seconds' \
  '(-i --input)'{-i,--input}'=[AFL++ work directory]:dir:_files -/' \
  '(-o --output)'{-o,--output}'=[output directory with triaged reports]:dir:_files -/' \
  '--join=[use directory with previously triaged reports]:dir:_files -/' \
  '(-f --force-remove)'{-f,--force-remove}'[remove output directory if it exists]' \
  '--ignore-cmdline[force ARGS usage instead of AFL cmdline files]' \
  '--no-cluster[do not cluster CASR reports]' \
  '--hint=[force specific tool]:hint:(auto gdb san)' \
  '*::args:_normal' && ret=0

return ret
