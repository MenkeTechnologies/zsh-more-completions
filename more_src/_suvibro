#compdef suvibro
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/synthetics_waveforms_testpatterns/suvibro.c
# generate a Vibroseis sweep

local ret=1

_arguments -s -S \
  'dt=[time sampling interval]:dt' \
  'sweep=[sweep type 1..5]:sweep:(1 2 3 4 5)' \
  'swconst=[sweep constant for nonlinear sweeps]:swconst' \
  'f1=[sweep frequency at start]:f1' \
  'f2=[sweep frequency at end]:f2' \
  'tv=[sweep length]:tv' \
  'phz=[initial phase]:phz' \
  'radians=[phase units 1=radians 0=degrees]:radians:(0 1)' \
  'fseg=[frequency segments for linear-segment sweep]:fseg' \
  'tseg=[time segments for linear-segment sweep]:tseg' \
  't1=[taper length at start]:t1' \
  't2=[taper length at end]:t2' \
  'taper=[taper type 1..5]:taper:(1 2 3 4 5)' \
  '*:file:_files' && ret=0


return ret
