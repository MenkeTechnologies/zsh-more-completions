#compdef comskip
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/comskip.1.html
# comskip — commercial detector for video files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display syntax]' \
  '(-w --debugwindow)'{-w,--debugwindow}'[show debug window]' \
  '(-n --playnice)'{-n,--playnice}'[slow detection down]' \
  '--zpcut[output a ZoomPlayer cutlist]' \
  '--zpchapter[output a ZoomPlayer chapter file]' \
  '--scf[output a simple chapter file for mkvmerge]' \
  '--videoredo[output a VideoRedo cutlist]' \
  '--videoredo3[output a VideoRedo3 cutlist]' \
  '--csvout[output a csv of the frame array]' \
  '--quality[output a csv of false detection segments]' \
  '--plist[output a mac-style plist for EyeTV archive]' \
  '(-m --demux)'{-m,--demux}'[demux the input into elementary streams]' \
  '--hwassist[activate hardware assisted video decoding]' \
  '--cuvid[use NVIDIA Video Decoder (CUVID) if available]' \
  '--vdpau[use NVIDIA Video Decode and Presentation API]' \
  '--dxva2[use DXVA2 Video Decode and Presentation API]' \
  '--decoders[list all decoders and exit]' \
  '--threads=[number of threads to use]:threads' \
  '(-p --pid)'{-p+,--pid=}'[PID of the video in the TS]:pid' \
  '(-t --ts)'{-t,--ts}'[the input file is a Transport Stream]' \
  '(-d --detectmethod)'{-d+,--detectmethod=}'[integer sum of the detection methods]:method' \
  '(-v --verbose)'{-v+,--verbose=}'[verbose level]:level' \
  '(-u --dump)'{-u+,--dump=}'[dump the cutscene at this frame number]:frame' \
  '(-s --play)'{-s,--play}'[play the video]' \
  '--timing[dump the timing into a file]' \
  '(-q --quiet)'{-q,--quiet}'[do not output logging to the console]' \
  '--ini=[ini file to use]:file:_files' \
  '--logo=[logo file to use]:file:_files' \
  '--cut=[cutscene file to use]:file:_files' \
  '--output=[folder to use for all output files]:dir:_files -/' \
  '--output-filename=[filename base to use for all output files]:name' \
  '--selftest=[execute a selftest]:int' \
  '*:file:_files' && ret=0

return ret
