#compdef prove6-j prove6-js
# Documentation: https://man.archlinux.org/search?q=prove6-j
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-v[verbose]' \
  '-q[quiet]' \
  '-r[recursive]' \
  '-e+[interpreter]:interpreter:_command_names -e' \
  '-l[lib mode]' \
  '*:test file or directory:_files' && ret=0

return ret
