#compdef evolver
# Documentation: http://abacus.gene.ucl.ac.uk/software/paml.html
# PAML evolver: simulate sequences and trees, and tree/branch manipulations

local ret=1

_arguments -s -S \
  '1:mode:((1\:"random trees, branch lengths from birth-death" 2\:"random trees, given branch lengths" 3\:"print random trees" 4\:"calculate partition distances" 5\:"simulate nucleotide data sets (MCbase.dat)" 6\:"simulate codon data sets (MCcodon.dat)" 7\:"simulate amino acid data sets (MCaa.dat)"))' \
  '2:data file:_files -g "*.dat"' && ret=0

return ret
