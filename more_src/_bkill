#compdef bkill

# bkill: kill an LSF job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-s[signal]:signal:' \
  '-r[force kill]' \
  '-q[queue]:queue:' \
  '-m[host]:host:_hosts' \
  '-u[user]:user:_users' \
  '-J[job name]:name:' \
  '-g[job group]:group:' \
  '0[kill all of user jobs]' \
  '*:jobid:' && ret=0
return ret
