#compdef ambpdb
# Documentation: https://ambermd.org/tutorials/Manuals.php
# AmberTools: convert an Amber prmtop+coordinates into a PDB, MOL2 or PQR file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p+[Amber topology (prmtop) file]:file:_files' \
  '-c+[coordinate/restart file]:file:_files' \
  '-tit+[title]:title' \
  '-pqr[output PQR file with charges and radii]' \
  '-bin[coordinates are binary (NetCDF)]' \
  '-offset+[renumber residues by this offset]:offset' \
  '-aatm[use Amber atom names]' \
  '-bres[use Brookhaven (PDB) residue names]' \
  '-ext[include chainIDs and alternate location flags]' \
  '-ep[print extra points]' \
  '-conect[write CONECT records]' \
  '-noter[do not write TER records]' \
  '-mol2[output a MOL2 file]' \
  '-sybyl[use SYBYL atom types in MOL2 output]' && ret=0

return ret
