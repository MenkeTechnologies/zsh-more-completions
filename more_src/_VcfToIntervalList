#compdef VcfToIntervalList
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#VcfToIntervalList
# Picard: convert a VCF/BCF into a Picard interval list

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[BCF or VCF input file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[output Picard interval list]:interval_list:_files -g "*.interval_list"' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
