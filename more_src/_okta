#compdef okta

# Zsh completion for okta - Okta CLI (provisions Okta resources for apps)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start with an Okta sample app or onboard'
  'register:sign up for a new Okta organization'
  'login:login to your Okta organization'
  'logout:log out of your Okta organization'
  'apps:manage Okta applications'
  'config:show or set configuration'
  'help:show help for a subcommand'
  'version:display okta CLI version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show okta version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'okta command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '1:sample:(angular express express-api javascript react spring-boot vue android ios go php)' && ret=0
        ;;
      (apps)
        _arguments \
          '1:subcommand:(create list)' \
          '--redirect-uri[OAuth redirect URI]:uri:' && ret=0
        ;;
      (register)
        _arguments \
          '--email[email for the new org]:email:' \
          '--first-name[first name]:name:' \
          '--last-name[last name]:name:' \
          '--company[company name]:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
