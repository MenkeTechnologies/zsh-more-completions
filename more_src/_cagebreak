#compdef cagebreak
# cagebreak - Tiling Wayland compositor inspired by ratpoison

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-s --socket)'{-s+,--socket=}'[Wayland socket name]:socket:' \
  '(-e --enable)'{-e,--enable}'[enable IPC]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-bs --border-size)'{-bs+,--border-size=}'[border size in pixels]:pixels:' \
  '(-bc --border-color)'{-bc+,--border-color=}'[border color (hex)]:color:' \
  '(-o --output)'{-o+,--output=}'[configure output]:output config:' \
  && ret=0

return ret
