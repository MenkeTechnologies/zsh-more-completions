#compdef libassuan-config
# Documentation: https://gnupg.org/software/libassuan/
# Reference accessed: 2026-05-19
# Verified: `libassuan-config --help` from installed binary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '--host[print build/host system]' && ret=0

return ret
