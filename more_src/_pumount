#compdef pumount
# Policy-based unmount for removable devices

local ret=1

_arguments -s -S \
  '-l[lazy unmount]' \
  '-d[also remove loop device]' \
  '--luks-force[force LUKS teardown]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:device or mount point:_files' && ret=0

return ret
