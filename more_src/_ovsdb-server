#compdef ovsdb-server
# _ovsdb-server — Open vSwitch ovsdb-server JSON-RPC database server for Open vSwitch and OVN (openvswitch team, C); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovsdb-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose modules]:str:' \
        '--verbose=+[verbose modules]:str:' \
        '--remote=+[remote spec]:str:' \
        '--run=+[run command]:str:' \
        '--unixctl=+[unixctl socket]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '--detach[run as background process]' \
        '--no-chdir[do not chdir to /]' \
        '--monitor[run with monitor]' \
        '--syslog-method=+[method]:m:(libc syslog null udp)' \
        '--syslog-target=+[target]:str:' \
        '--private-key=+[key file]:file:_files' \
        '-p+[key file]:file:_files' \
        '--certificate=+[cert file]:file:_files' \
        '-c+[cert file]:file:_files' \
        '--ca-cert=+[ca cert file]:file:_files' \
        '-C+[ca cert file]:file:_files' \
        '--ssl-ciphers=+[ciphers]:str:' \
        '--ssl-protocols=+[protocols]:str:' \
        '--peer-ca-cert=+[peer ca cert]:file:_files' \
        '--user=+[user[:group]]:user:_users' \
        '-R+[disable backtrace]:str:' \
        '--bootstrap-ca-cert=+[ca cert]:file:_files' \
        '--data-conventions[OVSDB data conventions]' \
        '--no-monitor[no monitor]' \
        '*:db file:_files -g "*.db"'
}

_ovsdb-server "$@"
