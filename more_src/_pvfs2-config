#compdef pvfs2-config
# Documentation: https://man.archlinux.org/search?q=pvfs2-config
# Reference accessed: 2026-05-16

# pvfs2-config: show PVFS2 build-time info
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*:files:_files' && ret=0
return ret
