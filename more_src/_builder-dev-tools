#compdef builder-dev-tools builder.io builderio
# Documentation: https://github.com/BuilderIO/builder
# Reference accessed: 2026-05-23
# Verified: @builder.io/dev-tools help output (builder-dev-tools npm bin).

# Zsh completion for builder-dev-tools - Builder.io Fusion AI dev tools CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'builder.io command' \
      'launch[launch Builder Fusion dev server]' \
      'auth[authenticate with Builder.io]' \
      'index-repo[index design system repo for AI codegen]' \
      'connect-repo[connect git repo to Builder Fusion]' \
      'code[generate or modify code from Figma]' \
      'figma[Figma mapping commands]' \
      'add[add component to project]' \
      'push[push local changes to Builder branch]' && ret=0
    ;;
  args)
    case $line[1] in
      figma)
        if (( CURRENT == 2 )); then
          _values 'figma command' \
            'publish[publish Figma mappings to Builder.io]' \
            'migrate[migrate Figma mappings into repo]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
