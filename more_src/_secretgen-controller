#compdef secretgen-controller
# _secretgen-controller — Carvel secretgen-controller (Password/Certificate/RSAKey generators)
# upstream: https://github.com/carvel-dev/secretgen-controller
# Flags from cmd/controller/main.go on tip.

_secretgen-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--namespace=[namespace to watch (empty = all)]:ns:' \
        '--metrics-bind-address=[metrics bind host\:port (0 disables)]:host\:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_secretgen-controller "$@"
