#compdef omz

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'changelog:print the Oh My Zsh changelog'
  'help:show help'
  'plugin:manage plugins'
  'pr:manage Oh My Zsh pull requests'
  'reload:reload the current zsh session'
  'shop:open the Oh My Zsh shop'
  'theme:manage themes'
  'update:update Oh My Zsh'
  'version:show version'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'omz subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (plugin)
        _values 'plugin action' \
          'disable' 'enable' 'info' 'list' 'load' && ret=0
        ;;
      (theme)
        _values 'theme action' \
          'list' 'set' 'use' && ret=0
        ;;
      (pr)
        _values 'pr action' 'clean' 'test' && ret=0
        ;;
    esac
    ;;
esac

return ret
