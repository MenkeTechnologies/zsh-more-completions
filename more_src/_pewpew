#compdef pewpew
# Documentation: https://github.com/bengadbois/pewpew
# Flexible HTTP command-line stress tester for websites and web services

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((
    stress\:"send requests as fast as the server can respond"
    benchmark\:"send requests at a fixed rate"
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _arguments -s -S \
      '(-n --num)'{-n,--num}'=[number of requests per target]:count:' \
      '(-c --concurrent)'{-c,--concurrent}'=[concurrent requests per target]:count:' \
      '(-t --timeout)'{-t,--timeout}'=[request timeout]:duration:' \
      '(-X --request-method)'{-X,--request-method}'=[HTTP request method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
      '--body=[request body]:body:' \
      '--body-file=[read request body from a file]:file:_files' \
      '*'{-H,--header}'=[request header]:header:' \
      '--user-agent=[user agent string]:agent:' \
      '--basic-auth=[basic auth "user:password"]:auth:' \
      '--ignore-ssl[ignore SSL certificate errors]' \
      '--compress[add the Accept-Encoding gzip header]' \
      '--keepalive[enable HTTP keepalive]' \
      '--no-http2[disable HTTP2]' \
      '--follow-redirects[follow HTTP redirects]' \
      '--dns-prefer=[preferred DNS resolution]:pref:' \
      '--enforce-ssl[enforce SSL certificate correctness]' \
      '--cpus=[number of CPUs to use]:count:' \
      '(-r --regex)'{-r,--regex}'[interpret targets as regex]' \
      '--json=[write results as JSON to a file]:file:_files' \
      '--csv=[write results as CSV to a file]:file:_files' \
      '--xml=[write results as XML to a file]:file:_files' \
      '--output-json=[write summary as JSON to a file]:file:_files' \
      '--verbose[print extra troubleshooting info]' \
      '--rps=[requests per second (benchmark mode)]:rps:' \
      '--duration=[test duration (benchmark mode)]:seconds:' \
      '*:target url:' && ret=0
    ;;
esac

return ret
