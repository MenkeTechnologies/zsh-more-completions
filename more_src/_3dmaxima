#compdef 3dmaxima
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dmaxima.html
# Find local maxima (extrema) in a functional dataset

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,-help,--help}'[show help]' \
  '-input[input functional dataset]:dataset:_files' \
  '-prefix[output mask dataset prefix]:prefix:' \
  '-spheres_1[set all output values to 1]' \
  '-spheres_1toN[output values 1 to N, extreme as 1]' \
  '-spheres_Nto1[output values N to 1, extreme as N]' \
  '-thresh[cutoff value for filtering extrema]:cutoff:' \
  '-min_dist[minimum distance between extrema (voxels)]:voxels:' \
  '-out_rad[output sphere radius around extrema]:size:' \
  '-n_style_sort[use Sort-n-Remove neighbor style]' \
  '-n_style_weight_ave[use Weighted-Average neighbor style]' \
  '-neg_ext[search for negative extrema (minima)]' \
  '-true_max[require extrema strictly greater than neighbors]' \
  '-debug[debug level]:level:' \
  '-no_text[suppress text display of extrema]' \
  '-coords_only[output only coordinates]' \
  '-dset_coords[display output in dataset orientation]' \
  '-hist[show module history]' \
  '-ver[show version number]' \
  '*:dataset:_files' && ret=0

return ret
