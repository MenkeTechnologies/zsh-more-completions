#compdef odhcp6c
# Documentation: https://man.archlinux.org/search?q=odhcp6c
# Reference accessed: 2026-05-16

# odhcp6c: lightweight DHCPv6 client (OpenWrt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[script (path to user hooks)]:file:_files' \
  '-S[stateful mode (managed)]' \
  '-N[non-stateful mode]:val:(force try try-no-prefix)' \
  '-P[prefix length hint]:n:' \
  '-c[client DUID hex]:duid:' \
  '-r[request option]:n:' \
  '-R[refuse all RA]' \
  '-t[transaction limit]:n:' \
  '-m[minimum retry interval]:s:' \
  '-T[disable preconfigured RAs]' \
  '-f[skip script]' \
  '-A[disable accept_ra]' \
  '-k[keep config when stopped]' \
  '-K[reuse existing IAID]' \
  '-x[xid (transaction id)]:hex:' \
  '-u[user-class]:str:' \
  '-V[vendor class data]:str:' \
  '-d[delegate prefix]' \
  '-p[PID file]:file:_files' \
  '-e[print events to stderr]' \
  '-v[verbose]' \
  '*:interface:' && ret=0
return ret
