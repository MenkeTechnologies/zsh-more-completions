#compdef woodpecker-server

# woodpecker-server: Woodpecker CI server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--server-addr=[server bind addr]:addr:' \
  '--server-cert=[TLS cert]:file:_files' \
  '--server-key=[TLS key]:file:_files' \
  '--server-host=[server hostname]:host:_hosts' \
  '--lets-encrypt[enable LetsEncrypt]' \
  '--lets-encrypt-email=[LE email]:email:' \
  '--grpc-addr=[gRPC bind addr]:addr:' \
  '--grpc-secret=[gRPC secret]:secret:' \
  '--admin=[admin users]:list:' \
  '--orgs=[allowed orgs]:list:' \
  '--repo-owners=[allowed repo owners]:list:' \
  '--open[allow open registration]' \
  '--docs=[docs base URL]:url:' \
  '--session-expires=[session expires]:duration:' \
  '--database-driver=[database driver]:driver:(sqlite3 mysql postgres)' \
  '--database-datasource=[database datasource]:dsn:' \
  '--prometheus-auth-token=[prometheus auth token]:token:' \
  '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
  '--log-format=[log format]:fmt:(text json color)' \
  '--gitea[enable Gitea integration]' \
  '--gitea-url=[Gitea URL]:url:' \
  '--gitlab[enable GitLab integration]' \
  '--github[enable GitHub integration]' \
  '--github-url=[GitHub URL]:url:' \
  '--bitbucket[enable Bitbucket integration]' \
  '*::woodpecker-server args:_files' && ret=0
return ret
