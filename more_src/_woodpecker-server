#compdef woodpecker-server
# Documentation: https://woodpecker-ci.org/docs/administration/configuration/server
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# woodpecker-server: Woodpecker CI server.
# Flags map 1:1 to documented WOODPECKER_* environment variables.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--host=[fully qualified server URL]:url:' \
  '--server-addr=[HTTP listener address]:addr:' \
  '--server-addr-tls=[HTTPS listener address]:addr:' \
  '--server-cert=[TLS certificate file]:file:_files' \
  '--server-key=[TLS key file]:file:_files' \
  '--grpc-addr=[gRPC listener address]:addr:' \
  '--grpc-secret=[gRPC JWT secret]:secret:' \
  '--grpc-secret-file=[gRPC JWT secret file]:file:_files' \
  '--admin=[comma-separated admin usernames]:list:' \
  '--orgs=[allowed organizations]:list:' \
  '--repo-owners=[allowed repository owners]:list:' \
  '--open[allow user registration]' \
  '--authenticate-public-repos[force auth for public repos]' \
  '--session-expires=[session token validity]:duration:' \
  '--agent-secret=[shared agent authentication secret]:secret:' \
  '--agent-secret-file=[agent secret file]:file:_files' \
  '--disable-user-agent-registration[prevent users from creating agents]' \
  '--database-driver=[database driver]:driver:(sqlite3 mysql postgres)' \
  '--database-datasource=[database connection string]:dsn:' \
  '--database-datasource-file=[datasource file]:file:_files' \
  '--database-max-connections=[max DB connections]:n:' \
  '--database-idle-connections=[idle DB connections]:n:' \
  '--database-connection-timeout=[DB connection timeout]:duration:' \
  '--database-log[enable database logging]' \
  '--database-log-sql[enable SQL command logging]' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic disabled)' \
  '--log-file=[log output destination]:destination:(stdout stderr)' \
  '--log-store=[log storage backend]:store:(database file addon)' \
  '--log-store-file-path=[log file directory or addon path]:path:_files' \
  '--debug-pretty[pretty-print debug output]' \
  '--debug-nocolor[disable colored output]' \
  '--metrics-server-addr=[metrics listener address]:addr:' \
  '--prometheus-auth-token=[Prometheus auth token]:token:' \
  '--prometheus-auth-token-file=[Prometheus auth token file]:file:_files' \
  '--default-allow-pull-requests[allow PRs by default]' \
  '--default-approval-mode=[default approval mode]:mode:(none forks pull_requests all_events)' \
  '--default-cancel-previous-pipeline-events=[events that cancel previous pipelines]:events:' \
  '--default-clone-plugin=[default clone plugin image]:image:' \
  '--default-workflow-labels=[default workflow label conditions]:labels:' \
  '--default-pipeline-timeout=[default pipeline timeout]:duration:' \
  '--max-pipeline-timeout=[maximum pipeline timeout]:duration:' \
  '--plugins-privileged=[images allowed privileged mode]:images:' \
  '--plugins-trusted-clone=[images allowed git creds]:images:' \
  '--docker-config=[Docker registry config path]:path:_files' \
  '--status-context=[SCM status context prefix]:context:' \
  '--status-context-format=[SCM status context Go template]:template:' \
  '--config-extension-endpoint=[config extension URL]:url:' \
  '--secret-extension-endpoint=[secret extension URL]:url:' \
  '--registry-extension-endpoint=[registry extension URL]:url:' \
  '--config-extension-exclusive[skip forge requests for config]' \
  '--extensions-allowed-hosts=[allowed extension hosts]:hosts:(loopback private external "*")' \
  '--forge-timeout=[forge fetch timeout]:duration:' \
  '--forge-retry=[forge fetch retries]:n:' \
  '--custom-css-file=[custom CSS file]:file:_files' \
  '--custom-js-file=[custom JS file]:file:_files' \
  '--environment=[global env vars (var1:val1,var2:val2)]:list:' \
  '--keepalive-min-time=[server keepalive policy]:duration:' \
  '--enable-swagger[enable Swagger API UI]' \
  '--disable-version-check[disable version check]' && ret=0
return ret
