#compdef zbarcam

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[do not display symbol data]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(--xml)--xml[print results as XML]' \
  '(--nodisplay)--nodisplay[do not display window]' \
  '(--display)--display[display window (default)]' \
  '(--prescale)--prescale=+[prescale image WxH]:size:' \
  '(--raw)--raw[print raw symbol data]' \
  '(--nodbus)--nodbus[disable D-Bus interface]' \
  '*:device:_files -g "/dev/video*"' && ret=0

return ret
