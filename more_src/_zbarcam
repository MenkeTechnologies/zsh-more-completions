#compdef zbarcam
# Documentation: https://manpages.debian.org/testing/zbar-tools/zbarcam.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus --display flag and --nodbus (not in
# Debian manpage).
# Added verified: -S/--set symbology configuration.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[disable audible beep on detection]' \
  '(-v --verbose)'{-v,--verbose}'[increase debug output level]' \
  '--xml[use XML output format]' \
  '--nodisplay[disable video window output]' \
  '--prescale=[request video input scaling WxH]:size:' \
  '--raw[use raw symbol data format]' \
  '*'{-S+,--set=}'[configure decoder option]:config:' \
  '*:device:_files -g "/dev/video*"' && ret=0

return ret
