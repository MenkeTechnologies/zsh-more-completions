#compdef crl_app

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'filename=:CRL file'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'filename='; then
      _files -g "*.(pem|crl)" && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
