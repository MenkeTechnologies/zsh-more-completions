#compdef uv-pip
# _uv-pip — uv pip interface (astral-sh/uv)
# upstream: https://github.com/astral-sh/uv

_uv_pip() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_uv_pip_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                install)
                    _arguments \
                        '(-r --requirement)'{-r,--requirement}'=[requirements file]:file:_files' \
                        '(-c --constraint)'{-c,--constraint}'=[constraint file]:file:_files' \
                        '--override=[override file]:file:_files' \
                        '(-e --editable)'{-e,--editable}'=[editable install]:path:_files -/' \
                        '--extra=[extra to install]:extra:' \
                        '--all-extras[install all extras]' \
                        '--no-deps[skip dependencies]' \
                        '--python=[Python interpreter]:python:_files' \
                        '--system[install to system Python]' \
                        '--break-system-packages[allow breaking system packages]' \
                        '--target=[install target directory]:dir:_files -/' \
                        '--prefix=[install prefix]:dir:_files -/' \
                        '--index-url=[package index URL]:url:' \
                        '--extra-index-url=[extra index URL]:url:' \
                        '--no-index[ignore package index]' \
                        '--reinstall[reinstall packages]' \
                        '--upgrade[upgrade packages]' \
                        '--compile-bytecode[compile .pyc files]' \
                        '--no-compile-bytecode[skip .pyc compilation]' \
                        '--link-mode=[link mode]:mode:(clone copy hardlink symlink)' \
                        '--quiet[quiet output]' \
                        '--verbose[verbose output]' \
                        '--help[show help]' \
                        '*:package:' && ret=0 ;;
                uninstall)
                    _arguments \
                        '(-r --requirement)'{-r,--requirement}'=[requirements file]:file:_files' \
                        '--python=[Python interpreter]:python:_files' \
                        '--system[use system Python]' \
                        '--break-system-packages[allow breaking system packages]' \
                        '--help[show help]' \
                        '*:package:' && ret=0 ;;
                freeze|list|check|show)
                    _arguments \
                        '--python=[Python interpreter]:python:_files' \
                        '--system[use system Python]' \
                        '--help[show help]' \
                        '*:package:' && ret=0 ;;
                compile)
                    _arguments \
                        '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
                        '--extra=[extra to include]:extra:' \
                        '--all-extras[include all extras]' \
                        '--python=[Python interpreter]:python:_files' \
                        '--system[use system Python]' \
                        '--help[show help]' \
                        '*:requirements file:_files' && ret=0 ;;
                sync)
                    _arguments \
                        '--python=[Python interpreter]:python:_files' \
                        '--system[use system Python]' \
                        '--help[show help]' \
                        '*:requirements file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_uv_pip_commands] )) ||
_uv_pip_commands() {
    local -a commands
    commands=(
        'install:install packages'
        'uninstall:uninstall packages'
        'freeze:list installed packages in requirements format'
        'list:list installed packages'
        'check:verify installed packages'
        'show:show package information'
        'compile:compile requirements'
        'sync:sync environment with requirements'
    )
    _describe -t commands 'uv pip command' commands
}

_uv_pip "$@"
