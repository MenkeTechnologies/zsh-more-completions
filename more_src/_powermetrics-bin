#compdef powermetrics
# _powermetrics-bin — macOS power consumption / power efficiency reporting (Apple); reads CPU/GPU/ANE power data from kext IOReport
# upstream: macOS

_powermetrics-bin() {
    _arguments \
        '-h[show help]' \
        '-a+[output format]:fmt:(text plist json)' \
        '-i+[sample interval ms]:ms:' \
        '-n+[sample count]:n:' \
        '-r[show running tasks]' \
        '-o+[output file]:file:_files' \
        '-u+[buffer size kbytes]:n:' \
        '--samplers+[sampler list]:samplers:(all cpu_power gpu_power ane_power thermal smc battery interrupts disk network gpu_drv ufs cpufreqstats cluster_freq disk_io_stats network_io_stats)' \
        '--show-process-coalition[show coalitions]' \
        '--show-process-energy[show energy impact]' \
        '--show-process-gpu[show GPU per-process]' \
        '--show-process-io[show I/O per-process]' \
        '--show-process-netstats[show network per-process]' \
        '--show-process-samp-norm[normalize sample count]' \
        '--show-process-wait-times[show wait times]' \
        '--show-pstates[show pstates]' \
        '--show-cpu-qos[show QoS info]' \
        '--show-cpu-scalability[show cpu scaling]' \
        '--show-cpu-instrs[show cpu instrs (DCS)]' \
        '--show-extra-power-info[extra power info]' \
        '--show-hg-stats[show hgr stats]' \
        '--show-ioreport[show IOReport keys]' \
        '--show-plimits[show plimits]' \
        '--show-rpmu[show RPMu data]' \
        '--show-smc-stats[show smc stats]' \
        '--show-thermal-pressure[show thermal pressure]' \
        '--show-usage-summary[show usage summary]' \
        '--show-all[show everything]' \
        '--enable-action-mode[enable action mode]' \
        '--unhide-info+[unhide info]:str:'
}

_powermetrics-bin "$@"
