#compdef sustkvel
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/data_conversion/sustkvel.c
# convert interval velocity model to stacking velocity model

local ret=1

_arguments -s -S \
  'v=[interval velocities]:v' \
  'h=[layer thicknesses at the cmp]:h' \
  'dip=[constant dip of the layers (degrees)]:dip' \
  'outpar=[output parameter file for sunmo]:file:_files' \
  '*:file:_files' && ret=0


return ret
