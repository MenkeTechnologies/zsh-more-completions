#compdef calibre
# Documentation: https://man.archlinux.org/search?q=calibre
# Reference accessed: 2026-05-16

# completions for calibre e-book management launcher

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '--with-library=[open with specified library]:library path:_directories'
  '--start-in-tray[start minimized to system tray]'
  '-v[verbose logging]'
  '--verbose[verbose logging]'
  '--no-update-check[do not check for updates on startup]'
  '--ignore-plugins[ignore third-party plugins]'
  '--shutdown-running-calibre[shutdown any running calibre instances]'
  '*:file:_files'
)

_arguments -s -S $arguments
