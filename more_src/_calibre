#compdef calibre
# Documentation: https://manual.calibre-ebook.com/generated/en/calibre.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# completions for calibre e-book management launcher

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '--with-library=[use the library located at the specified path]:library path:_directories'
  '--start-in-tray[start minimized to system tray]'
  '(-v --verbose)'{-v,--verbose}'[legacy verbose option (ignored in current versions)]'
  '--no-update-check[do not check for updates on startup]'
  '--ignore-plugins[ignore custom plugins]'
  '(-s --shutdown-running-calibre)'{-s,--shutdown-running-calibre}'[shutdown any running calibre instance]'
  '--detach[detach from controlling terminal (Linux only)]'
  '*:file:_files'
)

_arguments -s -S $arguments
