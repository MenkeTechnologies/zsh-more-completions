#compdef scott

# scott: Scott Adams adventure game interpreter
# Documentation: https://www.iflarchive.org/if-archive/scott-adams/scottfree/
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug]' \
  '-w[wait mode]' \
  '-t[TRS-80 mode]' \
  '-s[Scott mode]' \
  '*:story file:_files -g "*.dat"' && ret=0
return ret
