#compdef scott scottfree
# Documentation: https://manpages.debian.org/testing/scottfree/scottfree.6.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# scott / scottfree: Scott Adams adventure game interpreter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[debugging info on load]' \
  '-i[generate "I am"-style messages (default)]' \
  '-y[generate "You are"-style messages]' \
  '-s[generate authentic Scott Adams driver light messages]' \
  '-t[generate TRS-80 style display]' \
  '*:story file:_files -g "*.dat"' && ret=0
return ret
