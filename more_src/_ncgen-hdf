#compdef ncgen-hdf
# Documentation: https://docs.unidata.ucar.edu/netcdf-c/current/netcdf_utilities_guide.html
# HDF4 build of ncgen: generate a netCDF/HDF file or source from CDL

local ret=1

_arguments -s -S \
  '-b[create a binary netCDF file]' \
  '-o+[name of the output netCDF file (implies -b)]:output file:_files' \
  '-c[generate C source code that creates the file]' \
  '-f[generate FORTRAN 77 source code that creates the file]' \
  '-k+[format of the file to create]:format:(classic 64-bit-offset cdf5 netCDF-4 netCDF-4-classic)' \
  '-x[do not initialize data with fill values]' \
  '-l+[output language for generated source]:lang:(c f77 java)' \
  '-n[generate code from netCDF spec]' \
  '-d[set debug output level to 1]' \
  '1:cdl file:_files -g "*.(cdl|nc)"' && ret=0

return ret
