#compdef thumper
# Documentation: https://man.archlinux.org/search?q=thumper
# Reference accessed: 2026-05-16
# Source: cargo binstall thumper@0.2.2
# Probed via: completions --shell zsh
# Repository: https://github.com/kaaveland/thumper.git

autoload -U is-at-least

_thumper() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_thumper_commands" \
"*::: :->thumper" \
&& ret=0
    case $state in
    (thumper)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:thumper-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
'-e+[Which bunny cdn endpoint to use]:ENDPOINT:_default' \
'--endpoint=[Which bunny cdn endpoint to use]:ENDPOINT:_default' \
'-a+[Password for the storage zone - looked up in environment variable THUMPER_KEY if not present]:ACCESS_KEY:_default' \
'--access-key=[Password for the storage zone - looked up in environment variable THUMPER_KEY if not present]:ACCESS_KEY:_default' \
'-p+[Path inside the storage zone to sync to, path to a directory]:PATH:_default' \
'--path=[Path inside the storage zone to sync to, path to a directory]:PATH:_default' \
'--lockfile=[Filename to use for the lockfile. thumper will not sync if this file exists in the destination]:LOCKFILE:_default' \
'*-i+[Do not delete anything in the storage zone paths that start with this prefix (can pass multiple times)]:IGNORE:_default' \
'*--ignore=[Do not delete anything in the storage zone paths that start with this prefix (can pass multiple times)]:IGNORE:_default' \
'-c+[Number of threads to use when calling bunny.net API (default to number of cpus)]:CONCURRENCY:_default' \
'--concurrency=[Number of threads to use when calling bunny.net API (default to number of cpus)]:CONCURRENCY:_default' \
'--dry-run[Don'\''t sync, just show what would change]' \
'-f[Force a sync despite a hanging lock file]' \
'--force[Force a sync despite a hanging lock file]' \
'-v[]' \
'--verbose[]' \
'-h[Print help]' \
'--help[Print help]' \
':local_path -- Local directory to put in the storage zone:_default' \
':storage_zone -- Which storage zone to sync to:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-s+[]:SHELL:(bash zsh fish pwsh powershell)' \
'--shell=[]:SHELL:(bash zsh fish pwsh powershell)' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(purge-url)
_arguments "${_arguments_options[@]}" : \
'-a+[API key for bunny CDN --  looked up in environment variable THUMPER_API_KEY if not present]:API_KEY:_default' \
'--api-key=[API key for bunny CDN --  looked up in environment variable THUMPER_API_KEY if not present]:API_KEY:_default' \
'-h[Print help]' \
'--help[Print help]' \
':url -- URL to purge, wildcard * is allowed at the end:_default' \
&& ret=0
;;
(purge-zone)
_arguments "${_arguments_options[@]}" : \
'-a+[API key for bunny CDN --  looked up in environment variable THUMPER_API_KEY if not present]:API_KEY:_default' \
'--api-key=[API key for bunny CDN --  looked up in environment variable THUMPER_API_KEY if not present]:API_KEY:_default' \
'-c+[Optional Cache Tag to target]:CACHE_TAG:_default' \
'--cache-tag=[Optional Cache Tag to target]:CACHE_TAG:_default' \
'-h[Print help]' \
'--help[Print help]' \
':pullzone -- Numeric ID of pull zone to purge:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_thumper__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:thumper-help-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(purge-url)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(purge-zone)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_thumper_commands] )) ||
_thumper_commands() {
    local commands; commands=(
'sync:Sync a local folder to a path within a bunny.net Storage Zone' \
'completions:Provide shell completions' \
'purge-url:Purge a URL from the bunny.net cache' \
'purge-zone:Purge an entire pull zone from bunny.net cache' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'thumper commands' commands "$@"
}
(( $+functions[_thumper__completions_commands] )) ||
_thumper__completions_commands() {
    local commands; commands=()
    _describe -t commands 'thumper completions commands' commands "$@"
}
(( $+functions[_thumper__help_commands] )) ||
_thumper__help_commands() {
    local commands; commands=(
'sync:Sync a local folder to a path within a bunny.net Storage Zone' \
'completions:Provide shell completions' \
'purge-url:Purge a URL from the bunny.net cache' \
'purge-zone:Purge an entire pull zone from bunny.net cache' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'thumper help commands' commands "$@"
}
(( $+functions[_thumper__help__completions_commands] )) ||
_thumper__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'thumper help completions commands' commands "$@"
}
(( $+functions[_thumper__help__help_commands] )) ||
_thumper__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'thumper help help commands' commands "$@"
}
(( $+functions[_thumper__help__purge-url_commands] )) ||
_thumper__help__purge-url_commands() {
    local commands; commands=()
    _describe -t commands 'thumper help purge-url commands' commands "$@"
}
(( $+functions[_thumper__help__purge-zone_commands] )) ||
_thumper__help__purge-zone_commands() {
    local commands; commands=()
    _describe -t commands 'thumper help purge-zone commands' commands "$@"
}
(( $+functions[_thumper__help__sync_commands] )) ||
_thumper__help__sync_commands() {
    local commands; commands=()
    _describe -t commands 'thumper help sync commands' commands "$@"
}
(( $+functions[_thumper__purge-url_commands] )) ||
_thumper__purge-url_commands() {
    local commands; commands=()
    _describe -t commands 'thumper purge-url commands' commands "$@"
}
(( $+functions[_thumper__purge-zone_commands] )) ||
_thumper__purge-zone_commands() {
    local commands; commands=()
    _describe -t commands 'thumper purge-zone commands' commands "$@"
}
(( $+functions[_thumper__sync_commands] )) ||
_thumper__sync_commands() {
    local commands; commands=()
    _describe -t commands 'thumper sync commands' commands "$@"
}

if [ "$funcstack[1]" = "_thumper" ]; then
    _thumper "$@"
else
    compdef _thumper thumper
fi
