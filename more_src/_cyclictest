#compdef cyclictest

# Zsh completion for cyclictest - real-time latency testing

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --affinity)'{-a,--affinity}'[set CPU affinity]:CPU list' \
  '--aligned=[align thread wakeups]:offset_us' \
  '(-b --breaktrace)'{-b,--breaktrace}'[send break trace when latency exceeds value]:latency_us' \
  '(-c --clock)'{-c,--clock}'[select clock]:clock:(0 1)' \
  '(-d --distance)'{-d,--distance}'[distance of thread intervals]:distance_us' \
  '(-D --duration)'{-D,--duration}'[test duration]:duration' \
  '--latency=[write PM QoS latency value]:latency_us' \
  '(-i --interval)'{-i,--interval}'[base interval of thread]:interval_us' \
  '(-l --loops)'{-l,--loops}'[number of loops]:loops' \
  '(-m --mlockall)'{-m,--mlockall}'[lock current and future memory]' \
  '(-M --refresh_on_max)'{-M,--refresh_on_max}'[delay updating max latency until a new max is hit]' \
  '(-n --nanosleep)'{-n,--nanosleep}'[use clock_nanosleep]' \
  '(-N --nsecs)'{-N,--nsecs}'[print results in nanoseconds]' \
  '(-o --oscope)'{-o,--oscope}'[oscilloscope mode]:trigger_value' \
  '(-p --priority)'{-p,--priority}'[priority of highest priority thread]:priority' \
  '(-q --quiet)'{-q,--quiet}'[only print summary]' \
  '(-r --relative)'{-r,--relative}'[use relative timer instead of absolute]' \
  '(-s --system)'{-s,--system}'[use sys_nanosleep and sys_setitimer]' \
  '(-S --smp)'{-S,--smp}'[set standard options for SMP testing]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:count' \
  '(-T --tracer)'{-T,--tracer}'[set tracer]:tracer:(hwlat irqsoff preemptoff preemptirqsoff wakeup wakeup_rt)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --wakeup)'{-w,--wakeup}'[task wakeup tracing]' \
  '(-W --wakeuprt)'{-W,--wakeuprt}'[RT task wakeup tracing]' \
  '--dbg_cyclictest[enable internal debugging]' \
  '--policy=[scheduling policy]:policy:(other normal batch idle fifo rr)' \
  '--secaligned=[align thread wakeups to full second]:offset_us' \
  '--spike=[record spikes over threshold]:threshold_us' \
  '--spike-nodes=[maximum recorded spikes]:count' \
  '--histogram=[dump latency histogram to stdout]:histogram_size' \
  '(-H --histofall)'{-H,--histofall}'[dump histogram for all threads]:histogram_size' \
  '--histfile=[dump histogram to file]:file:_files'
