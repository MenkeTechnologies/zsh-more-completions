#compdef deepsecrets
# Documentation: https://github.com/ntoskernel/deepsecrets
# deepsecrets secrets scanner that understands code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--target-dir[directory path to scan for secrets]:dir:_files -/' \
  '--outformat[set output format]:format:(json dojo-sarif)' \
  '--outfile[output file path for the report]:file:_files' \
  '--regex-rules[supply a custom regex ruleset]:file:_files' \
  '--hashed-values[list of pre-hashed known production secrets]:file:_files' \
  '--excluded-paths[override or extend default ignored paths]:file:_files' \
  '--disable-masking[keep potential secrets unmasked in the output report]' && ret=0

return ret
