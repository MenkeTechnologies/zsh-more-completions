#compdef sakura
# Documentation: https://man.archlinux.org/man/sakura.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-? --help)'{-\?,--help}'[show help]' \
  '--help-all[show all help]' \
  '--help-gtk[show GTK help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --font)'{-f,--font}'=[font]:font:' \
  '(-n --ntabs)'{-n,--ntabs}'=[tabs]:n:' \
  '(-x --execute)'{-x,--execute}'=[command]:cmd:' \
  '(-e --xterm-execute)'{-e,--xterm-execute}'=[command]:cmd:' \
  '(-l --login)'{-l,--login}'[login shell]' \
  '(-c --columns)'{-c,--columns}'=[cols]:n:' \
  '(-r --rows)'{-r,--rows}'=[rows]:n:' \
  '(-h --hold)'{-h,--hold}'[hold open]' \
  '(-d --working-directory)'{-d,--working-directory}'=[dir]:dir:_files -/' \
  '(-m --maximize)'{-m,--maximize}'[maximize]' \
  '(-s --fullscreen)'{-s,--fullscreen}'[fullscreen]' \
  '--display=[display]:display:' \
  '--config-file=[config file]:file:_files' \
  '--class=[WM class]:class:' \
  '--name=[WM name]:name:' \
  '--screen=[screen]:screen:' \
  '--sync[synchronous]' \
  '--gtk-module=[modules]:modules:' \
  '--g-fatal-warnings[fatal warnings]'
