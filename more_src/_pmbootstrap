#compdef pmbootstrap

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize or update the pmbootstrap configuration'
  'shutdown:umount, unregister binfmt and stop running chroots'
  'work_migrate:migrate or set up the work folder'
  'log:follow the pmbootstrap log'
  'zap:safely delete chroot folders'
  'stats:show useful stats about the builds'
  'update:check for updates'
  'build:build a package for a specific architecture'
  'build_init:initialize the build environment'
  'checksum:update the checksums in an APKBUILD'
  'newapkbuild:generate a template for a new package'
  'aportgen:generate or update aports for cross-compilation'
  'chroot:start a shell in a chroot'
  'install:compile everything and create a flashable file'
  'export:copy a file from the work folder'
  'flasher:flash a kernel or rootfs to the device'
  'sideload:push a package to a running phone'
  'config:set or get a configuration option'
  'pull:update all existing git repos'
  'kconfig:kernel config helpers'
  'apkindex_parse:parse an APKINDEX file'
  'pkgrel_bump:bump the pkgrel of a package'
  'aportupgrade:upgrade an aport to a newer version'
  'lint:run quality checks on an APKBUILD file'
  'status:overview of the pmbootstrap status'
  'ci:run CI scripts locally'
  'bootimg_analyze:analyze a boot.img file'
  'netboot:launch a netboot server for the device'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[show program version]' \
  '(-c --config)'{-c,--config}'[path to config file]:config file:_files' \
  '(-d --details-to-stdout)'{-d,--details-to-stdout}'[print details to stdout]' \
  '(-j --jobs)'{-j,--jobs}'[parallel jobs count]:jobs:' \
  '(-m --mirror-pmOS)'{-m,--mirror-pmOS}'[postmarketOS mirror]:mirror URL:' \
  '(-mp --mirror-alpine)'{-mp,--mirror-alpine}'[Alpine Linux mirror]:mirror URL:' \
  '(-p --aports)'{-p,--aports}'[custom aports folder]:aports dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[do not output any log messages]' \
  '(-t --timeout)'{-t,--timeout}'[seconds after which processes are killed]:seconds:' \
  '(-v --verbose)'{-v,--verbose}'[write even more to the log]' \
  '(-w --work)'{-w,--work}'[folder where all data is stored]:work dir:_files -/' \
  '(-y --assume-yes)'{-y,--assume-yes}'[answer yes to all questions]' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'pmbootstrap command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (zap)
        _arguments \
          '(-hc --http)'{-hc,--http}'[also delete HTTP cache]' \
          '(-d --distfiles)'{-d,--distfiles}'[also delete downloaded source tarballs]' \
          '(-p --pkgs-local)'{-p,--pkgs-local}'[also delete locally compiled packages]' \
          '(-m --pkgs-local-mismatch)'{-m,--pkgs-local-mismatch}'[also delete packages with version mismatch]' \
          '(-o --pkgs-online-mismatch)'{-o,--pkgs-online-mismatch}'[also delete outdated online packages]' \
          '(-r --rust)'{-r,--rust}'[also delete Rust related caches]' \
          && ret=0
        ;;
      (build)
        _arguments \
          '(-a --arch)'{-a,--arch}'[target architecture]:arch:(x86_64 x86 aarch64 armhf armv7)' \
          '(-f --force)'{-f,--force}'[force rebuild even if already built]' \
          '(-i --ignore-depends)'{-i,--ignore-depends}'[only build the package, ignore dependencies]' \
          '(-n --no-depends)'{-n,--no-depends}'[do not build or install dependencies]' \
          '--src[override source package path]:source dir:_files -/' \
          '*:package name:' \
          && ret=0
        ;;
      (install)
        _arguments \
          '--sdcard[install to SD card device]:device:_files' \
          '--cipher[cipher for full disk encryption]:cipher:' \
          '--disk[install to target disk device]:device:_files' \
          '--fde[enable full disk encryption]' \
          '--flavor[kernel flavor]:flavor:' \
          '--no-fde[disable full disk encryption]' \
          '--recovery-install-partition[install a recovery OS]:partition:' \
          '--rsync[use rsync to copy rootfs]' \
          '--split[flash split image]' \
          && ret=0
        ;;
      (chroot)
        _arguments \
          '--add[install additional packages]:packages:' \
          '(-b --build)'{-b,--build}'[use the build chroot]' \
          '(-r --root)'{-r,--root}'[use the rootfs chroot]' \
          '(-i --install)'{-i,--install}'[use the install chroot]' \
          '--user[run as user instead of root]' \
          '*:command:' \
          && ret=0
        ;;
      (config)
        _arguments \
          '1:option:(device work aports jobs boot_size_default extra_space hostname ssh_keys timezone ui)' \
          '2::value:' \
          && ret=0
        ;;
      (flasher)
        _arguments \
          '1:action:(flash_rootfs flash_kernel flash_lk2nd list_flavors list_devices sideload boot)' \
          '--flash-method[override flash method]:method:(fastboot heimdall 0xffff)' \
          && ret=0
        ;;
      (kconfig)
        _arguments \
          '1:action:(check edit)' \
          '*:package name:' \
          && ret=0
        ;;
      (log)
        _arguments \
          '(-l --lines)'{-l,--lines}'[number of initial lines to print]:lines:' \
          '(-c --clear)'{-c,--clear}'[clear the log before tailing]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
