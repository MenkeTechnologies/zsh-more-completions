#compdef frida-compile
# Documentation: https://github.com/frida/frida-tools/blob/main/frida_tools/compiler.py
# Compile a TypeScript/JavaScript Frida agent to a single bundle

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[output version information and exit]' \
  '-o+[write output to file]:output file:_files' \
  '--output=[write output to file]:output file:_files' \
  '(-w --watch)'{-w,--watch}'[watch for changes and recompile]' \
  '(-S --no-source-maps)'{-S,--no-source-maps}'[omit source-maps]' \
  '(-c --compress)'{-c,--compress}'[minify code]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-F --output-format)'{-F,--output-format}'=[desired output format]:format:(unescaped hex-bytes c-string)' \
  '(-B --bundle-format)'{-B,--bundle-format}'=[desired bundle format]:format:(esm iife)' \
  '(-T --type-check)'{-T,--type-check}'=[desired type-checking mode]:mode:(full none)' \
  '(-P --platform)'{-P,--platform}'=[JavaScript runtime platform]:platform:(gum browser neutral)' \
  '*'{-E,--external}'=[mark MODULE as external]:module' \
  '1:module:_files' && ret=0

return ret
