#compdef pre-commit

# Zsh completion for pre-commit (git pre-commit hook framework)

_pre-commit() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a global_flags=(
        '(-c --config)'{-c,--config}'=[path to alternate config file]:config file:_files'
        '(-h --help)'{-h,--help}'[show help message]'
        '(-V --version)'{-V,--version}'[show version]'
    )

    local -a commands=(
        'autoupdate:auto-update pre-commit config to the latest repos versions'
        'clean:clean out cached pre-commit files'
        'gc:clean unused cached repos'
        'init-templatedir:install hook script in a directory intended for use with git init --template-dir'
        'install:install the pre-commit script'
        'install-hooks:install hook environments for all hooks'
        'migrate-config:migrate list configuration to new map configuration'
        'run:run hooks'
        'sample-config:produce a sample .pre-commit-config.yaml file'
        'try-repo:try the hooks in a repository'
        'uninstall:uninstall the pre-commit script'
        'validate-config:validate .pre-commit-config.yaml files'
        'validate-manifest:validate .pre-commit-hooks.yaml files'
        'help:show help for a particular command'
    )

    _arguments -C \
        $global_flags \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'pre-commit command' commands
            ;;
        args)
            case $words[1] in
                run)
                    _arguments -s -S \
                        $global_flags \
                        '(-a --all-files)'{-a,--all-files}'[run on all files in the repo]' \
                        '*--files=[specific filenames to run hooks on]:file:_files' \
                        '--from-ref=[ref to check against]:ref:' \
                        '--to-ref=[ref to check]:ref:' \
                        '--hook-stage=[choose the stage to run]:stage:(pre-commit pre-merge-commit pre-push prepare-commit-msg commit-msg post-checkout post-commit post-merge post-rewrite manual)' \
                        '--show-diff-on-failure[when hooks fail, run git diff to show changes]' \
                        '(-v --verbose)'{-v,--verbose}'[produce hook output independent of success]' \
                        '--color=[whether to use color]:color:(always auto never)' \
                        '--no-stash[skip stashing of unstaged files]' \
                        '1:hook id:'
                    ;;
                install)
                    _arguments -s -S \
                        $global_flags \
                        '(-f --overwrite)'{-f,--overwrite}'[overwrite existing hooks]' \
                        '(-t --hook-type)'{-t,--hook-type}'=[which hook type to install]:hook type:(pre-commit pre-merge-commit pre-push prepare-commit-msg commit-msg post-checkout post-commit post-merge post-rewrite)' \
                        '--install-hooks[install hook environments for all hooks]' \
                        '--allow-missing-config[allow hook scripts to run when config file is not present]'
                    ;;
                uninstall)
                    _arguments -s -S \
                        $global_flags \
                        '(-t --hook-type)'{-t,--hook-type}'=[which hook type to uninstall]:hook type:(pre-commit pre-merge-commit pre-push prepare-commit-msg commit-msg post-checkout post-commit post-merge post-rewrite)'
                    ;;
                autoupdate)
                    _arguments -s -S \
                        $global_flags \
                        '--bleeding-edge[update to the bleeding edge of the default branch]' \
                        '--freeze[store frozen hashes in rev instead of tag names]' \
                        '*--repo=[only update this repository]:repo:' \
                        '(-j --jobs)'{-j,--jobs}'=[number of parallel jobs]:jobs:'
                    ;;
                init-templatedir)
                    _arguments -s -S \
                        $global_flags \
                        '(-t --hook-type)'{-t,--hook-type}'=[which hook type to install]:hook type:(pre-commit pre-merge-commit pre-push prepare-commit-msg commit-msg post-checkout post-commit post-merge post-rewrite)' \
                        '--no-allow-missing-config[assume config file always exists]' \
                        '1:directory:_directories'
                    ;;
                try-repo)
                    _arguments -s -S \
                        $global_flags \
                        '--ref=[manually select a ref to run against]:ref:' \
                        '(-a --all-files)'{-a,--all-files}'[run on all files in the repo]' \
                        '*--files=[specific filenames to run hooks on]:file:_files' \
                        '--verbose[produce hook output independent of success]' \
                        '1:repository:'
                    ;;
                clean)
                    _arguments -s -S $global_flags
                    ;;
                gc)
                    _arguments -s -S $global_flags
                    ;;
                validate-config)
                    _arguments -s -S \
                        $global_flags \
                        '*:config file:_files'
                    ;;
                validate-manifest)
                    _arguments -s -S \
                        $global_flags \
                        '*:manifest file:_files'
                    ;;
                help)
                    _arguments -s -S \
                        '1:command:(autoupdate clean gc init-templatedir install install-hooks migrate-config run sample-config try-repo uninstall validate-config validate-manifest)'
                    ;;
                sample-config|migrate-config|install-hooks)
                    _arguments -s -S $global_flags
                    ;;
            esac
            ;;
    esac
}

_pre-commit "$@"
