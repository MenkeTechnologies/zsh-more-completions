#compdef percona-postgresql-operator
# _percona-postgresql-operator — Percona PostgreSQL operator (fork of Crunchy PGO; reconciles PerconaPGCluster + PerconaPGBackup/Restore/Upgrade CRs)
# upstream: https://github.com/percona/percona-postgresql-operator
# Source: cmd/postgres-operator/main.go on tip; no CLI flags — runtime config is env-driven (CRUNCHY_DEBUG, PGO_CONTROLLER_LEASE_NAME, PGO_NAMESPACE, PGO_TARGET_NAMESPACE, PGO_TARGET_NAMESPACES, PGO_WORKERS, PGO_FEATURE_GATES, DISABLE_TELEMETRY, OTEL_*).

_percona-postgresql-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_percona-postgresql-operator "$@"
