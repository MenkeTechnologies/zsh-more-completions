#compdef zotero-cli
# _zotero-cli — Bewotero zotero-cli CLI command-line interface to Zotero reference-manager library querying searching listing tagging attachments adding collections exports through the Zotero local API server BetterBibTeX integration JSON CSL bibliography file-attachment metadata enrichment for citation-driven workflows (zotero-cli team, Python); custom argparse
# upstream: https://github.com/seblissajou/zotero-cli

_zotero-cli() {
    local -a sub=(
        'list:list library entries'
        'search:search the library'
        'get:fetch single entry'
        'add:add a new entry'
        'remove:remove an entry'
        'tag:tag entries'
        'untag:remove tag from entries'
        'attach:attach a file to an entry'
        'sync:sync with Zotero server'
        'export:export bibliography'
        'collections:list collections'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--user-id=+[id]:str:' \
        '--library=+[library]:str:' \
        '--local[use local API server]' \
        '--port=+[port]:n:' \
        '-f+[format]:f:(json csv yaml bibtex biblatex csljson)' \
        '--format=+[format]:f:(json csv yaml bibtex biblatex csljson)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zotero-cli subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments '*:query:' ;;
                get|remove|tag|untag|attach) _arguments '1:key:' '*:tag-or-file:_files' ;;
                add) _arguments '*:file:_files -g "*.pdf *.bib *.ris *.enw *.json"' ;;
                export) _arguments '1:format:(bibtex biblatex csljson ris endnote-tagged endnote-xml mods rdf_bibliontology rdf_dc rdf_zotero refer wikipedia tei)' \
                                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_zotero-cli "$@"
