#compdef stellarium
# Documentation: https://man.archlinux.org/search?q=stellarium
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config-file)'{-c,--config-file}'+[config file]:file:_files' \
  '(-d --user-dir)'{-d,--user-dir}'+[user directory]:dir:_files -/' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-l --landscape)'{-l,--landscape}'+[landscape]:name:' \
  '(-s --startup-script)'{-s,--startup-script}'+[startup script]:file:_files -g "*.ssc"' \
  '(-S --safe-mode)'{-S,--safe-mode}'[safe mode]' \
  '(-r --renderer)'{-r,--renderer}'+[renderer]:r:(opengl angle d3d)' \
  '--screenshot-dir=[screenshot dir]:dir:_files -/' \
  '--screen-w=[screen width]:px:' \
  '--screen-h=[screen height]:px:' \
  '--screen-x=[screen position x]:x:' \
  '--screen-y=[screen position y]:y:' \
  '--full-screen=[fullscreen]:flag:(yes no)' \
  '--restore-defaults[restore defaults]' \
  '--single-buffer[disable double buffering]' \
  '--multi-res=[multi-resolution support]:flag:(yes no)' \
  '--mouse-cursor-timeout=[mouse cursor timeout sec]:sec:' \
  '--language=[language ISO code]:iso:' \
  '--sky-language=[sky language ISO]:iso:' \
  '--low-graphics[low graphics]' \
  '--openGL-mode=[OpenGL mode]:mode:(es desktop)' \
  '--dump-opengl-details[dump OpenGL details]' && ret=0

return ret
