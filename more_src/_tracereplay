#compdef tracereplay
# Documentation: https://manpages.debian.org/testing/libtrace-tools/tracereplay.1.en.html
# replay a libtrace trace in trace time from one uri to another

local ret=1

_arguments -s -S \
  '(-b --broadcast)'{-b,--broadcast}'[change the 802.3 destination address to broadcast]' \
  '(-s --snaplength)'{-s+,--snaplength=}'[truncate packets to the specified length]:snaplength' \
  '(-f --filter)'{-f+,--filter=}'[apply a filter to the input uri]:filter string' \
  '*:uri:_files' && ret=0

return ret
