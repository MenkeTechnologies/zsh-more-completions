#compdef vast vastai
# _vast — Vast.ai vast CLI for the Vast.ai distributed GPU compute marketplace (vast-ai team, Python); argparse
# upstream: https://github.com/vast-ai/vast-python

_vast() {
    local -a sub=(
        'search:search offers'
        'show:show entity details'
        'create:create instance'
        'destroy:destroy instance'
        'destroy_instance:destroy instance'
        'stop:stop instance'
        'start:start instance'
        'reboot:reboot instance'
        'execute:execute command on instance'
        'launch:launch a new instance'
        'set:set property'
        'change:change instance'
        'attach:attach to instance'
        'logs:fetch instance logs'
        'label:label instance'
        'unlabel:unlabel instance'
        'copy:copy files'
        'cloud:cloud subcommands'
        'login:login'
        'logout:logout'
        'set-api-key:set API key'
        'set-server:set server'
        'invoice:invoice subcommands'
        'change-bid:change bid'
        'show-deposit:show deposit'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--api-key=+[API key]:str:' \
        '--url=+[API URL]:url:_urls' \
        '--raw[raw output]' \
        '--explain[explain query]' \
        '--retry=+[N]:n:' \
        '--no-progress-bar[no progress bar]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vast subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments '1:type:(offers instances ssh-keys)' ;;
                show) _arguments '1:type:(invoices instances offers machines billing user team ssh-key)' ;;
                create) _arguments \
                    '--price=+[bid price]:f:' \
                    '--disk=+[disk GB]:n:' \
                    '--image=+[docker image]:str:' \
                    '--ssh[use ssh]' \
                    '--direct[direct]' \
                    '--login=+[login user:pass]:str:' \
                    '--label=+[label]:str:' \
                    '--onstart-cmd=+[command]:str:' \
                    '--jupyter[install jupyter]' \
                    '--jupyter-dir=+[dir]:dir:_files -/' \
                    '--env=+[env vars]:str:' ;;
                execute) _arguments '*:instance id command:' ;;
                copy) _arguments '*:src dst:_files' ;;
                cloud) _arguments '1:cloud cmd:(list create connect destroy)' ;;
                invoice) _arguments '1:invoice cmd:(list show download)' ;;
            esac
            ;;
    esac
}

_vast "$@"
