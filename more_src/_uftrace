#compdef uftrace

_uftrace_commands() {
  local -a commands=(
    'record:Record function calls'
    'replay:Replay recorded trace'
    'report:Report trace statistics'
    'live:Run and show trace live'
    'info:Show trace info'
    'dump:Dump raw trace data'
    'recv:Receive trace data from network'
    'graph:Show function call graph'
    'script:Run a script on trace data'
    'tui:Interactive TUI for trace data'
  )
  _describe 'command' commands
}

_uftrace() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '--version[Print version]' \
    '1:command:_uftrace_commands' \
    '*::arg:->args'

  case $state in
    args)
      local -a common_opts=(
        '(-F --filter)'{-F,--filter}'[Set function filter]:function:'
        '(-N --notrace)'{-N,--notrace}'[Do not trace function]:function:'
        '(-T --trigger)'{-T,--trigger}'[Set trigger on function]:trigger:'
        '(-t --time-filter)'{-t,--time-filter}'[Hide functions faster than]:time:'
        '(-D --depth)'{-D,--depth}'[Set max trace depth]:depth:'
        '(-d --data)'{-d,--data}'[Trace data directory]:dir:_directories'
        '--no-libcall[Do not trace library calls]'
        '--no-event[Do not record events]'
        '--match[Set function matching type]:type:(regex glob)'
      )
      case $line[1] in
        record)
          _arguments \
            $common_opts \
            '(-b --buffer)'{-b,--buffer}'[Set trace buffer size]:size:' \
            '--kernel[Trace kernel functions]' \
            '--host[Send data to host]:host:' \
            '--port[Network port]:port:' \
            '--nop[No operation recording]' \
            '--force[Force tracing]' \
            '--nest-libcall[Trace nested library calls]' \
            '*:command:_files'
          ;;
        replay|live)
          _arguments \
            $common_opts \
            '(-f --output-fields)'{-f,--output-fields}'[Set output fields]:fields:' \
            '--flat[Use flat output]' \
            '--column-view[Show in column view]' \
            '--column-offset[Column offset]:offset:' \
            '--no-merge[Do not merge threads]' \
            '--task-newline[Add newline between tasks]' \
            '*:command:_files'
          ;;
        report)
          _arguments \
            $common_opts \
            '-s+[Sort by field]:field:(total self call avg min max)' \
            '--avg-total[Show average total time]' \
            '--avg-self[Show average self time]' \
            '--task[Report per-task]' \
            '--diff[Diff with another trace]:dir:_directories'
          ;;
        graph)
          _arguments \
            $common_opts \
            '--task[Show task graph]' \
            '--format[Output format]:format:(normal json html)' \
            '1:function:'
          ;;
        dump)
          _arguments \
            '(-d --data)'{-d,--data}'[Trace data directory]:dir:_directories' \
            '--chrome[Dump in Chrome trace format]' \
            '--flame-graph[Dump in flame graph format]' \
            '--graphviz[Dump in Graphviz format]' \
            '--mermaid[Dump in Mermaid format]' \
            '--debug[Show debug info]' \
            '--sample-time[Sample time for flame graph]:time:'
          ;;
        info)
          _arguments \
            '(-d --data)'{-d,--data}'[Trace data directory]:dir:_directories' \
            '--task[Show task info]' \
            '--symbols[Show symbol info]'
          ;;
        script)
          _arguments \
            '(-d --data)'{-d,--data}'[Trace data directory]:dir:_directories' \
            '(-S --script)'{-S,--script}'[Script file to run]:script:_files' \
            '--record[Record before running script]'
          ;;
        tui)
          _arguments \
            $common_opts \
            '--report[Start in report mode]' \
            '--graph[Start in graph mode]'
          ;;
      esac
      ;;
  esac
}

_uftrace "$@"
