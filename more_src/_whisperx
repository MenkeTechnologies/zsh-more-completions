#compdef whisperx
# Documentation: https://github.com/m-bain/whisperX (whisperx/transcribe.py argparse)
# Reference accessed: 2026-05-29
# WhisperX: improved Whisper with word-level timestamps + diarization.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--model=[model identifier for ASR]:model:(tiny base small medium large large-v2 large-v3 turbo)' \
  '--batch_size=[processing batch size]:n:' \
  '--model_dir=[directory for model storage]:dir:_directories' \
  '--model_cache_only[use only cached models]' \
  '(-o --output_dir)'{-o,--output_dir=}'[directory for output files]:dir:_directories' \
  '(-f --output_format)'{-f,--output_format=}'[format for transcription output]:format:(txt vtt srt tsv json aud all)' \
  '--device=[compute device]:device:(cpu cuda mps)' \
  '--device_index=[device index for multi-GPU]:n:' \
  '--compute_type=[precision type for computation]:type:(float16 float32 int8)' \
  '--verbose=[print progress and debug messages]:bool:(True False)' \
  '--align_model=[alignment model]:model:' \
  '--interpolate_method=[interpolation method for alignment]:method:(nearest linear ignore)' \
  '--no_align[skip alignment step]' \
  '--task=[recognition or translation]:task:(transcribe translate)' \
  '--return_char_alignments[include character-level alignments]' \
  '--hf_token=[Hugging Face authentication token]:token:' \
  '--vad_method=[voice activity detection method]:method:(pyannote silero)' \
  '--vad_onset=[VAD onset threshold]:value:' \
  '--vad_offset=[VAD offset threshold]:value:' \
  '--chunk_size=[audio chunk size (seconds)]:seconds:' \
  '--diarize[enable speaker diarization]' \
  '--min_speakers=[minimum speaker count]:n:' \
  '--max_speakers=[maximum speaker count]:n:' \
  '--diarize_model=[diarization model]:model:' \
  '--print_progress[display progress indicators]' \
  '--speaker_embeddings[return speaker embeddings]' \
  '--language=[language code/name; None for auto-detection]:lang:' \
  '--temperature=[sampling temperature]:value:' \
  '--temperature_increment_on_fallback=[temperature fallback increment]:value:' \
  '--threads=[CPU inference threads]:n:' \
  '--beam_size=[beam search size]:n:' \
  '--patience=[beam search patience]:value:' \
  '--length_penalty=[token length penalty coefficient]:value:' \
  '--compression_ratio_threshold=[gzip ratio failure threshold]:value:' \
  '--logprob_threshold=[average log probability threshold]:value:' \
  '--no_speech_threshold=[no-speech token probability threshold]:value:' \
  '--initial_prompt=[prompt text for first window]:prompt:' \
  '--hotwords=[domain-specific hotwords]:words:' \
  '--suppress_tokens=[token IDs to suppress (comma-separated)]:ids:' \
  '--suppress_numerals[suppress numeral predictions]' \
  '--highlight_words[underline words in srt/vtt output]' \
  '--max_line_count=[max lines per subtitle]:n:' \
  '--max_line_width=[max chars per line]:n:' \
  '*:audio file:_files' && ret=0

return ret
