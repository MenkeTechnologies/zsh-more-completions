#compdef crash
# _crash-bin — Linux kernel crash dump analyzer (David Anderson, Red Hat); analyze /proc/vmcore and live kernels
# upstream: https://github.com/crash-utility/crash

_crash-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-d+[debug level]:n:' \
        '-i+[input commands file]:file:_files' \
        '-s[silent banner]' \
        '-S[mark live system]' \
        '-X[force xen mode]' \
        '-c+[config file]:file:_files' \
        '-mods+[modules dir]:dir:_files -/' \
        '-mod+[load module]:module:' \
        '-machdep+[machine-dependent option]:str:' \
        '--readonly[do not modify memory]' \
        '--mod-path+[module path]:path:_files -/' \
        '--osrelease+[print osrelease]:str:' \
        '--no_strip[do not strip whitespace]' \
        '--no_panic[do not require panic context]' \
        '--no_modules[skip module loading]' \
        '--xen-syms+[xen-syms]:file:_files' \
        '--xen-hyper[xen hyper mode]' \
        '*:vmlinux/dump:_files'
}

_crash-bin "$@"
