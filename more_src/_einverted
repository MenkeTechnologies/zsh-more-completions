#compdef einverted

# EMBOSS einverted: find inverted repeats in nucleotide sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-gap=[gap penalty]:penalty:' \
  '-threshold=[minimum score to report]:score:' \
  '-match=[match score]:score:' \
  '-mismatch=[mismatch score]:score:' \
  '-maxrepeat=[maximum repeat extent]:length:' \
  '-outfile=[report output file]:file:_files' \
  '-outseq=[matched sub-sequences output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
