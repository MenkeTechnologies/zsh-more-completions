#compdef einverted
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/einverted.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS einverted: find inverted repeats in nucleotide sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying]' \
  '-version[version]' \
  '-sequence=[nucleotide sequence(s) input USA]:DNA USA:_files' \
  '-gap=[gap penalty (default 12)]:penalty:' \
  '-threshold=[minimum score to report (default 50)]:score:' \
  '-match=[match score (default 3)]:score:' \
  '-mismatch=[mismatch score (default -4)]:score:' \
  '-maxrepeat=[maximum separation between repeats (default 2000)]:length:' \
  '-outfile=[Sanger Centre inverted output file]:file:_files' \
  '-outseq=[inverted repeat regions output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
