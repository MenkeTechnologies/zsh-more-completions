_couch() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_couch_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                auth)
                    _arguments \
                        '1:service:(realdebrid trakt telegram)' \
                        '*: :' && ret=0 ;;
                run)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_couch_commands] )) ||
_couch_commands() {
    local -a commands
    commands=(
        'run:run the application (long-lived media-acquisition daemon)'
        'auth:authenticate against an external service (realdebrid/trakt/telegram)'
    )
    _describe -t commands 'couch command' commands
}

_couch "$@"
