#compdef modbus_exporter
# ============================================================================
# _modbus_exporter — zsh completion for RichiH's Prometheus Modbus exporter
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/RichiH/modbus_exporter
#   Author     : Richard Hartmann (RichiH; ex-Grafana Labs, Prometheus team)
#   License    : Apache-2.0
#   Stars      : 110
#   Language   : Go
#   Module     : github.com/RichiH/modbus_exporter  (Go 1.23.0)
#   Binary     : modbus_exporter
#   Last push  : 2026-01-31
#
# WHAT IT IS
#   modbus_exporter is "an exporter which retrieves stats from a Modbus
#   system and exports them via HTTP for Prometheus consumption" — Richard
#   Hartmann's Go implementation of the canonical Prometheus exporter
#   pattern (`/metrics` + `/modbus?target=X&module=Y` HTTP endpoints) for
#   industrial Modbus TCP/RTU devices.  Reads device-and-register maps from
#   a YAML config file (`modbus.yml`), connects to a Modbus target named
#   in the `target` query param, scrapes the registers declared by the
#   `module` query param, and renders the results as Prometheus metrics.
#   Common deployments include solar inverter / energy meter / industrial
#   sensor scraping into a Prometheus + Grafana observability pipeline.
#
# CLI ARGUMENT GRAMMAR  (verbatim from modbus_exporter.go kingpin.Flag chain +
#                       prometheus/exporter-toolkit web.AddFlags +
#                       prometheus/common promlog.AddFlags)
#   modbus_exporter [OPTIONS]
#
#   Application flags:
#     --config.file <FILE>...    Sets the configuration file (repeatable
#                                kingpin `.Strings()`) — modbus.yml is
#                                merged across all `--config.file` values
#                                                       [default: modbus.yml]
#
#   Prometheus web flags (from exporter-toolkit/web kingpinflag.AddFlags):
#     --web.listen-address <ADDR>      Address on which to expose metrics
#                                                       [default: :9602]
#     --web.config.file <FILE>         exporter-toolkit web config
#                                      (TLS, basic auth, etc.)
#     --web.systemd-socket             Use systemd socket activation
#                                      (Linux only)
#
#   Prometheus logging flags (from promlog/flag.AddFlags):
#     --log.level <LEVEL>              debug | info | warn | error
#                                                       [default: info]
#     --log.format <FORMAT>            logfmt | json    [default: logfmt]
#
#   Kingpin auto-flags:
#     -h, --help                       Show context-sensitive help
#         --version                    Show application version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/goburrow/modbus v0.0.0-...` declared
#   in go.mod — the canonical Go Modbus client library (goburrow/modbus,
#   1031 stars, "Fault-tolerant implementation of modbus protocol in Go"),
#   the de-facto Modbus library across the Go ecosystem.  Paired with
#   `github.com/tbrandon/mbserver` for the test-server side.  Verified via:
#     gh api repos/RichiH/modbus_exporter/contents/go.mod
#       → github.com/goburrow/modbus v0.0.0-20161010020032-f7afd8db7d8d
#   This entry is the Go=116 leader bump that continues Axis 61
#   (Modbus Industrial Fieldbus Library) opened at R833 with
#   Rust=tokio-modbus 0.17 (acpiccolo/R4DCB08-Temperature-Collector
#   `tempcol`).
#
#   No completion for `modbus_exporter` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_modbus_exporter() {
    _arguments -s \
        '*--config.file=[modbus YAML configuration file (repeatable; default modbus.yml)]:config file:_files -g "*.(yml|yaml)"' \
        '--web.listen-address=[address on which to expose metrics (default :9602)]:listen addr:' \
        '--web.config.file=[exporter-toolkit web config (TLS / basic auth)]:web config:_files -g "*.(yml|yaml)"' \
        '--web.systemd-socket[use systemd socket activation (Linux only)]' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:format:(logfmt json)' \
        '(- *)'{-h,--help}'[show context-sensitive help]' \
        '(- *)--help-long[show all help including hidden flags]' \
        '(- *)--help-man[show help formatted as a man page]' \
        '(- *)--version[show application version]'
}

_modbus_exporter "$@"
