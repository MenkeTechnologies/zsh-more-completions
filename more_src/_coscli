#compdef coscli
# Documentation: https://www.tencentcloud.com/document/product/436/43249
# coscli - Tencent Cloud COS command line tool

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config-path)'{-c,--config-path=}'[config file path]:config:_files' \
  '(-i --secret-id)'{-i,--secret-id=}'[secret id]:id' \
  '(-k --secret-key)'{-k,--secret-key=}'[secret key]:key' \
  '--token=[session token for temporary credentials]:token' \
  '(-e --endpoint)'{-e,--endpoint=}'[service endpoint]:endpoint' \
  '--customized[enable customized configuration]' \
  '(-p --protocol)'{-p,--protocol=}'[communication protocol]:protocol:(http https)' \
  '--init-skip[skip initial setup]' \
  '--log-path=[directory for log files]:path:_files -/' \
  '--disable-log[turn off logging]' \
  '--bucket-type=[specify bucket variant]:type:(COS OFS)' \
  '1:command:(config config-add config-delete config-init config-set config-show mb rb ls du lsdu cp sync rm hash cat lsparts abort restore signurl symlink bucket-acl bucket-encryption bucket-inventory bucket-policy bucket-tagging bucket-versioning object-acl object-tagging)' \
  '*::args:->args' && ret=0

case $state in
  args)
    case $line[1] in
      cp|sync)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[recursively operate]' \
          '(-f --force)'{-f,--force}'[force operation without confirmation]' \
          '--include=[include files matching pattern]:pattern' \
          '--exclude=[exclude files matching pattern]:pattern' \
          '--fail-output[log failed information]' \
          '--fail-output-path=[path to write failed information]:path:_files -/' \
          '*:file:_files' && ret=0
        ;;
      rm)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[recursively delete]' \
          '(-f --force)'{-f,--force}'[force delete without confirmation]' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
