#compdef xevd_app
# Documentation: https://github.com/mpeg5/xevd/blob/master/README.md
# eXtra-fast Essential Video Decoder (MPEG-5 EVC)

local ret=1

_arguments -s -S \
  '--help[display all available options]' \
  '(-i --input)'{-i,--input}'+[input bitstream file]:file:_files' \
  '(-o --output)'{-o,--output}'+[output video file]:file:_files' \
  '(-m --threads)'{-m,--threads}'+[number of threads to create]:n:' && ret=0

return ret
