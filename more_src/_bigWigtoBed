#compdef bigWigtoBed
# _bigWigtoBed — UCSC Kent Lab bigWigToBed extract bed format above a threshold from a bigWig binary file (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigWig.html

_bigWigtoBed() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-threshold=+[F]:f:' \
        '-chrom=+[chromosome name]:str:' \
        '-start=+[start position]:n:' \
        '-end=+[end position]:n:' \
        '-udcDir=+[UDC cache dir]:dir:_files -/' \
        '*:bigWig out_bed:_files -g "*.bw *.bigwig *.bed"'
}

_bigWigtoBed "$@"
