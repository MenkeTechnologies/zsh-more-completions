#compdef leiningen-cli lein-cli
# _leiningen-cli — Phil Hagelberg Leiningen Clojure build tool CLI alias (technomancy team, Clojure); custom argparse
# upstream: https://github.com/technomancy/leiningen

_leiningen-cli() {
    local -a sub=(
        'change:rewrite project.clj'
        'check:check syntax and warnings'
        'classpath:print classpath'
        'clean:remove build artifacts'
        'compile:compile clojure source files'
        'deploy:deploy jar to remote'
        'deps:download/list dependencies'
        'do:higher-order task to perform multiple tasks'
        'help:show help for a task'
        'install:install jar in local repo'
        'jar:package up artifact jar'
        'javac:compile java source files'
        'new:generate a new project'
        'pom:write a pom.xml'
        'release:perform release tasks'
        'repl:start a repl'
        'retest:retest failing tests'
        'run:run the project main'
        'search:search remote artifacts'
        'show-profiles:list profiles'
        'test:run tests'
        'trampoline:run via subshell'
        'uberjar:package jar with deps'
        'update-in:update keys in project.clj'
        'upgrade:upgrade leiningen'
        'vcs:project versioning helpers'
        'version:show leiningen version'
        'with-profile:apply task with profile'
        'plugin:install plugin'
        'change-version:bump version'
        'pprint:pretty print project'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-o[offline]' \
        '-U[force update]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lein subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:template:(default app plugin template figwheel-main reagent)' \
                    '2:name:' \
                    '--to-dir=+[dir]:dir:_files -/' \
                    '--force[force overwrite]' ;;
                with-profile) _arguments '1:profile:' '*:task:' ;;
                do) _arguments '*:task:' ;;
                install|jar|uberjar) _arguments '*:profile:' ;;
                run) _arguments \
                    '-m+[main namespace]:str:' \
                    '*:args:' ;;
                test) _arguments '*:test selector:' ;;
                repl) _arguments \
                    '1:cmd:(:start :headless :connect :sub-repl)' \
                    '*:args:' ;;
                deploy) _arguments '1:repository:' ;;
                search) _arguments '1:query:' ;;
                help) _arguments '1:task:' ;;
            esac
            ;;
    esac
}

_leiningen-cli "$@"
