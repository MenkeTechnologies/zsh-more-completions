#compdef fyne

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a Fyne application'
  'bundle:bundle static resources into Go source'
  'env:print Fyne environment info'
  'get:download and install a Fyne application'
  'install:install a Fyne application'
  'package:package a Fyne application for distribution'
  'release:prepare a release of a Fyne application'
  'serve:build and serve a Fyne application via web'
  'version:show version info'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'fyne command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (build)
        _arguments \
          '-o+[output file]:output:_files' \
          '-tags=[build tags]:tags' \
          '-target=[target platform]:platform:(android android/arm android/arm64 android/amd64 android/386 ios darwin darwin/amd64 darwin/arm64 freebsd freebsd/amd64 freebsd/arm64 linux linux/amd64 linux/arm linux/arm64 linux/386 wasm web windows windows/amd64 windows/386)' \
          '-release[build in release mode]' && ret=0
        ;;
      (package)
        _arguments \
          '-appBuild=[build number]:build number' \
          '-appID=[app ID]:app ID' \
          '-appVersion=[app version]:version' \
          '-certificate=[signing certificate]:certificate' \
          '-developer=[developer signing ID]:developer' \
          '-icon=[app icon]:icon file:_files -g "*.png"' \
          '-name=[app name]:name' \
          '-o+[output directory]:directory:_directories' \
          '-os=[target OS]:os:(android darwin freebsd ios linux wasm web windows)' \
          '-release[package for release]' \
          '-sourceDir=[source directory]:directory:_directories' \
          '-tags=[build tags]:tags' && ret=0
        ;;
      (release)
        _arguments \
          '-appBuild=[build number]:build number' \
          '-appID=[app ID]:app ID' \
          '-appVersion=[app version]:version' \
          '-certificate=[signing certificate]:certificate' \
          '-developer=[developer signing ID]:developer' \
          '-icon=[app icon]:icon file:_files -g "*.png"' \
          '-name=[app name]:name' \
          '-os=[target OS]:os:(android darwin freebsd ios linux wasm web windows)' \
          '-tags=[build tags]:tags' \
          '-keyStore=[Android keystore file]:file:_files' \
          '-keyStorePass=[Android keystore password]:password' \
          '-keyPass=[Android key password]:password' \
          '-keyName=[Android key name]:name' \
          '-password=[macOS signing password]:password' \
          '-profile=[iOS provisioning profile]:profile' \
          '-category=[macOS app category]:category' && ret=0
        ;;
      (bundle)
        _arguments \
          '-name=[variable name]:name' \
          '-package=[package name]:package' \
          '-append[append to output file]' \
          '-o+[output file]:file:_files -g "*.go"' \
          '*:resource files:_files' && ret=0
        ;;
      (get)
        _arguments '1:package path' && ret=0
        ;;
      (install)
        _arguments \
          '-icon=[app icon]:icon file:_files -g "*.png"' \
          '-appID=[app ID]:app ID' \
          '-target=[target platform]:platform:(android darwin ios linux wasm web windows)' && ret=0
        ;;
      (serve)
        _arguments \
          '-port=[server port]:port' \
          '-tags=[build tags]:tags' && ret=0
        ;;
    esac
    ;;
esac

return ret
