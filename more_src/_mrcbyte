#compdef mrcbyte
# Documentation: https://bio3d.colorado.edu/imod/doc/man/mrcbyte.html
# Convert an MRC file to bytes

local ret=1

_arguments -s \
  '-c[Specify intensity scaling to match the scaling achieved]:value:' \
  '-s[Specify an initial intensity scaling, which will scale ]:value:' \
  '-l[Use logarithmic scaling (valid for short integer and fl]' \
  '-e[Use exponential scaling (valid for short integer and fl]' \
  '-R[Reverse contrast in the output]' \
  '-x[X0,X1]:value:' \
  '-y[Y0,Y1]:value:' \
  '-z[Z0,Z1]:value:' \
  '-b[Write raw byte data without a header]' \
  '-r[Request user input for the contrast and size options]' \
  '*:file:_files' && ret=0

return ret
