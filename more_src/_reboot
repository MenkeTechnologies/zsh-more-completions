#compdef reboot halt
# Documentation: man reboot(8) (BSD / macOS)
# Source: BSD halt / reboot — stop or restart the system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-l[do not log to the system log]' \
    '-N[skip filesystem-cache flush during initial process clean-up]' \
    '-n[do not flush the filesystem cache]' \
    '-q[quick + ungraceful (just cache flush)]' \
    && ret=0

return ret
