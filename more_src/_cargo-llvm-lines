#compdef cargo-llvm-lines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[package to analyze]:package' \
  '--package=[package to analyze]:package' \
  '--lib[analyze library target]' \
  '--bin=[analyze binary target]:binary' \
  '--all-features[activate all features]' \
  '--no-default-features[do not activate default features]' \
  '-F+[features to activate]:features' \
  '--features=[features to activate]:features' \
  '--release[analyze release build]' \
  '--filter=[filter by function name]:pattern' \
  '--sort=[sort order]:order:(lines copies name)' \
  '1:files:_files' && ret=0

return ret
