#compdef hugo
# Documentation: https://github.com/gohugoio/hugo (commands/commands.go + commandeer.go)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'build:compile the Hugo site (default when no subcommand)'
  'server:run the local development server'
  'new:create new content or projects'
  'config:manage configuration settings'
  'env:show environment details'
  'version:display version information'
  'deploy:deploy site to remote storage backend'
  'convert:transform content formats'
  'import:bring in content from other platforms'
  'list:display information about site content'
  'mod:manage Hugo modules'
  'gen:generate various outputs (chromastyles, manpages, autocomplete)'
  'release:handle release operations'
  'completion:generate shell completion script'
  'help:show help for a subcommand'
)

local -a _persistent_flags
_persistent_flags=(
  '(-s --source)'{-s,--source=}'[filesystem path to read files relative from]:dir:_directories'
  '(-d --destination)'{-d,--destination=}'[filesystem path to write files to]:dir:_directories'
  '(-e --environment)'{-e,--environment=}'[build environment]:env:'
  '--themesDir=[filesystem path to themes directory]:dir:_directories'
  '*--ignoreVendorPaths=[ignore _vendor for module paths matching glob]:glob:'
  '--noBuildLock[do not create .hugo_build.lock file]'
  '--clock=[set the clock used by Hugo (RFC3339)]:time:'
  '--config=[config file (default hugo.yaml|json|toml)]:file:_files'
  '--configDir=[config dir (default config)]:dir:_directories'
  '--quiet[build in quiet mode]'
  '(-M --renderToMemory)'{-M,--renderToMemory}'[render to memory]'
  '--logLevel=[log level]:level:(debug info warn error)'
  '(-h --help)'{-h,--help}'[show help]'
)

local -a _build_flags
_build_flags=(
  '(-w --watch)'{-w,--watch}'[watch filesystem and recreate as needed]'
  '--gc[run cleanup tasks after build]'
  '--poll=[poll interval for filesystem change detection]:interval:'
  '--printMemoryUsage[print memory usage to screen at intervals]'
  '--trace=[write trace to file]:file:_files'
  '--panicOnWarning[panic on first WARNING log]'
  '--printPathWarnings[print warnings on duplicate target paths]'
  '--templateMetrics[display metrics about template executions]'
  '--templateMetricsHints[improvement hints with --templateMetrics]'
  '--ignoreCache[ignore configured file caches]'
  '(-t --theme)'{-t,--theme=}'[themes to use]:theme:'
  '--minify[minify any supported output format]'
  '(-D --buildDrafts)'{-D,--buildDrafts}'[include content marked as draft]'
  '(-E --buildExpired)'{-E,--buildExpired}'[include expired content]'
  '(-F --buildFuture)'{-F,--buildFuture}'[include content with publishdate in future]'
  '(-b --baseURL)'{-b,--baseURL=}'[hostname (and path) to root URL]:url:_urls'
  '--cacheDir=[filesystem path to cache directory]:dir:_directories'
  '--cleanDestinationDir[remove files not in build from destination]'
  '--contentDir=[filesystem path to content directory]:dir:_directories'
  '--enableGitInfo[add last-modified date from Git]'
  '(-i --ignoreCacheStats)'{-i,--ignoreCacheStats}'[ignore cache stats]'
  '--layoutDir=[filesystem path to layout directory]:dir:_directories'
  '--noChmod[do not sync permission mode of files]'
  '--noTimes[do not sync modification time of files]'
  '--forceSyncStatic[copy all files when static is changed]'
)

_arguments -C \
  $_persistent_flags \
  $_build_flags \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'hugo subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _new _server _mod _gen _list _config
    _new=(
      'site:create a new site (skeleton)'
      'theme:create a new theme'
      'content:create new content for your site'
    )
    _server=()
    _mod=(
      'init:initialize a new module'
      'get:resolve dependencies in your current Hugo Project'
      'tidy:remove unused entries in go.mod and go.sum'
      'vendor:vendor all module dependencies into _vendor directory'
      'verify:verify that the dependencies of the current module have not been modified'
      'graph:print a module dependency graph'
      'clean:delete the entire dependency modules cache'
      'npm:various npm helpers'
    )
    _gen=(
      'autocomplete:generate shell autocompletion script for Hugo'
      'chromastyles:generate CSS stylesheet for the Chroma code renderer'
      'doc:generate Markdown documentation for the Hugo CLI'
      'man:generate man pages for the Hugo CLI'
    )
    _list=(
      'all:list all posts'
      'drafts:list all posts marked as drafts'
      'expired:list all posts already expired'
      'future:list all posts dated in the future'
    )
    _config=(
      'mounts:print the mounts entry'
    )
    case $line[1] in
      new) _arguments $_persistent_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'new' _new && ret=0 ;;
      server)
        _arguments $_persistent_flags $_build_flags \
          '(-p --port)'{-p,--port=}'[port on which the server will listen]:port:' \
          '--liveReloadPort=[port LiveReload listens on (-1 = same as server)]:port:' \
          '--bind=[interface to which the server will bind]:bind:' \
          '--appendPort[append port to baseURL]' \
          '--disableLiveReload[disable automatic live reloading]' \
          '--disableFastRender[enable full re-renders on changes]' \
          '--liveReload[render on file change]' \
          '--noHTTPCache[prevent HTTP caching]' \
          '--navigateToChanged[navigate to changed content file]' \
          '--openBrowser[open the site in default browser]' \
          '--tlsAuto[generate and use self-signed cert]' \
          '--tlsCertFile=[path to TLS certificate]:file:_files' \
          '--tlsKeyFile=[path to TLS key]:file:_files' && ret=0
        ;;
      mod) _arguments $_persistent_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'mod' _mod && ret=0 ;;
      gen) _arguments $_persistent_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'gen' _gen && ret=0 ;;
      list) _arguments $_persistent_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'list' _list && ret=0 ;;
      config) _arguments $_persistent_flags '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'config' _config && ret=0 ;;
      completion) _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac
    ;;
esac

return ret
