#compdef sem-ai
# Documentation: https://man.archlinux.org/search?q=sem-ai
# Reference accessed: 2026-05-16

# Zsh completion for Semaphore AI (sem-ai) CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(--format -f)'{--format,-f}'[output format]:format:(json table yaml)' \
  '(--verbose -v)'{--verbose,-v}'[print detailed output, including HTTP requests]' \
  '--examples[show usage examples for any specific command]' \
  '--help[show help message]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands
    commands=(
      'connect:connect to a Semaphore organization using an API token'
      'discover:return a structured map of all commands and flags'
      'diagnose:analyze CI failures using parsed test results and logs'
      'context:manage active organizations'
      'pipeline:manage pipelines'
      'testbox:run commands in a real CI environment before pushing code'
    )
    _describe -t commands 'command' commands
    ;;
  args)
    case $line[1] in
      context)
        _arguments \
          '1: :->subcommand' && ret=0
        case $state in
          subcommand)
            local -a subcommands
            subcommands=(
              'list:list all connected organizations'
              'show:show details of the current organization'
              'switch:switch to a different organization'
            )
            _describe -t subcommands 'subcommand' subcommands
            ;;
        esac
        ;;
      pipeline)
        _arguments \
          '1: :->subcommand' && ret=0
        case $state in
          subcommand)
            local -a subcommands
            subcommands=(
              'promote:promote a pipeline to the next stage'
              'stop:terminate a running pipeline'
              'rebuild:re-run a pipeline'
            )
            _describe -t subcommands 'subcommand' subcommands
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
