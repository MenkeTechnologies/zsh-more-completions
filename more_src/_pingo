#compdef pingo
# Documentation: https://github.com/mikaelmello/pingo
# Source: mikaelmello/pingo — Go-based ping clone with IPv4/IPv6 + privileged ICMP.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-c --count)'{-c+,--count=}'[stop after N ECHO_REQUEST packets (default -1)]:n:_default' \
    '(-w --deadline)'{-w+,--deadline=}'[exit after N seconds regardless (default -1)]:seconds:_default' \
    '(-f --flood)'{-f,--flood}'[flood ping mode]' \
    '(-i --interval)'{-i+,--interval=}'[wait time between packets in seconds (default 1)]:seconds:_default' \
    '(-p --privileged)'{-p,--privileged}'[use privileged raw ICMP endpoints]' \
    '(-W --timeout)'{-W+,--timeout=}'[response wait time in seconds (default 10)]:seconds:_default' \
    '(-t --ttl)'{-t+,--ttl=}'[IP TTL (default 64)]:n:_default' \
    '--log-level=[logging priority 0=Panic..6=Trace]:level:(0 1 2 3 4 5 6)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:host:_hosts' \
    && ret=0

return ret
