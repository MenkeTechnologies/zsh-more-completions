#compdef gnt-job

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'archive:archive completed jobs'
  'autoarchive:auto-archive completed jobs'
  'cancel:cancel a queued or running job'
  'change-priority:change priority of a queued job'
  'info:show information about a job'
  'list:list jobs'
  'list-fields:list available list fields'
  'wait:wait for a job to complete'
  'watch:watch a job'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnt-job command' commands && ret=0 ;;
esac

return ret
