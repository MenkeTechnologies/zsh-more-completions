#compdef aretext
# =============================================================================
# aretext — Wendell Pence's "Minimalist text editor with
#           vim-compatible key bindings" — a single-binary
#           Go terminal text editor designed to be a
#           focused, batteries-included alternative to
#           Neovim configuration sprawl.  Implements ~100+
#           normal-mode vim commands (motion, change,
#           delete, yank, put, ex `:` command line,
#           registers, marks, visual block) on top of
#           gdamore/tcell/v3 as a single statically-linked
#           Go binary with no plugin runtime.
#
#           Distinguishing from vim (Bram Moolenaar's
#           original; C; massive feature set + Vimscript +
#           Lua), neovim (Vim fork with libuv async +
#           built-in LSP + Lua plugin runtime), kakoune
#           (Maxime Coste's selection-then-action paradigm;
#           multi-cursor first), helix (Blaž Hrastnik's
#           modal Rust editor with selection-first model +
#           bundled tree-sitter + LSP), micro (Zachary Yedidia's
#           non-modal "easy" terminal editor; Go), and
#           amp (Jordan MacDonald's Rust modal editor) by:
#             - VIM KEYBINDINGS ONLY — no emacs-style or
#               non-modal mode; aretext targets users who
#               already know vim and want a lighter binary
#             - NO PLUGIN RUNTIME — instead of a script
#               language, aretext defines a "configuration
#               document" (YAML) plus "menu commands" that
#               shell out to external programs; the
#               composition model is "do one thing well +
#               pipe to other CLIs"
#             - YAML CONFIG — `~/.config/aretext/config.yaml`
#               with file-pattern-keyed style blocks
#               (syntax language, tab size, autoindent,
#               soft wrap, menu commands)
#             - MENU COMMANDS — `:menucmd` invocations
#               that pipe selection or document text
#               through external shell commands (rg, fzf,
#               jq, sd) and replace selection with output
#             - BUILT-IN SYNTAX — bundled tokenizers for
#               Go, Python, Rust, JavaScript, JSON, YAML,
#               TOML, Markdown, shell + others; no external
#               tree-sitter binaries
#             - TCELL/V3 BACKEND — uses gdamore/tcell/v3
#               (the modern Go terminal-cell library; v3
#               adds true-color + better Windows support
#               over v2)
#             - LINE TARGETING — `aretext -line N file`
#               jumps to line N on open (useful in
#               grep | xargs pipelines)
#             - EDIT-CONFIG SHORTCUT — `aretext -editconfig`
#               opens the configuration document itself
#               without needing to remember its path
#             - DETERMINISTIC LOGGING — `aretext -log
#               /tmp/aretext.log` writes structured logs
#               with microsecond timestamps via Go's stdlib
#               log package
#             - CPU PROFILING — `aretext -cpuprofile
#               /tmp/profile.out` for `go tool pprof`
#               investigation
#             - VERSION FROM BUILD INFO — populates
#               version, vcsRevision, vcsTime, vcsModified,
#               goVersion via runtime/debug.BuildInfo —
#               so `aretext -version` is reliable in
#               reproducible builds
#
# Author:   Wendell Pence (aretext on GitHub).
# Source:   https://github.com/aretext/aretext
#           https://github.com/aretext/aretext/blob/main/main.go
# Homepage: https://aretext.org
# License:  MIT
# Reference accessed: 2026-06-01
#
# -----------------------------------------------------------------------------
#
# THE aretext CLI
#
# aretext is invoked as:
#   aretext [OPTIONS] [FILE]
#
# Options (from aretext main.go flag block; Go's flag
# package accepts both `-foo` and `--foo`):
#
#   -line N            line number to view after opening
#                      the document (default 1)
#   -log FILE          log to FILE (microsecond timestamps;
#                      goes to io.Discard if unset)
#   -cpuprofile FILE   write CPU profile to FILE for
#                      `go tool pprof` analysis
#   -editconfig        open the aretext configuration file
#                      (~/.config/aretext/config.yaml or
#                      $XDG_CONFIG_HOME/aretext/config.yaml)
#   -noconfig          force default configuration (skip
#                      loading config.yaml)
#   -version           print version + exit
#
# Positional:
#   FILE               file to edit (optional; opens an
#                      empty buffer if omitted)
#
# Common invocations:
#   # Open file at line 120
#   aretext -line 120 src/main.go
#
#   # Edit the config file
#   aretext -editconfig
#
#   # Run with default config (skip user config)
#   aretext -noconfig README.md
#
#   # Profile session
#   aretext -cpuprofile /tmp/aretext-prof.out -log /tmp/aretext.log file.py
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-line=[line number to view after opening the document]:line:_default' \
    '--line=[line number to view after opening the document]:line:_default' \
    '-log=[log to file]:logfile:_files' \
    '--log=[log to file]:logfile:_files' \
    '-cpuprofile=[write CPU profile to file]:profile:_files' \
    '--cpuprofile=[write CPU profile to file]:profile:_files' \
    '-editconfig[open the aretext configuration file]' \
    '--editconfig[open the aretext configuration file]' \
    '-noconfig[force default configuration]' \
    '--noconfig[force default configuration]' \
    '(- *)-version[print version]' \
    '(- *)--version[print version]' \
    '*:file:_files' \
    && ret=0

return ret
