#compdef ndftrace
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss125.html
# KAPPA NDFTRACE - display the attributes of an NDF data structure

local ret=1

_arguments -C \
  'NDF=[NDF data structure whose attributes are displayed]:NDF file:_files' \
  'FULLAXIS=[display full axis array attributes]:flag:(TRUE FALSE)' \
  'FULLFRAME=[full coordinate Frame description]:flag:(TRUE FALSE)' \
  'FULLWCS=[display all WCS coordinate Frames]:flag:(TRUE FALSE)' \
  '*:NDF file:_files' && ret=0

return ret
