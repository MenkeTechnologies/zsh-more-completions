#compdef monero-blockchain-export
# Documentation: https://man.archlinux.org/search?q=monero-blockchain-export
# Reference accessed: 2026-05-16
# Source: https://github.com/BibXMR/monero-zsh-completions/blob/6540df4783f354863955175790dae12735e30b2d/_monero-blockchain-export
# Repository: BibXMR/monero-zsh-completions (_monero-blockchain-export)

_monero-blockchain-export() {
  _arguments \
    '(- *)--help[Produce help message]' \
    '--block-start=[Start at block number]:block height' \
    '--block-stop=[Stop at block number]:block height' \
    '--blocksdat[Output in blocks.dat format]' \
    '--data-dir=[Specify data directory]:data directory:_directories' \
    '--log-level=[0-4 or categories]:log level' \
    '--output-file=[Specify output file]:output file:_files' \
    '(--testnet)--stagenet[Run on stagenet.]' \
    '(--stagenet)--testnet[Run on testnet.]'
}

_monero-blockchain-export "$@"
