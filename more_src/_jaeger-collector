#compdef jaeger-collector
# _jaeger-collector — CNCF Jaeger jaeger-collector CLI distributed tracing backend collector component receiving traces from instrumented services via gRPC HTTP Thrift Zipkin OpenTelemetry protocols storing spans in Cassandra Elasticsearch Kafka memory backend with sampling kafka-replication-rate-limit (CNCF team, Go); pflag
# upstream: https://www.jaegertracing.io/

_jaeger-collector() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '--log-level=+[l]:l:(debug info warn error fatal panic)' \
        '--log-encoding=+[e]:e:(console json)' \
        '--metrics-backend=+[m]:m:(prometheus expvar none)' \
        '--metrics-http-route=+[path]:str:' \
        '--admin-host-port=+[host:port]:str:' \
        '--collector.http-server.host-port=+[host:port]:str:' \
        '--collector.grpc-server.host-port=+[host:port]:str:' \
        '--collector.grpc-server.tls.enabled[grpc TLS]' \
        '--collector.grpc-server.tls.cert=+[file]:file:_files' \
        '--collector.grpc-server.tls.key=+[file]:file:_files' \
        '--collector.grpc-server.tls.client-ca=+[file]:file:_files' \
        '--collector.grpc-server.max-message-size=+[size]:n:' \
        '--collector.otlp.enabled[enable OTLP]' \
        '--collector.otlp.grpc.host-port=+[host:port]:str:' \
        '--collector.otlp.http.host-port=+[host:port]:str:' \
        '--collector.queue-size=+[N]:n:' \
        '--collector.queue-size-memory=+[MB]:n:' \
        '--collector.num-workers=+[N]:n:' \
        '--collector.zipkin.host-port=+[host:port]:str:' \
        '--collector.zipkin.allowed-headers=+[list]:str:' \
        '--collector.zipkin.allowed-origins=+[list]:str:' \
        '--collector.tags=+[k=v]:str:' \
        '--span-storage.type=+[t]:t:(cassandra elasticsearch opensearch kafka memory badger grpc-plugin)' \
        '--sampling.strategies-file=+[file]:file:_files -g "*.json"' \
        '--sampling.strategies-reload-interval=+[duration]:str:' \
        '--downsampling.ratio=+[N]:str:' \
        '--downsampling.hashsalt=+[salt]:str:' \
        '*::'
}

_jaeger-collector "$@"
