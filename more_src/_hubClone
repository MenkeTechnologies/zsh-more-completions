#compdef hubClone
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: clone the remote hub text files to a local copy

local ret=1

_arguments -s -S \
  '-udcDir=[path to udc directory]:dir:_files -/' \
  '-download[download data files in addition to hub config files]' \
  '-skipMissingAssemblies[skip assemblies with missing trackDb.txt instead of aborting]' \
  '1:hub.txt url:_files' && ret=0

return ret
