#compdef mlmmj-maintd
# Documentation: https://mlmmj.org/mlmmj-maintd.html
# Reference accessed: 2026-05-30
# mlmmj-maintd — mlmmj maintenance daemon. Runs as daemon by default; use -F for cron usage.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-d -L)-d+[directory containing multiple lists (recurse all subdirectories)]:dir:_directories' \
  '(-d -L)-L+[full path to a single list directory]:dir:_directories' \
  '-F[non-daemon mode (one maintenance cycle - use with cron)]' \
  && ret=0

return ret
