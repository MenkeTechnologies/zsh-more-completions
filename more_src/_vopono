#compdef vopono
# Documentation: https://github.com/jamesmcm/vopono
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --verbose)'{-v,--verbose}'[Verbose]' \
  '(-c --config -i)'{-c,--config,-i}'+[Application hosts file]:file:_files' \
  '(-k --keep-alive)'{-k,--keep-alive}'[Keep tun interface up]' \
  '(--vpn-target)'--vpn-target+'[VPN provider and profile]:target:' \
  '(--protocol)'--protocol+'[VPN protocol]:protocol:' \
  '*:application and arguments: _default'
