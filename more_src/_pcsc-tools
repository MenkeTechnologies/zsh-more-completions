#compdef pcsc-tools

# pcsc-tools umbrella for pcsc_scan / ATR_analysis / scriptor
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'pcsc_scan:scan for plugged smart cards/readers'
  'ATR_analysis:analyze smart card ATR'
  'scriptor:run an APDU script'
  'gscriptor:GUI APDU script runner'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pcsc-tools command' commands && ret=0 ;;
esac
return ret
