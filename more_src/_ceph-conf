#compdef ceph-conf
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-conf/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-conf: show options from ceph.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c+[Ceph configuration file]:file:_files -g "*.conf"' \
  '-L[list all sections]' \
  '--list-all-sections[list all sections]' \
  '-l+[list sections with given prefix]:prefix:' \
  '--list-sections=[list sections with given prefix]:prefix:' \
  '--lookup=[lookup a configuration setting]:key:' \
  '--name=[Ceph name (type.id) to search in (default client.admin)]:name:' \
  '--pid=[override $pid when expanding options]:pid:' \
  '-r[search for first existing file in search list]' \
  '--resolve-search[search for first existing file in search list]' \
  '-s+[additional sections to search]:section:' \
  '--section=[additional sections to search]:section:' \
  '--filter-key=[filter section list by key]:key:' \
  '--filter-key-value=[filter section list by key=value]:key=value:' \
  '*::ceph-conf args:_files' && ret=0
return ret
