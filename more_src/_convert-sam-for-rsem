#compdef convert-sam-for-rsem
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: convert SAM/BAM/CRAM to satisfy RSEM alignment adjacency requirements

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --num-threads)'{-p,--num-threads}'=[number of threads]:int' \
  '--memory-per-thread=[max memory per thread (K/M/G)]:mem' \
  '1:input sam/bam/cram:_files -g "*.(sam|bam|cram)"' \
  '2:output file name:_files' && ret=0

return ret
