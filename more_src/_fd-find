#compdef fd-find
# Documentation: https://man.archlinux.org/search?q=fd-find
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_fd] )) || autoload -Uz _fd 2>/dev/null
if (( $+functions[_fd] )); then
  _fd "$@"
  return
fi

_arguments \
  '*::fd arg:_files' && ret=0

return ret
