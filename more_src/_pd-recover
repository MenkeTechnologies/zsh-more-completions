#compdef pd-recover
# _pd-recover — TiKV PD cluster bootstrap/recovery helper
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-recover/main.go on tip.

_pd-recover() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-V[print version information]' \
        '-from-old-member[recover from a member of an existing cluster]' \
        '-endpoints=[PD etcd endpoints (comma-separated URLs)]:csv:' \
        '-alloc-id=[allocated ID to start from (must be safe)]:n:' \
        '-cluster-id=[cluster ID (must match TiKV)]:n:' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files'
}

_pd-recover "$@"
