#compdef condor_ssh_to_job
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_ssh_to_job.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_ssh_to_job: open an SSH session to a running Condor job
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-debug[debug]' \
  '-name[schedd name]:name:' \
  '-pool[pool]:pool:' \
  '-ssh[ssh command]:ssh-cmd:' \
  '-X[forward X11]' \
  '-Y[trusted X11]' \
  '-keygen-options[ssh-keygen options]:opts:' \
  '-shells[shells preference]:list:' \
  '-auto-retry[retry until job runs]' \
  '-remove-on-interrupt[remove job on interrupt]' \
  '*:job-id command:' && ret=0
return ret
