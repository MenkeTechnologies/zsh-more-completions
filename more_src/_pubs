#compdef pubs
# Documentation: https://man.archlinux.org/search?q=pubs
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add document to library'
  'rename:rename citekey'
  'remove:remove documents'
  'rm:alias for remove'
  'list:list documents'
  'ls:alias for list'
  'edit:edit bibtex/yaml metadata'
  'tag:tag documents'
  'note:edit notes for document'
  'export:export bibtex'
  'import:import bibtex file'
  'attach:attach file to entry'
  'open:open document'
  'doc:document file operations'
  'url:document URL operations'
  'init:initialise pubs library'
  'conf:edit pubs config'
  'statistics:library statistics'
  'website:open document website'
  'cat:print bibtex entry to stdout'
  'help:show help'
  'olist:open list of citekeys'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[silent output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--force-colors[force colored output]' \
  '--no-colors[disable colored output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pubs command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '(-D --doi)'{-D+,--doi=}'[DOI]:doi:' \
          '(-I --isbn)'{-I+,--isbn=}'[ISBN]:isbn:' \
          '(-X --arxiv)'{-X+,--arxiv=}'[arXiv ID]:id:' \
          '(-b --bibfile)'{-b+,--bibfile=}'[bibtex file]:file:_files' \
          '(-d --docfile)'{-d+,--docfile=}'[document file]:file:_files' \
          '(-t --tags)'{-t+,--tags=}'[tags csv]:tags:' \
          '(-k --citekey)'{-k+,--citekey=}'[citekey]:key:' \
          '*:bibtex:_files' && ret=0 ;;
      (list|ls)
        _arguments \
          '(-k --citekeys-only)'{-k,--citekeys-only}'[only citekeys]' \
          '--alphabetical[alphabetical order]' \
          '--ignore-case[ignore case in filter]' \
          '*:filter query:' && ret=0 ;;
      (open|doc|edit|note|attach|export|tag)
        _arguments '*:citekey:' && ret=0 ;;
    esac ;;
esac

return ret
