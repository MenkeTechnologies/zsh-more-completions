#compdef cargo-call-stack
# _cargo-call-stack — whole-program stack-usage analysis for embedded Rust (japaric/cargo-call-stack)
# upstream: https://github.com/japaric/cargo-call-stack
# Flags from src/main.rs (clap).

_cargo-call-stack() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--target=[target triple]:triple:' \
        '--bin=[only the named binary]:name:' \
        '--example=[only the named example]:name:' \
        '--features=[space-separated feature list]:features:' \
        '--all-features[activate all features]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--format=[output format]:fmt:(dot top)' \
        '1:start node:'
}

_cargo-call-stack "$@"
