#compdef cec-client
# _cec-client — Pulse-Eight libCEC cec-client CLI for sending and receiving HDMI CEC Consumer Electronics Control commands to TV AV-receiver adapter cec-tools listing power-on standby active-source detecting devices vendor-OSD strings (Pulse-Eight team, C++); getopt
# upstream: https://github.com/Pulse-Eight/libcec

_cec-client() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-l[list adapters]' \
        '--list-adapters[list adapters]' \
        '-i+[language]:str:' \
        '--info[show info]' \
        '-b+[base device]:n:' \
        '--base-device=+[base device]:n:' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-r+[adapter device]:file:_files -g "/dev/cec* /dev/ttyACM* /dev/ttyUSB*"' \
        '--rs232=+[adapter device]:file:_files -g "/dev/cec* /dev/ttyACM*"' \
        '-t+[type]:t:(p r t a u)' \
        '--device-type=+[type]:t:(p r t a u)' \
        '-f+[log file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '-s[single-line mode]' \
        '--single-command[single command]' \
        '-d+[log level]:n:(1 2 4 8 16 32 64 128)' \
        '--log-level=+[log level]:n:(1 2 4 8 16 32 64 128)' \
        '-o+[OSD name]:str:' \
        '--osd-name=+[OSD name]:str:' \
        '-m[monitor mode]' \
        '--monitor[monitor mode]' \
        '-n[no detect]' \
        '--no-detect[no detect]' \
        '-x+[command]:str:' \
        '--command=+[command]:str:' \
        '-w[wake up after init]' \
        '--wake[wake up after init]' \
        '-W+[wake-targets]:str:' \
        '--wake-up=+[wake-targets]:str:' \
        '*:command:'
}

_cec-client "$@"
