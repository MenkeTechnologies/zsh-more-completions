#compdef fh
# Documentation: https://man.archlinux.org/search?q=fh
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--api-addr=[Override FlakeHub API base URL]:url:' \
  '--cache-addr=[Override FlakeHub cache URL]:url:' \
  '--frontend-addr=[Override FlakeHub web URL]:url:' \
  '*-v[Increase log verbosity (repeat for trace)]' \
  '--logger=[Tracing output style]:logger:(compact full pretty json)' \
  '*--log-directive=[Tracing filter directives]:directive:' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'add:Add a FlakeHub input to flake.nix'
      'apply:Apply FlakeHub-provided configuration helpers'
      'completion:Emit shell completions'
      'convert:Convert existing flake.lock entries for FlakeHub'
      'eject:Remove FlakeHub metadata from a flake'
      'fetch:Fetch flake metadata or archives'
      'init:Initialize flake.nix for FlakeHub'
      'list:List organizations, flakes, or releases'
      'login:Authenticate this host with FlakeHub'
      'resolve:Resolve store paths or download URLs'
      'search:Search published flakes'
      'status:Show CLI authentication status'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
