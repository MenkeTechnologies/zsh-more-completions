#compdef vcfcommonsamples
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfcommonsamples.md
# Emit each record from the first VCF, removing samples not present in the second

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
