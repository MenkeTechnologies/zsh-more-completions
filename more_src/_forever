#compdef forever

# Zsh completion for forever - simple CLI tool for running node scripts continuously

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'start:start a script as a daemon'
      'stop:stop a running daemon'
      'stopall:stop all running daemons'
      'restart:restart a running daemon'
      'restartall:restart all running daemons'
      'list:list all running forever processes'
      'config:list user configuration'
      'set:set a forever config value'
      'clear:clear a forever config value'
      'logs:list log files for all forever processes'
      'cleanlogs:delete all log files'
      'columns:add or remove columns from list output'
    )
    _describe -t commands 'forever command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      start|restart)
        _arguments \
          '(-l --logFile)'{-l,--logFile}'[log file]:file:_files' \
          '(-o --outFile)'{-o,--outFile}'[stdout file]:file:_files' \
          '(-e --errFile)'{-e,--errFile}'[stderr file]:file:_files' \
          '(-a --append)'{-a,--append}'[append to log files]' \
          '(-c --command)'{-c,--command}'[command to run]:command:(node coffee python ruby)' \
          '(-d --sourceDir)'{-d,--sourceDir}'[source directory]:dir:_files -/' \
          '--minUptime[minimum uptime in ms]:ms' \
          '--spinSleepTime[spin sleep time in ms]:ms' \
          '--uid[unique identifier]:id' \
          '(-p --pidFile)'{-p,--pidFile}'[PID file]:file:_files' \
          '--workingDir[working directory]:dir:_files -/' \
          '--watchDirectory[watch directory]:dir:_files -/' \
          '-w[watch for file changes]' \
          '--killSignal[kill signal]:signal:(SIGTERM SIGKILL SIGINT SIGHUP)' \
          '*:script:_files -g "*.js *.coffee *.py *.rb"' && ret=0
        ;;
      stop|restart)
        _arguments \
          ':process index or script' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
