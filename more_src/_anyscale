#compdef anyscale
# Documentation: https://docs.anyscale.com/reference/quickstart-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_anyscale() {
    local line state
    local -a commands
    commands=(
        'login:Login to Anyscale'
        'job:Manage Anyscale jobs'
        'workspace:Manage Anyscale workspaces'
        'service:Manage Anyscale services'
        'compute-config:Manage compute configurations'
        'image:Manage Anyscale images'
        'schedule:Manage schedules'
        'logs:View Anyscale logs'
    )

    _arguments -C \
        '--working-dir[Specify working directory]:directory:_files -/' \
        '--expire-in-days[API key expiration]:days:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'anyscale command' commands
            ;;
        args)
            case $line[1] in
                job)
                    _arguments '1:subcommand:(list submit get stop logs)'
                    ;;
                workspace)
                    _arguments '1:subcommand:(list create delete stop start)'
                    ;;
            esac
            ;;
    esac
}

_anyscale "$@"
