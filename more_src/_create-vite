#compdef create-vite
# Documentation: https://github.com/vitejs/vite/tree/main/packages/create-vite
# Reference accessed: 2026-05-17
# Verified: upstream src/index.ts (mri argv config) at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --template)'{-t,--template=}'[project template]:template:(vanilla vanilla-ts vue vue-ts react react-ts react-swc react-swc-ts preact preact-ts lit lit-ts svelte svelte-ts solid solid-ts qwik qwik-ts)' \
  '--overwrite[overwrite target directory if non-empty]' \
  '(-i --immediate)'{-i,--immediate}'[skip interactive prompts]' \
  '--interactive[run interactively even with template arg]' \
  '1:project name:' && ret=0

return ret
