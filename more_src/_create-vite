#compdef create-vite

# Zsh completion for create-vite - Vite project scaffolding

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-t+[project template]:template:(vanilla vanilla-ts vue vue-ts react react-ts react-swc react-swc-ts preact preact-ts lit lit-ts svelte svelte-ts solid solid-ts qwik qwik-ts)' \
  '--template=[project template]:template:(vanilla vanilla-ts vue vue-ts react react-ts react-swc react-swc-ts preact preact-ts lit lit-ts svelte svelte-ts solid solid-ts qwik qwik-ts)' \
  '1:project name' && ret=0

return ret
