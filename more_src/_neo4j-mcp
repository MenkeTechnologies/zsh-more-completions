#compdef neo4j-mcp
# Documentation: https://neo4j.com/docs/mcp/current/configuration/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--neo4j-uri=[connection URI]:uri:' \
  '--neo4j-username=[username]:username:' \
  '--neo4j-password=[password]:password:' \
  '--neo4j-database=[database name]:database:' \
  '--neo4j-read-only=[disable write tools]:bool:(true false)' \
  '--neo4j-telemetry=[enable telemetry]:bool:(true false)' \
  '--neo4j-log-level=[log level]:level:(debug info warning error)' \
  '--neo4j-log-format=[log format]:format:(text json)' \
  '--neo4j-schema-sample-size=[nodes to sample for schema]:n:' \
  '--neo4j-transport-mode=[transport mode]:mode:(stdio http)' \
  '--neo4j-http-host=[HTTP server bind address]:host:' \
  '--neo4j-http-port=[HTTP server port]:port:' \
  '--neo4j-mcp-http-allowed-origins=[CORS allowed origins]:origins:' \
  '--neo4j-http-auth-header-name=[custom auth header name]:header:' \
  '--neo4j-http-allow-unauthenticated-ping[allow unauthenticated ping]' \
  '--neo4j-http-allow-unauthenticated-tools-list[allow unauthenticated tools listing]' \
  '--neo4j-http-tls-enabled[enable TLS]' \
  '--neo4j-http-tls-cert-file=[TLS certificate file]:file:_files' \
  '--neo4j-http-tls-key-file=[TLS key file]:file:_files' \
  '*::arguments:_default'
