#compdef raven
# Documentation: https://github.com/lbcb-sci/raven
# de novo assembler for long uncorrected reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '--version[show version]' \
  '(-k --kmer-len)'{-k,--kmer-len}'+[length of minimizers used to find overlaps]:len' \
  '(-w --window-len)'{-w,--window-len}'+[length of sliding window for minimizers]:len' \
  '(-f --frequency)'{-f,--frequency}'+[threshold for ignoring frequent minimizers]:freq' \
  '(-i --identity)'{-i,--identity}'+[threshold for overlap between two reads]:identity' \
  '(-o --kMaxNumOverlaps)'{-o,--kMaxNumOverlaps}'+[maximum number of overlaps]:num' \
  '(-p --polishing-rounds)'{-p,--polishing-rounds}'+[number of times racon is invoked]:rounds' \
  '(-m --match)'{-m,--match}'+[score for matching bases]:score' \
  '(-n --mismatch)'{-n,--mismatch}'+[score for mismatching bases]:score' \
  '(-g --gap)'{-g,--gap}'+[gap penalty (negative)]:penalty' \
  '(-u --min-unitig-size)'{-u,--min-unitig-size}'+[minimal unitig size]:size' \
  '--graphical-fragment-assembly=[print assembly graph in GFA format]:file:_files' \
  '--resume[resume previous run from last checkpoint]' \
  '--disable-checkpoints[disable checkpoint file creation]' \
  '(-t --threads)'{-t,--threads}'+[number of threads]:threads' \
  '*:sequences:_files' && ret=0

return ret
