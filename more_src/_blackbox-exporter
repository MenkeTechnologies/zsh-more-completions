#compdef blackbox-exporter blackbox_exporter
# _blackbox-exporter — Prometheus blackbox_exporter (HTTP/HTTPS/TCP/ICMP/DNS/gRPC probes for endpoint monitoring)
# upstream: https://github.com/prometheus/blackbox_exporter
# Flags from main.go on tip + kingpinflag/web (--web.listen-address, --web.systemd-socket, --web.config.file) + promslog (--log.level, --log.format).

_blackbox-exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--config.file=[blackbox exporter configuration file]:file:_files' \
        '--timeout-offset=[seconds subtracted from probe timeout]:sec:' \
        '--config.check[validate config file and exit]' \
        '--log.prober=[log level for probe request logs]:level:(debug info warn error)' \
        '--config.enable-auto-reload[reload config file at --config.auto-reload-interval]' \
        '--config.auto-reload-interval=[config auto-reload check interval (seconds)]:sec:' \
        '--history.limit=[max items kept in probe history]:n:' \
        '--web.external-url=[external URL under which exporter is reachable]:url:_urls' \
        '--web.route-prefix=[prefix for internal web routes]:path:' \
        '*--web.listen-address=[listen address (repeatable for systemd socket activation)]:addr:' \
        '--web.systemd-socket[use systemd socket activation listener instead of port]' \
        '--web.config.file=[path to TLS/auth config file]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)'
}

_blackbox-exporter "$@"
