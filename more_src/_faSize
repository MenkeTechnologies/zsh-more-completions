#compdef faSize
# print total base count in fa or 2bit files

local ret=1

_arguments -s -S \
  '-detailed[output name and size of each record, nothing else]' \
  '-tab[output statistics in a tab separated format]' \
  '-veryDetailed[output name, size, #Ns, #real, #upper, #lower of each record]' \
  '*:fasta or 2bit file:_files -g "*.(fa|fasta|2bit)"' && ret=0

return ret
