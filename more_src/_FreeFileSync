#compdef FreeFileSync
# Documentation: https://freefilesync.org/manual.php?topic=command-line
# FreeFileSync: folder comparison and synchronization tool

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[display the syntax overview]' \
  '-dirpair[replace the source/target directories of a config]:source:_files -/:target:_files -/' \
  '*:config file:_files -g "*.ffs_(batch|gui) *.xml"' && ret=0

return ret
