#compdef square
# Documentation: https://man.archlinux.org/search?q=square
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize Square CLI configuration'
  'get:make a GET request to the Square API'
  'post:make a POST request to the Square API'
  'put:make a PUT request to the Square API'
  'delete:make a DELETE request to the Square API'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--access-token=[Square access token]:token:' \
  '--config=[config file]:file:_files -g "*.toml"' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--profile=[config profile]:profile:' \
  '--sandbox[use Square sandbox environment]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'square command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get|post|put|delete)
        local -a paths=(
          'v2/locations:locations endpoint'
          'v2/payments:payments endpoint'
          'v2/customers:customers endpoint'
          'v2/catalog:catalog endpoint'
          'v2/orders:orders endpoint'
          'v2/refunds:refunds endpoint'
          'v2/terminal/checkouts:terminal checkouts'
          'v2/team-members:team members endpoint'
          'v2/inventory:inventory endpoint'
          'v2/invoices:invoices endpoint'
          'v2/subscriptions:subscriptions endpoint'
          'v2/webhooks:webhooks endpoint'
        )
        _describe -t paths 'API path' paths && ret=0
        _arguments \
          '(-d --data)'{-d+,--data=}'[request body data]:json:' \
          '*'{-H+,--header=}'[HTTP header]:header:' \
          '*'{-q+,--query=}'[query parameter key=value]:query:' \
          '--idempotency-key=[idempotency key]:key:' \
          '--api-version=[Square API version]:version:' && ret=0 ;;
      (init)
        _arguments \
          '--access-token=[access token to save]:token:' \
          '--profile=[profile to create]:profile:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
