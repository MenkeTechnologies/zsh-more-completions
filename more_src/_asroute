#compdef asroute
# Documentation: https://man.archlinux.org/search?q=asroute
# Reference accessed: 2026-05-16

# stevenpack/asroute — stdin filter for `traceroute -a` lines; no CLI flags; Homebrew: Formula/a/asroute.rb

local ret=1
_message -e args 'asroute: pipe output of `traceroute -a` (no options; see README)'
_arguments -s '*:: :_default' && ret=0
return ret
