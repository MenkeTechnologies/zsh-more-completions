# SU2 discrete adjoint CFD solver module (algorithmic differentiation build)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --dryrun)'{-d,--dryrun}'[only run preprocessing using a dummy geometry]' \
  '(-t --threads)'{-t,--threads}'[OpenMP threads per MPI rank]:threads:' \
  '--thread_multiple[request MPI_THREAD_MULTIPLE thread support]' \
  '*:config file:_files -g "*.cfg"' && ret=0

return ret
