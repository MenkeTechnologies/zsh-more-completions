#compdef akka-cluster

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'join:request a JOIN node with the specified URL'
  'leave:request that the node with URL LEAVE the cluster'
  'down:mark the node with URL as DOWN'
  'member-status:ask the member node for its current status'
  'members:ask the cluster for addresses of current members'
  'unreachable:ask the cluster for addresses of unreachable members'
  'cluster-status:ask the cluster for its current status'
  'leader:ask the cluster who the current leader is'
  'is-singleton:check if the cluster is a singleton cluster'
  'is-available:check if the member node is available'
)

_arguments -C \
  '1:node hostname:_hosts' \
  '2:jmx port:' \
  '3: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'akka-cluster subcommand' subcommands && ret=0
    ;;
esac

return ret
