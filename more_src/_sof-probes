#compdef sof-probes
# _sof-probes — extract Sound Open Firmware probe streams (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/probes/probes_main.c (getopt).

_sof-probes() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-p+[parse an extracted probe data file]:file:_files'
        '-l[log to stdout instead of demuxing to files]'
        '1:buffer id or input file:_files'
    )
    _arguments -s $args
}

_sof-probes "$@"
