#compdef mri_compute_volume_fractions
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_compute_volume_fractions
# FreeSurfer compute cortex/subcort/wm/csf partial volume fractions

local ret=1

_arguments -s -S \
  '--o[output stem (cortex subcort_gm wm csf)]:outstem:_files' \
  '--reg[registration (LTA or reg.dat)]:regfile:_files' \
  '--usf[upsample factor (default 2)]:USF:' \
  '--regheader[use subject header registration]:subject:' \
  '--r[resolution, sets USF=round(1/res)]:res:' \
  '--seg[use segfile instead of aseg.mgz]:segfile:_files' \
  '--wsurf[white surface (default white)]:wsurf:_files' \
  '--psurf[pial surface (default pial)]:psurf:_files' \
  '--no-aseg[do not include aseg]' \
  '--stack[ctx subcortgm wm csf into one multi-frame file]:stackfile:_files' \
  '--gm[ctx+subcortgm into a single-frame file]:gmfile:_files' \
  '--no-fill-csf[do not fill surrounding extracerebral CSF]' \
  '--dil[for xCSF fill, dilate by N (default 3)]:N:' \
  '--out-seg[save seg after adding xcsf voxels]:outseg:_files' \
  '--ttseg[save tissue type segmentation]:ttseg:_files' \
  '--ttseg-ctab[save tissue type segmentation ctab]:ctab:_files' \
  '--mgz[output mgz format]' \
  '--mgh[output mgh format]' \
  '--nii[output nii format]' \
  '--nii.gz[output nii.gz format]' \
  '--ttype+head[use default+head tissue type info]' \
  '--vg-thresh[threshold for LTAconcat mismatch]:threshold:' \
  '--debug[turn on debugging]' \
  '--checkopts[check options and exit]' \
  '--help[print help]' \
  '--version[print version]' && ret=0

return ret
