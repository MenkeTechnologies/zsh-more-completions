#compdef kinde

_kinde() {
    local line state
    local -a commands
    commands=(
        'login:Login to Kinde'
        'logout:Logout from Kinde'
        'whoami:Show current user'
        'manage:Manage Kinde resources'
        'completion:Generate shell completions'
        'version:Show version'
        'help:Show help'
    )

    _arguments -C \
        '--domain[Kinde business domain]:domain:' \
        '--client_id[M2M client ID]:id:' \
        '--client_secret[M2M client secret]:secret:' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kinde command' commands
            ;;
        args)
            case $line[1] in
                completion)
                    _arguments '1:shell:(bash fish powershell zsh)'
                    ;;
            esac
            ;;
    esac
}

_kinde "$@"
