#compdef kinde
# Documentation: https://github.com/kinde-oss/kinde-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: --domain is the only root persistent flag;
# --client_id/--client_secret are flags on the `login` subcommand only.

_kinde() {
    local line state
    local -a commands
    commands=(
        'login:Authenticate with Kinde'
        'logout:Remove authentication credentials'
        'whoami:Show current authenticated token details'
        'manage:Access the management API'
        'version:Show current version and check for updates'
        'completion:Generate shell completion script'
        'help:Show help for commands'
    )

    _arguments -C \
        '--domain=[Kinde domain (environment) to work against]:domain:' \
        '(-h --help)'{-h,--help}'[Show help information]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kinde command' commands
            ;;
        args)
            case $line[1] in
                login)
                    _arguments \
                        '--domain=[Kinde domain (environment) to work against]:domain:' \
                        '--client_id=[Client ID to use]:id:' \
                        '--client_secret=[Client secret to use (switches to client_credentials)]:secret:'
                    ;;
                completion)
                    _arguments '1:shell:(bash fish powershell zsh)'
                    ;;
            esac
            ;;
    esac
}

_kinde "$@"
