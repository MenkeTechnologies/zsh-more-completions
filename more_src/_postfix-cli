#compdef postfix-cli
# _postfix-cli — Wietse Venema Postfix mail transfer agent CLI alias (vdukhovni team, C); custom argparse
# upstream: https://github.com/vdukhovni/postfix

_postfix-cli() {
    local -a sub=(
        'start:start postfix'
        'start-fg:start postfix in foreground'
        'stop:stop postfix'
        'abort:abort postfix'
        'reload:reload configuration'
        'flush:flush deferred queue'
        'check:check configuration syntax'
        'status:show status'
        'set-permissions:set permissions'
        'upgrade-configuration:upgrade configuration'
        'logrotate:rotate logs'
        'tls:tls helper'
        'reset:reset postfix'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config dir]:dir:_files -/' \
        '-D[debug mode]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'postfix subcommand' sub ;;
    esac
}

_postfix-cli "$@"
