#compdef auval
# Documentation: auval -h (AU Validation Tool 1.10.0)
# Source: Apple AudioUnit validation tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help]' \
    '(- *)-vers[print version]' \
    '(- *)-versh[print version as 8-digit hex]' \
    '(-a -al -l -s -v -vt -t -f)-a[list all available AudioUnits]' \
    '(-a -al -l -s -v -vt -t -f)-al[list all AUs with location]' \
    '(-a -al -l -s -v -vt -t -f)-l[list all AUs without instantiating]' \
    '(-a -al -l -s -v -vt -t -f)-s+[list AUs of TYPE]:type:' \
    '(-a -al -l -s -v -vt -t -f)-v[validate by TYPE SUBT MANU]:type:' \
    '(-a -al -l -s -v -vt -t -f)-vt[iterate AUs of TYPE+MANU]:type:' \
    '(-a -al -l -s -v -vt -t -f)-t[validate by TYPE MANU SUBT (alternate order)]:type:' \
    '(-a -al -l -s -v -vt -t -f)-f+[full path to command file]:file:_files' \
    '-oop[load AU out-of-process]' \
    '-strict[enforce all strict-mode checks]' \
    '-strict_SP[enforce AudioUnitScheduleParameter check]' \
    '-strict_DefP[enforce parameter default-in-range check]' \
    '-strict_CPUL[enforce CPULoad implementation check]' \
    '-de[terminate on first error]' \
    '-dw[terminate on first warning]' \
    '-q[quiet (only errors/warnings)]' \
    '-qp[do not print parameter/Factory Presets info]' \
    '-r+[repeat validation N times]:n:' \
    '-stress[run multi-thread stress test]:seconds:' \
    '-real-time-safety[run real-time safety test (needs sudo)]' \
    '-o[basic open+initialize test only]' \
    '-w[wait after finishing (for memory profiling)]' \
    '-c[continue batch on error]' \
    '-comp[open AU as component (not plugin)]' \
    '*:component IDs (TYPE SUBT MANU):' \
    && ret=0

return ret
