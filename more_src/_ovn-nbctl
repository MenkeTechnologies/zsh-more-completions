#compdef ovn-nbctl
# Documentation: https://man7.org/linux/man-pages/man8/ovn-nbctl.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize NB database'
  'show:show NB resources'
  'ls-add:add logical switch'
  'ls-del:delete logical switch'
  'ls-list:list logical switches'
  'lsp-add:add logical switch port'
  'lsp-del:delete switch port'
  'lsp-list:list switch ports'
  'lsp-get-parent:get LSP parent'
  'lsp-get-tag:get LSP tag'
  'lsp-set-addresses:set LSP addresses'
  'lsp-get-addresses:get LSP addresses'
  'lsp-set-port-security:set port security'
  'lsp-get-port-security:get port security'
  'lsp-get-up:get LSP up state'
  'lsp-set-enabled:enable/disable LSP'
  'lsp-get-enabled:get enabled state'
  'lsp-set-type:set LSP type'
  'lsp-get-type:get LSP type'
  'lsp-set-options:set LSP options'
  'lsp-get-options:get LSP options'
  'lsp-set-dhcpv4-options:set DHCPv4 options'
  'lsp-get-dhcpv4-options:get DHCPv4 options'
  'lsp-set-dhcpv6-options:set DHCPv6 options'
  'lsp-get-dhcpv6-options:get DHCPv6 options'
  'lsp-get-ls:get LSP logical switch'
  'lsp-attach-mirror:attach mirror'
  'lsp-detach-mirror:detach mirror'
  'acl-add:add ACL'
  'acl-del:delete ACL'
  'acl-list:list ACLs'
  'qos-add:add QoS'
  'qos-del:delete QoS'
  'qos-list:list QoS'
  'meter-add:add meter'
  'meter-del:delete meter'
  'meter-list:list meters'
  'lr-add:add logical router'
  'lr-del:delete logical router'
  'lr-list:list logical routers'
  'lrp-add:add router port'
  'lrp-del:delete router port'
  'lrp-list:list router ports'
  'lrp-set-enabled:enable/disable LRP'
  'lrp-get-enabled:get enabled state'
  'lrp-set-gateway-chassis:set gateway chassis'
  'lrp-del-gateway-chassis:delete gateway chassis'
  'lrp-get-gateway-chassis:get gateway chassis'
  'lr-route-add:add static route'
  'lr-route-del:delete static route'
  'lr-route-list:list static routes'
  'lr-policy-add:add router policy'
  'lr-policy-del:delete router policy'
  'lr-policy-list:list router policies'
  'lr-nat-add:add NAT rule'
  'lr-nat-del:delete NAT rule'
  'lr-nat-list:list NAT rules'
  'lb-add:add load balancer'
  'lb-del:delete load balancer'
  'lb-list:list load balancers'
  'ls-lb-add:add LB to switch'
  'ls-lb-del:remove LB from switch'
  'ls-lb-list:list switch LBs'
  'lr-lb-add:add LB to router'
  'lr-lb-del:remove LB from router'
  'lr-lb-list:list router LBs'
  'dhcp-options-create:create DHCP options'
  'dhcp-options-list:list DHCP options'
  'dhcp-options-del:delete DHCP options'
  'dhcp-options-set-options:set DHCP option values'
  'dhcp-options-get-options:get DHCP option values'
  'pg-add:add port group'
  'pg-set-ports:set ports in group'
  'pg-get-ports:get ports in group'
  'pg-del:delete port group'
  'ha-chassis-group-add:add HA chassis group'
  'ha-chassis-group-del:delete HA chassis group'
  'ha-chassis-group-list:list HA chassis groups'
  'fwd-group-add:add forwarding group'
  'fwd-group-del:delete forwarding group'
  'fwd-group-list:list forwarding groups'
  'list:list records'
  'find:find records'
  'get:get column value'
  'set:set column value'
  'add:add to set column'
  'remove:remove from set column'
  'clear:clear column'
  'create:create record'
  'destroy:destroy record'
  'wait-until:wait until condition'
  'comment:add comment'
  'run:run as daemon'
  'exit:exit daemon'
)

_arguments -C \
  '--no-wait[do not wait]' \
  '--wait=[wait mode]:mode:(none sb hv)' \
  '--db=[OVSDB remote]:remote:' \
  '--leader-only[connect only to leader]' \
  '--no-leader-only[connect to any]' \
  '--no-syslog[no syslog]' \
  '--oneline[oneline output]' \
  '--dry-run[do not commit]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '--print-wait-time[print wait time]' \
  '(-f --format)'{-f,--format=}'[output format]:fmt:(table list html csv json)' \
  '(-d --data)'{-d,--data=}'[data format]:fmt:(string bare json)' \
  '--no-headings[no headings]' \
  '--pretty[pretty JSON]' \
  '--bare[bare output]' \
  '(-p --private-key)'{-p,--private-key=}'[private key]:file:_files' \
  '(-c --certificate)'{-c,--certificate=}'[certificate]:file:_files' \
  '(-C --ca-cert)'{-C,--ca-cert=}'[CA cert]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovn-nbctl subcommand' subcommands && ret=0
    ;;
esac

return ret
