#compdef obsrms
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/obsrms.html
# MIRIAD obsrms - compute the theoretical rms noise of an observation

local ret=1

_arguments -s -S \
  'tsys=[SSB system temperature in Kelvin]:tsys' \
  'jyperk=[antenna gain in units Jy/K]:jyperk' \
  'antdiam=[antenna diameter in meters]:antdiam' \
  'lambda=[wavelength in millimeters]:lambda' \
  'freq=[frequency in GHz]:freq' \
  'theta=[beamsize in arcsec]:theta' \
  'nants=[number of antennas in array]:nants' \
  'bw=[bandwidth in MHz for continuum]:bw' \
  'deltav=[velocity resolution in km/s]:deltav' \
  'inttime=[total integration time on source in minutes]:inttime' \
  'coreta=[correlator efficiency factor]:coreta' \
  'rmsphase=[RMS phase noise in degrees]:rmsphase' && ret=0

return ret
