#compdef gen-shacl
# _gen-shacl — generate SHACL shapes from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/shaclgen.py (click).

_gen-shacl() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(ttl|shacl|nt|rdf)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(turtle xml nt json-ld n3)'
        '--closed[generate closed shapes]'
        '--non-closed[generate non-closed shapes]'
        '--suffix=[suffix appended to generated shape IRIs]:suffix:'
        '--include-annotations[include SHACL sh:order / sh:description annotations]'
        '--exclude-annotations[strip SHACL annotations from output]'
        '--exclude-imports[exclude imports from generated shapes]'
        '--include-imports[include imports]'
        '--use-class-uri-names[name shapes by class URI]'
        '--use-native-names[name shapes by LinkML class name]'
        '--expand-subproperty-of[expand subPropertyOf into shape properties]'
        '--no-expand-subproperty-of[do not expand subPropertyOf]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-shacl "$@"
