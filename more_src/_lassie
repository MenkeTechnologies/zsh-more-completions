#compdef lassie
# _lassie — minimal universal retrieval client for IPFS and Filecoin (filecoin-project/lassie)
# upstream: https://github.com/filecoin-project/lassie
# Subcommands from cmd/lassie/main.go; flags from cmd/lassie/{flags,fetch,daemon}.go.

_lassie() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--verbose[enable verbose mode for logging]' \
        '--very-verbose[enable very-verbose mode for debugging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_lassie_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            local -a common
            common=(
                '--event-recorder-auth=[authorization token for the event-recorder API]:token:'
                '--event-recorder-instance-id=[instance ID sent to the event recorder]:id:'
                '--event-recorder-url=[URL of the event-recorder API]:url:'
                '--exclude-providers=[provider peer IDs to exclude (comma-separated)]:peer ids:'
                '--providers=[explicit provider addresses to use (comma-separated)]:multiaddrs:'
                '--protocols=[retrieval protocols to use (comma-separated)]:protocols:(bitswap graphsync http)'
                '--tempdir=[directory for temporary files]:dir:_files -/'
                '--bitswap-concurrency=[max concurrent bitswap requests]:n:'
                '--bitswap-concurrency-per-retrieval=[max bitswap requests per retrieval]:n:'
                '--global-timeout=[overall retrieval timeout]:duration:'
                '--provider-timeout=[per-provider response timeout]:duration:'
                '--ipni-endpoint=[HTTP endpoint of the IPNI used to discover providers]:url:'
            )
            case $words[1] in
                fetch)
                    _arguments $common \
                        '(-o --output)'{-o+,--output=}'[CAR file to write to (- for stdout)]:file:_files' \
                        '--progress[print progress output]' \
                        '--dag-scope=[traversal scope]:scope:(all entity block)' \
                        '--entity-bytes=[byte range to consider when selecting blocks]:range:' \
                        '--duplicates[allow duplicate blocks in the output CAR]' \
                        '1:CID or CID/path:' && ret=0 ;;
                daemon)
                    _arguments $common \
                        '--address=[address the HTTP server listens on]:addr:' \
                        '--port=[port the HTTP server listens on]:port:' \
                        '--maxblocks=[max blocks per response before closing]:n:' \
                        '--libp2p-conns-lowwater=[libp2p connection low-water mark]:n:' \
                        '--libp2p-conns-highwater=[libp2p connection high-water mark]:n:' \
                        '--concurrent-sp-retrievals=[max simultaneous SP retrievals]:n:' \
                        '--access-token=[require Bearer auth with this token]:token:' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_lassie_commands] )) ||
_lassie_commands() {
    local -a commands
    commands=(
        'daemon:run lassie as an HTTP retrieval daemon'
        'fetch:fetch content from the IPFS / Filecoin network'
        'version:print version information'
    )
    _describe -t commands 'lassie command' commands
}

_lassie "$@"
