#compdef lsd
# Documentation: https://man.archlinux.org/search?q=lsd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[show hidden]' \
  '(-A --almost-all)'{-A,--almost-all}'[show hidden except . ..]' \
  '(--color)--color=[color mode]:c:(always auto never)' \
  '(--icon)--icon=[icon mode]:i:(always auto never)' \
  '(--icon-theme)--icon-theme=[icon theme]:t:(fancy unicode)' \
  '(-F --classify)'{-F,--classify}'[append classifier]' \
  '(-l --long)'{-l,--long}'[long format]' \
  '(-1 --oneline)'{-1,--oneline}'[one per line]' \
  '(-R --recursive)'{-R,--recursive}'[recursive]' \
  '(-d --directory-only)'{-d,--directory-only}'[directory only]' \
  '(--depth)--depth=[depth]:n:' \
  '(-h --human-readable)'{-h,--human-readable}'[human-readable sizes]' \
  '(--size)--size=[size mode]:s:(default short bytes)' \
  '(--total-size)--total-size[show total size for dirs]' \
  '(--date)--date=[date format]:d:(date locale relative +FORMAT)' \
  '(--timesort -t)'{-t,--timesort}'[sort by time]' \
  '(--sizesort -S)'{-S,--sizesort}'[sort by size]' \
  '(--extensionsort -X)'{-X,--extensionsort}'[sort by extension]' \
  '(--versionsort -v)'{-v,--versionsort}'[version sort]' \
  '(--sort)--sort=[sort by]:s:(size time version extension git none)' \
  '(--no-sort -U)'{-U,--no-sort}'[no sort]' \
  '(--reverse -r)'{-r,--reverse}'[reverse]' \
  '(--group-dirs)--group-dirs=[group dirs]:g:(none first last)' \
  '(--group-directories-first)--group-directories-first[dirs first]' \
  '(--blocks)--blocks=[blocks csv]:list:(permission user group context size date name inode links blocks git)' \
  '(--inode -i)'{-i,--inode}'[show inode]' \
  '(--git)--git[show git status]' \
  '(--no-symlink)--no-symlink[no symlink target]' \
  '(--ignore-glob)*--ignore-glob=[glob to ignore]:g:' \
  '(--system-protected)--system-protected[show system protected]' \
  '(--header)--header[show table header]' \
  '(--hyperlink)--hyperlink=[hyperlinks]:h:(always auto never)' \
  '(--permission)--permission=[permission format]:p:(rwx octal attributes disable)' \
  '(--no-symlink)--no-symlink[no symlink follow]' \
  '(--config-file)--config-file=[config file]:file:_files -g "*.yaml *.yml"' \
  '(--literal -N)'{-N,--literal}'[literal output]' \
  '(--tree)--tree[tree view]' \
  '(--truncate-owner-after)--truncate-owner-after=[chars]:n:' \
  '(--truncate-owner-marker)--truncate-owner-marker=[marker]:m:' \
  '*: :_files' && ret=0

return ret
