#compdef synquid
# ============================================================================
#  _synquid — synquid: Polikarpova's polymorphic-refinement-type program
#             synthesizer (POPL'16, PLDI'16)
#
#  Source-direct extraction from
#    https://github.com/nadia-polikarpova/synquid/blob/master/src/Synquid.hs
#    https://github.com/ndmitchell/cmdargs (the cmdargs library by
#    Neil Mitchell)
#
#  Maintained by Nadia Polikarpova (nadia-polikarpova/synquid; assistant
#  prof, UCSD CSE).  148 GH stars.  Synquid SYNTHESIZES Haskell-like
#  functional programs from polymorphic refinement type specifications.
#  Given a refinement type `replicate :: n:Nat -> x:a -> {List a | len _v
#  = n}`, Synquid SYNTHESIZES the program `replicate = \n. \x. if n <= 0
#  then Nil else Cons x (replicate (n - 1) x)`.  Sister tools: Liquid
#  Haskell (refinement type checker, in corpus via _liquid), Coq (proof
#  assistant, in corpus), Lean 4 (in corpus, R326), Z3 (SMT solver, in
#  corpus via _z3), Rosette (in corpus).
#
#  CLI library taxonomy update: 3rd Haskell CLI library — Neil
#  Mitchell's **cmdargs** (ndmitchell/cmdargs).  Haskell ecosystem
#  now has 3 documented CLI libraries (R270 optparse-applicative +
#  R373 stdlib System.Console.GetOpt + R374 cmdargs).
#
#  cmdargs (ndmitchell/cmdargs) is Neil Mitchell's ANNOTATION-DSL CLI
#  library for Haskell — used by HLint, HLint, Hoogle, Shake, Ghcid,
#  Bake, Tamarin Prover, HLedger, Hindent, Weeder, c2hsc, blackstar,
#  HaskellR, kite-lang, Synquid, and many other Haskell tools.  cmdargs
#  uses Haskell's `Data` and `Typeable` typeclasses (deriving instance)
#  + a fluent `&=` annotation operator + `cmdArgs`/`cmdArgsMode`/
#  `cmdArgsRun` entry points to implement a CLI parser entirely from
#  default-value definitions decorated with annotations.
#
#  cmdargs Implicit-mode API:
#    {-# LANGUAGE DeriveDataTypeable #-}
#    import System.Console.CmdArgs
#
#    data Options = Synthesis {
#      file       :: String,        -- positional 0
#      libs       :: [String],      -- remaining positional
#      app_max    :: Int,           -- --app-max (auto-kebab-case)
#      verbose_   :: Bool,
#      output     :: OutputFormat
#    } deriving (Data, Typeable, Show, Eq)
#
#    synt = Synthesis {
#      file    = ""           &= typFile &= argPos 0,
#      libs    = []           &= args &= typ "FILES",
#      app_max = 3            &= help "Max depth (default: 3)"
#                             &= groupname "Explorer parameters",
#      verbose_ = False       &= help "Verbose output" &= name "v",
#      output  = Plain        &= help "Output format" &= typ "FORMAT"
#    } &= auto &= help "Synthesize goals from input file"
#
#    mode = cmdArgsMode $ synt &=
#      help "Synquid program synthesizer" &=
#      program "synquid" &=
#      summary "synquid v0.4"
#
#    main = do
#      res <- cmdArgsRun mode
#      case res of
#        Synthesis file libs ... -> runOnFile ...
#
#  cmdargs distinctive features:
#    - ANNOTATION-DSL using `&=` OPERATOR — fluent annotations applied
#      to DEFAULT VALUES via `&=` to attach metadata (help, name,
#      groupname, typ, opt, args, argPos, etc.)
#    - REQUIRES `{-# LANGUAGE DeriveDataTypeable #-}` and `deriving (Data,
#      Typeable, Show, Eq)` on the option record — uses GHC Generic
#      Programming via the `Data.Data` typeclass to introspect the record
#      structure at runtime
#    - AUTOMATIC kebab-case derivation — field name `app_max` becomes
#      `--app-max`, `out_file` becomes `--out-file`
#    - TRAILING UNDERSCORE TRICK — field name `log_` becomes `--log`
#      (suffix underscore is stripped, allows using Haskell keywords
#      as flag names)
#    - SUBCOMMANDS via `modes [mode1, mode2, mode3]` — defines multiple
#      mode constructors of the same data type as subcommands
#    - `&= help "..."` annotation for help text per option
#    - `&= name "x"` annotation for short name (single char or alias)
#    - `&= groupname "..."` annotation for section grouping in help
#    - `&= typ "FOO"` annotation for VALUE PLACEHOLDER in help
#    - `&= typFile` annotation marks option as taking a file path
#    - `&= typDir` annotation marks option as taking a directory path
#    - `&= opt "X"` annotation makes value-taking option OPTIONAL with
#      default-on-empty value X (e.g. `-o` vs `-o file.txt`)
#    - `&= args` annotation marks field as collecting remaining positional
#      args
#    - `&= argPos N` annotation marks field as the Nth positional arg
#    - `&= auto` annotation marks a mode as DEFAULT when no subcommand
#      specified
#    - `&= verbosity` annotation enables built-in --verbose/--quiet
#    - `&= explicit` annotation requires explicit `&= name` (no
#      auto-derivation)
#    - `&= ignore` annotation excludes field from CLI
#    - `&= details ["..."]` annotation adds detailed help text
#    - `cmdArgs :: Data a => a -> IO a` — Implicit-mode entry point
#      (one-shot)
#    - `cmdArgsMode :: Data a => a -> Mode (CmdArgs a)` — build a Mode
#      for reuse
#    - `cmdArgsRun :: Mode (CmdArgs a) -> IO a` — run a built Mode
#    - AUTOMATIC --help / --version / --numeric-version / --color flags
#      injected by cmdargs (no need to define manually)
#    - PROCESS EXIT model — cmdargs calls `exitWith` on parse error /
#      --help / --version (different from System.Console.GetOpt's
#      pure-function model)
#    - Two API levels: `Implicit` (record + annotations + Data typeclass,
#      magic but concise) and `Explicit` (manual `Mode`/`Flag` records,
#      verbose but introspectable)
#  Distinct from R270 Haskell optparse-applicative (functional applicative
#  combinator with `<$>`/`<*>`/`<|>` — pure-typed, no Data typeclass
#  magic), R373 Haskell base stdlib System.Console.GetOpt (record-based
#  option transformations with `OptDescr a` data type, pure `getOpt`
#  function returning triple result, ships with base), R275 Rust
#  clap-derive (struct + clap-derive macro — closest cross-language
#  analog but Rust compile-time macros vs cmdargs's runtime Data
#  introspection), R322 Java JCommander (annotation-driven `@Parameter`
#  field annotations with reflection-based binding), R275 case-app
#  (case class annotations with Scala macros).  cmdargs's approach:
#  RUNTIME Data INTROSPECTION + `&=` ANNOTATION DSL + AUTOMATIC
#  kebab-case + TRAILING UNDERSCORE TRICK + SUBCOMMANDS via `modes`
#  + AUTOMATIC --help/--version/--numeric-version/--color + PROCESS
#  EXIT model — corpus's **first documented runtime-Data-introspection-
#  annotation-DSL Haskell CLI library**.  Brings cross-language CLI
#  library taxonomy variant count to 113; Haskell ecosystem now has
#  3 documented CLI libraries (tied with Common Lisp 3 + Clojure 3
#  + Nim 3 + C++ 3 + TypeScript-Node 3 below the multi-library
#  leaders Rust 9 + Go 9 + Python 5 + OCaml 5 + Scala 5 + Java 5).
#
#  Surface (verbatim from Synquid.hs `synt` definition with field-
#  name auto-kebab applied; cmdargs default --help/--version/--verbose/
#  --quiet/--numeric-version/--color added automatically):
#
#  Input (positional):
#    INPUT                        Input .sq specification file (required)
#    LIBS...                      Additional library files (FILES)
#
#  Synthesis options:
#    --only=GOAL,...              Only synthesize the specified functions
#
#  Explorer parameters:
#    --app-max=N                  Max depth of an application term (3)
#    --scrutinee-max=N            Max depth of match scrutinee (1)
#    --match-max=N                Max depth of matches (2)
#    -x, --aux-max=N              Max depth of auxiliary functions (1)
#    --fix=STRATEGY               Termination metric strategy:
#                                 AllArguments / FirstArgument /
#                                 DisableFixpoint / Nonterminating
#                                 (default: FirstArgument)
#    --generalize-preds           Polymorphic refinement recursion (T)
#    --explicit-match             Do not abduce match scrutinees (F)
#    --unfold-locals              Use all variables in scrutinee abduction
#    -p, --partial                Generate best-effort partial solutions
#    --incremental                Subtyping during bottom-up phase (T)
#    --consistency                Check incomplete-app consistency (T)
#    -z, --memoize                Use memoization (F)
#    -s, --symmetry               Use symmetry reductions (F)
#
#  Solver parameters:
#    --lfp                        Use least fixpoint solver (F)
#    --bfs-solver                 BFS instead of MARCO (F)
#
#  Output:
#    -o, --out-file[=FILE]        Generate Haskell output file (optional
#                                 value via `&= opt ""`)
#    --out-module=NAME            Haskell module name (default: from file)
#    --output=FORMAT              Output format: Plain | Ansi | Html
#                                 (default: Plain)
#    --resolve                    Resolve only (no type check or synthesis)
#    --print-spec                 Show spec of each synthesis goal (T)
#    --print-stats                Show spec and solution size (F)
#    -l, --log=N                  Logger verbosity level (default 0)
#
#  Default cmdargs flags (auto-injected by cmdargs runtime):
#    -?, --help                   Show help
#    -V, --version                Show version
#    --numeric-version            Show numeric version
#    --color, --colour            Use color output
#
#  Dup-skipped neighbors during hunt (in corpus, also cmdargs-based,
#  already documented under different attribution):
#    - hlint / hoogle / shake / ghcid (Neil Mitchell tools, ALL IN
#      CORPUS, ALL cmdargs-based)
#    - tamarin-prover (IN CORPUS via _tamarin completion — uses cmdargs)
#    - hledger / hledger-ui / hledger-web / hledger-iadd (IN CORPUS —
#      use cmdargs)
#    - hindent / weeder / hpack (IN CORPUS — use cmdargs)
#    - c2hsc / kite / blackstar / HaskellR (smaller user bases; HaskellR
#      ships single-letter binary `H` which conflicts with shell idioms)
#    - hledger-stockquotes (IN CORPUS via _hledger-stockquotes)
# ============================================================================

_synquid() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--only=[only synthesize the specified comma-separated functions]:goals' \
    '--app-max=[max depth of an application term (default 3)]:n' \
    '--scrutinee-max=[max depth of match scrutinee (default 1)]:n' \
    '--match-max=[max depth of matches (default 2)]:n' \
    '(-x --aux-max)'{-x,--aux-max}'=[max depth of auxiliary functions (default 1)]:n' \
    '--fix=[termination metric strategy]:strategy:(AllArguments FirstArgument DisableFixpoint Nonterminating)' \
    '--generalize-preds[polymorphic refinement recursion]' \
    '--explicit-match[do not abduce match scrutinees]' \
    '--unfold-locals[use all variables in scrutinee abduction]' \
    '(-p --partial)'{-p,--partial}'[generate best-effort partial solutions]' \
    '--incremental[subtyping during bottom-up phase (default true)]' \
    '--consistency[check incomplete-app consistency (default true)]' \
    '(-z --memoize)'{-z,--memoize}'[use memoization]' \
    '(-s --symmetry)'{-s,--symmetry}'[use symmetry reductions]' \
    '--lfp[use least fixpoint solver]' \
    '--bfs-solver[BFS instead of MARCO for second-order constraints]' \
    '(-o --out-file)'{-o,--out-file}'=-[generate Haskell output file (optional value)]::file:_files -g "*.hs"' \
    '--out-module=[Haskell module name (default: from file)]:name' \
    '--output=[output format]:format:(Plain Ansi Html)' \
    '--resolve[resolve only (no type check or synthesis)]' \
    '--print-spec[show spec of each synthesis goal (default true)]' \
    '--print-stats[show spec and solution size]' \
    '(-l --log)'{-l,--log}'=[logger verbosity level (default 0)]:n' \
    '(-\? --help)'{-\?,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--numeric-version[show numeric version]' \
    '--color[use color output]' \
    '--colour[use colour output]' \
    '1:input file:_files -g "*.sq"' \
    '*:library file:_files -g "*.sq"'
}

_synquid "$@"
