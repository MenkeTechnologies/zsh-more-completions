#compdef unique
# Documentation: https://www.ccp4.ac.uk/html/unique.html
# CCP4: generate a complete list of unique reflections for a cell and symmetry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLOUT[output MTZ reflection file]:mtz:_files' \
  '*:keyword:(CELL RESOLUTION SYMMETRY DEFAULT TITLE LABOUT RUN GO END)' && ret=0

return ret
