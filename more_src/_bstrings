#compdef bstrings
# Documentation: https://github.com/EricZimmerman/bstrings
# bstrings - binary string extractor with regex support

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f[file to search]:file:_files' \
  '-d[directory to recursively process]:directory:_directories' \
  '-o[file to save results to]:file:_files' \
  '-a[look for ASCII strings]:bool:(true false)' \
  '-u[look for Unicode strings]:bool:(true false)' \
  '-m[minimum string length]:length' \
  '-b[chunk size in MB (1-1024)]:size' \
  '-q[quiet mode]' \
  '-s[really quiet mode]' \
  '-x[maximum string length]:length' \
  '-p[display built in regular expressions]' \
  '--ls=[string to look for]:string' \
  '--lr=[regex to look for]:regex' \
  '--fs=[file containing strings to look for]:file:_files' \
  '--fr=[file containing regex patterns]:file:_files' \
  '--ar=[character range for code page strings]:range' \
  '--ur=[character range for Unicode strings]:range' \
  '--cp=[code page to use]:codepage' \
  '--mask=[file mask for directory searches]:mask' \
  '--ms=[maximum file size in bytes]:bytes' \
  '--ro[list regex-matched text only]' \
  '--off[show offset to hit after string]' \
  '--sa[sort results alphabetically]' \
  '--sl[sort results by length]' \
  '--debug[show debug information]' \
  '--trace[show trace information]' && ret=0

return ret
