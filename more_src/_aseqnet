#compdef aseqnet
# Documentation: https://manpages.debian.org/aseqnet.1
# Source: alsa-utils — bridge ALSA sequencer events over TCP between machines.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[TCP port number or TCP service name]:port:' \
    '-s[subscribe address for read automatically]:client:port:' \
    '-d[subscribe address for write automatically]:client:port:' \
    '-n[MIDI name of the process]:name:' \
    '-v[verbose mode]' \
    '*:remote host:_hosts' \
    && ret=0

return ret
