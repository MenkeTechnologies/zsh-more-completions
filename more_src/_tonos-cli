#compdef tonos-cli ever-cli
# Documentation: https://github.com/EverX-Labs/ever-cli
# tonos-cli / ever-cli - TON/Everscale smart-contract command-line client

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'genphrase:generate a seed phrase'
  'genpubkey:generate a public key from a seed phrase'
  'getkeypair:create a key pair file'
  'genaddr:generate a contract address'
  'deploy:deploy a contract'
  'deploy_message:generate an offline deploy message'
  'account:check contract status'
  'call:call a contract method'
  'run:run a method locally'
  'runget:run a get-method'
  'message:generate an encrypted message offline'
  'send:broadcast a message'
  'sendfile:broadcast a message from a BOC file'
  'body:generate an internal call payload'
  'decode:decode messages/account data/state init'
  'config:manage configuration'
  'multisig:multisig wallet operations'
  'depool:DePool stake operations'
  'debot:run a DeBot'
  'proposal:create/vote/decode proposals'
  'fee:calculate fees'
  'debug:debug transactions/calls/runs'
  'wait:monitor account changes'
  'query:raw GraphQL queries'
  'dumpconfig:export blockchain config'
  'version:display version'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[force JSON output]' \
  '(-c --config)'{-c,--config}'=[configuration file path]:file:_files' \
  '(-u --url)'{-u,--url}'=[override network URL]:url:' \
  '1:command:->cmd' \
  '*::args:_files' && ret=0

case $state in
  cmd) _describe -t commands 'tonos-cli command' sub && ret=0 ;;
esac

return ret
