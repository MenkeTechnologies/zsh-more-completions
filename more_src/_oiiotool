#compdef oiiotool

# Zsh completion for oiiotool (OpenImageIO image processing tool)

_arguments -s -S \
  '--help[display help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--threads=[number of threads]:threads:' \
  '--frames=[frame range (e.g. 1-10)]:frame range:' \
  '--views=[list of views]:views:' \
  '--wildcardoff[disable wildcard expansion]' \
  '--wildcardon[enable wildcard expansion]' \
  '--no-autopremult[disable automatic premultiplication]' \
  '--autopremult[enable automatic premultiplication]' \
  '--autoorient[automatically orient based on EXIF data]' \
  '--autocc[automatic color conversion]' \
  '--noautocc[disable automatic color conversion]' \
  '--native[keep native pixel data types]' \
  '--cache=[image cache size in MB]:cache size (MB):' \
  '--autotile=[tile size for auto-tiling]:tile size:' \
  '-i[input image file]:input file:_files' \
  '-o[output image file]:output file:_files' \
  '--resize[resize image]:geometry (WxH):' \
  '--fit[fit image within size]:geometry (WxH):' \
  '--crop[crop image]:crop region (WxH+X+Y):' \
  '--trim[trim edges]' \
  '--flip[flip image vertically]' \
  '--flop[flip image horizontally]' \
  '--rotate90[rotate 90 degrees clockwise]' \
  '--rotate180[rotate 180 degrees]' \
  '--rotate270[rotate 270 degrees clockwise]' \
  '--rotate=[rotate by given degrees]:degrees:' \
  '--colorconvert[convert between color spaces]:from space: :to space:' \
  '--tocolorspace[convert to color space]:color space:' \
  '--unpremult[un-premultiply alpha]' \
  '--premult[premultiply alpha]' \
  '--ch[select or rearrange channels]:channel list:' \
  '--chnames[rename channels]:channel names:' \
  '--flatten[flatten deep image]' \
  '--fill[fill with a color value]:fill value:' \
  '--clamp[clamp pixel values]' \
  '--text[render text on image]:text string:' \
  '--info[print image info]' \
  '--stats[print image statistics]' \
  '--hash[print image hash]' \
  '--dumpdata[dump pixel data]' \
  '--metamatch=[metadata name pattern to print]:regex pattern:' \
  '--no-metamatch=[metadata name pattern to exclude]:regex pattern:' \
  '*:file:_files'
