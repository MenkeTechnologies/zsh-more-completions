#compdef imsmooth
# imsmooth: box median, mean, or Gaussian filter a FITS or IRAF image (WCSTools)

local ret=1

_arguments -s -S \
  '-a[mean filter dx x dy pixels]:dx:_message dx' \
  '-g[Gaussian filter dx x dy pixels]:dx:_message dx' \
  '-h[Gaussian half-width at half-height]:halfwidth' \
  '-l[logging interval in lines]:num' \
  '-m[median filter dx x dy pixels]:dx:_message dx' \
  '-o[allow overwriting of input image, else write new one]' \
  '-v[verbose]' \
  '*:FITS file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
