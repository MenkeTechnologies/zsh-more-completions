#compdef freesasa
# Documentation: https://freesasa.github.io/doxygen/CLI.html
# Calculate solvent accessible surface area (SASA)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-w --no-warnings)'{-w,--no-warnings}'[suppress warning messages]' \
  '(-e --error-file)'{-e,--error-file}'=[write errors to file]:file:_files' \
  '(-S --shrake-rupley -L --lee-richards)'{-S,--shrake-rupley}'[use Shrake-Rupley algorithm]' \
  '(-L --lee-richards -S --shrake-rupley)'{-L,--lee-richards}'[use Lee-Richards algorithm]' \
  '(-p --probe-radius)'{-p,--probe-radius}'=[probe radius in Angstroms]:radius' \
  '(-n --resolution)'{-n,--resolution}'=[slices per atom]:slices' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-f --format)'{-f,--format}'=[output format]:format:(json xml pdb cif rsa res seq)' \
  '(-c --config-file)'{-c,--config-file}'=[atomic radii config file]:file:_files' \
  '(-t --n-threads)'{-t,--n-threads}'=[number of parallel threads]:threads' \
  '--radii=[predefined radii set]:radii:(protor naccess)' \
  '--radius-from-occupancy[use occupancy values as atomic radii]' \
  '--cif[process mmCIF input files]' \
  '--unknown=[handling of unknown atoms]:mode:(skip halt guess)' \
  '(-Y --hydrogen)'{-Y,--hydrogen}'[include hydrogen atoms]' \
  '(-H --hetatm)'{-H,--hetatm}'[include HETATM entries]' \
  '(-C --separate-chains)'{-C,--separate-chains}'[calculate SASA per chain]' \
  '(-M --separate-models)'{-M,--separate-models}'[calculate SASA per model]' \
  '(-m --join-models)'{-m,--join-models}'[join all models into one structure]' \
  '(-g --chain-groups)'{-g,--chain-groups}'=[analyze groups of chains]:groups' \
  '*--select=[define groups of atoms for integrated SASA]:selection' \
  '(-d --depth)'{-d,--depth}'=[JSON/XML output depth]:depth:(atom residue chain structure)' \
  '*:structure file:_files -g "*.(pdb|cif)"' && ret=0

return ret
