#compdef tvdisp
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/tvdisp.html
# MIRIAD: display an image on a TV device

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input image]:in:_files' \
  'region=[region of interest]:region:' \
  'range=[min and max scaling values]:range:' \
  'tvchan=[TV channel number]:tvchan:' \
  'incr=[pixel sampling density]:incr:' \
  'tvcorn=[lower-left corner device coords]:tvcorn:' \
  'server=[TV server]:server:' \
  'options=[fiddle,zoom,movie]:options:(fiddle zoom movie)' \
  '*:image:_files' && ret=0

return ret
