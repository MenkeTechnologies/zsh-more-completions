#compdef uf2conv
# UF2 firmware format converter

local ret=1

_arguments -s -S \
  '-b[specify base address]:address:' \
  '-o[specify output file]:output file:_files' \
  '-d[specify device]:device:_files' \
  '-l[list connected devices]' \
  '-c[convert to UF2]' \
  '-f[specify family ID]:family id:' \
  '-D[deploy to device]' \
  '-C[convert from UF2 to bin]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:input file:_files -g "*.(bin|hex|uf2)"' && ret=0

return ret
