#compdef tablemaker
# Documentation: https://github.com/leekgroup/tablemaker
# Tablemaker: prep Cufflinks/StringTie output into Ballgown-readable tables

local ret=1

_arguments -s -S \
  '-p+[number of threads]:int' \
  '-q[quiet, suppress verbose messages]' \
  '-W[run in tablemaker mode]' \
  '-G+[assembly file in GTF format]:gtf file:_files -g "*.(gtf|gff)"' \
  '-o+[output directory]:dir:_files -/' \
  '*:read alignments bam:_files -g "*.bam"' && ret=0

return ret
