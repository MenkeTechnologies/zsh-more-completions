#compdef loclx

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'tunnel:start or manage tunnels'
  'account:manage account'
  'domain:manage reserved domains'
  'endpoint:manage reserved endpoints'
  'service:manage system service'
  'setting:CLI settings'
  'update:check for updates'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '(-f --config)'{-f,--config}'=[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'loclx subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (tunnel)
        _values 'tunnel type/action' \
          'http[HTTP tunnel]' 'tls[TLS tunnel]' 'tcp[TCP tunnel]' 'udp[UDP tunnel]' \
          'config[load tunnel from config]' 'list[list tunnels]' 'stop[stop a tunnel]' && ret=0
        ;;
      (account)
        _values 'account action' login logout status region && ret=0
        ;;
      (domain)
        _values 'domain action' reserve list status delete clear letsencrypt && ret=0
        ;;
      (endpoint)
        _values 'endpoint action' reserve list delete clear && ret=0
        ;;
      (service)
        _values 'service action' install uninstall start stop restart status && ret=0
        ;;
      (setting)
        _values 'setting action' proxy list && ret=0
        ;;
    esac
    ;;
esac

return ret
