#compdef ovs-kmod-ctl
# _ovs-kmod-ctl — Open vSwitch ovs-kmod-ctl manage the Open vSwitch kernel module insertion removal and conflicts (openvswitch team, Bash); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-kmod-ctl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '*:command:(load remove insert remove-datapath-modules upgrade)'
}

_ovs-kmod-ctl "$@"
