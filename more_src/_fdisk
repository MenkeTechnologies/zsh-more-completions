#compdef fdisk

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-i[initialize disk with new MBR]' \
  '-u[update MBR code, preserve partition table]' \
  '-e[edit MBRs on disk interactively]' \
  '-f+[non-standard MBR template]:file:_files' \
  '-c+[cylinders]:cyl:' \
  '-h+[heads]:head:' \
  '-s+[sectors]:sect:' \
  '-S+[disk size]:size:' \
  '-r[read partition specs from stdin]' \
  '-a+[auto-partition style]:style:(boothfs hfs dos raid)' \
  '-d[dump partition table]' \
  '-y[do not ask any questions]' \
  '-t[test if disk is partitioned]' \
  '*:disk:_files -g "/dev/(r)disk*"' && ret=0

return ret
