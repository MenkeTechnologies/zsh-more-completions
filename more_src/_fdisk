#compdef fdisk
# Documentation: fdisk usage on macOS / Darwin
# Source: Darwin fdisk — MBR partition table editor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[initialize disk with new MBR]' \
    '-u[update MBR code, preserve partition table]' \
    '-e[edit MBRs on disk interactively]' \
    '-f+[non-standard MBR template]:mbrboot:_files' \
    '-c+[disk geometry cylinders]:cyl:' \
    '-h+[disk geometry heads]:head:' \
    '-s+[disk geometry sectors]:sect:' \
    '-S+[disk size]:size:' \
    '-r[read partition specs from stdin (implies -i)]' \
    '-a+[auto-partition style]:style:(boothfs hfs dos raid)' \
    '-d[dump partition table]' \
    '-y[do not ask any questions]' \
    '-t[test if disk is partitioned]' \
    '1:disk:_files -g "/dev/rdisk*"' \
    && ret=0

return ret
