#compdef massa-client
# _massa-client — Massa Labs massa-client interactive REPL and CLI for Massa node API wallet operations smart contract deployment and chain queries (massalabs team, Rust); clap
# upstream: https://github.com/massalabs/massa

_massa-client() {
    local -a sub=(
        'help:show help'
        'version:show version'
        'exit:exit'
        'node_status:show node status'
        'node_stop:stop node'
        'get_addresses:get addresses'
        'get_blocks:get blocks'
        'get_endorsements:get endorsements'
        'get_operations:get operations'
        'get_filtered_sc_output_event:get filtered SC events'
        'wallet_info:wallet info'
        'wallet_get_public_key:get public key'
        'wallet_get_secret_key:get secret key'
        'wallet_add_secret_keys:add secret keys'
        'wallet_remove_addresses:remove addresses'
        'wallet_generate_secret_key:generate secret key'
        'wallet_sign:sign message'
        'buy_rolls:buy rolls'
        'sell_rolls:sell rolls'
        'send_transaction:send transaction'
        'execute_smart_contract:execute smart contract'
        'read_only_execute_smart_contract:read-only execute'
        'read_only_call_smart_contract:read-only call'
        'call_smart_contract:call smart contract'
        'when_episode_ends:when episode ends'
        'when_moved:when moved'
        'subscribe_new_blocks:subscribe new blocks'
        'subscribe_new_blocks_headers:subscribe block headers'
        'subscribe_new_filled_blocks:subscribe new filled blocks'
        'subscribe_new_operations:subscribe new operations'
        'node_get_status:node get status'
        'node_add_staking_secret_keys:add staking secret keys'
        'node_remove_staking_addresses:remove staking addresses'
        'node_get_staking_addresses:get staking addresses'
        'node_ban_by_ip:ban by IP'
        'node_ban_by_id:ban by ID'
        'node_unban_by_ip:unban by IP'
        'node_unban_by_id:unban by ID'
        'node_peers_whitelist:peers whitelist'
        'node_add_to_peers_whitelist:add peer to whitelist'
        'node_remove_from_peers_whitelist:remove from whitelist'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-w+[wallet password]:str:' \
        '--wallet-password=+[wallet password]:str:' \
        '-p+[node password]:str:' \
        '--password=+[node password]:str:' \
        '-a+[node address]:str:' \
        '--node-address=+[node address]:str:' \
        '-j[json output]' \
        '--json[json output]' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-r+[chain id]:n:' \
        '--chain-id=+[chain id]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'massa-client subcommand' sub ;;
        args) ;;
    esac
}

_massa-client "$@"
