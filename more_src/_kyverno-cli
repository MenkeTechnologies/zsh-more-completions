#compdef kyverno
# Documentation: https://man.archlinux.org/search?q=kyverno
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apply:apply policies to resources'
  'create:create policies/exceptions/values'
  'completion:generate shell completion'
  'docs:generate docs'
  'fix:fix policies'
  'help:show help'
  'init:initialize project'
  'jp:JSON path tester'
  'json:json subcommands'
  'migrate:migrate policy version'
  'oci:OCI commands'
  'test:run policy tests'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-v[verbose level]' \
  '*--add_dir_header[log directory header]' \
  '*--alsologtostderr[also log to stderr]' \
  '*--log_backtrace_at=[loc]:l:' \
  '*--log_dir=[log dir]:dir:_files -/' \
  '*--log_file=[log file]:file:_files' \
  '*--log_file_max_size=[max size]:n:' \
  '*--logtostderr[log to stderr]' \
  '*--one_output[one output]' \
  '*--skip_headers[skip headers]' \
  '*--skip_log_headers[skip log headers]' \
  '*--stderrthreshold=[threshold]:l:' \
  '*--vmodule=[vmodule]:m:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kyverno command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apply)
        _arguments \
          '(-r --resource)*'{-r+,--resource=}'[resource file]:file:_files' \
          '*--cluster[fetch from cluster]' \
          '*--policy-report[output policy report]' \
          '*--namespace=[namespace]:ns:' \
          '*--audit-warn[audit warns]' \
          '*--context-selector=[context selector]:s:' \
          '*--exception=[exception file]:file:_files' \
          '*--git-branch=[git branch]:b:' \
          '*-v+[k=v values]:v:' \
          '*--values-file=[values file]:file:_files' \
          '*--variables-values=[var values]:v:' \
          '*--user-info=[user info file]:file:_files' \
          '*--registry[allow registry]' \
          '*--remove-color[no color]' \
          '*--detailed-results[detailed results]' \
          '*--table[table output]' \
          '*--store-config=[store config]:file:_files' \
          '*--no-fail-on-failure[no fail on failure]' \
          '*--target-resource=[target resource]:r:' \
          '*--cluster-context=[cluster context]:c:' \
          '*-f+[output format]:f:' \
          '*--output=[output file]:file:_files' \
          '*: :_files -g "*.yaml *.yml"' && ret=0 ;;
      (test)
        _arguments \
          '*--git-branch=[git branch]:b:' \
          '*--manifest-mutate[manifest mutate]' \
          '*--manifest-validate[manifest validate]' \
          '*--registry[allow registry]' \
          '*--detailed-results[detailed]' \
          '*--remove-color[no color]' \
          '*-t+[test cases regex]:re:' \
          '*--fail-only[fail only]' \
          '*: :_files' && ret=0 ;;
      (jp)
        _arguments \
          '1:subcommand:(query function parse)' \
          '*: :' && ret=0 ;;
      (json)
        _arguments \
          '1:subcommand:(scan)' \
          '*: :' && ret=0 ;;
      (oci)
        _arguments \
          '1:subcommand:(pull push)' \
          '*: :' && ret=0 ;;
      (create)
        _arguments \
          '1:subcommand:(metric-config exception policy test values)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
