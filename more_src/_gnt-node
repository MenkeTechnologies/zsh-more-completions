#compdef gnt-node
# Documentation: https://man.archlinux.org/search?q=gnt-node
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a new node'
  'add-tags:add tags to a node'
  'evacuate:evacuate primary or secondary instances'
  'failover:fail over the primary instances'
  'health:show node health'
  'info:show node information'
  'list:list nodes'
  'list-drbd:list DRBD devices'
  'list-storage:list storage'
  'list-tags:list node tags'
  'migrate:migrate instances off a node'
  'modify:modify a node'
  'modify-storage:modify storage on a node'
  'physical-volume-info:show LVM PV info'
  'power:control node power'
  'remove:remove a node'
  'remove-tags:remove node tags'
  'repair-storage:repair storage on a node'
  'restricted-command:run a restricted command'
  'volumes:list logical volumes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnt-node command' commands && ret=0 ;;
esac

return ret
