#compdef cargo-license
# Documentation: https://github.com/onur/cargo-license
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_cargo-license() {
  _arguments \
    '(- *)'{-h,--help}'[Show help message]' \
    '(- *)'{-V,--version}'[Show version]' \
    {-a,--authors}'[show authors of each crate]' \
    {-d,--do-not-bundle}'[output one license per line, do not bundle]' \
    {-j,--json}'[detailed JSON output]' \
    {-t,--tsv}'[tab-separated-values output]' \
    {-g,--gitlab}'[output in GitLab license scanner format]' \
    {-o,--output=}'[write results to file]:file:_files' \
    '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
    '--current-dir=[set the current directory]:dir:_directories' \
    '--features=[space-separated list of features]:features:' \
    '--all-features[activate all features]' \
    '--no-default-features[disable default features]' \
    '--avoid-dev-deps[exclude dev dependencies]' \
    '--avoid-build-deps[exclude build dependencies]' \
    '--avoid-proc-macros[exclude proc-macro dependencies]' \
    '--direct-deps-only[only show direct dependencies]' \
    '--root-only[only show root package information]' \
    '--filter-platform=[filter by target platform]:triple:'
}

_cargo-license "$@"
