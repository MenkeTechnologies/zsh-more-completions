#compdef flux

# Zsh completion for flux - Flux v2 GitOps toolkit CLI

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'bootstrap:Bootstrap toolkit components'
  'check:Check requirements and installation'
  'create:Create or update sources and resources'
  'delete:Delete sources and resources'
  'diff:Diff a kustomization or a helm release'
  'events:Display Kubernetes events for Flux resources'
  'export:Export resources in YAML format'
  'get:Display one or many resources'
  'install:Install or upgrade Flux'
  'logs:Display formatted logs from Flux pods'
  'reconcile:Reconcile sources and resources'
  'resume:Resume a suspended resource'
  'suspend:Suspend resources'
  'trace:Trace an object through the reconciliation chain'
  'tree:Print the resources of a Kustomization as a tree'
  'uninstall:Uninstall Flux and its custom resource definitions'
  'version:Print the client and server version information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for flux]' \
  '--context=[kubernetes context to use]:context' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'[the namespace scope]:namespace' \
  '--timeout=[timeout for this operation]:duration' \
  '--verbose[print generated objects]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'flux command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      bootstrap)
        local -a bootstrap_cmds=(
          'github:Bootstrap toolkit components in a GitHub repository'
          'gitlab:Bootstrap toolkit components in a GitLab repository'
          'git:Bootstrap toolkit components in a Git repository'
          'bitbucket-server:Bootstrap toolkit components in a Bitbucket Server repository'
        )
        _describe -t bootstrap_cmds 'bootstrap provider' bootstrap_cmds && ret=0
        ;;
      create|delete|export|get|reconcile|resume|suspend)
        local -a resource_types=(
          'source:Source resources'
          'kustomization:Kustomization resources'
          'helmrelease:HelmRelease resources'
          'alert:Alert resources'
          'alert-provider:Alert Provider resources'
          'image:Image automation resources'
          'receiver:Receiver resources'
        )
        _describe -t resource_types 'resource type' resource_types && ret=0
        ;;
      check)
        _arguments \
          '--pre[only run pre-installation checks]' \
          '--components=[list of components]:components' && ret=0
        ;;
      install)
        _arguments \
          '--components=[list of components]:components' \
          '--export[export manifests instead of installing]' \
          '--registry=[container registry]:registry' && ret=0
        ;;
      logs)
        _arguments \
          '-f[stream logs]' \
          '--follow[stream logs]' \
          '--all-namespaces[list across all namespaces]' \
          '--tail=[lines of recent log to display]:lines' \
          '--level=[log level to filter]:level:(info error)' && ret=0
        ;;
      trace)
        _arguments \
          '--kind=[the Flux resource kind]:kind' \
          '--api-version=[the resource API version]:api-version' \
          '1:name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
