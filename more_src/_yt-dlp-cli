#compdef yt-dlp-cli
# _yt-dlp-cli — yt-dlp video downloader CLI alias (yt-dlp team / pukkandan, Python); custom argparse
# upstream: https://github.com/yt-dlp/yt-dlp

_yt-dlp-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--update[update yt-dlp]' \
        '-U[update yt-dlp]' \
        '--no-update[no update]' \
        '--update-to=+[update to channel:version]:str:' \
        '--ignore-errors[ignore errors]' \
        '-i[ignore errors]' \
        '--no-abort-on-error[no abort on error]' \
        '--abort-on-error[abort on error]' \
        '--force-overwrites[force overwrites]' \
        '--no-overwrites[no overwrites]' \
        '--continue[resume download]' \
        '-c[resume download]' \
        '--no-continue[no resume]' \
        '--part[use .part files]' \
        '--no-part[no part files]' \
        '--mtime[set file mtime]' \
        '--no-mtime[no set mtime]' \
        '--write-description[write video description]' \
        '--write-info-json[write video info JSON]' \
        '--no-write-info-json[no write info]' \
        '--write-thumbnail[write thumbnail]' \
        '--no-write-thumbnail[no write thumbnail]' \
        '--write-all-thumbnails[write all thumbnails]' \
        '--list-thumbnails[list thumbnails]' \
        '--write-link[write a link file]' \
        '--write-url-link[write .url file (Windows)]' \
        '--write-webloc-link[write .webloc file (macOS)]' \
        '--write-desktop-link[write .desktop file (Linux)]' \
        '--write-subs[write subtitles]' \
        '--no-write-subs[no write subtitles]' \
        '--write-auto-subs[write auto-generated subs]' \
        '--no-write-auto-subs[no write auto subs]' \
        '--all-subs[all subs]' \
        '--list-subs[list subs]' \
        '--sub-format=+[subtitle format]:fmt:(srt ass vtt lrc best)' \
        '--sub-langs=+[subtitle languages]:list:' \
        '--convert-subs=+[convert subs to format]:fmt:(srt ass vtt lrc)' \
        '--format=+[video format]:fmt:' \
        '-f+[video format]:fmt:' \
        '--format-sort=+[format sort]:str:' \
        '-S+[format sort]:str:' \
        '--format-sort-force[force format sort]' \
        '--no-format-sort-force[no force format sort]' \
        '--video-multistreams[allow multiple video streams]' \
        '--no-video-multistreams[no multiple video streams]' \
        '--audio-multistreams[allow multiple audio streams]' \
        '--no-audio-multistreams[no multiple audio streams]' \
        '--prefer-free-formats[prefer free formats]' \
        '--no-prefer-free-formats[no prefer free formats]' \
        '--check-formats[check formats]' \
        '--no-check-formats[no check formats]' \
        '--list-formats[list formats]' \
        '-F[list formats]' \
        '--merge-output-format=+[merge output format]:fmt:(mkv mp4 ogg webm flv mov)' \
        '--output=+[output template]:str:' \
        '-o+[output template]:str:' \
        '--output-na-placeholder=+[NA placeholder]:str:' \
        '--restrict-filenames[restrict filenames to ASCII]' \
        '--no-restrict-filenames[no restrict filenames]' \
        '--windows-filenames[windows filenames]' \
        '--trim-filenames=+[trim filenames]:n:' \
        '--auto-number[number files]' \
        '--paths=+[paths key=val]:list:' \
        '-P+[paths key=val]:list:' \
        '--batch-file=+[batch file]:file:_files' \
        '-a+[batch file]:file:_files' \
        '--cookies=+[cookies file]:file:_files' \
        '--cookies-from-browser=+[cookies from browser]:b:(chrome chromium edge firefox brave opera safari vivaldi)' \
        '--no-cookies-from-browser[no cookies from browser]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-cache-dir[no cache dir]' \
        '--rm-cache-dir[remove cache dir]' \
        '--external-downloader=+[external downloader]:e:(aria2c axel curl ffmpeg httpie wget)' \
        '--external-downloader-args=+[external downloader args]:str:' \
        '--proxy=+[proxy URL]:url:_urls' \
        '--socket-timeout=+[socket timeout]:n:' \
        '--source-address=+[source address]:str:' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '--geo-verification-proxy=+[geo verification proxy]:url:_urls' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-warnings[no warnings]' \
        '--simulate[simulate]' \
        '-s[simulate]' \
        '--no-simulate[no simulate]' \
        '--no-download-archive[no download archive]' \
        '--download-archive=+[download archive]:file:_files' \
        '--max-downloads=+[max downloads]:n:' \
        '--encoding=+[encoding]:enc:' \
        '--legacy-server-connect[legacy server connect]' \
        '--no-check-certificate[no check cert]' \
        '--prefer-insecure[prefer insecure]' \
        '--user-agent=+[user agent]:str:' \
        '--referer=+[referer]:str:' \
        '--add-headers=+[add headers]:list:' \
        '--add-header=+[add header]:list:' \
        '--bidi-workaround[bidi workaround]' \
        '--sleep-requests=+[sleep requests]:f:' \
        '--sleep-interval=+[sleep interval]:f:' \
        '--max-sleep-interval=+[max sleep interval]:f:' \
        '--retries=+[retries]:n:' \
        '-R+[retries]:n:' \
        '--file-access-retries=+[file access retries]:n:' \
        '--fragment-retries=+[fragment retries]:n:' \
        '--retry-sleep=+[retry sleep]:str:' \
        '--skip-unavailable-fragments[skip unavailable fragments]' \
        '--abort-on-unavailable-fragments[abort on unavailable fragments]' \
        '--keep-fragments[keep fragments]' \
        '--no-keep-fragments[no keep fragments]' \
        '--buffer-size=+[buffer size]:str:' \
        '--no-resize-buffer[no resize buffer]' \
        '--http-chunk-size=+[http chunk size]:str:' \
        '--playlist-reverse[playlist reverse]' \
        '--no-playlist-reverse[no playlist reverse]' \
        '--playlist-random[playlist random]' \
        '--lazy-playlist[lazy playlist]' \
        '--no-lazy-playlist[no lazy playlist]' \
        '--xattr-set-filesize[set filesize xattr]' \
        '--hls-prefer-native[hls prefer native]' \
        '--hls-prefer-ffmpeg[hls prefer ffmpeg]' \
        '--hls-use-mpegts[hls use mpegts]' \
        '--external-downloader-args=+[external downloader args]:str:' \
        '--audio-format=+[audio format]:fmt:(best aac flac mp3 m4a opus vorbis wav alac)' \
        '--audio-quality=+[audio quality]:n:' \
        '--remux-video=+[remux video]:fmt:(mp4 mkv flv ogg webm mov avi mka mp3)' \
        '--recode-video=+[recode video]:fmt:(mp4 mkv flv ogg webm mov avi mka mp3 aac)' \
        '--postprocessor-args=+[postprocessor args]:str:' \
        '--ffmpeg-location=+[ffmpeg location]:dir:_files -/' \
        '--extract-audio[extract audio]' \
        '-x[extract audio]' \
        '--keep-video[keep video]' \
        '-k[keep video]' \
        '--no-keep-video[no keep video]' \
        '--embed-subs[embed subs]' \
        '--no-embed-subs[no embed subs]' \
        '--embed-thumbnail[embed thumbnail]' \
        '--no-embed-thumbnail[no embed thumbnail]' \
        '--embed-chapters[embed chapters]' \
        '--no-embed-chapters[no embed chapters]' \
        '--embed-info-json[embed info json]' \
        '--no-embed-info-json[no embed info json]' \
        '--embed-metadata[embed metadata]' \
        '--add-metadata[add metadata]' \
        '--no-add-metadata[no add metadata]' \
        '--parse-metadata=+[parse metadata]:str:' \
        '--replace-in-metadata=+[replace in metadata]:str:' \
        '--xattrs[xattrs]' \
        '--concat-playlist=+[concat playlist mode]:m:(never always multi_video)' \
        '--fixup=+[fixup mode]:m:(never warn detect_or_warn force)' \
        '--prefer-avconv[prefer avconv]' \
        '--prefer-ffmpeg[prefer ffmpeg]' \
        '--exec=+[exec on download]:str:' \
        '*:url:_urls'
}

_yt-dlp-cli "$@"
