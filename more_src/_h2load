#compdef h2load
# Documentation: h2load --help (nghttp2)
# Source: HTTP/2 / HTTP/3 / HTTP/1.1 benchmarking client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    {-n+,--requests=}'[number of requests]:n:' \
    {-c+,--clients=}'[concurrent clients]:n:' \
    {-t+,--threads=}'[native threads]:n:' \
    {-i+,--input-file=}'[URI list file]:file:_files' \
    {-m+,--max-concurrent-streams=}'[max concurrent streams per session]:n:' \
    {-f+,--max-frame-size=}'[max frame size]:size:' \
    {-w+,--window-bits=}'[stream window 2^N-1]:n:' \
    {-W+,--connection-window-bits=}'[connection window 2^N-1]:n:' \
    {-H+,--header=}'[add request header]:header:' \
    {-b+,--body=}'[request body]:body:' \
    {-d+,--data=}'[POST data file]:file:_files' \
    {-r+,--rate=}'[connections per second]:n:' \
    '--rate-period=[rate period seconds]:seconds:' \
    {-T+,--connection-active-timeout=}'[max connection lifetime seconds]:seconds:' \
    {-N+,--connection-inactivity-timeout=}'[idle connection timeout seconds]:seconds:' \
    {-D+,--duration=}'[benchmark duration seconds]:seconds:' \
    '--warm-up-time=[warm-up duration seconds]:seconds:' \
    {-B+,--base-uri=}'[base URI]:uri:_urls' \
    {-p+,--alpn-list=}'[ALPN identifiers]:list:' \
    '--h1[use HTTP/1.1]' \
    '--ciphers=[TLS cipher list]:ciphers:' \
    '--tls13-ciphers=[TLS 1.3 cipher list]:ciphers:' \
    '--ca-certificate=[CA certificate file]:file:_files' \
    '--cert=[client certificate]:file:_files' \
    '--key=[client private key]:file:_files' \
    '--groups=[TLS groups list]:groups:' \
    '--no-tls-proto=[non-TLS protocol]:proto:(h2c http/1.1)' \
    {-v,--verbose}'[verbose output]' \
    '--log-file=[per-request log file]:file:_files' \
    '--qlog-file-base=[QUIC qlog file base]:base:' \
    '--connect-to=[redirect connect host:port]:host:_hosts' \
    '*:uri:_urls' \
    && ret=0

return ret
