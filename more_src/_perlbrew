#compdef perlbrew

# Zsh completion for perlbrew - Perl version manager

local curcontext="$curcontext" state line ret=1

_perlbrew_installed() {
  local -a versions
  versions=(${(f)"$(perlbrew list 2>/dev/null | sed 's/^[* ]*//')"})
  _describe -t versions 'installed perl version' versions
}

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '--verbose[enable verbose output]' \
  '-q[quiet mode]' \
  '-f[force operation]' \
  '-j+[number of parallel build jobs]:jobs' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize perlbrew environment'
      'install:install a perl version'
      'uninstall:uninstall a perl version'
      'available:list available perl versions'
      'lib:manage local::lib directories'
      'alias:manage version aliases'
      'upgrade-perl:upgrade the current perl in-place'
      'list:list installed perl versions'
      'use:use a perl version in the current shell'
      'switch:permanently switch to a perl version'
      'switch-off:turn off perlbrew'
      'exec:execute a command across perl versions'
      'self-install:install perlbrew itself'
      'self-upgrade:upgrade perlbrew'
      'install-cpanm:install cpanm'
      'install-patchperl:install patchperl'
      'install-multiple:install multiple perl versions'
      'download:download a perl source tarball'
      'clean:remove build artifacts'
      'version:show perlbrew version'
      'help:show help'
    )
    _describe -t commands 'perlbrew command' commands && ret=0
    ;;
  args)
    case $words[1] in
      use|switch|uninstall)
        _perlbrew_installed && ret=0
        ;;
      install)
        _arguments -s -S \
          '-f[force install]' \
          '-j+[parallel build jobs]:jobs' \
          '-n[skip running tests]' \
          '--notest[skip running tests]' \
          '--as=[install under an alias]:alias' \
          '-Dusethreads[enable thread support]' \
          '*:perl version:' \
          && ret=0
        ;;
      exec)
        _arguments -s -S \
          '--with=[perl versions to use]:versions' \
          '*:command:_command_names' \
          && ret=0
        ;;
      lib)
        local -a lib_commands=(create delete rename list)
        _describe -t commands 'lib subcommand' lib_commands && ret=0
        ;;
      alias)
        local -a alias_commands=(create rename delete)
        _describe -t commands 'alias subcommand' alias_commands && ret=0
        ;;
      help)
        local -a subcmds=(init install uninstall available lib alias upgrade-perl list use switch exec)
        _describe -t commands 'perlbrew command' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
