#compdef dscacheutil

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-h[show help]' \
  '-q+[query category]:category:(group host service users)' \
  '-a+[restrict by key/value]:key value:' \
  '-cachedump[dump the cache]' \
  '-buckets[show bucket distribution with -cachedump]' \
  '-entries+[show entries with -cachedump]:category:(group host service users)' \
  '-configuration[show configuration]' \
  '-flushcache[flush the cache]' \
  '-statistics[show cache statistics]' && ret=0

return ret
