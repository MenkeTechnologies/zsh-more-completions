#compdef dnsqr
# Documentation: https://manpages.debian.org/testing/djbdns/dnsqr.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dnsqr from djbdns: asks for records using local recursive resolver.
# Synopsis: dnsqr type fqdn

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:type:(any a ns mx ptr txt cname soa hinfo rp sig key aaaa axfr)' \
  '2:fqdn:_hosts' && ret=0

return ret
