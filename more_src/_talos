#compdef talos talosctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply-config:apply configuration to a node'
  'bootstrap:bootstrap the etcd cluster'
  'cluster:manage local docker-based clusters'
  'completion:generate shell completion'
  'config:manage client configuration'
  'conformance:run conformance tests'
  'containers:list containers'
  'copy:copy files from a node'
  'dashboard:launch a dashboard'
  'disks:list disks on a node'
  'dmesg:retrieve kernel logs'
  'edit:edit a resource'
  'etcd:manage etcd'
  'events:watch events'
  'gen:generate certificates and configs'
  'get:get a resource'
  'health:check cluster health'
  'image:manage images'
  'inject:inject configuration'
  'inspect:inspect resources'
  'kubeconfig:retrieve kubeconfig'
  'list:list files on a node'
  'logs:retrieve container logs'
  'memory:show memory usage'
  'meta:manage META partition'
  'mount:list mounts'
  'netstat:show network connections'
  'patch:patch a resource'
  'pcap:capture network packets'
  'processes:list running processes'
  'read:read a file'
  'reboot:reboot a node'
  'reset:reset a node'
  'restart:restart a container'
  'rollback:rollback a node'
  'service:manage services'
  'shutdown:shutdown a node'
  'stats:get container stats'
  'support:generate support bundle'
  'time:show system time'
  'upgrade:upgrade Talos on a node'
  'upgrade-k8s:upgrade Kubernetes'
  'usage:show disk usage'
  'validate:validate configuration'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cluster[cluster name]:name:' \
  '--context[context name]:context:' \
  {-e,--endpoints}'[node endpoints]:endpoints:' \
  {-n,--nodes}'[target nodes]:nodes:' \
  '--talosconfig[path to talosconfig]:config:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'talosctl command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (apply-config)
        _arguments \
          '--file[config file]:file:_files' \
          '--insecure[skip TLS verification]' \
          '--mode[apply mode]:mode:(auto no-reboot reboot staged try)' \
          '--dry-run[dry run]' \
          '--timeout[timeout]:timeout:' && ret=0
        ;;
      (cluster)
        local -a cluster_cmds=(
          'create:create a local cluster'
          'destroy:destroy a local cluster'
          'show:show cluster info'
        )
        _describe -t commands 'cluster command' cluster_cmds && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
