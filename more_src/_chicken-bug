#compdef chicken-bug
# Documentation: https://manpages.debian.org/testing/chicken-bin/chicken-bug.1.en.html
# CHICKEN Scheme bug-report generation tool

local ret=1

_arguments -s -S \
  '(-help)-help[show usage information]' \
  '-to-stdout[write bug report to standard output instead of a file]' \
  '-[read user input from standard input even if files are given]' \
  '*:file:_files' && ret=0

return ret
