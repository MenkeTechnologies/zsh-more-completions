#compdef peggy
# Documentation: https://man.archlinux.org/search?q=peggy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--allowed-start-rules)--allowed-start-rules=[start rules csv]:rules:' \
  '(--ast)--ast[output AST]' \
  '(--cache)--cache[use results cache]' \
  '(--no-cache)--no-cache[disable results cache]' \
  '(-d --dependency)'{-d+,--dependency=}'[runtime dependency]:dep:' \
  '(--dts)--dts[generate .d.ts]' \
  '(-e --export-var)'{-e+,--export-var=}'[export variable name]:name:' \
  '(--extra-options)--extra-options=[extra JSON options]:json:' \
  '(--extra-options-file)--extra-options-file=[extra options file]:file:_files' \
  '(--format)--format=[output format]:fmt:(amd bare commonjs es globals umd)' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(--plugin)*--plugin=[plugin]:plugin:' \
  '(--source-map)--source-map+[source map file or auto]:f:' \
  '(--inline-source-map)--inline-source-map[inline source map]' \
  '(--no-source-map)--no-source-map[no source map]' \
  '(-S --start-rule)'{-S+,--start-rule=}'[start rule]:rule:' \
  '(--trace)--trace[output trace]' \
  '(-t --test)'{-t+,--test=}'[run test on string]:s:' \
  '(-T --test-file)'{-T+,--test-file=}'[run test on file]:file:_files' \
  '*: :_files -g "*.peg *.pegjs *.peggy"' && ret=0

return ret
