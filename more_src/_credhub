#compdef credhub

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'api:target API endpoint'
  'login:authenticate'
  'logout:discard session'
  'get:fetch a credential'
  'set:set a credential'
  'generate:generate and set a credential'
  'regenerate:regenerate using same attributes'
  'bulk-regenerate:regenerate certs signed by given CA'
  'delete:delete a credential'
  'find:find names or paths'
  'import:bulk-set credentials from file'
  'export:export credentials to file'
  'interpolate:fill template with CredHub values'
  'curl:arbitrary REST request'
  'set-permission:set ACL for actor on path'
  'get-permission:get ACL for actor on path'
  'delete-permission:delete ACL for actor on path'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--http-timeout=[HTTP timeout seconds]:secs:' \
  '--token=[bearer token]:token:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'credhub subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (api|a)
        _arguments \
          '--server=[API server URL]:url:' \
          '--ca-cert=[CA cert]:file:_files' \
          '--skip-tls-validation[skip TLS validation]' && ret=0
        ;;
      (login|l)
        _arguments \
          '(-u --username)'{-u,--username=}'[username]:user:_users' \
          '(-p --password)'{-p,--password=}'[password]:password:' \
          '--client-name=[UAA client name]:client:' \
          '--client-secret=[UAA client secret]:secret:' \
          '--sso[SSO login]' \
          '--sso-passcode=[SSO passcode]:code:' && ret=0
        ;;
      (set|s)
        _arguments \
          '(-n --name)'{-n,--name=}'[credential name]:name:' \
          '(-t --type)'{-t,--type=}'[type]:type:(value password certificate json user ssh rsa)' \
          '(-v --value)'{-v,--value=}'[value]:value:' \
          '(-z --private)'{-z,--private=}'[private key file]:file:_files' \
          '(-u --public)'{-u,--public=}'[public key file]:file:_files' \
          '(-r --root)'{-r,--root=}'[root cert file]:file:_files' \
          '(-c --certificate)'{-c,--certificate=}'[cert file]:file:_files' \
          '(-p --password)'{-p,--password=}'[password]:password:' && ret=0
        ;;
      (generate|n)
        _arguments \
          '(-n --name)'{-n,--name=}'[credential name]:name:' \
          '(-t --type)'{-t,--type=}'[type]:type:(password certificate user ssh rsa)' \
          '(-j --length)'{-j,--length=}'[password length]:n:' \
          '--include-special[include special chars]' \
          '--exclude-upper[exclude uppercase]' \
          '--exclude-lower[exclude lowercase]' \
          '--exclude-number[exclude numbers]' \
          '--common-name=[CN for cert]:cn:' \
          '--duration=[cert duration days]:days:' \
          '--self-sign[self-signed cert]' \
          '--is-ca[generate CA cert]' \
          '--ca=[issuing CA name]:ca:' \
          '--key-length=[RSA/SSH key length]:n:' \
          '--organization=[organization]:org:' \
          '--organization-unit=[organization unit]:ou:' \
          '--locality=[locality]:locality:' \
          '--state=[state]:state:' \
          '--country=[country code]:cc:' \
          '*--alternative-name=[SAN]:san:' \
          '*--key-usage=[key usage]:usage:' \
          '*--extended-key-usage=[extended key usage]:usage:' \
          '--username=[username for user type]:user:_users' && ret=0
        ;;
      (get|g)
        _arguments \
          '(-n --name)'{-n,--name=}'[credential name]:name:' \
          '(-i --id)'{-i,--id=}'[credential id]:id:' \
          '(-k --key)'{-k,--key=}'[output key]:key:' \
          '(-j --output-json)'{-j,--output-json}'[JSON output]' \
          '--quiet[quiet output]' \
          '(-v --version)'{-v,--version=}'[credential version]:version:' && ret=0
        ;;
      (find|f)
        _arguments \
          '(-n --name-like)'{-n,--name-like=}'[name substring]:name:' \
          '(-p --path)'{-p,--path=}'[path filter]:path:' \
          '--all-paths[list all paths]' \
          '(-j --output-json)'{-j,--output-json}'[JSON output]' && ret=0
        ;;
      (delete|d)
        _arguments \
          '(-n --name)'{-n,--name=}'[credential name]:name:' \
          '(-p --path)'{-p,--path=}'[path]:path:' && ret=0
        ;;
      (regenerate|r)
        _arguments \
          '(-n --name)'{-n,--name=}'[credential name]:name:' && ret=0
        ;;
      (import|i)
        _arguments \
          '(-f --file)'{-f,--file=}'[input file]:file:_files' && ret=0
        ;;
      (export|e)
        _arguments \
          '(-f --file)'{-f,--file=}'[output file]:file:_files' \
          '(-p --path)'{-p,--path=}'[path]:path:' && ret=0
        ;;
      (interpolate)
        _arguments \
          '(-f --file)'{-f,--file=}'[template file]:file:_files' \
          '--prefix=[path prefix]:prefix:' && ret=0
        ;;
      (curl)
        _arguments \
          '(-p --path)'{-p,--path=}'[API path]:path:' \
          '(-X --request)'{-X,--request=}'[HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '(-d --data)'{-d,--data=}'[request data]:data:' \
          '(-i --include-headers)'{-i,--include-headers}'[include headers]' \
          '(-f --fail-silently)'{-f,--fail-silently}'[fail silently]' && ret=0
        ;;
      (set-permission|get-permission|delete-permission)
        _arguments \
          '(-a --actor)'{-a,--actor=}'[actor]:actor:' \
          '(-p --path)'{-p,--path=}'[path]:path:' \
          '(-o --operations)'{-o,--operations=}'[operations]:ops:' && ret=0
        ;;
    esac
    ;;
esac

return ret
