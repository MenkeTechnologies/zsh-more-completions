#compdef ConsensusID
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: compute a consensus from multiple peptide identifications

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-rt_delta[maximum retention time deviation for grouping]:value:' \
  '-mz_delta[maximum precursor m/z deviation for grouping]:value:' \
  '-per_spectrum[exact spectrum matching by mzML and spectrum reference]' \
  '-algorithm[consensus scoring method]:method:(PEPMatrix PEPIons best worst average ranks)' \
  '-filter:considered_hits[top hits per ID run considered]:n:' \
  '-filter:min_support[minimum fraction of supporting ID runs]:value:' \
  '-filter:count_empty[include empty ID runs in support calculations]' \
  '-filter:keep_old_scores[retain original scores as user parameters]' \
  '-PEPIons:mass_tolerance[fragment mass tolerance for PEPIons]:value:' \
  '-PEPMatrix:matrix[substitution matrix for PEPMatrix]:matrix:' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
