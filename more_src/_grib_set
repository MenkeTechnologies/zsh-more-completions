#compdef grib_set
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_set
# Source: ecmwf/eccodes tools/grib_set.dox — set key/value pairs in GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-r[repack data]' \
    '-d+[set all data values]:value:_default' \
    '-p+[keys to print (key[:s/d/i],...)]:keys:_default' \
    '-P+[append keys to default print list]:keys:_default' \
    '-w+[where clause filter]:filter:_default' \
    '-7[do not fail on wrong message length]' \
    '-S[strict — only matching messages are copied]' \
    '(- *)-V[show version]' \
    '-M[turn off multi-field support]' \
    '-g[copy GTS header]' \
    '*:grib file:_files' \
    && ret=0

return ret
