#compdef apisix

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start Apache APISIX'
  'stop:stop Apache APISIX'
  'quit:gracefully stop Apache APISIX'
  'restart:restart Apache APISIX'
  'reload:hot-reload Apache APISIX'
  'init:initialize configuration'
  'init_etcd:initialize etcd data'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[set configuration file]:config file:_files -g "*.yaml"' \
  '--config=[set configuration file]:config file:_files -g "*.yaml"' \
  '1:command:->command' && ret=0

case "$state" in
  command)
    _describe -t commands 'apisix command' commands && ret=0
    ;;
esac

return ret
