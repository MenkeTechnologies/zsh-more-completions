#compdef o2

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'create:create a resource'
  'list:list resources'
  'get:get a single resource'
  'update:update a resource'
  'delete:delete a resource'
  'apply:apply a YAML file'
  'login:authenticate with OpenObserve'
  'logout:sign out'
  'help:show help'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-url=[OpenObserve API base URL]:url:' \
  '--api-key=[API key]:key:' \
  '--user=[username/email]:email:' \
  '--password=[password]:password:' \
  '--organization=[organization id]:org:' \
  '--output=[output format]:format:(table json yaml)' \
  '--config=[config file]:file:_files -g "*.{yaml,yml,toml,json}"' \
  '1: :->verb' \
  '*::arg:->args' && ret=0

case $state in
  (verb) _describe -t verbs 'o2 verb' verbs && ret=0 ;;
  (args)
    case $line[1] in
      (create|list|get|update|delete)
        _arguments \
          '*::resource:(template dest dashboard pipeline function alert organization user role stream)' \
          '--file=[YAML/JSON file]:file:_files' && ret=0 ;;
      (apply)
        _arguments '*::file:_files -g "*.{yaml,yml,json}"' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
