#compdef vectorstrip

# EMBOSS vectorstrip: strip vector sequence from ends of sequence(s)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-sequence=[input sequence(s)]:file:_files' \
  '-vectorsfile=[vector primer file]:file:_files' \
  '-mismatch=[allowed mismatch percent]:n:' \
  '-besthits[only report best hits]' \
  '-allsequences[strip all sequences not just matched]' \
  '*:sequence:_files' && ret=0

return ret
