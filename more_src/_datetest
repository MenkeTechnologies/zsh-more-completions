#compdef datetest dtest
# Documentation: https://github.com/hroptatyr/dateutils
# Reference accessed: 2026-06-10

# Zsh completion for datetest (dateutils) - compare dates/times

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)'{-V,--version}'[output version information and exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '(-i --input-format)'{-i,--input-format=}'[strptime-style input format]:input format:' \
  '(-e --empty)'{-e,--empty=}'[use VALUE when date cannot be parsed]:empty value:' \
  '--from-zone=[interpret input dates in ZONE]:timezone:' \
  '--to-zone=[convert output to ZONE]:timezone:' \
  '(--ne --gt --lt --ge --le --nt --ot)--eq[test if dates are equal]' \
  '(--eq --gt --lt --ge --le --nt --ot)--ne[test if dates are not equal]' \
  '(--eq --ne --lt --ge --le --nt --ot)--gt[test if date1 is greater than date2]' \
  '(--eq --ne --gt --ge --le --nt --ot)--lt[test if date1 is less than date2]' \
  '(--eq --ne --gt --lt --le --nt --ot)--ge[test if date1 is greater than or equal to date2]' \
  '(--eq --ne --gt --lt --ge --nt --ot)--le[test if date1 is less than or equal to date2]' \
  '(--eq --ne --gt --lt --ge --le --ot)--nt[test if date1 is newer than date2]' \
  '(--eq --ne --gt --lt --ge --le --nt)--ot[test if date1 is older than date2]' \
  '1:date1:' \
  '2:date2:'
