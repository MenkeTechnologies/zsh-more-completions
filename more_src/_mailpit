#compdef mailpit

# Zsh completion for mailpit - email testing tool

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--db-file=[path to database file]:file:_files' \
  '--listen=[HTTP listen address]:address' \
  '--max=[max number of messages to store]:count' \
  '--smtp=[SMTP bind address]:address' \
  '--smtp-auth-accept-any[accept any SMTP credentials]' \
  '--smtp-auth-allow-insecure[allow insecure plain SMTP auth]' \
  '--smtp-auth-file=[password file for SMTP authentication]:file:_files' \
  '--smtp-tls-cert=[TLS certificate for SMTP]:file:_files' \
  '--smtp-tls-key=[TLS key for SMTP]:file:_files' \
  '--smtp-require-starttls[require STARTTLS]' \
  '--smtp-require-tls[require TLS connections]' \
  '--smtp-relay-config=[SMTP relay config file]:file:_files' \
  '--smtp-relay-all[relay all messages]' \
  '--smtp-relay-matching=[regex to match relay recipients]:pattern' \
  '--smtp-strict-rfc-headers[enforce strict RFC compliance for headers]' \
  '--pop3=[POP3 listen address]:address' \
  '--pop3-auth-file=[password file for POP3 authentication]:file:_files' \
  '--pop3-tls-cert=[TLS certificate for POP3]:file:_files' \
  '--pop3-tls-key=[TLS key for POP3]:file:_files' \
  '--tag=[auto-tag new messages]:tag' \
  '--ui-auth-file=[password file for UI authentication]:file:_files' \
  '--ui-tls-cert=[TLS certificate for UI]:file:_files' \
  '--ui-tls-key=[TLS key for UI]:file:_files' \
  '--webroot=[set the webroot for the UI]:path' \
  '--api-cors=[set allowed CORS origins for API]:origin' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--quiet[quiet logging (errors only)]' \
  '--enable-spamassassin=[enable SpamAssassin integration]:address' \
  '--allow-untrusted-tls[allow untrusted TLS certificates for relay]' \
  '--block-remote-css-and-fonts[block remote CSS and fonts in HTML preview]' \
  '--label=[custom label for this instance]:label' \
  && return 0
