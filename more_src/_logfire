#compdef logfire
# _logfire — Pydantic Logfire observability CLI
# upstream: https://github.com/pydantic/logfire

_logfire() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'auth:authenticate with Logfire'
                'projects:manage Logfire projects'
                'whoami:show current authenticated user'
                'info:show Logfire configuration info'
                'clean:clean Logfire data directory'
                'inspect:inspect integration setup'
                'backfill:backfill data from files'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                auth)
                    _arguments \
                        '1:subcommand:(login logout token)' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                projects)
                    _arguments \
                        '1:subcommand:(list create use new)' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                inspect)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                backfill)
                    _arguments \
                        '--file=[file to backfill]:file:_files' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
            esac
            ;;
    esac
}

_logfire "$@"
