#compdef maas-rack-controller

# MAAS rack controller: PXE/TFTP/DHCP/iSCSI services for a rack of nodes
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'config:print/set rack config (region URL, secret)'
  'install-shared-secret:install MAAS shared secret on this rack'
  'register:register this rack with the region controller'
  'support-dump:bundle support diagnostics tarball'
)

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rack subcommand' commands && ret=0 ;;
esac
return ret
