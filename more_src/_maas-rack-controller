#compdef maas-rack-controller maas-rackd

# maas-rack-controller: MAAS rack controller daemon
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'register:register this rack controller with a region'
  'install-shared-secret:install shared secret for region-rack auth'
  'config:show rack configuration'
  'support-dump:produce support dump'
  'changepassword:change MAAS account password'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--logfile=[log file]:file:_files' \
  '--no-fork[run in foreground]' \
  '--pidfile=[PID file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rack-controller command' commands && ret=0 ;;
esac
return ret
