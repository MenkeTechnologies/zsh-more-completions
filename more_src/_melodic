#compdef melodic
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/resting_state/melodic.html
# melodic - multivariate exploratory linear optimised ICA decomposition

local ret=1

_arguments -s -S \
  '(-i --in)'{-i,--in}'[input file names (comma-separated 4D images)]:files:_files' \
  '(-o --outdir)'{-o,--outdir}'[output directory name]:dir:_files -/' \
  '(-m --mask)'{-m,--mask}'[mask file name for restricting analysis]:file:_files' \
  '--dim=[number of dimensions for ICA (-1 for automatic)]:n:' \
  '--tr=[TR in seconds]:tr:' \
  '--mmthresh=[threshold for mixture model based thresholding]:thresh:' \
  '--report[generate HTML report]' \
  '--nobet[switch off BET brain extraction]' \
  '--bgthreshold=[brightness threshold percentage for masking]:pct:' \
  '--mix=[mixing matrix for mixture modelling / filtering]:file:_files' \
  '--ICs=[input component map for filtering / display]:file:_files' \
  '(-f)-f[component map filtering with mixing matrix]:file:_files' \
  '--Oall[output everything]' \
  '(-v --verbose)'{-v,--verbose}'[switch on verbose mode]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
