#compdef clisp2
# _clisp2 — Bruno Haible Michael Stoll GNU clisp2 CLI command-line frontend wrapping the GNU CLISP open-source implementation of ANSI Common Lisp originally Bruno Haible Michael Stoll now GNU project ANSI-Common-Lisp bytecode interpreter and compiler Just-In-Time REPL listener portable runs on Unix Windows MacOSX MS-DOS Amiga OS400 supports CLOS MOP CLOSURE compile load eval execute interpreter dribble fopen list memory image stack stdin stderr norc nointerrupt noinit noremoteinit no-saving repl batchmode (Bruno Haible Michael Stoll GNU team, C/Common Lisp); custom argparse
# upstream: https://clisp.sourceforge.io/

_clisp2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-qq[quiet quiet]' \
        '-h2[help short]' \
        '-list-modules[list modules]' \
        '-list-all-modules[list all modules]' \
        '-help[help]' \
        '-modern[modern syntax]' \
        '-traditional[traditional syntax]' \
        '-Mb+[memory base]:str:' \
        '-m+[memory size]:str:' \
        '-K+[kernel]:str:' \
        '-N+[localedir]:dir:_files -/' \
        '-E+[encoding]:str:' \
        '-Eterminal=+[enc]:str:' \
        '-Efile=+[enc]:str:' \
        '-Epathname=+[enc]:str:' \
        '-Emisc=+[enc]:str:' \
        '-Eforeign=+[enc]:str:' \
        '-L+[lang]:str:' \
        '-norc[no rc file]' \
        '-modules[load modules]' \
        '-no-readline[no readline]' \
        '-disable-readline[disable readline]' \
        '-on-error=+[m]:m:(debug exit abort appease)' \
        '-no-debug[no debug]' \
        '-i+[init file]:file:_files -g "*.lisp"' \
        '*-i+[init file]:file:_files -g "*.lisp"' \
        '-c[compile only]' \
        '*-c+[compile]:file:_files -g "*.lisp"' \
        '-l+[listing]' \
        '-x+[expression]:str:' \
        '*-x+[expression]:str:' \
        '-w[wait for return]' \
        '-on-error[on error]' \
        '-repl[REPL]' \
        '-norepl[no REPL]' \
        '-b[batch]' \
        '-batchmode[batch mode]' \
        '-interactive[interactive]' \
        '-M+[memory image]:file:_files -g "*.mem"' \
        '-mem+[memory image]:file:_files -g "*.mem"' \
        '-d+[dir]:dir:_files -/' \
        '-o+[output]:file:_files -g "*.fas *.lib *.c"' \
        '-O+[output]:file:_files' \
        '-o-default-file-encoding=+[enc]:str:' \
        '-on-load=+[fn]:str:' \
        '-Diagnostic-mode[diagnostic mode]' \
        '-set-clos-search-precedence[set CLOS search precedence]' \
        '*:lisp file:_files -g "*.lisp *.lsp *.cl *.fas *.lib *.mem"'
}

_clisp2 "$@"
