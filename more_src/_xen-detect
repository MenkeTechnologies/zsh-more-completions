#compdef xen-detect
# Documentation: https://man.archlinux.org/search?q=xen-detect
# Reference accessed: 2026-05-16

# xen-detect: check whether running under Xen
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-H[query Xen via /proc/xen]' \
  '*::xen-detect args:_files' && ret=0
return ret
