#compdef astquery
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astquery.html
# astquery — query remote astronomical data servers and download catalog data

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '--cite[show BibTeX citation for this program]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-S --setdirconf)'{-S,--setdirconf}'[set default values for this directory]' \
  '(-U --setusrconf)'{-U,--setusrconf}'[set default values for this user]' \
  '--config[read configuration file immediately]:file:_files' \
  '--checkconfig[list all config files and variables read]' \
  '--lastconfig[do not parse any more configuration files]' \
  '--onlyversion[only run if program version matches]:version' \
  '(-h --hdu)'{-h,--hdu}'[extension name or number of input data]:HDU' \
  '(-L --limitinfo)'{-L,--limitinfo}'[retrieve only dataset info matching this string]:string' \
  '(-Q --query)'{-Q,--query}'[raw query as a simple string]:query' \
  '(-v --overlapwith)'{-v,--overlapwith}'[set query region to overlap with image]:file:_files' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '(-i --information)'{-i,--information}'[print database or dataset information]' \
  '(-k --keeprawdownload)'{-k,--keeprawdownload}'[retain raw downloaded file]' \
  '--dry-run[print download command without executing]' \
  '--tableformat[output table format]:format:(txt fits-ascii fits-binary)' \
  '--wcslinearmatrix[WCS linear matrix of output]:matrix:(pc cd)' \
  '(-s --dataset)'{-s,--dataset}'[dataset name in database]:dataset' \
  '(-c --column)'{-c,--column}'[column names to download]:column' \
  '--ccol[coordinate column names in dataset]:column' \
  '(-C --center)'{-C,--center}'[center coordinates for region selection]:center' \
  '(-r --radius)'{-r,--radius}'[radius around center for target selection]:radius' \
  '(-w --width)'{-w,--width}'[box width around center]:width' \
  '(-g --range)'{-g,--range}'[range filter on column values]:range' \
  '(-b --noblank)'{-b,--noblank}'[exclude rows with blank values]:columns' \
  '(-H --head)'{-H,--head}'[download only top N rows]:number' \
  '--sort[sort by columns]:columns' \
  '*:database:(astron gaia ned vizier)' && ret=0

return ret
