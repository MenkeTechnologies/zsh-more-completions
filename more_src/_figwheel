#compdef figwheel
# Documentation: https://figwheel.org/docs/main_options.html
# Figwheel.main ClojureScript build/REPL tool

local ret=1

_arguments -s -S \
  '(-h --help -?)'{-h,--help,-\?}'[print help message and exit]' \
  '(-b --build)'{-b,--build}'+[build using supplied build name]:build:' \
  '(-bo --build-once)'{-bo,--build-once}'+[compile a build once without watching]:build:' \
  '*'{-bb,--background-build}'+[watch and build a named build in the background]:build:' \
  '(-co --compile-opts)'{-co,--compile-opts}'+[supply a ClojureScript compile options file or map]:opts:_files' \
  '(-fwo --fw-opts)'{-fwo,--fw-opts}'+[supply a figwheel.main options file or map]:opts:_files' \
  '(-ro --repl-opts)'{-ro,--repl-opts}'+[supply a repl options file or map]:opts:_files' \
  '(-fw --figwheel)'{-fw,--figwheel}'+[use figwheel to auto-reload and report compile errors]:bool:(true false)' \
  '(-pc --print-config)'{-pc,--print-config}'[print out the computed configuration and exit]' \
  '(-d --output-dir)'{-d,--output-dir}'+[set the output directory for compiled files]:dir:_files -/' \
  '(-o --output-to)'{-o,--output-to}'+[set the output file for the compiled JavaScript]:file:_files' \
  '(-O --optimizations)'{-O,--optimizations}'+[set the optimization level]:level:(none whitespace simple advanced)' \
  '(-t --target)'{-t,--target}'+[set the JavaScript target environment]:target:(none nodejs webworker)' \
  '(-w --watch)'{-w,--watch}'+[add a source directory to watch and recompile]:dir:_files -/' \
  '(-e --eval)'{-e,--eval}'+[evaluate a ClojureScript expression]:expr:' \
  '(-i --init)'{-i,--init}'+[load a ClojureScript file on init]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[emit verbose ClojureScript compiler output]' \
  '(-re --repl-env)'{-re,--repl-env}'+[set the repl environment]:env:' \
  '(-r --repl)'{-r,--repl}'[run a REPL]' \
  '(-s --serve)'{-s,--serve}'+[run a server on the supplied host:port]:host\:port:' \
  '(-m --main)'{-m,--main}'+[call the -main function of a namespace with args]:namespace:' \
  '(-c --compile)'{-c,--compile}'+[compile a namespace]:namespace:' \
  '*::ns and args:' && ret=0

return ret
