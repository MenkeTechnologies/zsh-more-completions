#compdef gdtopng
# Documentation: https://manpages.debian.org/testing/libgd-tools/libgd-tools.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input GD:_files -g "*.gd"' \
  '2:output PNG:_files -g "*.png"' && ret=0

return ret
