#compdef kimpersonate
# Documentation: https://www.heimdal.software/
# Source: heimdal/heimdal kuser/kimpersonate.c — create a Kerberos 5 service ticket as an arbitrary principal.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --ccache)'{-c+,--ccache=}'[Kerberos 5 credential cache name]:ccache:_default' \
    '(-s --server)'{-s+,--server=}'[server principal name]:principal:_default' \
    '(-C --client)'{-C+,--client=}'[client principal name]:principal:_default' \
    '(-k --keytab)'{-k+,--keytab=}'[keytab file]:file:_files' \
    '-5[create a Kerberos 5 ticket]' \
    '--krb5[create a Kerberos 5 ticket]' \
    '-a[add to ccache without re-initializing]' \
    '--add[add to ccache without re-initializing]' \
    '--referral[store additional entry for service with empty realm]' \
    '(-e --expire-time)'{-e+,--expire-time=}'[ticket lifetime (seconds)]:seconds:_default' \
    '*--client-addresses=[client addresses]:addrs:_default' \
    '(-t --enc-type)'{-t+,--enc-type=}'[encryption type]:enctype:_default' \
    '--session-enc-type=[session encryption type]:enctype:_default' \
    '-f+[ticket flags for krb5 ticket]:flags:_default' \
    '--ticket-flags=[ticket flags for krb5 ticket]:flags:_default' \
    '--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
