#compdef afscexpand
# Documentation: https://keith.github.io/xcode-man-pages/afscexpand.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[print contents of every file instead of decompressing]' \
  '*:path:_files' && ret=0

return ret
