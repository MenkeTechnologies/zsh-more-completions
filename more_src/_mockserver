#compdef mockserver
# _mockserver — MockServer for HTTP/HTTPS mocking and proxying
# upstream: https://github.com/mock-server/mockserver

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '-serverPort=[HTTP port]:port:' \
    '-proxyRemotePort=[proxy remote port]:port:' \
    '-proxyRemoteHost=[proxy remote host]:host:_hosts' \
    '-logLevel=[log level]:level:(TRACE DEBUG INFO WARN ERROR OFF)' \
    '-jvmOptions=[JVM options]:options:' \
    '-maxExpectations=[max number of expectations]:count:' \
    '-requestLogSize=[max log entries]:count:' \
    '-maxWebSocketExpectations=[max WebSocket expectations]:count:' \
    '-maxHeaderSize=[max HTTP header size]:bytes:' \
    '-maxInitialLineLength=[max HTTP initial line length]:bytes:' \
    '-nioEventLoopThreadCount=[NIO thread count]:threads:' \
    '-actionHandlerThreadCount=[action handler thread count]:threads:' \
    '-webSocketClientEventLoopThreadCount=[WebSocket client threads]:threads:' \
    '-clientNioEventLoopThreadCount=[client NIO thread count]:threads:' \
    '-pipeLogToConsole=[pipe log to console]:bool:(true false)' \
    '-initializationJsonPath=[init expectations JSON]:file:_files -g "*.json"' \
    '-initializationClass=[init expectation class]:class:' \
    '-watchInitializationJson=[watch init JSON for changes]:bool:(true false)' \
    '-tlsMutualAuthenticationRequired=[require mutual TLS]:bool:(true false)' \
    '-tlsMutualAuthenticationCertificateChain=[mutual TLS cert chain]:file:_files' \
    '-proxyConfiguration=[proxy configuration]:config:' \
    && return 0
