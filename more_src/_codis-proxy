#compdef codis-proxy
# Documentation: https://github.com/CodisLabs/codis/blob/master/cmd/proxy/main.go
# Codis proxy — proxy-based Redis cluster solution

local ret=1

_arguments -s -S \
  '--ncpu=[set runtime.GOMAXPROCS to N]:n:' \
  '--max-ncpu=[set maximum GOMAXPROCS]:n:' \
  '(-c --config)'{-c,--config=}'[run with the specific configuration]:file:_files -g "*.toml"' \
  '(-l --log)'{-l,--log=}'[path/name of daily rotated log file]:file:_files' \
  '--log-level=[set the log level]:level:(INFO WARN DEBUG ERROR)' \
  '--host-admin=[admin address to register with dashboard]:addr:' \
  '--host-proxy=[proxy address to register with dashboard]:addr:' \
  '--dashboard=[dashboard address for coordination]:addr:' \
  '--zookeeper=[ZooKeeper address for coordination]:addr:' \
  '--zookeeper-auth=[ZooKeeper auth as USR:PWD]:auth:' \
  '--etcd=[etcd address for coordination]:addr:' \
  '--etcd-auth=[etcd auth as USR:PWD]:auth:' \
  '--filesystem=[filesystem root for coordination]:root:_files -/' \
  '--fillslots=[fill slots from a file]:file:_files' \
  '--ulimit=[check max number of open file descriptors]:nlimit:' \
  '--pidfile=[write pid to this file]:file:_files' \
  '--product_name=[product name]:name:' \
  '--product_auth=[product auth]:auth:' \
  '--session_auth=[session auth]:auth:' \
  '--default-config[print the default configuration and exit]' \
  '--version[show version and exit]' && ret=0

return ret
