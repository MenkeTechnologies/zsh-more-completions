#compdef icinga2

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'api:API operations'
  'ca:certificate authority operations'
  'console:start an interactive console'
  'daemon:run the daemon'
  'feature:enable/disable Icinga 2 features'
  'node:node setup operations'
  'object:object commands'
  'pki:PKI operations'
  'repository:repository operations (legacy)'
  'troubleshoot:collect diagnostic data'
  'variable:Icinga 2 variable operations'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--color[VT100 color output]' \
  '*'{-D,--define=}'[set constant key=value]:define:' \
  '(-a --app)'{-a,--app=}'[load application library]:name:' \
  '*'{-l,--library=}'[load library]:name:' \
  '*'{-I,--include=}'[add include directory]:dir:_files -/' \
  '(-x --log-level)'{-x,--log-level=}'[log level]:level:(debug notice information warning critical)' \
  '(-X --script-debugger)'{-X,--script-debugger}'[enable script debugger]' \
  '--no-stack-rlimit[do not adjust stack rlimit]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'icinga2 subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (api)
        _values 'api action' 'setup' && ret=0
        ;;
      (ca)
        _values 'ca action' 'list' 'remove' 'restore' 'sign' && ret=0
        ;;
      (feature)
        _values 'feature action' 'enable' 'disable' 'list' && ret=0
        ;;
      (node)
        _values 'node action' 'setup' 'wizard' && ret=0
        ;;
      (object)
        _values 'object action' 'list' && ret=0
        ;;
      (pki)
        _values 'pki action' \
          'new-ca' 'new-cert' 'request' 'save-cert' 'sign-csr' 'ticket' 'verify' && ret=0
        ;;
      (variable)
        _values 'variable action' 'get' 'list' && ret=0
        ;;
    esac
    ;;
esac

return ret
