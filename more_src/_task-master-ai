#compdef task-master-ai
# Documentation: https://github.com/eyaltoledano/claude-task-master
# Reference accessed: 2026-05-23
# Verified: task-master-ai npm package task-master-ai --help.

# Zsh completion for task-master-ai - Task Master AI agent task planning CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'task-master command' \
      'init[initialize Task Master project]' \
      'models[view or configure AI models]' \
      'parse-prd[generate tasks from PRD file]' \
      'generate[create task files from tasks.json]' \
      'list[list tasks]' \
      'set-status[update task status]' \
      'sync-readme[export tasks to README.md]' \
      'update[update multiple tasks from prompt]' \
      'update-task[update single task]' \
      'add-subtask[add or convert subtask]' \
      'remove-subtask[remove subtask]' \
      'clear-subtasks[clear subtasks]' \
      'analyze-complexity[analyze task complexity]' \
      'complexity-report[show complexity report]' \
      'expand[break task into subtasks]' \
      'research[AI research with project context]' \
      'next[show next task to work on]' \
      'show[show task details]' \
      'tags[manage tags]' \
      'add-dependency[add task dependency]' \
      'remove-dependency[remove task dependency]' \
      'validate-dependencies[find invalid dependencies]' \
      'fix-dependencies[fix invalid dependencies]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--name[project name]:name:' \
          '--description[project description]:desc:' \
          '-y[skip prompts]' && ret=0
        ;;
      models)
        _arguments '--setup[interactive model setup]' && ret=0
        ;;
      parse-prd)
        _arguments \
          '--input[PRD input file]:file:_files' \
          '--num-tasks[number of tasks to generate]:n:' && ret=0
        ;;
      list)
        _arguments \
          '(-s)--status[filter by status]:status:(pending done in-progress review deferred cancelled)' \
          '(-t)--tag[filter by tag]:tag:' \
          '--with-subtasks[include subtasks]' \
          '(-f)--format[output format]:format:(text json compact)' \
          '--json[JSON output]' \
          '(-c)--compact[compact output]' \
          '(-w)--watch[watch mode]' \
          '--ready[ready tasks only]' \
          '--blocking[blocking tasks only]' \
          '--all-tags[show all tags]' && ret=0
        ;;
      set-status)
        _arguments '1:task id:' '2:status:(pending done in-progress review deferred cancelled)' && ret=0
        ;;
      expand)
        _arguments \
          '--id[task id]:id:' \
          '--num[number of subtasks]:n:' \
          '--research[use research model]' \
          '--prompt[extra context]:prompt:' \
          '--all[expand all pending tasks]' \
          '--force[force re-expand]' && ret=0
        ;;
      tags)
        if (( CURRENT == 2 )); then
          _values 'tags command' \
            'add[create tag]' \
            'use[switch tag context]' \
            'remove[delete tag]' \
            'rename[rename tag]' \
            'copy[copy tag and tasks]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
