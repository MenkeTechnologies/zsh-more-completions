#compdef elysia create-elysia
# Documentation: https://man.archlinux.org/search?q=elysia
# Reference accessed: 2026-05-16

# Zsh completion for elysia / create-elysia - Bun web framework CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(-t --template)'{-t,--template}'[project template]:template:' \
  '1:project directory:_directories' && ret=0

return ret
