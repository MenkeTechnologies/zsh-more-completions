#compdef ghorg

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'clone:clone all repos from an org or user'
      'ls:list cloned orgs'
      'reclone:reclone repos for a previously cloned org'
      'version:print version'
    )
    _describe -t commands 'ghorg command' commands && ret=0
    ;;
  args)
    case $line[1] in
      clone)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-t+[token for SCM provider]:token' \
          '--token=[token for SCM provider]:token' \
          '-s+[SCM type]:scm:(github gitlab bitbucket gitea)' \
          '--scm=[SCM type]:scm:(github gitlab bitbucket gitea)' \
          '--clone-type=[clone type]:type:(org user)' \
          '--protocol=[clone protocol]:protocol:(https ssh)' \
          '--branch=[default branch to clone]:branch' \
          '--path=[absolute path to clone into]:directory:_directories' \
          '--base-url=[base URL for self-hosted]:url' \
          '--concurrency=[max concurrent clones]:number' \
          '--topics=[filter by topics]:topics' \
          '--match-regex=[filter repos by regex]:regex' \
          '--exclude-match-regex=[exclude repos by regex]:regex' \
          '--skip-archived[skip archived repos]' \
          '--skip-forks[skip forked repos]' \
          '--backup[backup mode, no git pull on existing]' \
          '--clone-wiki[clone wiki repos]' \
          '--include-submodules[init submodules on clone]' \
          '--dry-run[show what would be cloned]' \
          '--fetch-all[fetch all remote refs]' \
          '--output-dir=[override clone directory name]:name' \
          '--no-clean[do not remove repos not in remote]' \
          '--prune[remove local repos not in remote]' \
          '1:org or user name' && ret=0
        ;;
      ls)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      reclone)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:org name' && ret=0
        ;;
    esac
    ;;
esac

return ret
