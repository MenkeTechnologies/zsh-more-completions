#compdef fsntfsinfo
# Documentation: https://github.com/libyal/libfsntfs
# Source: libyal/libfsntfs manuals/fsntfsinfo.1 — display info about an NTFS volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B[output file system hierarchy as a bodyfile]:bodyfile:_files' \
    '-d[calculate MD5 hash of file entry for bodyfile]' \
    '-E[show info about a specific MFT entry index or "all"]:mft entry:' \
    '-F[show info about a specific file entry path]:path:' \
    '-h[show help]' \
    '-H[show file system hierarchy]' \
    '-o[volume offset]:offset:' \
    '-U[show info from USN change journal ($UsnJrnl)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
