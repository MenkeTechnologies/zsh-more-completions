#compdef sqlplus

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-H[show help]' \
  '(- *)-HELP[show help]' \
  '(- *)-V[show version]' \
  '(- *)-VERSION[show version]' \
  '-C+[compatibility release]:release:' \
  '-COMPATIBILITY+[compatibility release]:release:' \
  '-L[do not reprompt on logon failure]' \
  '-LOGON[do not reprompt on logon failure]' \
  '-F[fast mode (improved defaults)]' \
  '-FAST[fast mode (improved defaults)]' \
  '-M+[markup output]:markup:' \
  '-MARKUP+[markup output]:markup:' \
  '-nologintime[suppress last login time display]' \
  '-NOLOGINTIME[suppress last login time display]' \
  '-R+[restrict OS commands]:level:(1 2 3)' \
  '-RESTRICT+[restrict OS commands]:level:(1 2 3)' \
  '-S[silent mode]' \
  '-SILENT[silent mode]' \
  '-prelim[connect in preliminary auth mode]' \
  '-PRELIM[connect in preliminary auth mode]' \
  '/NOLOG[start without connection]' \
  '*:logon string or @script:_files' && ret=0

return ret
