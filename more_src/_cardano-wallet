#compdef cardano-wallet
# Documentation: https://cardano-foundation.github.io/cardano-wallet/user-guide/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'serve:serve an HTTP API for the wallet'
  'launch:launch and monitor a wallet server with chain producers'
  'recovery-phrase:recovery-phrase commands (generate)'
  'key:HD-key operations (from-recovery-phrase/child/public/inspect/walletid)'
  'wallet:wallet commands (list/create/get/utxo/update/delete)'
  'transaction:transaction commands (create/submit/forget/list)'
  'address:address commands (list)'
  'stake-pool:stake-pool commands (list)'
  'network:network commands (information/parameters/clock)'
  'mnemonic:legacy mnemonic alias for recovery-phrase'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--port=[wallet API port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cardano-wallet command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (serve)
        _arguments \
          '--listen-address=[HTTP listen host]:host:_hosts' \
          '--port=[port]:port:' \
          '--random-port[bind to random port]' \
          '--node-socket=[cardano-node socket]:file:_files' \
          '--node-port=[cardano-node port]:port:' \
          '--database=[wallet DB directory]:dir:_files -/' \
          '--sync-tolerance=[sync tolerance duration]:duration:' \
          '--mainnet[connect to mainnet]' \
          '--testnet=[testnet genesis file]:file:_files -g "*.json"' \
          '--shutdown-handler[install shutdown handler]' \
          '--log-level=[log level]:level:(DEBUG INFO NOTICE WARNING ERROR CRITICAL ALERT EMERGENCY)' \
          '--trace=[trace setting]:setting:' \
          '--help-tracing[show tracing help and exit]' && ret=0 ;;
      (recovery-phrase|mnemonic)
        _arguments \
          '*::sub:(generate)' \
          '--size=[number of mnemonic words]:n:(9 12 15 18 21 24)' && ret=0 ;;
      (key)
        _arguments \
          '*::sub:(from-recovery-phrase child public inspect walletid hash)' \
          '--encoding=[encoding]:enc:(hex bech32 base58)' && ret=0 ;;
      (wallet|transaction|address|stake-pool|network)
        _arguments \
          '*::sub:(list create get update delete utxo information parameters clock)' \
          '--port=[port]:port:' && ret=0 ;;
    esac ;;
esac

return ret
