#compdef dnstxt
# _dnstxt — djbdns dnstxt (look up TXT records for one or more domain names; commonly used for SPF/DKIM/DMARC inspection)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnstxt.c on tip.

_dnstxt() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-n --new)'{-n,--new}'[new output style]' \
        '*:domain:_hosts'
}

_dnstxt "$@"
