#compdef hcloud
# _hetzner-cli — Hetzner Cloud CLI (Hetzner Online, Go); manage Hetzner Cloud resources from the command line
# upstream: https://github.com/hetznercloud/cli

_hetzner-cli() {
    local -a sub=(
        'all:list all resources'
        'certificate:certificates'
        'completion:print shell completion'
        'config:config commands'
        'context:manage CLI contexts'
        'datacenter:datacenters'
        'firewall:firewalls'
        'floating-ip:floating IPs'
        'help:show help'
        'image:images'
        'iso:ISOs'
        'load-balancer:load balancers'
        'load-balancer-type:load balancer types'
        'location:locations'
        'network:networks'
        'placement-group:placement groups'
        'primary-ip:primary IPs'
        'server:servers'
        'server-type:server types'
        'ssh-key:SSH keys'
        'volume:volumes'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[config file]:file:_files' \
        '--context+[context name]:context:' \
        '--debug[debug log]' \
        '--debug-file+[debug log file]:file:_files' \
        '--endpoint+[Hetzner API URL]:url:_urls' \
        '--poll-interval+[poll interval]:duration:' \
        '--quiet[quiet]' \
        '--token+[API token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hcloud subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments '1:server cmd:(create delete describe disable-protection enable-protection enable-rescue disable-rescue ip list metrics poweroff poweron reboot rebuild request-console reset reset-password shutdown ssh update update-default-image update-name update-rescue-image)' '*:server:' ;;
                volume) _arguments '1:volume cmd:(attach create delete describe detach disable-protection enable-protection list resize update update-name)' '*:volume:' ;;
                ssh-key) _arguments '1:ssh-key cmd:(create delete describe list update update-name)' '*:ssh-key:' ;;
                network) _arguments '1:network cmd:(add-route add-subnet change-ip-range create delete describe disable-protection enable-protection expose-routes-to-vswitch list remove-route remove-subnet update update-name)' '*:network:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hetzner-cli "$@"
