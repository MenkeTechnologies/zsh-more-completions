#compdef taskinfo
# Documentation: https://www.unix.com/man-page/osx/1/TASKINFO/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: macOS BSD taskinfo accepts only [process name | pid], no documented flags.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:process or pid:_pids' && ret=0
return ret
