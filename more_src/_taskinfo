#compdef taskinfo
# Documentation: https://man.archlinux.org/search?q=taskinfo
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help message]'
    '--help[Show help message]'
    '-v[Verbose output]'
    '--verbose[Verbose output]'
    '-p[Process ID]:process id'
    '--pid=[Process ID]:process id'
    '-a[Show all tasks]'
    '--all[Show all tasks]'
    '*:process id'
)

_arguments -s -S $arguments
