#compdef roocommander
# Documentation: https://github.com/jezweb/roo-commander
# Reference accessed: 2026-05-22
# Verified: src/cli.ts Commander program and subcommands.

# Zsh completion for roocommander - Claude Code skills bridge for Roo Code

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'roocommander command' \
      'list[list available skills]' \
      'read[read skill content]' \
      'search[search skills by keyword]' \
      'generate-index[generate skills index markdown]' \
      'sync-index[update skills index]' \
      'init[initialize Roo Commander setup]' && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments \
          '(-s --source)'{-s,--source}'[custom skills directory]:directory:_directories' \
          '(-v --verbose)'{-v,--verbose}'[show full descriptions]' && ret=0
        ;;
      search)
        _arguments \
          '(-s --source)'{-s,--source}'[custom skills directory]:directory:_directories' \
          '(-v --verbose)'{-v,--verbose}'[show full descriptions]' \
          '1:keyword:' && ret=0
        ;;
      read)
        _arguments \
          '(-s --source)'{-s,--source}'[custom skills directory]:directory:_directories' \
          '(-r --raw)'{-r,--raw}'[raw markdown output]' \
          '1:skill name:' && ret=0
        ;;
      generate-index|sync-index)
        _arguments \
          '(-s --source)'{-s,--source}'[custom skills directory]:directory:_directories' \
          '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
      init)
        _arguments \
          '(-s --source)'{-s,--source}'[custom skills directory]:directory:_directories' \
          '(-r --repo)'{-r,--repo}'[GitHub skills repository user/repo]:repo:' \
          '--force[force reinstall]' \
          '--project[project-scoped install]' && ret=0
        ;;
    esac
    ;;
esac

return ret
