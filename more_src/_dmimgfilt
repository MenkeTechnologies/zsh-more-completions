#compdef dmimgfilt
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmimgfilt.html
# Apply a non-linear spatial filter to a 2D image

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input 2D image]:infile:_files' \
  'outfile=[output filtered image]:outfile:_files' \
  'function=[filter function to use]:function:(median min max mean mode mid sigma extreme locheq kuwahara unsharp range variance nmode q25 q33 q67 q75 mcv sum count olympic pmean jitter rclip peak valley ridge plain 3sigmean 3sigmedian)' \
  'mask=[input mask region]:mask:' \
  'numiter=[number of iterations]:numiter:' \
  'lookupTab=[header merging table]:lookupTab:_files' \
  'randseed=[random seed for jitter]:randseed:' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
