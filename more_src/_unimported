#compdef unimported

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--init[create .unimportedrc.json config]' \
  '--update[update ignore lists in config]' \
  '--flow[enable Flow type support]' \
  '--no-cache[disable caching]' \
  '--clear-cache[clear the cache]' \
  '--show-config[show resolved configuration]' \
  '--show-preset=[show preset configuration]:preset' \
  '--ignore-unresolved[ignore unresolved imports]' \
  '*:entry files:_files' && ret=0

return ret
