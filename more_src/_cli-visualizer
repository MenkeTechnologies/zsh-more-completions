#compdef vis cli-visualizer
# _cli-visualizer — CLI Visualizer terminal music visualizer (C++); supports spectrum / lorenz / ellipse modes via MPD/ALSA/SHM/FIFO
# upstream: https://github.com/dpayne/cli-visualizer

_cli-visualizer() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]'
}

_cli-visualizer "$@"
