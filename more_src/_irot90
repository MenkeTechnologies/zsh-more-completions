#compdef irot90
# Documentation: http://www.starlink.ac.uk/docs/sun86.htx/sun86.html
# FIGARO: Rotate an image by 90 degrees

local ret=1

_arguments -s -S \
  'IMAGE=[image to be rotated]:image:_files' \
  'OUTPUT=[resulting image]:output:_files' \
  'ANTI=[rotate anti-clockwise]:anti:(TRUE FALSE)' \
  '*:NDF data file:_files' && ret=0

return ret
