#compdef sc
# Documentation: https://www.openfoam.com/documentation/guides/latest/man/
# CCP4: calculate shape complementarity statistics between two surfaces

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input PDB file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'SCRADII[radii reference file]:radii:_files' \
  'SURFIN1[input GRASP surface file 1]:surface:_files' \
  'SURFIN2[input GRASP surface file 2]:surface:_files' \
  'SURFOUT1[output GRASP surface file 1]:surface:_files' \
  'SURFOUT2[output GRASP surface file 2]:surface:_files' \
  '*:keyword:(MOLECULE CHAIN ZONE AT_EXCL AT_INCL PROBE_RADIUS DOT_DENSITY TRIM INTERFACE WEIGHT GRASP_MATCH GRASP_BACKGROUND END)' && ret=0

return ret
