#compdef sfdots
# Documentation: http://www.ahay.org/RSF/sfdots.html
# Madagascar: plot data with dots

local ret=1

_arguments -s \
  'clip=[data clip]:clip' \
  'connect=[connection type: 1 diagonal 2 bar 4 non-zero only]:type:(1 2 4)' \
  'constsep=[if y, use constant trace separation]:flag:(y n)' \
  'corners=[number of polygon corners]:corners' \
  'dots=[dot type: 1 balloon 0 none 2 non-zero only]:type:(0 1 2)' \
  'font=[font to use in text]:font' \
  'gaineach=[if y, gain each trace independently]:flag:(y n)' \
  'label1=[label for the axis]:label1' \
  'labels=[trace labels]:labels' \
  'labelsz=[label size]:labelsz' \
  'overlap=[trace overlap]:overlap' \
  'radius=[dot radius]:radius' \
  'screenht=[screen height]:screenht' \
  'screenratio=[screen aspect ratio]:screenratio' \
  'screenwd=[screen width]:screenwd' \
  'seedead=[if y, show zero traces]:flag:(y n)' \
  'seemean=[if y, draw axis lines]:flag:(y n)' \
  'silk=[if y, silky plot]:flag:(y n)' \
  'strings=[if y, draw strings]:flag:(y n)' \
  'title=[plot title]:title' \
  'transp=[if y, transpose the axis]:flag:(y n)' \
  'unit1=[unit for the axis]:unit1' \
  'xxscale=[x scaling]:xxscale' \
  'yreverse=[if y, reverse y axis]:flag:(y n)' \
  'yyscale=[y scaling]:yyscale' \
  '*:rsf file:_files' && ret=0

return ret
