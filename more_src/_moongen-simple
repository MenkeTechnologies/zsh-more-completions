#compdef moongen-simple
# Documentation: https://github.com/emmericp/MoonGen/blob/master/interface/README.md
# MoonGen simple command-line interface wrapper

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(start debug list help)' \
  '*:arg: ' && ret=0

return ret
