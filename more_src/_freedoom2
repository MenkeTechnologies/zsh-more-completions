# Reference accessed: 2026-05-16
# Verified: same wrapper as freedoom1 (different IWAD). Debian
# bookworm freedoom package manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# freedoom2: Freedoom Phase 2 launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[Doom engine to use]:engine:(prboom prboom-plus zandronum chocolate-doom crispy-doom)' \
  '--[forward following args to engine]' \
  '*:engine arg:_files' && ret=0
return ret
