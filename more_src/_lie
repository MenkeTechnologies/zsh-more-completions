#compdef lie gmx-lie
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-lie.html
# gmx lie: estimate free energy from linear combinations

local ret=1

_arguments -s \
  '-f[energy file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[only use frame when t MOD dt equals first time]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-Elj[Lennard-Jones interaction between ligand and solvent]:real:' \
  '-Eqq[Coulomb interaction between ligand and solvent]:real:' \
  '-Clj[factor in LIE equation for Lennard-Jones component]:real:' \
  '-Cqq[factor in LIE equation for Coulomb component]:real:' \
  '-ligand[name of the ligand in the energy file]:string:' && ret=0

return ret
