#compdef clusterBed
# Documentation: https://bedtools.readthedocs.io/en/latest/content/tools/cluster.html
# cluster overlapping/nearby features (bedtools cluster)

local ret=1

_arguments -s -S \
  '-i[input BED/GFF/VCF file]:file:_files' \
  '-s[force strandedness; only cluster same-strand features]' \
  '-d[maximum distance between features to be clustered]:distance' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
