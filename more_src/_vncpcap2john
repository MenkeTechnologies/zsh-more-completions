#compdef vncpcap2john
# Documentation: https://github.com/openwall/john/blob/bleeding-jumbo/src/vncpcap2john.c
# vncpcap2john (JtR) — extract VNC auth from pcap dumps. Usage: vncpcap2john <pcapfiles>.

local ret=1

_arguments -s -S \
  '*:pcap file:_files -g "*.(pcap|pcapng|cap)"' \
  && ret=0

return ret
