#compdef jose

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'alg:list algorithms'
  'b64:base64url encode/decode'
  'fmt:format JSON from the command line'
  'jwk:manage JSON Web Keys'
  'jwe:manage JSON Web Encryption'
  'jws:manage JSON Web Signatures'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      jwk)
        local -a jwk_cmds=(
          'gen:generate a JWK'
          'pub:extract public key from a JWK'
          'thp:calculate thumbprint of a JWK'
          'use:show valid uses of a JWK'
          'eql:test if two JWKs are equal'
          'exc:perform a key exchange'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jwk subcommand' jwk_cmds && ret=0
        ;;
      jwe)
        local -a jwe_cmds=(
          'dec:decrypt a JWE'
          'enc:encrypt a JWE'
          'fmt:format a JWE'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jwe subcommand' jwe_cmds && ret=0
        ;;
      jws)
        local -a jws_cmds=(
          'fmt:format a JWS'
          'sig:create a JWS signature'
          'ver:verify a JWS signature'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jws subcommand' jws_cmds && ret=0
        ;;
      b64)
        local -a b64_cmds=(
          'dec:base64url decode'
          'enc:base64url encode'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'b64 subcommand' b64_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
