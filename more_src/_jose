#compdef jose
# Documentation: https://man.archlinux.org/man/jose.1.en
# Reference accessed: 2026-05-19
# Verified: upstream jose(1) manpage SYNOPSIS at the URL above.

# Corrected from prior file: removed the invented top-level "fmt"
# command (only jwe fmt / jws fmt exist) and the invented "jwk eql"
# subcommand (real jwk subcommands are exc gen pub thp use).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'alg:list supported algorithms'
  'b64:base64url encode/decode'
  'jwk:manage JSON Web Keys'
  'jwe:manage JSON Web Encryption'
  'jws:manage JSON Web Signatures'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      jwk)
        local -a jwk_cmds=(
          'gen:generate a JWK'
          'pub:extract public key from a JWK'
          'thp:calculate thumbprint of a JWK'
          'use:show valid uses of a JWK'
          'exc:perform a key exchange'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jwk subcommand' jwk_cmds && ret=0
        ;;
      jwe)
        local -a jwe_cmds=(
          'dec:decrypt a JWE'
          'enc:encrypt a JWE'
          'fmt:convert a JWE between serialization formats'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jwe subcommand' jwe_cmds && ret=0
        ;;
      jws)
        local -a jws_cmds=(
          'fmt:convert a JWS between serialization formats'
          'sig:create a JWS signature'
          'ver:verify a JWS signature'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jws subcommand' jws_cmds && ret=0
        ;;
      b64)
        local -a b64_cmds=(
          'dec:base64url decode'
          'enc:base64url encode'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'b64 subcommand' b64_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
