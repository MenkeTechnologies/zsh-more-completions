#compdef dnscontrol

# Zsh completion for dnscontrol - DNS as code tool

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'preview:read live DNS records and output what changes would be made'
  'push:apply changes to DNS providers'
  'check-creds:verify that provider credentials are correct'
  'get-zones:download zone files from providers'
  'get-certs:get SSL certificates via ACME/Let'\''s Encrypt'
  'create-domains:create domains on DNS providers'
  'fmt:format a dnsconfig.js file'
  'ppreview:preview with parallel provider queries'
  'ppush:push with parallel provider queries'
  'version:print version'
  'help:show help'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'dnscontrol subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (preview|push|ppreview|ppush)
        _arguments \
          '--config[DNS configuration file]:file:_files -g "*.js"' \
          '--creds[credentials file]:file:_files -g "*.json"' \
          '--providers[providers to include]:providers:' \
          '--domains[domains to include]:domains:' \
          '--notify[send notifications]' \
          '--dev[use dev mode]' \
          '-v[increase verbosity]' \
          '--full[disable two-step TXT update]' \
          '--no-populate[do not auto-create non-existing zones]' \
          '--report[generate report]:file:_files' && ret=0
        ;;
      (check-creds)
        _arguments \
          '--creds[credentials file]:file:_files -g "*.json"' \
          '1:provider name:' && ret=0
        ;;
      (get-zones)
        _arguments \
          '--creds[credentials file]:file:_files -g "*.json"' \
          '--format[output format]:format:(js zone tsv nameonly djs)' \
          '--out[output directory]:directory:_files -/' \
          '1:provider name:' \
          '*:zone name:' && ret=0
        ;;
      (fmt)
        _arguments \
          '1:file:_files -g "*.js"' && ret=0
        ;;
      (create-domains)
        _arguments \
          '--config[DNS configuration file]:file:_files -g "*.js"' \
          '--creds[credentials file]:file:_files -g "*.json"' && ret=0
        ;;
    esac
    ;;
esac

return ret
