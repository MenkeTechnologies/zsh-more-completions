#compdef ipa-server-install
# Documentation: https://man.archlinux.org/search?q=ipa-server-install
# Reference accessed: 2026-05-16

_arguments -s \
  '(-r --realm)'{-r,--realm=}'[Kerberos realm]:realm:' \
  '(-n --domain)'{-n,--domain=}'[primary DNS domain]:domain:' \
  '(-p --ds-password)'{-p,--ds-password=}'[Directory Manager password]:pw:' \
  '(-a --admin-password)'{-a,--admin-password=}'[admin password]:pw:' \
  '--mkhomedir[create home directories]' \
  '--hostname=[server FQDN]:host:_hosts' \
  '*--ip-address=[IP address]:ip:' \
  '*--ntp-server=[NTP server]:host:_hosts' \
  '--ntp-pool=[NTP pool]:pool:' \
  '(-N --no-ntp)'{-N,--no-ntp}'[skip NTP setup]' \
  '--idstart=[starting UID/GID]:n:' \
  '--idmax=[maximum UID/GID]:n:' \
  '--no-hbac-allow[skip default HBAC rule]' \
  '--ignore-topology-disconnect[ignore topology errors]' \
  '--ignore-last-of-role[ignore removal of last role]' \
  '--no-ui-redirect[skip UI redirect]' \
  '--ssh-trust-dns[trust DNS SSHFP]' \
  '--no-ssh[skip SSH client config]' \
  '--no-sshd[skip SSH server config]' \
  '--subid[configure SSSD as subid source]' \
  '--skip-mem-check[skip memory check]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-U --unattended)'{-U,--unattended}'[no prompts]' \
  '--dirsrv-config-file=[directory server LDIF]:file:_files' \
  '--external-ca[generate CSR for external CA]' \
  '--external-ca-type=[external CA type]:type:(generic ms-cs)' \
  '--external-ca-profile=[cert profile]:profile:' \
  '*--external-cert-file=[external cert file]:file:_files' \
  '--random-serial-numbers[random cert serial numbers]' \
  '--no-pkinit[disable pkinit]' \
  '--dirsrv-cert-file=[dirsrv cert file]:file:_files' \
  '--http-cert-file=[http cert file]:file:_files' \
  '--pkinit-cert-file=[pkinit cert file]:file:_files' \
  '--dirsrv-pin=[dirsrv key password]:pw:' \
  '--http-pin=[http key password]:pw:' \
  '--pkinit-pin=[pkinit key password]:pw:' \
  '--dirsrv-cert-name=[dirsrv cert name]:name:' \
  '--http-cert-name=[http cert name]:name:' \
  '--pkinit-cert-name=[pkinit cert name]:name:' \
  '--ca-cert-file=[CA cert file]:file:_files' \
  '--pki-config-override=[CA install overrides]:file:_files' \
  '--ca-subject=[CA cert subject]:dn:' \
  '--subject-base=[subject base]:dn:' \
  '--ca-signing-algorithm=[signing algorithm]:algo:' \
  '--key-type-size=[key type and size]:spec:' \
  '--token-name=[HSM token name]:name:' \
  '--token-library-path=[HSM library path]:file:_files' \
  '--token-password=[HSM password]:pw:' \
  '--token-password-file=[HSM password file]:file:_files' \
  '--setup-kra[install KRA]' \
  '--setup-dns[setup DNS]' \
  '*--forwarder=[DNS forwarder]:ip:' \
  '--no-forwarders[no forwarders]' \
  '--auto-forwarders[auto-discover forwarders]' \
  '--forward-policy=[forward policy]:policy:(first only)' \
  '*--reverse-zone=[reverse zone]:zone:' \
  '--no-reverse[no reverse zones]' \
  '--auto-reverse[auto-detect reverse zones]' \
  '--zonemgr=[zone manager email]:email:' \
  '--no-host-dns[do not use DNS for host]' \
  '--no-dns-sshfp[do not create SSHFP records]' \
  '--no-dnssec-validation[disable DNSSEC validation]' \
  '--allow-zone-overlap[allow zone overlap]' \
  '--dns-over-tls[enable DoT]' \
  '*--dot-forwarder=[DoT forwarder]:host:' \
  '--dns-over-tls-cert=[DoT cert]:file:_files' \
  '--dns-over-tls-key=[DoT key]:file:_files' \
  '--dns-policy=[DNS policy]:policy:(relaxed enforced)' \
  '--netbios-name=[NetBIOS name]:name:' \
  '--rid-base=[RID base]:n:' \
  '--secondary-rid-base=[secondary RID base]:n:' \
  '--setup-adtrust[setup AD trust]' \
  '--enable-compat[enable compat tree]' \
  '--uninstall[uninstall server]' \
  '(- *)'{-h,--help}'[show help]'
