#compdef ceph-mon
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-mon/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Ceph monitor daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --foreground -d)'{-f,--foreground}'[do not daemonize after startup]' \
  '(-d -f --foreground)-d[debug mode: like -f, send log output to stderr]' \
  '--setuser=[set uid after starting]:user or uid:_users' \
  '--setgroup=[set gid after starting]:group or gid:_groups' \
  '(-c --conf)'{-c+,--conf=}'[use this ceph.conf instead of default]:file:_files -g "*.conf"' \
  '-m+[monitor host list]:host1,host2...:' \
  '--mkfs[initialize mon data directory]' \
  '--keyring=[keyring file (with --mkfs)]:file:_files' \
  '--no-config-file[do not read ceph.conf]' \
  '--monmap=[monmap file]:file:_files' \
  '--fsid=[cluster fsid]:uuid:' \
  '*::ceph-mon args:_files' && ret=0
return ret
