#compdef rocprof

# rocprof: AMD ROCm performance profiler
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-i[input metrics file]:file:_files' \
  '-o[output file]:file:_files' \
  '-d[output dir]:dir:_files -/' \
  '--basenames[short kernel names]:val:(on off)' \
  '--timestamp[include timestamps]:val:(on off)' \
  '--hsa-trace[trace HSA API]' \
  '--hip-trace[trace HIP API]' \
  '--roctx-trace[trace ROCTX]' \
  '--sys-trace[system-wide trace]' \
  '--stats[print stats]' \
  '--ctx-limit=[context limit]:n:' \
  '--mpi[mpi mode]' \
  '*:application args:_files' && ret=0
return ret
