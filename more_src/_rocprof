#compdef rocprof
# Documentation: https://rocm.docs.amd.com/projects/rocprofiler/en/docs-5.6.1/rocprof.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rocprof: AMD ROCm performance profiler
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--list-basic[list basic HW counters]' \
  '--list-derived[list derived metrics with formulas]' \
  '--verbose[verbose, dump base counters]' \
  '-i[input metrics file]:file:_files' \
  '-o[output CSV file]:file:_files' \
  '-d[output data directory]:dir:_files -/' \
  '-t[temporary directory]:dir:_files -/' \
  '--basenames[truncate to base kernel names]:val:(on off)' \
  '--timestamp[include dispatch timestamps]:val:(on off)' \
  '--obj-tracking[track code objects]:val:(on off)' \
  '--cmd-qts[quote profiled cmd line]:val:(on off)' \
  '--hsa-trace[trace HSA API]' \
  '--hip-trace[trace HIP API]' \
  '--kfd-trace[trace KFD driver]' \
  '--roctx-trace[trace rocTX annotations]' \
  '--sys-trace[system-wide trace HIP+HSA+GPU]' \
  '--trace-start[enable trace on start]:val:(on off)' \
  '--trace-period[periodic trace]:delay:length:rate:' \
  '--flush-rate[trace flush rate]:rate:' \
  '--stats[generate stats CSV]' \
  '--ctx-wait[wait for outstanding contexts]:val:(on off)' \
  '--ctx-limit=[max concurrent contexts]:n:' \
  '--heartbeat[progress heartbeat rate]:rate:' \
  '--parallel-kernels[enable concurrent kernels]' \
  '--merge-traces[merge multiple profiler dirs]' \
  '--tool-version[rocprof tool version]:v:(1 2)' \
  '*:application args:_files' && ret=0
return ret
