#compdef sftahread
# Documentation: http://www.ahay.org/RSF/sftahread.html
# Madagascar: read trace and headers, write trace-and-header (tah) to stdout

local ret=1

_arguments -s \
  'headers=[trace header file name (default input _hdr.rsf)]:file:_files' \
  'input=[input file for trace amplitudes]:file:_files' \
  'makeheader=[load headers using input file axis labels]:flag:(y n)' \
  'verbose=[print level: 0 terse 1 info 2 chatty 3 debug]:level:(0 1 2 3)' \
  '*:rsf file:_files' && ret=0

return ret
