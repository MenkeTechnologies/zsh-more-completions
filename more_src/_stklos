#compdef stklos stklos-compile stklos-config stklos-genlex stklos-pkg

local curcontext="$curcontext" state line ret=1

case $service in
  (stklos)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-l --load)'{-l+,--load=}'[load file]:file:_files -g "*.scm *.stk"' \
      '(-f --file)'{-f+,--file=}'[execute file]:file:_files -g "*.scm *.stk"' \
      '(-e --execute)'{-e+,--execute=}'[execute expression]:expr:' \
      '(-b --boot-file)'{-b+,--boot-file=}'[boot image]:file:_files' \
      '(-d --debug)'{-d,--debug}'[enable debugger]' \
      '(-D --no-debug)'{-D,--no-debug}'[disable debugger]' \
      '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
      '(-i --interactive)'{-i,--interactive}'[force interactive]' \
      '(-n --no-init-file)'{-n,--no-init-file}'[skip init file]' \
      '(-c --case-sensitive)'{-c,--case-sensitive}'[case sensitive reader]' \
      '(-I --case-insensitive)'{-I,--case-insensitive}'[case insensitive]' \
      '(-u --utf8-encoding)'{-u+,--utf8-encoding=}'[UTF-8 mode]:m:(yes no)' \
      '(-A --conf-dir)'{-A+,--conf-dir=}'[config dir]:dir:_files -/' \
      '*'{-I+,--load-path=}'[load path]:dir:_files -/' \
      '*'{-L+,--prepend-load-path=}'[prepend load path]:dir:_files -/' \
      '--no-startup-message[suppress startup msg]' \
      '*: :_files -g "*.scm *.stk"' && ret=0 ;;
  (stklos-compile)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '(-c --case-sensitive)'{-c,--case-sensitive}'[case sensitive]' \
      '(-l --line-info)'{-l,--line-info}'[include line info]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-C --no-time)'{-C,--no-time}'[no timestamp]' \
      '(-D --no-debug)'{-D,--no-debug}'[no debug]' \
      '(-s --shared)'{-s,--shared}'[shared library]' \
      '(-x --executable)'{-x,--executable}'[standalone executable]' \
      '*: :_files -g "*.scm *.stk"' && ret=0 ;;
  (stklos-config)
    _arguments -C \
      '--prefix[print prefix]' \
      '--libdir[print libdir]' \
      '--bindir[print bindir]' \
      '--datadir[print datadir]' \
      '--cflags[print CFLAGS]' \
      '--ldflags[print LDFLAGS]' \
      '--libs[print LIBS]' \
      '--cc[print CC]' \
      '--version[print version]' \
      '--help[help]' && ret=0 ;;
  (stklos-pkg)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '1:command:(install uninstall list search update upgrade info config build new)' \
      '*: :_files' && ret=0 ;;
  (*)
    _arguments '*: :_files' && ret=0 ;;
esac

return ret
