#compdef varnishtop
# Documentation: https://man.archlinux.org/search?q=varnishtop
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-1[one-shot mode]' \
  '-f[show full text]' \
  '-i+[include tag]:tag:' \
  '-I+[include regex]:regex:' \
  '-x+[exclude tag]:tag:' \
  '-X+[exclude regex]:regex:' \
  '-N+[varnish vsm file]:file:_files' \
  '-n+[varnish instance name]:name:' \
  '-T+[seconds before exit]:sec:' \
  '-q+[VSL query]:query:' \
  '-r+[varnish log file]:file:_files' \
  '-c[include client requests]' \
  '-b[include backend requests]' \
  '-d[start with old entries]' \
  '-p+[period sec]:sec:' && ret=0

return ret
