#compdef maxima-jupyter
# Documentation: https://man.archlinux.org/search?q=maxima-jupyter
# Reference accessed: 2026-05-16

# maxima-jupyter: Jupyter kernel for Maxima
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*::maxima-jupyter args:_files' && ret=0
return ret
