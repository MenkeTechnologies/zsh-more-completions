#compdef oj
# Documentation: https://man.archlinux.org/search?q=oj
# Reference accessed: 2026-05-16

# ohler55/ojg/cmd/oj — Go `flag` package (`main.go` init)

local ret=1
_arguments -s -S \
  '-i+[indent spaces]:n:' \
  '-c[color output]' \
  '-s[sort object keys]' \
  '-b[bright color]' \
  '-o[omit nil/empty fields]' \
  '-w[wrap extracts in array]' \
  '-z[lazy / SEN input]' \
  '-sen[output Simple Encoding Notation]' \
  '-t[indent with tabs]' \
  '-annotate[annotate dig paths]' \
  '*-x+[JSONPath extract]:path:' \
  '*-m+[match filter script]:expr:' \
  '*-d+[delete path]:path:' \
  '-dig[token/stream dig mode]' \
  '-discover[locate JSON/SEN in file]' \
  '-version[print version and exit]' \
  '-a+[assembly plan or @file]:plan:' \
  '-r[show root with assemble plan]' \
  '-p+[pretty width.depth.align]:spec:' \
  '-html[HTML colored output]' \
  '-safe[escape HTML entities]' \
  '-f+[config file (- disables)]:file:_files' \
  '-fn[describe assembly functions]' \
  '-help-fn[describe assembly functions]' \
  '-help-filter[describe filter operators]' \
  '-help-config[describe .oj-config.sen]' \
  '-mongo[parse mongo extended JSON]' \
  '-conv+[time/converter preset]:name:' \
  '*::JSON file or inline JSON:_files' && ret=0
return ret
