#compdef twilio

# Zsh completion for twilio - Twilio CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:access the Twilio REST API'
  'autocomplete:display autocomplete installation instructions'
  'config:manage Twilio CLI configuration'
  'debugger:listen to Twilio debugger events'
  'help:display help'
  'login:create a new profile to store credentials'
  'logout:remove all credentials'
  'plugins:list installed plugins'
  'profiles:manage credentials for Twilio profiles'
  'phone-numbers:manage Twilio phone numbers'
  'update:update the CLI'
  'version:show version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logLevel)'{-l,--logLevel}'[log level]:level:(debug info warn error)' \
  '(-o --output)'{-o,--output}'[output format]:format:(columns json tsv)' \
  '(-p --profile)'{-p,--profile}'[profile to use]:profile:' \
  '--silent[silence all output]' \
  '--region[Twilio region]:region:' \
  '--edge[Twilio edge location]:edge:' \
  '--no-color[disable colored output]' \
  '--version[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'twilio command' commands && ret=0
    ;;
  args)
    case $words[1] in
      profiles)
        local -a profile_commands=(
          'add:add a new profile'
          'create:create a new profile'
          'list:list all profiles'
          'remove:remove a profile'
          'use:set the active profile'
        )
        _describe -t profile-commands 'profiles command' profile_commands && ret=0
        ;;
      plugins)
        local -a plugin_commands=(
          'install:install a plugin'
          'link:link a plugin into the CLI'
          'uninstall:uninstall a plugin'
          'update:update plugins'
          'inspect:inspect plugins'
        )
        _describe -t plugin-commands 'plugins command' plugin_commands && ret=0
        ;;
      phone-numbers)
        local -a pn_commands=(
          'list:list phone numbers'
          'update:update a phone number'
          'buy:purchase a phone number'
        )
        _describe -t pn-commands 'phone-numbers command' pn_commands && ret=0
        ;;
      api)
        _message 'API resource path' && ret=0
        ;;
      debugger)
        local -a debugger_commands=(
          'logs:list debugger logs'
          'live:listen for debugger events'
        )
        _describe -t debugger-commands 'debugger command' debugger_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
