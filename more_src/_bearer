#compdef bearer
# Documentation: https://docs.bearer.com/reference/commands/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Bearer security scanner CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'scan:Scan a directory or file'
      'init:Generate default config file'
      'ignore:Manage ignored findings'
      'version:Print version'
    )
    _describe -t commands 'bearer command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      scan)
        _arguments -s -S \
          '--config-file=[path to config file]:config file:_files' \
          '(-f --format)'{-f,--format}'=[output format]:format:(json yaml sarif html gitlab-sast rdjson)' \
          '--output=[output file path]:output file:_files' \
          '--report=[report type]:type:(security privacy dataflow)' \
          '--severity=[minimum severity to report]:severity:(critical high medium low warning)' \
          '--scanner=[scanner to use]:scanner:(sast secrets)' \
          '--skip-path=[paths to skip]:path:_files' \
          '--only-rule=[only run specific rules]:rule' \
          '--skip-rule=[skip specific rules]:rule' \
          '--external-rule-dir=[directory with custom rules]:directory:_directories' \
          '--context=[set context for the scan]:context' \
          '--diff[report only diff vs base branch]' \
          '--quiet[suppress progress output]' \
          '--hide-progress-bar[hide progress bar]' \
          '--debug[enable debug logging]' \
          '--force[force scanning of files]' \
          '--exit-code=[set exit code for findings]:code' \
          '-h[show help]' \
          '--help[show help]' \
          '1:target path:_files' && ret=0
        ;;
      ignore)
        local -a subcmds=(
          'show:Show ignored fingerprint'
          'add:Add an ignored fingerprint'
          'remove:Remove an ignored fingerprint'
          'migrate:Migrate ignored fingerprints to ignore file'
          'pull:Pull ignored fingerprints from cloud'
        )
        if (( CURRENT == 2 )); then
          _describe -t subcmds 'ignore subcommand' subcmds && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
