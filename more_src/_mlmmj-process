#compdef mlmmj-process
# Documentation: https://mlmmj.org/mlmmj-process.html
# Reference accessed: 2026-05-30
# mlmmj-process — process mail in an mlmmj mailing list (access control, header mgmt, moderation).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L+[full path to list directory]:dir:_directories' \
  '-m+[full path to mail file]:file:_files' \
  '-P[skip mlmmj-send execution (debug only)]' \
  && ret=0

return ret
