#compdef ggshield

# Zsh completion for ggshield - GitGuardian CLI for secrets detection

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '--allow-self-signed[allow self-signed certificates]' \
  '--json[JSON output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'secret:secret detection commands'
      'iac:Infrastructure as Code scanning'
      'sca:Software Composition Analysis'
      'honeytoken:manage honeytokens'
      'install:install git hooks'
      'quota:show scanning quota'
      'api-status:show API status'
    )
    _describe -t commands 'ggshield command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout token)' && ret=0
        ;;
      secret)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(scan ignore)' \
          '*::scanarg:->scanargs' && ret=0
        ;;
      iac)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(scan diff)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-m+[hook type]:type:(pre-commit pre-push pre-receive)' \
          '--mode=[hook type]:type:(pre-commit pre-push pre-receive)' \
          '-f[force overwrite existing hooks]' \
          '--force[force overwrite existing hooks]' && ret=0
        ;;
    esac
    case $state in
      scanargs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all-policies[use all policies]' \
          '--exit-zero[return exit code 0 on non-blocking incidents]' \
          '--show-secrets[show secrets in output]' \
          '--no-git[do not use git]' \
          '--ignore-known-secrets[ignore already known secrets]' \
          '*:scan target:(commit pre-commit ci path repo docker)' && ret=0
        ;;
    esac
    ;;
esac

return ret
