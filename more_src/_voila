#compdef voila

# Zsh completion for voila - Jupyter notebooks as standalone web applications

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--port=[port to listen on]:port' \
  '--ip=[IP address to listen on]:address' \
  '--no-browser[do not open a browser window]' \
  '--autoreload[enable live reloading]' \
  '--template=[template to use for rendering]:template' \
  '--theme=[theme name for templates]:theme:(dark light)' \
  '--strip_sources=[strip source code from notebooks]:enable:(True False)' \
  '--enable_nbextensions=[enable notebook extensions]:enable:(True False)' \
  '--show_tracebacks[show full tracebacks on errors]' \
  '--preheat_kernel=[pre-start kernels]:enable:(True False)' \
  '--pool_size=[size of preheated kernel pool]:size' \
  '--base_url=[base URL for the Voila server]:url' \
  '--static=[serve static content]:path:_files -/' \
  '--server_url=[URL for the Jupyter server]:url' \
  '--token=[authentication token]:token' \
  '--debug[enable debug mode]' \
  '--config=[configuration file]:file:_files -g "*.py"' \
  '--VoilaConfiguration.resources=[resources config]:resources' \
  '--VoilaConfiguration.template=[template name]:template' \
  '*:notebook:_files -g "*.ipynb"'
