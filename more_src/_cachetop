#compdef cachetop cachetop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/cachetop.py argparse)
# Reference accessed: 2026-05-29
# cachetop — top-like display of page cache HITS/MISSES/DIRTIES per process (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '1:interval (seconds, default 5):' \
  && ret=0

return ret
