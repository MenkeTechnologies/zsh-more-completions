#compdef blkcalc
# Documentation: https://www.sleuthkit.org/sleuthkit/man/blkcalc.html
# Source: sleuthkit/sleuthkit man/blkcalc.1 — convert between disk unit addresses across regular/unallocated/slack images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d -s -u)-d[unit address is from regular disk image (convert to unallocated)]' \
    '(-d -s -u)-s[unit address is in the slack image]' \
    '(-d -s -u)-u[unit address is in the unallocated unit image]' \
    '-v[verbose output to stderr]' \
    '-V[display version]' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-f[identify file system type of image]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '*:image file or unit addr:_files' \
    && ret=0

return ret
