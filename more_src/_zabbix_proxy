#compdef zabbix_proxy

local -a runtime_opts

runtime_opts=(
  config_cache_reload snmp_cache_reload housekeeper_execute
  diaginfo prof_enable prof_disable
  log_level_increase log_level_decrease
)

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-R --runtime-control)'{-R,--runtime-control}"=[runtime option]:opt:($runtime_opts)" \
  '(-T --test-config)'{-T,--test-config}'[test config and exit]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
