#compdef featureform
# Documentation: https://github.com/featureform/featureform
# Reference accessed: 2026-05-23
# Verified: featureform --help (Featureform feature store CLI).

# Zsh completion for featureform - Featureform feature store CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'featureform command' \
      'apply[apply resources]' \
      'deploy[deploy resources]' \
      'get[get resources of a given type]' \
      'head[head resources]' \
      'list[list resources]' \
      'search[search resources]' \
      'stop[stop resources]' \
      'version[show version]' && ret=0
    ;;
esac

return ret
