#compdef prysk
# Functional testing framework for CLI applications

local ret=1

_arguments -s -S \
  '--shell=[specify shell]:shell:_files' \
  '--shell-opts=[shell options]:options:' \
  '--indent=[specify indent level]:indent:(2 4)' \
  '-E[do not use default environment]' \
  '-i[run tests interactively]' \
  '-v[verbose output]' \
  '-d[debug mode]' \
  '--xfail[expected failures]' \
  '--timeout=[test timeout in seconds]:seconds:' \
  '-j[number of parallel jobs]:jobs:' \
  '--yes[accept all test output as correct]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:test files:_files -g "*.t"' && ret=0

return ret
