#compdef jwt_tool

# Zsh completion for jwt_tool (Python JWT exploitation/testing tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(-t --targeturl)'{-t,--targeturl}'=[URL to send requests to]:url:' \
  '(-rc --cookies)'{-rc,--cookies}'=[request cookies to send]:cookies:' \
  '(-rh --headers)'{-rh,--headers}'=[request headers to send]:headers:' \
  '(-pd --postdata)'{-pd,--postdata}'=[POST data to send]:data:' \
  '(-cv --canaryvalue)'{-cv,--canaryvalue}'=[canary value for testing]:value:' \
  '(-np --noproxy)'{-np,--noproxy}'[disable proxy for requests]' \
  '(-nr --noredir)'{-nr,--noredir}'[disable redirects]' \
  '(-M --mode)'{-M,--mode}'=[scanning mode]:mode:((pb\:"playbook" er\:"exploit/recon" cc\:"claim check" at\:"automated test" fuzz\:"fuzz"))' \
  '(-T --tamper)'{-T,--tamper}'[tamper with the token]' \
  '(-I --inject)'{-I,--inject}'[inject claims into the token]' \
  '(-S --sign)'{-S,--sign}'=[sign the token with the given algorithm]:algorithm:(hs256 hs384 hs512 rs256 rs384 rs512 es256 es384 es512 ps256 ps384 ps512)' \
  '(-pk --privkey)'{-pk,--privkey}'=[private key for signing]:file:_files' \
  '(-pr --public)'{-pr,--public}'=[public key for verification]:file:_files' \
  '(-x --exploit)'{-x,--exploit}'=[exploit type]:exploit:((a\:"alg\:none" n\:"null signature" b\:"blank password" s\:"spoof JWKS" k\:"key confusion" i\:"inject inline JWKS"))' \
  '(-ju --jku-url)'{-ju,--jku-url}'=[URL for JKU header injection]:url:' \
  '(-jw --jwks-url)'{-jw,--jwks-url}'=[URL for x5u header injection]:url:' \
  '(-hp --header-path)'{-hp,--header-path}'=[header path to inject]:path:' \
  '(-hc --header-claim)'{-hc,--header-claim}'=[header claim to tamper]:claim:' \
  '(-pc --payload-claim)'{-pc,--payload-claim}'=[payload claim to tamper]:claim:' \
  '(-hv --header-value)'{-hv,--header-value}'=[value for the header claim]:value:' \
  '(-pv --payload-value)'{-pv,--payload-value}'=[value for the payload claim]:value:' \
  '(-C --crack)'{-C,--crack}'[crack the JWT secret]' \
  '(-d --dict)'{-d,--dict}'=[dictionary file for cracking]:file:_files' \
  '(-p --password)'{-p,--password}'=[password for cracking/signing]:password:' \
  '(-kf --keyfile)'{-kf,--keyfile}'=[key file for cracking/signing]:file:_files' \
  '(-V --verify)'{-V,--verify}'[verify the token]' \
  '(-Q --query)'{-Q,--query}'=[query a value from the token]:query:' \
  '1:JWT token:' \
  && ret=0

return ret
