#compdef s6-svscan
# Documentation: https://skarnet.org/software/s6/s6-svscan.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-d+[readiness notification fd (>=3)]:fd' \
  '-X+[console holder fd]:fd' \
  '-C+[maximum number of service directories]:services_max' \
  '-L+[maximum length for names in scan directory]:name_max' \
  '-t+[rescan interval in milliseconds]:rescan ms' \
  '1:scan directory:_files -/' && ret=0

return ret
