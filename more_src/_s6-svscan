#compdef s6-svscan

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[set maximum number of services]:number' \
  '-t[set rescan interval in milliseconds]:milliseconds' \
  '-d[set notify readiness fd]:fd number' \
  '-X[set early exit code]:exit code' \
  '-S[log to stderr even if logging pipe is set]' \
  '-L[set logging pipe]:pipe' \
  '-s[use signal-based notifications]' \
  '1:scan directory:_files -/' && ret=0

return ret
