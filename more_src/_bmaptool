#compdef bmaptool

# Zsh completion for bmaptool - flash images with bmap files

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'copy:Copy an image to a block device using bmap'
  'create:Create a bmap file for an image'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:subcommand:->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'bmaptool subcommand' subcommands
    ;;
  args)
    case $words[1] in
      copy)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '--bmap[bmap file path]:bmap file:_files -g "*.bmap"' \
          '--nobmap[disable bmap, copy entire image]' \
          '--no-sig-verify[do not verify bmap file signature]' \
          '1:image file:_files' \
          '2:destination:_files'
        ;;
      create)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output}'[output bmap file]:output file:_files' \
          '1:image file:_files'
        ;;
    esac
    ;;
esac

return ret
