#compdef kronosnetd kronosnetctl
# _kronosnetd — Kronosnet Team kronosnetd VPN daemon for cluster high-availability stack libknet HA layer (kronosnet team, C); custom argparse
# upstream: https://github.com/kronosnet/kronosnet

_kronosnetd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-f[run in foreground]' \
        '--foreground[run in foreground]' \
        '-d[debug logging]' \
        '--debug[debug logging]' \
        '-l+[log destination]:l:(stdout syslog file)' \
        '--log=+[log destination]:l:(stdout syslog file)' \
        '-L+[log level]:l:(debug info warning error fatal)' \
        '--log-level=+[log level]:l:(debug info warning error fatal)' \
        '-p+[pid file]:file:_files' \
        '--pid=+[pid file]:file:_files' \
        '-s+[shutdown timeout]:n:' \
        '--shutdown-timeout=+[shutdown timeout]:n:' \
        '-u+[user]:user:_users' \
        '--user=+[user]:user:_users' \
        '-g+[group]:group:_groups' \
        '--group=+[group]:group:_groups' \
        '-S[disable shared net]'
}

_kronosnetd "$@"
