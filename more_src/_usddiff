#compdef usddiff
# Documentation: https://openusd.org/release/toolset.html
# Runs a diff program on two USD-readable files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --noeffect)'{-n,--noeffect}'[do not modify either file]' \
  '(-f --flatten)'{-f,--flatten}'[fully compose both layers as Usd Stages]' \
  '(-q --brief)'{-q,--brief}'[do not return full diff results]' \
  '*:USD file:_files' && ret=0

return ret
