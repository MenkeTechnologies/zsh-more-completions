#compdef sheldon

# Zsh completion for sheldon - fast, configurable, shell plugin manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:Initialize a new config file'
  'add:Add a new plugin to the config file'
  'edit:Open up the config file in the default editor'
  'remove:Remove a plugin from the config file'
  'sync:Install the plugins sources and generate the lock file'
  'lock:Generate the lock file'
  'source:Generate and print out the script'
  'completions:Generate completions for a shell'
  'version:Print version info and exit'
  'help:Print help'
)

_arguments -s -S \
  '--color[control when color is used]:color:(always auto never)' \
  '--no-color[do not use color in output]' \
  '-q[suppress output]' \
  '--quiet[suppress output]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '--profile[profile to use for source command]:profile:' \
  '--config-dir[path to the config directory]:dir:_files -/' \
  '--data-dir[path to the data directory]:dir:_files -/' \
  '--config-file[path to the config file]:file:_files' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      add)
        _arguments \
          '--git[add a Git hosted plugin]:URL:' \
          '--gist[add a Gist hosted plugin]:ID:' \
          '--github[add a GitHub hosted plugin]:user/repo:' \
          '--gitlab[add a GitLab hosted plugin]:user/repo:' \
          '--bitbucket[add a Bitbucket hosted plugin]:user/repo:' \
          '--local[add a local plugin]:path:_files -/' \
          '--remote[add a remote plugin]:URL:' \
          '--inline[add an inline plugin]:script:' \
          '--proto[protocol to use when installing]:proto:(https ssh git)' \
          '--branch[branch to use for the plugin]:branch:' \
          '--rev[revision to use for the plugin]:rev:' \
          '--tag[tag to use for the plugin]:tag:' \
          '--dir[subdirectory of the plugin]:dir:' \
          '--use[template to use for the plugin]:template:' \
          '--apply[templates to apply]:templates:' \
          ':name:' && ret=0
        ;;
      remove)
        _arguments ':plugin name:' && ret=0
        ;;
      completions)
        _arguments ':shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
