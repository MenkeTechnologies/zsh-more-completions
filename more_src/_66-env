#compdef 66-env
# 66-env — manage environment variables for 66 services (Obarun/s6)

_arguments -s -S \
  '-h[show help]' \
  '-z[use color output]' \
  '-v[set verbosity level]:verbosity:(0 1 2 3 4)' \
  '-t[set tree name]:tree name:' \
  '-r[replace existing environment variable]' \
  '*:service name:'
