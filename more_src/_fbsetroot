#compdef fbsetroot

# fbsetroot: set root window background (Fluxbox)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-display[X display]:display:' \
  '-fg[foreground color]:color:' \
  '-bg[background color]:color:' \
  '-solid[solid color]:color:' \
  '-mod[modula pattern]:XxY:' \
  '-gradient[gradient type]:type:(Horizontal Vertical Diagonal CrossDiagonal PipeCross Elliptic Rectangle Pyramid)' \
  '-from[gradient start color]:color:' \
  '-to[gradient end color]:color:' \
  '*::fbsetroot args:_files' && ret=0
return ret
