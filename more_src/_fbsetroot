#compdef fbsetroot
# Documentation: https://man.archlinux.org/man/fbsetroot.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fbsetroot: set root window background (Fluxbox / Blackbox)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-display[X display]:display:' \
  '(-fg -foreground)'{-fg,-foreground}'[foreground color (needed for -mod)]:color:' \
  '(-bg -background)'{-bg,-background}'[background color (needed for -mod)]:color:' \
  '-solid[solid color]:color:' \
  '-mod[modula pattern]:x:' \
  '-gradient[gradient texture]:texture:(Horizontal Vertical Diagonal CrossDiagonal PipeCross Elliptic Rectangle Pyramid)' \
  '-from[gradient start color]:color:' \
  '-to[gradient end color]:color:' \
  '*::fbsetroot args:_files' && ret=0
return ret
