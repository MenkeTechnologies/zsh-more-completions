#compdef fslroi
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/utilities/fslutils.html
# fslroi - extract a region of interest (ROI) from an image (positional args)

local ret=1

_arguments -s -S \
  '1:input volume:_files' \
  '2:output volume:_files' \
  '3:xmin or tmin:' \
  '4:xsize or tsize:' \
  '5:ymin:' \
  '6:ysize:' \
  '7:zmin:' \
  '8:zsize:' \
  '9:tmin:' \
  '10:tsize:' && ret=0

return ret
