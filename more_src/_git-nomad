#compdef git-nomad
# Source: cargo binstall git-nomad@0.8.0
# Probed via: completions zsh
# Repository: https://github.com/rraval/git-nomad

autoload -U is-at-least

_git-nomad() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--git=[Git binary to use]: :_command_names -e' \
'-U+[User name, shared by multiple clones, unique per remote]: :_users' \
'--user=[User name, shared by multiple clones, unique per remote]: :_users' \
'-H+[Host name, unique per clone]: :_hosts' \
'--host=[Host name, unique per clone]: :_hosts' \
'-R+[Git remote to operate against]: :' \
'--remote=[Git remote to operate against]: :' \
'-q[Suppress all output]' \
'--quiet[Suppress all output]' \
'*-v[Verbose output, repeat up to 2 times for increasing verbosity]' \
'*--verbose[Verbose output, repeat up to 2 times for increasing verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_git-nomad_commands" \
"*::: :->git-nomad" \
&& ret=0
    case $state in
    (git-nomad)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:git-nomad-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
'--git=[Git binary to use]: :_command_names -e' \
'-U+[User name, shared by multiple clones, unique per remote]: :_users' \
'--user=[User name, shared by multiple clones, unique per remote]: :_users' \
'-H+[Host name, unique per clone]: :_hosts' \
'--host=[Host name, unique per clone]: :_hosts' \
'-R+[Git remote to operate against]: :' \
'--remote=[Git remote to operate against]: :' \
'-q[Suppress all output]' \
'--quiet[Suppress all output]' \
'*-v[Verbose output, repeat up to 2 times for increasing verbosity]' \
'*--verbose[Verbose output, repeat up to 2 times for increasing verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
'--print=[Format for listing nomad managed refs]: :((grouped\:"Print ref name and commit ID grouped by host"
ref\:"Print only the ref name"
commit\:"Print only the commit ID"))' \
'*-b+[Only display refs for the named branch (can be specified multiple times)]: :_default' \
'*--branch=[Only display refs for the named branch (can be specified multiple times)]: :_default' \
'--git=[Git binary to use]: :_command_names -e' \
'-U+[User name, shared by multiple clones, unique per remote]: :_users' \
'--user=[User name, shared by multiple clones, unique per remote]: :_users' \
'-H+[Host name, unique per clone]: :_hosts' \
'--host=[Host name, unique per clone]: :_hosts' \
'-R+[Git remote to operate against]: :' \
'--remote=[Git remote to operate against]: :' \
'-F[Fetch refs from remote before listing]' \
'--fetch[Fetch refs from remote before listing]' \
'--head[Only display refs for the current branch]' \
'--print-self[Print refs for the current host]' \
'-q[Suppress all output]' \
'--quiet[Suppress all output]' \
'*-v[Verbose output, repeat up to 2 times for increasing verbosity]' \
'*--verbose[Verbose output, repeat up to 2 times for increasing verbosity]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(purge)
_arguments "${_arguments_options[@]}" : \
'--git=[Git binary to use]: :_command_names -e' \
'-U+[User name, shared by multiple clones, unique per remote]: :_users' \
'--user=[User name, shared by multiple clones, unique per remote]: :_users' \
'-H+[Host name, unique per clone]: :_hosts' \
'--host=[Host name, unique per clone]: :_hosts' \
'-R+[Git remote to operate against]: :' \
'--remote=[Git remote to operate against]: :' \
'--all[Delete refs for all hosts]' \
'-q[Suppress all output]' \
'--quiet[Suppress all output]' \
'*-v[Verbose output, repeat up to 2 times for increasing verbosity]' \
'*--verbose[Verbose output, repeat up to 2 times for increasing verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--git=[Git binary to use]: :_command_names -e' \
'-U+[User name, shared by multiple clones, unique per remote]: :_users' \
'--user=[User name, shared by multiple clones, unique per remote]: :_users' \
'-H+[Host name, unique per clone]: :_hosts' \
'--host=[Host name, unique per clone]: :_hosts' \
'-R+[Git remote to operate against]: :' \
'--remote=[Git remote to operate against]: :' \
'-q[Suppress all output]' \
'--quiet[Suppress all output]' \
'*-v[Verbose output, repeat up to 2 times for increasing verbosity]' \
'*--verbose[Verbose output, repeat up to 2 times for increasing verbosity]' \
'-h[Print help]' \
'--help[Print help]' \
'::shell -- Shell dialect:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_git-nomad__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:git-nomad-help-command-$line[1]:"
        case $line[1] in
            (sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(ls)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(purge)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_git-nomad_commands] )) ||
_git-nomad_commands() {
    local commands; commands=(
'sync:Sync local branches to remote' \
'ls:List nomad managed refs' \
'purge:Delete nomad refs locally and on the remote' \
'completions:Print tab-completion code for a given supported shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'git-nomad commands' commands "$@"
}
(( $+functions[_git-nomad__completions_commands] )) ||
_git-nomad__completions_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad completions commands' commands "$@"
}
(( $+functions[_git-nomad__help_commands] )) ||
_git-nomad__help_commands() {
    local commands; commands=(
'sync:Sync local branches to remote' \
'ls:List nomad managed refs' \
'purge:Delete nomad refs locally and on the remote' \
'completions:Print tab-completion code for a given supported shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'git-nomad help commands' commands "$@"
}
(( $+functions[_git-nomad__help__completions_commands] )) ||
_git-nomad__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad help completions commands' commands "$@"
}
(( $+functions[_git-nomad__help__help_commands] )) ||
_git-nomad__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad help help commands' commands "$@"
}
(( $+functions[_git-nomad__help__ls_commands] )) ||
_git-nomad__help__ls_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad help ls commands' commands "$@"
}
(( $+functions[_git-nomad__help__purge_commands] )) ||
_git-nomad__help__purge_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad help purge commands' commands "$@"
}
(( $+functions[_git-nomad__help__sync_commands] )) ||
_git-nomad__help__sync_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad help sync commands' commands "$@"
}
(( $+functions[_git-nomad__ls_commands] )) ||
_git-nomad__ls_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad ls commands' commands "$@"
}
(( $+functions[_git-nomad__purge_commands] )) ||
_git-nomad__purge_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad purge commands' commands "$@"
}
(( $+functions[_git-nomad__sync_commands] )) ||
_git-nomad__sync_commands() {
    local commands; commands=()
    _describe -t commands 'git-nomad sync commands' commands "$@"
}

if [ "$funcstack[1]" = "_git-nomad" ]; then
    _git-nomad "$@"
else
    compdef _git-nomad git-nomad
fi
