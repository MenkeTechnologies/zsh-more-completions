#compdef mri_seg_overlap
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_seg_overlap/mri_seg_overlap.help.xml
# Compute similarity measures between two segmentation volumes

local ret=1

_arguments -s -S \
  '(-o --out)'{-o,--out}'[export detailed overlap to JSON]:file:_files' \
  '(-m --measures)'{-m,--measures}'[statistical comparisons]:measure:(dice jaccard voldiff)' \
  '(-l --labels)'{-l,--labels}'[label indices for analysis]:labels:' \
  '(-n --names)'{-n,--names}'[custom names for label indices]:names:' \
  '(-f --labelfile)'{-f,--labelfile}'[freesurfer lookup-table file]:file:_files' \
  '(-x --no-names)'{-x,--no-names}'[omit label names from output]' \
  '(-s --seg)'{-s,--seg}'[analyze 12 major anatomical structures]' \
  '(-q --quiet)'{-q,--quiet}'[suppress terminal output]' \
  '*:volume:_files' && ret=0

return ret
