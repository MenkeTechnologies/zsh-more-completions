#compdef impacket-getuserspns

# Impacket GetUserSPNs.py: enumerate user SPNs (Kerberoasting)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '-request[request TGS for each SPN]' \
  '-request-user[user to Kerberoast]:user:' \
  '-save[save TGS to disk]' \
  '-outputfile[output file]:file:_files' \
  '-no-preauth[don'\''t use preauth (AS-REP roast)]' \
  '-usersfile[user list file]:file:_files' \
  '-target-domain[target domain]:domain:' \
  '-stealth[avoid LDAP UAC bitmask query]' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-no-pass[no password prompt]' \
  '-k[Kerberos auth]' \
  '-aesKey[AES key]:key:' \
  '-dc-ip[DC IP]:ip:' \
  '-dc-host[DC hostname]:host:' \
  '*:domain/user[:password]:' && ret=0
return ret
