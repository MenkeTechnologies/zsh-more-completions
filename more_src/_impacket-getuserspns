#compdef impacket-getuserspns

# impacket-getuserspns: Kerberoasting (request TGS for SPN users)
local curcontext="$curcontext" ret=1
_arguments -C \
  \
  "(- *)"{-h,--help}"[show help]" \
  "-debug[verbose debug output]" \
  "-ts[print timestamps in log]" \
  "-ts-utc[print timestamps in UTC]" \
  "-target-ip[target IP]:ip:" \
  "-dc-ip[domain controller IP]:ip:" \
  "-codec[codec for non-utf-8 strings]:codec:" \
  "-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:" \
  "-no-pass[do not ask for password]" \
  "-k[use Kerberos]" \
  "-aesKey[AES key in hex]:hex:" \
  "-cert-pem[pem certificate file]:file:_files" \
  "-cert-pfx[pkcs12 cert file]:file:_files" \
  "-pfx-pass[pkcs12 cert password]:pass:" \
  -request[request TGS for users with SPN] -request-user[request TGS for specific user]:user: -save[save TGS to disk] -outputfile[output file]:file:_files -usersfile[users file]:file:_files -dc-host[domain controller hostname]:host:_hosts \
  '*::impacket-getuserspns args:_files' && ret=0
return ret
