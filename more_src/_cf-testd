#compdef cf-testd
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-testd.html
# Source: cfengine/core cf-testd/cf-testd.c — CFEngine test/benchmark server daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --address)'{-a+,--address=}'[bind to specific address]:addr:_default' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(- *)'{-h,--help}'[show help]' \
    '(-I --inform)'{-I,--inform}'[print basic info]' \
    '(-j --jobs)'{-j+,--jobs=}'[number of parallel jobs (threads)]:n:_default' \
    '(-k --key-file)'{-k+,--key-file=}'[private key for communication]:file:_files' \
    '(-l --timestamp)'{-l,--timestamp}'[log timestamps]' \
    '(-p --port)'{-p+,--port=}'[listen port]:port:_default' \
    '(-r --report)'{-r+,--report=}'[read report from file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
