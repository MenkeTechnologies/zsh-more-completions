#compdef census-cli
# _census-cli — Census census-cli CLI command-line frontend wrapping the Census reverse-ETL Operational Analytics platform managing sources destinations syncs models segments cohorts datasets activations entities accounts users metadata webhooks Identity Resolution Audience Activation Hub Census API administering integrations Salesforce HubSpot (Census team, Go); cobra
# upstream: https://www.getcensus.com/

_census-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'source:source management'
        'destination:destination management'
        'sync:sync operations'
        'model:model management'
        'segment:segment management'
        'cohort:cohort management'
        'dataset:dataset management'
        'activation:activation management'
        'entity:entity management'
        'workspace:workspace management'
        'user:user management'
        'webhook:webhook management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--workspace-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'census-cli subcommand' sub ;;
        args)
            case $words[1] in
                source|destination|sync|model|segment|cohort|dataset|activation|entity|workspace|user|webhook) _arguments '1:op:(list get create update delete run start stop pause resume enable disable)' '*:id:' ;;
            esac
            ;;
    esac
}

_census-cli "$@"
