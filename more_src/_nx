#compdef nx

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:set up Nx in workspace'
  'add:install and initialize plugins'
  'list:view installed plugins/capabilities'
  'graph:visualize project dependencies'
  'show:display workspace info'
  'run:execute a target for a project'
  'run-many:run targets across multiple projects'
  'affected:run targets on changed projects'
  'watch:monitor and execute on changes'
  'format:check:verify formatting'
  'format:write:apply formatting'
  'sync:run sync generators'
  'sync:check:verify sync generators'
  'generate:create code via schematics'
  'release:versioning and publishing'
  'migrate:update packages and run migrations'
  'repair:fix unsupported configurations'
  'daemon:manage background process'
  'reset:clear cache and metadata'
  'report:display version info'
  'import:integrate code from another repo'
  'connect:link workspace to Nx Cloud'
  'login:Nx Cloud login'
  'logout:Nx Cloud logout'
  'view-logs:open cloud analytics dashboard'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--verbose[verbose output]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'nx subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--parallel=[parallel jobs]:n:' \
          '--graph[show graph]' \
          '--skipNxCache[skip cache]' \
          '(-c --configuration)'{-c,--configuration=}'[configuration]:cfg:' \
          ':project[:target[:configuration]]:' && ret=0
        ;;
      (run-many)
        _arguments \
          '*'{-p,--projects=}'[projects]:projects:' \
          '*-t[targets]:target:' \
          '*--exclude=[exclude]:projects:' \
          '--all[all projects]' \
          '--parallel=[parallel jobs]:n:' && ret=0
        ;;
      (affected)
        _arguments \
          '*-t[targets]:target:' \
          '--base=[base ref]:ref:' \
          '--files=[files]:files:' \
          '*--exclude=[exclude]:projects:' \
          '--graph[show graph]' && ret=0
        ;;
      (generate)
        _arguments \
          '--dry-run[dry run]' \
          ':generator:' && ret=0
        ;;
      (graph)
        _arguments \
          '--file=[output file]:file:_files' \
          '--focus=[focus on project]:project:' \
          '--watch[watch for changes]' && ret=0
        ;;
      (list)
        _arguments '--json[JSON output]' && ret=0
        ;;
      (migrate)
        _arguments \
          '--run-migrations[run migrations]' \
          '--create-commits[create commits]' \
          ':version:' && ret=0
        ;;
      (init)
        _arguments \
          '--nxCloud=[connect to Nx Cloud]:value:(yes no)' \
          '--plugins=[plugins]:plugins:' && ret=0
        ;;
      (reset)
        _arguments \
          '--onlyCache[only clear cache]' \
          '--onlyDaemon[only reset daemon]' && ret=0
        ;;
      (show)
        _values 'show target' 'projects' 'project' 'target' && ret=0
        ;;
      (watch)
        _arguments \
          '--all[all projects]' \
          '--projects=[projects]:projects:' \
          '(-d --includeDependentProjects)'{-d,--includeDependentProjects}'[include dependent projects]' && ret=0
        ;;
    esac
    ;;
esac

return ret
