#compdef mirth
# =============================================================================
# mirth — mirth-lang/mirth's "Mirth" — a
#   STRONGLY-TYPED CONCATENATIVE programming
#   language inspired by Forth + Joy + Haskell +
#   Lisp + monoidal category theory.  Mirth's
#   key research contribution is bringing
#   STATIC TYPES + LINEAR / MULTI-STACK TYPE
#   INFERENCE to the concatenative paradigm
#   (where types had historically been
#   implicit + dynamically checked).  Compiles
#   to C99 + emits a self-contained
#   executable.  SELF-HOSTED via a four-stage
#   bootstrap chain (mirth0 → mirth1 →
#   mirth2 → mirth3) where mirth0 is a checked-
#   in C source generated by mirth3.  131st
#   language entry in the corpus.
#
# 131ST LANGUAGE ENTRY — Mirth closes the 3+1
# micro-cycle started after Axis 51 (DNS
# Server / Resolver Library) closed at 1/1/1
# three-language symmetry in R795 (TS-Node=106
# `_dohnut` on dns-packet ^5.2.1 + R794
# Go=106 `_dnsping` on miekg/dns v1.1.72 +
# R793 Rust=106 `_crab-hole` on hickory-dns
# 0.26.1).
#
# Distinguishing Mirth from the 130 prior
# corpus languages — closest neighbours and
# their differences:
#   - FORTH (the parent; many corpus entries:
#     `_gforth`, `_pforth`, `_8th`, etc.):
#     untyped, interactive, stack-based.
#     Mirth is statically typed AT THE
#     STACK LEVEL — each word has a
#     [input-types -> output-types]
#     signature that the compiler checks.
#     Stack-effect comments become
#     enforceable contracts
#   - JOY (Manfred von Thun): untyped
#     functional concatenative.  Mirth is
#     a typed evolution
#   - FACTOR (`_factor`): dynamically typed,
#     image-based, Smalltalk-influenced
#     concatenative with class system.
#     Mirth is statically typed, file-
#     based, monoidal-category influenced
#   - CAT (Christopher Diggins): typed
#     concatenative.  Mirth ships a self-
#     hosting compiler with a bootstrap
#     chain; Cat doesn't
#   - MLATU (R784, `_mlatu`):
#     concatenative + DECLARATIVE term-
#     rewriting + untyped.  Mirth is
#     concatenative + IMPERATIVE + statically
#     typed.  Different evaluation model
#   - COGNATE (cognate-lang/cognate):
#     "human-readable concatenative" with
#     keyword-comment syntax.  Mirth is
#     terse + symbolic
#   - HASKELL (`_runghc`, `_ghc`):
#     lazy applicative + parametric
#     polymorphism + ad-hoc polymorphism
#     via typeclasses.  Mirth is eager
#     concatenative + parametric
#     polymorphism + tags-based variant
#     dispatch.  The two share monoidal-
#     category-theory inspiration but
#     compose programs very differently
#     (Haskell composes via `.`, Mirth
#     composes via juxtaposition)
#
# KEY MIRTH LANGUAGE FEATURES:
#   - STATIC STACK-EFFECT TYPES — every word
#     declares [input -> output] stack
#     types.  The compiler type-checks
#     stack-shape preservation through
#     composition.  No "lost track of
#     stack" runtime errors:
#       def main [ +World |- ] {
#           "Hello, world!" print
#       }
#     The `[ +World |- ]` is the world-
#     effect annotation (analogous to
#     Haskell's `IO ()`)
#   - CATEGORICAL EFFECTS — `+World`,
#     `+Mirth`, etc. are first-class
#     "rune" effects that thread through
#     the type system.  Words that need
#     I/O declare the world rune; words
#     that need the compiler context
#     declare `+Mirth`.  Pure words have
#     no rune
#   - DESTRUCTURING WITH `dip` / `keep` /
#     `nip` / `over` / `swap` /
#     `dup` — Forth's traditional combinators
#     are first-class in Mirth's standard
#     library.  Typed
#   - MULTI-RETURN WORDS — words can return
#     2 or more stack items.  Type checker
#     enforces that consumers handle them
#     correctly
#   - PATTERN-MATCHING — `match { Case ->
#     body | ... }` destructures sum
#     types.  Exhaustiveness checked
#   - MODULES — `module foo.bar` declares
#     the namespace.  `import std.prelude`
#     for the standard library.  Two-
#     segment dotted paths
#   - PACKAGES — `--package NAME:PATH`
#     declares external packages.
#     `--package-search-path` searches for
#     them.  No central registry yet
#   - C99 CODEGEN — mirth compiles to
#     readable, portable C99 source +
#     leaves the final C compiler call to
#     the user.  No LLVM dep; just `cc`
#   - SELF-HOSTING BOOTSTRAP — the
#     repository ships `bin/mirth0.c` (a
#     checked-in C source generated by an
#     earlier mirth3).  The Makefile
#     builds mirth0 → uses mirth0 to
#     compile src/main.mth → mirth1.c →
#     mirth1 → mirth2.c → mirth2 → mirth3.c
#     → mirth3.  Stages 1, 2, 3 must all
#     produce IDENTICAL `.c` output —
#     that's the fixpoint test
#   - SUBLIME + VS CODE + VIM + ATOM
#     INTEGRATIONS — `tools/mirth-vim`,
#     `tools/mirth-code`, `tools/mirth-
#     sublime`, `tools/mirth-atom`.
#     Install via `make install-vim` /
#     `make install-code` / etc.
#     Sublime ships the most complete
#     "definition tracking" experience
#     so far
#
# SAMPLE PROGRAM:
#
#   # examples/hello.mth
#   module examples.hello
#   import std.prelude
#   import std.world
#
#   def main {
#       "Hello, world!" print
#   }
#
# COMPILE + RUN:
#
#   # Compile examples/hello.mth into hello.c
#   mirth -o hello.c examples/hello.mth
#
#   # Compile + link C output
#   cc hello.c -o hello
#
#   # Run
#   ./hello
#   # → Hello, world!
#
# FILE EXTENSION: `*.mth`
#
# CRITICAL BUILD DEPENDENCIES:
#   - C99 compiler (gcc / clang)
#                              — for the
#                                bootstrap +
#                                final
#                                codegen
#                                stages
#   - GNU make                 — orchestrates
#                                the build
#   - (optional) POSIX shell   — for the
#                                helper
#                                scripts
#                                under
#                                tools/
#
# Cross-platform: builds on Linux, macOS,
# BSD, and Windows (via MSYS2 / MinGW).
# No runtime deps — the emitted C is
# freestanding.
#
# UPSTREAM:
#   * Main repo          : https://git.sr.ht/~typeswitch/mirth
#   * GitHub mirror      : https://github.com/mirth-lang/mirth
#   * Issue tracker      : https://todo.sr.ht/~typeswitch/mirth
#   * Patreon            : https://patreon.com/typeswitch
#   * License            : 0BSD (BSD Zero Clause; public-domain equivalent)
#   * Maintainer         : typeswitch
#
# INSTALL:
#   # Build from source
#   git clone https://github.com/mirth-lang/mirth
#   cd mirth
#   make build
#   sudo install -m 0755 bin/mirth3 /usr/local/bin/mirth
#
#   # Or, after `make build`:
#   sudo make install            # not implemented as of 0BSD
#                                # release; copy bin/mirth3
#                                # manually
#
#   # Install editor support
#   make install-vim
#   make install-code
#   make install-sublime
#   make install-atom
#
# USAGE EXAMPLES:
#
#   # Compile mirth.mth to mirth.c (default
#   # input file: mirth.mth, default
#   # entry-point: main, no output by default
#   # unless --output-file is given)
#   mirth -o mirth.c mirth.mth
#
#   # Custom input file + output file
#   mirth -o build/hello.c examples/hello.mth
#
#   # Compile-only mode (skip codegen, just
#   # typecheck)
#   mirth -c examples/hello.mth
#   mirth --compile-only examples/hello.mth
#
#   # Custom entry-point word (default is
#   # "main")
#   mirth -e my-entry -o out.c src/main.mth
#   mirth --entry-point my-entry -o out.c src/main.mth
#
#   # Declare a package + give its path
#   mirth -p std:./std \
#         -o out.c src/main.mth
#
#   # Multiple packages
#   mirth -p std:./std \
#         -p mylib:./vendor/mylib \
#         -o out.c src/main.mth
#
#   # Add package search paths
#   mirth -P ./local-libs \
#         -P /usr/local/share/mirth/lib \
#         -o out.c src/main.mth
#
#   # Emit debugging information for the
#   # generated C output
#   mirth --debug -o out.c src/main.mth
#
#   # Compile + run in one step (shell
#   # one-liner)
#   mirth -o /tmp/hello.c examples/hello.mth \
#       && cc /tmp/hello.c -o /tmp/hello \
#       && /tmp/hello
#
# OPTIONS (sourced directly from
# https://github.com/mirth-lang/mirth/blob/main/src/options.mth):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(-o --output-file)'{-o+,--output-file=}'[output file path (e.g. out.c)]:OUTPUT_FILE:_files -g "*.(c|h)"' \
    '(-c --compile-only)'{-c,--compile-only}'[compile code without running the codegen step (typecheck-only)]' \
    '(-e --entry-point)'{-e+,--entry-point=}'[entry-point word for compilation (default main)]:ENTRY_POINT: ' \
    '*'{-p+,--package=}'[package locations in PACKAGE:PATH form (repeatable)]:PACKAGE:PATH: ' \
    '*'{-P+,--package-search-path=}'[package search path (repeatable)]:SEARCH_PATH:_files -/' \
    '--debug[emit debugging information during codegen]' \
    '*:Mirth source file (default mirth.mth):_files -g "*.mth"' \
    && ret=0

return ret
