#compdef distccd
# _distccd — distcc distributed C compilation daemon (Martin Pool / distcc team, C); custom argparse
# upstream: https://github.com/distcc/distcc

_distccd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--daemon[run as daemon]' \
        '--no-detach[do not detach]' \
        '--inetd[run from inetd]' \
        '--listen=+[listen address]:addr:' \
        '-a+[listen address]:addr:' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--allow=+[allow client cidr]:list:' \
        '--allow-private[allow private addresses]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--nice=+[nice level]:n:' \
        '-N+[nice level]:n:' \
        '--user=+[user]:str:_users' \
        '-u+[user]:str:_users' \
        '--lifetime=+[lifetime seconds]:n:' \
        '--pid-file=+[pid file]:file:_files' \
        '-P+[pid file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--log-stderr[log to stderr]' \
        '--log-level=+[log level]:level:(critical error warning notice info debug)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--zeroconf[advertise via mdns]' \
        '--make-me-a-botnet[allow code execution]' \
        '--enable-tcp-insecure[enable insecure tcp]' \
        '--job-lifetime=+[job lifetime]:n:' \
        '--stats[enable stats]' \
        '--stats-port=+[stats port]:port:' \
        '*:arg:'
}

_distccd "$@"
