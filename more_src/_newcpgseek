#compdef newcpgseek
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/newcpgseek.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS newcpgseek: find CpG island regions using Gardiner-Garden method
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-score=[minimum CpG score to report]:score:' \
  '-outfile=[report output file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
