#compdef xrpd rippled
# _xrpd — Ripple Labs rippled XRP Ledger reference daemon CLI for the XRP Ledger XRPL running a validator full-node or stand-alone testnet maintaining the ledger validating transactions consensus subscribe websocket grpc submit ledger_data path_find (XRPLF team, C++); custom argparse
# upstream: https://github.com/XRPLF/rippled

_xrpd() {
    local -a sub=(
        'account_currencies:list issued currencies'
        'account_info:show account info'
        'account_lines:list trust lines'
        'account_objects:list account objects'
        'account_offers:list account offers'
        'account_tx:list account transactions'
        'channel_authorize:authorize payment channel'
        'channel_verify:verify payment channel'
        'connect:connect to peer'
        'deposit_authorized:check deposit authorization'
        'fee:show fee info'
        'gateway_balances:show gateway balances'
        'get_counts:show counts'
        'ledger:show ledger'
        'ledger_accept:accept ledger'
        'ledger_closed:show closed ledger'
        'ledger_current:show current ledger'
        'ledger_request:request ledger'
        'log_level:set log level'
        'noripple_check:check no-ripple flag'
        'path_find:find path'
        'peer_reservations_add:add peer reservation'
        'ping:ping rippled'
        'random:get random'
        'ripple_path_find:find ripple path'
        'server_info:show server info'
        'server_state:show server state'
        'sign:sign transaction'
        'sign_for:sign for multisig'
        'stop:stop server'
        'submit:submit transaction'
        'submit_multisigned:submit multisigned'
        'subscribe:subscribe to events'
        'tx:show transaction'
        'tx_history:show transaction history'
        'unl_list:show UNL list'
        'validation_create:create validator'
        'validators:show validators'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--conf=+[file]:file:_files -g "*.cfg rippled.cfg"' \
        '--rpc=+[port]:n:' \
        '--rpc-ip=+[host]:str:' \
        '--rpc-port=+[port]:n:' \
        '--ws=+[host:port]:str:' \
        '--ws-ip=+[host]:str:' \
        '--ws-port=+[port]:n:' \
        '--ledgerfile=+[file]:file:_files' \
        '--standalone[standalone mode]' \
        '-a[standalone mode]' \
        '--testnet[use testnet]' \
        '--reportingReadOnly[reporting read-only]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '--quorum=+[N]:n:' \
        '--valid[require valid]' \
        '--start[start]' \
        '--net[network]:net:(testnet devnet)' \
        '--nodetoshard[shard nodes]' \
        '--ledger=+[N]:n:' \
        '--load[load]' \
        '--noripple[no ripple]' \
        '--replay[replay]' \
        '--fg[foreground]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xrpd subcommand' sub ;;
        args) ;;
    esac
}

_xrpd "$@"
