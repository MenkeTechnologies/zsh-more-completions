#compdef naive
# Documentation: https://github.com/nickel-org/nickel.rs (naiveproxy)
# NaiveProxy binary

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--listen=[listen address (socks://addr, http://addr, redir://addr)]:address:' \
  '--proxy=[upstream proxy URL (https://user:pass@host:port)]:url:' \
  '--padding[enable padding to obfuscate traffic length]' \
  '--host-resolver-rules=[host resolution rules]:rules:' \
  '--resolver-range=[request an IP range for resolver]:range:' \
  '--log=[log settings]:log spec:' \
  '--log-net-log=[NetLog file path]:file:_files' \
  '--ssl-key-log-file=[TLS key log file]:file:_files' \
  '--no-post-quantum[disable post-quantum key exchange]' \
  '--extra-headers=[extra headers to add to requests]:headers:' \
  '--host=[override Host header]:host:_hosts' \
  '--insecure-concurrency=[number of concurrent connections]:n:' \
  && return 0
