#compdef zoxide
# _zoxide-bin — zoxide smarter cd (Ajeet D'Souza, Rust); frecency-based directory jumper inspired by z/autojump
# upstream: https://github.com/ajeetdsouza/zoxide

_zoxide-bin() {
    local -a sub=(
        'add:add a dir to the database'
        'edit:edit the database'
        'import:import from z, autojump, fasd, or rupa/z'
        'init:print shell integration script'
        'query:query the database (like z)'
        'remove:remove a dir from the database'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zoxide subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:shell:(bash zsh fish posix powershell elvish nushell xonsh)' \
                    '--cmd+[cmd name]:cmd:' \
                    '--hook+[hook]:hook:(none prompt pwd)' \
                    '--no-aliases[skip alias creation]' \
                    '--no-cmd[skip cmd alias]' ;;
                query) _arguments \
                    '(-l --list)'{-l,--list}'[list matches]' \
                    '(-i --interactive)'{-i,--interactive}'[fzf interactive picker]' \
                    '(-s --score)'{-s,--score}'[print score]' \
                    '(-e --exclude)'{-e,--exclude}'+[exclude dir]:dir:_files -/' \
                    '*:query:' ;;
                add|remove) _arguments '*:dir:_files -/' ;;
                import) _arguments \
                    '--from+[source]:source:(autojump z fasd)' \
                    '--merge[merge with existing]' \
                    '1:file:_files' ;;
            esac
            ;;
    esac
}

_zoxide-bin "$@"
