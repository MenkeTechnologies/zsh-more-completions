#compdef nifcloud
# Documentation: https://nifcloud-cli.readthedocs.io/en/stable/reference/index.html
# Universal Command Line Interface for NIFCLOUD services

local ret=1

_arguments -s -S \
  '--debug[turn on debug logging]' \
  '--endpoint-url=[override the command default endpoint URL]:url' \
  '--no-verify-ssl[do not verify SSL certificates]' \
  '--no-paginate[disable automatic pagination]' \
  '--output=[the formatting style for command output]:format:(json text table)' \
  '--query=[a JMESPath query to use in filtering the response]:query' \
  '--profile=[use a specific profile from your credential file]:profile' \
  '--region=[the region to use]:region' \
  '--version[display the version of this tool]' \
  '--color=[turn on/off color output]:color:(on off auto)' \
  '--no-sign-request[do not sign requests]' \
  '--ca-bundle=[the CA certificate bundle to use]:file:_files' \
  '--cli-read-timeout=[maximum socket read time in seconds]:seconds' \
  '--cli-connect-timeout=[maximum socket connect time in seconds]:seconds' \
  '*:command:((computing\:"Computing service" configure\:"configure CLI options" devops\:"DevOps service" devops-runner\:"DevOps Runner service" dns\:"DNS service" ess\:"Email Sending Service" nas\:"NAS service" rdb\:"RDB service" service-activity\:"service activity" storage\:"Object Storage service"))' && ret=0

return ret
