#compdef gcovr

# Zsh completion for gcovr (code coverage reporting)

_gcovr() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-r --root)'{-r,--root}'[root directory]:root dir:_files -/' \
    '--config=[configuration file]:config file:_files -g "*.cfg"' \
    '--no-markers[turn off exclusion markers]' \
    '--fail-under-line=[fail if line coverage is below]:percentage:' \
    '--fail-under-branch=[fail if branch coverage is below]:percentage:' \
    '--fail-under-function=[fail if function coverage is below]:percentage:' \
    '--source-encoding=[source file encoding]:encoding:' \
    '(-f --filter)'{-f,--filter}'[keep only source files matching]:filter regex:' \
    '(-e --exclude)'{-e,--exclude}'[exclude source files matching]:exclude regex:' \
    '--gcov-filter=[keep only gcov files matching]:filter regex:' \
    '--gcov-exclude=[exclude gcov files matching]:exclude regex:' \
    '--exclude-directories=[exclude directories matching]:regex:' \
    '--exclude-unreachable-branches[exclude branches that are not reachable]' \
    '--exclude-function-lines[exclude function body lines from coverage]' \
    '--exclude-throw-branches[exclude throw and rethrow branches]' \
    '--exclude-noncode-lines[exclude compiler-generated non-code lines]' \
    '(-g --gcov-executable)'{-g,--gcov-executable}'[gcov executable]:executable:_command_names' \
    '--gcov-ignore-errors=[ignore gcov errors]:mode:(all warn.gc_open)' \
    '--gcov-ignore-parse-errors=[ignore gcov parse errors]:mode:' \
    '--object-directory=[search for gcov data files in directory]:directory:_files -/' \
    '(-k --keep)'{-k,--keep}'[keep gcov files after processing]' \
    '(-d --delete)'{-d,--delete}'[delete gcov files after processing]' \
    '(-j --threads)'{-j,--threads}'[number of threads]:threads:' \
    '-o+[output file]:output file:_files' \
    '--output=[output file]:output file:_files' \
    '--txt[output in text format]' \
    '--txt-metric=[metric for text report]:metric:(line branch)' \
    '--txt-summary=[print text summary]:mode:' \
    '--html[output in HTML format]' \
    '--html-details[HTML report with file details]' \
    '--html-details-syntax-highlighting[enable syntax highlighting in HTML details]' \
    '--html-nested[HTML report with nested directories]' \
    '--html-self-contained[self-contained HTML report]' \
    '--html-template-dir=[HTML template directory]:directory:_files -/' \
    '--html-theme=[HTML report theme]:theme:(green blue)' \
    '--html-title=[HTML report title]:title:' \
    '--html-medium-threshold=[medium threshold for HTML]:percentage:' \
    '--html-high-threshold=[high threshold for HTML]:percentage:' \
    '--html-medium-threshold-branch=[medium branch threshold]:percentage:' \
    '--html-high-threshold-branch=[high branch threshold]:percentage:' \
    '--html-medium-threshold-line=[medium line threshold]:percentage:' \
    '--html-high-threshold-line=[high line threshold]:percentage:' \
    '--html-tab-size=[tab size for HTML]:size:' \
    '--xml[output in Cobertura XML format]' \
    '--xml-pretty[pretty-print XML output]' \
    '--sonarqube[output in SonarQube XML format]' \
    '--json[output in JSON format]' \
    '--json-pretty[pretty-print JSON output]' \
    '--json-summary[output JSON summary]' \
    '--json-summary-pretty[pretty-print JSON summary]' \
    '--json-base=[base URI for JSON report]:URI:' \
    '--csv[output in CSV format]' \
    '--coveralls[output in Coveralls JSON format]' \
    '--coveralls-pretty[pretty-print Coveralls JSON]' \
    '--timestamp=[override timestamp]:timestamp:' \
    '(-b --branches)'{-b,--branches}'[include branch coverage]' \
    '(-s --print-summary)'{-s,--print-summary}'[print summary to stdout]' \
    '-p[use relative path names]' \
    '--sort-percentage=[sort by percentage]:direction:(asc desc)' \
    '--sort-uncovered=[sort by uncovered count]:direction:(asc desc)' \
    '--decisions[include decision coverage]' \
    '--calls[include call coverage]' \
    '--merge-mode-functions=[function merge mode]:mode:(strict lax)' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '--version[print version]' \
    '*:search paths:_files -/' \
    && ret=0

  return ret
}

_gcovr "$@"
