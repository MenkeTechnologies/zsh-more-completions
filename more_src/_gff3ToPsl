#compdef gff3ToPsl
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert a GFF3 file with Gap attributes to a PSL file

local ret=1

_arguments -s -S \
  '1:map file (locusName chromName chromSize):_files' \
  '2:input gff3:_files' \
  '3:output psl:_files' && ret=0

return ret
