#compdef qpdfview

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--unique[reuse running instance]' \
  '--quiet[suppress error dialogs]' \
  '--no-restore[do not restore previous tabs]' \
  '--choose-instance[choose instance from chooser]' \
  '*:pdf_file:_files -g "*.{pdf,ps,djvu,xps,oxps,fb2,epub,cbz,cbr,cbt,cba,cb7}"' && ret=0

return ret
