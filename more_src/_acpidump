#compdef acpidump
# Documentation: man acpidump(8)
# Source: acpica/acpica source/tools/acpidump/apmain.c (master) — dump ACPI tables (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[dump tables to binary files]' \
    '(-h -?)'{-h,-\\?}'[show help]' \
    '-o+[redirect output to file]:file:_files' \
    '-r+[dump tables from RSDP address]:address:_default' \
    '-s[print table summaries only]' \
    '(-v -vd)-v[show version]' \
    '(-v -vd)-vd[show build date/time]' \
    '-z[verbose mode]' \
    '-a+[get table via physical address]:address:_default' \
    '-c+[customized table dumping]:state:(on off)' \
    '-f+[get table via binary file]:file:_files' \
    '-n+[get table via name/signature]:sig:_default' \
    '-x[use RSDT instead of XSDT]' \
    && ret=0

return ret
