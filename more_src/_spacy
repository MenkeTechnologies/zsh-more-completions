#compdef spacy

# Zsh completion for spacy - spaCy NLP library CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:download a trained pipeline'
  'info:show installation and pipeline info'
  'validate:validate installed pipeline packages'
  'convert:convert files to spaCy format'
  'init:initialize configs, pipelines, and projects'
  'train:train a pipeline'
  'pretrain:pretrain token vectors'
  'evaluate:evaluate a trained pipeline'
  'assemble:assemble a pipeline from components'
  'package:package a trained pipeline as a Python package'
  'project:manage spaCy projects'
  'ray:distributed training with Ray'
  'huggingface-hub:Hugging Face Hub integration'
  'debug:debugging utilities'
  'find-function:find registered functions'
  'benchmark:benchmark utilities'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'spacy command' commands && ret=0
    ;;
  args)
    case $words[1] in
      download)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--direct[force direct download]' \
          '--sdist[download source package]' \
          '1:model name:' && ret=0
        ;;
      info)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--markdown[generate Markdown]' \
          '--silent[suppress output]' \
          '--no-url-check[skip URL check]' \
          '1::model name:' && ret=0
        ;;
      convert)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--file-type[input file type]:type:(conllu conll ner json)' \
          '--n-sents[sentences per document]:count:' \
          '--seg-sents[segment sentences]' \
          '--base[tokenizer model]:model:' \
          '--morphology[enable morphology]' \
          '--merge-subtokens[merge subtokens]' \
          '--converter[converter to use]:converter:(auto conllu conll ner json)' \
          '--lang[language]:lang:' \
          '1:input file:_files' \
          '2::output directory:_directories' && ret=0
        ;;
      train)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--output[output directory]:directory:_directories' \
          '--code[path to Python code]:file:_files -g "*.py"' \
          '--verbose[enable verbose logging]' \
          '--gpu-id[GPU device ID]:id:' \
          '1:config file:_files -g "*.cfg"' && ret=0
        ;;
      evaluate)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--output[output file]:file:_files' \
          '--code[path to Python code]:file:_files -g "*.py"' \
          '--gold-preproc[use gold preprocessing]' \
          '--gpu-id[GPU device ID]:id:' \
          '--displacy-path[path for displaCy output]:directory:_directories' \
          '--displacy-limit[number of texts for displaCy]:count:' \
          '1:model:_files' \
          '2:data path:_files' && ret=0
        ;;
      package)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--code[path to Python code]:file:_files -g "*.py"' \
          '--meta-path[path to meta.json]:file:_files -g "*.json"' \
          '--create-meta[create meta.json]' \
          '--name[package name]:name:' \
          '--version[package version]:version:' \
          '--build[build type]:type:(sdist wheel none)' \
          '--force[force overwrite]' \
          '1:input directory:_directories' \
          '2:output directory:_directories' && ret=0
        ;;
      init)
        local -a init_commands=(
          'config:generate a training config'
          'fill-config:fill a config with default values'
          'vectors:create word vectors'
          'labels:find labels for training data'
        )
        _describe -t init-commands 'init command' init_commands && ret=0
        ;;
      project)
        local -a project_commands=(
          'clone:clone a project template'
          'assets:fetch project assets'
          'run:run a project workflow or command'
          'push:push artifacts to remote storage'
          'pull:pull artifacts from remote storage'
          'document:auto-generate project docs'
        )
        _describe -t project-commands 'project command' project_commands && ret=0
        ;;
      debug)
        local -a debug_commands=(
          'config:debug a training config'
          'data:debug training and development data'
          'profile:profile a trained pipeline'
          'model:debug a model'
          'diff:show config differences'
        )
        _describe -t debug-commands 'debug command' debug_commands && ret=0
        ;;
      benchmark)
        local -a benchmark_commands=(
          'accuracy:benchmark model accuracy'
          'speed:benchmark model speed'
        )
        _describe -t benchmark-commands 'benchmark command' benchmark_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
