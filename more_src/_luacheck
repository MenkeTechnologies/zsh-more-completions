#compdef luacheck

# Zsh completion for luacheck - Lua linter

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--no-color[disable color output]' \
  '--codes[show error/warning codes]' \
  '--ranges[show column ranges]' \
  '--formatter=[output formatter]:formatter:(default plain JUnit TAP)' \
  '-q[suppress output for passing files]' \
  '--quiet[suppress output for passing files]' \
  '--no-config[do not look for config file]' \
  '--config=[path to config file]:file:_files' \
  '--default-config=[path to default config file]:file:_files' \
  '--filename=[use this filename for stdin]:name:' \
  '--exclude-files=[glob pattern for files to exclude]:pattern:' \
  '--include-files=[glob pattern for files to include]:pattern:' \
  '-g[enable checking of global variables]' \
  '--no-global[disable checking of global variables]' \
  '--no-unused[disable checking for unused variables]' \
  '--no-redefined[disable checking for redefined variables]' \
  '--no-unused-args[disable checking for unused arguments]' \
  '--no-unused-secondaries[disable checking for unused secondary values]' \
  '--no-self[disable checking for unused self argument]' \
  '--std=[set standard globals]:std:(lua51 lua52 lua53 luajit min max none)' \
  '--globals=[allow extra globals]:globals:' \
  '--read-globals=[allow extra read globals]:globals:' \
  '--new-globals=[set globals]:globals:' \
  '--new-read-globals=[set read globals]:globals:' \
  '--allow-defined[allow implicitly defined globals]' \
  '--allow-defined-top[allow globals defined at top level]' \
  '--module[enable module mode]' \
  '--max-line-length=[set max line length]:length:' \
  '--no-max-line-length[disable max line length check]' \
  '--max-code-line-length=[set max code line length]:length:' \
  '--max-string-line-length=[set max string line length]:length:' \
  '--max-comment-line-length=[set max comment line length]:length:' \
  '--max-cyclomatic-complexity=[set max complexity]:complexity:' \
  '--ignore=[ignore warnings matching pattern]:pattern:' \
  '--enable=[enable warnings matching pattern]:pattern:' \
  '--only=[enable only warnings matching pattern]:pattern:' \
  '-j[number of parallel jobs]:jobs:' \
  '--jobs=[number of parallel jobs]:jobs:' \
  '--cache=[enable caching]:path:_files' \
  '--no-cache[disable caching]' \
  '*:Lua file:_files -g "*.lua"'
