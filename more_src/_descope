#compdef descope

# descope/descopecli (cobra); Homebrew: Formula/d/descope.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '--debug[debug logs]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'descope command' compadd -- audit project user tenant access-key secret flow screen permission
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
