#compdef trasher
# Documentation: https://github.com/ClementNerma/Trasher
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Trasher: portable trash directory CLI (Rust)
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ls:list items in the trash'
  'rm:move items to the trash'
  'unrm:restore items from the trash'
  'drop:permanently delete items from the trash'
  'path-of:print the path of an item in the trash'
  'trash-path:print the trash directory for the current mountpoint'
  'empty:remove all items from the trash'
  'help:display usage information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --allow-invalid-utf8-item-names)'{-a,--allow-invalid-utf8-item-names}'[allow invalid UTF-8 filenames]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'trasher command' commands && ret=0
    ;;
  args)
    case $line[1] in
      ls)
        _arguments \
          '(-d --details)'{-d,--details}'[show size and contents]' \
          '*:filter:' && ret=0
        ;;
      rm)
        _arguments \
          '(-p --permanently)'{-p,--permanently}'[permanently delete instead of trashing]' \
          '*:file or directory:_files' && ret=0
        ;;
      unrm)
        _arguments \
          '--id=[item ID]:id' \
          '--to=[restore location]:path:_directories' \
          '*:name:' && ret=0
        ;;
      drop)
        _arguments \
          '--id=[item ID]:id' \
          '*:name:' && ret=0
        ;;
      path-of)
        _arguments \
          '*:name:' && ret=0
        ;;
      trash-path|empty|help)
        ;;
    esac
    ;;
esac

return ret
