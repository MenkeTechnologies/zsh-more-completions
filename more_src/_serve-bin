#compdef serve
# _serve-bin — Vercel serve static file server (Node.js); zero-config static + SPA file serving
# upstream: https://github.com/vercel/serve

_serve-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-l --listen)'{-l,--listen}'+[listen addr]:addr:' \
        '(-p --port)'{-p,--port}'+[port]:port:' \
        '(-s --single)'{-s,--single}'[SPA rewrite to index.html]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-c --config)'{-c,--config}'+[serve.json config]:file:_files' \
        '(-u --no-clipboard)'{-u,--no-clipboard}'[do not copy URL to clipboard]' \
        '(-n --no-compression)'{-n,--no-compression}'[disable gzip]' \
        '(-N --no-port-switching)'{-N,--no-port-switching}'[fail if port busy]' \
        '(-S --symlinks)'{-S,--symlinks}'[follow symlinks]' \
        '(-C --cors)'{-C,--cors}'[enable CORS]' \
        '--ssl-cert+[TLS cert]:file:_files' \
        '--ssl-key+[TLS key]:file:_files' \
        '--ssl-pass+[TLS passphrase]:file:_files' \
        '--no-etag[disable ETag]' \
        '--no-request-logging[disable request log]' \
        '*:dir:_files -/'
}

_serve-bin "$@"
