local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:test image:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:similarity metric:(CC MI PR MSQ)' \
    '3:iters:_default' \
    '4:transform spec (e.g. 0.25x3x11):_default' \
    '5:N:_default' \
    '6:testTransform.txt:_files -g "*.{txt,mat}"' \
    '7:debug flag (0/1):(0 1)' \
    '*:training images:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
