#compdef Resample
# Documentation: https://github.com/senbox-org/snap-engine/blob/master/snap-gpf/src/main/java/org/esa/snap/core/gpf/common/resample/ResamplingOp.java
# ESA SNAP gpt Resample operator - resample all bands to a common size/resolution

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show operator help]' \
  '-e[show detailed error messages with stack trace]' \
  '-t+[set target output file]:target:_files' \
  '-f+[set output file format]:format:(GeoTIFF GeoTIFF-BigTIFF HDF5 BEAM-DIMAP NetCDF4-CF)' \
  '-p+[read processing parameters from file]:param file:_files' \
  '-c+[set tile cache size in bytes]:size' \
  '-q+[set maximum parallelism]:threads' \
  '-x[clear internal tile cache after each tile row]' \
  '*-S-[define a source product location]:source=file:_files' \
  '*-D-[define a system property]:name=value' \
  '-PreferenceBandName=-[name of the reference band]:band' \
  '-PtargetWidth=-[target width for all bands]:width' \
  '-PtargetHeight=-[target height for all bands]:height' \
  '-PtargetResolution=-[target resolution for all bands]:resolution' \
  '-PupsamplingMethod=-[interpolation method for upsampling]:method:(Nearest Bilinear Bicubic)' \
  '-PdownsamplingMethod=-[aggregation method for downsampling]:method:(First Min Max Mean Median)' \
  '-PflagDownsamplingMethod=-[aggregation method for flag downsampling]:method:(First FlagAnd FlagOr FlagMedianAnd FlagMedianOr)' \
  '-PresamplingPreset=-[the resampling preset]:preset' \
  '-PbandResamplings=-[the band resamplings]:resamplings' \
  '-PresampleOnPyramidLevels=-[resample on pyramid levels for faster imaging]:bool:(true false)' \
  '*:source product:_files' && ret=0

return ret
