#compdef kong-cli2 kong2
# _kong-cli2 — Kong Inc kong-cli2 CLI command-line frontend wrapping the Kong Gateway open-source cloud-native API gateway and microservices abstraction layer Nginx-based written in Lua originally OpenResty-based providing scalable cloud-native API gateway start stop restart health migrations prepare reload roar deploy clearstop quit healthcheck migrations-bootstrap migrations-up migrations-finish migrations-status config dbless declarative-config plugin Lua server hybrid mode dataplane controlplane vitals workspaces RBAC dev-portal mTLS (Kong Inc team Marco Palladino Augusto Marietti, Lua); custom argparse
# upstream: https://konghq.com/

_kong-cli2() {
    local -a sub=(
        'start:start Kong'
        'stop:stop Kong'
        'restart:restart Kong'
        'reload:reload Kong'
        'health:check Kong health'
        'check:check config'
        'config:declarative config operations'
        'hybrid:hybrid mode operations'
        'migrations:migration operations'
        'prepare:prepare working directory'
        'quit:gracefully quit Kong'
        'roar:loud start'
        'vault:vault operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-vv[more verbose]' \
        '-c+[config file]:file:_files -g "kong.conf *.conf"' \
        '--conf=+[file]:file:_files -g "kong.conf *.conf"' \
        '-p+[prefix]:str:' \
        '--prefix=+[dir]:dir:_files -/' \
        '--nginx-conf=+[file]:file:_files -g "nginx.conf"' \
        '--vaults=+[list]:str:' \
        '--plugins=+[list]:str:' \
        '--db=+[d]:d:(off postgres cassandra)' \
        '--database=+[d]:d:(off postgres cassandra)' \
        '--db-update-propagation=+[d]:str:' \
        '--lua-version=+[v]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--force[force]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--db-timeout=+[sec]:n:' \
        '--lock-timeout=+[sec]:n:' \
        '--nginx-strict[strict nginx]' \
        '--no-daemon[no daemon]' \
        '--shm-size=+[size]:str:' \
        '--state=+[s]:s:(loaded coredns)' \
        '--socket-path=+[path]:_files' \
        '--wait=+[sec]:n:' \
        '--watch[watch config]' \
        '--with-app-version=+[v]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--include-defaults[include defaults]' \
        '--with-default-postgres[with default postgres]' \
        '-s+[serve port]:n:' \
        '--filename=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kong subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:op:(init db_import db_export parse)' '*:arg:' ;;
                migrations) _arguments '1:op:(bootstrap up finish list reset status migrate)' '*:arg:' ;;
                hybrid) _arguments '1:op:(gen_cert)' '*:arg:' ;;
                vault) _arguments '1:op:(get)' '*:reference:' ;;
            esac
            ;;
    esac
}

_kong-cli2 "$@"
