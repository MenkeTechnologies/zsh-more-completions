#compdef wazuh-db
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-db.html
# Wazuh database daemon

local ret=1

_arguments -s \
  '-V[version and license message]' \
  '-h[show help]' \
  '*-d[debug mode (repeat to increase verbosity)]' \
  '-t[test configuration]' \
  '-f[run in foreground]' && ret=0

return ret
