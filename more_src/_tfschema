#compdef tfschema
# Documentation: https://github.com/minamijoyo/tfschema
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'data:inspect data sources'
  'resource:inspect managed resources'
  'provider:inspect provider schema'
)

local -a subcommands=(
  'browse:open provider documentation in browser'
  'list:list available types'
  'show:display type definitions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-install-autocomplete[install bash/zsh autocompletion]' \
  '1:command:->command' \
  '2:subcommand:->subcommand' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tfschema command' commands && ret=0
    ;;
  (subcommand)
    _describe -t subcommands 'tfschema subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '-format=[output format]:format:(table json)' \
      '*:type name: _default' && ret=0
    ;;
esac

return ret
