#compdef tfschema

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'block:inspect block schemas'
  'data:inspect data sources'
  'resource:inspect managed resources'
  'provider:inspect provider schema'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tfschema command' commands && ret=0
    ;;
  (args)
    _arguments '*:type name or flags: _default' && ret=0
    ;;
esac

return ret
