#compdef euse

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --info)'{-i,--info}'[show description for USE flags]' \
  '(-I --info-installed)'{-I,--info-installed}'[show USE flags for installed packages]' \
  '(-a --active)'{-a,--active}'[show active USE flags]' \
  '(-E --enable)'{-E,--enable}'[enable USE flag(s)]' \
  '(-D --disable)'{-D,--disable}'[disable USE flag(s)]' \
  '(-P --prune)'{-P,--prune}'[remove USE flag(s) from make.conf]' \
  '(-p --package)'{-p,--package}'+[specify a package for per-package USE]:package:' \
  '(-g --global)'{-g,--global}'[affect global USE flags only]' \
  '*:USE flag:' && ret=0

return ret
