(( $+functions[_qnap_commands] )) ||
_qnap_commands() {
    local commands; commands=(
'login:Save credentials and verify connectivity' \
'info:Show system information (model, firmware, hostname, uptime)' \
'status:Show system resource usage (CPU, RAM, temperature)' \
'volumes:List storage volumes and disks' \
'shares:List shared folders' \
'files:File operations' \
'dump:Save raw API responses for debugging and compatibility reporting' \
'network:Show network adapter information' \
'config:Show current saved configuration' \
'schema:Print command schema for agent use' \
'completions:Generate shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'qnap commands' commands "$@"
}
