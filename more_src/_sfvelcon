#compdef sfvelcon
# Documentation: https://github.com/ahay/src/blob/master/user/fomels/Mvelcon.c
# Madagascar: post-stack velocity continuation by implicit finite differences

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'vel=[final velocity]:velocity' \
  'v0=[starting velocity]:velocity' \
  'nv=[number of steps]:count' \
  'adj=[adjoint flag]:flag:(y n)' \
  'add=[addition flag]:flag:(y n)' \
  'inv=[amplitude type]:type' \
  '*:RSF file:_files' && ret=0

return ret
