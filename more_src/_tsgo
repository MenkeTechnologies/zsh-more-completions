#compdef tsgo
# _tsgo — TypeScript compiler ported to Go (microsoft/typescript-go)
# upstream: https://github.com/microsoft/typescript-go
# Flags from internal/tsoptions/declscompiler.go + cmd/tsgo/main.go.

_tsgo() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--all[show all compiler options]' \
        '(- *)'{-v,--version}'[show version]' \
        '--lsp[run as language server]' \
        '--api[run as API server]' \
        '(-w --watch)'{-w,--watch}'[watch input files]' \
        '(-b --build --b)'{-b,--build}'[run in build mode]' \
        '--preserveWatchOutput[do not clear screen between watch reports]' \
        '--listFiles[print files part of the compilation]' \
        '--explainFiles[print files and why they are part of the compilation]' \
        '--listEmittedFiles[print emitted file paths]' \
        '--pretty=[stylize errors and messages]:val:(true false)' \
        '--traceResolution[enable verbose module resolution logging]' \
        '--diagnostics[show diagnostic information]' \
        '--extendedDiagnostics[show extended diagnostic information]' \
        '--generateCpuProfile=[generate CPU profile to file]:file:_files' \
        '--generateTrace=[generate trace events into directory]:dir:_files -/' \
        '--incremental[enable incremental compilation]' \
        '--declaration[generate .d.ts files]' \
        '--declarationMap[generate sourcemap for .d.ts files]' \
        '--emitDeclarationOnly[only emit .d.ts files]' \
        '--sourceMap[generate corresponding .map file]' \
        '--inlineSourceMap[embed source map in generated JavaScript]' \
        '--noCheck[skip type checking]' \
        '--deduplicatePackages[deduplicate package versions]' \
        '--noEmit[do not emit outputs]' \
        '--assumeChangesOnlyAffectDirectDependencies[skip rechecking transitive deps]' \
        '--locale=[locale for messages]:locale:' \
        '--quiet[suppress non-error output]' \
        '--singleThreaded[disable parallelism]' \
        '--pprofDir=[directory for pprof output]:dir:_files -/' \
        '--checkers=[number of checker workers]:n:' \
        '--init[create a tsconfig.json]' \
        '(-p --project)'{-p+,--project=}'[path to tsconfig.json or its directory]:project:_files' \
        '--showConfig[print the final config]' \
        '--listFilesOnly[print files included by the compile then exit]' \
        '--ignoreConfig[ignore tsconfig.json discovery]' \
        '--target=[ES target version]:target:(ES3 ES5 ES2015 ES2016 ES2017 ES2018 ES2019 ES2020 ES2021 ES2022 ES2023 ES2024 ESNext)' \
        '--module=[module code generation]:module:(none commonjs amd umd system es2015 es2020 es2022 esnext node16 node18 nodenext preserve)' \
        '*--lib=[available library APIs]:lib:' \
        '--allowJs[allow JavaScript files]' \
        '--checkJs[type-check JavaScript files]' \
        '*:file or option:_files'
}

_tsgo "$@"
