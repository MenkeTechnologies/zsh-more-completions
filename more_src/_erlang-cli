#compdef erl
# _erlang-cli — Erlang/OTP runtime CLI (Ericsson, Erlang); launch Erlang virtual machine
# upstream: https://github.com/erlang/otp

_erlang-cli() {
    _arguments \
        '-version[show version]' \
        '-help[show help]' \
        '-eval+[evaluate expression]:str:' \
        '-init_debug[init debug]' \
        '-noinput[no input]' \
        '-noshell[no shell]' \
        '-detached[detached node]' \
        '-emu_args[show emulator args]' \
        '-name+[long node name]:str:' \
        '-sname+[short node name]:str:' \
        '-hidden[hidden node]' \
        '-cookie+[cookie]:str:' \
        '-setcookie+[cookie]:str:' \
        '-setcookie\ +[cookie]:str:' \
        '-setcookie__+[cookie]:str:' \
        '-config+[config file]:file:_files -g "*.config"' \
        '-args_file+[args file]:file:_files' \
        '-boot+[boot script]:file:_files' \
        '-boot_var+[boot var]:KEY VAL:' \
        '-mode+[code load mode]:mode:(embedded interactive)' \
        '-make[make mode]' \
        '-man+[man page]:str:' \
        '-pa+[prepend code path]:dir:_files -/' \
        '-pz+[append code path]:dir:_files -/' \
        '-instr+[instrument]:opts:' \
        '-run+[run M F A]:module function args:' \
        '-s+[run M F A]:module function args:' \
        '-shutdown_time+[shutdown time]:ms:' \
        '-smp+[smp]:mode:(auto enable disable)' \
        '-async_threads+[async threads]:n:' \
        '-stop[stop after running]' \
        '-start_epmd+[start epmd]:bool:(true false)' \
        '-no_epmd[no epmd]' \
        '+A+[async threads]:n:' \
        '+B+[break handling]:val:(c d i)' \
        '+P+[max processes]:n:' \
        '+Q+[max ports]:n:' \
        '+R+[compat release]:n:' \
        '+S+[scheduler threads]:str:' \
        '+T+[trace level]:n:' \
        '+V[show emulator version]' \
        '+W+[warning mapping]:val:(w i e)' \
        '+a+[async stack size]:n:' \
        '+c[no time correction]' \
        '+e+[max ets tables]:n:' \
        '+l[disable late warnings]' \
        '+swt+[scheduler wake threshold]:val:(very_low low medium high very_high)' \
        '+sbt+[scheduler binding]:val:' \
        '+stbt+[soft scheduler binding]:val:' \
        '+zdbbl+[dist buffer busy limit kb]:n:' \
        '*:args:'
}

_erlang-cli "$@"
