#compdef pyftinspect
# Documentation: https://fonttools.readthedocs.io/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: pyftinspect is a GUI font-inspector; no CLI flags besides positional font files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:font file:_files -g "*.(ttf|otf|ttc|otc|woff|woff2)"' && ret=0

return ret
