#compdef nakama
# Documentation: https://man.archlinux.org/search?q=nakama
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'migrate:run database migrations'
  'check:check config and run server'
)

_arguments -C \
  '*--config=[config file]:file:_files -g "*.(yaml|yml)"' \
  '--name=[node name]:name:' \
  '--data_dir=[data directory]:dir:_files -/' \
  '--shutdown_grace_sec=[shutdown grace seconds]:n:' \
  '--logger.level=[log level]:level:(DEBUG INFO WARN ERROR)' \
  '--logger.format=[log format]:format:(JSON STACKDRIVER)' \
  '--logger.stdout[log to stdout]' \
  '--logger.file=[log file]:file:_files' \
  '--logger.rotation[rotate log file]' \
  '--logger.compress[compress rotated logs]' \
  '*--database.address=[database DSN]:dsn:' \
  '--socket.server_key=[server key]:key:' \
  '--socket.port=[socket port]:port:' \
  '--socket.address=[socket address]:addr:' \
  '--socket.protocol=[socket protocol]:proto:(tcp tcp4 tcp6)' \
  '--socket.idle_timeout_ms=[idle timeout ms]:ms:' \
  '--socket.write_wait_ms=[write wait ms]:ms:' \
  '--socket.pong_wait_ms=[pong wait ms]:ms:' \
  '--socket.ssl_certificate=[SSL cert file]:file:_files' \
  '--socket.ssl_private_key=[SSL key file]:file:_files' \
  '--session.encryption_key=[session encryption key]:key:' \
  '--session.token_expiry_sec=[token expiry seconds]:n:' \
  '--session.refresh_token_expiry_sec=[refresh token expiry seconds]:n:' \
  '--metrics.prometheus_port=[Prometheus port]:port:' \
  '--metrics.namespace=[metrics namespace]:ns:' \
  '--console.port=[console port]:port:' \
  '--console.username=[console username]:user:' \
  '--console.password=[console password]:pw:' \
  '--runtime.path=[runtime modules path]:dir:_files -/' \
  '--runtime.http_key=[runtime HTTP key]:key:' \
  '--runtime.js_entrypoint=[JS entrypoint]:file:_files' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'nakama subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (migrate)
        _arguments \
          '--limit=[migrate limit]:n:' \
          '1:action:(up down redo status)' && ret=0
        ;;
    esac
    ;;
esac

return ret
