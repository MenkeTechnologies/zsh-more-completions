#compdef cntr
# Documentation: https://github.com/Mic92/cntr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'attach:Enter container with mount overlay'
      'exec:Execute command in container'
    )
    _describe 'command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      attach)
        _arguments \
          '(-t --type)'{-t+,--type=}'[container types to try (csv)]:types:(process-id podman docker nspawn lxc lxd containerd command kubernetes)' \
          '--effective-user=[effective username for new files on host]:user' \
          '--apparmor=[AppArmor profile mode]:mode:(auto off)' \
          '(- *)'{-h,--help}'[show help]' \
          '(- *)'{-V,--version}'[show version]' \
          '1:container id or name' \
          '*:command:_command_names -e' && ret=0
        ;;
      exec)
        _arguments \
          '(-t --type)'{-t+,--type=}'[container types to try (csv)]:types:(process-id podman docker nspawn lxc lxd containerd command kubernetes)' \
          '--apparmor=[AppArmor profile mode]:mode:(auto off)' \
          '(- *)'{-h,--help}'[show help]' \
          '(- *)'{-V,--version}'[show version]' \
          '1:container id or name' \
          '*:command:_command_names -e' && ret=0
        ;;
    esac
    ;;
esac

return ret
