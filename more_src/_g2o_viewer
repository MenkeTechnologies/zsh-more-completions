#compdef g2o_viewer
# Documentation: https://github.com/RainerKuemmerle/g2o/blob/master/g2o/apps/g2o_viewer/g2o_viewer.cpp
# GUI viewer and optimizer for g2o graphs

local ret=1

_arguments -s -S \
  '-solverlib[specify a solver library to load]:lib:_files' \
  '-typeslib[specify a types library to load]:lib:_files' \
  '*:graph:_files -g "*.g2o"' && ret=0

return ret
