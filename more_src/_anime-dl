#compdef anime-dl anime_dl
# _anime-dl — download anime from CrunchyRoll / Funimation (Xonshiz/anime-dl)
# upstream: https://github.com/Xonshiz/anime-dl
# Flags from anime_dl/__main__.py (argparse).

_anime-dl() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-p --password)'{-p+,--password=}'[website password]:password:' \
        '(-u --username)'{-u+,--username=}'[website username]:user:' \
        '(-i --input)'{-i+,--input=}'[input URL to anime]:url:' \
        '(-r --resolution)'{-r+,--resolution=}'[video resolution (default 720p)]:resolution:(360p 480p 720p 1080p)' \
        '(-l --language)'{-l+,--language=}'[language (default Japanese)]:lang:(Japanese English)' \
        '(-rn --range)'{-rn+,--range=}'[episode range (default All)]:range:' \
        '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
        '--skip[skip video download (subtitles only)]' \
        '(-v --verbose)'{-v,--verbose}'[verbose debugging output]'
}

_anime-dl "$@"
