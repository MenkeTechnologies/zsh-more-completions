#compdef yle-dl yledl
# Documentation: https://man.archlinux.org/search?q=yle-dl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-i+[input file with URLs]:file:_files' \
  '-o+[output file]:file:_files' \
  '--pipe[output stream to stdout]' \
  '--destdir=[output directory]:dir:_files -/' \
  '--showurl[show stream URL only]' \
  '--showtitle[show stream title]' \
  '--showepisodepage[show episode page URL]' \
  '--showmetadata[print stream metadata]' \
  '--vfat[use VFAT-safe filenames]' \
  '--resume[resume partial download]' \
  '--ratelimit=[bandwidth limit kb/s]:rate:' \
  '--proxy=[proxy URL]:url:' \
  '--postprocess=[post-process command]:cmd:' \
  '--audiolang=[audio language]:lang:(fin swe smi)' \
  '--sublang=[subtitle language]:lang:(all fin swe smi none)' \
  '--hardsubs[hard-burned subs only]' \
  '--latestepisode[only latest episode of series]' \
  '--maxbitrate=[max bitrate]:rate:(best worst)' \
  '--resolution=[max resolution]:res:' \
  '--duration=[stop after seconds]:secs:' \
  '--backend=[backend]:backend:(yle-dl ffmpeg adobehdsphp wget youtubedl)' \
  '--debug[enable debug output]' \
  '--metadata-language=[metadata language]:lang:(fin swe smi)' \
  '--xattr[set extended file attrs]' \
  '*:URL:' && ret=0

return ret
