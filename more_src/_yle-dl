#compdef yle-dl yledl
# Documentation: https://github.com/aajanki/yle-dl
# Reference accessed: 2026-05-21
# Verified: upstream sources scripts/yle-dl + yledl/yledl.py argparse config.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[verbose/debug output]' \
  '--debug[enable debug output]' \
  '-q[quiet mode]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '-i+[input file with URLs]:file:_files' \
  '-o+[output filename]:file:_files' \
  '--pipe[stream to stdout]' \
  '--destdir=[output directory]:dir:_files -/' \
  '--create-dirs[create output directories]' \
  '--no-create-dirs[do not create output directories]' \
  '--showurl[print stream URL only]' \
  '--showtitle[print stream title only]' \
  '--showepisodepage[print episode page URL]' \
  '--showmetadata[print stream metadata as JSON]' \
  '--subtitles-only[retrieve only subtitle files]' \
  '--restrict-filename-no-spaces[filenames without spaces]' \
  '--restrict-filename-no-specials[Windows-safe filenames]' \
  '--vfat[alias for --restrict-filename-no-specials]' \
  '--resume[resume partial download]' \
  '--no-resume[do not resume]' \
  '--no-overwrite[do not overwrite existing files]' \
  '--ratelimit=[bandwidth limit (kB/s)]:rate:' \
  '--proxy=[proxy URI]:uri:' \
  '--postprocess=[post-process command]:cmd:' \
  '--sublang=[subtitle language]:lang:(none fin swe all)' \
  '--metadatalang=[metadata language]:lang:(fin swe smi)' \
  '--latestepisode[only latest episode of series]' \
  '--maxbitrate=[max bitrate (kB/s)]:rate:' \
  '--resolution=[max vertical resolution]:res:' \
  '--startposition=[start position (seconds)]:secs:' \
  '--duration=[stop after seconds]:secs:' \
  '--preferformat=[preferred container format]:fmt:' \
  '--subdelay=[subtitle delay (seconds)]:s:' \
  '--output-template=[output filename template]:template:' \
  '--output-na-placeholder=[placeholder for N/A]:placeholder:' \
  '--backend=[downloader backends (comma-separated)]:backends:(ffmpeg wget)' \
  '--ffmpeg=[ffmpeg path]:path:_files' \
  '--ffprobe=[ffprobe path]:path:_files' \
  '--wget=[wget path]:path:_files' \
  '--xattrs[set extended file attributes]' \
  '*:URL:' && ret=0

return ret
