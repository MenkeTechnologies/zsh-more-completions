#compdef bal ballerina

# Zsh completion for bal/ballerina - Ballerina programming language

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'build:compile a Ballerina program'
      'run:run a Ballerina program'
      'test:run tests for a Ballerina package'
      'doc:generate API documentation'
      'clean:clean build artifacts'
      'format:format Ballerina source files'
      'grpc:generate Ballerina sources for gRPC'
      'graphql:generate Ballerina sources for GraphQL'
      'openapi:generate Ballerina sources for OpenAPI'
      'asyncapi:generate Ballerina sources for AsyncAPI'
      'persist:manage data persistence'
      'add:add a new module to a package'
      'pull:pull a package from Ballerina Central'
      'push:push a package to Ballerina Central'
      'pack:create a distributable package archive'
      'new:create a new Ballerina package'
      'init:initialize a Ballerina package in current directory'
      'search:search Ballerina Central for packages'
      'semver:validate semantic versioning'
      'shell:start the Ballerina shell'
      'dist:manage Ballerina distributions'
      'version:show version information'
      'help:show help for a command'
      'tool:manage Ballerina tools'
      'profile:profile a Ballerina program'
      'bindgen:generate Ballerina bindings for Java classes'
      'start:start a Ballerina service'
    )
    _describe -t subcommands 'ballerina subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-o,--output}'[output file name]:file:_files' \
          '--offline[build offline without resolving dependencies]' \
          '--sticky[stick to dependency versions in lock file]' \
          '--dump-bir[dump BIR]' \
          '--dump-bir-file[dump BIR to a file]' \
          '--dump-graph[dump dependency graph]' \
          '--dump-raw-graphs[dump raw dependency graphs]' \
          '--observability-included[include observability]' \
          '--cloud=[enable cloud artifact generation]:target:(k8s docker choreo)' \
          '--export-openapi[export OpenAPI specification]' \
          '--export-component-model[export component model]' \
          '--graalvm[build a GraalVM native image]' \
          '--graalvm-build-options=[GraalVM native-image build options]:options' \
          '--show-dependency-diagnostics[show dependency diagnostics]' \
          '--enable-cache[enable build cache]' \
          '--disable-syntax-tree-caching[disable syntax tree caching]' \
          '*:Ballerina file or directory:_files' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--observability-included[include observability]' \
          '--offline[run offline without resolving dependencies]' \
          '--debug=[enable remote debugging on port]:port' \
          '--experimental[enable experimental features]' \
          '*:Ballerina file or directory:_files' && ret=0
        ;;
      test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--code-coverage[enable code coverage]' \
          '--coverage-format=[coverage report format]:format:(xml html)' \
          '--list-groups[list available test groups]' \
          '--groups=[run tests in specified groups]:groups' \
          '--disable-groups=[disable specified test groups]:groups' \
          '--tests=[run specified tests]:test names' \
          '--rerun-failed[rerun only failed tests]' \
          '--test-report[generate test report]' \
          '--parallel[run tests in parallel]' \
          '--offline[run offline without resolving dependencies]' \
          '*:Ballerina file or directory:_files' && ret=0
        ;;
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          {-t,--template}'[project template]:template:(lib service main tool)' \
          '1:package name' && ret=0
        ;;
      doc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:Ballerina file or directory:_files' && ret=0
        ;;
      dist)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:dist subcommand:(list pull update remove use)' \
          '*:distribution' && ret=0
        ;;
      pull|push|pack|add|search|format|grpc|graphql|openapi|asyncapi|persist|semver|tool|profile|bindgen)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:argument:_files' && ret=0
        ;;
      help)
        _arguments -s -S \
          '1:command:(build run test doc clean format grpc graphql openapi asyncapi persist add pull push pack new init search semver shell dist version tool profile bindgen start)' && ret=0
        ;;
      clean|init|shell|start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
