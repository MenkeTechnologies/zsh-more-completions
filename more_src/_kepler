#compdef kepler
# _kepler — Kepler power-consumption monitoring exporter for Prometheus
# upstream: https://github.com/sustainable-computing-io/kepler
# Flags from config/config.go RegisterFlags() (kingpin) on tip.

_kepler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config.file=[YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(text json)' \
        '--host.sysfs=[host sysfs path]:dir:_files -/' \
        '--host.procfs=[host procfs path]:dir:_files -/' \
        '--monitor.interval=[monitor sampling interval]:dur:' \
        '--monitor.max-terminated=[max terminated processes retained]:n:' \
        '--debug.pprof=[enable pprof debug endpoints]:bool:(true false)' \
        '--web.config-file=[web config file path]:file:_files' \
        '*--web.listen-address=[web server listen address(es)]:host\:port:' \
        '--exporter.stdout=[enable stdout exporter]:bool:(true false)' \
        '--exporter.prometheus=[enable Prometheus exporter]:bool:(true false)' \
        '--metrics=[metrics levels to export]:levels:(node process container vm pod)' \
        '--kube.enable=[enable Kubernetes monitoring]:bool:(true false)' \
        '--kube.config=[kubeconfig file (out-of-cluster)]:file:_files' \
        '--kube.node-name=[node name kepler runs on]:name:' \
        '--experimental.platform.redfish.enabled=[enable Redfish BMC power monitoring]:bool:(true false)' \
        '--experimental.platform.redfish.node-name=[Redfish node name]:name:' \
        '--experimental.platform.redfish.config-file=[Redfish config file]:file:_files' \
        '--experimental.hwmon.force-enabled=[force hwmon power meter]:bool:(true false)' \
        '*--experimental.hwmon.zones=[hwmon zone filter (power labels)]:label:' \
        '--experimental.gpu.enabled=[enable GPU power monitoring]:bool:(true false)' \
        '--experimental.gpu.idle-power=[GPU idle power (W)]:w:' \
        '--experimental.gpu.dcgm-endpoint=[dcgm-exporter metrics endpoint URL]:url:_urls' \
        '--version[show version]'
}

_kepler "$@"
