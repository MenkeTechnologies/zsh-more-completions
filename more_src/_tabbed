#compdef tabbed
# Documentation: https://git.suckless.org/tabbed/file/tabbed.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tabbed - simple generic tabbed frontend to xembed-aware applications

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[close tabbed when last tab is closed (excl. -f)]' \
  '-d[detach from terminal and print XID to stdout]' \
  '-f[fill up tabbed by spawning command when last tab closed]' \
  '-g+[window geometry]:geometry:' \
  '-k[close foreground tabbed client on WM_DELETE_WINDOW]' \
  '-n+[WM_CLASS name]:name:' \
  '-p+[position for new tabs]:position:' \
  '-r+[index of command argument to replace with window id]:narg:' \
  '-s[disable automatic spawning of command]' \
  '-o+[normal background color]:color:' \
  '-O+[normal foreground color]:color:' \
  '-t+[selected background color]:color:' \
  '-T+[selected foreground color]:color:' \
  '-u+[urgent background color]:color:' \
  '-U+[urgent foreground color]:color:' \
  '-v[print version information]' \
  '*:command:_command_names -e' && ret=0

return ret
