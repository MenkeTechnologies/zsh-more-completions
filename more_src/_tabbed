#compdef tabbed

# Zsh completion for tabbed - simple generic tabbed frontend to xembed-aware applications

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[close when last tab is closed]' \
  '-d[detach and print XID to stdout]' \
  '-f[fill empty space with color]' \
  '-h[show help]' \
  '-k[kill window]' \
  '-n[set window name]:name' \
  '-o[close when last tab is closed]' \
  '-p[set position]:position:(s e)' \
  '-r[number of tabs to replace]:number' \
  '-s[disable automatic first tab]' \
  '-t[set tab bar color]:color' \
  '-T[set tab bar selected color]:color' \
  '-u[set unfocused color]:color' \
  '-U[set urgent color]:color' \
  '-v[print version]' \
  '*:command:_command_names -e' && ret=0

return ret
