#compdef net-cli
# _net-cli — Samba net administration tool for Samba/Windows networks CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_net-cli() {
    local -a sub=(
        'help:show help'
        'time:show time on remote'
        'lookup:lookup remote info'
        'user:user account commands'
        'group:group commands'
        'groupmap:windows-to-unix group mapping'
        'share:share commands'
        'file:file commands'
        'session:session commands'
        'sam:SAM database commands'
        'ads:Active Directory commands'
        'rap:RAP-based commands'
        'rpc:RPC-based commands'
        'cache:cache commands'
        'getlocalsid:get local SID'
        'setlocalsid:set local SID'
        'setdomainsid:set domain SID'
        'getdomainsid:get domain SID'
        'maxrid:get max RID'
        'idmap:idmap commands'
        'usershare:usershare commands'
        'usersidlist:list user SIDs'
        'changesecretpw:change secret password'
        'changetrustpw:change trust password'
        'tdbbackup:backup tdb files'
        'eventlog:eventlog commands'
        'printing:printing commands'
        'serverid:server ID commands'
        'notify:notify commands'
        'tdb:tdb commands'
        'vfs:vfs commands'
        'witness:witness commands'
        'g_lock:global lock commands'
        'msg:message commands'
        'fsmo:FSMO commands'
        'samba-tool:redirect to samba-tool'
        'addshare:add share'
        'delshare:delete share'
        'status:show status'
        'lookup:lookup'
        'join:join domain'
        'unjoin:unjoin domain'
        'testjoin:test domain join'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-w+[target workgroup]:str:' \
        '--target-workgroup=+[target workgroup]:str:' \
        '-W+[workgroup]:str:' \
        '--workgroup=+[workgroup]:str:' \
        '-U+[user]:_users' \
        '--user=+[user]:_users' \
        '-I+[ip address]:str:' \
        '--ipaddress=+[ip address]:str:' \
        '-p+[port]:port:' \
        '--port=+[port]:port:' \
        '-n+[my workgroup]:str:' \
        '--myname=+[my workgroup]:str:' \
        '-S+[server]:host:_hosts' \
        '--server=+[server]:host:_hosts' \
        '-l[long display]' \
        '--long[long display]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-f[force]' \
        '--force[force]' \
        '-c+[container]:str:' \
        '--container=+[container]:str:' \
        '-N[no password]' \
        '--no-pass[no password]' \
        '-k[use kerberos]' \
        '--use-kerberos[use kerberos]' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[debug level]:n:' \
        '--debug-stdout[debug to stdout]' \
        '-s+[config file]:file:_files -g "smb.conf"' \
        '--configfile=+[config file]:file:_files -g "smb.conf"' \
        '--option=+[name=value]:str:' \
        '-r+[realm]:str:' \
        '--realm=+[realm]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'net subcommand' sub ;;
    esac
}

_net-cli "$@"
