#compdef gitopscli
# Documentation: https://github.com/baloise/gitopscli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:create deploy request'
  'add-pr-comment:add PR comment'
  'create-pr:create PR'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-v[verbose logging]' \
  '--username=[Git username]:user:' \
  '--password=[token or password]:secret:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gitopscli command' commands && ret=0
    ;;
  (args)
    _arguments '*:key=value or args: _default' && ret=0
    ;;
esac

return ret
