#compdef maas-test-db
# Documentation: https://man.archlinux.org/search?q=maas-test-db
# Reference accessed: 2026-05-16

# maas-test-db: scratch PostgreSQL DB for MAAS development/testing
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'shell:open psql shell against the test DB'
  'run:run a command against the test DB'
  'destroy:tear down the test DB'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'maas-test-db command' commands && ret=0 ;;
esac
return ret
