#compdef drone-runner-aws
# _drone-runner-aws — Drone CI AWS-VM pipeline runner (drone-runners/drone-runner-aws)
# upstream: https://github.com/drone-runners/drone-runner-aws
# Subcommands from command/command.go (kingpin) on tip.

_drone-runner-aws() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the runner daemon (reads .env / envfile)'
                exec:'execute a pipeline locally'
                compile:'compile a pipeline YAML and print the intermediate'
                delegate:'run the Harness delegate runner mode'
                dlite:'run the Harness dlite runner mode'
                setup:'bootstrap a runner host (install dependencies)'
            )
            _describe -t commands 'drone-runner-aws command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments \
                        '--pool=[pool config YAML file]:file:_files' \
                        ':envfile:_files'
                    ;;
                exec)
                    _arguments \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--include=[include pipeline step]:step:' \
                        '*--exclude=[exclude pipeline step]:step:' \
                        '*--environ=[set environment variable]:var:' \
                        '--pool=[pool config YAML file]:file:_files' \
                        '--debug[enable debug logging]' \
                        '--trace[enable trace logging]' \
                        '--dump[dump pipeline state to stdout]' \
                        ':source-file:_files'
                    ;;
                compile)
                    _arguments \
                        '--source=[source file location]:file:_files' \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--environ=[set environment variable]:var:'
                    ;;
                delegate|dlite)
                    _arguments \
                        '--pool=[pool config YAML file]:file:_files' \
                        ':envfile:_files'
                    ;;
                setup)
                    _arguments ':envfile:_files'
                    ;;
            esac
            ;;
    esac
}

_drone-runner-aws "$@"
