#compdef systemd-keyutil
# Documentation: source-direct extraction from upstream
# systemd/systemd src/keyutil/keyutil.c —
#   verb dispatch table at lines 163-323 (VERB_NOARG +
#     VERB declarations for validate / extract-public + alias
#     public / extract-certificate / pkcs7)
#   parse_argv() at lines 88-161 (the OptionParser FOREACH_
#     OPTION_OR_RETURN dispatch + OPTION_COMMON_* + OPTION_LONG
#     entries)
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-keyutil is the **PKCS#7 / X.509 / TPM key utility**
# — newer addition (systemd v257+) that bundles common
# OpenSSL-driven crypto operations for systemd's growing
# signature-verification needs (used by sysupdate.d/*.transfer
# verify-paths, by systemd-cryptenroll TPM bindings, by the
# systemd-boot kernel-image signature checks).
#
# Critical extraction note: keyutil documents the
# `OPTION_COMMON_PRIVATE_KEY` / `OPTION_COMMON_PRIVATE_KEY_
# SOURCE` / `OPTION_COMMON_CERTIFICATE` / `OPTION_COMMON_
# CERTIFICATE_SOURCE` macros — systemd's standard OpenSSL key/
# cert-source option set.  These add 4 flags consistently
# across keyutil, cryptenroll, ukify, and other crypto-aware
# systemd tools:
#   --private-key=PATH           (PEM or PKCS11 URL)
#   --private-key-source=SOURCE  (auto|file|provider:NAME|engine:NAME)
#   --certificate=PATH           (PEM)
#   --certificate-source=SOURCE  (auto|file|provider:NAME)

local curcontext="$curcontext" state line ret=1

# Verbs decoded source-direct from keyutil.c lines 163-323.
# `extract-public` has a backward-compat alias `public` at
# line 222.
local -a subcommands=(
  'validate:load and validate the given certificate and private key (no positional)'
  'extract-public:extract the public key from a private key or certificate (no positional)'
  'public:DEPRECATED alias for extract-public (kept for backward compatibility)'
  'extract-certificate:extract a certificate from a signature or other source (no positional)'
  'pkcs7:build a PKCS#7 signature from a PKCS#1 signature + certificate + content'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  '--private-key=[private key in PEM format OR PKCS#11 URL]:path:_files' \
  '--private-key-source=[private key source]:source:(auto file provider engine)' \
  '--certificate=[PEM certificate to use for signing]:path:_files -g "*.(pem|crt)"' \
  '--certificate-source=[certificate source]:source:(auto file provider)' \
  '--signature=[PKCS#1 signature to embed in PKCS#7 signature (pkcs7 verb)]:path:_files' \
  '--content=[raw data content to embed in PKCS#7 signature (pkcs7 verb)]:path:_files' \
  '--hash-algorithm=[hash algorithm used to create the PKCS#1 signature]:algo:(sha1 sha256 sha384 sha512)' \
  '--output=[where to write the PKCS#7 signature]:path:_files' \
  '1:verb:->subcmd' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'systemd-keyutil verb' subcommands && ret=0
    ;;
esac

return ret
