#compdef aerospace

# Zsh completion for aerospace - i3-like tiling window manager for macOS

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'balance-sizes:balance the sizes of all windows in the current workspace'
  'close:close the focused window'
  'close-all-windows-but-current:close all windows in the current workspace but the currently focused one'
  'config:query AeroSpace config'
  'debug-windows:debug windows'
  'enable:temporarily disable window management'
  'flatten-workspace-tree:flatten the tree of the focused workspace'
  'focus:set focus to the nearest window in the given direction'
  'focus-back-and-forth:toggle focus between the current and previously focused window'
  'focus-monitor:focus a monitor'
  'fullscreen:toggle the fullscreen mode for the focused window'
  'join-with:join the focused window with the window in the given direction'
  'layout:change layout of the focused container'
  'list-apps:print the list of running applications'
  'list-exec-env-vars:list environment variables that exec-* commands will use'
  'list-monitors:print monitors'
  'list-windows:print windows that match conditions'
  'list-workspaces:print workspaces that match conditions'
  'macos-native-fullscreen:toggle macOS fullscreen for the focused window'
  'macos-native-minimize:minimize the focused window'
  'mode:activate the specified binding mode'
  'move:move the focused window in the given direction'
  'move-mouse:move mouse to the requested position'
  'move-node-to-monitor:move the focused window to the specified monitor'
  'move-node-to-workspace:move the focused window to the specified workspace'
  'move-workspace-to-monitor:move the focused workspace to the next or previous monitor'
  'reload-config:reload currently active config'
  'resize:resize the focused window'
  'split:split the focused window'
  'summon-workspace:summon the specified workspace on the focused monitor'
  'trigger-binding:trigger AeroSpace binding'
  'workspace:focus the specified workspace'
  'workspace-back-and-forth:toggle focus between the current and previously focused workspace'
  'server:start AeroSpace server'
  'version:print AeroSpace version'
  'help:print help'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[print help]' \
  '--version[print version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'aerospace command' commands && ret=0
    ;;
esac

return ret
