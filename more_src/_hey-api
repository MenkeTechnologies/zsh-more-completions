#compdef hey-api
# _hey-api — OpenAPI client code generator for TypeScript
# upstream: https://github.com/hey-api/openapi-ts

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --input)'{-i+,--input=}'[path or URL to OpenAPI spec]:input:_files' \
  '(-o --output)'{-o+,--output=}'[output directory for generated code]:directory:_directories' \
  '(-c --client)'{-c+,--client=}'[HTTP client to generate]:client:(@hey-api/client-fetch @hey-api/client-axios legacy/fetch legacy/axios legacy/node legacy/angular)' \
  '--plugins=[plugins to use]:plugins' \
  '--experimentalParser[use experimental parser]' \
  '--dry-run[print output without writing files]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--base=[base URL override]:url' \
  '--name=[exported client name]:name' \
  '-f[path to hey-api config file]:file:_files' \
  '--configFile=[path to hey-api config file]:file:_files' && ret=0

return ret
