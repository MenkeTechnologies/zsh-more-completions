#compdef antlr4 antlr3 antlr4-parse grun

local curcontext="$curcontext" state line ret=1

case $service in
  (antlr4|antlr3)
    _arguments -C \
      '(- *)-help[show help]' \
      '(- *)'{-X,-version}'[show version]' \
      '-o+[output dir]:dir:_files -/' \
      '-lib+[lib dir]:dir:_files -/' \
      '-atn[generate ATN diagrams]' \
      '-encoding+[grammar encoding]:enc:(UTF-8 ASCII ISO-8859-1)' \
      '-message-format+[message format]:fmt:(antlr gnu vs2005 antlr3 default)' \
      '-long-messages[long messages]' \
      '-listener[generate parse tree listener]' \
      '-no-listener[do not generate listener]' \
      '-visitor[generate parse tree visitor]' \
      '-no-visitor[do not generate visitor]' \
      '-package+[output package]:pkg:' \
      '-depend[generate file dependencies]' \
      '-D+[define option]:opt:' \
      '-Werror[treat warnings as errors]' \
      '-XdbgST[print template tree on console]' \
      '-XdbgSTWait[show debug ST wait]' \
      '-Xforce-atn[force ATN simulation]' \
      '-Xlog[log details]' \
      '-Xexact-output-dir[exact output dir]' \
      '-Dlanguage=[target language]:lang:(Java JavaScript TypeScript Python3 Python CSharp Cpp Go Swift PHP Dart)' \
      '*: :_files -g "*.g4 *.g"' && ret=0 ;;
  (antlr4-parse|grun)
    _arguments -C \
      '-tokens[print tokens]' \
      '-tree[print parse tree]' \
      '-gui[show parse tree GUI]' \
      '-ps+[postscript output]:file:_files' \
      '-encoding+[input encoding]:enc:' \
      '-trace[print debug trace]' \
      '-diagnostics[print diagnostics]' \
      '-SLL[use SLL prediction]' \
      '*: :' && ret=0 ;;
esac

return ret
