#compdef agedu
# Documentation: https://www.chiark.greenend.org.uk/~sgtatham/agedu/manpage.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# agedu — see `agedu --help`

local curcontext="$curcontext" state line ret=1

local -a common=(
  '(-f)'{-f+,--file=}'[index filename]:file:_files'
  '--cross-fs[scan across filesystems]'
  '--no-cross-fs[stay on one filesystem]'
  '--prune=[prune matching files]:glob:'
  '--prune-path=[prune matching paths]:glob:'
  '--exclude=[exclude files]:glob:'
  '--exclude-path=[exclude paths]:glob:'
  '--include=[include files]:glob:'
  '--include-path=[include paths]:glob:'
  '--progress[report scan progress on stderr]'
  '--no-progress[disable scan progress]'
  '--tty-progress[progress if stderr is tty]'
  '--dir-atime[keep real directory atimes]'
  '--no-dir-atime[fake directory atimes]'
  '--mtime[use mtime instead of atime]'
  '--logicalsize[use logical file size]'
  '--launch=[shell command with base URL]:cmd:'
  '--no-eof[web server stays up after stdin EOF]'
  '(-r)'{-r+,--age-range=}'[colour range age-age]:range:'
  '(-o)'{-o+,--output=}'[html output file/dir]:path:_files'
  '--numeric[numeric HTML filenames]'
  '--address=[bind addr:port]:addr:'
  '--auth=[HTTP auth method]:method:'
  '--auth-file=[HTTP basic user/pass file]:file:_files'
  '--auth-fd=[fd with HTTP basic credentials]:fd:'
  '--title=[HTML title prefix]:title:'
  '(-d)'{-d+,--depth=}'[directory depth for text/html]:levels:'
  '(-a)'{-a+,--age=}'[text mode age filter]:age:'
  '--files[list individual files in reports]'
  '--help[show help]'
  '--version[show version]'
  '--licence[show licence]'
)

_arguments -s -S \
  $common \
  '1: :->action' \
  '*:: :->rest' && ret=0

case $state in
  (action)
    local -a act=(
      '-s:scan directory into index'
      '--scan:scan directory into index'
      '-w:serve HTML UI from index'
      '--web:serve HTML UI from index'
      '-t:text report for subdirectory'
      '--text:text report for subdirectory'
      '-R:remove index file'
      '--remove:remove index file'
      '-D:dump index to stdout'
      '--dump:dump index to stdout'
      '-L:load index from dump stream'
      '--load:load index from dump stream'
      '--presort:prepare dump for sorting'
      '--postsort:undo presort'
      '-S:scan directory producing dump only'
      '--scan-dump:scan directory producing dump only'
      '-H:HTML fragment for subdirectory'
      '--html:HTML fragment for subdirectory'
      '--cgi:CGI mode'
    )
    _describe -t actions 'agedu action' act && ret=0
    ;;
  (rest)
    _arguments -s -S $common '*:path:_files -/' && ret=0
    ;;
esac

return ret
