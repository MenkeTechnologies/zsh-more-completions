#compdef ossec-logtest

# ossec-logtest: test rules/decoders against sample log lines
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[debug level]:level:(1 2)' \
  '-D[chroot directory]:dir:_files -/' \
  '-U[user]:user:_users' \
  '-a[alert format (json|plain)]:format:(json plain)' \
  '-v[verbose - print decoded fields]' \
  '*::ossec-logtest args:_files' && ret=0
return ret
