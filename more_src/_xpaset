#compdef xpaset
# Documentation: https://github.com/ericmandel/xpa/blob/master/doc/pod/xpaset.pod
# Send data to one or more XPA servers

local ret=1

_arguments -s -S \
  '-h[display help message]' \
  '-i+[access XPA point on a different machine]:nsinet' \
  '-m+[override XPA_METHOD]:method' \
  '-n[do not wait for status message]' \
  '-p[do not read/send buffer data from stdin]' \
  '-s[enter server mode]' \
  '-t+[short,long timeout values]:sval,lval' \
  '-u+[restrict to XPA points from users]:users' \
  '-v[verify message to stdout]' \
  '--version[show version information]' \
  '1:template or host\:port:_hosts' \
  '*:paramlist' && ret=0

return ret
