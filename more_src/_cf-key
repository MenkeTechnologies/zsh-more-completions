#compdef cf-key
# Documentation: https://docs.cfengine.com/docs/master/reference-components-cf-key.html
# Source: cfengine/core cf-key/cf-key.c — CFEngine key management utility.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-I --inform)'{-I,--inform}'[print basic info about key generation]' \
    '(-d --debug)'{-d,--debug}'[enable debugging output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-g --log-level)'{-g+,--log-level=}'[log level]:level:(error warning notice info verbose debug)' \
    '(-f --output-file)'{-f+,--output-file=}'[alternative output file]:file:_files' \
    '(-T --key-type)'{-T+,--key-type=}'[RSA key size in bits (default 2048)]:bits:(1024 2048 3072 4096)' \
    '(-s --show-hosts)'{-s,--show-hosts}'[show lastseen hostnames and IPs]' \
    '(-N --no-truncate)'{-N,--no-truncate}'[do not truncate -s output]' \
    '(-r --remove-keys)'{-r+,--remove-keys=}'[remove keys for host/IP/MD5/SHA]:identifier:_default' \
    '(-x --force-removal)'{-x,--force-removal}'[force removal of keys]' \
    '(-l --install-license)'{-l+,--install-license=}'[install license on Enterprise server]:file:_files' \
    '(-p --print-digest)'{-p+,--print-digest=}'[print digest of public key]:file:_files' \
    '(-t --trust-key)'{-t+,--trust-key=}'[trust the specified public key]:file:_files' \
    '(-C --color)'{-C+,--color=}'[colorized output]:when:(always auto never)' \
    '--timestamp[log timestamps]' \
    '(-n --numeric)'{-n,--numeric}'[do not lookup host names]' \
    && ret=0

return ret
