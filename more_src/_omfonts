#compdef omfonts
# OFM/OPL and OVF/OVP font metric translator (TeX)

local ret=1

_arguments -s -S \
  '(- *)-ofm2opl[translate font metrics OFM to human-readable OPL]' \
  '(- *)-opl2ofm[compile property list OPL to binary OFM metrics]' \
  '(- *)-ovf2ovp[translate virtual font OVF to human-readable OVP]' \
  '(- *)-ovp2ovf[compile property list OVP to binary OVF virtual font]' \
  '-char-format=[output character codes as num or ascii]:type:(num ascii)' \
  '-num-format=[output numbers as hex or octal]:type:(hex octal)' \
  '-text-format=[output coding scheme/family as mixed or upper case]:type:(mixed upper)' \
  '-charcode-format=[output character codes (compatibility)]:type:(hex octal ascii)' \
  '-verbose[display progress reports]' \
  '-help[display help and exit]' \
  '-version[output version information and exit]' \
  '*:file:_files' && ret=0

return ret
