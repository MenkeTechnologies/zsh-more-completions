#compdef create-t3-app
# Documentation: https://create.t3.gg/en/installation
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--noGit[skip git repository initialization]' \
  '--noInstall[skip dependency installation]' \
  '(-y --default)'{-y,--default}'[bypass CLI with all options selected]' \
  '--CI[run in CI mode (enables flag-based scaffolding)]' \
  '--tailwind[include Tailwind CSS]' \
  '--trpc[include tRPC]' \
  '--prisma[include Prisma]' \
  '--drizzle[include Drizzle ORM]' \
  '--nextAuth[include NextAuth.js]' \
  '--appRouter[use Next.js App Router]' \
  '--dbProvider=[database provider]:provider:(mysql postgres planetscale sqlite)' \
  '1:project directory:_directories' && ret=0

return ret
