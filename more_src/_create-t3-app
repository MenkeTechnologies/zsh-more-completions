#compdef create-t3-app

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--noGit[skip git repository initialization]' \
  '--noInstall[skip dependency installation]' \
  '(-y --default)'{-y,--default}'[use default configuration]' \
  '--CI[run in CI mode]' \
  '--tailwind[include Tailwind CSS]' \
  '--trpc[include tRPC]' \
  '--prisma[include Prisma]' \
  '--drizzle[include Drizzle ORM]' \
  '--nextAuth[include NextAuth.js]' \
  '--appRouter[use the App Router]' \
  '--import-alias=[configure import alias]:alias' \
  '1:project directory:_directories' && ret=0

return ret
