#compdef bxss
# Documentation: https://github.com/ethicalhackingplayground/bxss
# bxss - blind XSS injection scanner

local ret=1

_arguments -s -S \
  '-a[append the payload to the parameter]' \
  '-c[set the concurrency level]:level:' \
  '-H[set a custom header]:header:' \
  '-hf[path to file with headers]:file:_files' \
  '-p[the blind XSS payload]:payload:' \
  '-pf[path to file with payloads]:file:_files' \
  '-t[test parameters for blind XSS]' \
  '-X[HTTP method to use]:method:(GET POST PUT OPTIONS)' \
  '-v[enable debug mode]' \
  '-rl[rate limit (requests per second)]:rate:' \
  '-f[follow redirects]' \
  '-l[enable trace mode (experimental)]' \
  '*:url:_files' && ret=0

return ret
