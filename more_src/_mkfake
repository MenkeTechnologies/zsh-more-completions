#compdef mkfake
# Documentation: https://bio-formats.readthedocs.io/en/stable/users/comlinetools/mkfake.html
# bio-formats: create a high-content screen for testing

local ret=1

_arguments -s \
  '-plates[number of plates in the screen]:plates:' \
  '-runs[number of acquisitions for each plate]:runs:' \
  '-rows[number of rows of wells in each plate]:rows:' \
  '-columns[number of columns of wells in each plate]:columns:' \
  '-fields[number of fields per well]:fields:' \
  '-debug[enable debugging output]:debug:' \
  '*:file:_files' && ret=0

return ret
