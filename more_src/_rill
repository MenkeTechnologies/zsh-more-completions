#compdef rill
# Documentation: https://man.archlinux.org/search?q=rill
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'start:run local analytics dev server'
      'deploy:deploy project to Rill Cloud'
      'login:authenticate with Rill Cloud'
      'logout:clear credentials'
      'version:print version'
      'docs:open documentation'
    )
    _describe -t commands 'rill command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--project=[path to project]:directory:_directories' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
