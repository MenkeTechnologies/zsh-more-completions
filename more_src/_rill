#compdef rill
# Documentation: https://docs.rilldata.com/reference/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[print usage]' \
  '(-v --version)'{-v,--version}'[show rill version]' \
  '--api-token=[token for authenticating with the cloud API]:token' \
  '--format=[output format]:format:(human json csv)' \
  '--interactive[prompt for missing required parameters]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'billing:manage billing'
      'chat:chat with Rill AI'
      'deploy:deploy project to Rill Cloud'
      'docs:open documentation'
      'env:manage project environment variables'
      'init:initialize a new Rill project'
      'login:authenticate with Rill Cloud'
      'logout:clear credentials'
      'org:manage organizations'
      'project:manage projects'
      'public-url:manage public URLs'
      'query:run a SQL query against the runtime'
      'service:manage service accounts'
      'start:run local analytics dev server'
      'token:manage personal access tokens'
      'uninstall:uninstall Rill'
      'upgrade:upgrade Rill to latest version'
      'user:manage users'
      'usergroup:manage user groups'
      'validate:validate project configuration'
      'version:print version'
      'whoami:show current authenticated identity'
    )
    _describe -t commands 'rill command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
