#compdef consul-k8s-control-plane
# _consul-k8s-control-plane — Consul service-mesh Kubernetes control plane
# upstream: https://github.com/hashicorp/consul-k8s
# Subcommands from control-plane/commands.go on tip.

_consul-k8s-control-plane() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'acl-init:bootstrap an ACL token for a Consul client'
                'connect-init:Consul Connect injection bootstrapping (sidecar startup)'
                'consul-logout:revoke a Consul ACL token on Pod termination'
                'create-federation-secret:create the multi-cluster federation Secret'
                'delete-completed-job:delete a Job after it completes'
                'fetch-server-region:fetch the Consul server region label'
                'gateway-cleanup:clean up Consul-managed gateways on uninstall'
                'gateway-cleanup-custom:clean up custom-resource managed gateways'
                'gateway-resources:create/update gateway Deployments + Services'
                'gateway-resources-custom:create/update custom gateway resources'
                'generate-manifests:render Consul control-plane manifests'
                'get-consul-client-ca:fetch the Consul client CA cert'
                'gossip-encryption-autogenerate:autogenerate the gossip-encryption Secret'
                'inject-connect:run the Connect/sidecar-injection webhook server'
                'install-cni:install the Consul CNI plugin on a node'
                'partition-init:bootstrap an Admin Partition'
                'server-acl-init:bootstrap the server-side Consul ACL system'
                'sync-catalog:run the Kubernetes <-> Consul catalog sync controller'
                'tls-init:initialize Consul TLS materials'
                'version:print version'
                'webhook-cert-manager:manage webhook TLS certificates'
            )
            _describe -t commands command cmds
            ;;
        args)
            _arguments \
                '-help[show subcommand help]' \
                '*: :_files'
            ;;
    esac
}

_consul-k8s-control-plane "$@"
