#compdef tinygo

# Zsh completion for tinygo - Go compiler for embedded systems and WASM

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'build:compile packages and dependencies'
  'run:compile and run immediately'
  'test:test packages'
  'flash:compile and flash to connected device'
  'gdb:run with GDB debugger'
  'lldb:run with LLDB debugger'
  'monitor:connect to serial port'
  'ports:list serial ports'
  'targets:list available targets'
  'info:show target info'
  'version:show version'
  'env:show environment info'
  'list:list installed packages'
  'clean:empty cache directory'
  'help:print help'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build|run|test|flash|gdb|lldb)
        _arguments \
          '-o[output filename]:file:_files' \
          '-target=[target board or chip]:target:' \
          '-port=[flash port]:port:_files -g "/dev/*"' \
          '-opt=[optimization level]:level:(0 1 2 s z)' \
          '-gc=[garbage collector]:gc:(none leaking conservative)' \
          '-scheduler=[scheduler type]:scheduler:(none coroutines tasks)' \
          '-print-allocs=[print allocations for func]:function:' \
          '-print-stacks[print goroutine stack sizes]' \
          '-printir[print LLVM IR]' \
          '-size=[print code size]:size:(none short full)' \
          '-tags=[build tags]:tags:' \
          '-no-debug[disable debug symbols]' \
          '-ldflags=[linker flags]:flags:' \
          '-v[verbose output]' \
          '-work[keep temporary directory]' \
          '-x[print commands]' \
          '-panic=[panic strategy]:panic:(print trap)' \
          '-cpuprofile=[write CPU profile]:file:_files' \
          '*:package:_files -/' && ret=0
        ;;
      monitor)
        _arguments \
          '-port=[serial port]:port:_files -g "/dev/*"' \
          '-baudrate=[baud rate]:rate:(9600 19200 38400 57600 115200)' && ret=0
        ;;
      info)
        _arguments '-target=[target]:target:' && ret=0
        ;;
    esac
    ;;
esac

return ret
