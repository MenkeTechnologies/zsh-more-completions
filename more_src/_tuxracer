#compdef tuxracer
# Documentation: https://tuxracer.sourceforge.net/
# Reference accessed: 2026-05-16
# Verified: original Tux Racer (sourceforge classic). Driven via env vars
# (TUXRACER_*) and ~/.tuxracer/options config file; no CLI flag table.
# extremetuxracer is the modern fork with CLI flags (see _extremetuxracer).
# Removed from prior file: fabricated -h/--help/--version/-fullscreen/
# -window/-d/-c flags and bogus man.archlinux.org search URL.

# tuxracer: classic Tux downhill racing (no CLI flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  ':no-flags (config via TUXRACER_* env vars / ~/.tuxracer/options):' && ret=0
return ret
