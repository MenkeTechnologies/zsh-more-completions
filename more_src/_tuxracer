#compdef tuxracer
# Documentation: https://man.archlinux.org/search?q=tuxracer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-fullscreen[fullscreen mode]' \
  '-window[windowed]' \
  '-d+[data directory]:dir:_files -/' \
  '-c+[config file]:file:_files' && ret=0

return ret
