#compdef bucts
# Documentation: https://github.com/coreboot/coreboot/blob/master/util/bucts/bucts.c
# coreboot backup control top swap bit tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-s --set)'{-s,--set}'[set top swap bit to invert bootblock decoding]' \
  '(-u --unset)'{-u,--unset}'[unset top swap bit for regular decoding]' \
  '(-p --print)'{-p,--print}'[print current hardware status]' && ret=0

return ret
