#compdef namd2

# NAMD 2.x: parallel molecular dynamics
local curcontext="$curcontext" ret=1
_arguments -C \
  '+p[number of processors]:n:' \
  '+pemap[CPU affinity mapping]:map:' \
  '+commap[communication thread CPU map]:map:' \
  '+stdout[redirect stdout to per-rank file]:prefix:' \
  '+ofi[use OFI network layer]' \
  '+isomalloc_sync[Charm++ isomalloc sync]' \
  '+devices[list of GPU devices]:list:' \
  '+ignoresharing[ignore shared GPU warnings]' \
  '+replicas[number of replicas for replica-exchange]:n:' \
  '+restart[restart filename]:file:_files' \
  '+pmePEs[PEs dedicated to PME]:n:' \
  '+autotune[enable Charm++ auto-tuning]' \
  '+netpoll[network polling mode]' \
  '*::NAMD config file:_files -g "*.(conf|namd|inp)"' && ret=0
return ret
