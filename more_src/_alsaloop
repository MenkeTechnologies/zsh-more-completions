#compdef alsaloop
# Documentation: https://manpages.debian.org/alsaloop.1
# Source: alsa-utils — userland software PCM loopback between capture and playback devices.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(-g --config)'{-g+,--config=}'[configuration file]:file:_files' \
    '(-d --daemonize)'{-d,--daemonize}'[daemonize; use syslog for messages]' \
    '(-P --pdevice)'{-P+,--pdevice=}'[playback device]:device:' \
    '(-C --cdevice)'{-C+,--cdevice=}'[capture device]:device:' \
    '(-X --pctl)'{-X+,--pctl=}'[CTL device for playback]:device:' \
    '(-Y --cctl)'{-Y+,--cctl=}'[CTL device for capture]:device:' \
    '(-x --prateshift)'{-x+,--prateshift=}'[playshift sync mode control name]:ctl:' \
    '(-l --latency)'{-l+,--latency=}'[requested latency in frames]:frames:' \
    '(-t --tlatency)'{-t+,--tlatency=}'[requested latency in usec]:usec:' \
    '(-f --format)'{-f+,--format=}'[sample format (e.g. S16_LE, S32_LE)]:fmt:(S16_LE S16_BE S24_LE S24_BE S24_3LE S24_3BE S32_LE S32_BE U8 FLOAT_LE FLOAT_BE)' \
    '(-c --channels)'{-c+,--channels=}'[channel count]:n:' \
    '(-r --rate)'{-r+,--rate=}'[sample rate (Hz)]:hz:(8000 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
    '(-n --resample)'{-n,--resample}'[allow rate resampling via alsa-lib]' \
    '(-A --samplerate)'{-A+,--samplerate=}'[libsamplerate converter]:converter:(sincbestquality sincmediumquality sincfastest zeroorderhold linear)' \
    '(-B --buffer)'{-B+,--buffer=}'[buffer size in frames]:frames:' \
    '(-E --period)'{-E+,--period=}'[period size in frames]:frames:' \
    '(-s --seconds)'{-s+,--seconds=}'[loop duration in seconds]:seconds:' \
    '(-b --nblock)'{-b,--nblock}'[non-block mode (early process wakeup)]' \
    '(-S --sync)'{-S+,--sync=}'[capture-to-playback sync mode]:mode:(none simple captshift playshift samplerate auto)' \
    '(-T --thread)'{-T+,--thread=}'[thread number (-1 = unique)]:n:' \
    '(-m --mixer)'{-m+,--mixer=}'[redirect mixer control playback->capture]:mixid:' \
    '(-O --ossmixer)'{-O+,--ossmixer=}'[redirect mixer control OSS->ALSA]:ossmixid:' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-U --xrun)'{-U,--xrun}'[verbose xrun profiling]' \
    '(-W --wake)'{-W+,--wake=}'[process wake timeout]:timeout:' \
    && ret=0

return ret
