#compdef esl-alimap
# Easel: map two alignments to each other

local ret=1

_arguments -s -S \
  '(-h)-h[show help]' \
  '-q[be quiet; do not print per-column mapping information]' \
  '--mask-a2a=[save mask of alignment 1 positions mapping to alignment 2]:file:_files' \
  '--mask-a2rf=[save mask of alignment 1 positions mapping to nongap RF of alignment 2]:file:_files' \
  '--mask-rf2a=[save mask of nongap RF of alignment 1 mapping to alignment 2]:file:_files' \
  '--mask-rf2rf=[save mask of nongap RF of alignment 1 mapping to nongap RF of alignment 2]:file:_files' \
  '--submap=[assume identical columns and save mapping mask]:file:_files' \
  '--amino[assert both input files are protein]' \
  '--dna[assert both input files are DNA]' \
  '--rna[assert both input files are RNA]' \
  '*:alignment file:_files' && ret=0

return ret
