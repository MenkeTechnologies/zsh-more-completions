#compdef cargo-instruments

# https://github.com/cmyr/cargo-instruments — profile binaries with Xcode Instruments

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '-l[list available Instruments templates]' \
  '--list-templates[list available templates]' \
  '--no-open[do not open trace in Instruments.app]' \
  '--release[build with --release]' \
  '--all-features[enable all features for target]' \
  '--no-default-features[disable default features]' \
  '--bench=[benchmark target]:benchmark:' \
  '--bin=[binary target]:binary:' \
  '--example=[example target]:example:' \
  '--features=[cargo feature flags]:features:' \
  '--manifest-path=[path to Cargo.toml]:file:_files -g "Cargo.toml"' \
  '(-p --package)'{-p,--package}'=[workspace package]:package:' \
  '--profile=[cargo profile name]:profile:' \
  '(-t --template)'{-t,--template}'=[Instruments template]:template:' \
  '--time-limit=[max recording time in ms]:milliseconds:' \
  '(-o --output)'{-o,--output}'=[output .trace path]:path:_files' \
  '*::target_binary_args:_default' && return 0
