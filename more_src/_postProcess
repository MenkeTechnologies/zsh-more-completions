#compdef postProcess
# OpenFOAM: execute functionObjects for the selected times, fields and case

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print the usage]' \
  '-case=[specify alternate case directory (default cwd)]:dir:_files -/' \
  '-region=[specify alternative mesh region]:name' \
  '-dict=[read functions dictionary from specified location]:file:_files' \
  '-field=[name of the field to be processed, eg U]:field' \
  '-fields=[list of fields to be processed, eg (U T p)]:fields' \
  '-func=[name of the functionObject to execute, eg Q]:func' \
  '-funcs=[names of the functionObjects to execute, eg (Q div(U))]:funcs' \
  '-list[list the available configured functionObjects]' \
  '-constant[include the constant/ dir in the times list]' \
  '-withZero[include the 0/ dir in the times list]' \
  '-noZero[exclude the 0/ dir from the times list]' \
  '-latestTime[select the latest time]' \
  '-time=[comma-separated time ranges - eg :10,20,40:70,1000:]:ranges' \
  '-parallel[run in parallel]' \
  '-fileHandler=[override the fileHandler]:handler:(collated uncollated masterUncollated)' \
  '-libs=[pre-load libraries]:libs' \
  '-doc[display application documentation in browser]' \
  '-srcDoc[display source code in browser]' && ret=0

return ret
