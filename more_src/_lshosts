#compdef lshosts
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lshosts.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lshosts(1) reference.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -c (cluster summary), -K (only local cluster), -o
# (output fields). The real lshosts has -a, -cname, -l, -w, -R, -s,
# -T, -h, -V.

# lshosts: show LSF cluster hosts (static info)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '-a[show all hosts including Dynamic Cluster VM hosts]' \
  '-cname[include cluster name (LSF Advanced Edition)]' \
  '-l[long multi-line format]' \
  '-w[wide format (no truncation)]' \
  '-R+[resource requirement expression]:expr:' \
  '-s[show static resource information]:resource:' \
  '-T[show host topology information]' \
  '*:host:_hosts' && ret=0
return ret
