#compdef lshosts

# lshosts: show LSF cluster hosts (static info)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-l[long format]' \
  '-w[wide format]' \
  '-s[show shared resources]' \
  '-c[show cluster summary]' \
  '-K[show local cluster]' \
  '-o[output fields]:fields:' \
  '*:host:_hosts' && ret=0
return ret
