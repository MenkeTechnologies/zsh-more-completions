#compdef mlxfwreset
# Documentation: https://docs.nvidia.com/networking/display/mftv4240/mlxfwreset+%E2%80%93+loading+firmware+on+5th+generation+devices+tool
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'q:query supported reset parameters'
  'query:query supported reset parameters'
  'r:reset device'
  'reset:reset device'
  'reset_fsm_register:reset multi-host synchronization register'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d+,--device=}'[mst device]:dev:' \
  '(-l --level)'{-l+,--level=}'[reset level]:level:(0 3 4)' \
  '(-t --type)'{-t+,--type=}'[reset type]:type:(0 1 2)' \
  '--sync=[reset synchronization mode]:n:(0 1)' \
  '(-y --yes)'{-y,--yes}'[answer yes]' \
  '(-m --mst_flags)'{-m+,--mst_flags=}'[mst flags for restart]:flags:' \
  '(-s --skip_driver)'{-s,--skip_driver}'[skip driver start/stop stage]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mlxfwreset command' commands && ret=0 ;;
esac
return ret
