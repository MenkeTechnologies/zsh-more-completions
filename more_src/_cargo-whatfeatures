#compdef cargo-whatfeatures
# Documentation: https://github.com/museun/cargo-whatfeatures
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# cargo-whatfeatures: cargo subcommand to display the features available on a
# crate, including features of dependencies and version listings.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print program name and version]' \
  '(-d --deps)'{-d,--deps}'[display dependencies for the crate]' \
  '(-n --no-features)'{-n,--no-features}'[disable listing features for the crate]' \
  '(-r --restricted)'{-r,--restricted}'[on local workspace include private packages]' \
  '(-t --this-crate)'{-t,--this-crate}'[do not traverse to workspace root from a member crate]' \
  '(-l --list)'{-l,--list}'[list all versions for the crate]' \
  '(-s --short)'{-s,--short}'[display only name and latest version]' \
  '(-v --verbose)'{-v,--verbose}'[list all implied features]' \
  '(-o --offline)'{-o,--offline}'[do not connect to the internet]' \
  '(-j --json)'{-j,--json}'[output JSON rather than human-readable]' \
  '--print-cache-dir[print path to the cache directory]' \
  '--purge[purge the local cache]' \
  '--theme=[output theme]:theme:(basic colorful)' \
  '(-c --color)'{-c+,--color=}'[color mode]:color:(always auto never)' \
  '(-p --pkgid)'{-p+,--pkgid=}'[specify a version, e.g. foo:0.7.1]:pkgid:' \
  '--manifest-path=[path to local Cargo.toml]:path:_files -g "*.toml"' \
  '(-y --show-yanked)'{-y+,--show-yanked=}'[show yanked versions]:yanked:(exclude include only)' \
  '1::crate name:' && ret=0

return ret
