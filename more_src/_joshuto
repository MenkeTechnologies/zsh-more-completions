#compdef joshuto
# Documentation: https://github.com/kamiyaa/joshuto/blob/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap Args definition at the URL above.

# Zsh completion for joshuto - Terminal file manager.
# Corrected from prior file: removed invented --choosefile,
# --choosefiles, --printwd, --mouse, --no-mouse, --session and the
# -V short for version (joshuto uses -v/--version). Real flags are
# only --change-directory, --file-chooser, --output-file plus the
# completions/config/version subcommands.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-v,--version}'[print version information]' \
  '--change-directory[change directory on exit]' \
  '--file-chooser[start in file chooser mode]' \
  '--output-file=[file to write last directory/selection on exit]:file:_files' \
  '1:command or directory:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a subcommands=(
      'completions:print completions for a given shell'
      'config:print embedded toml configuration for a config type'
      'version:print joshuto build version'
    )
    _alternative \
      'commands:command:_describe -t commands "joshuto command" subcommands' \
      'dirs:directory:_directories' && ret=0
    ;;
  (args)
    _directories && ret=0
    ;;
esac

return ret
