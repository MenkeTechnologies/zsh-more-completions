#compdef gdmap
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/gdmap.1.html
# gdmap - graphical disk map, display directory tree as treemap

local ret=1

_arguments -s -S \
  '(-? --help)'{-\?,--help}'[print the command line options]' \
  '(-f --folder)-f[inspect directory after startup]:dir:_files -/' \
  '--folder=[inspect directory after startup]:dir:_files -/' \
  '*:directory:_files -/' && ret=0

return ret
