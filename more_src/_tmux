#compdef tmux

# Zsh completion for tmux (terminal multiplexer)

local curcontext="$curcontext" state line ret=1

_tmux_sessions() {
  local -a sessions
  sessions=( ${(f)"$(tmux list-sessions -F '#S' 2>/dev/null)"} )
  _describe -t sessions 'session' sessions
}

_tmux_windows() {
  local -a windows
  windows=( ${(f)"$(tmux list-windows -a -F '#{session_name}:#{window_index}: #{window_name}' 2>/dev/null)"} )
  _describe -t windows 'window' windows
}

_tmux_panes() {
  local -a panes
  panes=( ${(f)"$(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)"} )
  _describe -t panes 'pane' panes
}

_tmux_clients() {
  local -a clients
  clients=( ${(f)"$(tmux list-clients -F '#{client_tty}' 2>/dev/null)"} )
  _describe -t clients 'client' clients
}

_tmux_buffers() {
  local -a buffers
  buffers=( ${(f)"$(tmux list-buffers -F '#{buffer_name}' 2>/dev/null)"} )
  _describe -t buffers 'buffer' buffers
}

local -a tmux_commands
tmux_commands=(
  'attach-session:attach or switch to a session'
  'bind-key:bind a key to a command'
  'break-pane:break a pane from an existing into a new window'
  'capture-pane:capture the contents of a pane'
  'choose-buffer:put a pane into buffer choice mode'
  'choose-client:put a window into client choice mode'
  'choose-tree:put a window into tree choice mode'
  'clear-history:remove and free the history of a pane'
  'clock-mode:enter clock mode'
  'command-prompt:open the tmux command prompt'
  'confirm-before:run a command but ask for confirmation first'
  'copy-mode:enter copy mode'
  'delete-buffer:delete a named paste buffer'
  'detach-client:detach a client from the server'
  'display-message:display a message in the status line'
  'display-panes:display a visible indicator of each pane'
  'display-popup:display a popup box over a pane'
  'find-window:search for a pattern in windows'
  'has-session:check and report if a session exists'
  'if-shell:execute a tmux command if a shell command succeeds'
  'join-pane:split a pane and move an existing one into the new space'
  'kill-pane:destroy a given pane'
  'kill-server:kill the tmux server'
  'kill-session:destroy a given session'
  'kill-window:destroy a given window'
  'last-pane:select the previously selected pane'
  'last-window:select the previously selected window'
  'link-window:link a window to another'
  'list-buffers:list paste buffers of a session'
  'list-clients:list clients attached to server'
  'list-commands:list supported sub-commands'
  'list-keys:list all key bindings'
  'list-panes:list panes of a window'
  'list-sessions:list sessions managed by server'
  'list-windows:list windows of a session'
  'load-buffer:load a file into a paste buffer'
  'lock-client:lock a client'
  'lock-server:lock all clients attached to the server'
  'lock-session:lock all clients attached to a session'
  'menu:display a menu'
  'move-pane:move a pane into a new space'
  'move-window:move a window to another'
  'new-session:create a new session'
  'new-window:create a new window'
  'next-layout:move a window to the next layout'
  'next-window:move to the next window in a session'
  'paste-buffer:insert a paste buffer into the window'
  'pipe-pane:pipe output from a pane to a shell command'
  'previous-layout:move a window to the previous layout'
  'previous-window:move to the previous window in a session'
  'refresh-client:refresh a client'
  'rename-session:rename a session'
  'rename-window:rename a window'
  'resize-pane:resize a pane'
  'resize-window:resize a window'
  'respawn-pane:reuse a pane in which a command has exited'
  'respawn-window:reuse a window in which a command has exited'
  'rotate-window:rotate positions of panes in a window'
  'run-shell:execute a command without creating a new window'
  'save-buffer:save a paste buffer to a file'
  'select-layout:choose a specific layout for a window'
  'select-pane:make a pane the active one in the window'
  'select-window:select a window'
  'send-keys:send a key or keys to a window'
  'send-prefix:send the prefix key to a window'
  'server-info:show server information'
  'set-buffer:set contents of a paste buffer'
  'set-environment:set or unset an environment variable'
  'set-hook:set a hook to a command'
  'set-option:set a session option'
  'set-window-option:set a window option'
  'show-buffer:display the contents of a paste buffer'
  'show-environment:display the environment'
  'show-hooks:show the global hooks'
  'show-messages:show client message log'
  'show-options:show session options'
  'show-window-options:show window options'
  'source-file:execute tmux commands from a file'
  'split-window:create a new pane by splitting an existing one'
  'start-server:start the tmux server'
  'suspend-client:suspend a client'
  'swap-pane:swap two panes'
  'swap-window:swap two windows'
  'switch-client:switch the client to another session'
  'unbind-key:unbind a key'
  'unlink-window:unlink a window'
  'wait-for:wait for an event or trigger it'
)

_arguments -s -S \
  '-2[assume 256 colours]' \
  '-C[start in control mode]' \
  '-c[execute shell command]:command:' \
  '-D[do not start the tmux server as a daemon]' \
  '-f[specify configuration file]:config file:_files' \
  '-L[specify socket name]:socket name:' \
  '-l[behave as a login shell]' \
  '-N[do not start the server even if the command would normally do so]' \
  '-S[specify full path to server socket]:socket path:_files' \
  '-u[flag explicitly tells tmux UTF-8 is supported]' \
  '-T[set terminal features]:features:' \
  '-v[verbose logging]' \
  '-V[report the tmux version]' \
  '1:command:_describe -t commands command tmux_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    local cmd="${line[1]}"
    case "$cmd" in
      attach-session|attach)
        _arguments -s -S \
          '-d[detach other clients]' \
          '-r[read-only]' \
          '-x[set width of client]' \
          '-y[set height of client]' \
          '-t[specify target session]:session:_tmux_sessions' \
          '-E[do not apply update-environment option]' && ret=0
        ;;
      detach-client|detach)
        _arguments -s -S \
          '-a[kill all clients except the one given with -t]' \
          '-P[send SIGHUP to parent process]' \
          '-s[specify target session]:session:_tmux_sessions' \
          '-t[specify target client]:client:_tmux_clients' \
          '-E[set shell command to run when client detaches]:command:' && ret=0
        ;;
      new-session|new)
        _arguments -s -S \
          '-A[attach to existing session if it exists]' \
          '-d[do not attach new session to current terminal]' \
          '-D[if -A, detach other clients attached to session]' \
          '-E[do not apply update-environment option]' \
          '-f[set client flags]:flags:' \
          '-P[print information about the new session]' \
          '-F[specify output format]:format:' \
          '-n[name the initial window]:window name:' \
          '-s[name the session]:session name:' \
          '-t[specify target session for grouping]:session:_tmux_sessions' \
          '-x[specify width]:width:' \
          '-y[specify height]:height:' \
          '-X[if -A, send the command to existing session]' \
          '*:command:_cmdstring' && ret=0
        ;;
      new-window|neww)
        _arguments -s -S \
          '-a[insert after current window]' \
          '-b[insert before current window]' \
          '-d[do not make the new window the current window]' \
          '-e[set environment variable]:variable:' \
          '-k[destroy it if the specified window exists]' \
          '-n[specify window name]:name:' \
          '-P[print information about the new window]' \
          '-F[specify output format]:format:' \
          '-S[specify start directory]:directory:_directories' \
          '-t[specify target window]:window:_tmux_windows' \
          '*:command:_cmdstring' && ret=0
        ;;
      split-window|splitw)
        _arguments -s -S \
          '-b[create pane to the left or above]' \
          '-d[do not make the new pane the current pane]' \
          '-e[set environment variable]:variable:' \
          '-f[create spanning full window width or height]' \
          '-h[create horizontal split]' \
          '-v[create vertical split]' \
          '-l[specify size]:size:' \
          '-p[specify percentage]:percentage:' \
          '-P[print information about the new pane]' \
          '-F[specify output format]:format:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          '*:command:_cmdstring' && ret=0
        ;;
      send-keys|send)
        _arguments -s -S \
          '-H[expect hexadecimal key values]' \
          '-l[disable key name lookup]' \
          '-M[pass through mouse event]' \
          '-R[reset terminal state]' \
          '-X[send a command into copy mode]' \
          '-N[specify a repeat count]:count:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          '*:key:' && ret=0
        ;;
      kill-session)
        _arguments -s -S \
          '-a[kill all sessions except the one specified]' \
          '-C[clear alerts in the session]' \
          '-t[specify target session]:session:_tmux_sessions' && ret=0
        ;;
      kill-window|killw)
        _arguments -s -S \
          '-a[kill all windows except the one specified]' \
          '-t[specify target window]:window:_tmux_windows' && ret=0
        ;;
      kill-pane|killp)
        _arguments -s -S \
          '-a[kill all panes except the one specified]' \
          '-t[specify target pane]:pane:_tmux_panes' && ret=0
        ;;
      select-window|selectw)
        _arguments -s -S \
          '-l[select last window]' \
          '-n[select next window]' \
          '-p[select previous window]' \
          '-T[if already the current window, select last window]' \
          '-t[specify target window]:window:_tmux_windows' && ret=0
        ;;
      select-pane|selectp)
        _arguments -s -S \
          '-D[select pane below]' \
          '-d[disable input to the pane]' \
          '-e[enable input to the pane]' \
          '-L[select pane to the left]' \
          '-l[select last pane]' \
          '-M[clear marked pane]' \
          '-m[set marked pane]' \
          '-R[select pane to the right]' \
          '-U[select pane above]' \
          '-Z[keep zoomed if already zoomed]' \
          '-T[set pane title]:title:' \
          '-t[specify target pane]:pane:_tmux_panes' && ret=0
        ;;
      resize-pane|resizep)
        _arguments -s -S \
          '-D[resize down]' \
          '-L[resize left]' \
          '-M[begin mouse resizing]' \
          '-R[resize right]' \
          '-U[resize up]' \
          '-Z[toggle zoom]' \
          '-x[set width]:width:' \
          '-y[set height]:height:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          ':adjustment:' && ret=0
        ;;
      rename-session|rename)
        _arguments -s -S \
          '-t[specify target session]:session:_tmux_sessions' \
          ':new name:' && ret=0
        ;;
      rename-window|renamew)
        _arguments -s -S \
          '-t[specify target window]:window:_tmux_windows' \
          ':new name:' && ret=0
        ;;
      switch-client|switchc)
        _arguments -s -S \
          '-E[do not apply update-environment option]' \
          '-l[move to the last session]' \
          '-n[move to the next session]' \
          '-p[move to the previous session]' \
          '-r[toggle read-only]' \
          '-Z[keep zoomed if already zoomed]' \
          '-t[specify target session]:session:_tmux_sessions' && ret=0
        ;;
      source-file|source)
        _arguments -s -S \
          '-F[expand format sequences in path]' \
          '-n[file is parsed but no commands are executed]' \
          '-q[suppress error messages for nonexistent files]' \
          '-v[show parsed commands]' \
          '*:config file:_files' && ret=0
        ;;
      set-option|set)
        _arguments -s -S \
          '-a[append to string options]' \
          '-F[expand formats in the option value]' \
          '-g[set global option]' \
          '-o[prevent setting an option already set]' \
          '-p[set a pane option]' \
          '-q[suppress errors about unknown or ambiguous options]' \
          '-s[set a server option]' \
          '-u[unset an option]' \
          '-U[unset an option, including inherited value]' \
          '-w[set a window option]' \
          '-t[specify target]:target:_tmux_sessions' \
          ':option:' \
          ':value:' && ret=0
        ;;
      set-window-option|setw)
        _arguments -s -S \
          '-a[append to string options]' \
          '-F[expand formats in the option value]' \
          '-g[set global option]' \
          '-o[prevent setting an option already set]' \
          '-q[suppress errors about unknown or ambiguous options]' \
          '-u[unset an option]' \
          '-t[specify target]:target:_tmux_windows' \
          ':option:' \
          ':value:' && ret=0
        ;;
      list-sessions|ls)
        _arguments -s -S \
          '-F[specify output format]:format:' \
          '-f[filter sessions]:filter:' && ret=0
        ;;
      list-windows|lsw)
        _arguments -s -S \
          '-a[list windows on the server]' \
          '-F[specify output format]:format:' \
          '-f[filter windows]:filter:' \
          '-t[specify target session]:session:_tmux_sessions' && ret=0
        ;;
      list-panes|lsp)
        _arguments -s -S \
          '-a[list panes on the server]' \
          '-F[specify output format]:format:' \
          '-f[filter panes]:filter:' \
          '-s[list panes in the session]' \
          '-t[specify target]:target:_tmux_windows' && ret=0
        ;;
      move-window|movew)
        _arguments -s -S \
          '-a[move after src]' \
          '-b[move before src]' \
          '-d[do not make new index current]' \
          '-k[kill target window if it exists]' \
          '-r[renumber windows sequentially]' \
          '-s[specify source window]:source:_tmux_windows' \
          '-t[specify destination window]:destination:_tmux_windows' && ret=0
        ;;
      swap-window|swapw)
        _arguments -s -S \
          '-d[do not make new index current]' \
          '-s[specify source window]:source:_tmux_windows' \
          '-t[specify destination window]:destination:_tmux_windows' && ret=0
        ;;
      swap-pane|swapp)
        _arguments -s -S \
          '-D[swap with next pane]' \
          '-U[swap with previous pane]' \
          '-Z[keep zoomed if already zoomed]' \
          '-d[do not change active pane]' \
          '-s[specify source pane]:source:_tmux_panes' \
          '-t[specify destination pane]:destination:_tmux_panes' && ret=0
        ;;
      display-message|display)
        _arguments -s -S \
          '-a[list format variables and their values]' \
          '-I[do not wait for input after displaying message]' \
          '-l[disable format expansion]' \
          '-N[print the number of lines]' \
          '-p[print to stdout]' \
          '-v[print verbose format]' \
          '-c[specify target client]:client:_tmux_clients' \
          '-d[delay in milliseconds]:delay:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          '-F[specify output format]:format:' \
          ':message:' && ret=0
        ;;
      capture-pane|capturep)
        _arguments -s -S \
          '-a[use alternate screen]' \
          '-e[include escape sequences for colors]' \
          '-J[join wrapped lines and preserve trailing spaces]' \
          '-N[preserve trailing spaces]' \
          '-p[redirect output to stdout]' \
          '-q[quiet, do not error if no alternate screen]' \
          '-C[escape non-printable characters as octal]' \
          '-b[specify target buffer]:buffer:_tmux_buffers' \
          '-E[end line number]:end line:' \
          '-S[start line number]:start line:' \
          '-t[specify target pane]:pane:_tmux_panes' && ret=0
        ;;
      pipe-pane|pipep)
        _arguments -s -S \
          '-I[connect stdin of command to pane output]' \
          '-O[connect stdout of command to pane input]' \
          '-o[only open if not already opened]' \
          '-t[specify target pane]:pane:_tmux_panes' \
          ':command:_cmdstring' && ret=0
        ;;
      run-shell|run)
        _arguments -s -S \
          '-b[run in background]' \
          '-C[run tmux command instead of shell command]' \
          '-d[specify delay]:delay:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          ':command:_cmdstring' && ret=0
        ;;
      wait-for|wait)
        _arguments -s -S \
          '-L[lock the channel]' \
          '-S[send/signal the channel]' \
          '-U[unlock the channel]' \
          ':channel:' && ret=0
        ;;
      bind-key|bind)
        _arguments -s -S \
          '-n[bind without prefix]' \
          '-r[key may repeat]' \
          '-N[attach a note]:note:' \
          '-T[specify key table]:table:' \
          ':key:' \
          '*:command:' && ret=0
        ;;
      unbind-key|unbind)
        _arguments -s -S \
          '-a[remove all key bindings]' \
          '-n[unbind without prefix]' \
          '-q[do not error if key is not bound]' \
          '-T[specify key table]:table:' \
          ':key:' && ret=0
        ;;
      display-popup|popup)
        _arguments -s -S \
          '-B[do not surround the popup with a border]' \
          '-C[close any popup on the client]' \
          '-E[close the popup on command exit]' \
          '-b[specify border lines]:border:(rounded padded double heavy simple none)' \
          '-c[specify target client]:client:_tmux_clients' \
          '-d[start directory]:directory:_directories' \
          '-e[set environment variable]:variable:' \
          '-h[height]:height:' \
          '-s[set style]:style:' \
          '-S[set border style]:style:' \
          '-T[set popup title]:title:' \
          '-t[specify target pane]:pane:_tmux_panes' \
          '-w[width]:width:' \
          '-x[x position]:x:' \
          '-y[y position]:y:' \
          '*:command:_cmdstring' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
