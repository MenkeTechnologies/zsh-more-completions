#compdef local-ai

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--address[address to listen on]:address:' \
  '--backend-assets-path[path to backend assets]:path:_directories' \
  '--context-size[default context size]:size:' \
  '--cors[enable CORS]' \
  '--cors-allow-origins[allowed CORS origins]:origins:' \
  '--debug[enable debug mode]' \
  '--galleries[JSON list of model galleries]:galleries:' \
  '--log-level[log level]:level:(debug info warn error)' \
  '--models-path[path to models directory]:path:_directories' \
  '--parallel-requests[enable parallel requests]' \
  '--preload-models[JSON list of models to preload]:models:' \
  '--threads[number of threads]:threads:' \
  '--upload-limit[upload file size limit]:limit:' \
  && ret=0

return ret
