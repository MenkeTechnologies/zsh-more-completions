#compdef mentat
# Documentation: https://github.com/AbanteAI/archive-old-cli-mentat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_mentat() {
    local -a args
    args=(
        '--model[Specify the LLM to use (defaults to gpt-4)]:model'
        '--cwd[Set the current working directory for the session]:directory:_directories'
        '--no-code-map[Disable the generation of a code map]'
        '--exclude[Exclude specific files or directories from the context]:file:_files'
        '--ignore[Ignore files based on patterns]:pattern'
        '--version[Show version]'
        '(-h --help)'{-h,--help}'[Display help message]'
        '*:files or directories:_files'
    )

    _arguments -s -S $args
}

_mentat "$@"
