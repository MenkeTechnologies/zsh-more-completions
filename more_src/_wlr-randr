#compdef wlr-randr

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--output=[specify output to configure]:output' \
  '--on[enable the output]' \
  '--off[disable the output]' \
  '--mode=[set resolution and refresh rate]:WxH@rate' \
  '--custom-mode=[set custom mode]:WxH@rate' \
  '--preferred[use the preferred mode]' \
  '--pos=[set position]:X,Y' \
  '--transform=[set transform]:transform:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
  '--scale=[set scale factor]:scale' \
  '--adaptive-sync=[set adaptive sync]:state:(enabled disabled)' && ret=0

return ret
