#compdef arxiv-cli arxiv arxiv-dl
# _arxiv-cli — arxiv arxiv-cli CLI Python command-line client for the arXiv.org Cornell University preprint server search query metadata download paper PDF source-tarball list-by-author title-substring abstract-keyword category cs.AI cs.LG math physics quant-ph filtering rate-limited (lukasschwab arxiv.py team, Python); custom argparse
# upstream: https://arxiv.org/

_arxiv-cli() {
    local -a sub=(
        'search:search arXiv for papers'
        'download:download paper PDF/source'
        'info:fetch paper metadata'
        'list:list papers by author or category'
        'cite:fetch BibTeX or RIS citation'
        'recent:show recent submissions'
        'open:open paper in browser'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[category]:c:(cs.AI cs.CL cs.CV cs.DB cs.DC cs.DS cs.GT cs.LG cs.LO cs.NE cs.OS cs.PL cs.RO cs.SE cs.SY math math.AG math.NT math.ST physics physics.acc-ph quant-ph cond-mat astro-ph hep-ph hep-th stat stat.AP stat.ML econ q-bio q-fin)' \
        '--category=+[category]:str:' \
        '-a+[author]:str:' \
        '--author=+[author]:str:' \
        '-t+[title]:str:' \
        '--title=+[title]:str:' \
        '-y+[year]:str:' \
        '--year=+[year]:str:' \
        '-n+[max results]:n:' \
        '--max-results=+[N]:n:' \
        '-S+[sort]:s:(relevance lastUpdatedDate submittedDate)' \
        '--sort=+[s]:s:(relevance lastUpdatedDate submittedDate)' \
        '-O+[order]:o:(ascending descending)' \
        '--order=+[o]:o:(ascending descending)' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '--source[download source tarball]' \
        '--format=+[fmt]:f:(json bibtex ris csv yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'arxiv-cli subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments '*:query:' ;;
                download|info|cite|open) _arguments '*:arxiv id:' ;;
                list) _arguments '*:author or category:' ;;
            esac
            ;;
    esac
}

_arxiv-cli "$@"
