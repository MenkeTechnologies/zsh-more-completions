#compdef pass-update

# Zsh completion for pass-update - pass extension for updating passwords

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --clip)'{-c,--clip}'[put the password in the clipboard]' \
  '(-n --no-symbols)'{-n,--no-symbols}'[do not use symbols in generated password]' \
  '(-l --length)'{-l,--length}'=[length of the generated password]:length' \
  '(-p --provide)'{-p,--provide}'[let the user provide the password]' \
  '(-m --multiline)'{-m,--multiline}'[multiline mode]' \
  '(-i --include)'{-i,--include}'=[include specific password stores]:pattern' \
  '(-e --exclude)'{-e,--exclude}'=[exclude specific password stores]:pattern' \
  '(-E --edit)'{-E,--edit}'[edit the password using the default editor]' \
  '(-f --force)'{-f,--force}'[force update without confirmation]' \
  '*:pass-name' \
  && return 0
