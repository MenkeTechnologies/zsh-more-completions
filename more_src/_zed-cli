#compdef zed
# Documentation: https://github.com/authzed/zed
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n --new)'{-n,--new}'[open new workspace]' \
  '(-a --add)'{-a,--add}'[add to current workspace]' \
  '(--foreground)--foreground[run in foreground]' \
  '(--zed)--zed=[zed binary]:file:_files' \
  '(--user-data-dir)--user-data-dir=[user data dir]:dir:_files -/' \
  '(--dev-server-token)--dev-server-token=[dev server token]:t:' \
  '(--diff)--diff[open diff view]' \
  '(--system-specs)--system-specs[print system specs]' \
  '(--printenv)--printenv[print env vars]' \
  '(--no-pause)--no-pause[no pause on exit]' \
  '(-w --wait)'{-w,--wait}'[wait for window close]' \
  '*: :_files' && ret=0

return ret
