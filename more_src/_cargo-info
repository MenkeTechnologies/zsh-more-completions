#compdef cargo-info
# Documentation: https://doc.rust-lang.org/cargo/commands/cargo-info.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for cargo-info (Rust crate info viewer)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[use verbose output]' \
  '--verbose[use verbose output]' \
  '-q[do not print cargo log messages]' \
  '--quiet[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--index=[registry index URL]:url' \
  '--registry=[registry to use]:registry' \
  '--frozen[require Cargo.lock is up to date and offline]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without network access]' \
  '--config=[override configuration value]:KEY=VALUE:' \
  '-C[change working directory before execution]:dir:_files -/' \
  '*-Z[unstable (nightly-only) flag]:flag:' \
  '*:crate spec (name or name@version)'
