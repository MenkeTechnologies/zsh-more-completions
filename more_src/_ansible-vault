#compdef ansible-vault
# _ansible-vault — Ansible vault (manage encrypted YAML files in playbooks; create/decrypt/edit/encrypt/encrypt_string/rekey/view subcommands; --vault-id selects label/path scheme, --output sends decrypted text elsewhere)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/vault.py)
# Subcommands from ansible cli/vault.py on tip.

_ansible-vault() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ansible-vault command' '(create decrypt edit view encrypt encrypt_string rekey)' ;;
        args)
            _arguments \
                '--vault-id+[vault id]:vault_id:' \
                '--vault-password-file+[file]:file:_files' \
                '--ask-vault-password[ask pass]' \
                '--new-vault-id+[new vault id]:vault_id:' \
                '--new-vault-password-file+[file]:file:_files' \
                '--encrypt-vault-id+[vault id to encrypt with]:vault_id:' \
                '--output+[output file]:file:_files' \
                '*:file:_files'
            ;;
    esac
}

_ansible-vault "$@"
