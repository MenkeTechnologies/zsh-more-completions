#compdef faircamp

# Zsh completion for faircamp static music site / Gemini capsule

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-o+[site output directory]:dir:_directories' \
  '-a+[feed author]:author' \
  '-t+[item / feed title]:title' \
  '-c+[public audio base URL]:url' \
  '-l+[locale]:locale' \
  '-u+[site URL for feeds]:url' \
  '--no-build-symlinks[do not symlink release assets]' \
  '--clean-urls[omit .html from URLs]' \
  '1:subcommand:(init build serve)' \
  '*::args:{ _files }' && ret=0

return ret
