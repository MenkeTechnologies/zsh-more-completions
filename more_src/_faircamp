#compdef faircamp
# Documentation: https://codeberg.org/simonrepp/faircamp/src/branch/main/cli/src/args.rs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for faircamp static music site generator

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--analyze-cache[report obsolete cached assets]' \
  '--build-dir=[override build directory]:dir:_directories' \
  '--cache-dir=[override cache directory]:dir:_directories' \
  '--debug[print debug information for the site]' \
  '--debug-translations[render with translation keys instead of values]' \
  '(-d --deploy)'{-d,--deploy}'[deploy via rsync after build]' \
  '--deploy-destination=[rsync destination]:dest:' \
  '--docs[open faircamp docs in browser]' \
  '*--exclude=[exclude paths containing pattern]:pattern:' \
  '--export-tree=[export data tree to JSON file]:file:_files -g "*.json"' \
  '--ignore-errors[continue build despite errors]' \
  '*--include=[include only paths containing pattern]:pattern:' \
  '--no-clean-urls[generate full links with index.html]' \
  '--optimize-cache[reclaim cache disk space and exit]' \
  '(-p --preview)'{-p,--preview}'[preview build in browser after finish]' \
  '--preview-ip=[ip for preview server]:ip:' \
  '--preview-port=[port for preview server]:port:' \
  '--render-tree=[render from data tree JSON file]:file:_files -g "*.json"' \
  '--theming-widget[inject theme color widget]' \
  '(-v --verbose)'{-v,--verbose}'[show more messages during build]' \
  '--wipe-all[wipe build and cache directory and exit]' \
  '--wipe-build[wipe build directory and exit]' \
  '--wipe-cache[wipe cache directory and exit]' \
  '*:site directory:_directories' && ret=0

return ret
