#compdef berks

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '-F[output format]:format:(human json)' \
  '--format=[output format]:format:(human json)' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'apply:apply version locks to Chef environment'
      'contingent:list cookbooks that depend on given one'
      'info:show cookbook info'
      'init:initialize Berkshelf in current directory'
      'install:install cookbooks from Berksfile'
      'list:list cookbooks and dependencies'
      'outdated:list outdated cookbooks'
      'package:package cookbooks into archive'
      'search:search for cookbooks on Chef Supermarket'
      'shelf:manage local cookbook shelf'
      'show:show cookbook path'
      'update:update cookbooks'
      'upload:upload cookbooks to Chef server'
      'vendor:vendor cookbooks into directory'
      'verify:verify if Berksfile.lock is up to date'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      install|update)
        _arguments -s -S \
          '-b[path to Berksfile]:file:_files' \
          '--berksfile=[path to Berksfile]:file:_files' \
          '-e[exclude groups]:groups' \
          '--except=[exclude groups]:groups' \
          '-o[only groups]:groups' \
          '--only=[only groups]:groups' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      upload)
        _arguments -s -S \
          '--no-freeze[do not freeze uploaded versions]' \
          '--force[upload even if frozen]' \
          '--halt-on-frozen[halt on frozen cookbooks]' \
          '--ssl-verify[verify SSL]' \
          '--skip-syntax-check[skip syntax check]' \
          '-b[path to Berksfile]:file:_files' \
          '(- *)'{-h,--help}'[show help]' \
          '*:cookbook' && ret=0
        ;;
      vendor)
        _arguments -s -S \
          '-b[path to Berksfile]:file:_files' \
          '--berksfile=[path to Berksfile]:file:_files' \
          '--delete[delete vendor directory before vendoring]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
