#compdef halmos

_halmos() {
    _arguments -S \
        '--loop=[Set the loop unrolling bound]:number:' \
        '--solver-timeout=[Set timeout for the SMT solver in ms]:ms:' \
        '--early-exit[Stop execution as soon as the first counter-example is found]' \
        '--revert-as-failure[Treat any EVM revert as a test failure]' \
        '--match-test=[Only run tests matching the regex]:regex:' \
        '--match-contract=[Only run tests in contracts matching the regex]:regex:' \
        '--version[Show the currently installed version]' \
        '(-h --help)'{-h,--help}'[Display help for command]'
}

_halmos "$@"
