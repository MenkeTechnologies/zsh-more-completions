#compdef curlie

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--curl[show underlying curl command]' \
  '--pretty=[pretty]:p:(all colors format none)' \
  '--style=[style]:s:(auto solarized monokai)' \
  '-A+[user agent]:ua:' \
  '-b+[cookie]:c:' \
  '-c+[cookie jar]:file:_files' \
  '-d+[data]:d:' \
  '--data-binary=[binary data]:d:' \
  '--data-raw=[raw data]:d:' \
  '--data-urlencode=[urlencoded data]:d:' \
  '*-F+[form data]:f:' \
  '--form-string=[form string]:s:' \
  '*-H+[header]:h:' \
  '-X+[method]:m:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '--request=[method]:m:' \
  '-G[as query parameters]' \
  '--get[as query parameters]' \
  '-I[head request]' \
  '--head[head request]' \
  '-L[follow redirects]' \
  '--location[follow redirects]' \
  '--max-redirs=[max redirects]:n:' \
  '-o+[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '-O[remote-name]' \
  '--remote-name[remote-name]' \
  '-J[remote-header-name]' \
  '--remote-header-name[remote header name]' \
  '-e+[referer]:r:' \
  '--referer=[referer]:r:' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-s[silent]' \
  '--silent[silent]' \
  '-S[show errors]' \
  '--show-error[show errors]' \
  '-k[insecure]' \
  '--insecure[insecure]' \
  '-x+[proxy]:p:' \
  '--proxy=[proxy]:p:' \
  '-U+[proxy user]:u:' \
  '--proxy-user=[proxy user]:u:' \
  '-u+[user]:u:' \
  '--user=[user]:u:' \
  '*-K+[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--connect-timeout=[s]:s:' \
  '--max-time=[s]:s:' \
  '--retry=[n]:n:' \
  '--retry-delay=[s]:s:' \
  '--retry-max-time=[s]:s:' \
  '--cert=[file]:file:_files' \
  '--key=[file]:file:_files' \
  '--cacert=[file]:file:_files' \
  '--http1.0[HTTP/1.0]' \
  '--http1.1[HTTP/1.1]' \
  '--http2[HTTP/2]' \
  '--http3[HTTP/3]' \
  '--ipv4[IPv4]' \
  '--ipv6[IPv6]' \
  '-4[IPv4]' \
  '-6[IPv6]' \
  '*: :' && ret=0

return ret
