#compdef swapin swapin-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/swapin.py argparse)
# Reference accessed: 2026-05-29
# swapin — count swap-in events by process (BCC/eBPF). Detects swap thrashing.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --notime)'{-T,--notime}'[do not show the timestamp (HH\:MM\:SS)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
