#compdef wpactl
# Documentation: https://man.archlinux.org/search?q=wpactl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'status:show server, devices, and nodes'
  'info:show information about a node'
  'inspect:dump full object properties'
  'get-volume:get current sink volume'
  'set-volume:set node volume'
  'set-mute:toggle mute on a node'
  'set-default:set the default sink/source'
  'set-profile:set device profile'
  'set-route:set device route'
  'set-log-level:set WirePlumber log level'
  'list:list nodes'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wpctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set-volume|get-volume|set-mute|set-default|set-profile|set-route|info|inspect)
        _arguments \
          '*::node_id_or_name:' && ret=0 ;;
      (set-log-level)
        _arguments \
          '*::level:(off critical error warn message info debug trace)' && ret=0 ;;
    esac ;;
esac

return ret
