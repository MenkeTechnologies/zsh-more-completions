#compdef las2dem
# Documentation: https://github.com/LAStools/LAStools
# LAStools: rasterize a TIN from LAS/LAZ points into a DEM/DSM

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help]' \
  '-version[display version information]' \
  '-gui[launch graphical interface]' \
  '(-v -verbose)'{-v,-verbose}'[enable verbose output]' \
  '-elevation[use elevation as output values (default)]' \
  '-hillshade[apply hillside shading to image]' \
  '-false[false-color based on elevation/intensity]' \
  '(-gray -grey)'{-gray,-grey}'[grayscale coloring]' \
  '-rgb[use RGB values if available]' \
  '-intensity[use intensity values as output]' \
  '-slope[use slope as output parameter]' \
  '-attribute+[use attribute n value for output]:n' \
  '-step+[raster step size (default 1)]:size' \
  '-grid+[raster with specified step size]:size' \
  '-ncols+[maximum number of columns]:n' \
  '-nrows+[maximum number of rows]:n' \
  '-kill+[skip triangles with edges longer than n]:meters' \
  '-ll+[set lower-left raster coordinates x y]:x' \
  '-use_tile_bb[use tile bounding box without buffer]' \
  '-grid_center[align grid origin to cell center]' \
  '-extra_pass[count points before triangulation]' \
  '-last_only[use last returns only]' \
  '-first_only[use first returns only]' \
  '*-keep_class+[keep points of classification n]:code' \
  '*-i+[input file(s)]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-merged[merge multiple input files]' \
  '-o+[output file]:output:_files' \
  '-oasc[output as ASCII]' \
  '-obil[output as BIL]' \
  '-otif[output as GeoTIFF]' \
  '-opng[output as PNG]' \
  '-ojpg[output as JPG]' \
  '-oxyz[output as XYZ text]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
