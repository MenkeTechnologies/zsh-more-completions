#compdef wmcpuload

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --display)'{-d,--display}'+[X display]:display:' \
  '(-g --geometry)'{-g,--geometry}'+[geometry]:geom:' \
  '(-bw --border-width)'{-bw,--border-width}'+[border width]:px:' \
  '(-i --interval)'{-i,--interval}'+[update sec]:sec:' \
  '(-a --alarm)'{-a,--alarm}'+[alarm percent]:pct:' \
  '(-l --led)'{-l,--led}'+[normal led color]:color:' \
  '(-A --alarm-led)'{-A,--alarm-led}'+[alarm led color]:color:' \
  '(-f --frequency)'{-f,--frequency}'[show freq]' \
  '(-n --notify)'{-n,--notify}'+[notify cmd]:cmd:' && ret=0

return ret
