#compdef fmttest
# Documentation: man fmttest(1)
# Source: nmh uip/fmttest.c (master) — test nmh format strings (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-form+[format file]:file:_files' \
    '-format+[format string]:string:_default' \
    '(-address -raw -date -message)-address[treat input as address]' \
    '(-address -raw -date -message)-raw[do not parse input]' \
    '(-address -raw -date -message)-date[treat input as date]' \
    '(-address -raw -date -message)-message[treat input as a message]' \
    '(-file -nofile)-file[read input from file]' \
    '(-file -nofile)-nofile[read input from stdin]' \
    '(-dupaddrs -nodupaddrs)-dupaddrs[allow duplicate addresses]' \
    '(-dupaddrs -nodupaddrs)-nodupaddrs[remove duplicate addresses]' \
    '(-ccme -noccme)-ccme[include local user in cc/to]' \
    '(-ccme -noccme)-noccme[exclude local user from cc/to]' \
    '-outsize+[output size limit]:N:_default' \
    '-width+[output column width]:cols:_default' \
    '-msgnum+[message number]:N:_default' \
    '-msgcur+[current-message flag]:bool:(true false)' \
    '-msgsize+[message size]:N:_default' \
    '-unseen+[unseen flag]:bool:(true false)' \
    '(-dump -nodump)-dump[dump parsed format tree]' \
    '(-dump -nodump)-nodump[do not dump format tree]' \
    '(-trace -notrace)-trace[trace format processing]' \
    '(-trace -notrace)-notrace[no tracing]' \
    '-version[show version]' \
    '-help[show help]' \
    '*:file or text:_files' \
    && ret=0

return ret
