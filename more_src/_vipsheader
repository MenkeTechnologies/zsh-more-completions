#compdef vipsheader
# _vipsheader — print metadata header(s) for image file(s) (libvips/libvips)
# upstream: https://github.com/libvips/libvips
# Flags from tools/vipsheader.c.

_vipsheader() {
    local -a args
    args=(
        '(-a --all)'{-a,--all}'[print all metadata fields, one per line]'
        '(-f --field)'{-f+,--field=}'[print only the named field]:field:'
        '(- *)'{-v,--version}'[show version]'
        '(- *)--help[show help]'
        '*:image file:_files'
    )
    _arguments -s -S $args
}

_vipsheader "$@"
