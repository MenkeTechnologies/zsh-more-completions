#compdef ch-remote
# Documentation: https://www.cloudhypervisor.org/docs/prologue/commands/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Cloud Hypervisor ch-remote client).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'add-device:add a VFIO/virtio device'
  'add-disk:hot-plug a disk'
  'add-fs:hot-plug a virtio-fs device'
  'add-pmem:hot-plug a pmem device'
  'add-net:hot-plug a network device'
  'add-user-device:hot-plug a vfio-user device'
  'add-vdpa:hot-plug a vDPA device'
  'add-vsock:hot-plug a vsock device'
  'remove-device:hot-unplug a device'
  'info:return general VM info'
  'counters:show counters'
  'pause:pause the VM'
  'reboot:reboot the VM'
  'power-button:trigger ACPI power button event'
  'resize:resize CPUs / memory / balloon'
  'resize-zone:resize a memory zone'
  'resume:resume the VM'
  'boot:boot the VM'
  'delete:delete the VM'
  'shutdown:shut down the VM'
  'snapshot:snapshot the VM'
  'restore:restore the VM from a snapshot'
  'coredump:dump the VM core'
  'send-migration:send live migration data'
  'receive-migration:receive live migration data'
  'create:create a VM'
  'ping:ping the VMM'
  'shutdown-vmm:shut down the VMM'
  'help:print help for a subcommand'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--api-socket)--api-socket=[HTTP API UNIX socket (path=... or fd=...)]:socket:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'ch-remote command' subcmds && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
