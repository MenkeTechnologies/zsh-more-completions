#compdef ch-remote
# Documentation: https://man.archlinux.org/search?q=ch-remote
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --api-socket)'{-s,--api-socket=}'[UNIX socket for cloud-hypervisor API]:socket:_files' \
  '1:command:(help resize create vm delete vmm ping shutdown reboot)' \
  '*::args: _default'
