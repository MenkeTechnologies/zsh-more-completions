#compdef mkosi
# Documentation: https://github.com/systemd/mkosi
# Reference accessed: 2026-05-19
# Verified: upstream Verb enum at mkosi/config.py.

# Zsh completion for mkosi - build bespoke OS images

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'build:Build an image'
  'clean:Remove build artifacts'
  'summary:Show a summary of the configuration'
  'cat-config:Concatenate configuration'
  'shell:Boot and open a shell in the image'
  'boot:Boot the image in systemd-nspawn'
  'vm:Boot in a virtual machine'
  'qemu:Start image in QEMU'
  'ssh:SSH into a running image'
  'serve:Serve the output directory via HTTP'
  'bump:Bump version'
  'help:Show help'
  'genkey:Generate secure boot keys'
  'documentation:Show mkosi documentation'
  'journalctl:Show journal from last boot'
  'coredumpctl:Show core dumps'
  'burn:Write image to a block device'
  'dependencies:Show build dependencies'
  'completion:Generate shell completions'
  'sysupdate:Apply system updates'
  'box:Run in a build container'
  'sandbox:Run command in a sandbox'
  'init:Initialize a new configuration'
  'latest-snapshot:Show the latest snapshot'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --force)'{-f,--force}'=[remove existing outputs]:count' \
  '(-C --directory)'{-C,--directory}'=[change to directory before doing anything]:dir:_directories' \
  '--debug[enable debug logging]' \
  '--debug-shell[spawn an interactive shell if a build fails]' \
  '(-d --distribution)'{-d,--distribution}'=[distribution to install]:distro:(arch centos debian fedora opensuse ubuntu)' \
  '(-r --release)'{-r,--release}'=[distribution release]:release' \
  '--mirror=[distribution mirror]:url' \
  '(-t --output-format)'{-t,--output-format}'=[output format]:format:(directory tar cpio disk gpt_ext4 gpt_xfs gpt_btrfs gpt_squashfs plain_squashfs none)' \
  '(-o --output)'{-o,--output}'=[output path]:path:_files' \
  '--output-dir=[output directory]:dir:_directories' \
  '(-p --package)'{-p,--package}'=[add package to install]:package' \
  '--build-package=[add build package]:package' \
  '--with-docs[include documentation]' \
  '--without-tests[exclude test suites]' \
  '--cache-dir=[package cache directory]:dir:_directories' \
  '--extra-tree=[overlay a directory on top of the OS tree]:dir:_directories' \
  '--skeleton-tree=[use a directory as a skeleton tree]:dir:_directories' \
  '--build-script=[build script]:file:_files' \
  '--prepare-script=[prepare script]:file:_files' \
  '--postinst-script=[post install script]:file:_files' \
  '--finalize-script=[finalize script]:file:_files' \
  '--source-file-transfer=[how to transfer sources to build image]:method:(copy-git-others copy-git-cached mount-bind)' \
  '--bootable=[make the image bootable]:choice:(auto yes no)' \
  '--boot-protocols=[boot protocols to use]:protocols:(bios uefi)' \
  '--kernel-command-line=[set kernel command line]:cmdline' \
  '--secure-boot[sign for secure boot]' \
  '--secure-boot-key=[secure boot key]:file:_files' \
  '--secure-boot-certificate=[secure boot certificate]:file:_files' \
  '--image-id=[set image identifier]:id' \
  '--image-version=[set image version]:version' \
  '--hostname=[set hostname]:hostname' \
  '--root-size=[set root partition size]:size' \
  '--root-password=[set root password]:password' \
  '--autologin[enable root autologin]' \
  '--with-network[enable network during build]' \
  '--settings=[read mkosi settings from]:file:_files' \
  '--profile=[configuration profile]:profile' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'mkosi command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      burn)
        _arguments '1:device:_files -g "*(%%)"' && ret=0
        ;;
      qemu)
        _arguments \
          '--qemu-smp=[number of CPUs]:cpus' \
          '--qemu-mem=[memory]:memory' \
          '--qemu-kvm=[enable KVM]:choice:(auto yes no)' && ret=0
        ;;
      clean)
        _arguments '--all[remove all artifacts]' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
