#compdef link-parser
# Documentation: https://www.mankier.com/1/link-parser
# Parse natural language sentences using Link Grammar

local ret=1

_arguments -s -S \
  '-batch[process input in batch mode]' \
  '-echo[echo input sentence]' \
  '-graphics[enable graphical display of linkage]' \
  '-postscript[generate postscript output]' \
  '-constituents[generate constituent output]:level:(0 1 2 3)' \
  '-links[enable display of complete link data]' \
  '-walls[display wall words]' \
  '-verbosity[level of detail in output]:level' \
  '-limit[limit the maximum linkages processed]:n' \
  '-timeout[abort parsing after this many seconds]:secs' \
  '-panic[use panic mode if a parse cannot be quickly found]' \
  '-spell[control spell and run-on corrections of unknown words]:n' \
  '-version[print program version and configuration details and exit]' \
  '*:language or dictionary:' && ret=0

return ret
