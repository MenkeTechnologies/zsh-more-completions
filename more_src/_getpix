#compdef getpix
# _getpix — extract pixel values from a FITS image (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from getpix.c (single-letter getopt-style).

_getpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-d+[decimal places]:n:' \
        '-e[print range of values]' \
        '-g+[keep pixels greater than]:val:' \
        '-h[print filename above values]' \
        '-i[identifier precedes x y]' \
        '-l+[keep pixels less than]:val:' \
        '-m[print mean and sigma]' \
        '-n+[pixels per line]:n:' \
        '-o+[output pixel format (printf)]:fmt:' \
        '-p[label pixels]' \
        '-r+[box radius (arcsec)]:arcsec:' \
        '-s[print x y value without punctuation]' \
        '-t[separate pixels with tabs]' \
        '-y[display by column instead of line]' \
        '-x+[FITS extension to read]:ext:' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y or list file:_files'
}

_getpix "$@"
