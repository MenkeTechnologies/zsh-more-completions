#compdef raid-monitor
# Documentation: https://man.archlinux.org/search?q=raid-monitor
# Reference accessed: 2026-05-16

# raid-monitor: distro-shipped md-raid status emailer (wrapper around mdadm --monitor)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '*::raid-monitor args:_files' && ret=0
return ret
