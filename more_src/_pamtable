#compdef pamtable
# Documentation: man pamtable (Netpbm)
# Source: Netpbm pamtable — print the raster as a table of numerical sample values.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-tuple[group samples by tuple (one tuple per line)]' \
    '-hex[print samples in hexadecimal]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
