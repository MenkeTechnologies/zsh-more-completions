#compdef abc2abc
# Documentation: https://manpages.debian.org/testing/abcmidi/abc2abc.1.en.html
# read an abc file and write a transposed or otherwise reformatted abc file

local ret=1

_arguments -s -S \
  '-s[rework note spacing/beaming]' \
  '-n+[reformat with line breaks every X bars]:bars' \
  '-b[do not do bar checking]' \
  '-r[do not do repeat checking]' \
  '-e[do not report errors]' \
  '-t+[transpose tune by n semitones]:semitones' \
  '-nda[convert double accidentals in guitar chords]' \
  '-u[update old chord and slur notation to modern syntax]' \
  '-OCC[accept the old notation for chords]' \
  '-d[re-notate with all note lengths doubled]' \
  '-v[re-notate with all note lengths halved]' \
  '-ver[print version number and exit]' \
  '-V+[copy only the specified voices]:voices' \
  '-P+[modify only the specified voices]:voices' \
  '-X+[renumber X: reference numbers sequentially from n]:start' \
  '-xref+[process only the tune with X\: n]:xref' \
  '-nokeys[assume no key signature, use sharps and naturals]' \
  '-nokeyf[assume no key signature, use flats and naturals]' \
  '-usekey+[force output in specified key signature (-5 to +5)]:sf' \
  '-useclef[honour clef in K: field with transpose]' \
  '*:abc file:_files -g "*.abc"' && ret=0

return ret
