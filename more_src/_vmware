#compdef vmware
# Documentation: https://techdocs.broadcom.com/us/en/vmware-cis/desktop-hypervisors/workstation-pro/17-0/using-vmware-workstation-pro/using-the-vmware-command/run-the-vmware-command/vmware-command-options.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-X[fullscreen]' \
  '-q[quiet]' \
  '-T+[take screenshot]:file:_files' \
  '-x+[start vm]:vm:' \
  '*:vmx file:_files -g "*.vmx"' && ret=0

return ret
