#compdef vmware

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-X[fullscreen]' \
  '-q[quiet]' \
  '-T+[take screenshot]:file:_files' \
  '-x+[start vm]:vm:' \
  '*:vmx file:_files -g "*.vmx"' && ret=0

return ret
