#compdef nginxctl
# _nginxctl — nginxctl CLI command-line frontend wrapper around the NGINX webserver-reverse-proxy supporting start stop reload reopen-logs upgrade-binary configtest enable disable site-link sites-available sites-enabled status nginx-process management for the de-facto Linux distribution-included NGINX deployment workflow (nginxctl authors team, shell); getopt
# upstream: https://github.com/nginxinc/nginxctl

_nginxctl() {
    local -a sub=(
        'start:start nginx'
        'stop:stop nginx'
        'restart:restart nginx'
        'reload:reload config'
        'reopen:reopen logs'
        'upgrade:upgrade binary'
        'configtest:test configuration'
        'status:show status'
        'enable:enable a site'
        'disable:disable a site'
        'sites:list available sites'
        'check:check installation'
        'install:install nginx'
        'uninstall:uninstall nginx'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "nginx.conf *.conf"' \
        '--config=+[file]:file:_files -g "nginx.conf *.conf"' \
        '-p+[prefix]:dir:_files -/' \
        '--prefix=+[dir]:dir:_files -/' \
        '-g+[directive]:str:' \
        '--global=+[directive]:str:' \
        '-e+[error log]:file:_files' \
        '--error-log=+[file]:file:_files' \
        '--sites-available=+[dir]:dir:_files -/' \
        '--sites-enabled=+[dir]:dir:_files -/' \
        '--user=+[user]:_users' \
        '--pid=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nginxctl subcommand' sub ;;
        args)
            case $words[1] in
                enable|disable) _arguments '*:site:_files' ;;
            esac
            ;;
    esac
}

_nginxctl "$@"
