#compdef sucvs4fowler
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stacking/sucvs4fowler.c
# compute constant velocity stacks for input to Fowler codes

local ret=1

_arguments -s -S \
  'ncdps=[number of input cdp gathers]:ncdps' \
  'vminstack=[minimum velocity panel in m/s to output]:vminstack' \
  'nvstack=[number of stacking velocity panels to compute]:nvstack' \
  'lmute=[length of mute taper in ms]:lmute' \
  'nonhyp=[1 mute at 2*offset/vhyp to avoid non-hyperbolic moveout, 0 otherwise]:nonhyp:(0 1)' \
  'vhyp=[velocity for non-hyperbolic moveout mute]:vhyp' \
  'lbtaper=[length of bottom taper in ms]:lbtaper' \
  'lstaper=[length of side taper in traces]:lstaper' \
  'dtout=[output sample rate in s]:dtout' \
  'mxfold=[maximum number of offsets per input cmp]:mxfold' \
  'salias=[fraction of output frequencies within sloth antialias limit]:salias' \
  '*:file:_files' && ret=0

return ret
