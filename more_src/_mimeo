#compdef mimeo
# Documentation: https://xyne.dev/projects/mimeo/
# XDG file association tool

_arguments -s -S \
  '-m[display MIME type of file]' \
  '-d[display desktop file for MIME type]' \
  '-M[display MIME associations]' \
  '--add[add MIME association]:association:' \
  '--remove[remove MIME association]:association:' \
  '--prefer[set preferred application]:application:' \
  '--update[update desktop database]' \
  '--help[show help]' \
  '*:file:_files' \
  && return 0
