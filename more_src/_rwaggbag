#compdef rwaggbag rwaggbagbuild rwaggbagcat rwaggbagtool
# Documentation: https://tools.netsa.cert.org/silk/rwaggbag{,build,cat,tool}.html
# Reference accessed: 2026-05-30
# SiLK Round 4 — companion to rounds 135 (_rwfilter, 8 stems), 136
# (_rwsetbuild, 9 stems), and 137 (_rwipfix2silk, 9 stems). The Aggregate
# Bag family — multi-key/multi-counter binned aggregation, distinct from
# the single-key/single-counter Bag covered in round 136.

local curcontext="$curcontext" state line ret=1

# Shared metadata flags appearing in every tool.
local -a _meta
_meta=(
  '*--note-add=[annotation for header]:text:'
  '*--note-file-add=[annotation file]:file:_files'
  '--invocation-strip[omit command line from header]'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '--site-config-file=[SiLK site config]:file:_files'
  '(- *)--help[show help]'
  '(- *)--version[show version]'
)

case $service in

  rwaggbag)
    _arguments -s -S \
      $_meta \
      '--keys=[key fields for binning]:fields:' \
      '--counters=[counter fields for aggregation]:fields:' \
      '--output-path=[output aggregate bag]:path:_files' \
      '--copy-input=[duplicate input flows here]:path:_files' \
      '--note-strip[omit input annotations from output]' \
      '*--xargs=-[read filenames from FILE]:file:_files' \
      '--print-filenames[show input filenames on stderr]' \
      '--ipv6-policy=[IPv4/IPv6 handling]:policy:(ignore asv4 mix force only)' \
      '(- *)--help-fields[show field descriptions]' \
      '*:SiLK flow file:_files' \
      && ret=0
    ;;

  rwaggbagbuild)
    _arguments -s -S \
      $_meta \
      '--fields=[key + counter field list]:fields:' \
      '*--constant-field=[insert/replace constant field]:spec:' \
      '--column-separator=[field delimiter (default |)]:char:' \
      '--no-titles[treat first line as data]' \
      '--bad-input-lines=[capture unparseable lines]:file:_files' \
      '--verbose[report parse errors]' \
      '--stop-on-error[exit on first parse error]' \
      '--output-path=[output aggregate bag]:path:_files' \
      '*--xargs=-[read filenames from FILE]:file:_files' \
      '(- *)--help-fields[show field descriptions]' \
      '*:text input file:_files' \
      && ret=0
    ;;

  rwaggbagcat)
    _arguments -s -S \
      $_meta \
      '--fields=[output column order/selection]:fields:' \
      '*--missing-field=[placeholder for missing FIELD=STRING]:spec:' \
      '--output-path=[output path]:path:_files' \
      '--pager=[pager program]:program:_command_names -e' \
      '--timestamp-format=[time display format]:fmt:' \
      '--ip-format=[IP display]:fmt:(canonical no-mixed decimal hexadecimal zero-padded map-v4 unmap-v6 force-ipv6)' \
      '--no-titles[suppress column headers]' \
      '--no-columns[disable fixed-width columns]' \
      '--column-separator=[column delimiter]:char:' \
      '--no-final-delimiter[omit trailing separator]' \
      '--delimited=-[pipe-delimited (custom char)]:char:' \
      '--integer-sensors[show sensor IDs not names]' \
      '--integer-tcp-flags[show flags as integers]' \
      '(- *)--help-fields[show field descriptions]' \
      '*:aggregate bag file:_files' \
      && ret=0
    ;;

  rwaggbagtool)
    _arguments -s -S \
      $_meta \
      '(--remove-fields --select-fields)--remove-fields=[drop these fields]:fields:' \
      '(--remove-fields --select-fields)--select-fields=[keep only these fields]:fields:' \
      '*--insert-field=[add FIELD=VALUE]:spec:' \
      '(--add --subtract --divide)--add[sum counters across files (default)]' \
      '(--add --subtract --divide)--subtract[first file minus subsequent]' \
      '(--add --subtract --divide)--divide[first divided by subsequent]' \
      '--zero-divisor-result=[divide-by-zero handling]:result:(error remove nochange maximum)' \
      '*--scalar-multiply=[multiply counters by N or FIELD=N]:spec:' \
      '*--min-field=[drop entries below FIELD=VALUE]:spec:' \
      '*--max-field=[drop entries above FIELD=VALUE]:spec:' \
      '*--set-intersect=[keep IPs in FIELD=SETFILE]:spec:' \
      '*--set-complement=[remove IPs in FIELD=SETFILE]:spec:' \
      '(--to-bag --to-ipset)--to-bag=[convert to Bag BAG_KEY,BAG_COUNTER]:spec:' \
      '(--to-bag --to-ipset)--to-ipset=[convert to IPset on FIELD]:field:' \
      '--ipset-record-version=[IPset record version]:version:(0 2 3 4 5)' \
      '--output-path=[output file]:path:_files' \
      '--modify-inplace[safely overwrite input file]' \
      '--backup-path=[backup before overwrite]:file:_files' \
      '--note-strip[omit input annotations from output]' \
      '(- *)--help-fields[show field descriptions]' \
      '*:aggregate bag file:_files' \
      && ret=0
    ;;

esac

return ret
