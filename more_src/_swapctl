#compdef swapctl swapon
# _swapctl — OpenBSD swapctl (manage swap devices/files; -A enables all entries in /etc/fstab, -a adds one path, -c reprioritises, -d removes, -l/-s list, -t filters block/noblock, -p sets priority)
# upstream: https://github.com/openbsd/src (sbin/swapctl)
# Flags from sbin/swapctl/swapctl.8 on tip (also covers swapon binary alias).

_swapctl() {
    _arguments \
        '-A[add all swap entries from fstab]' \
        '-a[add this device/file]' \
        '-c[change priority]' \
        '-d[disable this device/file]' \
        '-k[show in 1k blocks]' \
        '-l[list]' \
        '-s[summary]' \
        '-p+[priority]:priority:' \
        '-t+[type filter]:type:(blk noblk)' \
        '*:path:_files'
}

_swapctl "$@"
