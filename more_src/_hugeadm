#compdef hugeadm
# Hugepage administration

local ret=1

_arguments -s -S \
  '--pool-pages-min=[set minimum pool pages]:size\:count:' \
  '--pool-pages-max=[set maximum pool pages]:size\:count:' \
  '--set-recommended-min_free_kbytes[set recommended min_free_kbytes]' \
  '--set-recommended-shmmax[set recommended shmmax]' \
  '--set-shm-group=[set group for hugepage shm]:group:_groups' \
  '--create-mount=[create mount point]:mount point:_files -/' \
  '--create-user-mounts=[create per-user mount points]:user:_users' \
  '--create-group-mounts=[create per-group mount points]:group:_groups' \
  '--create-global-mounts[create global mount points]' \
  '--page-sizes[show supported page sizes]' \
  '--page-sizes-all[show all page sizes]' \
  '--list-all-mounts[list all hugepage mounts]' \
  '--pool-list[list pool information]' \
  '--explain[explain current configuration]' \
  '--verbose[verbose output]' \
  '-v[verbose output]' \
  '--help[show help]' && ret=0

return ret
