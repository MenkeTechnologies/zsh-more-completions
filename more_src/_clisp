#compdef clisp
# Documentation: clisp --help (GNU CLISP 2.49.92)
# Source: ANSI Common Lisp implementation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(- *)--license[show license]' \
    '(- *)-help-image[print image-specific help]' \
    '-B+[CLISP install directory]:lisplibdir:_files -/' \
    '-K+[linking set]:name:' \
    '-M+[memory image file]:memfile:_files' \
    '-m+[memory size (nB/nKB/nMB)]:size:' \
    '-L+[language]:language:' \
    '-N+[NLS catalog directory]:nlsdir:_files -/' \
    '-Edomain+[encoding for domain]:domain encoding:' \
    '(-q --quiet --silent -v --verbose)'{-q,--quiet,--silent,-v,--verbose}'[verbosity]' \
    '-w[wait for keypress on exit]' \
    '-I[ILISP-friendly mode]' \
    '-disable-readline[do not use GNU readline]' \
    '(-ansi -traditional -modern)-ansi[more ANSI CL compliance]' \
    '(-ansi -traditional -modern)-traditional[undoes -ansi]' \
    '(-ansi -traditional -modern)-modern[case-sensitive lowercase-preferring package]' \
    '-p+[start in package]:package:' \
    '-C[set *LOAD-COMPILING* to T]' \
    '-norc[do not load ~/.clisprc]' \
    '*-lp+[add directory to *LOAD-PATHS*]:dir:_files -/' \
    '*-i+[load init file]:file:_files' \
    '-c[compile mode]' \
    '-l[list mode (with -c)]' \
    '-o+[output file (with -c)]:file:_files' \
    '-x+[execute expressions, then exit]:expressions:' \
    '*:lisp source file:_files -g "*.(lisp|lsp|cl|asd)"' \
    && ret=0

return ret
