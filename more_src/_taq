#compdef taq
# Documentation: https://taqueria.io/docs/intro/
# Source: TezosTaqueria/taqueria — Tezos developer task runner.
# Reference accessed: 2026-06-01
# Per-project plugins add additional tasks; baseline tasks listed below.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _taq_cmds
_taq_cmds=(
    'init:initialize a new Taqueria project'
    'install:install a plugin (taq install <pluginName>)'
    'uninstall:remove a plugin'
    'compile:compile contracts (LIGO/SmartPy/Archetype)'
    'originate:deploy contracts via the Taquito plugin'
    'test:run automated tests via Jest plugin'
    'dev:start local development environment'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'taq command' _taq_cmds && ret=0
        ;;
    args)
        case $line[1] in
            install|uninstall)
                _arguments -s -S '*:plugin name:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
