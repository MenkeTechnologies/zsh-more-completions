#compdef topiary

local curcontext="$curcontext" state line ret=1

_topiary_commands() {
  local -a commands=(
    'format:format files'
    'visualise:visualise parsed tree-sitter output'
    'config:print the current configuration'
    'prefetch:prefetch all grammars'
    'completion:generate shell completions'
  )
  _describe -t commands 'topiary command' commands
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--configuration=[configuration file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '1: :_topiary_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      format)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '(-l --language)'{-l,--language}'=[language override]:language' \
          '(-q --query)'{-q,--query}'=[query file]:file:_files' \
          '--skip-idempotence[skip idempotence check]' \
          '--tolerate-parsing-errors[tolerate parsing errors]' \
          '*:input file:_files'
        ;;
      visualise)
        _arguments \
          '(- *)'{-h,--help}'[show help]' \
          '(-l --language)'{-l,--language}'=[language override]:language' \
          '(-q --query)'{-q,--query}'=[query file]:file:_files' \
          '--output-format=[output format]:format:(dot json)' \
          '*:input file:_files'
        ;;
    esac
    ;;
esac

return ret
