#compdef zenon
# Documentation: https://www.mankier.com/1/zenon
# Automated theorem prover for first-order classical logic

local ret=1

_arguments -s -S \
  '(-help --help)'{-help,--help}'[print this option list and exit]' \
  '-context[provide context for checking the proof independently]' \
  '-d[debug mode]' \
  '-errmsg+[prefix warnings and errors with message]:message:' \
  '-I+[add dir to the include path (TPTP input format)]:dir:_files -/' \
  '-icoq[read input file in Coq format]' \
  '-ifocal[read input file in Focal format]' \
  '-itptp[read input file in TPTP format]' \
  '-iz[read input file in Zenon format (default)]' \
  '-loadpath+[path to Zenon coq libraries]:dir:_files -/' \
  '-max+[set size, step, and time limits]:limits:' \
  '-max-size+[limit heap size (default 100M)]:size:' \
  '-max-step+[limit number of steps (default 10k)]:steps:' \
  '-max-time+[limit CPU time (default 5m)]:time:' \
  '-ocoq[print the proof in Coq script format]' \
  '-ocoqterm[print the proof in Coq term format]' \
  '-oh+[print the proof in high-level format up to depth]:depth:' \
  '-ol[print the proof in low-level format]' \
  '-olx[print the proof in raw low-level format]' \
  '-om[print the proof in middle-level format]' \
  '-onone[do not print the proof (default)]' \
  '-opt0[do not optimise the proof]' \
  '-opt1[do peephole optimisation of the proof (default)]' \
  '-p0[turn off progress bar and progress messages]' \
  '-p1[display progress bar (default)]' \
  '-p2[display progress messages]' \
  '-q[suppress proof-found/no-proof/begin-proof/end-proof]' \
  '-rename[prefix all input symbols to avoid clashes]' \
  '-rnd+[randomize proof search]:seed:' \
  '-stats[print statistics]' \
  '-short[output a less detailed proof]' \
  '-v[print version string and exit]' \
  '-versions[print CVS version strings and exit]' \
  '-w[suppress warnings]' \
  '-where[print the location of the zenon library and exit]' \
  '-wout+[output errors and warnings to file]:file:_files' \
  '-x+[activate extension]:extension:' \
  '*:input file:_files' && ret=0

return ret
