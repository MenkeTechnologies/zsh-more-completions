#compdef risingwave

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'compute:run a compute node'
  'compute-node:run a compute node'
  'meta:run a meta node'
  'meta-node:run a meta node'
  'frontend:run a frontend node'
  'frontend-node:run a frontend node'
  'compactor:run a compactor node'
  'compactor-node:run a compactor node'
  'ctl:run risectl admin tool'
  'risectl:run risectl admin tool'
  'playground:run all components in one process for dev'
  'play:run all components in one process for dev'
  'standalone:run all server components in one process'
  'single-node:all-in-one single-node mode'
  'single:all-in-one single-node mode'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'risingwave subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (compute|compute-node|meta|meta-node|frontend|frontend-node|compactor|compactor-node|standalone|single-node|single|playground|play)
        _arguments \
          '--listen-addr=[listen address]:addr:' \
          '--advertise-addr=[advertise address]:addr:' \
          '--prometheus-listener-addr=[Prometheus listener address]:addr:' \
          '--meta-address=[meta node address]:addr:' \
          '--config-path=[config file path]:file:_files' \
          '--metrics-level=[metrics verbosity]:level:(info debug trace)' \
          '--state-store=[state store backend]:backend:' \
          '--data-directory=[data directory]:dir:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
