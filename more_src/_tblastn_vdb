#compdef tblastn_vdb
# BLAST+ tool to search a protein query against translated SRA/WGS runs (no prebuilt db)
# Flags from NCBI BLAST+ Command Line Applications User Manual (NBK279684); -db takes SRA accessions

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-query=[query file name]:file:_files' \
  '-query_loc=[location on the query sequence (start-stop)]:range:' \
  '-db=[comma-separated list of SRA accessions to search]:accessions:' \
  '-out=[output file name]:file:_files' \
  '-evalue=[expect value threshold for saving hits]:float:' \
  '-word_size=[word size for the lookup table]:int:' \
  '-matrix=[scoring matrix name]:matrix:(BLOSUM45 BLOSUM50 BLOSUM62 BLOSUM80 BLOSUM90 PAM30 PAM70 PAM250)' \
  '-threshold=[neighboring word score threshold]:float:' \
  '-db_gencode=[genetic code for translating the database]:code:' \
  '-outfmt=[alignment view / output format]:format:' \
  '-num_descriptions=[number of one-line descriptions to show]:int:' \
  '-num_alignments=[number of database sequences to show alignments for]:int:' \
  '-max_target_seqs=[number of aligned sequences to keep]:int:' \
  '-num_threads=[number of threads (CPUs) to use]:int:' \
  '-seg=[filter query with SEG]:seg:' \
  '-comp_based_stats=[composition-based statistics mode]:mode:(0 1 2 3 D F)' \
  '-lcase_masking[use lower-case masking in query and subject]' \
  '-parse_deflines[parse query and subject bar-delimited sequence identifiers]' \
  '-html[produce HTML output]' \
  '-show_gis[show NCBI GIs in report]' && ret=0

return ret
