#compdef appimaged
# Documentation: https://github.com/probonopd/go-appimage/tree/master/src/appimaged
# Documentation: https://github.com/probonopd/go-appimage/blob/master/src/appimaged/appimaged.go
# Documentation: https://github.com/probonopd/go-appimage/blob/master/src/appimaged/commands.go
# Reference accessed: 2026-05-27
# Verified: upstream appimaged.go flag.Bool definitions and commands.go subcommand switch

# Zsh completion for appimaged (AppImage daemon from probonopd/go-appimage).

local curcontext="$curcontext" state line ret=1

local -a _appimaged_subcommands
_appimaged_subcommands=(
  'wrap:execute an executable and send desktop notifications for any errors'
  'update:update the AppImage using the most recent AppImageUpdate registered'
  'run:run the most recent AppImage registered for the given updateinformation'
  'start:start the most recent AppImage for the updateinformation and exit immediately'
)

_arguments -C \
  '-v[print verbose log messages]' \
  '-o[overwrite existing desktop integration files (slower)]' \
  '-c[clean pre-existing desktop files]' \
  '-q[do not send desktop notifications]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'appimaged subcommand' _appimaged_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      wrap)
        _arguments '*:executable:_files' && ret=0
        ;;
      update)
        _arguments '*:AppImage:_files -g "*.AppImage(-.)"' && ret=0
        ;;
      run|start)
        _arguments \
          '1:updateinformation:' \
          '*:arg:_files' && ret=0
        ;;
      *)
        _arguments '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
