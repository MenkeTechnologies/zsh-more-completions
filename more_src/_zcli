#compdef zcli

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apps:manage Zendesk apps workflow'
  'themes:manage Zendesk themes workflow'
  'connectors:manage Zendesk connectors workflow'
  'profiles:manage zcli profiles'
  'login:login to a Zendesk account'
  'logout:logout and remove active profile'
  'autocomplete:show shell autocomplete instructions'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[active zcli profile]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zcli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apps)
        local -a app_subs=(
          'new:scaffold a new app'
          'create:create the app on the server'
          'install:install the app to a Zendesk subdomain'
          'update:update an installed app'
          'validate:validate the app'
          'package:package the app into a zip'
          'list:list installed apps'
          'server:run a local app server'
          'theme:legacy themes alias'
        )
        _describe -t acmds 'apps subcommand' app_subs && ret=0
        _arguments \
          '(-d --directory)'{-d+,--directory=}'[app directory]:dir:_files -/' \
          '(-p --port)'{-p+,--port=}'[server port]:port:' \
          '--bind=[bind address]:address:' \
          '--app-id=[installed app id]:id:' && ret=0 ;;
      (themes)
        local -a theme_subs=(
          'new:scaffold a new theme'
          'preview:preview a theme on a subdomain'
          'package:package theme into a zip'
          'publish:publish a theme'
          'validate:validate a theme'
        )
        _describe -t tcmds 'themes subcommand' theme_subs && ret=0
        _arguments \
          '(-d --directory)'{-d+,--directory=}'[theme directory]:dir:_files -/' \
          '--theme-id=[theme id]:id:' && ret=0 ;;
      (profiles)
        _arguments '*::sub:(add list remove use show)' && ret=0 ;;
      (login)
        _arguments \
          '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
          '(-s --subdomain)'{-s+,--subdomain=}'[Zendesk subdomain]:subdomain:' \
          '(-e --email)'{-e+,--email=}'[user email]:email:' \
          '(-p --password)'{-p+,--password=}'[password]:password:' \
          '(-t --token)'{-t+,--token=}'[API token]:token:' && ret=0 ;;
      (autocomplete)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
