#compdef apachetop

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '*-f+[Apache log file]:file:_files' \
  '-H+[number of hits to remember]:n:' \
  '-T+[seconds of hits to remember]:secs:' \
  '-q[parse log only once and exit]' \
  '-l[lowercase URLs before processing]' \
  '-s+[number of URL path segments]:n:' \
  '-p[preserve URL query strings]' \
  '-r+[refresh interval seconds]:secs:' \
  '-d+[max URLs to display]:n:' \
  '-S+[max sort key entries]:n:' \
  '*:log file:_files' && ret=0

return ret
