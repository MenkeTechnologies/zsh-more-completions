#compdef smokeping_prober
# _smokeping_prober — Prometheus smokeping-style ICMP latency exporter (multi-host ping prober emitting histogram metrics)
# upstream: https://github.com/SuperQ/smokeping_prober
# Flags from main.go on tip + kingpinflag/web (--web.listen-address, --web.systemd-socket, --web.config.file) + promslog (--log.level, --log.format).

_smokeping_prober() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--config.file=[optional YAML config]:file:_files' \
        '--web.telemetry-path=[path under which to expose metrics]:path:' \
        '--buckets=[comma-delimited histogram bucket list]:list:' \
        '(-i --ping.interval)'{-i+,--ping.interval=}'[ping interval]:dur:' \
        '--privileged=[use privileged ICMP mode]:bool:(true false)' \
        '(-s --ping.size)'{-s+,--ping.size=}'[ping packet size in bytes]:n:' \
        '(-O --ping.tos)'{-O+,--ping.tos=}'[ping packet IP ToS field]:hex:' \
        '*--web.listen-address=[listen address (repeatable for systemd socket activation)]:addr:' \
        '--web.systemd-socket[use systemd socket activation listener]' \
        '--web.config.file=[TLS/auth config file]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)' \
        '*:hostname:_hosts'
}

_smokeping_prober "$@"
