#compdef cpuid

# Zsh completion for cpuid (display x86 CPU information)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[display information for only one CPU]' \
  '-f[read raw CPUID data from file]:input file:_files' \
  '-d[use specified CPUID data file format]:format' \
  '-i[use kernel CPUID driver interface]' \
  '-r[display raw CPUID data]' \
  '-c[display CPU number for each CPU]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '--inst[use CPUID instruction directly]' \
  '--dump[dump raw hex CPUID data]' && ret=0

return ret
