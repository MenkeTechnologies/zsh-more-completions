#compdef xcp

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-r --recursive)'{-r,--recursive}'[copy directories recursively]' \
  '--reflink=[control reflink/CoW copies]:when:(auto always never)' \
  '(-n --no-clobber)'{-n,--no-clobber}'[do not overwrite existing files]' \
  '-v[verbose output]' \
  '--glob[use glob patterns for source]' \
  '--no-progress[disable progress bar]' \
  '--workers=[number of parallel workers]:number' \
  '--block-size=[block size for copies]:size' \
  '*:file or directory:_files'
