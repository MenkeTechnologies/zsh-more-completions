#compdef amplify
# _amplify-bin — AWS Amplify CLI (Amazon Web Services, Node.js); add/manage cloud features for mobile + web apps
# upstream: https://github.com/aws-amplify/amplify-cli

_amplify-bin() {
    local -a sub=(
        'add:add a cloud resource'
        'auth:auth commands'
        'build:build the project'
        'configure:configure resources'
        'console:open console'
        'codegen:generate code from API'
        'delete:delete env'
        'diagnose:report diagnostics'
        'env:env commands'
        'export:export resources'
        'fix:fix conflicts'
        'function:functions'
        'help:show help'
        'import:import existing resources'
        'init:initialize project'
        'login:login'
        'logout:logout'
        'mock:run mock locally'
        'override:override generated cloud resources'
        'plugin:plugin commands'
        'predictions:predictions resources'
        'publish:publish hosting'
        'pull:pull from cloud'
        'push:push to cloud'
        'remove:remove resource'
        'restapi:REST APIs'
        'serve:serve frontend'
        'status:show status'
        'storage:storage resources'
        'update:update resources'
        'version:show version'
        'webhook:webhook'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug]' \
        '--yes[yes to all]' \
        '-y[yes to all]' \
        '--profile+[AWS profile]:profile:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'amplify subcommand' sub ;;
    esac
}

_amplify-bin "$@"
