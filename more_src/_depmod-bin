#compdef depmod
# _depmod-bin — generate modules.dep + map files (kmod); scan kernel module tree and rebuild dependency database
# upstream: https://github.com/kmod-project/kmod

_depmod-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[all modules (default)]' \
        '(-A --quick)'{-A,--quick}'[only changed modules]' \
        '(-b --basedir)'{-b,--basedir}'+[base dir]:dir:_files -/' \
        '(-C --config)'{-C,--config}'+[config file or dir]:file:_files' \
        '(-e --errsyms)'{-e,--errsyms}'[print unresolved symbols]' \
        '(-F --filesyms)'{-F,--filesyms}'+[System.map file]:file:_files' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-n --show)'{-n,--show}'[print to stdout instead of writing]' \
        '(-P --symbol-prefix)'{-P,--symbol-prefix}'+[symbol prefix]:str:' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-w --warn)'{-w,--warn}'[warn on dup symbols]' \
        '*:kernel version:'
}

_depmod-bin "$@"
