#compdef wiredoor
# Documentation: https://github.com/wiredoor/wiredoor-cli
# wiredoor - WireGuard-based ingress to expose local services

local ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(login connect config http tcp status enable disable disconnect)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      login)
        _arguments -s '--url=[wiredoor instance url]:url:' && ret=0
        ;;
      connect)
        _arguments -s \
          '--url=[wiredoor instance url]:url:' \
          '--token=[authentication token]:token:' && ret=0
        ;;
      config)
        _arguments -s \
          '--url=[wiredoor instance url]:url:' \
          '--token=[authentication token]:token:' && ret=0
        ;;
      http)
        _arguments -s \
          '--domain=[public domain]:domain:' \
          '--port=[local port]:port:' \
          '--path=[url path]:path:' \
          '--proto=[backend protocol]:proto:' \
          '--backendHost=[backend host]:host:' \
          '--allow=[allow CIDR]:cidr:' \
          '--block=[block CIDR]:cidr:' \
          '*:service:' && ret=0
        ;;
      tcp)
        _arguments -s \
          '--port=[local port]:port:' \
          '--proto=[protocol]:proto:(tcp udp)' \
          '--ssl[enable SSL termination]' \
          '--backendHost=[backend host]:host:' \
          '--allow=[allow CIDR]:cidr:' \
          '--block=[block CIDR]:cidr:' \
          '*:service:' && ret=0
        ;;
      status)
        _arguments -s \
          '--health[show health status]' \
          '--watch[continuously watch status]' \
          '--interval=[refresh interval]:interval:' && ret=0
        ;;
      enable|disable)
        _arguments -s \
          '1:type:(http tcp)' \
          '*:service:' && ret=0
        ;;
    esac
    ;;
esac

return ret
