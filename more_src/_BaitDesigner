#compdef BaitDesigner
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#BaitDesigner
# Picard: design oligonucleotide baits for hybrid selection reactions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  '--TARGETS=[file with design parameters and targets]:file:_files' \
  '--DESIGN_NAME=[name of the bait design]:name:' \
  '--REFERENCE_SEQUENCE=[reference sequence fasta file]:fasta:_files -g "*.(fa|fasta)"' \
  '--LEFT_PRIMER=[amplification primer prepended to all baits]:seq:' \
  '--RIGHT_PRIMER=[amplification primer appended to all baits]:seq:' \
  '--DESIGN_STRATEGY=[approach for laying out baits]:strategy:(CenteredConstrained FixedOffset Simple)' \
  '--BAIT_SIZE=[length of each individual bait]:int:' \
  '--MINIMUM_BAITS_PER_TARGET=[minimum bait count per target]:int:' \
  '--BAIT_OFFSET=[distance between sequential bait start positions]:int:' \
  '--PADDING=[pad input targets by this amount when designing baits]:int:' \
  '--REPEAT_TOLERANCE=[maximum masked bases allowed per bait]:int:' \
  '--POOL_SIZE=[synthesis pool size (0 to disable)]:int:' \
  '--FILL_POOLS=[fill pools with alternating forward and reverse copies]:bool:(true false)' \
  '--DESIGN_ON_TARGET_STRAND=[design baits on the target strand]:bool:(true false)' \
  '--MERGE_NEARBY_TARGETS=[merge targets close enough for efficient design]:bool:(true false)' \
  '--OUTPUT_AGILENT_FILES=[output Agilent design files per pool]:bool:(true false)' \
  '--OUTPUT_DIRECTORY=[directory for output files]:dir:_files -/' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:argument:_files' && ret=0

return ret
