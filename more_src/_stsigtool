#compdef stsigtool
# _stsigtool — Syncthing signature key + verify tool (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Subcommands from cmd/dev/stsigtool/main.go.

_stsigtool() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)-h[show help]' \
        '1: :_stsigtool_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                sign)
                    _arguments \
                        '1:private key file:_files -g "*.pem"' \
                        '2:file to sign:_files'
                    ;;
                verify)
                    _arguments \
                        '1:signature file:_files -g "*.sig"' \
                        '2:file to verify:_files' \
                        '3:public key file (optional):_files -g "*.pem"'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_stsigtool_commands] )) ||
_stsigtool_commands() {
    local -a commands
    commands=(
        'gen:generate a fresh ECDSA signing key'
        'sign:sign a file with a private key'
        'verify:verify a signature (with explicit pubkey or built-in)'
    )
    _describe -t commands 'stsigtool command' commands
}

_stsigtool "$@"
