#compdef mammoth

# Zsh completion for mammoth - convert Word documents (.docx) to simple HTML

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[print version]' \
  '--style-map=[path to a style map file]:file:_files' \
  '--output-format=[output format]:format:(html markdown)' \
  '--output-dir=[output directory for images]:dir:_directories' \
  '1:docx file:_files -g "*.docx"' \
  '2:output file:_files' && ret=0

return ret
