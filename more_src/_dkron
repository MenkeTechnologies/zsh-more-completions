#compdef dkron

# Zsh completion for dkron - Distributed job scheduling

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'agent:Start a dkron agent'
      'doc:Generate documentation'
      'keygen:Generate an encryption key'
      'raft:Raft cluster management'
      'run:Run a job'
      'show:Show a job'
      'status:Show agent status'
      'version:Show version'
    )
    _describe -t commands 'dkron command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      agent)
        _arguments -s -S \
          '--bind-addr=[bind address]:address' \
          '--http-addr=[HTTP address]:address' \
          '*--join=[join address]:address' \
          '--advertise-addr=[advertise address]:address' \
          '*--tag=[tag key=value]:tag' \
          '--encrypt=[encryption key]:key' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--node-name=[node name]:name' \
          '--data-dir=[data directory]:directory:_directories' \
          '--server[enable server mode]' \
          '--bootstrap-expect=[expected number of servers]:count' \
          '*--retry-join=[retry join address]:address' \
          '--retry-interval=[retry join interval]:interval' \
          '--retry-max=[maximum retry attempts]:count' \
          '--dog-statsd-addr=[DogStatsD address]:address' \
          '*--dog-statsd-tags=[DogStatsD tags]:tags' \
          '--statsd-addr=[StatsD address]:address' \
          '--enable-prometheus[enable Prometheus metrics]' \
          '--mail-host=[mail server host]:host' \
          '--mail-port=[mail server port]:port' \
          '--mail-username=[mail username]:username' \
          '--mail-password=[mail password]:password' \
          '--mail-from=[mail from address]:email' \
          '--mail-payload=[mail payload template]:template' \
          '--mail-subject-prefix=[mail subject prefix]:prefix' \
          '--pre-webhook-url=[pre-execution webhook URL]:url' \
          '--pre-webhook-payload=[pre-execution webhook payload]:payload' \
          '--pre-webhook-headers=[pre-execution webhook headers]:headers' \
          '--webhook-url=[post-execution webhook URL]:url' \
          '--webhook-payload=[post-execution webhook payload]:payload' \
          '--webhook-headers=[post-execution webhook headers]:headers' && ret=0
        ;;
      raft)
        local -a subcmds=(
          'list-peers:List raft peers'
          'remove-peer:Remove a raft peer'
        )
        _describe -t subcmds 'raft subcommand' subcmds && ret=0
        ;;
      run|show)
        _arguments '1:job name' && ret=0
        ;;
    esac
    ;;
esac

return ret
