#compdef iceprog
# Documentation: https://man.archlinux.org/search?q=iceprog
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[device serial number]:serial:' \
  '-I+[interface (A/B/C/D)]:iface:(A B C D)' \
  '-o+[offset bytes]:off:' \
  '-s[skip file size verification]' \
  '-S[program SRAM directly (no flash write)]' \
  '-b[bulk erase entire flash]' \
  '-n[do not erase flash]' \
  '-c+[client speed]:speed:' \
  '-e+[erase N bytes]:n:' \
  '-p+[probe (read flash ID)]:flag:' \
  '-r+[read flash to file]:file:_files' \
  '-R+[read flash N bytes to file]:file:_files' \
  '-c[check / verify only]' \
  '-t[test reset]' \
  '-v[verbose]' \
  '*:file:_files -g "*.bin"' && ret=0

return ret
