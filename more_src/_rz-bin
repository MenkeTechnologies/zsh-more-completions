#compdef rz-bin rzbin
# Documentation: https://man.archlinux.org/search?q=rz-bin
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show rz-bin version]' \
  '-V[show binary version information]' \
  '-@+[show section/symbol/import at address]:address:' \
  '-A[list sub-binaries and arch-bits pairs]' \
  '-a+[set target architecture]:arch:(x86 arm arm64 mips ppc sparc avr msp430 8051 m68k riscv)' \
  '-b+[set bits]:bits:(8 16 32 64)' \
  '-B+[override base address]:addr:' \
  '-c[list classes]' \
  '-cc[list classes (all)]' \
  '-d[show debug/dwarf information]' \
  '-dd[show all debug info]' \
  '-e[show entrypoint]' \
  '-E[show globally exportable symbols]' \
  '-f+[select sub-bin by name]:name:' \
  '-F+[force bin plugin]:plugin:' \
  '-g[show all information (-SMZIHVResizcld -SS -SSS -ee)]' \
  '-G+[load address offset]:addr:' \
  '-H[show header fields]' \
  '-i[show imports]' \
  '-I[show binary info]' \
  '-j[JSON output]' \
  '-k+[run sdb query]:query:' \
  '-K+[calculate checksum]:algo:(md5 sha1 sha256 crc32)' \
  '-l[list linked libraries]' \
  '-L+[list plugins or info about a specific plugin]:plugin:' \
  '-m+[show source line for address]:addr:' \
  '-M[show main symbol address]' \
  '-n+[show only named item]:name:' \
  '-N+[force string length min:max]:range:' \
  '-o+[output file/folder]:path:_files' \
  '-O+[write/extract operations]:operation:' \
  '-p[show physical addresses]' \
  '-P[show debug/PDB information]' \
  '-PP[detailed PDB info]' \
  '-q[quiet mode]' \
  '-Q[show load address for dlopen]' \
  '-r[Rizin script output]' \
  '-R[show relocations]' \
  '-s[show symbols]' \
  '-S[show sections]' \
  '-SS[show segments]' \
  '-SSS[show segment-section mapping]' \
  '-T[show file signature]' \
  '-u[unfiltered output]' \
  '-U[show resources]' \
  '-w[show try/catch blocks]' \
  '-x[extract contained bins]' \
  '-X+[package bins]:format:' \
  '-Y+[calculate base address candidates]:fw_file:_files' \
  '-z[show strings (sections)]' \
  '-zz[show strings (whole binary)]' \
  '-zzz[show strings + offsets]' \
  '-Z[guess binary size]' \
  '*::file:_files' && ret=0

return ret
