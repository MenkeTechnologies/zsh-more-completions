#compdef cameratopam
# Documentation: man cameratopam (Netpbm)
# Source: convert a raw digital-camera image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-identify_only[print info without decoding image]' \
    '-quick_interpolate[fast (low-quality) interpolation]' \
    '-half_size[half-size output]' \
    '-four_color_rgb[four-color RGB processing]' \
    '-document_mode[document scan mode (no color processing)]' \
    '(-balance_auto -balance_camera)-balance_auto[automatic white balance]' \
    '(-balance_auto -balance_camera)-balance_camera[use camera white balance]' \
    '-red_scale=[red multiplier]:float:' \
    '-blue_scale=[blue multiplier]:float:' \
    '-brightness=[brightness fraction]:fraction:' \
    '-no_clip_color[do not clip colors to [0,1] range]' \
    '-rgb[RGB output]' \
    '-secondary[use secondary image (if present)]' \
    '-linear[linear output]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:raw camera file:_files' \
    && ret=0

return ret
