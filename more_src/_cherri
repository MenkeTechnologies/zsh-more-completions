#compdef cherri
# ============================================================================
# _cherri — zsh completion for the **Cherri** programming language —
#            electrikmilk/cherri — "Siri Shortcuts Programming Language" —
#            a domain-specific compiled programming language that emits
#            iOS / iPadOS / macOS *Apple Shortcuts* `.shortcut` binary
#            plist files from textual `.cherri` source.  188th
#            programming language entry in this completion corpus
#            (R1030 round-number commit milestone).
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/electrikmilk/cherri
#   Maintainer : electrikmilk
#   License    : GPL-2.0
#   Stars      : 1,536
#   Language   : Go  (the Cherri *compiler* `cherri` is itself a Go
#                 program built on `github.com/electrikmilk/
#                 args-parser` + `howett.net/plist`; the *language*
#                 it compiles is Cherri, a brand-new DSL distinct
#                 from any general-purpose language)
#   Binary     : cherri
#   Source ext : .cherri  (the canonical extension for Cherri
#                 source files; the compiler reads exactly one
#                 .cherri file per invocation and emits a
#                 .shortcut binary plist)
#   Last push  : 2026-05-23
#
# WHAT IT IS
#   Cherri is **the programming language for Apple Shortcuts**.
#   Apple's `Shortcuts.app` (iOS 13+, iPadOS 13+, macOS 12+
#   Monterey+) is a node-graph visual automation builder; its
#   on-disk format is a binary plist of typed action records
#   (`WFWorkflowActions` array, `WFWorkflowActionIdentifier`
#   strings, `WFWorkflowActionParameters` dictionaries, an
#   `WFWorkflowClientVersion` integer, the bundled icon glyph,
#   etc.) cryptographically signed via Apple's `shortcuts sign`
#   subcommand (or a remote third-party signing service such as
#   RoutineHub's hubsign endpoint, or scaxyz/shortcut-signing-
#   server which runs Apple's signing flow on a Mac).
#
#   Cherri replaces the visual builder with a **textual,
#   statically-checked compiled DSL**:
#
#     // example.cherri
#     #define color red
#     #define glyph cherries
#     #define icon "system://cup.and.saucer"
#
#     const fruits = ["Apple", "Banana", "Cherry"]
#
#     for fruit in fruits {
#         alert("I like {fruit}.")
#     }
#
#     const selected = chooseFromList(fruits)
#     speakText(selected)
#
#   The compiler validates that every action identifier exists
#   in the Shortcuts ToolKit SQLite catalog (`--toolkit`),
#   type-checks every parameter against Apple's action schema,
#   resolves device-content references (file/photo/contact
#   selectors), assigns deterministic action UUIDs (with
#   `--derive-uuids`), then serializes the workflow as a
#   binary plist and (optionally) submits it for signing.
#
#   Reverse direction is also supported: `cherri --import` /
#   `cherri --refs` take an iCloud Shortcuts URL or a local
#   `.shortcut` file and **decompile** it into Cherri source,
#   making it the canonical text-based round-trip format for
#   Shortcuts.
#
# CLI ARGUMENT GRAMMAR  (verbatim from args.go `args.Register`
#                       calls; extracted via `gh api repos/
#                       electrikmilk/cherri/contents/args.go`)
#
#   cherri [FILE.cherri]
#          [GENERAL]
#          [COMPILATION OPTIONS]
#          [DECOMPILATION OPTIONS]
#          [PACKAGE COMMANDS]
#          [TOOLKIT OPTIONS]
#          [SEARCH COMMANDS]
#          [DOCS COMMANDS]
#
#   General:
#     -h, --help                     Print usage information
#     -v, --version                  Print version information
#
#   Compilation options:
#     -s, --share <mode>             Set signing mode
#                                    [values: anyone, contacts;
#                                     default: contacts]
#     -d, --debug                    Create .plist file, preprocessed
#                                    file; print debug + stack
#                                    traces
#     --derive-uuids                 Output deterministic action UUIDs
#     -o, --output <PATH>            Custom output file path
#     -c, --comments                 Include `comment` actions in
#                                    compiled Shortcut or import
#     --open                         Open compiled Shortcut after
#                                    build (ignored if unsigned)
#     --no-ansi                      Don't emit ANSI escape sequences
#     --skip-sign                    Do not sign the compiled Shortcut
#     --signing-server <URL>         Use scaxyz/shortcut-signing-server
#                                    at the URL for signing
#     --hubsign                      Sign using RoutineHub's remote
#                                    signing service
#
#   Decompilation options:
#     --import <PATH-or-iCloud-URL>  Import a Shortcut and convert
#                                    to Cherri source  [BETA]
#     --refs <PATH-or-iCloud-URL>    Encode device content
#                                    references from a Shortcut for
#                                    re-use in Cherri code
#
#   Package commands (Cherri has its own package manager that
#                     pulls Cherri source from git URIs):
#     --init <@author/name>          Create a Cherri package; pattern
#                                    @{author}/{package_name} or a
#                                    full URI
#     --add-uri <URI>                Add remote Git repo URI to the
#                                    current package
#     --install <NAME>               Install a package
#     --remove <NAME>                Remove a package
#     --package                      List package info
#     --packages                     List installed packages
#     --tidy                         Re-install all packages
#
#   Toolkit options  (the Shortcuts ToolKit DB is a SQLite
#                     catalog of every typed action / parameter
#                     schema in Apple's Shortcuts.app and is
#                     used to type-check Cherri source and
#                     decompile non-standard actions):
#     --toolkit <PATH>               Path to Shortcuts ToolKit
#                                    SQLite database
#     --toolkit-locale <LOCALE>      Locale to get action data for
#                                    [default: en]
#     --no-toolkit                   Do not use the toolkit DB to
#                                    decompile non-standard actions
#
#   Search / discovery commands (cherri can act as a queryable
#                                catalog over the action +
#                                glyph universe of Shortcuts):
#     --action [PATTERN]             Search available actions
#                                    (empty pattern prints all
#                                    definitions)
#     --glyph [PATTERN]              Search available glyphs
#
#   Docs commands:
#     --docs [CATEGORY]              Generate action documentation,
#                                    optionally by category
#     --subcat <SUBCATEGORY>         Filter action documentation
#                                    category by subcategory
#
# LANGUAGE-CORPUS POSITION
#   Cherri is the **188th programming language** entry in this
#   completion corpus.  It joins Tauraro (R1026 187th — the
#   bilingual English+Hausa compiled language with `.tr`
#   source extension and a self-hosted compiler), Keel (R1022
#   186th), Aether (R1018 185th), Qore (R1014 184th), XGo
#   (R1010 183rd — R1010 round-number commit milestone),
#   Lunite (R1006 182nd), lone (R999 181st — R999 TRIPLE-9
#   commit landmark), daslang (R992 180th — round-number
#   180th-language milestone), Blaise (R988 179th), Fusion
#   (R984 178th), Aver (R980 177th — R980 round-number commit
#   landmark), Raven (R976 176th), HydraScript (R972 175th),
#   Lazurite (R968 174th), duck-lang (R964 173rd), Rascal
#   (R960 172nd — R960 round-number commit landmark), Ixion
#   (R956 171st), KernelScript (R952 170th — round-number
#   170th-language milestone), Prog8 (R948 169th), Objeck
#   (R944 168th), Feral (R940 167th — R940 round-number commit
#   landmark), Biscuit/BL (R936 166th), Rux (R932 165th),
#   Jule (R928 164th), Nevalang (R924 163rd), Corvid (R920
#   162nd — round-number R920 commit landmark), Soppo (R916
#   161st), Cyrus (R912 160th — round-number language
#   milestone), Lumina (R908 159th), Penne (R904 158th),
#   EndBASIC (R900 157th — R900 prior TRIPLE-9 commit
#   landmark), goboscript (R896 156th), Alan (R892 155th),
#   Mech (R888 154th — triple-8 landmark), Lisette (R884
#   153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG (R872
#   150th — round-number language milestone), Roto (R868
#   149th), Pipefish (R864 148th), Mochi (R860 147th), Oden
#   (R856 146th), Hop (R852 145th), Lustre via Kind 2 (R848
#   144th), Ravi (R844 143rd), ZetZ (R840 142nd), Granule
#   (R836 141st), Sixten (R832 140th), Imba (R828 139th),
#   Tao (R824 138th), Dada (R820 137th), Acton (R816 136th),
#   and Stanza (R812 135th).
#
#   Cherri is a particularly distinctive entry: it is a
#   **single-platform, single-target compiled DSL** — its
#   sole compilation target is Apple's Shortcuts.app binary
#   workflow plist format (`*.shortcut`), and its sole
#   runtime environment is Siri/Shortcuts on iOS /  iPadOS /
#   macOS.  This makes it categorically different from a
#   general-purpose language like Tauraro or KernelScript:
#   Cherri does not produce machine code, does not produce
#   bytecode for a VM, and does not produce an executable —
#   it produces an Apple-signed binary workflow file
#   consumed exclusively by `Shortcuts.app`.  Despite (or
#   because of) that narrow target, the language has rich
#   structured-flow constructs (`for-in`, `repeat`,
#   `if/else`, `switch`), typed `const` bindings, a
#   `#define` preprocessor for the workflow's color / glyph
#   / icon / share-mode / version / mac / inputs / outputs
#   / quicklook metadata, string-interpolation syntax
#   (`"... {var} ..."`), a package manager that pulls
#   Cherri source from arbitrary git URIs, a decompiler
#   that round-trips existing `.shortcut` files back to
#   Cherri source, and an action-catalog / glyph-catalog
#   search built directly into the compiler.
#
#   Verified via:
#     gh api repos/electrikmilk/cherri
#       → "stargazers_count": 1536
#       → "language": "Go"
#       → "license": "GPL-2.0"
#       → "description": "Siri Shortcuts Programming Language"
#       → "pushed_at": "2026-05-23"
#     gh api repos/electrikmilk/cherri/contents/main.go
#       → package main
#       → import "github.com/electrikmilk/args-parser"
#       → import "howett.net/plist"
#       → if args.Using("help") | "version" | "docs" |
#         "init" | "add-uri" | "install" | "remove" |
#         "package" | "packages" | "tidy" | "import" |
#         "refs" | "action" | "glyph" branches
#     gh api repos/electrikmilk/cherri/contents/args.go
#       → args.CustomUsage = "[FILE]"
#       → 26 args.Register(...) calls (version, help, share,
#         debug, derive-uuids, output, comments, open,
#         import, refs, init, add-uri, install, remove,
#         package, packages, tidy, toolkit, toolkit-locale,
#         no-toolkit, signing-server, hubsign, no-ansi,
#         skip-sign, action, glyph, docs, subcat)
#       → share Values: anyone, contacts (default contacts)
#       → docs Values: actionCategories  (the set of action
#         category names registered by actionIncludes)
#
#   No completion for `cherri` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_cherri() {
    _arguments -s \
        '(- *)'{-h,--help}'[print usage information]' \
        '(- *)'{-v,--version}'[print version information]' \
        '(-s --share)'{-s,--share}'=[signing mode]:mode:(anyone contacts)' \
        '(-d --debug)'{-d,--debug}'[create .plist file, preprocessed file, debug + stack traces]' \
        '--derive-uuids[output deterministic action UUIDs]' \
        '(-o --output)'{-o,--output}'=[custom output file path]:path:_files -g "*.shortcut"' \
        '(-c --comments)'{-c,--comments}'[include comment actions in compiled Shortcut or import]' \
        '--open[open compiled Shortcut (ignored if unsigned)]' \
        '--no-ansi[do not output ANSI escape sequences]' \
        '--skip-sign[do not sign the compiled Shortcut]' \
        '--signing-server=[remote signing service URL (scaxyz/shortcut-signing-server)]:url:' \
        '--hubsign[sign using RoutineHub remote signing service]' \
        '--import=[import a Shortcut and convert to Cherri (BETA)]:path or iCloud URL:_files -g "*.shortcut"' \
        '--refs=[encode device content references from a Shortcut]:path or iCloud URL:_files -g "*.shortcut"' \
        '--init=[create a Cherri package (@author/name or URI)]:pattern:' \
        '--add-uri=[add a remote Git repository URI to current package]:uri:' \
        '--install=[install a Cherri package]:name:' \
        '--remove=[remove a Cherri package]:name:' \
        '--package[list package info]' \
        '--packages[list installed packages]' \
        '--tidy[re-install all packages]' \
        '--toolkit=[path to Shortcuts ToolKit SQLite database]:path:_files -g "*.db *.sqlite *.sqlite3"' \
        '--toolkit-locale=[custom locale for action data]:locale:(en de es fr it ja ko nl pl pt ru tr zh zh-Hans zh-Hant)' \
        '--no-toolkit[do not use the toolkit DB to decompile non-standard actions]' \
        '--action=[search for available actions (empty prints all)]:pattern:' \
        '--glyph=[search for available glyphs]:pattern:' \
        '--docs=[generate action documentation, optionally by category]:category:' \
        '--subcat=[filter action documentation category by subcategory]:subcategory:' \
        '*:Cherri source file:_files -g "*.cherri"'
}

_cherri "$@"
