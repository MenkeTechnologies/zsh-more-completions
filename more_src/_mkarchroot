#compdef mkarchroot
# Documentation: https://github.com/archlinux/devtools/blob/master/src/mkarchroot.in
# Reference accessed: 2026-05-27
# Verified: upstream getopts string 'hUC:M:c:f:s' and usage() in src/mkarchroot.in (archlinux/devtools).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help message]' \
  '-U[use pacman -U to install packages]' \
  '-C[location of a pacman config file]:file:_files' \
  '-M[location of a makepkg config file]:file:_files' \
  '*-c[set pacman cache directory]:dir:_files -/' \
  '*-f[copy src file from host to chroot (src[:dst])]:src[:dst]:_files' \
  '-s[do not run setarch]' \
  '1:working dir:_files -/' \
  '*:package:' && ret=0

return ret
