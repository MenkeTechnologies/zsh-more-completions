#compdef aws-load-balancer-controller
# _aws-load-balancer-controller — AWS Load Balancer Controller (ALB/NLB ingress)
# upstream: https://github.com/kubernetes-sigs/aws-load-balancer-controller
# Flags from pkg/config/controller_config.go BindFlags() on tip.

_aws-load-balancer-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--cluster-name=[Kubernetes cluster name]:name:' \
        '--default-tags=[default AWS tags applied to managed resources]:k=v:' \
        '--default-target-type=[default TargetGroup target type]:type:(instance ip)' \
        '--default-load-balancer-scheme=[default LB scheme]:scheme:(internal internet-facing)' \
        '--external-managed-tags=[comma-separated AWS tag keys externally managed]:keys:' \
        '--service-target-eni-security-group-tags=[ENI SG tag filters]:k=v:' \
        '--service-max-concurrent-reconciles=[Service reconcile concurrency]:n:' \
        '--targetgroupbinding-max-concurrent-reconciles=[TGB reconcile concurrency]:n:' \
        '--gateway-class-max-concurrent-reconciles=[GatewayClass reconcile concurrency]:n:' \
        '--alb-gateway-max-concurrent-reconciles=[ALB Gateway reconcile concurrency]:n:' \
        '--nlb-gateway-max-concurrent-reconciles=[NLB Gateway reconcile concurrency]:n:' \
        '--globalaccelerator-max-concurrent-reconciles=[Global Accelerator reconcile concurrency]:n:' \
        '--globalaccelerator-max-exponential-backoff-delay=[Global Accelerator max backoff]:dur:' \
        '--targetgroupbinding-max-exponential-backoff-delay=[TGB max backoff]:dur:' \
        '--lb-stabilization-monitor-interval=[LB stabilization monitor interval]:dur:' \
        '--default-ssl-policy=[default SSL policy for HTTPS listeners]:policy:' \
        '--enable-backend-security-group=[create shared backend SG]:bool:(true false)' \
        '--enable-manage-backend-security-group-rules=[manage backend SG rules]:bool:(true false)' \
        '--backend-security-group=[user-managed backend SG ID]:sg-id:' \
        '--enable-endpoint-slices=[use EndpointSlices for IP targets]:bool:(true false)' \
        '--disable-restricted-sg-rules=[disable restricted SG rules]:bool:(true false)' \
        '--max-targets-per-target-group=[max targets per TargetGroup (0=AWS default)]:n:' \
        '--targetgroupbinding-requeue-duration=[TGB requeue duration]:dur:' \
        '--ingress-class=[only reconcile Ingresses with this IngressClass]:class:' \
        '--watch-namespace=[watch single namespace (empty=all)]:ns:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--metrics-bind-addr=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-addr=[health probe bind host\:port]:host\:port:' \
        '--webhook-port=[webhook bind port]:port:' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--aws-region=[AWS region]:region:' \
        '--aws-api-throttle=[per-API throttle settings]:list:' \
        '--aws-max-retries=[AWS SDK max retries]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_aws-load-balancer-controller "$@"
