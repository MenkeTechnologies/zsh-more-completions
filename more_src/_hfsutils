#compdef hfsutils hmount humount hattrib hcd hcopy hdel hdir hformat hls hmkdir hpwd hrename hvol
# _hfsutils — Robert Leslie hfsutils CLI suite hmount humount hattrib hcd hcopy hdel hdir hformat hls hmkdir hpwd hrename hvol for reading writing classic Apple HFS volumes on Linux Unix (hfsutils team, C); getopt
# upstream: https://www.mars.org/home/rob/proj/hfs/

_hfsutils() {
    local -a sub=(
        'hmount:mount HFS volume'
        'humount:unmount HFS volume'
        'hattrib:change HFS attributes'
        'hcd:change directory'
        'hcopy:copy files'
        'hdel:delete files'
        'hdir:list directory'
        'hformat:format HFS volume'
        'hls:list files'
        'hmkdir:make directory'
        'hpwd:print working directory'
        'hrename:rename files'
        'hvol:list volumes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hfsutils subcommand' sub ;;
        args)
            case $words[1] in
                hmount|humount|hformat|hvol) _arguments '*:device or partition:_files' ;;
                hcopy|hrename) _arguments '*:source destination:_files' ;;
                hcd|hmkdir|hls|hdir) _arguments '*:HFS path:' ;;
                hattrib) _arguments '*:attr-flags HFS path:' ;;
                hdel) _arguments '*:HFS file:' ;;
            esac
            ;;
    esac
}

_hfsutils "$@"
