#compdef dr14_tmeter
# Documentation: https://github.com/simon-r/dr14_t.meter/blob/master/man/dr14_tmeter.1
# dr14_tmeter - compute the DR14 dynamic range of audio files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-1 --disable_multithread)'{-1,--disable_multithread}'[disable the multi-core mode]' \
  '(-r --recursive)'{-r,--recursive}'[scan recursively the subdirectories]' \
  '(-a --append)'{-a,--append}'[append all results in a single file]' \
  '(-b --basic_table)'{-b,--basic_table}'[write tables in the basic format]' \
  '(-n --turn_off_out)'{-n,--turn_off_out}'[do not write the output files]' \
  '(-p --print_std_out)'{-p,--print_std_out}'[write the full result on std_out]' \
  '(-o --outdir)'{-o,--outdir}'=[write resulting files into given directory]:dir:_files -/' \
  '(-t --tables)'{-t,--tables}'=[select output format]:format:(h t b w a)' \
  '(-f --file)'{-f,--file}'=[compute DR14 of a single file and exit]:file:_files' \
  '(-d --dr_database)'{-d,--dr_database}'[output file compatible with the DR database]' \
  '--hist=[plot the histogram of dynamic of a single file]:file:_files' \
  '--lev_hist=[plot the histogram of sample levels of a single file]:file:_files' \
  '--spectrogram=[plot the spectrogram of a single file (beta)]:file:_files' \
  '--plot_track=[plot the track of the given file]:file:_files' \
  '--plot_track_dst=[plot the track in a cool manner]:file:_files' \
  '--compress=[perform dynamic compression on a single file]:file:_files' \
  '--dyn_vivacity=[plot the dynamic vivacity of an audio file]:file:_files' \
  '--files_list=[take a files list and compute the DR of each file]:file:_files' \
  '--quiet[quiet mode]' \
  '*:directory:_files -/' && ret=0

return ret
