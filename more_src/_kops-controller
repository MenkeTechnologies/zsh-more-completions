#compdef kops-controller
# _kops-controller — kOps in-cluster controller (issues node bootstrap certs + maintains node labels/taints from the kOps cluster spec)
# upstream: https://github.com/kubernetes/kops
# Flags from cmd/kops-controller/main.go on tip.

_kops-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--conf=[path to the kops-controller yaml configuration file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_kops-controller "$@"
