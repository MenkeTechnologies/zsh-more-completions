#compdef fvwm3
# Documentation: https://man.archlinux.org/man/fvwm3.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'-h'[show help]' \
  '(- *)'-V'[show version]' \
  '-c[execute command on startup]:command' \
  '-d[specify display]:display' \
  '-f[specify config file]:config file:_files' \
  '-r[replace running window manager]' \
  '-s[manage a single screen]' \
  '-v[enable verbose output]' \
  '-i[set client id for session management]:client id' \
  '-F[specify visual class]:visual class:(StaticGray GrayScale StaticColor PseudoColor TrueColor DirectColor)' \
  '-I[specify visual id]:visual id' \
  '-l[set color limit]:color limit' \
  '-L[set strict color limit]:color limit' \
  '-C[use click to focus]' \
  '-S[use sloppy focus]' \
  '-D[set debug level]:debug level'
