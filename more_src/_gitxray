#compdef gitxray
# Documentation: https://www.kali.org/tools/gitxray/
# gitxray GitHub OSINT, forensics and pentesting scanner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --repository)'{-r,--repository}'[specify a repository to check]:url:' \
  '(-rf --repositories-file)'{-rf,--repositories-file}'[file containing repositories, one per line]:file:_files' \
  '(-o --organization)'{-o,--organization}'[check all repositories for an organization]:url:' \
  '(-c --contributor)'{-c,--contributor}'[focus on contributor usernames, comma-separated]:usernames:' \
  '(-l --list)'{-l,--list}'[list contributors or repositories]' \
  '(-f --filters)'{-f,--filters}'[comma separated keywords to filter results by]:keywords:' \
  '(-out --outfile)'{-out,--outfile}'[set output log file location]:file:_files' \
  '(-outformat --output-format)'{-outformat,--output-format}'[output format]:format:(html text json)' \
  '--debug[enable debug mode]' \
  '--shush[reduced output in stdout]' && ret=0

return ret
