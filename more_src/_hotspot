#compdef hotspot

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--appimage-extract[extract AppImage contents]' \
  '--sysroot=[path to sysroot for remote profiling]:directory:_directories' \
  '--kallsyms=[path to kallsyms file]:file:_files' \
  '--arch=[target architecture]:architecture' \
  '--objdump=[path to objdump binary]:path:_files' \
  '--debugPaths=[colon-separated list of debug symbol paths]:paths' \
  '--extraLibPaths=[colon-separated list of extra library paths]:paths' \
  '*:perf data file:_files'
