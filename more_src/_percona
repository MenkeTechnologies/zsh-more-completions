#compdef percona percona-toolkit pt
# _percona — Percona percona percona-toolkit CLI command-line frontend wrapping the Percona Toolkit collection of advanced MySQL PostgreSQL MongoDB administration tools pt-query-digest pt-online-schema-change pt-archiver pt-table-checksum pt-summary pt-stalk pt-mext pt-show-grants pt-mysql-summary pt-pg-summary (Percona team, Perl/Python); custom argparse
# upstream: https://www.percona.com/

_percona() {
    local -a sub=(
        'query-digest:pt-query-digest'
        'online-schema-change:pt-online-schema-change'
        'archiver:pt-archiver'
        'table-checksum:pt-table-checksum'
        'table-sync:pt-table-sync'
        'summary:pt-summary'
        'stalk:pt-stalk'
        'mext:pt-mext'
        'show-grants:pt-show-grants'
        'mysql-summary:pt-mysql-summary'
        'pg-summary:pt-pg-summary'
        'mongodb-summary:pt-mongodb-summary'
        'config-diff:pt-config-diff'
        'duplicate-key-checker:pt-duplicate-key-checker'
        'fingerprint:pt-fingerprint'
        'fk-error-logger:pt-fk-error-logger'
        'index-usage:pt-index-usage'
        'kill:pt-kill'
        'k8s-debug-collector:pt-k8s-debug-collector'
        'sift:pt-sift'
        'slave-restart:pt-slave-restart'
        'upgrade:pt-upgrade'
        'variable-advisor:pt-variable-advisor'
        'visual-explain:pt-visual-explain'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--host=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '--socket=+[file]:file:_files' \
        '--database=+[name]:str:' \
        '--defaults-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'percona subcommand' sub ;;
    esac
}

_percona "$@"
