#compdef ld-find-code-refs
# Documentation: https://github.com/launchdarkly/ld-find-code-refs/blob/main/docs/CONFIGURATION.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# LaunchDarkly code references scanner

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version information]' \
  '(-t --accessToken)'{-t,--accessToken}'+[LaunchDarkly personal access token]:token:' \
  '--allowTags[enable storing references for tags]' \
  '(-U --baseUri)'{-U,--baseUri}'+[LaunchDarkly base URI]:uri:' \
  '(-b --branch)'{-b,--branch}'+[currently checked out branch]:branch:' \
  '--commitUrlTemplate=[VCS commit link template]:template:' \
  '(-C --contextLines)'{-C,--contextLines}'+[context lines to send]:n:' \
  '--debug[verbose debug logging]' \
  '(-B --defaultBranch)'{-B,--defaultBranch}'+[default branch]:branch:' \
  '(-d --dir)'{-d,--dir}'+[path to repository checkout]:dir:_files -/' \
  '--dryRun[run scanner without sending to LaunchDarkly]' \
  '--hunkUrlTemplate=[VCS code reference link template]:template:' \
  '(-i --ignoreServiceErrors)'{-i,--ignoreServiceErrors}'[exit 0 on API errors]' \
  '(-l --lookback)'{-l,--lookback}'+[git commits to search]:n:' \
  '(-o --outDir)'{-o,--outDir}'+[output directory for CSV file]:dir:_files -/' \
  '(-p --projKey)'{-p,--projKey}'+[LaunchDarkly project key]:key:' \
  '--prune[delete branches not in remote repo]' \
  '(-r --repoName)'{-r,--repoName}'+[repository name]:name:' \
  '(-T --repoType)'{-T,--repoType}'+[repo service provider]:type:(bitbucket custom github gitlab)' \
  '(-u --repoUrl)'{-u,--repoUrl}'+[repository URL]:url:' \
  '(-R --revision)'{-R,--revision}'+[repository revision for non-git codebases]:rev:' \
  '--skipArchivedFlags[do not fetch archived feature flags]' \
  '--subdirectory=[path to configuration file relative to root]:dir:_files -/' \
  '(-s --updateSequenceId)'{-s,--updateSequenceId}'+[version number for concurrent executions]:n:' \
  '--userAgent=[internal platform identifier]:agent:' \
  '*::args:_default' && ret=0

return ret
