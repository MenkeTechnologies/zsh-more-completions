#compdef oathkeeper

# Zsh completion for Ory Oathkeeper - identity and access proxy

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'credentials:manage credentials'
      'health:check health'
      'rules:manage access rules'
      'serve:start the server'
      'validate:validate configuration'
      'version:show version'
    )
    _describe -t commands 'oathkeeper command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--config=[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '1:mode:(all api proxy)' && ret=0
        ;;
      rules)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--endpoint=[Oathkeeper API endpoint]:url' \
          '1:subcommand:(delete get import list validate)' && ret=0
        ;;
      credentials)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(generate)' && ret=0
        ;;
      health)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--endpoint=[endpoint URL]:url' \
          '1:subcommand:(alive ready)' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:config file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
