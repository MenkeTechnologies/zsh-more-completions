#compdef immedian
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/immedian.html
# MIRIAD immedian - apply a median (or outlier-rejection) filter to an image

local ret=1

_arguments -s -S \
  'in=[input image (no default)]:in:_files' \
  'out=[output image (no default)]:out:_files' \
  'size=[half box size; box is 2*SIZE+1 pixels]:size' \
  'nsigma=[remove outliers beyond nsigma*sigma from the mean]:nsigma' \
  '*:image:_files' && ret=0

return ret
