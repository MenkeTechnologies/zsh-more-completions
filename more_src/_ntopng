#compdef ntopng
# Documentation: https://man.archlinux.org/search?q=ntopng
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-G --pid-path)'{-G,--pid-path}'+[PID file]:file:_files' \
  '(-i --interface)'{-i,--interface}'+[capture interface]:iface:_net_interfaces' \
  '(-w --http-port)'{-w,--http-port}'+[HTTP port]:port:' \
  '(-W --https-port)'{-W,--https-port}'+[HTTPS port]:port:' \
  '(-d --data-dir)'{-d,--data-dir}'+[data directory]:dir:_files -/' \
  '(-r --redis)'{-r,--redis}'+[redis server host[:port]]:host:_hosts' \
  '(-u --user)'{-u,--user}'+[run as user]:user:_users' \
  '(-g --pid)'{-g,--pid}'+[group]:group:_groups' \
  '(-e --daemon)'{-e,--daemon}'[run as daemon]' \
  '(-n --dns-mode)'{-n,--dns-mode}'+[DNS mode]:mode:(0 1 2 3 4)' \
  '(-c --categorization-key)'{-c,--categorization-key}'+[ntop categorization key]:key:' \
  '(-D --packet-decoding)'{-D,--packet-decoding}'+[decoding level]:lvl:(0 1 2 3)' \
  '(-E --export-flows)'{-E,--export-flows}'+[export flows to]:dest:' \
  '(-F --flow-collection)'{-F,--flow-collection}'+[flow collection method]:method:(zmq es kafka syslog mysql)' \
  '(-I --interface-name)'{-I,--interface-name}'+[interface name]:name:' \
  '(-l --disable-login)'{-l,--disable-login}'[disable login]' \
  '(-m --local-networks)'{-m,--local-networks}'+[local network CIDR list]:nets:' \
  '(-N --instance-name)'{-N,--instance-name}'+[instance name]:name:' \
  '(-o --options)'{-o,--options}'+[passthru options]:opts:' \
  '(-p --ndpi-protocols)'{-p,--ndpi-protocols}'+[nDPI protocols file]:file:_files' \
  '(-P --community)'{-P,--community}'[run in Community Edition mode]' \
  '(-q --disable-autologout)'{-q,--disable-autologout}'[disable auto-logout]' \
  '(-s --no-promisc)'{-s,--no-promisc}'[disable promiscuous mode]' \
  '(-S --sticky-hosts)'{-S,--sticky-hosts}'[sticky host caching]' \
  '(-t --traffic-filtering)'{-t,--traffic-filtering}'+[traffic filtering rules]:rules:' \
  '(-U --umask)'{-U,--umask}'+[umask]:umask:' \
  '(-v --verbose)'{-v,--verbose}'+[verbose level]:lvl:(0 1 2 3)' \
  '(-x --max-num-flows)'{-x,--max-num-flows}'+[max flow count]:n:' \
  '(-X --max-num-hosts)'{-X,--max-num-hosts}'+[max host count]:n:' \
  '(-z --disable-alerts)'{-z,--disable-alerts}'[disable alerts]' \
  '(-Z --zmq-publish)'{-Z,--zmq-publish}'+[ZMQ publish endpoint]:endpoint:' \
  '(--http-prefix)'{--http-prefix}'+[HTTP path prefix]:prefix:' \
  '*:config_file:_files' && ret=0

return ret
