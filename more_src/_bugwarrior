#compdef bugwarrior
# _bugwarrior — sync issues from GitHub/Bitbucket/Trac into Taskwarrior (GothenburgBitFactory/bugwarrior)
# upstream: https://github.com/GothenburgBitFactory/bugwarrior
# Subcommands from bugwarrior/command.py (click).

_bugwarrior() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'pull:sync issues into Taskwarrior'
                'uda:print recommended UDAs config'
                'ini2toml:convert legacy bugwarriorrc to TOML'
                'vault:manage credential vault'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                pull)
                    _arguments \
                        '--dry-run[do not modify Taskwarrior]' \
                        '--flavor=[flavor section to use]:flavor:' \
                        '--quiet[set logging to WARNING]'
                    ;;
                uda) _arguments '--flavor=[flavor]:flavor:' ;;
                vault)
                    _arguments '1:subcommand:(list clear set)' '2:target:' '3:username:'
                    ;;
                ini2toml) _arguments '1:rcfile:_files' ;;
            esac
            ;;
    esac
}

_bugwarrior "$@"
