#compdef autoload
# Documentation: man zshbuiltins (zsh)
# Source: zsh — autoload mark functions for autoloading at first call.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-+[turn on options after autoloading]:options:' \
    '-X[execute autoload from within a function]' \
    '-U[do not expand aliases when autoloaded]' \
    '-K[mark for KSH-style autoload]' \
    '-z[mark for ZSH-style autoload]' \
    '-w[handle file as wordcode (compiled)]' \
    '-r[resolve absolute path to file at autoload]' \
    '-R[resolve and report error if missing]' \
    '-t[turn on execution trace when called]' \
    '-T[mark for trace; like -t but each line traced]' \
    '-d[define functions but do not autoload]' \
    '+X[load now (without executing)]' \
    '+W[wordcode + load now]' \
    '-m[treat names as patterns]' \
    '-S[search FPATH but do not mark loaded]' \
    '-I[skip when already loaded]' \
    '-k[mark function for KSH autoload semantics]' \
    '*:function name:_functions' \
    && ret=0

return ret
