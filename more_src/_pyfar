#compdef pyfar pyfar-cli
# _pyfar — pyfar consortium pyfar Python framework for acoustic research signal processing and audio I/O CLI helpers (pyfar team, Python); argparse
# upstream: https://github.com/pyfar/pyfar

_pyfar() {
    local -a sub=(
        'analyze:run acoustic analysis'
        'filter:apply filter to signal'
        'spectrum:compute spectrum'
        'spectrogram:compute spectrogram'
        'plot:plot signal or spectrum'
        'convert:convert audio formats'
        'sweep:generate sweep signal'
        'impulse:generate impulse'
        'noise:generate noise signal'
        'sine:generate sine wave'
        'convolve:convolve signals'
        'deconvolve:deconvolve signals'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--sampling-rate=+[Hz]:n:' \
        '--n-samples=+[N]:n:' \
        '--duration=+[seconds]:f:' \
        '--amplitude=+[F]:f:' \
        '--frequency=+[Hz]:f:' \
        '--bandwidth=+[Hz]:f:' \
        '--fmin=+[Hz]:f:' \
        '--fmax=+[Hz]:f:' \
        '--filter-type=+[filter]:f:(butter cheby1 cheby2 ellip bessel)' \
        '--filter-order=+[N]:n:' \
        '--n-fft=+[N]:n:' \
        '--window=+[window]:w:(hann hamming blackman bartlett kaiser)' \
        '--overlap=+[F]:f:' \
        '--format=+[format]:f:(wav flac ogg sofa hdf5)' \
        '--no-progress[no progress]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pyfar subcommand' sub ;;
        args)
            case $words[1] in
                analyze|filter|spectrum|spectrogram|plot|convert|convolve|deconvolve) _arguments \
                    '*:input file:_files -g "*.wav *.flac *.sofa *.h5 *.hdf5 *.csv"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_pyfar "$@"
