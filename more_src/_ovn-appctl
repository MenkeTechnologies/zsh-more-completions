#compdef ovn-appctl
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man8/ovn-appctl.8.html
# utility for configuring running OVN daemons

local ret=1

_arguments -s -S \
  '(-t --target)'{-t,--target}'=[target daemon to send commands to]:target:_files' \
  '(-T --timeout)'{-T,--timeout}'=[max time to wait for a response in seconds]:seconds' \
  '(-h --help)'{-h,--help}'[print a brief help message]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '*:command:_default' && ret=0

return ret
