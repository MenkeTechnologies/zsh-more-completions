#compdef flipt

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[config file path]:config file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bundle:manage Flipt bundles'
      'cloud:manage Flipt Cloud'
      'completion:generate shell completion'
      'config:manage configuration'
      'export:export flags and segments'
      'import:import flags and segments'
      'migrate:run database migrations'
      'validate:validate Flipt flag state files'
    )
    _describe -t commands 'flipt command' commands && ret=0
    ;;
  args)
    case $line[1] in
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--address=[server address]:address' \
          '--namespace=[namespace to export]:namespace' \
          '--all-namespaces[export all namespaces]' && ret=0
        ;;
      import)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--address=[server address]:address' \
          '--namespace=[namespace to import into]:namespace' \
          '--drop[drop existing data before import]' \
          '*:import file:_files' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--database-url=[database URL]:url' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:features file:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      bundle)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(build list)' && ret=0
        ;;
    esac
    ;;
esac

return ret
