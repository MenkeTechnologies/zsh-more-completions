#compdef xclogparser
# Documentation: https://man.archlinux.org/search?q=xclogparser
# Reference accessed: 2026-05-16

# Zsh completion for XCLogParser (MobileNativeFoundation/XCLogParser)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'dump:emit raw xcactivitylog JSON'
      'parse:emit reporter output'
      'manifest:dump LogStoreManifest.plist JSON'
    )
    _describe -t commands 'xclogparser command' commands && ret=0
    ;;
  args)
    case $line[1] in
      dump)
        _arguments -s -S \
          '--file[explicit xcactivitylog path]:log:_files' \
          '--project[DerivedData project folder prefix]:name' \
          '--strict-project-name[stricter --project matching]' \
          '--workspace[path to xcworkspace]:workspace:_files -g "*.xcworkspace"' \
          '--xcodeproj[path to xcodeproj]:project:_files -g "*.xcodeproj"' \
          '--derived_data[custom DerivedData path]:path:_files -/' \
          '--output[write output to path]:file:_files' \
          '--redacted[redact usernames in paths]' \
          '--without-build-specific-info[strip UUID-ish path segments]' && ret=0
        ;;
      parse)
        _arguments -s -S \
          '--reporter[output format]:reporter:(json flatJson summaryJson chromeTracer issues html)' \
          '--file[explicit xcactivitylog path]:log:_files' \
          '--project[DerivedData project folder prefix]:name' \
          '--strict-project-name[stricter --project matching]' \
          '--workspace[path to xcworkspace]:workspace:_files -g "*.xcworkspace"' \
          '--xcodeproj[path to xcodeproj]:project:_files -g "*.xcodeproj"' \
          '--derived_data[custom DerivedData path]:path:_files -/' \
          '--output[write output to path]:file:_files' \
          '--redacted[redact usernames in paths]' \
          '--without-build-specific-info[strip UUID-ish path segments]' && ret=0
        ;;
      manifest)
        _arguments -s -S \
          '--derived_data[DerivedData root]:path:_files -/' \
          '--manifest[path to LogStoreManifest.plist]:file:_files' \
          '--output[write JSON to path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
