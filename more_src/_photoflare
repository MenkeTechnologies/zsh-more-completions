#compdef photoflare
# Documentation: https://man.archlinux.org/search?q=photoflare
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:image:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.heic *.psd *.xcf"' && ret=0

return ret
