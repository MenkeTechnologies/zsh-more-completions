#compdef tcpserver
# _tcpserver — DJB ucspi-tcp tcpserver (single-binary inetd replacement: accepts TCP connections, applies cdb access rules, drops privileges, then execs child with UCSPI-TCP env vars)
# upstream: https://github.com/schmonz/ucspi-tcp
# Flags from tcpserver.c on tip (getopt).

_tcpserver() {
    _arguments \
        '-1[print local IP:port on stdout when listener is ready]' \
        '-U[read uid/gid from $UID/$GID]' \
        '-X[allow connections even if -x rules.cdb is missing]' \
        '-x+[access-control cdb produced by tcprules]:file:_files' \
        '-B+[respond with banner string before child starts]:banner:' \
        '-c+[max simultaneous connections]:n:' \
        '-g+[setgid to gid]:gid:_groups' \
        '-u+[setuid to uid]:uid:_users' \
        '-b+[listen() backlog]:n:' \
        '-l+[local hostname (for $TCPLOCALHOST)]:host:' \
        '-t+[timeout for DNS+ident lookups (sec)]:sec:' \
        '(-p -P)-p[paranoid: require matching forward DNS]' \
        '(-p -P)-P[do not look up remote host PTR]' \
        '(-h -H)-h[look up remote host (default)]' \
        '(-h -H)-H[skip remote host lookup]' \
        '(-r -R)-r[ask remote for ident (default)]' \
        '(-r -R)-R[skip ident lookup]' \
        '(-o -O)-o[set TCP_NODELAY]' \
        '(-o -O)-O[clear TCP_NODELAY]' \
        '(-d -D)-d[delay (Nagle on)]' \
        '(-d -D)-D[do not delay (Nagle off)]' \
        '(-q -Q -v)-q[quiet (no status messages)]' \
        '(-q -Q -v)-Q[error messages only]' \
        '(-q -Q -v)-v[verbose status]' \
        '1:host:_hosts' \
        '2:port:' \
        '*::program:_command_names -e'
}

_tcpserver "$@"
