#compdef kube-score2
# _kube-score2 — Simon Andersson kube-score2 CLI command-line frontend wrapping the kube-score tool that performs static code analysis of your Kubernetes object definitions open-source written in Go points out improvements to make your application more secure and resilient YAML-Kubernetes-Manifest-Validator object-aware checks for application running as non-root user pod-disruption-budget set memory cpu requests and limits read-only-root-filesystem TopologyConstraints CIS-style score ci-mode kubernetes-version optional-test (Simon Andersson zegl team, Go); cobra
# upstream: https://kube-score.com/

_kube-score2() {
    local -a sub=(
        'score:score Kubernetes manifests'
        'list:list available checks'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-o+[output format]:f:(human ci json sarif)' \
        '--output-format=+[fmt]:f:(human ci json sarif)' \
        '--output-version=+[v]:str:' \
        '--enable-optional-test=+[ids]:str:' \
        '*--enable-optional-test=+[id]:str:' \
        '--ignore-test=+[ids]:str:' \
        '*--ignore-test=+[id]:str:' \
        '--ignore-container-cpu-limit[ignore container cpu limit]' \
        '--ignore-container-memory-limit[ignore container memory limit]' \
        '-e+[exit one on warning]' \
        '--exit-one-on-warning[exit one on warning]' \
        '--threshold-ok=+[N]:n:' \
        '--kubernetes-version=+[v]:str:' \
        '--use-ignore-checks-annotation[use ignore checks annotation]' \
        '--use-optional-checks-annotation[use optional checks annotation]' \
        '--use-namespace-default[use namespace default]' \
        '--default-pdb=+[v]:v:(true false)' \
        '--all-default-optional[all optional]' \
        '--help-info[help info]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kube-score subcommand' sub ;;
        args)
            case $words[1] in
                score) _arguments '*:file:_files -g "*.yaml *.yml"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kube-score2 "$@"
