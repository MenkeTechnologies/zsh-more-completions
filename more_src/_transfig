#compdef transfig

# transfig: master xfig → many-formats translator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[generic flags]:flags:' \
  '-e[encapsulate language]:lang:' \
  '-I[X include path]:path:_files' \
  '-L[output language]:lang:(eps pdf pdftex pdftex_t ps pstex pstex_t latex epic eepic eepicemu mp mmp mptex mfpic pic ibmgl box pcx jpeg gif png shape sld svg tk html cgm)' \
  '-l[output language]:lang:' \
  '-M[mode]:mode:' \
  '-m[magnification]:n:' \
  '-p[page mode]:mode:' \
  '-q[query mode]' \
  '-s[font size]:n:' \
  '-T[paper size]:size:' \
  '-V[verbose]' \
  '*:xfig files:_files -g "*.fig"' && ret=0
return ret
