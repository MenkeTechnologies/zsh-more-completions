#compdef missfits
# Documentation: https://github.com/astromatic/missfits/blob/master/src/main.c
# MissFITS - perform basic maintenance and packaging tasks on FITS files

local ret=1

_arguments -s -S \
  '-h[show syntax/help]' \
  '-v[show version information]' \
  '-d[dump a default configuration file]' \
  '-dd[dump an extended default configuration file]' \
  '-c+[use the given configuration file]:config file:_files' \
  '*:FITS image or @list:_files -g "*.(fits|fit|FITS|FIT|fz|txt|list)"' && ret=0

return ret
