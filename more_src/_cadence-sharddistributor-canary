#compdef cadence-sharddistributor-canary
# _cadence-sharddistributor-canary — canary worker exercising the Cadence shard distributor (cadence-workflow/cadence)
# upstream: https://github.com/cadence-workflow/cadence
# Subcommands from cmd/sharddistributor-canary/main.go (urfave/cli/v2).

_cadence-sharddistributor-canary() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(start:'start shard distributor canary')
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '(-e --endpoint)'{-e+,--endpoint=}'[shard distributor endpoint host:port]:addr:' \
                        '--fixed-namespace=[namespace for fixed shard processing]:ns:' \
                        '--ephemeral-namespace=[namespace for ephemeral shard creation testing]:ns:' \
                        '--canary-grpc-port=[port for canary to receive ping requests]:port:' \
                        '--num-executors=[number of executors (overrides per-namespace flags)]:n:' \
                        '--num-fixed-executors=[fixed namespace executors]:n:' \
                        '--num-ephemeral-executors=[ephemeral namespace executors]:n:' ;;
            esac
            ;;
    esac
}

_cadence-sharddistributor-canary "$@"
