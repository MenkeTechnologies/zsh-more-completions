#compdef wikijs wiki
# _wikijs — Nicolas Giard Wiki.js modern open-source self-hosted documentation/wiki platform (Requarks team, Node.js); standard argv
# upstream: https://github.com/Requarks/wiki

_wikijs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "config.yml *.yaml *.json"' \
        '-c+[config file]:file:_files' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--bind-ip=+[bind ip]:host:_hosts' \
        '--db-type=+[db driver]:d:(postgres mariadb mysql mssql sqlite)' \
        '--db-host=+[db host]:host:_hosts' \
        '--db-port=+[db port]:port:_ports' \
        '--db-user=+[db user]:user:_users' \
        '--db-pass=+[db password]:str:' \
        '--db-name=+[db name]:str:' \
        '--db-ssl[db ssl]' \
        '--db-pool-min=+[min pool]:n:' \
        '--db-pool-max=+[max pool]:n:' \
        '--ssl-enabled[enable https]' \
        '--ssl-port=+[ssl port]:port:_ports' \
        '--ssl-provider=+[provider]:p:(custom letsencrypt)' \
        '--ssl-domain=+[domain]:host:_hosts' \
        '--ssl-subscriber=+[email]:str:' \
        '--ssl-cert-path=+[cert file]:file:_files' \
        '--ssl-key-path=+[key file]:file:_files' \
        '--upload-max-file-size=+[bytes]:n:' \
        '--upload-max-files=+[N]:n:' \
        '--ha[high availability]' \
        '--data-path=+[data dir]:dir:_files -/' \
        '--offline[offline mode]' \
        '--log-level=+[level]:l:(error warn info verbose debug silly)' \
        '--log-format=+[format]:f:(json simple)'
}

_wikijs "$@"
