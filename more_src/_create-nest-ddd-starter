# Zsh completion for create-nest-ddd-starter - NestJS DDD starter scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--db=[database engine to configure]:database:(postgres mysql)' \
  '--docker[include Dockerfile and compose.yaml]' \
  '--skip-install[skip running npm install]' \
  ':project name:' && ret=0

return ret
