#compdef create-ai-rules
# Documentation: https://www.npmjs.com/package/create-ai-rules
# Reference accessed: 2026-05-24
# Verified: npm view create-ai-rules bin; npm readme CLI flags section.

# Zsh completion for create-ai-rules - AI coding assistant rules scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[non-interactive mode with defaults]' \
  '(-f --force)'{-f,--force}'[overwrite existing generated files]' \
  '--minimal[generate minimal rules bundle]' \
  '--full[generate full rules bundle]' \
  '--verbosity=[rules verbosity level]:verbosity:(minimal standard strict)' \
  '--stack=[comma-separated stack ids for --yes mode]:stack:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
