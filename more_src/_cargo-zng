#compdef cargo-zng
# Documentation: https://github.com/zng-ui/zng/tree/main/crates/cargo-zng
# Tools for the Zng GUI framework

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmd' && ret=0

case $state in
  cmd)
    if (( CURRENT == 1 )); then
      _values 'cargo-zng subcommand' \
        'fmt[format code and macros]' \
        'new[new project from a Zng template repository]' \
        'l10n[localization text scraper]' \
        'res[build resources]' \
        'trace[run an app with trace recording enabled]' && ret=0
    else
      case ${words[1]} in
        fmt)
          _arguments -s \
            '--check[verify formatting without modifying files]' \
            '--manifest-path=[target Cargo.toml]:file:_files -g "*.toml"' \
            '(-p --package)'{-p,--package}'=[format workspace crate by name]:package' \
            '(-f --files)'{-f,--files}'=[format files matching glob]:glob' \
            '(-s --stdin)'{-s,--stdin}'[format from stdin to stdout]' \
            '--edition=[rustfmt style edition]:edition' \
            '--full[check every file, not just changed]' && ret=0
          ;;
        new)
          _arguments -s \
            '(-t --template)'{-t,--template}'=[specify template]:template' \
            '(-s --set)'{-s,--set}'=[set template values]:value' \
            '(-k --keys)'{-k,--keys}'[display available template values]' && ret=0
          ;;
        l10n)
          _arguments -s \
            '(-i --input)'{-i,--input}'=[Rust files glob or directory]:input' \
            '(-o --output)'{-o,--output}'=[l10n resources directory]:dir:_files -/' \
            '(-p --package)'{-p,--package}'=[target package to scrap]:package' \
            '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
            '--no-deps[skip dependency localization]' \
            '--check[validate scraped resources]' && ret=0
          ;;
        res)
          _arguments -s \
            '--pack[copy static files to target]' \
            '--tool=[specify resource tool]:tool' \
            '--tools[display available tools]' && ret=0
          ;;
      esac
    fi
    ;;
esac

return ret
