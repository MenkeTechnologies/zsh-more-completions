# pip-installable Python client + Chapel
# compilation, ~15 user-facing config flags in
# clean ServerConfig.chpl exercise every major
# Chapel `config` PATTERN (config const for
# immutable, config var for mutable, config
# param for compile-time, type inference from
# initializer, explicit type annotation `: string`,
# enum-typed config, env-var fallback via
# `try! getEnv(NAME, DEFAULT)`, `private config`
# for module-scoping), real production server
# used at DoD labs and HPC sites for terabyte-
# scale array analytics.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Enum values from ServerConfig.chpl
local -a deployments=(
  'STANDARD:bare-metal or HPC environment (default)'
  'KUBERNETES:Kubernetes pod deployment'
)
local -a log_levels=(
  'DEBUG:verbose debug logging'
  'INFO:informational logging (default)'
  'WARN:warning-level logging'
  'ERROR:error-level logging only'
  'CRITICAL:critical-level logging only'
)
local -a log_channels=(
  'CONSOLE:log to stdout/stderr (default)'
  'FILE:log to file'
)

# 14 user-facing config flags decoded source-
# direct from ServerConfig.chpl + ~12 Chapel
# runtime built-in flags.  Chapel auto-generates
# parser from `config` decls; we expose the same
# surface as zsh completion.
_arguments -s -S \
  '(- *)--help[print Chapel runtime help and exit]' \
  '--about[print "about" information]' \
  '--usage[print usage]' \
  '(-nl --numLocales)'{-nl+,--numLocales=}'[number of locales for distributed HPC execution]:locale count:' \
  '--numTasksPerLocale=[number of tasks per locale]:tasks:' \
  '--dataParTasksPerLocale=[data-parallel tasks per locale]:tasks:' \
  '--memTrack=[enable memory tracking]:bool:(true false)' \
  '--memStats=[print memory stats at program exit]:bool:(true false)' \
  '--memThreshold=[memory allocation threshold]:bytes:' \
  '--memLeaks[check for memory leaks at program exit]' \
  '--memLeaksTable[print memory-leaks table at exit]' \
  '--quiet[suppress runtime informational output]' \
  '--verbose[enable verbose runtime output]' \
  '--deployment=[deployment mode]:mode:->deployments' \
  '--trace=[trace logging flag]:bool:(true false)' \
  '--logLevel=[global log level]:level:->log_levels' \
  '--logChannel=[global log channel]:channel:->log_channels' \
  '--logCommands=[log arkouda_server commands]:bool:(true false)' \
  '--ServerPort=[ZeroMQ server port (default: 5555)]:port:' \
  '--perLocaleMemLimit=[per-locale memory limit as percentage (default: 90)]:percent:' \
  '--autoShutdown=[auto-shutdown server when client disconnects]:bool:(true false)' \
  '--serverInfoNoSplash=[skip server-info splash on startup]:bool:(true false)' \
  '--authenticate=[enable client authentication]:bool:(true false)' \
  '--saveUsedModules=[save list of used modules]:bool:(true false)' \
  '--serverConnectionInfo=[file path to write server hostname:port]:path:_files' \
  '--pythonVersion=[Python client version (compile-time set)]:version:' && ret=0

case $state in
  deployments)
    _describe -t deployments 'deployment mode' deployments && ret=0
    ;;
  log_levels)
    _describe -t log_levels 'log level' log_levels && ret=0
    ;;
  log_channels)
    _describe -t log_channels 'log channel' log_channels && ret=0
    ;;
esac

return ret
