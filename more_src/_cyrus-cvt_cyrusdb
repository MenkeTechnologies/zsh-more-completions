#compdef cyrus-cvt_cyrusdb
# Documentation: https://www.cyrusimap.org/imap/reference/manpages/systemcommands/cvt_cyrusdb.html
# Reference accessed: 2026-05-16
# Verified: upstream cyrusimap.org cvt_cyrusdb(8) reference manpage. Only
# documented flag is -C; rest are positional arguments.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# cyrus-cvt_cyrusdb: convert Cyrus database files between formats
local curcontext="$curcontext" ret=1
local -a backends
backends=(berkeley flat quotalegacy skiplist sql twoskip twom zeroskip)
_arguments -C \
  '-C[alternate imapd.conf]:file:_files' \
  '1:source db file:_files' \
  '2:source format:'"($backends)" \
  '3:dest db file:_files' \
  '4:dest format:'"($backends)" && ret=0
return ret
