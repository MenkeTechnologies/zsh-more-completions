#compdef reloader
# Documentation: https://github.com/stakater/Reloader
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Reloader: Kubernetes controller that watches ConfigMaps/Secrets and restarts pods
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--auto-reload-all=[auto-reload all]:bool:(true false)' \
  '--auto-search-annotation=[auto search annotation]:annotation:' \
  '--search-match-annotation=[search match annotation]:annotation:' \
  '--reload-strategy=[reload strategy]:strategy:(env-vars annotations)' \
  '--reload-on-create=[reload on create]:bool:(true false)' \
  '--reload-on-delete=[reload on delete]:bool:(true false)' \
  '--reload-on-secret-update=[reload on secret update]:bool:(true false)' \
  '--reload-on-configmap-update=[reload on configmap update]:bool:(true false)' \
  '--enable-ha=[enable HA mode]:bool:(true false)' \
  '--namespace-selector=[namespace selector]:selector:' \
  '--resource-label-selector=[resource label selector]:selector:' \
  '--namespace=[namespace]:ns:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:fmt:(text json)' \
  '--metrics-address=[metrics address]:addr:' \
  '--enable-leader-election[enable leader election]' \
  '--leader-election-namespace=[leader election namespace]:ns:' \
  '*::reloader args:_files' && ret=0
return ret
