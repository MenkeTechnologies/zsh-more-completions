#compdef moon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build the project'
      'check:check the project for errors'
      'run:run the project'
      'test:run tests'
      'clean:clean build artifacts'
      'fmt:format source files'
      'info:show package info'
      'new:create a new project'
      'update:update dependencies'
      'upgrade:upgrade the toolchain'
      'version:print version'
      'doc:generate documentation'
      'coverage:generate coverage report'
    )
    _describe -t commands 'moon command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--verbose[enable verbose output]' \
          '--target=[target backend]:target:(wasm wasm-gc js native)' \
          '--source-dir=[source directory]:directory:_directories' \
          '--debug[build in debug mode]' \
          '--release[build in release mode]' \
          '--target-dir=[target directory]:directory:_directories' \
          '--serial[build serially]' && ret=0
        ;;
      (check)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--verbose[enable verbose output]' \
          '--target=[target backend]:target:(wasm wasm-gc js native)' \
          '--source-dir=[source directory]:directory:_directories' \
          '--debug[check in debug mode]' && ret=0
        ;;
      (run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--verbose[enable verbose output]' \
          '--target=[target backend]:target:(wasm wasm-gc js native)' \
          '--source-dir=[source directory]:directory:_directories' \
          '--debug[run in debug mode]' \
          '--release[run in release mode]' \
          '1:package name' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--verbose[enable verbose output]' \
          '--target=[target backend]:target:(wasm wasm-gc js native)' \
          '--source-dir=[source directory]:directory:_directories' \
          '--debug[test in debug mode]' \
          '--release[test in release mode]' \
          '--filter=[filter test cases by name]:pattern' \
          '--update[update test snapshots]' && ret=0
        ;;
      (clean)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-dir=[source directory]:directory:_directories' && ret=0
        ;;
      (fmt)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-dir=[source directory]:directory:_directories' \
          '--check[check if files are formatted]' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--lib[create a library project]' \
          '--name=[project name]:name' \
          '--path=[project path]:directory:_directories' \
          '1:project name' && ret=0
        ;;
      (doc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-dir=[source directory]:directory:_directories' \
          '--serve[serve documentation locally]' && ret=0
        ;;
      (coverage)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--source-dir=[source directory]:directory:_directories' \
          '--target=[target backend]:target:(wasm wasm-gc js native)' && ret=0
        ;;
      (update|upgrade|version|info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
