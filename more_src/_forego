#compdef forego

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:validate Procfile'
      'run:run a one-off command'
      'start:start the application'
      'version:display version'
    )
    _describe -t commands 'forego command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start)
        _arguments -s -S \
          '-e+[specify env file]:env file:_files' \
          '-f+[specify Procfile]:procfile:_files' \
          '-p+[base port number]:port' \
          '-c+[concurrency]:concurrency' \
          '-r[restart on exit]' \
          '-t+[shutdown timeout in seconds]:seconds' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-e+[specify env file]:env file:_files' \
          '*::command:_command_names -e' && ret=0
        ;;
    esac
    ;;
esac

return ret
