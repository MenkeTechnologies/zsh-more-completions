#compdef auth0

# Zsh completion for auth0 - Auth0 command line interface

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'actions:manage actions for extending Auth0 functionality'
  'apis:manage resource server APIs'
  'apps:manage applications'
  'branding:manage branding options'
  'domains:manage custom domains'
  'email:manage email templates and providers'
  'logs:view Auth0 logs'
  'login:authenticate with an Auth0 tenant'
  'logout:log out of a tenant session'
  'orgs:manage organizations'
  'protect:manage attack protection'
  'quickstarts:download a Quickstart sample app'
  'roles:manage roles'
  'rules:manage rules for a tenant'
  'tenants:manage configured tenants'
  'test:try out your Universal Login box and access tokens'
  'universal-login:manage Universal Login experience'
  'users:manage resources for users'
  'api:make authenticated API requests'
  'completion:generate shell completion script'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show auth0 version]' \
  '--json[output result in JSON]' \
  '--force[skip confirmation]' \
  '--no-color[disable colors]' \
  '--no-input[disable interactive prompts]' \
  '--debug[enable debug mode]' \
  '--tenant[specific tenant to use]:tenant:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'auth0 command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '--scopes[scopes to request]:scopes:' \
          '--domain[tenant domain]:domain:' \
          '--client-id[client ID]:id:' \
          '--client-secret[client secret]:secret:' && ret=0
        ;;
      (apps|apis|roles|users|orgs|actions|rules|logs|domains)
        _arguments '1:subcommand:(list create show update delete use search)' && ret=0
        ;;
      (test)
        _arguments \
          '1:subcommand:(login token)' \
          '--audience[audience for token]:audience:' \
          '--scopes[scopes]:scopes:' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (tenants)
        _arguments '1:subcommand:(list use add remove show open)' && ret=0
        ;;
    esac
    ;;
esac

return ret
