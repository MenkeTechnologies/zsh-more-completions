#compdef gdbserver
# _gdbserver-bin — GNU GDB remote stub (FSF); attach gdb to a running or new process over network/serial
# upstream: https://sourceware.org/gdb

_gdbserver-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--attach[attach to existing PID]' \
        '--multi[stay alive after debuggee exits]' \
        '--once[exit after first connection drops]' \
        '--debug[debug logging]' \
        '--remote-debug[print remote protocol]' \
        '--debug-format+[debug format]:fmt:(none all timestamps)' \
        '--disable-packet+[disable packet]:packet:' \
        '--disable-randomization[disable ASLR]' \
        '--no-disable-randomization[allow ASLR]' \
        '--wrapper+[wrapper program]:wrapper:_command_names -e' \
        '*::args:'
}

_gdbserver-bin "$@"
