#compdef armagetronad armagetronad-dedicated armagetron
# Documentation: https://manpages.debian.org/bookworm/armagetronad/armagetronad.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm armagetronad(6) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --dedicated/--input flags (not in armagetronad client;
# dedicated server is a separate binary armagetronad-dedicated).

# armagetronad: Armagetron Advanced 3D Tron lightcycle game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--doc[show full --help docstring]' \
  '--datadir[shared game data directory]:dir:_files -/' \
  '--userdatadir[per-user data directory]:dir:_files -/' \
  '--vardir[var dir (high scores etc.)]:dir:_files -/' \
  '--uservardir[user var dir]:dir:_files -/' \
  '--configdir[shared config dir]:dir:_files -/' \
  '--userconfigdir[user config dir]:dir:_files -/' \
  '--resourcedir[network resource cache]:dir:_files -/' \
  '--userresourcedir[user resource cache]:dir:_files -/' \
  '--autoresourcedir[auto-download resource dir]:dir:_files -/' \
  '--language[language]:lang:' \
  '--connect[server to connect to on start]:host:_hosts' \
  '--server[server to connect to on start]:host:_hosts' \
  '--debug[enable debugging output]' \
  '--prefix[print install prefix and exit]' && ret=0
return ret
