#compdef armagetronad armagetron

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--dedicated[dedicated server]' \
  '--connect=+[connect to server]:host:_hosts' \
  '--input=+[input file]:file:_files' \
  '--datadir=+[data dir]:dir:_files -/' \
  '--userdatadir=+[user data dir]:dir:_files -/' \
  '--vardir=+[var dir]:dir:_files -/' \
  '--configdir=+[config dir]:dir:_files -/' \
  '--language=+[language]:lang:' && ret=0

return ret
