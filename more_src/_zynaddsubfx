#compdef zynaddsubfx
# Documentation: https://github.com/zynaddsubfx/zynaddsubfx (doc/zynaddsubfx.1.txt)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated -A/--auto-save and -P/--preferred-port
# flags that do not appear in upstream zynaddsubfx.1. Added real
# -D/--dump and -M/--midi-learn options. Fixed -v as short for --version.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display command-line help and exit]' \
  '(- *)'{-v,--version}'[display version and exit]' \
  '(-l --load)'{-l,--load=}'[load a .xmz master file]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument=}'[load a .xiz instrument file]:file:_files -g "*.xiz"' \
  '(-M --midi-learn)'{-M,--midi-learn=}'[load a midi learn binding file]:file:_files -g "*.xlz"' \
  '(-r --sample-rate)'{-r,--sample-rate=}'[set the sample rate]:rate:(22050 44100 48000 88200 96000 192000)' \
  '(-b --buffer-size)'{-b,--buffer-size=}'[set the buffer size]:size:' \
  '(-o --oscil-size)'{-o,--oscil-size=}'[set the ADsynth oscillator size]:size:' \
  '(-S --swap)'{-S,--swap}'[swap left and right output channels]' \
  '(-D --dump)'{-D,--dump}'[dump midi note ON/OFF commands]' \
  '(-U --no-gui)'{-U,--no-gui}'[run without user interface]' \
  '(-N --named)'{-N,--named=}'[postfix IO name when possible]:name:' \
  '(-a --auto-connect)'{-a,--auto-connect}'[auto-connect when using JACK]' \
  '(-O --output)'{-O,--output=}'[set output engine]:engine:(jack alsa oss portaudio null)' \
  '(-I --input)'{-I,--input=}'[set input engine]:engine:(jack alsa oss portaudio null)' \
  '(-e --exec-after-init)'{-e,--exec-after-init=}'[run post-initialization command]:cmd:' \
  '*:session:_files' && ret=0

return ret
