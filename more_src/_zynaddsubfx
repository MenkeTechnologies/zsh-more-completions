#compdef zynaddsubfx

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-l --load)'{-l,--load}'+[load master file]:file:_files -g "*.xmz"' \
  '(-L --load-instrument)'{-L,--load-instrument}'+[load instrument]:file:_files -g "*.xiz"' \
  '(-r --sample-rate)'{-r,--sample-rate}'+[sample rate]:rate:(22050 44100 48000 88200 96000 192000)' \
  '(-b --buffer-size)'{-b,--buffer-size}'+[buffer size]:size:' \
  '(-o --oscil-size)'{-o,--oscil-size}'+[oscil size]:size:' \
  '(-S --swap)'{-S,--swap}'[swap stereo channels]' \
  '(-U --no-gui)'{-U,--no-gui}'[disable GUI]' \
  '(-N --named)'{-N,--named}'+[client name]:name:' \
  '(-a --auto-connect)'{-a,--auto-connect}'[auto connect JACK]' \
  '(-A --auto-save)'{-A,--auto-save}'+[autosave interval]:sec:' \
  '(-O --output)'{-O,--output}'+[output driver]:drv:(jack alsa oss portaudio null)' \
  '(-I --input)'{-I,--input}'+[input driver]:drv:(jack alsa oss portaudio null)' \
  '(-e --exec-after-init)'{-e,--exec-after-init}'+[exec cmd]:cmd:' \
  '(-P --preferred-port)'{-P,--preferred-port}'+[OSC port]:port:' \
  '*:session:_files' && ret=0

return ret
