#compdef haredoc
# Documentation: https://git.sr.ht/~sircmpwn/hare/tree/master/item/cmd/haredoc/main.ha
# Reference accessed: 2026-05-27
# Verified: upstream cmd/haredoc/main.ha getopt::help table

# haredoc: Hare documentation extractor. Short-only flags from getopt::help.
local curcontext="$curcontext" ret=1
_arguments -s \
  '-a[show undocumented members (only with -Ftty)]' \
  '-F+[output format]:format:(tty html)' \
  '-n[include file paths and line numbers]' \
  '-N[print symbol path and line number and exit]' \
  '-t[disable HTML template (requires postprocessing)]' \
  '*-T+[set/unset build tags]:tagset:' \
  '*:identifier or path:_files' && ret=0
return ret
