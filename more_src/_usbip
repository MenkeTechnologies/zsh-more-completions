#compdef usbip

# Zsh completion for usbip - USB/IP client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'attach:attach a remote USB device'
  'detach:detach an imported USB device'
  'list:list exportable or imported USB devices'
  'bind:bind device to usbip-host driver'
  'unbind:unbind device from usbip-host driver'
  'port:list imported devices/ports'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-l --log)'{-l,--log}'[log to syslog]' \
  '(-t --tcp-port)'{-t,--tcp-port}'[TCP port number]:port' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'usbip command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      attach)
        _arguments \
          '(-r --remote)'{-r,--remote}'[server hostname]:hostname:_hosts' \
          '(-b --busid)'{-b,--busid}'[bus ID of device]:bus_id' \
          '(-d --device)'{-d,--device}'[device ID]:device_id' && ret=0
        ;;
      detach)
        _arguments \
          '(-p --port)'{-p,--port}'[port number]:port' && ret=0
        ;;
      list)
        _arguments \
          '(-r --remote)'{-r,--remote}'[list exportable devices on remote]:hostname:_hosts' \
          '(-l --local)'{-l,--local}'[list local devices]' \
          '(-p --parsable)'{-p,--parsable}'[parsable output]' && ret=0
        ;;
      bind|unbind)
        _arguments \
          '(-b --busid)'{-b,--busid}'[bus ID of device]:bus_id' && ret=0
        ;;
    esac
    ;;
esac

return ret
