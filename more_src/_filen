#compdef filen
# Documentation: https://github.com/FilenCloudDienste/filen-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# npm package `@filen/cli`. Full subcommand list available via `filen --help`.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(--email)'--email='[account email]:email:' \
  '(--password)'--password='[account password]:password:' \
  '*::arguments:_default'
