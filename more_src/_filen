#compdef filen
# Documentation: https://man.archlinux.org/search?q=filen
# Reference accessed: 2026-05-16

# https://github.com/FilenCloudDienste/filen-cli — npm package `@filen/cli`

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(--email)'--email='[account email]:email:' \
  '(--password)'--password='[account password]:password:' \
  '*::arguments:_default'
