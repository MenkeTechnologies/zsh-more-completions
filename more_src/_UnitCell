#compdef UnitCell
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools UnitCell: reconstruct a crystal unit cell from a PDB asymmetric unit

local ret=1

_arguments -s -S \
  '-p[input PDB file]:file:_files -g "*.pdb"' \
  '-o[output PDB file]:file:_files -g "*.pdb"' \
  '*:file:_files' && ret=0

return ret
