#compdef rocksdb_ldb ldb

# rocksdb_ldb: RocksDB administration / debugging tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create_column_family:create a new column family'
  'drop_column_family:drop a column family'
  'list_column_families:list column families'
  'get:get a key'
  'put:put a key=value'
  'delete:delete a key'
  'merge:merge values for a key'
  'scan:scan keys'
  'dump:dump db'
  'dump_wal:dump WAL'
  'idump:internal dump'
  'compact:compact column family'
  'manifest_dump:dump MANIFEST'
  'file_checksum_dump:dump file checksums'
  'restore:restore from backup'
  'checkconsistency:check consistency'
  'list_file_range_deletes:list range tombstones'
  'wal_dump:dump WAL'
  'reduce_levels:reduce LSM levels'
  'change_compaction_style:change compaction style'
  'approxsize:approximate size'
  'batchput:batch put'
  'unsafe_remove_sst_file:remove SST file'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--db=[database directory]:dir:_files -/' \
  '--column_family=[column family]:cf:' \
  '--secondary_path=[secondary path]:dir:_files -/' \
  '--no_color[disable color]' \
  '--ttl[treat data as TTL]' \
  '--readonly[open read-only]' \
  '--hex[use hex keys/values]' \
  '--key_hex[hex keys]' \
  '--value_hex[hex values]' \
  '--try_load_options[try to load options from db]' \
  '--ignore_unknown_options[ignore unknown options]' \
  '--bloom_bits=[bloom bits]:n:' \
  '--compression_type=[compression type]:type:(snappy lz4 zlib zstd none)' \
  '--block_size=[block size]:bytes:' \
  '--auto_compaction=[auto compaction]:bool:(true false)' \
  '--from=[start key]:key:' \
  '--to=[end key]:key:' \
  '--max_keys=[max keys]:n:' \
  '--verbose[verbose]' \
  '--count_only[only count, no print]' \
  '--write_buffer_size=[write buffer size]:bytes:' \
  '--write_buffer_size_factor=[write buffer factor]:f:' \
  '--block_size=[block size]:bytes:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rocksdb_ldb command' commands && ret=0 ;;
esac
return ret
