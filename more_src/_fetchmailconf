#compdef fetchmailconf fetchmail-conf
# Documentation: man fetchmailconf(1)
# Source: fetchmail/fetchmail fetchmailconf.py (legacy_64) — Tkinter config editor for fetchmail (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[dump configuration (debug)]' \
    '-f+[alternate fetchmailrc file]:file:_files' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    && ret=0

return ret
