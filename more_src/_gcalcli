#compdef gcalcli

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--client-id=[OAuth client ID]:client id:' \
  '--client-secret=[OAuth client secret]:secret:' \
  '--config-folder=[config folder]:directory:_directories' \
  '--noauth-local-webserver[do not use local webserver for auth]' \
  '--calendar=[calendar to use]:calendar:' \
  '--allday-color=[color for all-day events]:color:' \
  '--default-color=[default output color]:color:' \
  '--military[use 24-hour time format]' \
  '--locale=[locale]:locale:' \
  '--refresh[refresh cached data]' \
  '--nocache[disable caching]' \
  '--conky[Conky output mode]' \
  '--nocolor[disable colors]' \
  '--lineart=[line art style]:style:(fancy unicode ascii)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:list calendars'
      'search:search for events'
      'agenda:show agenda'
      'calw:show week calendar'
      'calm:show month calendar'
      'quick:quick-add an event'
      'add:add a detailed event'
      'delete:delete an event'
      'edit:edit an event'
      'remind:set up reminders'
      'import:import events from ICS file'
    )
    _describe -t commands 'gcalcli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      agenda)
        _arguments -s -S \
          '--tsv[tab-separated output]' \
          '--details=[show details]:detail:(all calendar length location description url email attachments conference end)' \
          '--nostarted[hide started events]' \
          '--nodeclined[hide declined events]' \
          '--width=[set terminal width]:columns:' \
          '*:date range:' && ret=0
        ;;
      calw|calm)
        _arguments -s -S \
          '--monday[start week on Monday]' \
          '--noweekend[hide weekends]' \
          '--width=[set terminal width]:columns:' \
          '*:weeks or months:' && ret=0
        ;;
      add)
        _arguments -s -S \
          '--title=[event title]:title:' \
          '--when=[event start]:date/time:' \
          '--duration=[event duration]:minutes:' \
          '--where=[event location]:location:' \
          '--description=[event description]:description:' \
          '--calendar=[target calendar]:calendar:' \
          '--reminder=[reminder]:minutes:' \
          '--allday[all-day event]' \
          '--noprompt[do not prompt for confirmation]' && ret=0
        ;;
      quick)
        _arguments -s -S \
          '--calendar=[target calendar]:calendar:' \
          '1:quick add text:' && ret=0
        ;;
      search)
        _arguments -s -S \
          '--details=[show details]:detail:' \
          '*:search terms:' && ret=0
        ;;
      import)
        _arguments -s -S \
          '--calendar=[target calendar]:calendar:' \
          '1:ICS file:_files -g "*.ics"' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '--calendar=[target calendar]:calendar:' \
          '--iamaexpert[do not prompt for confirmation]' \
          '*:search terms:' && ret=0
        ;;
    esac
    ;;
esac

return ret
