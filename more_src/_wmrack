#compdef wmrack
# Documentation: https://manpages.debian.org/bookworm/wmrack/wmrack.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm wmrack(1) manpage OPTIONS list.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -display/-bg/-fg/-position/-version flags (real options
# are -b/--background, -l/--ledcolor, etc.).

# wmrack: WindowMaker CD player + mixer dockapp
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --background)'{-b,--background}'[background color]:color:' \
  '(-d --device)'{-d,--device}'[CD device (default /dev/cdrom)]:dev:_files' \
  '(-l --ledcolor)'{-l,--ledcolor}'[LED color]:color:' \
  '(-m --mixer)'{-m,--mixer}'[mixer device (default /dev/mixer)]:dev:_files' \
  '(-p --noprobe)'{-p,--noprobe}'[do not probe device]' \
  '(-s --style)'{-s,--style}'[style file]:file:_files' \
  '(-w --withdrawn)'{-w,--withdrawn}'[run withdrawn (for FVWM/etc.)]' \
  '(-M --mode)'{-M,--mode}'[startup mode]:mode:(cdrom mixer)' && ret=0
return ret
