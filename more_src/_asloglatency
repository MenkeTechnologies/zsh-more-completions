#compdef asloglatency
# Documentation: https://aerospike.com/docs/database/tools/asloglatency/
# asloglatency - analyze latency histograms from Aerospike log files

local ret=1

_arguments -s -S \
  '(-l --log)'{-l,--log}'=[log file to analyze]:file:_files' \
  '(-h --histogram)'{-h,--histogram}'=[histogram name to analyze]:histogram:' \
  '(-t --slice)'{-t,--slice}'=[analysis slice interval]:interval:' \
  '(-f --from)'{-f,--from}'=[log time from which to analyze]:from:' \
  '(-d --duration)'{-d,--duration}'=[maximum duration to analyze]:duration:' \
  '(-n --num_buckets)'{-n,--num_buckets}'=[number of buckets to display]:count:' \
  '(-e --every_nth)'{-e,--every_nth}'=[show 0-th then every n-th bucket]:n:' \
  '(-r --rolling)'{-r,--rolling}'[roll until user hits return or ctrl-c]' && ret=0

return ret
