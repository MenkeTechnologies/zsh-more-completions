#compdef hy

# Zsh completion for Hy - Lisp dialect that runs on Python

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[program passed as string]:code' \
  '-m+[run library module as script]:module' \
  '-E[ignore PYTHON* environment variables]' \
  '-B[do not write bytecode files]' \
  '-i[inspect interactively after running script]' \
  '--spy[print equivalent Python code]' \
  '--repl-output-fn=[function for REPL output]:function' \
  '*:script:_files -g "*.hy"' && ret=0

return ret
