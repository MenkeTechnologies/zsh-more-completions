#compdef qmail-tcpto
# _qmail-tcpto — qmail's IP timeout-cache reader (prints qmail-remote's current list of SMTP-connect-timeout IPs; must run as root or user qmailr+group qmail)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-tcpto.8 on tip; no flags.

_qmail-tcpto() {
    _arguments '(- *)-h[show help]'
}

_qmail-tcpto "$@"
