#compdef deps-try
# Documentation: https://github.com/eval/deps-try
# Try Clojure libraries in a rebel-readline REPL

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help/usage]' \
  '-v[show version information]' \
  '--recipe+[name, file path or url of a recipe to seed the REPL]:recipe:_files' \
  '--recipe-ns+[name, file path or url of a recipe using namespace steps]:recipe:_files' \
  '*::deps:->deps' && ret=0

case $state in
  deps)
    if (( CURRENT == 1 )); then
      _alternative 'commands:command:(recipes)' 'deps:dependency:'
      ret=0
    fi
    ;;
esac

return ret
