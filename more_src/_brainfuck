# brainfuck - Brainfuck interpreter written in C (fabianishere)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-e --eval)'{-e,--eval}'=[evaluate code string]:code:' \
  '*:file:_files'
