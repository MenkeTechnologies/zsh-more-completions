#compdef amplify

# Zsh completion for AWS Amplify CLI

_amplify() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'init:initialize a new Amplify project'
    'configure:configure the CLI or project'
    'push:provision cloud resources'
    'pull:fetch upstream changes'
    'publish:build and deploy the frontend and backend'
    'serve:start a local development server'
    'status:show the state of local resources'
    'delete:delete the Amplify project and all resources'
    'add:add resources to the backend'
    'update:update an existing resource'
    'remove:remove a resource from the backend'
    'env:manage environments'
    'hosting:manage hosting resources'
    'storage:manage storage resources'
    'api:manage API resources'
    'auth:manage auth resources'
    'function:manage Lambda function resources'
    'notifications:manage notification resources'
    'analytics:manage analytics resources'
    'predictions:manage predictions resources'
    'interactions:manage interactions resources'
    'codegen:generate client-side code'
    'console:open the Amplify console'
    'logout:log out of the Amplify CLI'
    'login:log in to the Amplify CLI'
    'override:override Amplify-generated resources'
    'diagnose:run a diagnostic check'
    'export:export Amplify CLI generated backends'
    'uninstall:uninstall the Amplify CLI'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'amplify command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        init)
          _arguments -s -S \
            '--app=[Amplify App ID]:app ID:' \
            '--envName=[environment name]:environment:' \
            '--yes[accept defaults]' \
            '--amplify=[Amplify project config as JSON]:config:' \
            '--frontend=[frontend config as JSON]:config:' \
            '--providers=[provider config as JSON]:config:' \
            && ret=0
          ;;
        push)
          _arguments -s -S \
            '--yes[automatically accept changes]' \
            '--force[override all config changes]' \
            '--allow-destructive-graphql-schema-updates[allow destructive schema updates]' \
            '--codegen=[codegen configuration]:config:' \
            && ret=0
          ;;
        pull)
          _arguments -s -S \
            '--appId=[Amplify App ID]:app ID:' \
            '--envName=[environment name]:environment:' \
            '--yes[accept defaults]' \
            '--restore[restore backend environment]' \
            && ret=0
          ;;
        add)
          _arguments -s -S \
            '1:category:(api auth function storage hosting analytics predictions interactions notifications geo custom)' \
            && ret=0
          ;;
        update)
          _arguments -s -S \
            '1:category:(api auth function storage hosting analytics predictions interactions notifications)' \
            && ret=0
          ;;
        remove)
          _arguments -s -S \
            '1:category:(api auth function storage hosting analytics predictions interactions notifications)' \
            && ret=0
          ;;
        env)
          _arguments -s -S \
            '1:subcommand:(add checkout get import list pull remove)' \
            && ret=0
          ;;
        configure)
          _arguments -s -S \
            '1:target:(project hosting codegen)' \
            && ret=0
          ;;
        codegen)
          _arguments -s -S \
            '1:subcommand:(add configure statements types models)' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            '-y[answer yes to all prompts]' \
            '--yes[answer yes to all prompts]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_amplify "$@"
