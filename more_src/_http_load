#compdef http_load
# Documentation: https://www.acme.com/software/http_load/
# http_load - multiprocessing http test client / load generator

local ret=1

_arguments -s -S \
  '-checksum[compute checksums on files fetched to verify integrity]' \
  '-throttle[throttle data consumption to 33.6Kbps to simulate modem users]' \
  '-proxy[run through a web proxy host:port]:proxy:' \
  '-verbose[progress reports every minute on stderr]' \
  '-timeout[idle connection timeout in seconds]:secs:' \
  '-sip[file with numeric source IP addresses]:file:_files' \
  '-cipher[SSL cipher set]:cipher:' \
  '-parallel[keep N parallel fetches going simultaneously]:N:' \
  '-rate[start N new connections each second]:N:' \
  '-jitter[vary the rate randomly by about 10 percent]' \
  '-fetches[quit when N fetches have completed]:N:' \
  '-seconds[quit after N seconds have elapsed]:N:' \
  '*:url file:_files' && ret=0

return ret
