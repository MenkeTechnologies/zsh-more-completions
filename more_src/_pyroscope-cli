#compdef pyroscope-cli pyroscope

# pyroscope-cli: profile/adopt commands for Pyroscope continuous profiling
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'adhoc:run an adhoc profile run'
  'agent:run as a sampling agent'
  'connect:connect to an existing process'
  'exec:start a process under profiling'
  'admin:admin commands'
  'server:run the pyroscope server'
  'convert:convert profile formats'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--log-level=[log level]:level:(error warn info debug trace)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pyroscope command' commands && ret=0 ;;
esac
return ret
