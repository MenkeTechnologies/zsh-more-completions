#compdef pdb_selresname
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Selects all residues matching the given name(s), e.g. -ALA or -ASP,GLU

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residue name(s) to select, e.g. -ALA,GLU]:residue name' \
  '*:PDB file:_files' && ret=0

return ret
