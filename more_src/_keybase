#compdef keybase

# completions for Keybase CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--home=[set home directory]:directory:_directories' \
  '--log-format=[log format]:format:(default plain file)' \
  '--api-uri-path-prefix=[API URI path prefix]:prefix' \
  '--use-default-log-file[use default log file location]' \
  '--debug[enable debug mode]' \
  '*::args:->subcmds' && ret=0

case $state in
  subcmds)
    local -a commands
    commands=(
      'account:manage account settings'
      'base62:base62 encoding/decoding'
      'blocks:manage user blocks'
      'bot:manage bot tokens'
      'chat:send and read chat messages'
      'config:get and set configuration options'
      'ctl:control the background services'
      'currency:manage cryptocurrency addresses'
      'decrypt:decrypt messages or files'
      'device:manage your devices'
      'dismiss:dismiss notifications'
      'dump-keyfamily:dump key family'
      'dump-push-notifications:dump push notifications'
      'encrypt:encrypt messages or files'
      'follow:follow a user'
      'fs:perform filesystem operations'
      'git:manage git repos'
      'id:identify a user'
      'list-followers:list followers'
      'list-following:list users you follow'
      'log:manage log settings'
      'login:log in to Keybase'
      'logout:log out of Keybase'
      'oneshot:establish a temporary device'
      'paperkey:generate a new paper key'
      'passphrase:change or recover your passphrase'
      'pgp:manage PGP keys'
      'ping:ping the keybase API'
      'prove:generate a new proof'
      'rekey:show rekey status'
      'search:search for users'
      'sign:sign a document'
      'signup:sign up for a new account'
      'sigs:manage signatures'
      'status:show current status'
      'team:manage teams'
      'unfollow:unfollow a user'
      'update:check for updates'
      'verify:verify a signed message'
      'version:show version info'
      'wallet:manage your Stellar wallet'
    )
    _describe -t commands 'keybase command' commands && ret=0
    ;;
esac

return ret
