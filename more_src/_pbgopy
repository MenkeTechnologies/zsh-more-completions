#compdef pbgopy

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'copy:copy data to the server'
  'paste:paste data from the server'
  'serve:start the pbgopy server'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'pbgopy command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      copy)
        _arguments -s -S \
          '--server=[server address]:address' \
          '--password=[password for encryption]:password' \
          '--basic-auth=[basic auth credentials]:user\:pass' \
          '--max-body-size=[max body size]:size' && ret=0
        ;;
      paste)
        _arguments -s -S \
          '--server=[server address]:address' \
          '--password=[password for decryption]:password' \
          '--basic-auth=[basic auth credentials]:user\:pass' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '--port=[port to listen on]:port' \
          '--address=[bind address]:address' \
          '--ttl=[data time-to-live]:duration' \
          '--max-body-size=[max body size]:size' \
          '--basic-auth=[basic auth credentials]:user\:pass' && ret=0
        ;;
    esac
    ;;
esac

return ret
