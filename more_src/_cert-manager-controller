#compdef cert-manager-controller
# Documentation: https://cert-manager.io/docs/cli/controller/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cert-manager-controller: cert-manager controller manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[ControllerConfiguration file]:file:_files' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--master=[Kubernetes API server URL]:url:' \
  '--namespace=[restrict to single namespace]:ns:' \
  '--cluster-resource-namespace=[namespace for cluster-scoped resources]:ns:' \
  '--leader-elect[enable leader election]' \
  '--leader-election-namespace=[leader election namespace]:ns:' \
  '--leader-election-lease-duration=[lease duration]:duration:' \
  '--leader-election-renew-deadline=[renew deadline]:duration:' \
  '--leader-election-retry-period=[retry period]:duration:' \
  '--controllers=[list of controllers to enable]:list:' \
  '--metrics-listen-address=[metrics listen addr]:addr:' \
  '--metrics-resource-labels=[metrics resource labels]:list:' \
  '--enable-profiling[enable Go profiler]' \
  '--profiler-address=[Go profiler listen address]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '--max-concurrent-challenges=[max concurrent challenges]:n:' \
  '--dns01-recursive-nameservers=[DNS-01 recursive nameservers]:list:' \
  '--dns01-recursive-nameservers-only[only use recursive ns for DNS-01]' \
  '--dns01-check-retry-period=[DNS-01 propagation check retry period]:duration:' \
  '--acme-http01-solver-image=[ACME HTTP-01 solver image]:image:' \
  '--acme-http01-solver-resource-request-cpu=[CPU request]:value:' \
  '--acme-http01-solver-resource-request-memory=[mem request]:value:' \
  '--acme-http01-solver-resource-limits-cpu=[CPU limit]:value:' \
  '--acme-http01-solver-resource-limits-memory=[mem limit]:value:' \
  '--acme-http01-solver-run-as-non-root[run solver pods as non-root]' \
  '--acme-http01-solver-nameservers=[solver DNS nameservers]:list:' \
  '--auto-certificate-annotations=[annotations triggering certificate requests]:list:' \
  '--certificate-request-minimum-backoff-duration=[initial retry delay]:duration:' \
  '--enable-certificate-owner-ref[clean up secrets when certificate is deleted]' \
  '--cluster-issuer-ambient-credentials[allow ClusterIssuer ambient credentials]' \
  '--default-issuer-name=[default issuer name]:name:' \
  '--default-issuer-kind=[default issuer kind]:kind:(Issuer ClusterIssuer)' \
  '--default-issuer-group=[default issuer group]:group:' \
  '--copied-annotation-prefixes=[copied annotation prefixes]:list:' \
  '--logging-format=[log format]:fmt:(text json)' \
  '(-v --v)'{-v+,--v=}'[log verbosity]:n:' \
  '*::cert-manager-controller args:_files' && ret=0
return ret
