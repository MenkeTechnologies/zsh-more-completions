#compdef identd
# _identd — OpenBSD identd (RFC 1413 Identification Protocol server; maps TCP connection 4-tuples to the username of the process that owns the local endpoint, optionally only over IPv4 or IPv6)
# upstream: https://github.com/openbsd/src (usr.sbin/identd)
# Flags from usr.sbin/identd/identd.8 on tip.

_identd() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-d[debug (foreground + stderr)]' \
        '-e[return ERROR responses without subtype]' \
        '-H[hide username in responses]' \
        '-h[opaque hashed username]' \
        '-N[return NO-USER hidden]' \
        '-n[numeric response (UID instead of username)]' \
        '-l+[bind address]:address:' \
        '-t+[connection timeout (seconds)]:seconds:'
}

_identd "$@"
