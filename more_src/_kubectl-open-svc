#compdef kubectl-open-svc
# kubectl-open-svc (krew plugin): open a Kubernetes service in your browser
# https://github.com/superbrothers/kubectl-open-svc-plugin

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--schema=[URL scheme]:scheme:(http https)' \
  '--port=[port to use]:port' \
  '--url[only print the URL, do not open the browser]' \
  '1:service name'
