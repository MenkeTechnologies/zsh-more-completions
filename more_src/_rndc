#compdef rndc

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'addzone:add a zone'
  'delzone:delete a zone'
  'modzone:modify a zone'
  'showzone:show zone configuration'
  'zonestatus:show zone status'
  'reload:reload configuration and zones'
  'reconfig:reload configuration only'
  'refresh:schedule zone maintenance'
  'retransfer:retransfer a zone'
  'freeze:suspend dynamic updates'
  'thaw:enable dynamic updates'
  'sync:dump in-memory journal to disk'
  'flush:flush DNS cache'
  'flushname:flush a name from cache'
  'flushtree:flush a name and below from cache'
  'halt:stop server without saving'
  'stop:stop server saving updates'
  'status:show server status'
  'dumpdb:dump cache to file'
  'trace:increase debug level'
  'notrace:reset debug level to 0'
  'nta:manage negative trust anchors'
  'querylog:toggle query logging'
  'recursing:dump recursing queries'
  'secroots:dump security roots'
  'validation:enable/disable DNSSEC validation'
  'managed-keys:manage trusted keys'
  'signing:control auto-DNSSEC signing'
  'sign:resign a zone'
  'loadkeys:load DNSSEC keys'
  'dnssec:DNSSEC management'
  'notify:send notify messages'
  'scan:rescan network interfaces'
  'stats:write statistics'
  'serve-stale:control serve-stale behavior'
  'tcp-timeouts:show or set TCP timeouts'
  'tsig-list:list TSIG keys'
  'tsig-delete:delete a TSIG key'
  'dnstap:control dnstap'
  'restart:restart the server'
)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-b=[source address]:addr:' \
  '-c=[config file]:file:_files' \
  '-k=[key file]:file:_files' \
  '-p=[port]:port:' \
  '-q[quiet]' \
  '-r[no retry]' \
  '-s=[server]:server:_hosts' \
  '-y=[key id]:keyid:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rndc subcommand' subcommands && ret=0
    ;;
esac

return ret
