#compdef bedit
# Documentation: https://github.com/bwhmather/bedit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bedit: a stripped-down fork of GNOME gedit for tiling window managers

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--help-all[show all help options]' \
  '(-s --standalone)'{-s,--standalone}'[run in standalone mode]' \
  '--new-window[create a new top-level window]' \
  '--new-document[create a new document]' \
  '--wait[open files and block process until they are closed]' \
  '(-b --background)'{-b,--background}'[run bedit in the background]' \
  '*:file:_files' && ret=0
return ret
