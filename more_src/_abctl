#compdef abctl

_abctl() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Show context-sensitive help]'
        '(-v --verbose)'{-v,--verbose}'[Enable verbose (debug) output]'
    )

    subcmds=(
        'local:Manage the local Airbyte instance'
        'images:Manage Docker images used by Airbyte'
        'version:Displays the version information for the abctl tool'
        'completion:Generate the autocompletion script for the specified shell'
        'help:Help about any command'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'abctl commands' subcmds
            ;;
        args)
            case $line[1] in
                local)
                    local -a local_subcmds
                    local_subcmds=(
                        'install:Installs or updates a local Airbyte instance'
                        'status:Displays the current status of the local Airbyte installation'
                        'credentials:Manages login credentials'
                        'deployments:Manages the underlying Kubernetes (Kind) deployment'
                        'uninstall:Removes the local Airbyte instance'
                    )
                    _describe -t commands 'local subcommands' local_subcmds
                    ;;
                images)
                    local -a images_subcmds
                    images_subcmds=(
                        'manifest:Generates a manifest of all Docker images required'
                    )
                    _describe -t commands 'images subcommands' images_subcmds
                    ;;
            esac
            ;;
    esac
}

_abctl "$@"
