#compdef wcsmosaic
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss207.html
# KAPPA: tiles a group of NDFs using World Co-ordinate System information

local ret=1

_arguments -s \
  'IN=[input NDFs]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'REF=[reference NDF for alignment]:ndf:_files -g "*.sdf"' \
  'ACC=[positional accuracy in pixels]:value' \
  'ALIGNREF=[align in reference coordinate system]:bool:(TRUE FALSE)' \
  'CONSERVE=[conserve total data value]:bool:(TRUE FALSE)' \
  'GENVAR=[generate output variances from spread]:bool:(TRUE FALSE)' \
  'LBND=[lower pixel bounds of output]:bounds' \
  'UBND=[upper pixel bounds of output]:bounds' \
  'MAXPIX=[initial scale size in pixels]:n' \
  'METHOD=[rebinning method]:method' \
  'NORM=[normalise by contributing pixels]:bool:(TRUE FALSE)' \
  'PARAMS=[additional interpolation parameters]:params' \
  'VARIANCE=[use input variances for weighting]:bool:(TRUE FALSE)' \
  'WEIGHTS=[weights per input NDF]:weights' \
  'WLIM=[min good pixels per output pixel]:frac' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
