#compdef cmuwmtopbm
# Documentation: man cmuwmtopbm (Netpbm)
# Source: convert a CMU window-manager bitmap to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:cmuwm file:_files' \
    && ret=0

return ret
