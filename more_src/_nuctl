#compdef nuctl
# Documentation: https://man.archlinux.org/search?q=nuctl
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace' \
  '(-k --kubeconfig)'{-k,--kubeconfig}'=[kubeconfig path]:file:_files' \
  '--platform=[nuclio platform]:platform:(auto kube local)' \
  '--concurrency=[parallel patch limit]:count' \
  '--mask-sensitive-fields[mask sensitive fields in logs]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'build:build function artifacts'
      'deploy:deploy a function'
      'invoke:invoke a deployed function'
      'get:list functions or projects'
      'delete:delete resources'
      'update:update resource fields'
      'version:print version'
      'create:create resources'
      'export:export functions or projects'
      'import:import functions from cluster'
      'beta:experimental commands'
      'parse:parse a function spec'
    )
    _describe -t commands 'nuctl command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
