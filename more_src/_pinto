#compdef pinto
# ============================================================================
#  _pinto — Pinto: curated Perl module repository manager (private CPAN)
#
#  Source-direct extraction from
#    https://github.com/thaljef/Pinto/blob/master/lib/App/Pinto.pm
#    https://github.com/thaljef/Pinto/blob/master/lib/App/Pinto/Command.pm
#    https://github.com/thaljef/Pinto/tree/master/lib/App/Pinto/Command/
#    https://metacpan.org/dist/App-Cmd (the App::Cmd library by
#    Ricardo Signes / RJBS)
#
#  Maintained by Jeffrey Thalhammer (thaljef/Pinto).  Pinto creates
#  and manages CURATED PERL MODULE REPOSITORIES — basically a private
#  CPAN that you control.  Pull modules from public CPAN into your
#  repo, pin specific versions, manage multiple "stacks" (named
#  collections of pinned versions for different deployments), share
#  the repo over HTTP via `pintod`, and serve cpanm/cpm clients from
#  your private mirror.  Used by enterprises with strict CPAN version
#  control needs and CI/CD pipelines that need reproducible Perl
#  module installations.  Sister tools: stratopan (commercial private
#  CPAN service), MyCPAN::App::DPAN (DPAN mirroring), CPAN::Mini
#  (mirror), Carton (in corpus via _carton — like Bundler for Perl),
#  cpanm (in corpus via _cpanm).
#
#  CLI library taxonomy update: 2nd Perl CLI library — Ricardo Signes's
#  **App::Cmd** (rjbs/App-Cmd).  Perl ecosystem now has 2 documented
#  CLI libraries (R281 Getopt::Long + R384 App::Cmd).
#
#  App::Cmd (rjbs/App-Cmd) is Ricardo Signes's COMMAND SUITE framework
#  for Perl — designed for building applications with multiple named
#  subcommands like `git`, `cpan`, `dzil`.  Distinct from Getopt::Long
#  (single-command flag parsing) by providing a FULL FRAMEWORK with
#  command dispatch, per-command option specs, plugin system, and
#  command discovery via Perl's module loading.  Used by `dzil`
#  (Dist::Zilla, Perl module dist tool — IN CORPUS via _dzil),
#  Pinto (private CPAN repo manager), perlrdf (RDF triple store),
#  HMMER2GO (bioinformatics), Phylosift (phylogenomic analysis),
#  Cyrus-IMAPd tools, UDPerl (UDP relay), and many CPAN tools that
#  need a `cmd subcmd [opts] args` style interface.
#
#  App::Cmd API:
#    # Main application class:
#    package App::Foo;
#    use App::Cmd::Setup -app;
#
#    sub global_opt_spec {
#      return (
#        [ 'verbose|v+'   => 'Increase verbosity (repeatable)' ],
#        [ 'config|c=s'   => 'Config file path' ],
#        [ 'color|colour!' => 'Colorize output (negatable)' ],
#      );
#    }
#
#    # Each subcommand is its own module:
#    package App::Foo::Command::build;
#    use App::Cmd::Setup -command;
#
#    sub opt_spec {
#      my ($class, $app) = @_;
#      return (
#        [ 'output|o=s'  => 'Output file' ],
#        [ 'target=s@'   => 'Build targets (repeatable)' ],
#        [ 'release!'    => 'Release mode (negatable)' ],
#        [ 'jobs|j=i'    => 'Number of parallel jobs' ],
#      );
#    }
#
#    sub abstract { "build the project" }
#    sub usage_desc { "%c build %o [files...]" }
#
#    sub validate_args {
#      my ($self, $opt, $args) = @_;
#      $self->usage_error("need at least one file") unless @$args;
#    }
#
#    sub execute {
#      my ($self, $opt, $args) = @_;
#      # ... do the work
#    }
#
#    # The entry script:
#    use App::Foo;
#    App::Foo->run;
#
#  App::Cmd distinctive features:
#    - COMMAND SUITE FRAMEWORK — designed for `cmd subcmd [opts]
#      args` style tools (git/svn/cpan/dzil pattern)
#    - `use App::Cmd::Setup -app` in main class — auto-discovers
#      subcommand modules via Perl module loading
#    - `use App::Cmd::Setup -command` in subcommand modules — sets
#      up the subcommand base class with App::Cmd::Command
#    - SUBCOMMAND AUTO-DISCOVERY — Pinto creates `App::Pinto::Command::add`,
#      `App::Pinto::Command::clean`, etc., and App::Cmd finds them all
#      automatically via Perl's `Module::Pluggable`-style namespace
#      scanning
#    - `global_opt_spec` METHOD — returns ARRAY of `[ 'spec' =>
#      'description' ]` pairs for GLOBAL options applying to ALL
#      subcommands
#    - `opt_spec` METHOD per-subcommand — returns ARRAY of `[ 'spec'
#      => 'description' ]` pairs for command-specific options
#    - SPEC SYNTAX from Getopt::Long::Descriptive (Perl convention):
#      `'option|alias=type'` where:
#      * `option` — long name (becomes `--option`)
#      * `|alias` — short name or additional alias (`|m` adds `-m`)
#      * `=s` — takes STRING value
#      * `=i` — takes INTEGER value
#      * `=f` — takes FLOAT value
#      * `=s@` — REPEATABLE string (collect into array)
#      * `=i@` — repeatable integer
#      * `=s%` — KEY=VALUE pairs (hash)
#      * `!` — NEGATABLE boolean (--option / --no-option)
#      * `+` — INCREMENTABLE counter (e.g. `-vvv` = 3)
#      * (no suffix) — boolean flag
#    - DESCRIPTION as second tuple element — shown in `--help` output
#    - `abstract` METHOD — short description of subcommand
#    - `usage_desc` METHOD — usage line template with `%c` (program
#      name) and `%o` (options string) interpolation
#    - `validate_args($opt, $args)` METHOD — VALIDATION HOOK before
#      `execute`; call `$self->usage_error("msg")` to abort with
#      usage display
#    - `execute($opt, $args)` METHOD — main command body
#    - `args_attribute` METHOD — sets the name for remaining positional
#      args (e.g. "archives", "files", "stacks")
#    - `args_from_stdin` METHOD — return true to read positional args
#      from STDIN when none given on CLI
#    - `$app->global_options` — hash of parsed global options
#    - `$self->opt_spec` — access to declared option specs
#    - PLUGINS via `use App::Cmd::Setup -app => { plugins => [...] }`
#      — e.g. `Prompt` plugin for interactive prompts
#    - AUTO-GENERATED `help` SUBCOMMAND — `pinto help` and `pinto help
#      SUBCMD` show formatted help
#    - AUTO-GENERATED `commands` SUBCOMMAND — `pinto commands` lists
#      all available subcommands
#    - PROCESS EXIT model — App::Cmd handles exit codes from `execute`
#      return value; calls `exit` automatically
#  Distinct from R281 Perl Getopt::Long (stdlib LOW-LEVEL imperative
#  `GetOptions("verbose+" => \$verbose)` — no subcommands, just flag
#  parsing), R357 Go mitchellh/cli (Go Cmd interface), R343 commander.js
#  (JS fluent builder), R322 Java JCommander (annotations + reflection),
#  R379 Ruby gli (`extend GLI::App` module + `command :name do |c|
#  ... end` block), R275 Rust clap-derive (Rust struct + macros),
#  R270 Haskell optparse-applicative (Haskell applicative combinator
#  with subparsers).  App::Cmd's approach: COMMAND SUITE FRAMEWORK
#  via `use App::Cmd::Setup -app` / `-command` ROLES + SUBCOMMAND AUTO-
#  DISCOVERY via PERL MODULE NAMESPACE SCANNING + `global_opt_spec` /
#  `opt_spec` METHODS returning GETOPT-LONG-DESCRIPTIVE specs + `=s` /
#  `=i` / `=s@` / `!` / `+` SUFFIX SYNTAX for VALUE TYPES + `abstract`/
#  `usage_desc`/`validate_args`/`execute` METHOD HIERARCHY + `args_attribute`/
#  `args_from_stdin` POSITIONAL HOOKS + AUTO-GENERATED `help` and
#  `commands` SUBCOMMANDS + PLUGIN SYSTEM via `-app => { plugins =>
#  [...] }` — corpus's **first documented command-suite-framework-
#  with-subcommand-auto-discovery Perl CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 123; Perl ecosystem
#  now has 2 documented CLI libraries.
#
#  Surface (verbatim from `lib/App/Pinto.pm` `global_opt_spec` and
#  `lib/App/Pinto/Command/*.pm` files):
#
#  Global options (apply to all subcommands):
#    -r, --root PATH                Path to repository root (env
#                                   PINTO_REPOSITORY_ROOT)
#        --color, --colour          Colorize output (negatable:
#                                   --no-color disables)
#    -p, --password PASS            Password for server auth
#                                   (use `-` to prompt)
#    -q, --quiet                    Only report fatal errors
#    -u, --username USER            Username for server auth
#    -v, --verbose                  More diagnostic output
#                                   (REPEATABLE: -vvv = level 3)
#
#  Subcommands (each is App::Pinto::Command::NAME):
#    add ARCHIVE...                 Add local archives to the repo
#    clean                          Remove orphaned distributions
#    copy STACK NEW_STACK           Copy a stack
#    default STACK                  Mark stack as default
#    delete ARCHIVE...              Delete archives from repo
#    diff STACK_A STACK_B           Show differences between stacks
#    help [SUBCMD]                  Show help (auto-generated by App::Cmd)
#    init                           Initialize a new repository
#    install MODULE...              Install modules into local Perl
#    kill STACK                     Permanently kill a stack
#    list                           List packages in the stack
#    lock STACK                     Lock a stack (read-only)
#    log                            Show stack revision log
#    look                           Show package details
#    manual                         Show the Pinto manual
#    merge SRC_STACK DST_STACK      Merge changes between stacks
#    migrate                        Migrate repository to new format
#    new STACK                      Create a new empty stack
#    nop                            No-op (testing/healthcheck)
#    pin TARGET                     Pin a package to specific version
#    props                          Show repository properties
#    pull TARGET                    Pull packages from upstream CPAN
#    register TARGET                Register packages on a stack
#    rename SRC NEW_NAME            Rename a stack
#    reset                          Reset a stack to previous revision
#    revert                         Revert to previous stack revision
#    roots                          Show root packages
#    stacks                         List all stacks
#    statistics                     Show repository statistics
#    thanks                         Show acknowledgements (easter egg)
#    unlock STACK                   Unlock a previously locked stack
#    unpin TARGET                   Unpin a previously pinned package
#    unregister TARGET              Unregister a previously registered
#                                   package from a stack
#    update                         Update all packages from upstream
#    verify                         Verify repository integrity
#    commands                       List all available subcommands
#                                   (auto-generated by App::Cmd)
#
#  Subcommand-specific options (e.g. `pinto add ARCHIVE...`):
#    --author=ID                    Archive author ID
#    --cascade                      Always pick latest upstream
#    --diff-style=STYLE             Diff report style
#    --dry-run                      Do not commit changes
#    -m, --message=MSG              Commit message
#    --no-fail                      Do not fail on error
#    -x, --no-index=PKG             Do not index matching packages
#                                   (REPEATABLE)
#    --recurse / --no-recurse       Recursively pull prereqs (NEGATABLE)
#    --pin                          Pin packages to stack
#    -k, --skip-missing-prerequisite=PKG
#                                   Skip missing prereq (REPEATABLE)
#    -K, --skip-all-missing-prerequisites
#                                   Skip all missing prereqs
#    -s, --stack=STACK              Put packages into this stack
#    -M, --use-default-message      Use generated commit message
#    --with-development-prerequisites, --wd
#                                   Also pull dev prereqs
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also App::Cmd users):
#    - dzil / Dist::Zilla (IN CORPUS via _dzil — RJBS's Perl module
#      distribution tool, uses App::Cmd; already documented under
#      different attribution; flagship App::Cmd use case)
#    - carton (IN CORPUS via _carton — like Bundler for Perl;
#      uses Getopt::Long not App::Cmd)
#    - cpanm (IN CORPUS via _cpanm — Perl module installer;
#      uses Getopt::Long)
#    - perlbrew / plenv (IN CORPUS — Perl version managers; use
#      hand-rolled CLI dispatch)
#    - perltidy / perlcritic / perldoc (IN CORPUS — use Getopt::Long
#      not App::Cmd)
#    - mojo (IN CORPUS via _mojo — Mojolicious commands; uses
#      Mojolicious::Commands custom dispatch not App::Cmd)
#    - stratopan (CLEAR — commercial private CPAN service; smaller
#      community than Pinto)
#    - perlrdf (gitpan/App-perlrdf — RDF triple store CLI, uses
#      App::Cmd; smaller community)
#    - cpan-outdated (App::cpanoutdated — uses Getopt::Long not
#      App::Cmd)
# ============================================================================

_pinto() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-r --root)'{-r,--root}'=[repository root path]:path:_directories' \
    '--color[colorize output]' \
    '--colour[colorize output]' \
    '--no-color[disable color]' \
    '--no-colour[disable colour]' \
    '(-p --password)'{-p,--password}'=[password for server auth (- to prompt)]:password' \
    '(-q --quiet)'{-q,--quiet}'[only report fatal errors]' \
    '(-u --username)'{-u,--username}'=[username for server auth]:user:_users' \
    '*'{-v,--verbose}'[increase diagnostic verbosity (repeatable)]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'add:add local archives to the repository'
        'clean:remove orphaned distributions'
        'copy:copy a stack'
        'default:mark stack as default'
        'delete:delete archives from repo'
        'diff:show differences between stacks'
        'help:show help'
        'init:initialize a new repository'
        'install:install modules into local Perl'
        'kill:permanently kill a stack'
        'list:list packages in the stack'
        'lock:lock a stack (read-only)'
        'log:show stack revision log'
        'look:show package details'
        'manual:show the Pinto manual'
        'merge:merge changes between stacks'
        'migrate:migrate repository to new format'
        'new:create a new empty stack'
        'nop:no-op (testing/healthcheck)'
        'pin:pin a package to specific version'
        'props:show repository properties'
        'pull:pull packages from upstream CPAN'
        'register:register packages on a stack'
        'rename:rename a stack'
        'reset:reset stack to previous revision'
        'revert:revert to previous stack revision'
        'roots:show root packages'
        'stacks:list all stacks'
        'statistics:show repository statistics'
        'thanks:show acknowledgements (easter egg)'
        'unlock:unlock a previously locked stack'
        'unpin:unpin a previously pinned package'
        'unregister:unregister a package from a stack'
        'update:update all packages from upstream'
        'verify:verify repository integrity'
        'commands:list all available subcommands'
      )
      _describe -t commands 'pinto subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        add)
          _arguments -s -S \
            '--author=[archive author ID]:author' \
            '--cascade[always pick latest upstream]' \
            '--diff-style=[diff report style]:style' \
            '--dry-run[do not commit changes]' \
            '(-m --message)'{-m,--message}'=[commit message]:msg' \
            '--no-fail[do not fail on error]' \
            '*'{-x,--no-index}'=[do not index matching packages]:pkg' \
            '--recurse[recursively pull prereqs]' \
            '--no-recurse[do not recursively pull prereqs]' \
            '--pin[pin packages to stack]' \
            '*'{-k,--skip-missing-prerequisite}'=[skip missing prereq]:pkg' \
            '(-K --skip-all-missing-prerequisites)'{-K,--skip-all-missing-prerequisites}'[skip all missing prereqs]' \
            '(-s --stack)'{-s,--stack}'=[put packages into this stack]:stack' \
            '(-M --use-default-message)'{-M,--use-default-message}'[use generated commit message]' \
            '--with-development-prerequisites[also pull dev prereqs]' \
            '--wd[also pull dev prereqs]' \
            '*:archive file:_files -g "*.tar.gz"'
          ;;
        help)
          _arguments '1:subcommand:'
          ;;
        list|log|props|roots|stacks|statistics|thanks|manual|nop|commands|init|verify|migrate|clean)
          ;;
        *)
          _files
          ;;
      esac
      ;;
  esac
}

_pinto "$@"
