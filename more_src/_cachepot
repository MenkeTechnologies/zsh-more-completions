#compdef cachepot
# _cachepot — distributed compilation cache (sccache fork)
# upstream: https://github.com/nicedoc/cachepot

_cachepot() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'start-server:start the background server'
                'stop-server:stop the background server'
                'show-stats:print cache statistics'
                'zero-stats:zero cache statistics'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                start-server)
                    _arguments \
                        '--port=[server port]:port:' \
                        '--log-level=[log level]:level:(error warn info debug trace)'
                    ;;
            esac
            ;;
    esac
}

_cachepot "$@"
