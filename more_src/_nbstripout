#compdef nbstripout

# Zsh completion for nbstripout - strip output from Jupyter notebooks

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--install[install nbstripout as git filter]' \
  '--uninstall[uninstall nbstripout git filter]' \
  '--is-installed[check if nbstripout is installed]' \
  '--status[show status of nbstripout installation]' \
  '--global[apply to global git config]' \
  '--system[apply to system git config]' \
  '--attributes=[path to .gitattributes]:attributes file:_files' \
  '--keep-output[do not strip output]' \
  '--keep-count[do not strip execution count]' \
  '--keep-id[do not strip cell id]' \
  '*--keep-metadata-keys=[metadata keys to preserve]:keys' \
  '*--strip-metadata-keys=[metadata keys to strip]:keys' \
  '--extra-keys=[extra keys to strip]:keys' \
  '--drop-empty-cells[remove empty cells]' \
  '--drop-tagged-cells=[remove cells with given tags]:tags' \
  '-t[write to stdout]' \
  '--textconv[write to stdout]' \
  '--dry-run[show what would be done without doing it]' \
  '*:notebook:_files -g "*.ipynb"' && ret=0

return ret
