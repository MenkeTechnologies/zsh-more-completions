#compdef tpm2-pkcs11 tpm2_ptool tpm2-pkcs11-tool
# _tpm2-pkcs11 — tpm2-software tpm2_ptool CLI for managing TPM2 PKCS#11 tokens initialising slots adding RSA EC keys importing X.509 certificates configuring PIN policy (tpm2-software team, Python); argparse
# upstream: https://github.com/tpm2-software/tpm2-pkcs11

_tpm2-pkcs11() {
    local -a sub=(
        'init:initialize new token'
        'destroy:destroy token'
        'addtoken:add token to existing primary'
        'rmtoken:remove token'
        'config:show/set config'
        'verify:verify PIN'
        'changepin:change user PIN'
        'addkey:generate key in token'
        'rmkey:remove key'
        'addcert:import X.509 cert'
        'rmcert:remove X.509 cert'
        'export:export public key'
        'import:import existing key'
        'listprimaries:list primary objects'
        'list:list token objects'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--path=+[token db path]:dir:_files -/' \
        '-p+[token db path]:dir:_files -/' \
        '--tcti=+[tcti]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tpm2-pkcs11 subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--primary-handle=+[hex]:str:' \
                    '--primary-auth=+[auth]:str:' \
                    '--pobj-pin=+[pin]:str:' \
                    '--algorithm=+[a]:a:(ecc rsa)' ;;
                addtoken) _arguments \
                    '--pid=+[N]:n:' \
                    '--sopin=+[pin]:str:' \
                    '--userpin=+[pin]:str:' \
                    '--label=+[label]:str:' ;;
                addkey) _arguments \
                    '--algorithm=+[a]:a:(rsa1024 rsa2048 rsa4096 ecc224 ecc256 ecc384 ecc521 aes128 aes256)' \
                    '--label=+[name]:str:' \
                    '--key-label=+[label]:str:' \
                    '--id=+[hex]:str:' ;;
                addcert) _arguments \
                    '--label=+[label]:str:' \
                    '--key-label=+[label]:str:' \
                    '--id=+[hex]:str:' \
                    '*:cert file:_files -g "*.pem *.crt *.der"' ;;
            esac
            ;;
    esac
}

_tpm2-pkcs11 "$@"
