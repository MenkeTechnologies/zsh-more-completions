#compdef agixt
# Documentation: https://github.com/Joshua-XT/AGiXT
# Reference accessed: 2026-05-22
# Verified: agixt --help argparse CLI (PyPI package agixt).

# Zsh completion for agixt - AGiXT agent orchestration platform CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agixt command' \
      'start[start AGiXT server]' \
      'stop[stop AGiXT server]' \
      'restart[restart AGiXT server]' \
      'logs[view AGiXT logs]' \
      'env[manage environment variables]' \
      'register[register new user]' \
      'login[login to AGiXT server]' \
      'logout[logout and clear session]' \
      'whoami[show login status]' \
      'prompt[send prompt to agent]' \
      'conversations[list and select conversations]' && ret=0
    ;;
  args)
    case $line[1] in
      start|restart)
        _arguments '--local[start locally instead of Docker]' && ret=0
        ;;
      logs)
        _arguments '-f[follow log output]' && ret=0
        ;;
      register|login)
        _arguments \
          '--email[user email]:email:' \
          '--magic-link[request email login link]' && ret=0
        ;;
      prompt)
        _arguments \
          '--image[image path for vision]:file:_files' \
          '*:prompt text:' && ret=0
        ;;
      conversations)
        _arguments '*:conversation id or - for new:' && ret=0
        ;;
      env)
        _arguments '*:KEY=VALUE:' && ret=0
        ;;
    esac
    ;;
esac

return ret
