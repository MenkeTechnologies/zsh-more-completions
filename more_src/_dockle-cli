#compdef dockle-cli dockle
# _dockle-cli — Yusuke Imai goodwithtech dockle-cli CLI command-line frontend wrapping the Dockle container image linter for security helping build the Best-Practice Docker Image easy to start open-source written in Go follows the CIS Benchmarks Docker Linter CIS-Benchmarks ENV-checks-Best-Practice-USER-instruction-COPY-add-CMD-multiple-CMD-WORKDIR HEALTHCHECK CIS-DI-Apt-Get-Yum-installations sensitive-files-in-container avoid-running-Docker-daemon avoid-installing-su (Yusuke Imai goodwithtech team, Go); cobra
# upstream: https://github.com/goodwithtech/dockle

_dockle-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '-i+[input file]:file:_files' \
        '--input=+[file]:file:_files' \
        '-c+[checkpoint]:str:' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--clear-cache[clear cache]' \
        '-f+[format]:f:(list json sarif)' \
        '--format=+[fmt]:f:(list json sarif)' \
        '*-f+[format]:f:(list json sarif)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[d]:str:' \
        '-x+[exit code]:n:' \
        '--exit-code=+[N]:n:' \
        '-l+[exit-level]:l:(INFO WARN FATAL)' \
        '--exit-level=+[l]:l:(INFO WARN FATAL)' \
        '--ignore=+[id]:str:' \
        '*--ignore=+[id]:str:' \
        '-a+[accept key]:str:' \
        '--accept-key=+[key]:str:' \
        '--accept-file=+[file]:str:' \
        '--accept-file-extension=+[ext]:str:' \
        '--accept-glob=+[glob]:str:' \
        '*-ak+[key]:str:' \
        '*-af+[file]:str:' \
        '*-ae+[ext]:str:' \
        '--allow-list=+[ids]:str:' \
        '*--allow-list=+[ids]:str:' \
        '--ignore-checkpoint=+[id]:str:' \
        '--auth-url=+[url]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--insecure[skip TLS verify]' \
        '--non-ssl[no SSL]' \
        '*:image:'
}

_dockle-cli "$@"
