#compdef alot

# Zsh completion for alot (terminal MUA based on notmuch)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r+[path to notmuch config]:file:_files' \
  '--read-only[open db in read-only mode]' \
  '-c+[path to alot config]:file:_files' \
  '--colour-mode=[terminal colour mode]:mode:(1 16 256 true)' \
  '-p+[db path]:directory:_directories' \
  '-d+[log to file]:file:_files' \
  '-l+[log level]:level:(debug info warning error)' \
  '-C+[force langauge encoding]:encoding' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'search:open search buffer'
      'compose:compose new email'
      'bufferlist:open buffer list'
      'taglist:open tag list'
      'namedqueries:open named queries list'
    )
    _describe -t commands 'alot command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      search)
        _arguments -s -S \
          '--sort=[sort order]:order:(oldest_first newest_first message_id unsorted)' \
          '*:query' && ret=0
        ;;
      compose)
        _arguments -s -S \
          '--to=[recipient]:address' \
          '--cc=[CC recipient]:address' \
          '--bcc=[BCC recipient]:address' \
          '--subject=[subject]:subject' \
          '--attach=[attachment]:file:_files' \
          '--omit_signature[do not add signature]' \
          '--sender=[sender address]:address' && ret=0
        ;;
    esac
    ;;
esac

return ret
