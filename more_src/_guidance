#compdef guidance
# _guidance — Microsoft Research guidance constrained-generation programming model for LLMs with regex grammar and structured output (guidance-ai team, Python); argparse
# upstream: https://github.com/guidance-ai/guidance

_guidance() {
    local -a sub=(
        'run:run a guidance program file'
        'compile:compile a guidance grammar'
        'test:run guidance tests'
        'serve:serve a guidance program'
        'cache:cache subcommands'
        'config:configuration subcommands'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--model=+[model name]:str:' \
        '-m+[model name]:str:' \
        '--backend=+[backend]:b:(transformers llama-cpp openai azure-openai mistral anthropic)' \
        '--api-key=+[API key]:str:' \
        '--api-base=+[API base URL]:url:_urls' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--top-p=+[F]:f:' \
        '--top-k=+[N]:n:' \
        '--seed=+[N]:n:' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-cache[disable cache]' \
        '--echo[echo program]' \
        '--silent[silent mode]' \
        '--debug[debug logging]' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'guidance subcommand' sub ;;
        args)
            case $words[1] in
                run|compile|test) _arguments \
                    '--vars=+[json file]:file:_files -g "*.json"' \
                    '--output=+[output file]:file:_files' \
                    '*:program:_files -g "*.py *.gbnf *.guidance"' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' \
                    '*:program:_files -g "*.py *.gbnf *.guidance"' ;;
                cache) _arguments '1:cache cmd:(clear list path size)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
            esac
            ;;
    esac
}

_guidance "$@"
