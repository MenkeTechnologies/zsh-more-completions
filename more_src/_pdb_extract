#compdef pdb_extract
# Documentation: https://www.ccp4.ac.uk/html/pdb_extract-CCP4.html
# CCP4 pdb_extract: gather harvest data for PDB deposition

local ret=1

_arguments -s -S \
  '-o+[output file name]:file:_files' \
  '-e+[experimental method]:method:(MR SAD MAD SIR SIRAS MIR MIRAS)' \
  '-m+[molecular replacement program]:program:(CNS Amore EPMR MOLREP)' \
  '-p+[phasing program]:program:(CNS MLPHARE SOLVE SHARP SHELXS SHELXD SnB BnP PHASES)' \
  '-d+[density modification program]:program:(CNS DM SOLOMON RESOLVE SHELXE SHARP)' \
  '-r+[refinement program]:program:(CNS REFMAC5 RESTRAIN SHELXL TNT WARP)' \
  '-s+[scaling program (refinement dataset)]:program:(HKL SCALA D*trek SAINT 3DSCALE)' \
  '-sp+[scaling program (phasing datasets)]:program:' \
  '-iPDB+[input PDB format file]:file:_files' \
  '-iCIF+[input mmCIF format file]:file:_files' \
  '*-iLOG+[input log file(s)]:file:_files' \
  '-iENT+[data template or additional info file]:file:_files' \
  '*:file:_files' && ret=0

return ret
