#compdef emproc
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/emproc/node11.html
# XMM-Newton SAS epicproc: process EPIC-MOS instrument data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--selectinstruments=[choose specific cameras]:flag:(yes no)' \
  '--emos1=[process EMOS1 detector data]:flag:(yes no)' \
  '--emos2=[process EMOS2 detector data]:flag:(yes no)' \
  '--removetemporaries=[delete temporary datasets]:flag:(yes no)' \
  '--removeintermediategtis=[delete intermediate GTI datasets]:flag:(yes no)' \
  '--removeintermediateeventlists=[delete intermediate event lists]:flag:(yes no)' \
  '--withinstexpids=[choose specific exposures]:flag:(yes no)' \
  '--instexpids=[list of exposures to process]:ids:' \
  '--selectccds=[choose specific CCDs]:flag:(yes no)' \
  '--selectmodes=[choose specific observation modes]:flag:(yes no)' \
  '--imaging=[process imaging mode data]:flag:(yes no)' \
  '--rimaging=[process reduced imaging mode data]:flag:(yes no)' \
  '--timing=[process timing mode data]:flag:(yes no)' \
  '--ctiming=[process compressed timing mode data]:flag:(yes no)' \
  '--withgtiset=[use external GTI dataset]:flag:(yes no)' \
  '--gtiset=[external GTI dataset name]:file:_files' \
  '--runhkgtigen=[generate GTI from housekeeping data]:flag:(yes no)' \
  '--runatthkgen=[pre-process attitude data]:flag:(yes no)' \
  '--referencepointing=[reference pointing coordinates source]:src:' \
  '--ra=[right ascension (degrees)]:ra:' \
  '--dec=[declination (degrees)]:dec:' \
  '--posangle=[position angle (degrees)]:angle:' \
  '--filterevents=[filter event lists]:flag:(yes no)' \
  '--flagfilteredevents=[flag instead of remove filtered events]:flag:(yes no)' \
  '--rungtimerge=[merge GTIs from each CCD]:flag:(yes no)' \
  '--applygti=[apply GTI filter to events]:flag:(yes no)' \
  '--runevlistcomb=[merge CCD-level into exposure-level lists]:flag:(yes no)' \
  '--searchforbadpixels=[detect bad pixels]:flag:(yes no)' \
  '--badpixfindalgo=[bad pixel detection algorithm]:algo:' \
  '--searchforbadcolumns=[detect bad columns]:flag:(yes no)' \
  '--withbadpixgti=[restrict bad pixel search to GTI]:flag:(yes no)' \
  '--badpixgti=[GTI dataset for bad pixel search]:file:_files' \
  '--thresholdlabel=[threshold type]:type:(peak rate counts)' \
  '--lothresh=[low threshold for dead pixels]:thresh:' \
  '--hithresh=[high threshold for hot pixels]:thresh:' \
  '--loenergythresh=[low energy threshold (keV)]:thresh:' \
  '--hienergythresh=[high energy threshold (keV)]:thresh:' \
  '--randomizeenergy=[randomize energy within ADU bin]:flag:(yes no)' \
  '--randomizeposition=[randomize detector coordinates]:flag:(yes no)' \
  '--randomizetime=[randomize time within frame]:flag:(yes no)' \
  '--withsrccoords=[supply source coordinates (timing)]:flag:(yes no)' \
  '--srcra=[source right ascension (J2000)]:ra:' \
  '--srcdec=[source declination (J2000)]:dec:' \
  '--findlowener=[additional search below 500 eV]:flag:(yes no)' \
  '*:event file:_files' && ret=0

return ret
