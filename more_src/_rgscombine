#compdef rgscombine
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/rgscombine/node4.html
# Combine RGS spectrum files into one combined spectrum, response and background

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--pha=[list of spectrum files produced by rgsspectrum]:files:_files' \
  '--rmf=[list of response matrix files produced by rgsrmfgen]:files:_files' \
  '--bkg=[background spectrum files for TOTAL-type spectra]:files:_files' \
  '--filepha=[output file name for the combined spectrum]:file:_files' \
  '--filebkg=[output file name for combined background spectrum]:file:_files' \
  '--filermf=[output file name for the combined response matrix]:file:_files' \
  '--rmfgrid=[number of energy bins in the response matrix]:n' \
  '--min=[minimum wavelength for output grid creation]:value' \
  '--max=[maximum wavelength for output grid creation]:value' \
  '--bins=[number of PHA channels in spectrum files]:n' \
  '*:param=value:_default' && ret=0

return ret
