#compdef duplik8s kubectl-duplicate
# Documentation: https://man.archlinux.org/search?q=duplik8s
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      pod:'duplicate a Pod'
      pods:'duplicate a Pod'
      deploy:'duplicate a Deployment'
      deployment:'duplicate a Deployment'
      deployments:'duplicate a Deployment'
      statefulset:'duplicate a StatefulSet'
      statefulsets:'duplicate a StatefulSet'
      list:'list duplicated resources'
      cleanup:'delete duplicated resources interactively'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--command-override=[container command override]:cmd:' \
      '--args-override=[container args override]:args:' \
      '--shell[attach an interactive shell after duplicate]' \
      '--preserve-init-containers[keep init containers in the duplicate]' \
      '1:resource name: _default' && ret=0
    ;;
esac

return ret
