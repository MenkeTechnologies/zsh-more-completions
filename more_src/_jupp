#compdef jupp
# jupp — Joe's Own Editor derivative

_arguments -s -S \
  '-asis[characters above 127 not langstripped]' \
  '-assume_256color[assume 256 color terminal]' \
  '-assume_color[assume color terminal]' \
  '-backpath[backup file path]:path:_directories' \
  '-beep[beep on errors]' \
  '-break_links[break hard links on save]' \
  '-break_hardlinks[break hard links on save]' \
  '-columns[set number of columns]:columns' \
  '-csmode[^C/^S mode for flow control]' \
  '-dopadding[enable terminal padding]' \
  '-exask[ask for file to edit on startup]' \
  '-flowed[handle flowed text]' \
  '-force[force overwrite]' \
  '-guess_crlf[auto-detect CR/LF line endings]' \
  '-guess_indent[auto-detect indentation]' \
  '-guess_non_utf8[guess non-UTF-8 encoding]' \
  '-guess_utf16[guess UTF-16 encoding]' \
  '-guess_utf8[guess UTF-8 encoding]' \
  '-help[show help]' \
  '-highlight[enable syntax highlighting]' \
  '-icase[case insensitive search]' \
  '-joe_state[save/restore state]:state file:_files' \
  '-joexterm[use xterm mouse support]' \
  '-keepup[keep status line up to date]' \
  '-lightoff[auto-turn-off highlighting after block copy/move]' \
  '-lmargin[left margin]:margin' \
  '-marking[mark mode]' \
  '-menu_above[menu appears above prompt]' \
  '-menu_explorer[menu acts as file explorer]' \
  '-menu_jump[jump into menu on open]' \
  '-mid[cursor is always in middle of screen]' \
  '-nobackups[disable backup files]' \
  '-nocurdir[do not use current directory]' \
  '-noexmsg[no exiting message]' \
  '-nolinefeeds[do not use line feeds]' \
  '-nomodcheck[no modification check]' \
  '-nonotice[do not show notice on startup]' \
  '-nosta[disable status line]' \
  '-noxon[turn off ^S/^Q flow control]' \
  '-nowrap[disable word wrap]' \
  '-orphan[orphan mode for extra files]' \
  '-pasting_mode[enable paste mode]' \
  '-pg[page scroll lines]:lines' \
  '-rmargin[right margin]:margin' \
  '-search_prompting[prompt during search]' \
  '-skiptop[skip top N lines for status]:lines' \
  '-smarthome[smart home key]' \
  '-smartbacks[smart backspace]' \
  '-spaces[use spaces instead of tabs]' \
  '-square[rectangular block mode]' \
  '-syntax[syntax file]:syntax file:_files' \
  '-tab[tab width]:width' \
  '-text_color[text color]:color' \
  '-usetabs[use tab characters]' \
  '-vispace[visible spaces]' \
  '-wordwrap[word wrap mode]' \
  '-wrap[search wraps]' \
  '*:file:_files' \
  && return 0
