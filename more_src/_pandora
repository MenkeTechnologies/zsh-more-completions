#compdef pandora
# Documentation: https://yandex.github.io/pandora/
# Pandora: high-performance load generator in Go

local ret=1

_arguments -s \
  '(- *)-example[print example config to STDOUT and exit]' \
  '-expvar[enable expvar service (DEPRECATED, use monitoring config)]' \
  '(- *)-version[print pandora core version]' \
  '(- *)-help[show help]' \
  '*:config:_files -g "*.yaml *.yml"' && ret=0

return ret
