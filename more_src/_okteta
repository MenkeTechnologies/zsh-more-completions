#compdef okteta

# Okteta: KDE hex editor
# Documentation: https://docs.kde.org/stable5/en/okteta/okteta/index.html
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--help-all[show all options]' \
  '--help-qt[show Qt options]' \
  '--help-kde[show KDE options]' \
  '-v[show version]' \
  '--version[show version]' \
  '*:file:_files' && ret=0
return ret
