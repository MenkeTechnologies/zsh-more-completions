#compdef pvesh

local -a _pvesh_commands
_pvesh_commands=(
  'get:call API GET'
  'set:call API PUT'
  'create:call API POST'
  'delete:call API DELETE'
  'ls:list child links'
  'usage:print API usage'
  'help:show help'
)

_arguments -C \
  '--hierarchical[hierarchical output]' \
  '--human-readable[human readable output]' \
  '--noborder[no border in output]' \
  '--noheader[no header in output]' \
  '--output-format[output format]:format:(json json-pretty text yaml)' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'pvesh commands' _pvesh_commands
    ;;
  args)
    case "$words[1]" in
      get|set|create|delete|ls)
        _arguments \
          '1:api path' \
          '--output-format[output format]:format:(json json-pretty text yaml)' \
          '*:parameter'
        ;;
    esac
    ;;
esac
