#compdef bartender bartender4 bartender-cli
# _bartender — Surtees Studios Bartender macOS menu-bar manager CLI alias (Surtees Studios, AppleScript bridge); custom URL scheme
# upstream: https://www.macbartender.com

_bartender() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--quit[quit Bartender]' \
        '--restart[restart Bartender]' \
        '--show-bartender[show bartender]' \
        '--hide-bartender[hide bartender]' \
        '--toggle-bartender[toggle bartender]' \
        '--show-all[show all menu items]' \
        '--show-hidden[show hidden menu items]' \
        '--hide-all[hide all]' \
        '--show-item=+[show menu item id]:str:' \
        '--hide-item=+[hide menu item id]:str:' \
        '--toggle-item=+[toggle menu item id]:str:' \
        '--list-items[list known menu items]' \
        '--reload-preferences[reload preferences]' \
        '--preferences[open preferences]' \
        '--check-license[check license]' \
        '--reset-license[reset license]' \
        '--export-config=+[export config file]:file:_files' \
        '--import-config=+[import config file]:file:_files' \
        '--profile=+[set profile]:str:' \
        '--current-profile[show current profile]' \
        '*:arg:'
}

_bartender "$@"
