#compdef gambit
# gambit - Play chess in your terminal (Go, Bubble Tea + Wish + dragontoothmg)
#
# Upstream: https://github.com/maaslalani/gambit  (898+ stars, MIT)
# Author:   Maas Lalani (@maaslalani, Charm)
# Library:  charmbracelet/bubbletea (canonical Go TUI framework) + Wish (SSH)
# Engine:   dylhunn/dragontoothmg (Go bitboard chess move generator)
# Flags:    muesli/coral (Charm fork of spf13/cobra; pflag-derived parser)
#
# Source-direct extraction from main.go (rootCmd) + cmd/serve.go (serve flags):
#   https://github.com/maaslalani/gambit/blob/main/main.go
#   https://github.com/maaslalani/gambit/blob/main/cmd/serve.go
#
# Continues Axis 297 (interactive terminal chess clients):
#   Rust : thomas-mauran/chess-tui (ratatui + ruci UCI + shakmaty + Lichess)
#   Go   : maaslalani/gambit       (bubbletea + dragontoothmg + Wish SSH)

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[help for gambit]' \
    '(- *)--version[print version (and short commit SHA if built with -ldflags)]' \
    '1: :->command' \
    '*::arg:->args' \
    && ret=0

case $state in
    command)
        local -a commands
        commands=(
            'serve:start a Gambit SSH server (alias: server)'
            'server:start a Gambit SSH server'
        )
        _describe -t commands 'gambit sub-command' commands && ret=0
        # If no subcommand: gambit reads an optional FEN/PGN start position
        # from stdin and runs the Bubble Tea local-play UI.  Nothing to
        # complete here beyond the global flags above.
        ;;
    args)
        case $line[1] in
            serve|server)
                _arguments -s -S \
                    '--key=[server private key path (env: GAMBIT_SERVER_KEY_PATH; default "gambit")]:key path:_files' \
                    '--host=[server host to bind to (env: GAMBIT_SERVER_HOST)]:host:_hosts' \
                    '--port=[server port to bind to (env: GAMBIT_SERVER_PORT; default 53531)]:port:' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
