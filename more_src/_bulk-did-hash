_bulk-did-hash() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _bdh_cmds=(
                'sha:hash a single DID or handle to stdout'
                'bulk:bulk-hash a newline-separated file of DIDs/handles to ./hashes.csv'
            )
            _describe -t commands 'bulk-did-hash command' _bdh_cmds && ret=0
            ;;
        args)
            case $words[1] in
                sha)
                    _arguments '1:DID or Bluesky handle:' && ret=0
                    ;;
                bulk)
                    _arguments '1:path to newline-separated DIDs/handles file:_files -g "*.txt *.csv"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_bulk-did-hash "$@"
