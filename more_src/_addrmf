#compdef addrmf
# Add together two or more RMFs with optional weighting factors

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'list=[input RMF files or @ASCII file of filenames]:rmf list:_files' \
  'weights=[comma-separated weighting factors for the RMFs]:weights:' \
  'rmffile=[output combined RMF filename]:output file:_files' \
  'clobber=[overwrite pre-existing output file]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
