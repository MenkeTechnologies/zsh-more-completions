#compdef mitmproxy2swagger
# Documentation: https://man.archlinux.org/search?q=mitmproxy2swagger
# Reference accessed: 2026-05-16

_arguments -s \
  '(-i --input)'{-i,--input}'=[input dump]:file:_files' \
  '(-o --output)'{-o,--output}'=[output schema]:file:_files' \
  '(-p --api-prefix)'{-p,--api-prefix}'=[API prefix URL]:url:' \
  '(-e --examples)'{-e,--examples}'[include examples]' \
  '(-hd --headers)'{-hd,--headers}'[include headers]' \
  '(-f --format)'{-f,--format}'=[input format]:fmt:(flow har mitmproxy)' \
  '(-r --param-regex)'{-r,--param-regex}'=[param regex]:regex:' \
  '(-s --suppress-params)'{-s,--suppress-params}'[suppress params]' \
  '(- *)'{-h,--help}'[show help]'
