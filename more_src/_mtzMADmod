#compdef mtzMADmod
# mtzMADmod — convert MAD structure factor columns in an MTZ file (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'HKLOUT[output reflection MTZ]:file:_files -g "*.mtz"' \
  'LABIN[input column labels]:labels:' \
  'LABOUT[output column labels]:labels:' \
  'TITLE[output title]:title:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
