#compdef cpplint

# Zsh completion for cpplint - C++ style checker

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--output[output format]:format:(emacs vs7 eclipse junit sed gsed)' \
  '--verbose[verbosity level]:level:(0 1 2 3 4 5)' \
  '--quiet[suppress output other than linting errors]' \
  '--counting[total error count display]:level:(total toplevel detailed)' \
  '--repository[root directory of repository]:directory:_files -/' \
  '--root[root directory for header guard]:directory:_files -/' \
  '--headers[file extensions for header files]:extensions' \
  '--extensions[file extensions to check]:extensions' \
  '--includeorder[order of include sections]:order' \
  '--linelength[max line length]:length' \
  '--exclude[exclude patterns]:pattern' \
  '--recursive[run recursively on directories]' \
  '--filter[error categories to enable/disable]:filters' \
  '*:file:_files -g "*.(cc|cpp|cxx|c|h|hpp|hxx)"'
