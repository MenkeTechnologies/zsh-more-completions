#compdef aws-vpc-cni
# _aws-vpc-cni — AWS VPC CNI installer (runs in aws-node DaemonSet to drop CNI plugins + conflist into /host/opt/cni)
# upstream: https://github.com/aws/amazon-vpc-cni-k8s
# Source: cmd/aws-vpc-cni/main.go on tip; no CLI flags — configuration via env vars (selected list below).
# Env vars: AWS_VPC_K8S_PLUGIN_LOG_FILE, AWS_VPC_K8S_PLUGIN_LOG_LEVEL, AWS_VPC_K8S_CNI_VETHPREFIX, AWS_VPC_ENI_MTU, AWS_VPC_K8S_POD_MTU, POD_SECURITY_GROUP_ENFORCING_MODE, AWS_VPC_K8S_CNI_RANDOMIZESNAT, EGRESS_V4_PLUGIN_LOG_FILE, EGRESS_V6_PLUGIN_LOG_FILE, WARM_IP_TARGET, WARM_PREFIX_TARGET, MINIMUM_IP_TARGET, HOST_CNI_BIN_PATH, HOST_CNI_CONFDIR_PATH.

_aws-vpc-cni() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_aws-vpc-cni "$@"
