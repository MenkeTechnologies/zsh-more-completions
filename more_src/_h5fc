#compdef h5fc
# Documentation: https://github.com/HDFGroup/hdf5
# Source: HDFGroup/hdf5 fortran/src/h5fc.in — Fortran HDF5 compiler wrapper (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,-help,--help}'[show help]' \
    '-echo[show all executed shell commands]' \
    '-prefix=-[HDF5 install prefix]:dir:_files -/' \
    '-show[show commands without executing]' \
    '-showconfig[show HDF5 library configuration summary]' \
    '(-noshlib)-shlib[compile with shared HDF5 libraries]' \
    '(-shlib)-noshlib[compile with static HDF5 libraries]' \
    '*:Fortran source / compile-line:_files -g "*.{f,f90,f95,F,F90,F95,o,a,so}"' \
    && ret=0

return ret
