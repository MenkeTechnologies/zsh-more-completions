#compdef dinfdistup DinfDistUp
# Documentation: https://hydrology.usu.edu/taudem/taudem5/help53/DInfinityDistanceUp.html
# TauDEM: D-infinity distance up to ridge

local ret=1

_arguments -s -S \
  '-ang[input Dinf flow direction grid]:angfile:_files' \
  '-fel[input pit-filled elevation grid]:felfile:_files' \
  '-slp[input slope grid]:slpfile:_files' \
  '-du[output Dinf rise-to-ridge grid]:dufile:_files' \
  '-m[statistical and distance method]:method:(ave min max h v p s)' \
  '-thresh[proportion threshold for upslope contribution]:value:' \
  '-nc[disable edge contamination checking]' \
  '*:file:_files' && ret=0

return ret
