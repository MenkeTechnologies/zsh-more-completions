#compdef ocount
# _ocount — OProfile ocount lightweight event counter using perf_events to tally hardware/software performance events without sampling (oprofile team, C++); getopt
# upstream: https://oprofile.sourceforge.io/

_ocount() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-e+[event spec]:str:' \
        '--events=+[event spec]:str:' \
        '-c+[cpu list]:str:' \
        '--cpu-list=+[cpu list]:str:' \
        '-p+[pid list]:str:' \
        '--process-list=+[pid list]:str:' \
        '-r+[thread list]:str:' \
        '--thread-list=+[thread list]:str:' \
        '-s[system-wide]' \
        '--system-wide[system-wide]' \
        '-f+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-b[brief output]' \
        '--brief-format[brief output]' \
        '-t+[time interval ms]:n:' \
        '--time-interval=+[ms]:n:' \
        '-d+[duration ms]:n:' \
        '*:command:_command_names -e'
}

_ocount "$@"
