#compdef zoekt-mirror-gitlab
# _zoekt-mirror-gitlab — Zoekt GitLab repository mirror
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-mirror-gitlab/main.go on tip.

_zoekt-mirror-gitlab() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-dest=[destination directory]:dir:_files -/' \
        '-url=[GitLab API URL]:url:_urls' \
        '-token=[GitLab personal access token]:token:' \
        '-membership=[mirror only repos this user is a member of]:bool:(true false)' \
        '-public=[mirror only public repos]:bool:(true false)' \
        '-delete=[delete missing repos]:bool:(true false)' \
        '-exclude_user=[exclude user repos]:bool:(true false)' \
        '-name=[regex of repo names to clone]:regex:' \
        '-exclude=[regex of repo names to skip]:regex:' \
        '-last_activity_after=[only repos active after date (YYYY-MM-DD)]:date:' \
        '-no_archived=[mirror only non-archived projects]:bool:(true false)'
}

_zoekt-mirror-gitlab "$@"
