#compdef keydb-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--port=[listen port]:port:' \
  '--bind=[bind address]:address:_hosts' \
  '--requirepass=[require password]:password:' \
  '--maxmemory=[max memory limit]:bytes:' \
  '--dbfilename=[snapshot filename]:filename:' \
  '--dir=[working directory]:directory:_directories' \
  '--loglevel=[log level]:level:(debug verbose notice warning)' \
  '--logfile=[log file path]:file:_files' \
  '--databases=[number of databases]:count:' \
  '--hz=[server frequency in hz]:hz:' \
  '--tcp-backlog=[TCP listen backlog]:size:' \
  '--timeout=[client idle timeout in seconds]:seconds:' \
  '--tcp-keepalive=[TCP keepalive interval]:seconds:' \
  '--daemonize=[run as daemon]::(yes no)' \
  '--supervised=[supervision mode]:mode:(no upstart systemd auto)' \
  '--pidfile=[PID file]:file:_files' \
  '--save=[RDB save schedule]:schedule:' \
  '--appendonly=[enable AOF]::(yes no)' \
  '--maxclients=[max number of clients]:count:' \
  '--slaveof=[replicate from master]:host port:' \
  '--replicaof=[replicate from master]:host port:' \
  '--masterauth=[master authentication]:password:' \
  '--server-threads=[number of server threads]:threads:' \
  '--server-thread-affinity=[set thread CPU affinity]::(true false)' \
  '--active-replica=[enable active replica mode]::(yes no)' \
  '--multi-master=[enable multi-master mode]::(yes no)' \
  '--sentinel[run in sentinel mode]' \
  '--loadmodule=[load module]:module:_files' \
  '1:config file:_files -g "*.conf"' \
  '*:config overrides:' && ret=0

return ret
