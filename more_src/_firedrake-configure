#compdef firedrake-configure
# Documentation: https://www.firedrakeproject.org/install.html
# Print Firedrake build configuration (PETSc options, packages, env)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--package-manager)--os=[operating system; guessed if omitted]:os:(ubuntu24.04-x86_64 ubuntu24.04-aarch64 ubuntu26.04-x86_64 ubuntu26.04-aarch64 macos-arm64 unknown)' \
  '--no-package-manager[(deprecated) equivalent to --os unknown]' \
  '(--arch)--scalar-type=[PETSc scalar type]:type:(default complex)' \
  '--gpu-arch=[GPU architecture to build for]:arch:(none cuda)' \
  '--show-system-packages[print the system packages required]' \
  '--show-petsc-configure-options[print arguments to pass to PETSc configure]' \
  '--show-petsc-version[print the officially supported PETSc version tag]' \
  '--show-env[print environment variables to export for install]' \
  '--show-extra-repo-pkg-url[print URL of any extra repo-access package]' && ret=0

return ret
