#compdef gml2gv
# Documentation: man gml2gv(1) (graphviz)
# Source: GraphViz gml2gv — convert a GML graph to DOT.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output during conversion]' \
    '(- *)-?[show usage]' \
    '-g+[output graph name (subsequent get integer-suffixed)]:gname:' \
    '-o+[output file]:file:_files' \
    '*:GML file:_files -g "*.gml"' \
    && ret=0

return ret
