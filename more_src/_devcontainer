#compdef devcontainer

# Zsh completion for devcontainer (Dev Container CLI)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global_opts=(
  '(-h --help)'{-h,--help}'[show help]'
)

local -a log_opts=(
  '--log-level[log level]:level:(trace debug info warning error)'
  '--log-format[log output format]:format:(text json)'
  '--terminal-columns[number of columns in the terminal]:columns:'
  '--terminal-rows[number of rows in the terminal]:rows:'
)

local -a subcommands=(
  'build:build a dev container image'
  'exec:execute a command in a running dev container'
  'features:manage dev container features'
  'open:open a dev container in VS Code'
  'read-configuration:read dev container configuration'
  'set-up:set up a dev container'
  'templates:manage dev container templates'
  'up:create and run a dev container'
)

_arguments -s -S -C \
  $global_opts \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'devcontainer command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      up)
        _arguments -s -S \
          $global_opts \
          $log_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' \
          '--config[path to devcontainer.json]:file:_files' \
          '--override-config[path to override devcontainer.json]:file:_files' \
          '*--id-label[label to identify the dev container]:label:' \
          '--default-user-env-probe[default user env probe]:probe:(none loginInteractiveShell interactiveShell loginShell)' \
          '*--remote-env[set remote environment variable]:key=value:' \
          '*--cache-from[image to use as cache source]:image:' \
          '*--cache-to[image to use as cache target]:image:' \
          '--buildkit[control BuildKit usage]:mode:(auto never)' \
          '--additional-features[additional features to install as JSON]:json:' \
          '--skip-post-create[skip post-create commands]' \
          '--dotfiles-repository[URL of a dotfiles git repository]:url:' \
          '--dotfiles-install-command[command to run after cloning dotfiles]:command:' \
          '--dotfiles-target-path[target path for dotfiles]:path:' \
          '--container-data-folder[container data folder]:path:' \
          '--container-system-data-folder[container system data folder]:path:' \
          '*--mount[additional mount point]:mount:' \
          '--remove-existing-container[remove existing container]' \
          '--update-remote-user-uid-default[update remote user UID]:mode:(on off)' \
          '--timeout[timeout in seconds]:seconds:' \
          '--expect-existing-container[expect an existing container]' && ret=0
        ;;
      build)
        _arguments -s -S \
          $global_opts \
          $log_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' \
          '--config[path to devcontainer.json]:file:_files' \
          '--override-config[path to override devcontainer.json]:file:_files' \
          '*--image-name[image name]:name:' \
          '*--cache-from[image to use as cache source]:image:' \
          '*--cache-to[image to use as cache target]:image:' \
          '--no-cache[do not use cache when building the image]' \
          '--platform[target platform]:platform:' \
          '--push[push the image to a registry]' && ret=0
        ;;
      exec)
        _arguments -s -S \
          $global_opts \
          $log_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' \
          '--config[path to devcontainer.json]:file:_files' \
          '--override-config[path to override devcontainer.json]:file:_files' \
          '*--id-label[label to identify the dev container]:label:' \
          '*--remote-env[set remote environment variable]:key=value:' \
          '*:command:_command_names' && ret=0
        ;;
      features)
        local -a features_commands=(
          'info:show information about a feature'
          'list:list available features'
          'publish:publish a feature'
          'test:test a feature'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->features_cmd' \
          '*::arg:->features_args' && ret=0
        case $state in
          features_cmd)
            _describe -t commands 'features subcommand' features_commands && ret=0
            ;;
          features_args)
            case $line[1] in
              info)
                _arguments -s -S $global_opts ':feature id:' && ret=0
                ;;
              list)
                _arguments -s -S $global_opts && ret=0
                ;;
              publish)
                _arguments -s -S $global_opts '--namespace[target namespace]:namespace:' ':source directory:_directories' && ret=0
                ;;
              test)
                _arguments -s -S $global_opts \
                  '--project-folder[project folder]:folder:_directories' \
                  '--features[features to test]:features:' \
                  '--base-image[base image to use]:image:' \
                  '--remote-user[remote user name]:user:' \
                  ':feature id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      templates)
        local -a templates_commands=(
          'apply:apply a dev container template'
          'publish:publish a template'
        )
        _arguments -s -S -C \
          $global_opts \
          '1:subcommand:->templates_cmd' \
          '*::arg:->templates_args' && ret=0
        case $state in
          templates_cmd)
            _describe -t commands 'templates subcommand' templates_commands && ret=0
            ;;
          templates_args)
            case $line[1] in
              apply)
                _arguments -s -S $global_opts '--template-id[template ID]:id:' '--template-args[template arguments as JSON]:json:' '--workspace-folder[workspace folder]:folder:_directories' && ret=0
                ;;
              publish)
                _arguments -s -S $global_opts '--namespace[target namespace]:namespace:' ':source directory:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      read-configuration)
        _arguments -s -S \
          $global_opts \
          $log_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' \
          '--config[path to devcontainer.json]:file:_files' \
          '--override-config[path to override devcontainer.json]:file:_files' \
          '--include-features-configuration[include features configuration]' \
          '--include-merged-configuration[include merged configuration]' && ret=0
        ;;
      set-up)
        _arguments -s -S \
          $global_opts \
          $log_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' \
          '--config[path to devcontainer.json]:file:_files' \
          '--override-config[path to override devcontainer.json]:file:_files' \
          '--container-id[ID of the container]:id:' && ret=0
        ;;
      open)
        _arguments -s -S \
          $global_opts \
          '--workspace-folder[workspace folder path]:folder:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
