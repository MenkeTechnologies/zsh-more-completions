#compdef PeptideIndexer
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: refer peptide/protein identifications to a sequence database

local ret=1

_arguments -s -S \
  '-in[input identification file]:input file:_files' \
  '-out[output file]:output file:_files' \
  '-fasta[protein sequence database (FASTA)]:fasta:_files' \
  '-decoy_string[string marking decoy entries]:string:' \
  '-decoy_string_position[position of decoy marker]:position:(prefix suffix)' \
  '-missing_decoy_action[behavior when no decoys detected]:action:(error warn silent)' \
  '-write_protein_sequence[include protein sequences in output]' \
  '-write_protein_description[include protein descriptions in output]' \
  '-keep_unreferenced_proteins[retain protein hits not referenced by peptides]' \
  '-unmatched_action[handling for unmatched peptides]:action:(error warn remove)' \
  '-aaa_max[maximum ambiguous amino acids allowed]:n:' \
  '-mismatches_max[maximum mismatched amino acids]:n:' \
  '-IL_equivalent[treat isoleucine and leucine as interchangeable]' \
  '-allow_nterm_protein_cleavage[allow N-terminus cleavage]:choice:' \
  '-enzyme:name[enzyme type]:enzyme:' \
  '-enzyme:specificity[cleavage specificity level]:spec:(full semi none)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
