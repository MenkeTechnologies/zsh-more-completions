#compdef hyperglot-report
# Documentation: https://github.com/rosettatype/hyperglot
# Explore missing language support of a font (hyperglot report mode)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-V --version)'{-V,--version}'[print version number]' \
  '*'{-c,--check}'=[character set to check]:set:(base auxiliary punctuation numerals currency all)' \
  '(-s --status)'{-s,--status}'=[language status]:status:(living historical constructed all)' \
  '(-o --orthography)'{-o,--orthography}'=[orthography types]:type:(primary secondary historical transliteration all)' \
  '(-d --decomposed)'{-d,--decomposed}'[accept component characters instead of precomposed]' \
  '(-m --marks)'{-m,--marks}'[require all combining marks]' \
  '--report-all=[set/overwrite all other --report-xxx parameters]:n' \
  '--report-missing=[report languages missing n or fewer characters]:n' \
  '--report-marks=[report languages missing n or fewer mark-attachment sequences]:n' \
  '--report-joining=[report languages missing n or fewer joining sequences]:n' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '*:font file:_files -g "*.(ttf|otf|TTF|OTF)"' && ret=0

return ret
