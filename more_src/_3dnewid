#compdef 3dnewid
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dnewid.html
# AFNI assign a new ID code to a dataset

local ret=1

_arguments -s -S \
  '-fun[display n randomly generated ID codes]:n:' \
  '-fun11[generate an 11-character ID code for scripting]' \
  '-int[produce a random positive integer seed]' \
  '-hash[unique hashcode for the provided string]:str:' \
  '-MD5[MD5 hash of the provided string]:str:' \
  '*:dataset:_files' && ret=0

return ret
