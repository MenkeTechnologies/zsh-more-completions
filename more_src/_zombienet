#compdef zombienet
# _zombienet — Paritytech zombienet flexible Polkadot ephemeral testnet orchestrator over Podman Kubernetes or native (paritytech team, TypeScript); commander
# upstream: https://github.com/paritytech/zombienet

_zombienet() {
    local -a sub=(
        'spawn:spawn a testnet'
        'test:run testnet test suite'
        'setup:install zombienet binaries'
        'version:show version'
        'help:show help'
        'convert:convert config to JSON'
        'topology:print topology'
        'compute:compute polkadot test config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--provider=+[provider]:p:(podman kubernetes native)' \
        '-p+[provider]:p:(podman kubernetes native)' \
        '--monitor[run with monitoring]' \
        '-m[run with monitoring]' \
        '--logType=+[log type]:l:(table json text)' \
        '-l+[log type]:l:(table json text)' \
        '--dir=+[work dir]:dir:_files -/' \
        '-d+[work dir]:dir:_files -/' \
        '--force[force]' \
        '-f[force]' \
        '--debug[debug logs]' \
        '--silent[silent]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zombienet subcommand' sub ;;
        args)
            case $words[1] in
                spawn|test) _arguments \
                    '--provider=+[provider]:p:(podman kubernetes native)' \
                    '--dir=+[work dir]:dir:_files -/' \
                    '--force[force]' \
                    '--monitor[run with monitoring]' \
                    '--logType=+[log type]:l:(table json text)' \
                    '-s+[test runner]:s:(mocha jest)' \
                    '*:config:_files -g "*.toml *.json *.zndsl"' ;;
                setup) _arguments \
                    '--yes[assume yes]' \
                    '-y[assume yes]' \
                    '--binary-path=+[binaries dir]:dir:_files -/' \
                    '*:binary:(polkadot polkadot-parachain polkadot-collator-protocol substrate moonbeam acala karura)' ;;
                convert) _arguments '*:file:_files -g "*.toml *.json"' ;;
                topology) _arguments '*:file:_files -g "*.toml *.json"' ;;
            esac
            ;;
    esac
}

_zombienet "$@"
