#compdef inferno-flamegraph

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--colors=[color palette]:palette:(hot mem io wakeup chain java js perl red yellow green blue aqua orange)' \
  '--bgcolors=[background color]:color' \
  '--hash[use consistent colors based on function name hash]' \
  '--cp[use consistent palette]' \
  '--search-color=[search highlight color]:color' \
  '--title=[chart title]:title' \
  '--subtitle=[chart subtitle]:subtitle' \
  '--width=[image width]:pixels' \
  '--height=[frame height]:pixels' \
  '--minwidth=[minimum function width]:pixels' \
  '--countname=[count type label]:label' \
  '--nametype=[name type label]:label' \
  '--factor=[scale factor]:factor' \
  '--notes=[notes]:notes' \
  '--reverse[generate reverse stack]' \
  '--inverted[invert stack order]' \
  '--flamechart[produce a flame chart]' \
  '--negate[negate values]' \
  '--no-sort[do not sort frames]' \
  '--no-javascript[disable JavaScript in SVG]' \
  '--deterministic[use deterministic colors]' \
  '--pretty-xml[produce pretty-printed SVG]' \
  '--truncate-name-left[truncate names on the left]' \
  '*:collapsed stacks file:_files' && ret=0

return ret
