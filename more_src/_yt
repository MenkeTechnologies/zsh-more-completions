#compdef yt

# Zsh completion for yt — yewtube / mps-youtube front-end

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values -s 'yt' play search user top set view config theme help quit && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
