#compdef limine
# Limine bootloader installer

local ret=1

_arguments -s -S \
  'bios-install[install BIOS bootloader]:device:_files' \
  '--force-mbr[force MBR installation]' \
  '--quiet[suppress output]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:device or image:_files' && ret=0

return ret
