#compdef wtdbg2
# Documentation: https://man.archlinux.org/search?q=wtdbg2
# Reference accessed: 2026-05-16

# WTDBG2: fast Nanopore/PacBio assembler
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[input reads file]:file:_files' \
  '-fo[output prefix]:prefix:' \
  '-t[number of threads]:n:' \
  '-x[preset profile]:preset:(ont ont-sq sq ccs)' \
  '-g[approximate genome size (e.g. 100m, 3g)]:size:' \
  '-X[max read length]:n:' \
  '-L[minimum read length]:n:' \
  '-k[k-mer size]:k:' \
  '-p[homopolymer-compressed k-mer size]:p:' \
  '-K[k-mer cutoff]:val:' \
  '-E[max edges per node]:n:' \
  '-S[subsample reads]:frac:' \
  '-l[minimum alignment identity]:val:' \
  '-m[max alignment errors]:val:' \
  '-A[also output alignment file]' \
  '-R[disable real-time assembly]' \
  '-v[verbose output]' \
  '-V[print version]' \
  '*:input reads:_files' && ret=0
return ret
