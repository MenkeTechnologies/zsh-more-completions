#compdef faust2webaudio
# Documentation: https://faustdoc.grame.fr/manual/tools/
# Faust to a WebAudio node

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-httpd[activate HTTP control]' \
  '-osc[activate OSC control]' \
  '-midi[activate MIDI control]' \
  '-nvoices[produce a polyphonic DSP with N voices]:voices' \
  '-effect[connect polyphonic output to a global effect]:effect:_files -g "*.dsp"' \
  '-soundfile[add resources required by the soundfile primitive]' \
  '-resample[resample soundfiles to the audio driver sample rate]' \
  '-qrcode[activate QR code generation]' \
  '-arch32[compile a 32 bit binary]' \
  '-arch64[compile a 64 bit binary]' \
  '-source[create source files without compilation]' \
  '-preset[add a preset manager and save presets to the given directory]:directory:_files -/' \
  '-vec[generate easier to vectorize code]' \
  '-vs[size of the vector (default 32 samples)]:size' \
  '-sch[generate tasks and use a Work Stealing scheduler]' \
  '-lv[loop variant: 0 fastest, 1 simple, 2 fixed]:variant:(0 1 2)' \
  '-double[use double precision floats for internal computations]' \
  '-single[use single precision floats for internal computations]' \
  '-ftz[flush to zero: 0 no, 1 fabs based, 2 mask based]:mode:(0 1 2)' \
  '-mcd[use a copy delay up to max delay N]:delay' \
  '-cn[name of the dsp class instead of mydsp]:name' \
  '-scn[name of the super class instead of dsp]:name' \
  '-lang[select the output language]:lang:(c cpp rust cmajor wast wasm)' \
  '-I[add a directory to the libraries search path]:directory:_files -/' \
  '-A[add a directory to the architecture search path]:directory:_files -/' \
  '-O[directory of the generated output code]:directory:_files -/' \
  '-o[the output file]:file:_files' \
  '-e[export expanded DSP with all included libraries]' \
  '-uim[add user interface macro definitions to the output code]' \
  '-json[generate a JSON description file]' \
  '-xml[generate an XML description file]' \
  '-inpl[generate code working when input and output buffers are the same]' \
  '-light[do not generate the entire DSP API]' \
  '*:DSP file:_files -g "*.dsp"' && ret=0

return ret
