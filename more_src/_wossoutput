#compdef wossoutput

# EMBOSS wossoutput: list applications by EDAM output
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output filename]:file:_files' \
  '-sensitive[search definitions/comments not just preferred name]' \
  '-subclasses[include subclasses of matched terms]' \
  '-obsoletes[include obsolete terms]' \
  '-explode[show all subclasses]' \
  '-showembassy=[EMBASSY package(s)]:packages:' \
  '-html[output as HTML]' \
  '-groups[show groups info]' \
  '-alphabetic[sort alphabetically]' \
  '*:query EDAM output:' && ret=0

return ret
