#compdef helm-restore
# Documentation: https://github.com/maorfr/helm-restore
# helm restore: restore last deployed release to original state

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--tiller-namespace=[namespace where Tiller is deployed]:namespace:' \
  '(-l --label)'{-l,--label}'=[label selector for Tiller resources]:label:' \
  '*:release:' && ret=0

return ret
