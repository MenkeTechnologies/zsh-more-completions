#compdef targetp
# Documentation: https://services.healthtech.dtu.dk/services/TargetP-2.0/
# targetp 2.0 - predict N-terminal targeting peptides (SP, mTP, cTP, luTP)

local ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-fasta+[input protein sequences in FASTA format]:file:_files' \
  '-org+[organism group]:org:(non-pl pl)' \
  '-format+[output format]:format:(short long)' \
  '*:fasta file:_files' && ret=0

return ret
