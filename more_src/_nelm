#compdef nelm
# Documentation: https://github.com/werf/nelm
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nelm - a Helm 4 alternative for deploying Helm Charts to Kubernetes (werf).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'release:manage releases (install, plan, list, rollback, uninstall, history, get)'
  'chart:manage charts (lint, render, download, upload, pack, dependency, secret)'
  'repo:manage chart repositories (add, remove, update, login, logout)'
  'completion:generate shell completion scripts'
  'version:print nelm version'
  'help:show help for any command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'nelm command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (release)
        _arguments \
          '1:subcommand:(install plan rollback uninstall list history get)' \
          '*::args:_default' && ret=0
        ;;
      (chart)
        _arguments \
          '1:subcommand:(lint render download upload pack dependency secret)' \
          '*::args:_default' && ret=0
        ;;
      (repo)
        _arguments \
          '1:subcommand:(add remove update login logout)' \
          '*::args:_default' && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash fish powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
