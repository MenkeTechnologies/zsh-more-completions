#compdef ojph_expand
# Documentation: https://github.com/aous72/OpenJPH
# Reference accessed: 2026-05-19
# Verified: local `ojph_expand` help output (/opt/homebrew/bin/ojph_expand).

local -a arguments

arguments=(
    '-i[input file]:input file:_files -g "*.{j2c,jph,j2k}"'
    '-o[output file (pgm/ppm/tif(f)/raw(yuv))]:output file:_files -g "*.{ppm,pgm,raw,yuv,png,tif,tiff,bmp}"'
    '-skip_res[resolutions to skip (parse,reconstruct)]:levels'
    '-resilient[continue on recoverable errors]:resilient:(true false)'
)

_arguments -s -S $arguments
