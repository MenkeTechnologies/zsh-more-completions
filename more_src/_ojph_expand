#compdef ojph_expand

local -a arguments

arguments=(
    '-i[Input file]:input file:_files -g "*.{j2c,jph,j2k}"'
    '-o[Output file]:output file:_files -g "*.{ppm,pgm,raw,yuv,png,tif,tiff,bmp}"'
    '-skip_res=[Number of resolution levels to skip]:levels'
    '-resilient[Enable error resilience]'
    '-num_threads=[Number of threads]:threads'
)

_arguments -s -S $arguments
