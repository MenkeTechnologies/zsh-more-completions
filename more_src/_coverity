#compdef coverity cov-analyze cov-build cov-commit-defects cov-import-results cov-manage-emit cov-translate
# _coverity — Synopsys Coverity static analysis CLI suite (Black Duck Software / Synopsys, C++); custom argparse
# upstream: https://github.com/blackducksoftware/synopsys-detect

_coverity() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--ident[show version + build ID]' \
        '--version[show version]' \
        '--dir+[intermediate directory]:dir:_files -/' \
        '-d+[intermediate directory]:dir:_files -/' \
        '--config+[config file]:file:_files -g "*.xml"' \
        '-c+[config file]:file:_files -g "*.xml"' \
        '--allow-symlinks[allow symlinks]' \
        '--no-command[no command]' \
        '--quiet[quiet]' \
        '--verbose+[verbose level]:n:' \
        '--debug+[debug categories]:str:' \
        '--user+[CI user]:str:_users' \
        '--password+[CI password]:str:' \
        '--host+[CI host]:host:_hosts' \
        '--port+[CI port]:port:' \
        '--scm+[SCM]:scm:(git svn p4 hg cvs accurev tfs)' \
        '--scm-tool+[SCM tool path]:file:_files' \
        '--strip-path+[strip path]:str:' \
        '--cwd+[change working dir]:dir:_files -/' \
        '--all[all]' \
        '--security[security checkers]' \
        '--security-all[security all]' \
        '--security-misra[security misra]' \
        '--enable+[enable checker]:checker:' \
        '--disable+[disable checker]:checker:' \
        '--enable-default[enable default]' \
        '--disable-default[disable default]' \
        '--checker-option+[checker option]:str:' \
        '--paths+[parallel paths]:n:' \
        '-j+[parallel paths]:n:' \
        '--max-mem+[max mem mb]:n:' \
        '--strip+[strip prefix]:str:' \
        '--encoding+[source encoding]:enc:' \
        '--stream+[stream name]:str:' \
        '--project+[project name]:str:' \
        '--description+[description]:str:' \
        '--language+[language]:lang:(c cpp cs java javascript python php go kotlin ruby swift typescript)' \
        '--platform+[platform]:str:' \
        '--platform-version+[platform version]:str:' \
        '--ticker+[ticker]:str:' \
        '--target+[target]:str:' \
        '--branch+[branch]:str:' \
        '--commit+[commit sha]:sha:' \
        '--snapshot-id+[snapshot id]:id:' \
        '--ttl+[time-to-live]:n:' \
        '--analyze-captured-source[analyze captured source]' \
        '--analyze-captured-binaries[analyze captured binaries]' \
        '--webapp-security[webapp security checkers]' \
        '--enable-callgraph-metrics[enable callgraph metrics]' \
        '--analyze-rta-binary[analyze rta binary]' \
        '--strip-path+[strip path]:str:' \
        '--add-strip-path+[add strip path]:str:' \
        '*:arg:'
}

_coverity "$@"
