#compdef makesure
# Documentation: https://github.com/xonixx/makesure
# makesure - make-like task runner driven by a Makesurefile

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage help and exit]' \
  '(-v --version)'{-v,--version}'[display version information and exit]' \
  '(-f --file)'{-f,--file}'[buildfile to use]:file:_files' \
  '(-l --list)'{-l,--list}'[list available non-private goals]' \
  '(-la --list-all)'{-la,--list-all}'[list all goals including private]' \
  '(-d --resolved)'{-d,--resolved}'[show resolved dependencies for goals]' \
  '(-D --define)'{-D,--define}'[override @define value]:var=val' \
  '(-s --silent)'{-s,--silent}'[silent mode, suppress goal logging]' \
  '(-t --timing)'{-t,--timing}'[report execution times]' \
  '(-x --tracing)'{-x,--tracing}'[enable bash/sh tracing via set -x]' \
  '(-U --selfupdate)'{-U,--selfupdate}'[update makesure to latest version]' \
  '*:goal:_default' && ret=0

return ret
