#compdef git-delete-merged-branches

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--branch[target branch to check against]:branch:' \
  '--effort[level of effort for detecting merged branches]:level:(1 2 3)' \
  '--delete-local-only[only delete local branches]' \
  '--delete-remote-only[only delete remote branches]' \
  '--yes[skip confirmation prompts]' \
  '--dry-run[only show what would be deleted]' \
  '-v[enable verbose output]' && ret=0

return ret
