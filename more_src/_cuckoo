#compdef cuckoo
# _cuckoo — Cuckoo Sandbox cuckoo CLI open-source malware-analysis system orchestrating Windows Linux macOS VM-based detonation behavioural-monitoring of suspicious files producing per-task structured JSON reports memory-dumps PCAPs API-driven YARA-rule-matching sandbox infrastructure (Cuckoo Foundation team, Python); argparse
# upstream: https://cuckoosandbox.org/

_cuckoo() {
    local -a sub=(
        'submit:submit a sample'
        'process:process pending tasks'
        'community:fetch the community signatures'
        'clean:clean working directory'
        'distributed:run in distributed mode'
        'machine:manage analysis machines'
        'api:start API server'
        'web:start web dashboard'
        'rooter:start rooter'
        'apidocs:generate API docs'
        'dnsserve:start internal DNS server'
        'init:initialize working directory'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--nolog[disable logging]' \
        '--user=+[user]:_users' \
        '--root=+[dir]:dir:_files -/' \
        '--cwd=+[dir]:dir:_files -/' \
        '--max-analysis-count=+[N]:n:' \
        '--max-vmstartup=+[N]:n:' \
        '--analysis-timeout=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cuckoo subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments \
                    '-u+[url]:str:' \
                    '-f+[file]:file:_files' \
                    '--options=+[opts]:str:' \
                    '--package=+[pkg]:str:' \
                    '--platform=+[p]:p:(windows linux darwin)' \
                    '--machine=+[name]:str:' \
                    '--timeout=+[N]:n:' \
                    '--priority=+[N]:n:(1 2 3)' \
                    '--memory[enable memory dump]' \
                    '--unique[avoid duplicates]' \
                    '*:file or URL:_files' ;;
                machine) _arguments \
                    '1:op:(list add update delete shutdown)' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_cuckoo "$@"
