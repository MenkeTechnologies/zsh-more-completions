#compdef thepeg-config
# Documentation: https://thepeg.hepforge.org/
# thepeg-config - query ThePEG build/link configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show this help message]' \
  '--prefix[show the installation prefix]' \
  '--datadir[path to directory containing shared data]' \
  '--libdir[path to directory containing the libraries]' \
  '--includedir[path to directory containing the headers]' \
  '--cppflags[show the required CPPFLAGS for building against ThePEG]' \
  '--ldflags[show the required LDFLAGS for linking against ThePEG]' \
  '--ldlibs[show the required libraries for linking against ThePEG]' \
  '--rivet-include[path to directory containing the Rivet headers]' \
  '--fastjet-include[path to directory containing the FastJet headers]' \
  '--rivet-libs[required libraries for linking against Rivet]' \
  '--fastjet-libs[required libraries for linking against FastJet]' && ret=0

return ret
