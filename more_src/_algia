# WHAT IT IS
#   algia is "a CLI application for nostr" — Yasuhiro Matsumoto's
#   feature-complete nostr terminal client.  It manages your
#   nostr identity (nsec stored in `~/.config/algia/config.json`)
#   plus a configurable relay set, then exposes every common
#   nostr operation as a typed subcommand:  read your follow-
#   feed (`timeline`), live-stream events (`stream`), publish
#   new notes (`post`/`reply`), react (`like`/`unlike`),
#   broadcast existing events (`broadcast`), send and read NIP-04
#   encrypted DMs (`dm-list`/`dm-timeline`/`dm-post`), manage
#   bookmarks (`bm-list`/`bm-post`), inspect and update your
#   profile metadata (`profile`/`update-profile`), publish
#   long-form articles via the `--article-name`/`--article-
#   title`/`--article-summary` flags on `post`, send Lightning
#   zaps (`zap`), report abusive content (`report`), manage
#   custom follow lists (`list*`), participate in NIP-28 public
#   channels (`channel-*`), and run an MCP server for AI agents
#   (`mcp`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go top-level
#                       urfave/cli/v2 `cli.App` chain — 30+
#                       subcommands organized in topical
#                       groups)
#   algia [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global flags:
#     -a <PROFILE>                   Profile name
#                                    (loads
#                                    `~/.config/algia/
#                                    config-<PROFILE>.json`)
#     --relays <CSV>                 Override relays for this
#                                    invocation
#     -V                             Verbose output
#
#   Subcommands (selected):
#     timeline                       Read your follow-feed
#       -u <USER>                      Filter by user
#       -n <N>                         Number of items
#                                      [default: 30]
#       --json                         Output as JSON
#       --extra                        Extra JSON fields
#       --article                      Show articles
#       --global                       Show global timeline
#
#     stream                         Live-stream events
#       --json / --author <PUBKEY> / --kind <KIND> /
#       --pattern <REGEX> / --reply <ID> / --tag <KEY=VAL> /
#       --global
#
#     post                           Publish a new note
#       -u <USER>...                   Mention users
#       --stdin                        Read content from stdin
#       --sensitive <REASON>           Mark as sensitive
#       --emoji <SHORTCODE>...         Custom emoji
#       --geohash <CODE>               Attach geohash
#       --tag <KEY=VAL>...             Custom tag (k=v1;v2)
#       --article-name <NAME>          Long-form article slug
#       --article-title <TITLE>        Long-form article title
#       --article-summary <SUMMARY>    Long-form article summary
#       --created-at <UNIX>            Override created_at
#                                      timestamp
#
#     reply / repost / unrepost / like / unlike / delete /
#     search / broadcast
#
#   Direct-message commands:
#     dm-list / dm-timeline / dm-post
#
#   Bookmark commands:
#     bm-list / bm-post
#
#   Profile commands:
#     profile / update-profile / npub
#
#   Event commands:
#     event / cat
#
#   Utility commands:
#     powa / puru / mcp / zap / version
#
#   List commands:
#     list / list-show / list-add / list-remove / list-delete
#
#   NIP-28 channel commands:
#     channel-create / channel-list / channel-timeline /
#     channel-stream / channel-post
#
#   Moderation:
#     report
#
#   Standard urfave/cli auto-flags:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/nbd-wtf/go-nostr v0.52.3`
#   declared in go.mod — `go-nostr` is THE canonical Go Nostr
#   SDK maintained by fiatjaf and the nbd-wtf org (nbd-wtf/
#   go-nostr, 600+ stars; the predominant typed Nostr client
#   in the Go ecosystem, used by Khatru, Strfry-mirror,
#   getAlby's nostr-wallet-connect, Algia, Narr, Arkd, and
#   dozens of other Go nostr applications).  go-nostr exposes
#   the typed `nostr.Event{ID, PubKey, CreatedAt, Kind, Tags,
#   Content, Sig}`, the `nostr.Filter` query builder with
#   `Authors`/`Kinds`/`Tags`/`Since`/`Until`/`Limit`/`Search`
#   fields, the `nostr.Tag` slice + `nostr.TagMap`, the
#   `nostr.RelayPool` and `nostr.SimplePool` connection
#   managers with `pool.Subscribe(ctx, urls, filters)` /
#   `pool.QuerySingle(ctx, urls, filter)`, automatic AUTH
#   handling, the `nostr.Relay` single-relay primitive with
#   `Publish`/`Subscribe`/`Close`, every NIP-19 bech32
#   identifier (npub/nsec/note/nevent/nprofile/naddr) via
#   `nip19.Decode` / `nip19.EncodeXxx`, NIP-04 encrypted DM
#   helpers (`nip04.Encrypt`/`nip04.Decrypt`), NIP-44 v2
#   encrypted payloads (`nip44.Encrypt`/`nip44.Decrypt`),
#   NIP-59 gift-wrap (`nip59.GiftWrap`), schnorr signing via
#   the bundled `btcec`-based crypto, the `nostr.GetPublicKey`
#   helper, and a `SimplePool.WithAuthHandler` for handling
#   NIP-42 challenges.  algia's `main.go` constructs a
#   `nostr.NewSimplePool(ctx, nostr.WithAuthHandler(...))`,
#   loads the user's nsec via `nip19.Decode`, builds a typed
#   `nostr.Filter` per subcommand, and routes
#   `pool.Subscribe`/`pool.QuerySingle` calls to the
#   configured relay set.  Verified via:
#     gh api repos/mattn/algia/contents/go.mod
#       → github.com/nbd-wtf/go-nostr v0.52.3
#       → github.com/urfave/cli/v2 v2.27.7
#       → module github.com/mattn/algia
#     gh api repos/mattn/algia/contents/main.go
#       → import "github.com/nbd-wtf/go-nostr"
#       → import "github.com/nbd-wtf/go-nostr/nip04"
#       → import "github.com/nbd-wtf/go-nostr/nip19"
#       → import "github.com/nbd-wtf/go-nostr/nip44"
#       → import "github.com/nbd-wtf/go-nostr/nip59"
#       → Commands: timeline | stream | post | reply | repost
#         | unrepost | like | unlike | delete | search |
#         broadcast | dm-list | dm-timeline | dm-post |
#         bm-list | bm-post | profile | update-profile | npub
#         | powa | puru | mcp | zap | event | version | cat |
#         list | list-show | list-add | list-remove |
#         list-delete | channel-create | channel-list |
#         channel-timeline | channel-stream | channel-post |
#         report
#   This entry is the Go=152 leader bump that continues Axis
#   97 (Nostr / nostr-sdk-rs protocol library) opened at R977
#   with Rust=nostr-sdk via DanConwayDev/ngit-cli.
#
#   No completion for `algia` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_algia() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '-a[profile name]:profile:' \
        '--relays=[override relays]:csv:' \
        '-V[verbose output]' \
        '1: :_algia_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                timeline)
                    _arguments \
                        '-u=[filter by user]:user:' \
                        '-n=[number of items (default 30)]:n:' \
                        '--json[output as JSON]' \
                        '--extra[extra JSON fields]' \
                        '--article[show articles]' \
                        '--global[show global timeline]' && ret=0 ;;
                stream)
                    _arguments \
                        '--json[output as JSON]' \
                        '*--author=[filter by author pubkey]:pubkey:' \
                        '*--kind=[event kind]:kind:' \
                        '--pattern=[content regex]:regex:' \
                        '--reply=[filter to replies of event id]:event-id:' \
                        '*--tag=[tag filter (k=v)]:tag:' \
                        '--global[show global stream]' && ret=0 ;;
                post)
                    _arguments \
                        '*-u=[mention users]:user:' \
                        '--stdin[read content from stdin]' \
                        '--sensitive=[mark as sensitive (reason)]:reason:' \
                        '*--emoji=[custom emoji shortcode]:shortcode:' \
                        '--geohash=[attach geohash]:code:' \
                        '*--tag=[custom tag (k=v1;v2)]:tag:' \
                        '*-t=[custom tag]:tag:' \
                        '--article-name=[long-form article slug]:slug:' \
                        '--article-title=[long-form article title]:title:' \
                        '--article-summary=[long-form article summary]:summary:' \
                        '--created-at=[override created_at (unix)]:timestamp:' && ret=0 ;;
                reply)
                    _arguments \
                        '--stdin[read content from stdin]' \
                        '--id=[event id to reply to (REQUIRED)]:event-id:' \
                        '--quote[quote-reply]' \
                        '--sensitive=[mark as sensitive]:reason:' \
                        '*--emoji=[custom emoji]:shortcode:' \
                        '--geohash=[attach geohash]:code:' && ret=0 ;;
                dm-post)
                    _arguments \
                        ':recipient pubkey:' \
                        '*:message:' && ret=0 ;;
                channel-create|channel-list|channel-timeline|channel-stream|channel-post|\
                broadcast|like|unlike|repost|unrepost|delete|search|\
                dm-list|dm-timeline|bm-list|bm-post|\
                profile|update-profile|npub|powa|puru|mcp|zap|event|cat|version|report|\
                list|list-show|list-add|list-remove|list-delete)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_algia_commands] )) ||
_algia_commands() {
    local -a commands
    commands=(
        'timeline:read your follow-feed'
        'stream:live-stream nostr events'
        'post:publish a new note'
        'reply:reply to an event'
        'repost:repost an event'
        'unrepost:undo a repost'
        'like:like an event'
        'unlike:undo a like'
        'delete:delete one of your events'
        'search:search nostr events'
        'broadcast:broadcast an existing event to your relay set'
        'dm-list:list DM threads'
        'dm-timeline:show a DM thread'
        'dm-post:send an encrypted DM'
        'bm-list:list bookmarks'
        'bm-post:add a bookmark'
        'profile:show profile metadata'
        'update-profile:update your profile metadata'
        'npub:print your npub'
        'powa:NIP-13 proof-of-work test'
        'puru:emit a tiny "puru" event'
        'mcp:run as an MCP server for AI agents'
        'zap:send a Lightning zap'
        'event:emit a raw event'
        'cat:cat a single event'
        'version:show version'
        'list:list custom follow lists'
        'list-show:show a custom follow list'
        'list-add:add to a custom follow list'
        'list-remove:remove from a custom follow list'
        'list-delete:delete a custom follow list'
        'channel-create:create a NIP-28 public channel'
        'channel-list:list NIP-28 channels'
        'channel-timeline:show a NIP-28 channel timeline'
        'channel-stream:stream a NIP-28 channel'
        'channel-post:post in a NIP-28 channel'
        'report:report abusive content'
    )
    _describe -t commands 'algia command' commands
}

_algia "$@"
