#compdef rocsolver-test rocsolver-bench
# _rocsolver — AMD ROCm rocSOLVER LAPACK functionality dense linear algebra solver tests and benchmark runner (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocSOLVER

_rocsolver() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_print_time=+[bool]:b:(0 1)' \
        '--gtest_output=+[format:file]:str:' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '-r+[precision]:p:(s d c z)' \
        '--precision=+[precision]:p:(s d c z)' \
        '-f+[function]:str:' \
        '--function=+[function]:str:' \
        '-m+[rows]:n:' \
        '-M+[rows]:n:' \
        '--sizeM=+[rows]:n:' \
        '-n+[cols]:n:' \
        '-N+[cols]:n:' \
        '--sizeN=+[cols]:n:' \
        '-k+[K]:n:' \
        '-K+[K]:n:' \
        '--sizeK=+[K]:n:' \
        '--ldA=+[ld A]:n:' \
        '--ldB=+[ld B]:n:' \
        '--ldC=+[ld C]:n:' \
        '--strideA=+[stride A]:n:' \
        '--strideB=+[stride B]:n:' \
        '--strideC=+[stride C]:n:' \
        '--batch_count=+[batch]:n:' \
        '--no_strided[no strided]' \
        '--transA=+[N T C]:str:' \
        '--transB=+[N T C]:str:' \
        '--side=+[L R]:str:' \
        '--uplo=+[U L]:str:' \
        '--direct=+[F B]:str:' \
        '--storev=+[C R]:str:' \
        '--itype=+[type]:n:' \
        '--evect=+[V N]:str:' \
        '--algo=+[algo]:str:' \
        '--devices=+[device id csv]:str:' \
        '--iters=+[iterations]:n:' \
        '--cold_iters=+[N]:n:' \
        '--bsymetric[blocked symmetric]' \
        '--profile=+[file]:file:_files'
}

_rocsolver "$@"
