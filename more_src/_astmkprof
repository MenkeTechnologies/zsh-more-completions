#compdef astmkprof
# Documentation: https://www.gnu.org/software/gnuastro/manual/html_node/Invoking-astmkprof.html
# astmkprof — create a FITS image of mock astronomical profiles from an input catalog

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[only report errors, remain quiet about steps]' \
  '(-P --printparams)'{-P,--printparams}'[print parameter values and abort]' \
  '(-o --output)'{-o,--output}'[output file name]:file:_files' \
  '(-T --type)'{-T,--type}'[type of output]:type:(uint8 int8 uint16 int16 uint32 int32 uint64 int64 float32 float64)' \
  '(-D --dontdelete)'{-D,--dontdelete}'[do not delete output if it exists]' \
  '(-K --keepinputdir)'{-K,--keepinputdir}'[keep input directory for automatic output]' \
  '--wcslinearmatrix[WCS linear matrix of output]:matrix:(pc cd)' \
  '(-h --hdu)'{-h,--hdu}'[input catalog HDU name or number]:HDU' \
  '(-I --ignorecase)'{-I,--ignorecase}'[ignore case when matching column names]' \
  '--searchin[where to search for columns]:where:(name unit comment)' \
  '--stdintimeout[microseconds to wait for standard input]:microseconds' \
  '(-k --background)'{-k,--background}'[background image for profiles]:file:_files' \
  '(-B --backhdu)'{-B,--backhdu}'[HDU of background image]:HDU' \
  '(-C --clearcanvas)'{-C,--clearcanvas}'[read all background pixels as zero]' \
  '(-E --kernel)'{-E,--kernel}'[parameters to build one kernel only]:params' \
  '--customimg[image file for custom-img profile]:file:_files' \
  '--customimghdu[HDU of custom image]:HDU' \
  '--customtable[file for custom-prof profile]:file:_files' \
  '--customtablehdu[HDU of custom table]:HDU' \
  '(-i --individual)'{-i,--individual}'[build all profiles separately]' \
  '(-m --nomerged)'{-m,--nomerged}'[do not create merged image]' \
  '--psfinimg[PSF profiles made with all in output]' \
  '(-s --oversample)'{-s,--oversample}'[oversampling scale (odd integer)]:scale' \
  '(-x --mergedsize)'{-x,--mergedsize}'[merged image size per dimension]:size' \
  '(-c --prepforconv)'{-c,--prepforconv}'[shift/expand based on first catalog PSF]' \
  '(-e --envseed)'{-e,--envseed}'[use GSL_RNG_SEED environment variable]' \
  '(-f --mforflatpix)'{-f,--mforflatpix}'[mcol is flat pixel value]' \
  '--magatpeak[magnitude for peak pixel, not full profile]' \
  '--mcolisbrightness[mcol is total brightness, not magnitude]' \
  '--mcolnocustimg[ignore mcol in custom-img]' \
  '--mcolnocustprof[ignore mcol in custom-prof]' \
  '--mode[--ccol coordinate mode]:mode:(img wcs)' \
  '(-p --tunitinp)'{-p,--tunitinp}'[truncation in pixel units, not radius]' \
  '(-r --numrandom)'{-r,--numrandom}'[random points for Monte Carlo integration]:number' \
  '(-R --replace)'{-R,--replace}'[replace overlapping pixels instead of adding]' \
  '(-t --tolerance)'{-t,--tolerance}'[tolerance for switching methods]:tolerance' \
  '(-w --circumwidth)'{-w,--circumwidth}'[circumference profile width (inward)]:width' \
  '(-X --shift)'{-X,--shift}'[shift profile centers in output]:shift' \
  '(-z --zeropoint)'{-z,--zeropoint}'[magnitude zero point]:magnitude' \
  '--ccol[coordinate columns (one per dimension)]:column' \
  '--fcol[profile type column]:column' \
  '--rcol[effective radius or FWHM column]:column' \
  '--ncol[Sersic index or Moffat beta column]:column' \
  '--pcol[position angle column]:column' \
  '--p2col[second Euler angle column]:column' \
  '--p3col[third Euler angle column]:column' \
  '--qcol[axis ratio column]:column' \
  '--q2col[second axis ratio column]:column' \
  '--mcol[magnitude column]:column' \
  '--tcol[truncation column]:column' \
  '--crpix[pixel coordinates of reference point]:crpix' \
  '--crval[WCS coordinates of reference point]:crval' \
  '--cdelt[resolution per dimension]:cdelt' \
  '--pc[WCS rotation matrix elements]:pc' \
  '--cunit[WCS coordinate units]:cunit' \
  '--ctype[FITS standard WCS types]:ctype' \
  '*:catalog:_files' && ret=0

return ret
