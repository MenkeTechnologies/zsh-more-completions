#compdef kumactl
# _kuma — Kuma service mesh CLI (Kong + Kuma, Go); install/manage Kuma control plane on k8s/VMs
# upstream: https://github.com/kumahq/kuma

_kuma() {
    local -a sub=(
        'apply:apply Kuma resources'
        'completion:print shell completion'
        'config:configure kumactl'
        'delete:delete Kuma resources'
        'generate:generate signing keys / cert'
        'get:get Kuma resources'
        'help:show help'
        'inspect:inspect resources'
        'install:install Kuma components'
        'uninstall:uninstall Kuma'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config-file+[config file]:file:_files' \
        '--api-timeout+[api timeout]:duration:' \
        '--log-level+[log level]:level:(off info debug)' \
        '--no-config[do not read config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kumactl subcommand' sub ;;
        args)
            case $words[1] in
                apply|delete) _arguments \
                    '-f+[resource file]:file:_files' \
                    '--file+[resource file]:file:_files' \
                    '--dry-run[dry run]' \
                    '-v+[variable]:KEY=VAL:' \
                    '--var+[variable]:KEY=VAL:' ;;
                get) _arguments \
                    '1:resource:(meshes dataplanes traffic-permissions traffic-routes traffic-traces traffic-logs traffic-rate-limit virtual-outbounds zones zone-egresses zone-ingresses retries timeouts proxytemplates secrets globalsecrets)' \
                    '*:name:' ;;
                inspect) _arguments \
                    '1:type:(meshes dataplanes services zones zone-egresses zone-ingresses policies)' \
                    '*:name:' ;;
                install) _arguments \
                    '1:component:(control-plane crds gateway logging metrics tracing transparent-proxy demo policy observability)' \
                    '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_kuma "$@"
