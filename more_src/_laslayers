#compdef laslayers
# Documentation: https://github.com/LAStools/LAStools
# LAStools: manage LASlayers (.lay) files storing edits/filters for LAS/LAZ

local ret=1

_arguments -s -S \
  '-help[display help information]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-verbose[print extra information]' \
  '-add[create or add to LAY files]' \
  '-del+[remove a specific layer by index]:n' \
  '-del_last+[remove the last N layers]:n' \
  '-detach[separate layers from the file]' \
  '-diff[generate difference LAY file between two files]' \
  '-ilay+[apply N or all LASlayers found on read]:n' \
  '-ilaydir+[look for LAY file in directory]:dir:_files -/' \
  '-olay[write/append classification changes to LAY file]' \
  '-olaydir+[write output LAY file to directory]:dir:_files -/' \
  '-short[display layer information only]' \
  '*-i+[input file or file pattern]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
