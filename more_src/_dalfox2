#compdef dalfox2
# _dalfox2 — hahwul Hyeong Hwul dalfox2 CLI command-line frontend wrapping the Dalfox powerful open-source XSS scanner and parameter analyzer utility written in Go DOM-XSS-Stored-XSS-Reflected-XSS Race-condition Mass-mode-from-pipe Mining-DOM-objects Static-analysis with-Babel-JS-bytecode-parser Optimization Headless-mode Bypass-WAF Custom-Header Custom-Payload Forwarding-PoCs Browser-Action JSON-CSV-output silent mining-dict found-action raw waf-bypass deep-domxss (hahwul team, Go); cobra
# upstream: https://github.com/hahwul/dalfox

_dalfox2() {
    local -a sub=(
        'url:scan a single URL'
        'file:scan from a file'
        'pipe:scan from stdin'
        'sxss:stored XSS'
        'payload:show payload'
        'server:start API server'
        'completion:generate shell completion'
        'update:update dalfox'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[data]:str:' \
        '--data=+[data]:str:' \
        '-H+[header]:str:' \
        '*-H+[header]:str:' \
        '--cookie=+[cookie]:str:' \
        '-X+[method]:m:(GET POST PUT DELETE PATCH OPTIONS TRACE HEAD)' \
        '--method=+[m]:m:(GET POST PUT DELETE PATCH OPTIONS TRACE HEAD)' \
        '--user-agent=+[ua]:str:' \
        '-w+[worker]:n:' \
        '--worker=+[N]:n:' \
        '--delay=+[ms]:n:' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '--proxy=+[url]:str:' \
        '--blind=+[url]:str:' \
        '-b+[blind url]:str:' \
        '--config=+[file]:file:_files -g "*.json *.yaml *.yml"' \
        '-C+[config]:file:_files' \
        '--custom-payload=+[file]:file:_files' \
        '--custom-alert-value=+[s]:str:' \
        '--custom-alert-type=+[t]:str:' \
        '--found-action=+[cmd]:str:' \
        '--found-action-shell=+[shell]:str:' \
        '--mining-dict-word=+[file]:file:_files' \
        '--mining-dict[enable dict mining]' \
        '--mining-dom[enable DOM mining]' \
        '--mining-dom-types=+[types]:str:' \
        '--ignore-params=+[params]:str:' \
        '--remote-payloads=+[name]:str:' \
        '--remote-wordlists=+[name]:str:' \
        '--only-discovery[discovery only]' \
        '--only-custom-payload[only custom payload]' \
        '--no-spinner[no spinner]' \
        '--no-color[no color]' \
        '--silence[silence]' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--format=+[fmt]:f:(plain json csv jsonl)' \
        '-f+[format]:f:(plain json csv jsonl)' \
        '--output-all[output all]' \
        '--output-request[output request]' \
        '--output-response[output response]' \
        '--report[report]' \
        '--report-format=+[fmt]:f:(plain json)' \
        '--har-file-path=+[file]:file:_files -g "*.har"' \
        '--debug[debug]' \
        '--skip-bav[skip BAV]' \
        '--skip-discovery[skip discovery]' \
        '--skip-grep[skip grep]' \
        '--skip-mining-all[skip mining all]' \
        '--skip-mining-dict[skip mining dict]' \
        '--skip-mining-dom[skip mining DOM]' \
        '--skip-xss-scanning[skip XSS scanning]' \
        '--skip-headless[skip headless]' \
        '--waf-evasion[WAF evasion]' \
        '--use-headless[use headless]' \
        '--use-bav[use BAV]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dalfox subcommand' sub ;;
        args)
            case $words[1] in
                url) _arguments '*:url:' ;;
                file|pipe) _arguments '*:file:_files' ;;
                sxss) _arguments '1:trigger url:' '2:target url:' ;;
                payload) _arguments '1:op:(--enum-xss-payload --enum-html-payload --enum-attr-payload --enum-injs-payload --remote-payloadbox --remote-portswigger --make-bav --entity-cve)' '*:arg:' ;;
            esac
            ;;
    esac
}

_dalfox2 "$@"
