#compdef syncoid

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--compress+[compression algorithm]:algorithm:(none lz4 gzip pigz-fast pigz-slow zstd)' \
  '--create-bookmark[create bookmark on source]' \
  '--debug[debug output]' \
  '--dumpsnaps[dump snapshot list and exit]' \
  '--exclude+[exclude datasets matching regex]:regex:' \
  '--force-delete[force deletion of old snapshots on target]' \
  '--identifier+[sync identifier]:id:' \
  '--insecure-direct-connection[skip host key verification]' \
  '--mbuffer-size+[mbuffer queue size]:size:' \
  '--no-command-checks[skip remote command checks]' \
  '--no-clone-handling[do not handle clones]' \
  '--no-privilege-elevation[do not use sudo]' \
  '--no-resume[do not use resume tokens]' \
  '--no-rollback[do not rollback destination]' \
  '--no-stream[use individual snapshots instead of stream]' \
  '--no-sync-snap[do not create new sync snapshot]' \
  '--pv-options+[pv command options]:options:' \
  '--quiet[suppress non-error output]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into child datasets]' \
  '--sendoptions+[additional zfs send options]:options:' \
  '--recvoptions+[additional zfs recv options]:options:' \
  '--skip-parent[do not sync the parent dataset]' \
  '--source-bwlimit+[bandwidth limit for source]:limit:' \
  '--target-bwlimit+[bandwidth limit for target]:limit:' \
  '--sshcipher+[SSH cipher to use]:cipher:' \
  '--sshkey+[SSH key file]:key:_files' \
  '--sshport+[SSH port]:port:' \
  '--sshoption+[SSH option]:option:' \
  '--use-hold[use zfs hold/release on snapshots]' \
  '1:source dataset:' \
  '2:target dataset:' && ret=0

return ret
