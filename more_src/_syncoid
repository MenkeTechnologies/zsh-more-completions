#compdef syncoid
# Documentation: https://github.com/jimsalterjrs/sanoid
# Reference accessed: 2026-05-21
# Verified: upstream syncoid Perl script
# (raw.githubusercontent.com/jimsalterjrs/sanoid/master/syncoid).
# Removed: fabricated --exclude flag (real flags are --exclude-datasets,
# --exclude-snaps, --include-snaps).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--compress=[compression algorithm]:algorithm:(gzip pigz-fast pigz-slow zstd-fast zstdmt-fast zstd-slow zstdmt-slow lz4 xz lzo none)' \
  '--create-bookmark[create bookmark on source after send]' \
  '--debug[verbose debug output]' \
  '--dumpsnaps[list snapshots during run]' \
  '--exclude-datasets=[exclude datasets matching regex]:regex:' \
  '--exclude-snaps=[exclude snapshots matching regex]:regex:' \
  '--include-snaps=[only include snapshots matching regex]:regex:' \
  '--delete-target-snapshots[destroy snapshots present only on target]' \
  '--force-delete[forcefully remove conflicting datasets]' \
  '--identifier=[extra identifier for snapshot/hold names]:id:' \
  '--insecure-direct-connection=[unencrypted direct data connection IP:PORT]:ip\:port:' \
  '--keep-sync-snap[do not prune syncoid-created sync snapshots]' \
  '--mbuffer-size=[mbuffer queue size]:size:' \
  '--monitor-version[version monitoring]' \
  '--no-command-checks[skip remote command availability checks]' \
  '--no-clone-handling[skip clone recreation handling]' \
  '--no-privilege-elevation[bypass root requirement]' \
  '--no-resume[do not use ZFS resume tokens]' \
  '--no-rollback[do not rollback destination]' \
  '--no-stream[use newest snapshot only, no intermediates]' \
  '--no-sync-snap[do not create a new sync snapshot]' \
  '--preserve-recordsize[preserve recordsize on initial send]' \
  '--preserve-properties[preserve dataset properties]' \
  '--pv-options=[options for pv progress meter]:options:' \
  '--quiet[suppress non-error output]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into child datasets]' \
  '--sendoptions=[additional zfs send flags]:options:' \
  '--recvoptions=[additional zfs receive flags]:options:' \
  '--skip-parent[skip parent dataset (with --recursive)]' \
  '--source-bwlimit=[bandwidth limit for source]:limit:' \
  '--target-bwlimit=[bandwidth limit for target]:limit:' \
  '--sshconfig=[SSH config file]:file:_files' \
  '--sshcipher=[SSH cipher]:cipher:' \
  '--sshkey=[SSH private key]:key:_files' \
  '--sshport=[SSH port]:port:' \
  '--sshoption=[additional SSH option]:option:' \
  '--use-hold[add zfs hold/release on snapshots]' \
  '1:source dataset:' \
  '2:target dataset:' && ret=0

return ret
