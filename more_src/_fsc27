#compdef fsc27
# Documentation: https://cmpg.unibe.ch/software/fastsimcoal27/man/fastsimcoal27.pdf
# fsc27 (fastsimcoal v2.7): coalescent simulator / SFS-based demographic inference. Flags from the Command-line options appendix.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print all available options]' \
  '(-i --ifile)'{-i,--ifile}'[parameter (.par) input file]:par file:_files -g "*.par"' \
  '(-n --numsims)'{-n,--numsims}'[number of simulations per parameter file]:n:' \
  '(-t --tplfile)'{-t,--tplfile}'[template (.tpl) file]:tpl file:_files -g "*.tpl"' \
  '(-f --dfile)'{-f,--dfile}'[definition (.def) file]:def file:_files -g "*.def"' \
  '(-F --dFile)'{-F,--dFile}'[definition file (no parameter sampling)]:def file:_files -g "*.def"' \
  '(-e --efile)'{-e,--efile}'[estimation (.est) file]:est file:_files -g "*.est"' \
  '(-E --numest)'{-E,--numest}'[number of estimations from random initial values]:n:' \
  '(-g --genotypic)'{-g,--genotypic}'[output genotypic (diploid) Arlequin data]' \
  '(-p --phased)'{-p,--phased}'[output phased data]' \
  '(-s --dnatosnp)'{-s,--dnatosnp}'[output DNA as SNP data]:maxsnps:' \
  '(-S --allsites)'{-S,--allsites}'[output whole DNA sequence including monomorphic sites]' \
  '(-I --inf)'{-I,--inf}'[infinite-sites mutation model]' \
  '(-d --dsfs)'{-d,--dsfs}'[compute derived site frequency spectrum]' \
  '(-m --msfs)'{-m,--msfs}'[compute minor allele frequency SFS]' \
  '(-u --multiSFS)'{-u,--multiSFS}'[compute multidimensional SFS]' \
  '(-0 --removeZeroSFS)'{-0,--removeZeroSFS}'[remove monomorphic sites from SFS]' \
  '(-P --pooledsfs)'{-P,--pooledsfs}'[compute pooled SFS over all samples]' \
  '(-j --jobs)'{-j,--jobs}'[output each replicate in its own directory]' \
  '(-b --nonparboot)'{-b,--nonparboot}'[generate non-parametric bootstrap SFS]:n:' \
  '(-H --header)'{-H,--header}'[output header line in SFS files]' \
  '(-q --quiet)'{-q,--quiet}'[minimal console output]' \
  '(-T --tree)'{-T,--tree}'[output all gene trees]' \
  '(-k --keep)'{-k,--keep}'[max number of recombination segments kept in memory]:n:' \
  '(-r --seed)'{-r,--seed}'[random number generator seed]:seed:' \
  '(-x --noarloutput)'{-x,--noarloutput}'[do not generate Arlequin output files]' \
  '(-M --maxlhood)'{-M,--maxlhood}'[estimate parameters by max composite likelihood]' \
  '(-L --numloops)'{-L,--numloops}'[number of ECM optimization cycles]:n:' \
  '(-l --minnumloops)'{-l,--minnumloops}'[minimum number of ECM cycles]:n:' \
  '(-C --minSFSCount)'{-C,--minSFSCount}'[minimum observed SFS entry count to use]:n:' \
  '(-a --ascDeme)'{-a,--ascDeme}'[deme used for SNP ascertainment]:deme:' \
  '(-A --ascSize)'{-A,--ascSize}'[ascertainment sample size]:size:' \
  '(-w --brentol)'{-w,--brentol}'[Brent optimization tolerance]:tol:' \
  '(-c --cores)'{-c,--cores}'[number of cores for multithreading]:cores:' \
  '(-B --numBatches)'{-B,--numBatches}'[number of batches for multithreading]:n:' \
  '(-G --indgenot)'{-G,--indgenot}'[generate individual genotype table]' \
  '--foldedSFS[compute folded (MAF) SFS]' \
  '--recordMRCA[record tMRCA per non-recombining segment]' \
  '--logprecision[precision for log of random numbers]:digits:' \
  '--nosingleton[ignore singletons in likelihood computation]' \
  '--initValues[file with initial parameter values]:pv file:_files -g "*.pv"' \
  '*:file:_files' && ret=0

return ret
