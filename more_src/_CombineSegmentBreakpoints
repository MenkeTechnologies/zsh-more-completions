#compdef CombineSegmentBreakpoints
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/copynumber/utils/CombineSegmentBreakpoints.java
# Combine the breakpoints of two segment files and annotate the resulting intervals with chosen columns

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'=[output file]:value:_files' \
  '*--segments-file=[input segment file]:value:_files' \
  '*--labels=[label for each segment file]:value:' \
  '*--columns-of-interest=[columns to preserve in output]:value:' \
  '*:argument:_files' && ret=0

return ret
