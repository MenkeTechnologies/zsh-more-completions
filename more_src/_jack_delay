#compdef jack_delay
# Documentation: https://github.com/jackaudio/jack-example-tools
# JACK sound card round-trip latency meter

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-O+[connect output to named playback port]:port' \
  '-I+[connect input to named capture port]:port' \
  '-E[show excess latency instead of full latency]' && ret=0

return ret
