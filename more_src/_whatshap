#compdef whatshap
# Documentation: https://whatshap.readthedocs.io/en/latest/guide.html
# WhatsHap: read-based phasing of genomic variants

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'whatshap subcommand' \
      'phase[phase diploid variants]' \
      'polyphase[phase polyploid variants]' \
      'polyphasegenetic[phase polyploid variants genetically]' \
      'stats[print phasing statistics]' \
      'compare[compare two or more phasings]' \
      'haplotag[tag reads by haplotype]' \
      'genotype[genotype variants]' \
      'split[split reads by haplotype]' \
      'learn[generate sequencing technology specific error profiles]' \
      'haplotagphase[phase VCF using haplotagged BAM]' \
      'unphase[remove phasing information from a VCF]' \
      'hapcut2vcf[convert hapCUT output format to VCF]' && ret=0
    _files
    ;;
esac

return ret
