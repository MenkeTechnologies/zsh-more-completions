#compdef radvd-config
# Documentation: https://man.archlinux.org/search?q=radvd-config
# Reference accessed: 2026-05-16

# radvd-config: utility to generate radvd.conf
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[interface]:interface:' \
  '-p[prefix]:prefix:' \
  '-o[output file]:file:_files' \
  '*::radvd-config args:_files' && ret=0
return ret
