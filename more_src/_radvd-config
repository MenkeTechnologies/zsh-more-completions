#compdef radvd-config

# radvd-config: helper to generate radvd configuration
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-i[network interface]:iface:' \
  '-o[output config file]:file:_files' \
  '-p[prefix]:prefix:' \
  '*::radvd-config args:_files' && ret=0
return ret
