#compdef pcarmf
# Creates an RMF file for an anode chain combination of layers in a PCU

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'outfile=[name of the output .rmf file]:output file:_files' \
  'pcuid=[desired PCU (0 to 4)]:pcu:(0 1 2 3 4)' \
  'lld_code=[desired LLD code]:code:' \
  'cdate=[observation date yyyy-mm-dd]:date:' \
  'chatter=[verbosity level]:level:' \
  'e2c_model=[energy to channel conversion model]:model:' \
  'e2cfile=[file with channel-to-energy parameters]:file:_files' \
  'nofits=[treat e2cfile as local ASCII file]:flag:(0 1)' \
  'scale_hack=[apply fudge factor to response matrix]:flag:(0 1)' \
  'scale_file=[ASCII file with efficiency corrections]:file:_files' \
  'clobber=[delete output file if it exists]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
