#compdef nicerl2
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/nicerl2.html
# Apply standard NICER Level 2 calibration, filtering and screening to an observation

local ret=1

_arguments -s -S \
  'indir=[input NICER observation directory]:indir:_files -/' \
  'ufdir=[uncalibrated event file directory]:ufdir:_files -/' \
  'cldir=[calibrated output file directory]:cldir:_files -/' \
  'mkfile=[filter MKF file name]:mkfile:_files' \
  'ra=[target right ascension J2000 deg]:ra:' \
  'dec=[target declination J2000 deg]:dec:' \
  'detlist=[detector selection expression]:detlist:' \
  'tasks=[operations to perform]:tasks:(CALMERGE MKF SCREEN ALL)' \
  'filtcolumns=[filter file columns to include]:filtcolumns:' \
  'picalfile=[PI gain calibration file or CALDB]:picalfile:' \
  'orbfile=[orbit file]:orbfile:_files' \
  'attfile=[attitude file]:attfile:_files' \
  'nicersaafilt=[apply NICER SAA filtering]:nicersaafilt:(yes no)' \
  'saafilt=[apply SAA filtering]:saafilt:(yes no)' \
  'trackfilt=[apply pointing tracking filtering]:trackfilt:(yes no)' \
  'elv=[ELV filter threshold deg]:elv:' \
  'br_earth=[BR_EARTH filter threshold deg]:br_earth:' \
  'cor_range=[COR_SAX filtering range GeV/c]:cor_range:' \
  'min_fpm=[minimum FPMs required on]:min_fpm:' \
  'threshfilter=[threshold range shortcut]:threshfilter:(ALL DAY NIGHT)' \
  'mingti=[minimum GTI size seconds]:mingti:' \
  'pirange=[pulse height screening range]:pirange:' \
  'trumpetfilt=[apply PI_RATIO background filtering]:trumpetfilt:(yes no)' \
  'timerange=[TIME column range filter]:timerange:' \
  'datamode=[X-ray event type screening mode]:datamode:' \
  'cleanup=[remove temporary files]:cleanup:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[write HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
