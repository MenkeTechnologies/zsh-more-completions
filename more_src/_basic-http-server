_basic-http-server() {
    _arguments -s -S \
        '(-a --addr -p --port --public)'{-a,--addr=}'[IP:PORT combination (conflicts with --port and --public)]:addr:_bind_addresses' \
        '(-a --addr)'{-p,--port=}'[port number (default 4000)]:port:_ports' \
        '(-a --addr)--public[listen on all interfaces (0.0.0.0) instead of localhost]' \
        '-x[enable developer extensions (markdown rendering + dir listing + source-text view via syntect highlighting)]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1:root directory (default .):_files -/'
}

_bind_addresses() {
    local -a addrs
    addrs=(
        '127.0.0.1\:4000:localhost default port'
        '0.0.0.0\:4000:all-interfaces default port (equivalent to --public)'
    )
    _describe -t addrs 'IP:PORT' addrs
}

_basic-http-server "$@"
