#compdef codes_bufr_filter
# Documentation: https://confluence.ecmwf.int/display/ECC/bufr_filter
# Apply filter rules to each BUFR message in the given files (ecCodes).

local ret=1

_arguments -s \
  '-f[force, do not fail on error]' \
  '-o+[write output to file (default filter.out)]:output:_files' \
  '-g[copy GTS header]' \
  '-7[do not fail on wrong message length]' \
  '-v[verbose]' \
  '(- *)-V[print version]' \
  '(- *)-h[display help]' \
  ':rules file:_files' \
  '*:bufr file:_files' && ret=0

return ret
