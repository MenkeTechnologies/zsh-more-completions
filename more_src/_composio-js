#compdef composio-js
# Documentation: https://www.npmjs.com/package/composio-core
# Reference accessed: 2026-05-23
# Verified: npx composio-core help (legacy composio-js binary).

# Zsh completion for composio-js - legacy Composio core CLI binary

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'composio-js command' \
      'whoami[show authentication info]' \
      'login[authenticate with Composio]' \
      'logout[clear authentication]' \
      'apps[list available apps]' \
      'connections[list connections]' \
      'integrations[list integrations]' \
      'triggers[manage triggers]' \
      'add[add a new app]' \
      'actions[Composio actions]' \
      'execute[execute an action]' \
      'mcp[MCP app integration]' \
      'transport[bridge MCP stdio and SSE]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
