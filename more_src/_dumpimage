#compdef dumpimage
# Documentation: https://man.archlinux.org/search?q=dumpimage
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-l[list image header and components]' \
  '-o+[output file]:file:_files' \
  '-p+[component index]:n:' \
  '-T+[image type]:type:' \
  ':image:_files'
