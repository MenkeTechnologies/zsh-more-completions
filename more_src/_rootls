#compdef rootls
# Documentation: https://github.com/root-project/root/blob/master/main/src/rootls.cxx
# Reference accessed: 2026-05-27
# Verified: upstream opts.AddFlag calls in main/src/rootls.cxx

# rootls: list contents of ROOT files (objects, classes, sizes).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-1 --oneColumn)'{-1,--oneColumn}'[print content in one column]' \
  '(-c --allCycles)'{-c,--allCycles}'[force display of all objects'\'' cycles]' \
  '(-l --longListing)'{-l,--longListing}'[use a long listing format]' \
  '(-t --treeListing)'{-t,--treeListing}'[print TTree recursively with long listing]' \
  '(-R --rntupleListing)'{-R,--rntupleListing}'[print RNTuples recursively with long listing]' \
  '(-r --recursiveListing)'{-r,--recursiveListing}'[traverse file recursively entering any TDirectory]' \
  '*:root file:_files -g "*.root"' && ret=0

return ret
