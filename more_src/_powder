#compdef powder
# Documentation: https://man.archlinux.org/search?q=powder
# Reference accessed: 2026-05-16
# Commands from https://github.com/powder-rb/powder/blob/master/bin/powder (Thor CLI, MIT)

local -a _powder_cmds

_powder_cmds=(
  'env:Pass an arbitrary environment variable to pow'
  'env_reset:Remove all custom environment variables'
  'test:Run pow with RAILS_ENV=test'
  'development:Run pow with RAILS_ENV=development'
  'dev:Alias for development'
  'production:Run pow with RAILS_ENV=production'
  'prod:Alias for production'
  'up:Enable pow'
  'start:Alias for up'
  'down:Disable pow'
  'stop:Alias for down'
  'link:Link a pow app'
  'default:Set this app as default'
  'un_default:Remove current default app'
  'restart:Restart current pow'
  'always_restart:Always restart current pow'
  'no_restarts:Reset restart settings'
  'respawn:Restart the pow process'
  'list:List current pows'
  'open:Open a pow in the browser'
  'unlink:Unlink a pow app'
  'remove:Alias for unlink (deprecated)'
  'cleanup:Clean up invalid symbolic links'
  'install:Install or update pow'
  'update:Alias for install'
  'log:Tail the Pow log'
  'applog:Tail log in current app'
  'uninstall:Uninstall pow'
  'debug:Open a debug session'
  'version:Show the version'
  'host:Map pow domains to 127.0.0.1 in hosts file'
  'unhost:Remove pow domains from hosts file'
  'config:Show current pow configuration'
  'status:Show current pow status'
  'portmap:Map a port to an app'
  'env_rvm:Create or add rvm env to .powenv'
)

if (( CURRENT == 1 )); then
  _describe -t commands 'powder command' _powder_cmds && return 0
fi

_default
