#compdef xgps
# Documentation: https://man.archlinux.org/search?q=xgps
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --debug)'{-D,--debug}'+[debug level]:lvl:' \
  '(-l --llfmt)'{-l,--llfmt}'+[lat/lon format]:fmt:(d m s)' \
  '(-u --units)'{-u,--units}'+[units]:units:(imperial nautical metric)' \
  '*:server:_hosts' && ret=0

return ret
