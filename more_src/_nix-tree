#compdef nix-tree
# Documentation: https://man.archlinux.org/search?q=nix-tree
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--derivation[show derivation dependencies]' \
  '--dot[output in Graphviz dot format]' \
  '--impure[allow impure expressions]' \
  '--json[output as JSON]' \
  '--quiet[suppress output]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:installable' && ret=0
return ret
