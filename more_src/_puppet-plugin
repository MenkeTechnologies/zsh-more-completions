#compdef puppet-plugin
# Documentation: https://raw.githubusercontent.com/puppetlabs/puppet/main/references/man/plugin.md
# puppet plugin - download plugins from the puppet master

local ret=1

_arguments -s -S \
  '--render-as=[output render format]:format:(json s yaml console dot)' \
  '--verbose[whether to log verbosely]' \
  '--debug[whether to log debug information]' \
  '1:action:(download)' && ret=0

return ret
