#compdef pyscf
# Documentation: https://man.archlinux.org/search?q=pyscf
# Reference accessed: 2026-05-16

# PySCF: Python-based simulations of chemistry framework (script runner)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:Python script:_files -g "*.py"' && ret=0
return ret
