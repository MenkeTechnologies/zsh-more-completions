#compdef bgpq4
# _bgpq4 — Alexandre Snarskii bgpq4 fork of bgpq3 with native RPKI support BGP prefix list generator (bgp team, C); custom argparse
# upstream: https://github.com/bgp/bgpq4

_bgpq4() {
    _arguments \
        '-h+[whois host:port]:host:_hosts' \
        '-S+[sources]:str:' \
        '-4[generate IPv4 prefix-list]' \
        '-6[generate IPv6 prefix-list]' \
        '-A[aggregate prefix-list]' \
        '-B[generate BIRD format]' \
        '-b[generate BIRD format]' \
        '-d[debug]' \
        '-D+[asdot/asplain]:str:' \
        '-E[extended access-list Cisco]' \
        '-F+[format]:str:' \
        '-f+[ASN]:n:' \
        '-G+[ASN for as-path access-list]:n:' \
        '-H+[host]:host:_hosts' \
        '-J[Juniper-style format]' \
        '-j[JSON format]' \
        '-K[VyOS format]' \
        '-l+[list name]:str:' \
        '-L+[list size]:n:' \
        '-m+[max prefixlen]:n:' \
        '-M+[match]:str:' \
        '-n[Nokia style]' \
        '-N[Nokia ssr style]' \
        '-p[strip private ASNs]' \
        '-q[quiet]' \
        '-r+[min prefixlen]:n:' \
        '-R+[max prefix length]:n:' \
        '-s[generate sequence numbers]' \
        '-t[generate list of asn rather than prefixes]' \
        '-T[disable as-path expansion]' \
        '-U[Huawei ipv4 style]' \
        '-W+[max width]:n:' \
        '-X[as-path access-list Cisco]' \
        '-z[Mikrotik format]' \
        '*:object:'
}

_bgpq4 "$@"
