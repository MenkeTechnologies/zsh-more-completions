#compdef chimerax ChimeraX
# _chimerax — UCSF RBVI ChimeraX next-generation Chimera molecular visualization and analysis program (UCSF team, Python/C++); custom argparse
# upstream: https://github.com/RBVI/ChimeraX

_chimerax() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--nogui[no GUI]' \
        '--offscreen[offscreen rendering]' \
        '--silent[silent mode]' \
        '--noexit[do not exit after script]' \
        '--debug[debug mode]' \
        '--cmd=+[command]:str:' \
        '--commandline-args=+[args]:str:' \
        '--exit[exit after running]' \
        '--app-info[show app info]' \
        '--list-io-formats[list I/O formats]' \
        '--lineprofile[line profile]' \
        '--profile[profile]' \
        '--script=+[script file]:file:_files -g "*.py *.cmd *.cxc"' \
        '--start=+[startup tool]:str:' \
        '--start-tools=+[tools csv]:str:' \
        '--stereo=+[stereo mode]:m:(quadbuffer redblue greenmagenta crosseyed wall-eyed checkerboard sequential anaglyph nvidia)' \
        '--toolshed=+[url]:url:_urls' \
        '--uninstall[uninstall ChimeraX]' \
        '--update-app-dirs[update app dirs]' \
        '--usedefaults[use default preferences]' \
        '--no-prompt[no prompt]' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--qtopengl=+[mode]:m:(0 1 2)' \
        '--style=+[Qt style]:str:' \
        '--gpu-id=+[id]:n:' \
        '--list-gpus[list GPUs]' \
        '--allow-mac-user-defaults[allow Mac defaults]' \
        '--noshell[no shell]' \
        '--osmesa[OSMesa rendering]' \
        '--list-cmd-aliases[list cmd aliases]' \
        '--list-commands[list commands]' \
        '*:file:_files -g "*.pdb *.mmcif *.cif *.cxc *.py *.com *.mol *.mol2 *.sdf *.xyz *.gro *.top *.dcd *.trr *.xtc *.cxs"'
}

_chimerax "$@"
