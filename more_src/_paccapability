#compdef paccapability
# Documentation: https://github.com/VorpalBlade/vorpal-zsh-completions/blob/master/src/_paccapability
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: paccapability accepts <capability> args plus --help / --version.

declare -a args
args=(
    '(-)--help[display help information]'
    '(-)--version[display version information]'
    '*:capability: '
)
_arguments $args
