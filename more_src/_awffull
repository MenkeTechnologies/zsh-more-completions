#compdef awffull
# Documentation: https://manpages.debian.org/testing/awffull/awffull.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[config file]:file:_files' \
  '-d[debug]' \
  '-D+[DNS cache file]:file:_files' \
  '-F+[log format]:format:(clf ftp squid)' \
  '-g+[group domains by N]:n:' \
  '-H+[max hostnames]:n:' \
  '-I[ignore case]' \
  '-l+[output language]:lang:' \
  '-L+[max URLs]:n:' \
  '-m+[max users]:n:' \
  '-n+[hostname]:host:' \
  '-N+[max sites in report]:n:' \
  '-o+[output directory]:dir:_files -/' \
  '-p[preserve state]' \
  '-P+[max pages]:n:' \
  '-q[quiet]' \
  '-Q[really quiet]' \
  '-r+[referer hostname]:host:' \
  '-s+[max sites]:n:' \
  '-S+[max referrers]:n:' \
  '-t+[report title]:title:' \
  '-T[time output]' \
  '-u+[max user agents]:n:' \
  '-v[verbose]' \
  '-w+[max pages]:n:' \
  '-W+[max keywords]:n:' \
  '-x+[output type]:type:(html htmlonly)' \
  '-X+[max sites by domain]:n:' \
  '-y[ignore site domain]' \
  '*:log_file:_files' && ret=0

return ret
