#compdef toolbox

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--assumeyes[automatically answer yes]' \
  '--log-level=[set log level]:level:(trace debug info warn error fatal panic)' \
  '--log-podman[show Podman log messages]' \
  '-v[set log-level to debug]' \
  '--verbose[set log-level to debug]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'create:create a new toolbox container'
      'enter:enter a toolbox container'
      'help:show help for a command'
      'init-container:initialize a running container'
      'list:list existing toolbox containers and images'
      'rm:remove one or more toolbox containers'
      'rmi:remove one or more toolbox images'
      'run:run a command in an existing toolbox container'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '(-c --container)'{-c,--container}'[assign a different name to container]:name' \
          '(-d --distro)'{-d,--distro}'[create from a different distribution]:distro' \
          '(-i --image)'{-i,--image}'[create from a custom image]:image' \
          '(-r --release)'{-r,--release}'[create from a different release]:release' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      enter)
        _arguments -s -S \
          '(-c --container)'{-c,--container}'[enter a different container]:name' \
          '(-d --distro)'{-d,--distro}'[enter container for a different distribution]:distro' \
          '(-r --release)'{-r,--release}'[enter container for a different release]:release' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-c --containers)'{-c,--containers}'[list only containers]' \
          '(-i --images)'{-i,--images}'[list only images]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all containers]' \
          '(-f --force)'{-f,--force}'[force removal]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:container' && ret=0
        ;;
      rmi)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[remove all images]' \
          '(-f --force)'{-f,--force}'[force removal]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:image' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-c --container)'{-c,--container}'[run in a different container]:name' \
          '(-d --distro)'{-d,--distro}'[run in container for a different distribution]:distro' \
          '(-r --release)'{-r,--release}'[run in container for a different release]:release' \
          '(- *)'{-h,--help}'[show help]' \
          '*:command:_command_names -e' && ret=0
        ;;
    esac
    ;;
esac

return ret
