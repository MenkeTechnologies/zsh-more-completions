#compdef ettercap-text ettercap-curses ettercap-gtk ettercap-graphical
# _ettercap-text — Ettercap textual / curses interfaces (multipurpose MITM toolkit; -T text, -C curses, -G GUI, -M mitm method (arp[:remote], dhcp:..., icmp:..., port[:remote]), -i interface, -T target1 target2 host filter, -F filter compiled with etterfilter, -w/-r pcap, -L log basename, -P plugin, -q quiet, -p only-sniff, -l only-passive)
# upstream: https://github.com/Ettercap/ettercap
# Flags from Ettercap/ettercap src/ec_main.c on tip.

_ettercap-text() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-T[text mode]' \
        '-C[curses mode]' \
        '-G[GTK GUI mode]' \
        '-D[daemon mode]' \
        '-M+[MITM]:method:(arp arp:remote arp:oneway dhcp:remote icmp port port:remote ndp:remote)' \
        '-i+[interface]:interface:_net_interfaces' \
        '-F+[filter file]:file:_files -g "*.ef"' \
        '-w+[pcap write]:file:_files -g "*.(pcap|pcapng)"' \
        '-r+[pcap read]:file:_files -g "*.(pcap|pcapng)"' \
        '-L+[log basename]:basename:' \
        '*-P+[plugin]:plugin:' \
        '-q[quiet]' \
        '-p[only sniff (no MITM)]' \
        '-l[only passive]' \
        '-z[do not perform host discovery]' \
        '-Z[restrict to discovered hosts]' \
        '*:targets:'
}

_ettercap-text "$@"
