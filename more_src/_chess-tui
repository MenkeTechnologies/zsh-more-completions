#compdef chess-tui
# chess-tui - Play chess in any terminal (Rust TUI + Stockfish UCI + Lichess)
#
# Upstream: https://github.com/thomas-mauran/chess-tui  (1091+ stars, MIT)
# Author:   Thomas Mauran (@thomas-mauran)
# Library:  ratatui 0.30 (canonical Rust TUI) + ruci 2.1 (UCI client) +
#           shakmaty 0.27 (canonical Rust chess move-gen) + reqwest 0.13
#
# Source-direct extraction from src/config.rs `Args` struct (clap-derive 4.x):
#   https://github.com/thomas-mauran/chess-tui/blob/main/src/config.rs
#
# Opens Axis 297 (Stockfish UCI + Lichess interactive terminal chess clients).

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_chess_tui_difficulties() {
    local -a d
    d=(
        'easy:bot_difficulty=0 (basic moves)'
        'medium:bot_difficulty=1'
        'hard:bot_difficulty=2'
        'magnus:bot_difficulty=3 (named after Magnus Carlsen)'
    )
    _describe -t difficulties 'bot difficulty preset' d
}

_chess_tui_skins() {
    local -a s
    s=(
        'Default:Unicode chess piece glyphs (▲♙♘ etc.)'
        'ASCII:plain ASCII letters for terminals without Unicode glyphs'
    )
    _describe -t skins 'skin / theme name' s
}

_arguments -C \
    '(- *)'{-h,--help}'[print help (summary)]' \
    '(- *)'{-V,--version}'[print chess-tui version]' \
    '(-e --engine-path)'{-e,--engine-path}'+[path to chess engine binary (UCI, e.g. stockfish)]:engine path:_files' \
    '(-d --depth)'{-d,--depth}'+[bot thinking depth (1-255 plies)]:depth:' \
    '--difficulty=[bot difficulty preset (omit for full engine strength)]:difficulty:_chess_tui_difficulties' \
    '(-l --lichess-token)'{-l,--lichess-token}'+[Lichess API token (get from lichess.org/account/oauth/token)]:token:' \
    '--no-sound[disable sound effects (auto-disabled when audio is unavailable)]' \
    '--skin=[skin/theme name; overrides persisted config for reproducible demos]:skin:_chess_tui_skins' \
    '--update-skins[update skin config with built-in defaults (archives current file)]' \
    '(-p --pgn)'{-p,--pgn}'+[open a PGN file or directory of .pgn files in the PGN viewer]:pgn path:_files -g "*.(pgn|PGN)"' \
    && ret=0

return ret
