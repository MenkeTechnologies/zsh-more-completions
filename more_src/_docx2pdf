#compdef docx2pdf
# Documentation: https://github.com/AlJohri/docx2pdf
# Convert docx to pdf on Windows or macOS using Microsoft Word

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '--version[display version and exit]' \
  '--keep-active[prevent closing Word after conversion]' \
  '1:input file or folder:_files' \
  '2:output file or folder:_files' && ret=0

return ret
