#compdef mdbook-presentation-preprocessor
# _mdbook-presentation-preprocessor — slide-style presentation mode for mdbook (FreeMasen/mdbook-presentation-preprocessor)
# upstream: https://github.com/FreeMasen/mdbook-presentation-preprocessor
# Subcommands from src/main.rs (docopt).

_mdbook-presentation-preprocessor() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-presentation-preprocessor "$@"
