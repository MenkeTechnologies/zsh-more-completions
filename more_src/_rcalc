#compdef rcalc
# Documentation: https://floyd.lbl.gov/radiance/man_html/rcalc.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Radiance rcalc: math/expression evaluator on tabular data streams
local curcontext="$curcontext" ret=1
_arguments -C \
  '-b[accept exact matches only in batch mode]' \
  '-l[ignore warnings]' \
  '-p[passive expressions only]' \
  '-P[passive: pass through unmatched output]' \
  '-n[no input expected]' \
  '-w[suppress non-fatal warnings]' \
  '-u[flush output after each input record]' \
  '-tS[input field separator character]:char:' \
  '-i[input format template]:fmt:' \
  '-o[output format template]:fmt:' \
  '-f[read function definitions from file]:file:_files' \
  '-e[evaluate command-line expression]:expr:' \
  '-s[assign string variable]:var=value:' \
  '*:input data file:_files' && ret=0
return ret
