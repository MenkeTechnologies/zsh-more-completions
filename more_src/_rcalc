#compdef rcalc
# Documentation: https://man.archlinux.org/search?q=rcalc
# Reference accessed: 2026-05-16

# Radiance rcalc: math/expression evaluator on tabular data streams
local curcontext="$curcontext" ret=1
_arguments -C \
  '-b[batch mode]' \
  '-l[no warning messages]' \
  '-p[passive expressions only]' \
  '-i[input format]:fmt:' \
  '-o[output format]:fmt:' \
  '-w[no diagnostic messages]' \
  '-h[no header in output]' \
  '-e[command-line expression]:expr:' \
  '-f[read functions from file]:file:_files' \
  '-s[scientific output]:n:' \
  '-c[force input commit per record]:n:' \
  '-tCS[input column separator]:char:' \
  '*:input data file:_files' && ret=0
return ret
