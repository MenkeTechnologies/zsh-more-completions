#compdef flashroute
# Documentation: https://github.com/lambdahuang/FlashRoute/blob/master/flashroute/main.cc
# FlashRoute - fast Internet-scale topology discovery prober (gflags style)

local ret=1

_arguments -s \
  '--split_ttl=[initial TTL to start scan]:ttl' \
  '--granularity=[scan granularity (/N subnet per address)]:granularity' \
  '--prober_type=[prober type]:type:(udp udp_idempotent)' \
  '--sequential_scan[scan destinations sequentially rather than randomly]' \
  '--preprobing[enable hop distance preprobing]' \
  '--preprobing_ttl=[TTL for preprobing]:ttl' \
  '--distance_prediction[enable distance prediction across proximity blocks]' \
  '--distance_prediction_prefix=[prefix length for distance prediction]:prefix' \
  '--proximity_span=[proximity span for distance prediction]:span' \
  '--forward_probing[enable forward route exploration]' \
  '--gaplimit=[consecutive silent interfaces before halting forward probing]:gaplimit' \
  '--remove_redundancy[enable Doubletree-based redundancy removal]' \
  '--remove_reserved_addresses[exclude IETF-reserved addresses]' \
  '--history_probing_result=[optimize scan based on historical data]:file:_files' \
  '--hitlist=[hitlist file]:file:_files' \
  '--blacklist=[blacklist file (one IP per line)]:file:_files' \
  '--bogon_filter_potaroo=[Potaroo bogon filter file]:file:_files' \
  '--targets=[target list file]:file:_files' \
  '--dump_targets_file=[dump destinations to file]:file:_files' \
  '--nonstop_set_file=[nonstop set file]:file:_files' \
  '--interface=[network interface for probing]:interface:_net_interfaces' \
  '--probing_rate=[probe sending rate in packets/second]:rate' \
  '--default_payload_message=[probe payload message]:message' \
  '--dst_port=[destination port for probes]:port' \
  '--src_port=[source port for probes]:port' \
  '--output=[output file path]:file:_files' \
  '--tcpdump_output=[dump packets to pcap file]:file:_files' \
  '--scan_count=[number of scans to perform]:count' \
  '--seed=[seed for destination selection]:seed' \
  '--ttl_offset=[TTL offset]:offset' \
  '--encode_timestamp[encode timestamp in probes]' \
  '--randomize_address_in_extra_scans[randomize address in extra scans]' \
  '--verbose[verbose logging]' \
  '--vverbose[very verbose logging]' \
  '*:target:_hosts' && ret=0

return ret
