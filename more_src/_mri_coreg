#compdef mri_coreg
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mri_coreg
# FreeSurfer robust within-modality registration tool

local ret=1

_arguments -s -S \
  '--mov[source volume]:movvol:_files' \
  '--ref[target volume]:refvol:_files' \
  '--targ[target volume]:refvol:_files' \
  '--reg[output registration]:reg.lta:_files' \
  '--lta[output registration]:reg.lta:_files' \
  '--s[subject, forces --ref-mask aparc+aseg.mgz]:subject:' \
  '--dof[degrees of freedom (default 6)]:dof:(6 9 12)' \
  '--6[6 DOF]' \
  '--9[9 DOF]' \
  '--12[12 DOF]' \
  '--ref-mask[mask ref with refmaskvol]:refmaskvol:_files' \
  '--no-ref-mask[do not mask ref]' \
  '--mov-mask[mask mov with movmaskvol]:movmaskvol:_files' \
  '--threads[number of threads]:nthreads:' \
  '--sd[subjects directory]:SUBJECTS_DIR:_files -/' \
  '--regdat[registration data file]:reg.dat:_files' \
  '--no-coord-dither[turn off coordinate dithering]' \
  '--no-intensity-dither[turn off intensity dithering]' \
  '*--sep[set spatial scales (def 2 and 4 vox)]:voxsep:' \
  '--trans[initial translation Tx Ty Tz in mm]:trans:' \
  '--rot[initial rotation Rx Ry Rz in deg]:rot:' \
  '--shear[initial shear Hxy Hxz Hyz]:shear:' \
  '--params[save parameters in this file]:outparamfile:_files' \
  '--no-cras0[do not align centers]' \
  '--regheader[same as no-cras0]' \
  '--nitersmax[max iterations (default 4)]:n:' \
  '--ftol[function tolerance]:ftol:' \
  '--linmintol[line minimization tolerance]:linmintol:' \
  '--sat[saturation threshold percent]:SatPct:' \
  '--conf-ref[conform the reference without rescaling]' \
  '--no-bf[do not do brute force search]' \
  '--bf-lim[constrain brute force search to +/- lim]:lim:' \
  '--bf-nsamp[number of samples in brute force search]:nsamples:' \
  '--no-smooth[do not apply smoothing to ref or mov]' \
  '--ref-fwhm[apply smoothing to ref]:fwhm:' \
  '--mov-oob[count mov out-of-bounds voxels as 0]' \
  '--no-mov-oob[do not count mov out-of-bounds voxels as 0]' \
  '--mat2par[extract parameters out of registration]:reg.lta:_files' \
  '--debug[turn on debugging]' \
  '--checkopts[check options and exit]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '--version[print version and exit]' && ret=0

return ret
