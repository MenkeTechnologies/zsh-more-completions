#compdef plotCorrelation
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotCorrelation.html
# deepTools: visualize sample correlations from multiBamSummary/multiBigwigSummary output

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-in --corData)'{-in,--corData}'[compressed correlation matrix file]:file:_files' \
  '(-c --corMethod)'{-c,--corMethod}'[correlation method]:method:(spearman pearson)' \
  '(-p --whatToPlot)'{-p,--whatToPlot}'[visualization type]:type:(heatmap scatterplot)' \
  '(-o --plotFile)'{-o,--plotFile}'[output file path]:file:_files' \
  '--skipZeros[exclude regions with zero/NaN in all samples]' \
  '(-l --labels)'{-l,--labels}'[custom sample labels]:labels:' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '--removeOutliers[filter extreme value bins]' \
  '--version[show version]' \
  '--outFileCorMatrix[output correlation matrix file]:file:_files' \
  '--plotHeight[height in cm]:cm:' \
  '--plotWidth[width in cm]:cm:' \
  '(-min --zMin)'{-min,--zMin}'[minimum heatmap intensity]:n:' \
  '(-max --zMax)'{-max,--zMax}'[maximum heatmap intensity]:n:' \
  '--colorMap[matplotlib colormap]:cmap:' \
  '--plotNumbers[display correlation values on heatmap]' \
  '--xRange[x-axis range limits]:range:' \
  '--yRange[y-axis range limits]:range:' \
  '--log1p[natural log transformation for plotting]' && ret=0

return ret
