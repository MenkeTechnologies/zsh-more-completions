#compdef risectl
# Documentation: https://github.com/risingwavelabs/risingwave/blob/main/src/ctl/src/lib.rs
# RisingWave streaming database control CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:((
    compute\:"commands for compute nodes"
    hummock\:"commands for hummock storage"
    table\:"commands for tables"
    meta\:"commands for the meta service"
    bench\:"commands for benchmarks"
    await-tree\:"dump, analyze and transcribe await-trees"
    trace\:"alias for await-tree"
    profile\:"commands for profiling nodes"
    throttle\:"commands for throttling"
    test\:"commands for self-testing"
  ))' \
  '*::arg:->args' && ret=0

return ret
