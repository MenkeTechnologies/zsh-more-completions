#compdef acpiexec
# Documentation: acpiexec
# Source: acpica/acpica source/tools/acpiexec/aemain.c (master) — ACPICA AML execution environment (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b+[batch mode command line]:cmds:_default' \
    '(-h -?)'{-h,-\\?}'[show help]' \
    '-m+[batch method execution (default MAIN)]:method:_default' \
    '-da[disable method abort on error]' \
    '-df[disable local fault handler]' \
    '-di[disable STA/INI methods during init]' \
    '-do[disable Operation Region address simulation]' \
    '-dr[disable repair of method return values]' \
    '-ds[disable method auto-serialization]' \
    '-dt[disable allocation tracking]' \
    '-ed[enable timer output for Debug Object]' \
    '-ef[show final memory statistics]' \
    '-ei[enable additional ACPICA interface tests]' \
    '-el[enable loading additional test tables]' \
    '-eo[enable object evaluation log]' \
    '-es[enable interpreter slack mode]' \
    '-et[enable debug semaphore timeout]' \
    '-fi+[namespace initialization file]:file:_files' \
    '-fv+[OperationRegion fill value]:value:_default' \
    '-l[load tables and namespace only]' \
    '-r[use hardware-reduced FADT v5]' \
    '-te[exit loop on timeout instead of aborting]' \
    '-to+[timeout seconds for AML while loops]:seconds:_default' \
    '(-v -vd)-v[show version]' \
    '-va[show verbose memory leak dump]' \
    '(-v -vd)-vd[show build date]' \
    '-vh[verbose exception handler]' \
    '-vi[verbose initialization]' \
    '-vr[verbose region handler]' \
    '-x+[debug output level]:level:_default' \
    '*:AML table file:_files -g "*.{aml,dat}"' \
    && ret=0

return ret
