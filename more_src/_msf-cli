#compdef msfconsole
# _msf-cli — Metasploit Framework console (Rapid7 + community, Ruby); CLI front-end for the Metasploit exploitation framework
# upstream: https://github.com/rapid7/metasploit-framework

_msf-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[do not print banner]' \
        '(-x --execute-command)'{-x,--execute-command}'+[commands]:cmd:' \
        '(-r --resource)'{-r,--resource}'+[resource script]:file:_files' \
        '(-y --yaml)'{-y,--yaml}'+[database config]:file:_files' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-L --logger)'{-L,--logger}'+[logger]:logger:' \
        '(-n --no-database)'{-n,--no-database}'[disable database]' \
        '(-A --disable-database)'{-A,--disable-database}'[no database]' \
        '(-z --no-banner)'{-z,--no-banner}'[no banner]' \
        '(-w --workspace)'{-w,--workspace}'+[workspace]:workspace:' \
        '(-d --defer-module-loads)'{-d,--defer-module-loads}'[defer module loads]' \
        '(-Q --enable-color)'{-Q,--enable-color}'[force color]' \
        '(-M --module-mode)'{-M,--module-mode}'[start in module mode]' \
        '*::commands:'
}

_msf-cli "$@"
