#compdef cube-cli cubectl
# _cube-cli — Cube Dev cube-cli cubectl CLI command-line frontend wrapping the Cube headless BI semantic layer Universal Semantic API providing dev-server build pre-aggregations dry-run rollup schema migrations validate query SQL deploy api-token aggregations queue refresh-keys metadata-cache (Cube Dev team, Node.js); commander
# upstream: https://cube.dev/

_cube-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'dev-server:start the dev server'
        'serve:start the server'
        'build:build the project'
        'deploy:deploy to Cube Cloud'
        'pre-aggregations:pre-aggregations operations'
        'query:run a query'
        'sql:generate SQL'
        'validate:validate schema'
        'schema:schema operations'
        'metadata:metadata operations'
        'rollup-designer:rollup designer'
        'token:token operations'
        'context:context operations'
        'doctor:diagnose installation'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--token=+[token]:str:' \
        '-c+[config file]:file:_files -g "cube.js *.js *.yaml *.yml *.json *.env"' \
        '--config=+[file]:file:_files -g "*.js *.yaml *.yml *.json"' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--cwd=+[dir]:dir:_files -/' \
        '--project=+[name]:str:' \
        '--deployment=+[id]:str:' \
        '--environment=+[name]:str:' \
        '-o+[format]:f:(json yaml csv table)' \
        '--output=+[format]:f:(json yaml csv table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'cube-cli subcommand' sub ;;
        args)
            case $words[1] in
                pre-aggregations) _arguments '1:op:(list build refresh trigger queue empty)' '*:cube name:' ;;
                query|sql) _arguments '*:query:' ;;
                schema|metadata) _arguments '1:op:(list show validate)' ;;
            esac
            ;;
    esac
}

_cube-cli "$@"
