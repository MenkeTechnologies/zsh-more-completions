autoload -U is-at-least

_uu-tsort() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-w[]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::file:_files' \
&& ret=0
}

(( $+functions[_uu-tsort_commands] )) ||
_uu-tsort_commands() {
    local commands; commands=()
    _describe -t commands 'uu-tsort commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-tsort" ]; then
    _uu-tsort "$@"
else
    compdef _uu-tsort uu-tsort
fi
