#compdef adf
# Documentation: https://man.archlinux.org/search?q=adf
# Reference accessed: 2026-05-16

# AMS/ADF: Amsterdam Density Functional - reads input from stdin or .run file
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::ADF input file (.run/.adf) - typically piped to adf via shell:_files -g "*.(run|adf|in)"' && ret=0
return ret
