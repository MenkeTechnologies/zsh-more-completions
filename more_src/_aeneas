#compdef aeneas
# _aeneas — Aeneas: Rust → pure functional translator for F*/Coq/Lean/HOL4
# upstream: https://github.com/AeneasVerif/aeneas
# Flags from src/Main.ml (OCaml Arg.parse spec_ls).

_aeneas() {
    local -a args
    args=(
        '-version[print the Aeneas version (git commit) and exit]'
        '-backend=[target backend for extraction]:backend:(fstar coq lean hol4)'
        '-namespace=[namespace of the definitions in the pure model]:namespace:'
        '-dest=[output directory]:dir:_files -/'
        '-subdir=[extract files into a sub-folder (affects import paths)]:subdir:'
        '-borrow-check[only borrow-check the program; do not generate translation]'
        '-borrow-check-globals[borrow-check globals (workaround for Charon limitation)]'
        '-test-units[test unit functions with the concrete interpreter]'
        '-decreases-clauses[emit decreases clauses / termination measures]'
        '-use-fuel[use a fuel parameter to control divergence]'
        '-no-template-clauses[do not generate templates for required decreases clauses]'
        '-split-files[split definitions across types/functions/etc. files]'
        '-checks[activate extensive sanity checks (~100x slowdown)]'
        '-gen-lib-entry[add an entry point file to the generated library]'
        '-lean-default-lakefile[generate a default lakefile.lean (Lean only)]'
        '-impl-namespace[Lean: prefix method names with "impl" to avoid collisions]'
        '-all-computable[Lean: do not emit `noncomputable section`]'
        '-loops-to-rec[always extract loops to recursive functions]'
        '-loops-no-rec[never extract loops to recursive functions]'
        '-max-heartbeats=[Lean: set `set_option maxHeartBeats`]:n:'
        '-max-recdepth=[Lean: set `set_option maxRecDepth`]:n:'
        '-tuple-nested-proj[use nested tuple projectors (.snd.fst)]'
        '-eval-drops[evaluate drops instead of treating them as no-ops]'
        '-strict-joins[error on context-join failure (no code duplication fallback)]'
        '-print-llbc[print the imported LLBC]'
        '-print-error-emitters[print Aeneas source span when reporting an error]'
        '-print-error-diagnostics[print extra diagnostics about error kinds]'
        '-print-unknown-externals[print external definitions not in builtins]'
        '-abort-on-error[abort on the first encountered error]'
        '-warnings-as-errors[treat warnings as errors]'
        '-sequential[execute sequentially (disable parallelism)]'
        '-no-progress-bar[do not display a progress bar]'
        '-color[use colors when printing log messages]'
        '-max-error-spans=[max local uses of an erroring external to print (<0 = all)]:n:'
        '-log=[activate trace log for the named logger(s) (comma-separated)]:loggers:'
        '-log-debug=[activate debug log for the named logger(s)]:loggers:'
        '-log-error=[activate error log for the named logger(s)]:loggers:'
        '-mark-ids=[mark IDs to throw on generation (s/b/a/r/f prefixes)]:ids:'
        '-diagnose-translation[time per-function translation, sorted longest first]'
        '-diagnose-micro-passes[time micro-passes per function]'
        '-diagnose-detailed[detailed per-function/per-pass timings]'
        '*:LLBC input file:_files -g "*.llbc"'
    )
    _arguments -s -S $args
}

_aeneas "$@"
