#compdef flit
# Documentation: https://flit.pypa.io/en/stable/cmdline.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize a new pyproject.toml'
  'build:build sdist and wheel'
  'install:install the package locally'
  'publish:upload to PyPI'
)

_arguments -C \
  '(-f --ini-file)'{-f,--ini-file}'=[pyproject.toml path]:file:_files -g "*.toml"' \
  '--debug[enable detailed logging]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'flit subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '*--format=[output format]:fmt:(wheel sdist)' \
          '--setup-py[include setup.py in sdist for older pip]' \
          '--no-setup-py[omit setup.py from sdist (default)]' \
          '--use-vcs[track files via VCS]' \
          '--no-use-vcs[do not track via VCS]' && ret=0
        ;;
      (publish)
        _arguments \
          '*--format=[output format]:fmt:(wheel sdist)' \
          '--setup-py[include setup.py in sdist]' \
          '--no-setup-py[omit setup.py from sdist]' \
          '--use-vcs[track files via VCS]' \
          '--no-use-vcs[do not track via VCS]' \
          '--pypirc=[pypirc file]:file:_files' \
          '--repository=[repository name]:repo:' && ret=0
        ;;
      (install)
        _arguments \
          '(-s --symlink)'{-s,--symlink}'[symlink instead of copy]' \
          '--pth-file[install via .pth file]' \
          '--user[user-site install]' \
          '--env[install in venv]' \
          '--python=[python interpreter]:python:_command_names' \
          '--deps=[deps to install]:deps:(all production develop none)' \
          '--only-deps[only deps]' \
          '--extras=[extras CSV]:extras:' && ret=0
        ;;
    esac
    ;;
esac

return ret
