#compdef yurt-tunnel-agent
# _yurt-tunnel-agent — OpenYurt edge-side tunnel agent (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Flags from cmd/yurt-tunnel-agent/app/options/options.go (pflag).

_yurt-tunnel-agent() {
    _arguments \
        '--version[print version and exit]' \
        '--node-name=[edge node name]:name:' \
        '--node-ip=[edge node host IP]:ip:' \
        '--tunnelserver-addr=[address of yurt-tunnel-server]:url:' \
        '--apiserver-addr=[reachable apiserver address]:url:' \
        '--kube-config=[kubeconfig file]:file:_files' \
        '--agent-identifiers=[agent identifiers for server matching]:ids:' \
        '--meta-host=[bind IP for meta listener]:ip:' \
        '--meta-port=[meta HTTP port (profiling/metrics)]:port:' \
        '--cert-dir=[certificate directory]:dir:_files -/'
}

_yurt-tunnel-agent "$@"
