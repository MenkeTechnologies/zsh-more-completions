#compdef sfmax1
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mmax1.c
# Madagascar: pick local maxima on the first axis (outputs time,amplitude)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show self-documentation]' \
  'min=[minimum value of time]:value' \
  'max=[maximum value of time]:value' \
  'np=[maximum number of picks]:count' \
  'sorted=[if y, sort by amplitude]:flag:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
