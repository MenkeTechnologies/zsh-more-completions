#compdef pointfree
# Documentation: https://man.archlinux.org/search?q=pointfree
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--verbose[verbose output]' \
  '--stdin[read from stdin]' \
  '*:expression:' && ret=0

return ret
