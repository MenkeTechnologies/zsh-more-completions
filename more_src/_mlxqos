#compdef mlxqos
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# mlxqos: configure QoS on Mellanox network ports
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-i[interface]:iface:' \
  '--interface=[interface]:iface:' \
  '-t[traffic class]:n:' \
  '--tc=[traffic class]:n:' \
  '-r[rate limit (Gbps)]:rate:' \
  '--ratelimit=[rate limit (Gbps)]:rate:' \
  '-p[prio2buffer]:list:' \
  '--prio2buffer=[prio2buffer]:list:' \
  '-b[buffer size]:size:' \
  '--buffer_size=[buffer size]:size:' \
  '*::mlxqos args:_files' && ret=0
return ret
