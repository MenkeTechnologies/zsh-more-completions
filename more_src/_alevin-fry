#compdef alevin-fry
# Documentation: https://alevin-fry.readthedocs.io/en/latest/
# Reference accessed: 2026-05-16
# Verified: alevin-fry readthedocs CLI reference (generate-permit-list,
# collate, quant, infer, atac subcommands).
# Removed from prior file: bogus man.archlinux.org search URL;
# generic _default arg handler with no subcommands.

# alevin-fry: single-cell RNA-seq quantification from RAD files
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'generate-permit-list:filter cell barcodes from RAD file'
  'collate:collate rad records by corrected barcode'
  'quant:quantify gene expression'
  'infer:infer count matrix from existing EQC'
  'atac:ATAC-seq processing subcommands'
  'view:view contents of a RAD file'
  'convert:convert between formats'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'alevin-fry command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate-permit-list)
        _arguments \
          '(-i --input)'{-i+,--input=}'[RAD-format input dir]:dir:_files -/' \
          '(-o --output-dir)'{-o+,--output-dir=}'[output dir]:dir:_files -/' \
          '--expected-ori[expected orientation]:ori:(fw rc both either)' \
          '(-k --knee-distance)'{-k,--knee-distance}'[knee-distance method]' \
          '--force-cells[force N cells]:n:' \
          '(-b --valid-bc)'{-b+,--valid-bc=}'[valid barcode file]:file:_files' \
          '(-u --unfiltered-pl)'{-u+,--unfiltered-pl=}'[unfiltered permit list]:file:_files' \
          '--expect-cells[expected cells]:n:' \
          '--min-reads[min reads (with --unfiltered-pl)]:n:' && ret=0
        ;;
      (collate)
        _arguments \
          '(-i --input-dir)'{-i+,--input-dir=}'[input dir]:dir:_files -/' \
          '(-r --rad-dir)'{-r+,--rad-dir=}'[RAD dir]:dir:_files -/' \
          '(-t --threads)'{-t+,--threads=}'[threads]:n:' \
          '--max-records[max records per chunk]:n:' \
          '--compress[compress output]' && ret=0
        ;;
      (quant)
        _arguments \
          '(-i --input-dir)'{-i+,--input-dir=}'[input dir]:dir:_files -/' \
          '(-m --tg-map)'{-m+,--tg-map=}'[transcript-gene map]:file:_files' \
          '(-r --resolution)'{-r+,--resolution=}'[resolution method]:res:(cr-like cr-like-em parsimony parsimony-em parsimony-gene parsimony-gene-em full trivial)' \
          '(-t --threads)'{-t+,--threads=}'[threads]:n:' \
          '(-o --output-dir)'{-o+,--output-dir=}'[output dir]:dir:_files -/' \
          '--use-mtx[output mtx format]' \
          '--num-bootstraps[number of bootstrap samples]:n:' \
          '--summary-stat[output summary stats]' \
          '--dump-eqclasses[dump eq classes]' && ret=0
        ;;
      (infer)
        _arguments \
          '(-c --count-mat)'{-c+,--count-mat=}'[count matrix]:file:_files' \
          '(-e --eq-labels)'{-e+,--eq-labels=}'[eq labels]:file:_files' \
          '(-o --output-dir)'{-o+,--output-dir=}'[output dir]:dir:_files -/' \
          '(-t --threads)'{-t+,--threads=}'[threads]:n:' \
          '--usa-mode[USA mode]' \
          '--quant-subset[quantify subset]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
