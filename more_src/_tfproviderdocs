#compdef tfproviderdocs
# Documentation: https://github.com/bflad/tfproviderdocs
# tfproviderdocs - Terraform Provider documentation tool

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-providers-schema-json=[validate against a provider schema JSON file]:file:_files' \
  '-provider-name=[provider name as used in Terraform configurations]:name' \
  '-enable-contents-check[enable file content validation]' \
  '-require-schema-ordering[verify schema attribute lists are ordered]' \
  '-allowed-resource-subcategories=[comma-separated allowed resource subcategories]:subcategories' \
  '1:command:(check generate)' \
  '*::arg:_files' && ret=0

return ret
