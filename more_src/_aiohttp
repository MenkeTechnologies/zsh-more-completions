#compdef aiohttp aiohttp-cli aiohttp.web
# _aiohttp — aio-libs aiohttp web framework runner (aio-libs, Python); python -m aiohttp.web argparse
# upstream: https://github.com/aio-libs/aiohttp

_aiohttp() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--hostname=+[host]:host:_hosts' \
        '-H+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '-P+[port]:port:' \
        '--path=+[unix socket path]:file:_files' \
        '-U+[unix socket path]:file:_files' \
        '*:entrypoint:'
}

_aiohttp "$@"
