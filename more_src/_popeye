#compdef popeye

# Zsh completion for popeye - Kubernetes cluster sanitizer

_arguments -s -S \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[scan all namespaces]' \
  '--cluster[specify cluster name]:cluster' \
  '--context[specify context name]:context' \
  '--kubeconfig[path to kubeconfig file]:kubeconfig:_files' \
  '(-n --namespace)'{-n,--namespace}'[specify namespace]:namespace' \
  '--lint[specify spinach lint config file]:lint config:_files' \
  '(-o --out)'{-o,--out}'[specify output format]:format:(standard jurassic yaml json html junit prometheus score)' \
  '--output-file[specify output file]:file:_files' \
  '(-s --save)'{-s,--save}'[save results to file]' \
  '(-S --sections)'{-S,--sections}'[specify sections to scan]:sections' \
  '--clear-screen[clear screen before scanning]' \
  '--force-exit-zero[force zero exit code]' \
  '--min-score[specify minimum score threshold]:score' \
  '--push-gtwy-url[specify push gateway URL]:url' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]'
