#compdef popeye
# Documentation: https://github.com/derailed/popeye
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for popeye - Kubernetes cluster sanitizer

_arguments -s -S \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[scan all namespaces]' \
  '--cluster=[kubeconfig cluster name]:cluster' \
  '--cluster-name=[cluster name when running in-cluster]:name' \
  '--context=[kubeconfig context name]:context' \
  '--user=[kubeconfig user name]:user' \
  '--as=[username to impersonate]:user' \
  '*--as-group=[group to impersonate]:group' \
  '--kubeconfig=[path to kubeconfig file]:kubeconfig:_files' \
  '(-n --namespace)'{-n,--namespace}'=[specify namespace]:namespace' \
  {-f,--file}'=[spinach YAML configuration file]:file:_files' \
  {-l,--lint}'=[lint level]:level:(ok info warn error)' \
  '(-o --out)'{-o,--out}'=[output format]:format:(standard jurassic yaml json html junit prometheus score)' \
  '--output-file=[report output file name]:file:_files' \
  '--save[persist output to file]' \
  '*'{-s,--sections}'=[resources to include in scan]:sections' \
  {-c,--clear}'[clear screen before run]' \
  '--force-exit-zero[force zero exit code]' \
  '--min-score=[minimum score threshold]:score' \
  '--over-allocs[check for CPU and memory over allocations]' \
  '--s3-bucket=[S3 bucket for saving output]:bucket' \
  '--s3-region=[S3-compatible region]:region' \
  '--s3-endpoint=[S3-compatible endpoint]:url' \
  '--push-gtwy-url=[Prometheus pushgateway address]:url' \
  '--push-gtwy-user=[pushgateway username]:user' \
  '--push-gtwy-password=[pushgateway password]:password' \
  '--logs=[log file location]:file:_files' \
  {-v,--log-level}'=[log verbosity 0-4]:level:(0 1 2 3 4)' \
  '--request-timeout=[server request timeout]:duration' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--certificate-authority=[CA certificate path]:file:_files' \
  '--client-key=[TLS client key path]:file:_files' \
  '--client-certificate=[TLS client certificate path]:file:_files' \
  '--token=[bearer token for authentication]:token' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]'
