#compdef lhapdf-config
# Documentation: https://manpages.debian.org/testing/liblhapdf-dev/lhapdf-config.1
# get version number and compiler flags of the installed LHAPDF library

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show LHAPDF release version number]' \
  '--prefix[show installation prefix]' \
  '--incdir[show path to LHAPDF header directory]' \
  '--libdir[show path to LHAPDF library directory]' \
  '--datadir[show path to LHAPDF installed data directory]' \
  '--pdfsets-path[show path to directory containing PDF set data files]' \
  '--cflags[get compiler flags]' \
  '--cppflags[get C preprocessor flags]' \
  '--cxxflags[get C++ compiler flags]' \
  '--libs[get linker flags]' \
  '--ldflags[get linker stage flags]' && ret=0

return ret
