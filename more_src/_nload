#compdef nload

# Zsh completion for nload - network traffic monitor

_nload_interfaces() {
  local -a interfaces
  if [[ -d /sys/class/net ]]; then
    interfaces=( /sys/class/net/*(N:t) )
  fi
  _describe -t interfaces 'network interface' interfaces
}

_arguments -s -S \
  '-a[set the length of the time window for average calculation in seconds]:seconds' \
  '-i[set the max scaling of the incoming traffic graph]:max value' \
  '-o[set the max scaling of the outgoing traffic graph]:max value' \
  '-t[set the refresh interval in milliseconds]:milliseconds' \
  '-u[set the display unit for traffic rates]:unit:(auto Bit kBit MBit GBit Byte kByte MByte GByte)' \
  '-U[set the display unit for data amounts]:unit:(auto Bit kBit MBit GBit Byte kByte MByte GByte)' \
  '-m[show multiple devices and do not show traffic graphs]' \
  '(- *)-h[show help]' \
  '*:network interface:_nload_interfaces'
