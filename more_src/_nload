#compdef nload

# Zsh completion for nload - network traffic monitor

_nload_interfaces() {
  local -a interfaces
  if [[ -d /sys/class/net ]]; then
    interfaces=( /sys/class/net/*(N:t) )
  fi
  _describe -t interfaces 'network interface' interfaces
}

_arguments -s -S \
  '-a[time window for average in seconds]:seconds:' \
  '-i[maximum incoming traffic scaling]:max:' \
  '-o[maximum outgoing traffic scaling]:max:' \
  '-t[refresh interval in milliseconds]:ms:' \
  '-u[display unit]:unit:(auto Bit kBit MBit GBit Byte kByte MByte GByte)' \
  '-U[data amount unit]:unit:(auto Bit kBit MBit GBit Byte kByte MByte GByte)' \
  '-m[show multiple devices without traffic graphs]' \
  '(- *)-h[show help]' \
  '*:interface:_nload_interfaces'
