#compdef soplex
# Documentation: https://soplex.zib.de/doc/html/USAGE.php
# SoPlex sequential object-oriented simplex LP solver

local ret=1

_arguments -s \
  '-h[display all parameters]' \
  '--version[print version and compiler information]' \
  '--readbas=[read starting basis from file]:basfile:_files' \
  '--writebas=[write terminal basis to file]:basfile:_files' \
  '--writefile=[write LP to file in LP or MPS format]:lpfile:_files' \
  '--writedual=[write the dual LP to a file]:lpfile:_files' \
  '--loadset=[load parameters from settings file]:setfile:_files' \
  '--saveset=[save parameters to settings file]:setfile:_files' \
  '--diffset=[save modified parameters to settings file]:setfile:_files' \
  '--extsol=[external solution for validation]:value' \
  '--readmode=[reading mode (0 floating-point, 1 rational)]:mode:(0 1)' \
  '--solvemode=[choose solving mode]:mode' \
  '--arithmetic=[choose base arithmetic type]:type' \
  '--precision=[choose multiprecision precision]:precision' \
  '-t+[set time limit in seconds]:seconds' \
  '-i+[set iteration limit]:iters' \
  '-f+[set primal feasibility tolerance]:eps' \
  '-o+[set dual feasibility (optimality) tolerance]:eps' \
  '-l+[set validation tolerance]:eps' \
  '-s+[choose simplifier/presolver]:value' \
  '-g+[choose scaling]:value' \
  '-p+[choose pricing]:value' \
  '-r+[choose ratio tester]:value' \
  '-v+[set verbosity level]:level' \
  '-x[print primal solution]' \
  '-y[print dual multipliers]' \
  '-X[print primal solution in rational numbers]' \
  '-Y[print dual multipliers in rational numbers]' \
  '-q[display detailed statistics]' \
  '-c[perform final check of optimal solution]' \
  '*:file:_files' && ret=0

return ret
