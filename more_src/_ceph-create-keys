#compdef ceph-create-keys
# Documentation: https://docs.ceph.com/en/latest/man/8/ceph-create-keys/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ceph-create-keys: bootstrap admin keys for newly-deployed mon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-i+[mon id (waits until quorum)]:id:' \
  '--id=[mon id (waits until quorum)]:id:' \
  '-t+[timeout seconds waiting for monitor (default 600)]:sec:' \
  '--cluster=[cluster name (default ceph)]:name:' \
  '*::ceph-create-keys args:_files' && ret=0
return ret
