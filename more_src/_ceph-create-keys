#compdef ceph-create-keys

# ceph-create-keys: bootstrap admin keys for newly-deployed mon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-i[mon id]:id:' \
  '--id=[mon id]:id:' \
  '--cluster=[cluster name]:name:' \
  '*::ceph-create-keys args:_files' && ret=0
return ret
