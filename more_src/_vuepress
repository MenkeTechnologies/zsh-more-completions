#compdef vuepress

# Zsh completion for vuepress - VuePress static site generator

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'dev:Start development server'
      'build:Build for production'
      'info:Display environment information'
    )
    _describe -t commands 'vuepress command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[specify port]:port' \
          '--host[specify host]:host' \
          '--temp[set the directory of the temporary files]:directory:_directories' \
          '--cache[set the directory of the cache files]:directory:_directories' \
          '--no-cache[disable caching]' \
          '--debug[enable debug mode]' \
          '--open[open browser on startup]' \
          '--clean-cache[clean the cache before dev]' \
          '--clean-temp[clean the temporary files before dev]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:sourceDir:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--dest[set the output directory]:directory:_directories' \
          '--temp[set the directory of the temporary files]:directory:_directories' \
          '--cache[set the directory of the cache files]:directory:_directories' \
          '--no-cache[disable caching]' \
          '--debug[enable debug mode]' \
          '--clean-cache[clean the cache before build]' \
          '--clean-temp[clean the temporary files before build]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:sourceDir:_directories' && ret=0
        ;;
      info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
