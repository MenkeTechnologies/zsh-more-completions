#compdef vuepress
# Documentation: https://v1.vuepress.vuejs.org/api/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (dev/build/eject/info
# subcommands and dev/build flags confirmed).
# Removed from prior file: --clean-cache, --clean-temp flags (not in
# upstream docs); --port long form on dev (-p/--port belongs to build).
# Added: eject subcommand; --host, --open, --no-clear-screen on dev;
# --silent, --max-concurrency on build per upstream.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'dev:start development server'
      'build:build for production'
      'eject:copy default theme into .vuepress/theme'
      'info:display environment information'
    )
    _describe -t commands 'vuepress command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      dev)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[specify port]:port:' \
          '--host=[specify host address]:host:' \
          '--temp=[directory of temporary files]:directory:_directories' \
          '--cache=[directory of cache files]:directory:_directories' \
          '--no-cache[disable caching]' \
          '--debug[enable debug mode]' \
          '--open[open browser on startup]' \
          '--no-clear-screen[do not clear screen when ready]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:sourceDir:_directories' && ret=0
        ;;
      build)
        _arguments -s -S \
          '(-d --dest)'{-d,--dest}'=[output directory]:directory:_directories' \
          '(-t --temp)'{-t,--temp}'=[directory of temporary files]:directory:_directories' \
          '(-c --cache)'{-c,--cache}'=[directory of cache files]:directory:_directories' \
          '--no-cache[disable caching]' \
          '--debug[enable debug mode]' \
          '--silent[silent mode]' \
          '--max-concurrency=[max concurrent page rendering]:n:' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:sourceDir:_directories' && ret=0
        ;;
      eject|info)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:sourceDir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
