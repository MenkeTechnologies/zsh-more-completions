#compdef arch-chroot
# Documentation: https://man.archlinux.org/man/arch-chroot.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for arch-chroot - Arch Linux chroot helper

local -a arguments

arguments=(
  '-N[run in unshare mode as a regular user]'
  '-u[specify user and optional group]:user[:group]:_users'
  '-h[show help information]'
  '1:new root directory:_files -/'
  '*::command:_command_names -e'
)

_arguments -s $arguments
