#compdef suharlan
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/noise/suharlan.c
# Signal-noise separation by Harlan's iterative method (SU data)

local ret=1

_arguments -s -S \
  'niter=[number of iterations]:niter' \
  'anenv=[analytic envelope flag]:anenv' \
  'scl=[scaling flag]:scl' \
  'plot=[plotting flag]:plot' \
  'norm=[normalization flag]:norm' \
  'verbose=[verbose flag]:verbose:(0 1)' \
  'rgt=[guide trace flag]:rgt' \
  'sts=[statistics flag]:sts' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  'dx=[trace spacing]:dx' \
  'fx=[first x coordinate]:fx' \
  'dt=[time sampling interval]:dt' \
  'gopt=[geometry option]:gopt' \
  'pmin1=[minimum slope, first pass]:pmin1' \
  'pmax1=[maximum slope, first pass]:pmax1' \
  'pmin2=[minimum slope, second pass]:pmin2' \
  'pmax2=[maximum slope, second pass]:pmax2' \
  'np=[number of slopes]:np' \
  'prewhite=[prewhitening factor]:prewhite' \
  'offref=[reference offset]:offref' \
  'depthref=[reference depth]:depthref' \
  'pmula=[multiple slope a]:pmula' \
  'pmulb=[multiple slope b]:pmulb' \
  'ninterp=[interpolation count]:ninterp' \
  'nintlh=[interpolation low-high count]:nintlh' \
  'sditer=[steepest-descent iterations]:sditer' \
  'c=[regularization constant]:c' \
  'rel1=[relaxation factor 1]:rel1' \
  'rel2=[relaxation factor 2]:rel2' \
  'r1=[smoothing parameter 1]:r1' \
  'r2=[smoothing parameter 2]:r2' \
  'signal=[output signal file]:file:_files' \
  'noise=[output noise file]:file:_files' \
  '*:file:_files' && ret=0

return ret
