#compdef yarn-hadoop

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'application:manage YARN applications'
  'app:alias for application'
  'applicationattempt:view application attempt information'
  'classpath:display Hadoop classpath'
  'container:retrieve container information'
  'jar:execute a JAR file with YARN'
  'logs:retrieve container logs'
  'node:view node information'
  'queue:display queue details'
  'version:print Hadoop version'
  'envvars:display environment variables'
  'daemonlog:dynamically adjust daemon logging levels'
  'nodemanager:start NodeManager daemon'
  'proxyserver:start web proxy server'
  'resourcemanager:start ResourceManager'
  'rmadmin:manage ResourceManager operations'
  'schedulerconf:update scheduler configuration'
  'scmadmin:manage Shared Cache Manager'
  'sharedcachemanager:start Shared Cache Manager'
  'timelineserver:start Timeline Server'
  'registrydns:start Registry DNS server'
  'router:start router daemon'
  'fs2cs:convert FairScheduler to CapacityScheduler config'
  'top:display running applications top-style'
  'cluster:cluster info'
)

_arguments -C \
  '--config[Hadoop config dir]:dir:_files -/' \
  '--debug[debug output]' \
  '--loglevel[log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--daemon=[daemon mode]:mode:(start status stop)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'yarn subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (application|app)
        _arguments \
          '-list[list applications]' \
          '-kill[kill application]:appId:' \
          '-status+[show app status]:appId:' \
          '-changeQueue+[change app queue]:queue appId:' \
          '-start+[start service]:serviceName:' \
          '-stop+[stop service]:serviceName:' \
          '-flex+[flex component count]:component=count:' \
          '-launch+[launch service]:serviceName file:_files' \
          '-save+[save service]:serviceName file:_files' \
          '-destroy+[destroy service]:serviceName:' \
          '-updateLifetime+[update lifetime]:appId timeout:' \
          '-updatePriority+[update priority]:appId priority:' \
          '*-appStates+[filter by states]:states:(ALL NEW NEW_SAVING SUBMITTED ACCEPTED RUNNING FINISHED FAILED KILLED)' \
          '*-appTypes+[filter by app types]:types:' \
          '*-appTags+[filter by tags]:tags:' \
          '-help[show help]' && ret=0
        ;;
      (applicationattempt)
        _arguments \
          '-list+[list attempts for app]:appId:' \
          '-status+[show attempt status]:attemptId:' \
          '-help[show help]' && ret=0
        ;;
      (container)
        _arguments \
          '-list+[list containers for attempt]:attemptId:' \
          '-status+[show container status]:containerId:' \
          '-help[show help]' && ret=0
        ;;
      (logs)
        _arguments \
          '-applicationId+[application ID]:appId:' \
          '-containerId+[container ID]:containerId:' \
          '-nodeAddress+[node address]:host:port:' \
          '-appOwner+[app owner]:user:_users' \
          '-log_files+[log files (comma-separated)]:files:' \
          '-out+[output dir]:dir:_files -/' \
          '-show_application_log_info[show app log info]' \
          '-show_container_log_info[show container log info]' \
          '-list_nodes[list nodes for app]' \
          '-help[show help]' && ret=0
        ;;
      (node)
        _arguments \
          '-list[list nodes]' \
          '-status+[show node status]:nodeId:' \
          '*-states+[filter by states]:states:(NEW RUNNING UNHEALTHY DECOMMISSIONED LOST REBOOTED SHUTDOWN DECOMMISSIONING)' \
          '-all[show all nodes]' \
          '-showDetails[show details]' \
          '-help[show help]' && ret=0
        ;;
      (queue)
        _arguments \
          '-status+[show queue status]:queueName:' \
          '-help[show help]' && ret=0
        ;;
      (rmadmin)
        _arguments \
          '-refreshQueues[refresh queue config]' \
          '-refreshNodes[refresh nodes]' \
          '-refreshNodesResources[refresh node resources]' \
          '-refreshSuperUserGroupsConfiguration[refresh proxy user config]' \
          '-refreshUserToGroupsMappings[refresh user-to-groups mappings]' \
          '-refreshAdminAcls[refresh admin ACLs]' \
          '-refreshServiceAcl[refresh service ACL]' \
          '-getGroups[get groups]:user:_users' \
          '-addToClusterNodeLabels+[add cluster node labels]:labels:' \
          '-removeFromClusterNodeLabels+[remove cluster node labels]:labels:' \
          '-replaceLabelsOnNode+[replace labels on node]:labels:' \
          '-directlyAccessNodeLabelStore[directly access label store]' \
          '-refreshClusterMaxPriority[refresh cluster max priority]' \
          '-updateNodeResource+[update node resource]:nodeId memSize cpuCores:' \
          '-transitionToActive+[transition to active]:rmId:' \
          '-transitionToStandby+[transition to standby]:rmId:' \
          '-getServiceState+[get service state]:rmId:' \
          '-getAllServiceState[get all service states]' \
          '-checkHealth+[check service health]:rmId:' \
          '-help[show help]' && ret=0
        ;;
      (resourcemanager)
        _arguments \
          '-format-state-store[format RM state store]' \
          '-remove-application-from-state-store+[remove app from state store]:appId:' \
          '-format-conf-store[format RM config store]' \
          '-convert-fs-configuration[convert FS to CS configuration]' && ret=0
        ;;
      (schedulerconf)
        _arguments \
          '-add+[add queues]:queueAddPath:' \
          '-remove+[remove queues]:queueRemovePath:' \
          '-update+[update queues]:queueUpdatePath:' \
          '-global+[update global config]:key=value:' && ret=0
        ;;
      (scmadmin)
        _arguments \
          '-runCleanerTask[run cleaner task]' \
          '-help[show help]' && ret=0
        ;;
      (jar)
        _files -g "*.jar" && ret=0
        ;;
    esac
    ;;
esac

return ret
