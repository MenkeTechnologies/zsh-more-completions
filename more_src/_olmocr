#compdef olmocr
# Documentation: https://github.com/allenai/olmocr/blob/main/olmocr/pipeline.py
# Toolkit for linearizing PDFs for LLM datasets/training

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--pdfs=[path to pdfs to add to the workspace, glob or list file]:pdfs:_files' \
  '--model=[path where the model is located (local, s3, or huggingface)]:model' \
  '--server=[URL of external vLLM server]:url' \
  '--api_key=[API key for authenticated remote servers]:key' \
  '--markdown[also write natural text to markdown files]' \
  '--workers=[number of workers to run at a time]:n' \
  '--pages_per_group=[pdf pages per work item group]:n' \
  '--max_page_retries=[max retries for rendering a page]:n' \
  '--target_longest_image_dim=[dimension on longest side for rendering pages]:dim' \
  '--apply_filter[apply basic filtering to English pdfs which are not forms]' \
  '--stats[report statistics about workspace instead of running a job]' \
  '--port=[port to use for the vLLM server]:port' \
  '1:workspace:_files -/' && ret=0

return ret
