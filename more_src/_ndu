#compdef ndu
# Documentation: https://man.archlinux.org/search?q=ndu
# Reference accessed: 2026-05-16
# Source: https://github.com/ndorma/utils/blob/d4e0054ab1e99291d1007681abf6c4038cfd76a0/autocomplete/_ndu
# Repository: ndorma/utils (autocomplete/_ndu)

function _ndu {
    local line

    _arguments -C \
        "1:subcommand:(xls2csv backup backup-check-config self-update)" \
        "*::arg:->args"

    _ndu_"${line[1]}" 2>/dev/null
}

_ndu_xls2csv() {
    _arguments -C \
        "1:input file:_files" \
        "2:output file:_files"
}

