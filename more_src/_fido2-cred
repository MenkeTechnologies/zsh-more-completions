#compdef fido2-cred
# Documentation: fido2-cred usage (libfido2)
# Source: make / verify FIDO2 credentials.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-M -V)-M[make credential]' \
    '(-M -V)-V[verify credential]' \
    '-b[blob extension]' \
    '-d[debug]' \
    '-h[hmac-secret extension]' \
    '-q[quiet]' \
    '-r[allow updated counter]' \
    '-u[U2F-only credential]' \
    '-v[verbose]' \
    '-w[wait for user]' \
    '-a+[attestation mode]:mode:' \
    '-c+[cred-protect level]:cred_protect:' \
    '-i+[input file]:file:_files' \
    '-o+[output file]:file:_files' \
    '*:device or type:_files' \
    && ret=0

return ret
