#compdef rotalm_cxx
# Documentation: https://healpix.sourceforge.io/doc/html/Healpix_cxx/facilities.html
# HEALPix C++: rotate a_lm coefficients between coordinate systems

local ret=1

_arguments -s -S \
  '1:input a_lm file:_files' \
  '2:output a_lm file:_files' \
  '3:transform number:' \
  '4:polarisation flag:' && ret=0

return ret
