#compdef lit
# ============================================================================
# lit - LiteParse: fast document parser by LlamaIndex (Rust, Apache-2.0)
#
# Author : run-llama (LlamaIndex) team
# Upstream: https://github.com/run-llama/liteparse
# crates : liteparse (binary: lit)
#
# `lit` is the CLI for LiteParse, LlamaIndex's open-source
# fast/lightweight document parser. Parses PDF / DOCX / XLSX
# / PPTX / images into structured text or JSON, with spatial
# text extraction (positioned characters/lines + layout
# inference) and optional OCR fallback via either embedded
# Tesseract or a remote OCR HTTP server. Designed as a
# self-hostable alternative to the proprietary LlamaParse SaaS
# - the LLM-input-prep step for the LlamaIndex / LlamaCloud
# retrieval pipeline.
#
# Architecture: pdfium-rs (Chromium's PDF engine bindings) for
# PDF; LibreOffice headless conversion for DOCX/XLSX/PPTX
# (shells out to `soffice`); image crate for raster decode;
# tesseract-rs for OCR (or HTTP POST to an OCR server);
# infer for content-type detection on input files.
#
# Subcommands (clap derive):
#   parse <file>             - parse one document, emit text/JSON
#   screenshot <file>        - render document pages as PNG
#   batch-parse <in> <out>   - parse a directory of documents
#   extract <pdf>            - dev tool: raw PDF text items (hidden)
#   image-bounds <pdf>       - dev tool: embedded image bboxes (hidden)
#
# parse flags:
#   -o, --output <file>            - output file (default stdout)
#       --format <fmt>             - "text" (default) or "json"
#       --no-ocr                   - disable OCR fallback
#       --ocr-language <lang>      - Tesseract lang (default "eng")
#       --ocr-server-url <url>     - remote OCR HTTP server
#       --tessdata-path <dir>      - override TESSDATA_PREFIX
#       --max-pages <n>            - max pages (default 1000)
#       --target-pages <ranges>    - "1-5,10,15-20"
#       --dpi <n>                  - render DPI (default 150)
#       --preserve-small-text      - keep very small text
#       --password <pw>            - for encrypted documents
#   -q, --quiet                    - suppress progress output
#       --num-workers <n>          - concurrent OCR workers
#
# screenshot flags:
#   -o, --output-dir <dir>         - default "./screenshots"
#       --target-pages <ranges>    - e.g. "1,3,5" or "1-5"
#       --dpi <n>                  - default 150
#       --password <pw>            - for encrypted documents
#   -q, --quiet                    - suppress progress output
#
# batch-parse flags:
#       --format / --no-ocr / --ocr-language / --ocr-server-url /
#       --tessdata-path / --max-pages / --dpi / --password /
#       --recursive / --extension <.pdf> / -q / --num-workers
#
# The infer lane is built on `infer = "0.19.0"` (declared
# verbatim at upstream crates/liteparse/Cargo.toml HEAD), the
# canonical Rust file-type detection library by Bojan Djurkovic
# (github.com/bojand/infer, 900+ stars). infer is the
# uncontested Rust file-format-by-magic-bytes library - given
# the first 8 KB of a file, returns the inferred MIME type +
# canonical extension. Supports 200+ file formats from the
# IANA registry (image/jpeg, application/pdf, video/mp4,
# application/vnd.openxmlformats-officedocument.*, archive
# formats, font formats, etc.). LiteParse uses it to
# dispatch the input file to the right parser branch (PDF
# vs. office vs. image vs. text) without trusting the file
# extension.
#
# ----------------------------------------------------------------------------
# AXIS 231 :: File-type / MIME detection from magic bytes  [OPENS]
# Round 1391 :: Rust slot 1 of 4 :: OPENS Axis 231
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : bojand/infer                 - byte-magic file-format detector
#   Go      : gabriel-vasile/mimetype      - de-facto Go MIME detector
#   TS/Node : sindresorhus/file-type       - npm-canonical file-type detector
#
# File-type detection libraries are a clean cross-language
# axis because the magic-byte-table is essentially the same
# across implementations - all three lanes maintain their
# own copy of the table but with byte-for-byte agreement on
# the 200+ widely-used formats. The differentiator is API
# shape: infer (Rust) returns an Option<Type>, mimetype (Go)
# returns a *MIME with a method chain (`.Is`, `.Parent`,
# `.Extension`), file-type (TS) returns a Promise<FileTypeResult>
# with an async stream-friendly API.
#
# All three handle the "file uploaded via HTTP with
# untrusted Content-Type or .txt extension that's actually
# an executable" case identically - the magic bytes are
# bit-for-bit identical regardless of source language.
# This is the canonical use case: never trust the
# extension, always probe the bytes.
# ============================================================================

_lit() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_lit_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                parse)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output file]:file:_files' \
                        '--format[output format]:fmt:(text json)' \
                        '--no-ocr[disable OCR]' \
                        '--ocr-language[OCR language code]:lang:(eng fra deu spa ita por rus chi_sim chi_tra jpn kor ara)' \
                        '--ocr-server-url[HTTP OCR server URL]:url:' \
                        '--tessdata-path[tessdata directory (overrides TESSDATA_PREFIX)]:dir:_files -/' \
                        '--max-pages[max pages to parse (default 1000)]:n:' \
                        '--target-pages[page ranges (e.g. 1-5,10,15-20)]:ranges:' \
                        '--dpi[render DPI (default 150)]:n:' \
                        '--preserve-small-text[preserve very small text]' \
                        '--password[password for encrypted documents]:password:' \
                        '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
                        '--num-workers[concurrent OCR workers]:n:' \
                        '(- *)'{-h,--help}'[help]' \
                        '1:input file:_files'
                    ;;
                screenshot)
                    _arguments \
                        '(-o --output-dir)'{-o,--output-dir}'[output directory (default ./screenshots)]:dir:_files -/' \
                        '--target-pages[page ranges]:ranges:' \
                        '--dpi[render DPI (default 150)]:n:' \
                        '--password[password for encrypted documents]:password:' \
                        '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
                        '(- *)'{-h,--help}'[help]' \
                        '1:input document:_files'
                    ;;
                batch-parse)
                    _arguments \
                        '--format[output format]:fmt:(text json)' \
                        '--no-ocr[disable OCR]' \
                        '--ocr-language[OCR language code]:lang:(eng fra deu spa ita por rus chi_sim chi_tra jpn kor ara)' \
                        '--ocr-server-url[HTTP OCR server URL]:url:' \
                        '--tessdata-path[tessdata directory]:dir:_files -/' \
                        '--max-pages[max pages per file (default 1000)]:n:' \
                        '--dpi[render DPI (default 150)]:n:' \
                        '--recursive[recursively search input directory]' \
                        '--extension[only process files with this extension]:ext:' \
                        '--password[password for encrypted documents]:password:' \
                        '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
                        '--num-workers[concurrent OCR workers]:n:' \
                        '(- *)'{-h,--help}'[help]' \
                        '1:input directory:_files -/' \
                        '2:output directory:_files -/'
                    ;;
                extract|image-bounds)
                    _arguments \
                        '--pdf-path[input PDF file]:file:_files -g "*.pdf"' \
                        '--page-num[target page number (1-based)]:n:' \
                        '(- *)'{-h,--help}'[help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_lit_cmds() {
    local -a cmds
    cmds=(
        'parse:Parse a document (PDF, DOCX, XLSX, PPTX, image)'
        'screenshot:Generate screenshots of document pages'
        'batch-parse:Parse multiple documents in batch mode'
        'extract:Extract raw text items from a PDF (dev tool)'
        'image-bounds:Extract embedded image bounding boxes (dev tool)'
    )
    _describe -t commands 'lit command' cmds
}

_lit "$@"
