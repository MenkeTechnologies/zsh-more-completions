#compdef pik

# Zsh completion for pik (process interactive kill)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-s --signal)'{-s,--signal}'[signal to send]:signal:(SIGTERM SIGKILL SIGHUP SIGINT SIGQUIT SIGSTOP SIGCONT SIGUSR1 SIGUSR2)' \
  '--no-header[hide the header row]' \
  '1:process filter pattern'
