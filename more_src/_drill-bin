#compdef drill-bin
# _drill-bin — drill DNS query tool (NLnet Labs); same flags as drill, packaged with bin suffix
# upstream: https://nlnetlabs.nl/projects/ldns

_drill-bin() {
    _arguments \
        '-D[enable DNSSEC OK]' \
        '-T[trace from root]' \
        '-S[chase signatures]' \
        '-V+[verbose level]:n:' \
        '-Q[quiet]' \
        '-f+[input file with packet]:file:_files' \
        '-i+[hex packet input]:str:' \
        '-w+[hex packet output file]:file:_files' \
        '-q+[hex query file output]:file:_files' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-a[adjusted output]' \
        '-b+[buffer size bytes]:n:' \
        '-c+[class]:class:(IN CH HS)' \
        '-k+[trust anchor file]:file:_files' \
        '-o+[output flags]:flags:' \
        '-p+[port]:port:' \
        '-r+[resolver file]:file:_files' \
        '-s[show RR signatures]' \
        '-t[TCP query]' \
        '-u[UDP query]' \
        '-v[show version]' \
        '-x[reverse query]' \
        '-y+[TSIG key]:key:' \
        '-z[no use of /etc/resolv.conf]' \
        '*:name [type] [@server]:'
}

_drill-bin "$@"
