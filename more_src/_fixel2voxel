#compdef fixel2voxel
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixel2voxel.html
# Source: MRtrix3/mrtrix3 cmd/fixel2voxel.cpp — collapse fixel data to a scalar per voxel (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-number+[use only the largest N fixels per voxel]:n:_default' \
    '-fill+[fill value when N>actual (default 0.0)]:value:_default' \
    '-weighted+[weight by fixel volume (fixel_in image)]:image:_files' \
    '1:fixel_in (input fixel data):_files' \
    '2:operation:(mean sum product min max absmax magmax count complexity sf dec_unit dec_scaled none)' \
    '3:image_out (output scalar image):_files' \
    && ret=0

return ret
