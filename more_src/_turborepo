#compdef turborepo
# Documentation: https://turborepo.com/docs/reference
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a task across packages'
  'watch:watch and re-run tasks on file changes'
  'prune:produce a pruned subset of the monorepo'
  'generate:scaffold new packages or apps'
  'ls:list packages in the monorepo'
  'login:log in to Vercel for remote cache'
  'logout:log out of Vercel'
  'link:link repo to Vercel team for remote cache'
  'unlink:remove link to Vercel team'
  'daemon:manage the turbo background daemon'
  'telemetry:configure anonymous telemetry'
  'completion:generate shell completion'
  'bin:print the binary path'
  'help:show help'
  'info:show package info'
  'query:query Turborepo dependency graph'
  'boundaries:check package import boundaries'
  'config:print resolved turbo config'
  'scan:run automated repo scan'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api=[remote cache API URL]:url:' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--cwd=[run from a different directory]:dir:_files -/' \
  '--heap=[heap profile path]:file:_files' \
  '--cpuprofile=[CPU profile path]:file:_files' \
  '--login=[Vercel login URL]:url:' \
  '--no-update-notifier[suppress update notifier]' \
  '--preflight[send preflight requests]' \
  '--remote-cache-timeout=[remote cache timeout]:duration:' \
  '--single-package[single-package mode]' \
  '--token=[Vercel token]:token:' \
  '--team=[Vercel team slug]:team:' \
  '--trace=[Chrome trace output path]:file:_files' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:n:(0 1 2)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'turbo command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|watch)
        _arguments \
          '--cache=[remote cache toggles]:opt:(local:r,remote:rw local:rw,remote:r local:rw,remote:rw)' \
          '--cache-dir=[local cache directory]:dir:_files -/' \
          '--concurrency=[max parallel tasks]:n:' \
          '--continue[continue on task failure]' \
          '--dry-run[dry run - print task graph]' \
          '--dry=[dry run with output format]:format:(json text)' \
          '--summarize[write run summary]' \
          '--env-mode=[env mode]:mode:(strict loose)' \
          '*--filter=[scope tasks]:filter:' \
          '*--force[ignore cached results]' \
          '--framework-inference[infer framework]' \
          '--graph=[output task graph]:file:_files' \
          '--ignore=[ignore pattern]:pattern:' \
          '--include-dependencies[include dependencies]' \
          '--global-deps=[global file deps]:pattern:' \
          '--no-cache[disable caching]' \
          '--no-daemon[disable daemon (deprecated)]' \
          '--output-logs=[logs to print]:logs:(full hash-only new-only errors-only none)' \
          '--log-order=[task log order]:order:(auto stream grouped)' \
          '--log-prefix=[log prefix mode]:mode:(auto none task)' \
          '--parallel[run all packages in parallel]' \
          '--profile=[profile output path]:file:_files' \
          '--remote-only[require remote cache]' \
          '--anchored-tasks[run only anchored tasks]' \
          '*::task:' && ret=0 ;;
      (prune)
        _arguments \
          '--docker[generate Docker-friendly output]' \
          '--out-dir=[output directory]:dir:_files -/' \
          '*--scope=[scope packages]:scope:' \
          '*--filter=[filter packages]:filter:' \
          '--use-gitignore[use .gitignore]' && ret=0 ;;
      (generate)
        _arguments \
          '*::sub:(workspace run)' \
          '--name=[generator name]:name:' \
          '--config=[generator config]:file:_files' \
          '--root=[root path]:dir:_files -/' && ret=0 ;;
      (ls)
        _arguments \
          '*--filter=[filter packages]:filter:' \
          '--output=[output format]:format:(pretty json)' && ret=0 ;;
      (daemon)
        _arguments \
          '*::sub:(start stop restart status logs clean)' && ret=0 ;;
      (telemetry)
        _arguments \
          '*::sub:(status enable disable)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
