#compdef conduit conduwuit
# _conduit-cli — Conduit / conduwuit Matrix homeserver (Rust); lightweight single-binary homeserver via RocksDB / SQLite backend
# upstream: https://gitlab.com/famedly/conduit

_conduit-cli() {
    _arguments \
        '--config+[TOML config file]:file:_files -g "*.toml"' \
        '--help[show help]' \
        '--version[show version]' \
        '--port+[port]:port:' \
        '--address+[bind address]:host:_hosts' \
        '--database-backend+[backend]:backend:(rocksdb sqlite)' \
        '--database-path+[database dir]:dir:_files -/' \
        '--log+[log level]:level:(trace debug info warn error)' \
        '--server-name+[server name]:name:' \
        '*:cmd:'
}

_conduit-cli "$@"
