#compdef star4ToFoam
# Converts a STAR-CD (v4) PROSTAR mesh to OpenFOAM format

local ret=1

_arguments -s -S \
  '-help[print the usage]' \
  '-ascii[write in ASCII instead of binary format]' \
  '-scale+[geometry scaling factor - default is 0.001 ([mm] to [m])]:factor:' \
  '-solids[retain solid cells and treat them like fluid cells]' \
  '-case+[specify alternate case directory]:dir:_files -/' \
  '-fileHandler+[override the fileHandler]:handler:(uncollated collated masterUncollated)' \
  '-libs+[pre-load libraries]:libs:' \
  ':pro-STAR prefix:_files' && ret=0

return ret
