#compdef deluge-console

# Zsh completion for deluge-console (Deluge BitTorrent client CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --daemon)'{-d,--daemon}'[daemon address]:address' \
  '(-p --port)'{-p,--port}'[daemon port]:port' \
  '(-U --username)'{-U,--username}'[daemon username]:username' \
  '(-P --password)'{-P,--password}'[daemon password]:password' \
  '(-c --config)'{-c,--config}'[config directory]:directory:_files -/' \
  '(-l --logfile)'{-l,--logfile}'[log file]:log file:_files' \
  '(-L --loglevel)'{-L,--loglevel}'[log level]:level:(none critical error warning info debug)' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'add:add a torrent'
      'cache:show cache status'
      'config:show or set configuration values'
      'connect:connect to a daemon'
      'debug:enable or disable debug'
      'halt:shutdown the daemon'
      'info:show torrent information'
      'manage:set torrent to managed'
      'move:move torrent storage'
      'pause:pause a torrent'
      'plugin:manage plugins'
      'quit:quit the console'
      'recheck:force a data recheck'
      'remove:remove a torrent'
      'resume:resume a torrent'
      'status:show session status'
      'update-tracker:update tracker for a torrent'
    )
    _describe -t commands 'deluge-console command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (add)
        _arguments \
          '-p[download path]:path:_files -/' \
          '*:torrent:_files -g "*.torrent"' && ret=0
        ;;
      (config)
        _arguments \
          '-s[set config value]:key' \
          '1:key' && ret=0
        ;;
      (info)
        _arguments \
          '-v[verbose output]' \
          '-d[detailed output]' \
          '-s[state filter]:state:(Active Allocating Checking Downloading Error Moving Paused Queued Seeding)' \
          '*:torrent id' && ret=0
        ;;
      (move)
        _arguments \
          '1:torrent id' \
          '2:destination:_files -/' && ret=0
        ;;
      (remove)
        _arguments \
          '--remove_data[remove downloaded data]' \
          '*:torrent id' && ret=0
        ;;
    esac
    ;;
esac

return ret
