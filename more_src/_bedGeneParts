#compdef bedGeneParts
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# given a bed, spit out promoter, first exon, or all introns

local ret=1

_arguments -s -S \
  '-proStart=[start of promoter relative to transcription start (default -100)]:n' \
  '-proEnd=[end of promoter relative to transcription start (default 50)]:n' \
  '1:part:(exons firstExon introns promoter firstCodingSplice secondCodingSplice)' \
  '2:in bed:_files -g "*.bed"' \
  '3:out bed:_files' && ret=0

return ret
