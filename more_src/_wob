#compdef wob

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-t+[timeout in milliseconds]:timeout' \
  '--timeout=[timeout in milliseconds]:timeout' \
  '-m+[maximum value]:max' \
  '--max=[maximum value]:max' \
  '-W+[bar width in pixels]:width' \
  '--width=[bar width in pixels]:width' \
  '-H+[bar height in pixels]:height' \
  '--height=[bar height in pixels]:height' \
  '-o+[bar offset from edge]:offset' \
  '--offset=[bar offset from edge]:offset' \
  '-b+[border width in pixels]:width' \
  '--border=[border width in pixels]:width' \
  '-p+[bar padding in pixels]:padding' \
  '--padding=[bar padding in pixels]:padding' \
  '-a+[anchor position]:anchor:(top bottom left right center)' \
  '--anchor=[anchor position]:anchor:(top bottom left right center)' \
  '-M+[margin]:margin' \
  '--margin=[margin]:margin' \
  '-O+[output name]:output' \
  '--output=[output name]:output' \
  '--border-color=[border color in AARRGGBB]:color' \
  '--background-color=[background color in AARRGGBB]:color' \
  '--bar-color=[bar color in AARRGGBB]:color' \
  '--overflow-mode=[overflow mode]:mode:(wrap nowrap)' \
  '--overflow-bar-color=[overflow bar color in AARRGGBB]:color' \
  '--overflow-background-color=[overflow background color]:color' \
  '--overflow-border-color=[overflow border color]:color' && ret=0

return ret
