#compdef upscmd
# Documentation: https://networkupstools.org/docs/man/upscmd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show NUT version]' \
  '-l[list available instant commands on UPS]' \
  '-u+[username]:user:' \
  '-p+[password]:pw:' \
  '-w[wait for driver completion]' \
  '-t+[timeout in seconds when using -w]:seconds:' \
  '-D[raise debugging level]' \
  '-W+[network connection timeout in seconds]:seconds:' \
  '*:ups@host_command:' && ret=0

return ret
