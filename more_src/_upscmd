#compdef upscmd
# Documentation: https://man.archlinux.org/search?q=upscmd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-l[list available commands on UPS]' \
  '-u+[username]:user:' \
  '-p+[password]:pw:' \
  '-w[wait for completion]' \
  '*:ups@host_command:' && ret=0

return ret
