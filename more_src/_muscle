#compdef muscle
# _muscle — Robert Edgar MUSCLE multiple sequence alignment tool with v5 super5 ensemble algorithm (rcedgar team, C++); custom argparse
# upstream: https://github.com/rcedgar/muscle

_muscle() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-align+[input file]:file:_files -g "*.fa *.fasta *.faa *.fna *.fa.gz"' \
        '-output+[output alignment]:file:_files -g "*.fa *.fasta *.aln *.afa *.msa"' \
        '-super5+[input fasta]:file:_files -g "*.fa *.fasta *.faa *.fna"' \
        '-stratified+[input fasta]:file:_files' \
        '-diversified+[input fasta]:file:_files' \
        '-replicates+[N]:n:' \
        '-perm+[mode]:m:(none abc acb bca cab cba bac)' \
        '-perturb+[N]:n:' \
        '-threads+[N]:n:' \
        '-consiters+[N]:n:' \
        '-refineiters+[N]:n:' \
        '-protein[protein input]' \
        '-nuc[nucleotide input]' \
        '-amino[amino acid input]' \
        '-resume+[checkpoint file]:file:_files' \
        '-checkpoint_dir+[dir]:dir:_files -/' \
        '-disto+[output guide tree]:file:_files -g "*.phy *.tree"' \
        '-tree1+[output tree 1]:file:_files' \
        '-tree2+[output tree 2]:file:_files' \
        '-savemsa+[output MSA]:file:_files -g "*.fa *.fasta *.aln *.afa"' \
        '-msaout+[output MSA]:file:_files -g "*.fa *.fasta *.aln *.afa"' \
        '-efaout+[output ensemble efa]:file:_files -g "*.efa"' \
        '-quiet[quiet]' \
        '-disto+[output distance file]:file:_files' \
        '-letterconfsi+[file]:file:_files' \
        '-columnconfsi+[file]:file:_files' \
        '-pdb_input+[PDB file]:file:_files -g "*.pdb"' \
        '-foldermsa+[folder]:dir:_files -/' \
        '-msafiles+[file list]:file:_files' \
        '-mpr+[file]:file:_files'
}

_muscle "$@"
