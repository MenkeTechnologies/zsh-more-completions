#compdef rz rb rx

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[ASCII transfer mode]' \
  '-b[binary transfer mode]' \
  '-B+[buffer size]:size' \
  '-c[use 16 bit CRC]' \
  '-C[use 32 bit CRC]' \
  '-D[output file data to stdout]' \
  '-e[escape all control characters]' \
  '-E[rename if target exists]' \
  '-O[disable timeouts]' \
  '-p[protect existing files]' \
  '-q[quiet mode]' \
  '-R[restricted mode]' \
  '-s[use HDB uucp path names]' \
  '-S+[set command string]:command' \
  '-t+[change timeout]:seconds' \
  '-v[verbose mode]' \
  '-w+[set window size]:size' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files]' \
  '-Z[use ZMODEM protocol]' && return 0
