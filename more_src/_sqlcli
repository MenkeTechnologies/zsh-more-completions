#compdef sqlcli
# Documentation: https://github.com/SamEdwardes/sqlcli
# Reference accessed: 2026-05-21
# Verified: sqlcli README (typer commands).

# Zsh completion for sqlcli (SQLModel CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init-demo:create a sample SQLite database for testing'
  'select:read and display data from a table'
  'insert:insert data into a table'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlcli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (select|insert)
        _arguments -s -S \
          '(-d --database)'{-d+,--database=}'[database connection string]:url:' \
          '(-m --models)'{-m+,--models=}'[path to SQLModel models file]:file:_files -g "*.py"' \
          '1:table:' && ret=0
        ;;
    esac
    ;;
esac

return ret
