#compdef sqlcli
# Documentation: https://man.archlinux.org/search?q=sqlcli
# Reference accessed: 2026-05-16

# Zsh completion for sqlcli (SQLModel CLI)
# https://github.com/SamEdwardes/sqlcli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init-demo:Create a sample SQLite database'
  'select:Query and display data from a table'
  'insert:Add new rows to a table'
  'inspect:Show schema and structure'
)

_arguments -s -S \
  '--db-url=[database connection string]:url:' \
  '--format=[output style]:format:(rich json csv)' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlcli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (select|insert|inspect)
        _arguments -s -S '1:table:' && ret=0
        ;;
    esac
    ;;
esac

return ret
