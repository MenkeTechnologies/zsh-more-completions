#compdef giteye gitstats
# _giteye — CollabNet GitEye Eclipse-based Git GUI client CLI (CollabNet, Java); custom argparse
# upstream: https://www.collab.net/products/giteye

_giteye() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--data=+[workspace dir]:dir:_files -/' \
        '--clean[clean workspace cache]' \
        '--clearPersistedState[clear persisted state]' \
        '--debug[debug mode]' \
        '--noSplash[no splash]' \
        '--noExit[no exit after running]' \
        '--showLocation[show location label]' \
        '--vm=+[JVM]:file:_files' \
        '--vmargs=+[JVM args]:str:' \
        '--ws=+[window system]:ws:(cocoa gtk win32)' \
        '--os=+[OS]:os:(macosx linux win32)' \
        '--arch=+[arch]:arch:(x86_64 aarch64 x86)' \
        '--stdout=+[stdout redirect]:file:_files' \
        '--stderr=+[stderr redirect]:file:_files' \
        '--repo=+[repository path]:dir:_files -/' \
        '-r+[repository path]:dir:_files -/' \
        '*:path:_files'
}

_giteye "$@"
