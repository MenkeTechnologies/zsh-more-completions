#compdef loft

# Zsh completion for loft - Kubernetes multi-tenancy and virtual clusters

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[path to loft config]:config file:_files' \
  '--debug[enable debug logging]' \
  '--silent[suppress output]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case "$state" in
  subcmd)
    local -a subcmds=(
      'login:log in to a loft instance'
      'logout:log out of a loft instance'
      'start:start a loft instance'
      'stop:stop a loft instance'
      'status:show the status of loft'
      'sleep:put a resource to sleep'
      'wakeup:wake up a sleeping resource'
      'connect:connect to a cluster'
      'create:create a resource'
      'delete:delete a resource'
      'get:get a resource'
      'list:list resources'
      'use:use a resource'
      'share:share a resource'
      'import:import a resource'
      'defaults:set or show defaults'
      'reset:reset configuration'
      'upgrade:upgrade loft'
      'completion:generate shell completion'
      'token:manage tokens'
      'vars:manage variables'
      'devspace:manage DevSpace integrations'
      'ui:open the loft UI'
      'backup:backup loft resources'
    )
    _describe -t subcommands 'loft subcommand' subcmds && ret=0
    ;;
  args)
    case "${line[1]}" in
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '--access-key=[access key for authentication]:access key' \
          '--docker-login[also log in to Docker]' \
          '--insecure[allow insecure connections]' \
          '1:loft URL' && ret=0
        ;;
      create)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '1:resource type:(space virtualcluster vcluster)' \
          '2:name' && ret=0
        ;;
      delete)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '1:resource type:(space virtualcluster vcluster)' \
          '2:name' && ret=0
        ;;
      use)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '1:resource type:(space virtualcluster vcluster management cluster)' \
          '2:name' && ret=0
        ;;
      get|list|share|import|sleep|wakeup|connect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '*:name' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config=[path to loft config]:config file:_files' \
          '--debug[enable debug logging]' \
          '--silent[suppress output]' \
          '*:argument' && ret=0
        ;;
    esac
    ;;
esac

return ret
