#compdef zed-policy-cli zed
# _zed-policy-cli — Authzed zed SpiceDB control plane CLI alias (authzed team, Go); cobra
# upstream: https://github.com/authzed/zed

_zed-policy-cli() {
    local -a sub=(
        'context:context subcommands'
        'context:list:list contexts'
        'context:use:select context'
        'context:set:set context'
        'context:remove:remove context'
        'context:rename:rename context'
        'experiment:experimental commands'
        'experiment:expand:expand permission'
        'experiment:bulk-checkpermissions:bulk checks'
        'experiment:bulk-importrelationships:bulk import'
        'experiment:bulk-exportrelationships:bulk export'
        'experiment:lookup-subjects:lookup subjects'
        'experiment:lookup-resources:lookup resources'
        'experiment:reflect-schema:reflect schema'
        'experiment:trace-relationship:trace relationship'
        'experiment:debug-permission:debug permission'
        'permission:check:check permission'
        'permission:lookup-resources:lookup resources'
        'permission:lookup-subjects:lookup subjects'
        'permission:expand:expand permission tree'
        'relationship:create:create relationship'
        'relationship:touch:upsert relationship'
        'relationship:delete:delete relationship'
        'relationship:read:read relationships'
        'relationship:bulk-delete:bulk delete'
        'restore:restore relationships backup'
        'backup:create relationships backup'
        'schema:read:read schema'
        'schema:write:write schema'
        'schema:copy:copy schema'
        'schema:diff:diff schemas'
        'validate:validate schema+relationships'
        'watch:watch relationship changes'
        'token:token management'
        'token:create:create token'
        'token:list:list tokens'
        'token:delete:delete token'
        'use:set context'
        'version:show CLI version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--endpoint=+[grpc endpoint]:str:' \
        '--insecure[insecure connection]' \
        '--no-verify-ca[skip CA verify]' \
        '--token=+[api token]:str:' \
        '--proxy=+[http proxy]:str:' \
        '--request-id=+[request id]:str:' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '--log-format=+[format]:f:(auto console json)' \
        '--max-retries=+[n]:n:' \
        '--skip-version-check[skip version check]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zed subcommand' sub ;;
        args)
            case $words[1] in
                permission:check) _arguments \
                    '1:resource:' \
                    '2:permission:' \
                    '3:subject:' \
                    '--revision=+[zedtoken]:str:' \
                    '--consistency-at-exactly=+[zedtoken]:str:' \
                    '--consistency-at-least=+[zedtoken]:str:' \
                    '--consistency-min-latency[min latency]' \
                    '--consistency-full[fully consistent]' ;;
                relationship:create|relationship:touch|relationship:delete) _arguments \
                    '1:resource:' \
                    '2:relation:' \
                    '3:subject:' \
                    '--caveat=+[caveat]:str:' ;;
                schema:write) _arguments \
                    '1:schema file:_files -g "*.{zed,zedschema}"' \
                    '--json[json output]' \
                    '--schema-definition-prefix=+[prefix]:str:' ;;
                schema:read) _arguments \
                    '--json[json output]' \
                    '--revision=+[zedtoken]:str:' ;;
                backup|restore) _arguments \
                    '1:file:_files' \
                    '--batch-size=+[n]:n:' \
                    '--prefix-filter=+[prefix]:str:' \
                    '--exclude-prefix=+[prefix]:str:' ;;
                use|context:use|context:remove|context:rename|context:set) _arguments '1:context:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_zed-policy-cli "$@"
