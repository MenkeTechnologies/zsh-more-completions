#compdef gdal_viewshed
# Documentation: https://gdal.org/programs/gdal_viewshed.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '--long-usage[extended usage]' \
  '(- *)--version[show version]' \
  '-b+[input DEM band]:band:' \
  '-a_nodata+[output nodata value]:value:' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-vv+[visible value (default 255)]:value:' \
  '-iv+[invisible value (default 0)]:value:' \
  '-ov+[out-of-range value (default 0)]:value:' \
  '-ox+[observer X coordinate]:x:' \
  '-oy+[observer Y coordinate]:y:' \
  '-oz+[observer height (default 2)]:z:' \
  '-tz+[target height (default 0)]:z:' \
  '-md+[maximum visibility distance]:m:' \
  '-cc+[curvature/refraction coefficient]:c:' \
  '-om+[output mode]:mode:(NORMAL DEM GROUND ACCUM)' \
  '-os+[observer cell spacing (ACCUM mode)]:value:' \
  '-j+[number of parallel jobs]:n:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '1:source raster:_files' \
  '2:output raster:_files' && ret=0

return ret
