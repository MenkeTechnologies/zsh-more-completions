#compdef gdal_viewshed

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b+[band number]:band:' \
  '-a_nodata+[output nodata value]:value:' \
  '-f+[output format]:format:' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-vv+[visible value]:value:' \
  '-iv+[invisible value]:value:' \
  '-ov+[out-of-range value]:value:' \
  '-ox+[observer X]:x:' \
  '-oy+[observer Y]:y:' \
  '-oz+[observer height]:z:' \
  '-tz+[target height]:z:' \
  '-md+[max distance]:m:' \
  '-cc+[curvature coefficient]:c:' \
  '-om+[output mode]:mode:(NORMAL DEM GROUND ACCUM_COST)' \
  '-q[quiet]' \
  '1:source raster:_files' \
  '2:output raster:_files' && ret=0

return ret
