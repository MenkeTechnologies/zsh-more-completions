#compdef CountVariants
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/CountVariants.java
# GATK4: count the number of variant records in a VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --variant)'{-V,--variant}'[input VCF file]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-O --output)'{-O,--output}'[optional output file for the variant count]:file:_files' \
  '*:options:_files' && ret=0

return ret
