#compdef 3dTfitter
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTfitter.html
# AFNI: fit a time series model voxelwise (L1/L2/LASSO/deconvolution)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-RHS[right-hand-side input dataset(s)]:dataset:_files' \
  '*-LHS[left-hand-side regressor column(s)]:column:_files' \
  '-polort[detrend RHS with polynomial of order p]:p:' \
  '-vthr[variance threshold to skip voxels]:v:' \
  '-FALTUNG[deconvolution: fset fpre pen fac]:fset fpre pen fac:_files' \
  '-lsqfit[least squares fit (alias -l2fit)]' \
  '-l2fit[least squares fit]' \
  '-L2[least squares fit]' \
  '-l1fit[L1 (least absolute deviation) fit]' \
  '-L1[L1 fit]' \
  '-l2lasso[L2 fit with LASSO penalty]:lam:' \
  '-LASSO[L2 fit with LASSO penalty]:lam:' \
  '-l2sqrtlasso[L2 fit with square-root LASSO]:lam:' \
  '-SQRTLASSO[L2 fit with square-root LASSO]:lam:' \
  '-lasso_centro_block[LASSO centro block list]:list:' \
  '-LCB[LASSO centro block list]:list:' \
  '-consign[allow sign constraints on parameters]:list:' \
  '-consFAL[sign constraint on deconvolution output]:s:' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-label[labels for LHS columns]:labels:' \
  '-fitts[output fitted time series dataset]:prefix:_files' \
  '-errsum[output error sum dataset]:prefix:_files' \
  '-mask[mask dataset]:mask:_files' \
  '-quiet[suppress progress messages]' \
  '*:dataset:_files' && ret=0

return ret
