#compdef rms gmx-rms
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-rms.html
# Calculate root mean square deviation (RMSD), rho or scaled rho between structures

local ret=1

_arguments -s -S \
  '-s+[structure+mass database]:structure:_files -g "*.(tpr|gro|g96|pdb|brk|ent)"' \
  '-f+[trajectory file]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-f2+[second trajectory for comparison matrix]:trajectory:_files -g "*.(xtc|trr|cpt|gro|g96|pdb|tng|h5md)"' \
  '-n+[index file]:index file:_files -g "*.ndx"' \
  '-o+[output xvg file with RMSD values]:xvg file:_files -g "*.xvg"' \
  '-mir+[output file for mirror image comparison]:xvg file:_files -g "*.xvg"' \
  '-a+[output file for average values]:xvg file:_files -g "*.xvg"' \
  '-dist+[output distribution file]:xvg file:_files -g "*.xvg"' \
  '-m+[XPM matrix file]:xpm file:_files -g "*.xpm"' \
  '-bin+[binary dump of comparison matrix]:file:_files -g "*.dat"' \
  '-bm+[XPM matrix of bond angle deviations]:xpm file:_files -g "*.xpm"' \
  '-b+[start time ps]:time:' \
  '-e+[end time ps]:time:' \
  '-dt+[frame selection interval ps]:time:' \
  '-tu+[time unit]:unit:(fs ps ns us ms s)' \
  '-xvg+[plot format]:format:(xmgrace xmgr none)' \
  '-what+[measurement type]:type:(rmsd rho rhosc)' \
  '-fit+[fitting method]:method:(rot+trans translation none)' \
  '-prev+[compare with frame N positions ago]:n:' \
  '-skip+[write every nth frame to matrix]:n:' \
  '-skip2+[write every nth frame to second matrix]:n:' \
  '-max+[maximum level in comparison matrix]:value:' \
  '-min+[minimum level in comparison matrix]:value:' \
  '-bmax+[maximum level in bond angle matrix]:value:' \
  '-bmin+[minimum level in bond angle matrix]:value:' \
  '-nlevels+[number of matrix levels]:n:' \
  '-ng+[number of groups for RMS computation]:n:' \
  '-w[view output files]' \
  '-pbc[enable periodic boundary condition checking]' \
  '-split[split graph at zero time points]' \
  '-mw[use mass weighting for superposition]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
