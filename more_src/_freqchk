#compdef freqchk
# Documentation: https://gaussian.com/freqchk/
# Display frequency and thermochemistry data from a Gaussian checkpoint file

local ret=1

_arguments -s -S \
  '-m[memory to allocate (must precede other options)]:amount' \
  '-o[send output to the specified file]:output file:_files' \
  '-nfd[skip diagonalization of the full (3*Natoms)^2 matrix]' \
  '-sel[select normal modes for inclusion]' \
  '-read[read normal modes from the checkpoint file]' \
  '-save[save normal modes (binary checkpoint files only)]' \
  '-np=[use N processors for the frequency analysis]:processors' \
  '*:checkpoint file:_files -g "*.(chk|fchk)"' && ret=0

return ret
