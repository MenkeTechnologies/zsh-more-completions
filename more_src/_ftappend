#compdef ftappend
# Documentation: https://heasarc.gsfc.nasa.gov/docs/software/lheasoft/help/ftappend.html
# Append a copy of an HDU from one FITS file to the end of another

local ret=1

_arguments -s -S \
  'infile=[input FITS file with optional extension/filters]:infile:_files' \
  'outfile=[existing output FITS file to append to]:outfile:_files' \
  'chatter=[verbosity level 0-5]:chatter:(0 1 2 3 4 5)' \
  'history=[record parameters as HISTORY keywords]:history:(yes no)' \
  '*:file:_files' && ret=0

return ret
