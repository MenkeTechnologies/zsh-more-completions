#compdef autoexpect
# Documentation: https://man.archlinux.org/search?q=autoexpect
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[run program with output]' \
  '-C+[quoting char]:char:' \
  '-f+[output file]:file:_files -g "*.exp"' \
  '-Q+[escape char]:char:' \
  '-p[promptmode]' \
  '-P[no promptmode]' \
  '*::cmd:_command_names' && ret=0

return ret
