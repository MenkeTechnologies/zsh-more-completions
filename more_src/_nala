#compdef nala

# Zsh completion for nala (APT frontend)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'install:install packages'
      'remove:remove packages'
      'purge:purge packages'
      'update:update package list'
      'upgrade:upgrade the system'
      'fetch:fetch fast mirrors'
      'show:show package details'
      'search:search package names and descriptions'
      'list:list packages based on package names'
      'history:show transaction history'
      'clean:clear out the local repository of downloaded package files'
      'autopurge:autopurge packages that are no longer needed'
      'autoremove:autoremove packages that are no longer needed'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '(-y --assume-yes)'{-y,--assume-yes}'[assume yes]' \
          '(-d --download-only)'{-d,--download-only}'[download only]' \
          '--no-install-recommends[do not install recommended packages]' \
          '--install-suggests[install suggested packages]' \
          '--no-update[skip updating the package list]' \
          '--no-fix-broken[skip fixing broken packages]' \
          '--no-autoremove[skip auto-removing unneeded packages]' \
          '(-o --option)'{-o,--option}'[set a configuration option]:option' \
          '--raw-dpkg[skip nala formatting and show raw dpkg output]' \
          '--debug[print debug information]' \
          '--verbose[verbose output]' \
          '*:package:_deb_packages avail' && ret=0
        ;;
      remove|purge)
        _arguments -s -S \
          '(-y --assume-yes)'{-y,--assume-yes}'[assume yes]' \
          '--no-autoremove[skip auto-removing unneeded packages]' \
          '--raw-dpkg[skip nala formatting and show raw dpkg output]' \
          '--debug[print debug information]' \
          '--verbose[verbose output]' \
          '*:package:_deb_packages installed' && ret=0
        ;;
      update)
        _arguments -s -S \
          '--debug[print debug information]' \
          '--raw-dpkg[skip nala formatting and show raw dpkg output]' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(-y --assume-yes)'{-y,--assume-yes}'[assume yes]' \
          '(-d --download-only)'{-d,--download-only}'[download only]' \
          '--no-update[skip updating the package list]' \
          '--no-fix-broken[skip fixing broken packages]' \
          '--no-autoremove[skip auto-removing unneeded packages]' \
          '--no-install-recommends[do not install recommended packages]' \
          '--full[perform a full upgrade]' \
          '--exclude=[exclude packages from upgrade]:packages' \
          '--raw-dpkg[skip nala formatting and show raw dpkg output]' \
          '--debug[print debug information]' \
          '--verbose[verbose output]' && ret=0
        ;;
      fetch)
        _arguments -s -S \
          '(-y --assume-yes)'{-y,--assume-yes}'[assume yes]' \
          '--fetches=[number of mirrors to fetch]:number' \
          '--debian[add the default Debian mirrors]' \
          '--ubuntu[add the default Ubuntu mirrors]' \
          '--devuan[add the default Devuan mirrors]' \
          '--ftp[include FTP mirrors]' \
          '--https-only[only use HTTPS mirrors]' \
          '--country=[filter mirrors by country]:country code' \
          '--sources[add source URIs for the mirror]' \
          '--debug[print debug information]' && ret=0
        ;;
      show)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[show all versions]' \
          '--installed[only show installed packages]' \
          '--debug[print debug information]' \
          '*:package:_deb_packages avail' && ret=0
        ;;
      search)
        _arguments -s -S \
          '(-A --all)'{-A,--all}'[show all versions]' \
          '--full[full description search]' \
          '--names[search only package names]' \
          '--installed[only search installed packages]' \
          '--debug[print debug information]' \
          '*:pattern' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-N[list only package names]' \
          '--installed[list only installed packages]' \
          '--upgradable[list only upgradable packages]' \
          '--all-versions[list all versions]' \
          '--debug[print debug information]' \
          '*:pattern' && ret=0
        ;;
      history)
        _arguments -s -S \
          '1:action:(info undo redo clear)' \
          '2:id' && ret=0
        ;;
      clean)
        _arguments -s -S \
          '--debug[print debug information]' \
          '--lists[also clear downloaded package lists]' && ret=0
        ;;
    esac
    ;;
esac

return ret
