#compdef picard-tools
# Documentation: https://broadinstitute.github.io/picard/
# Reference accessed: 2026-05-20
# Verified: upstream Broad Institute Picard documentation. picard-tools
# is the Debian/Ubuntu wrapper that exec'es `java -jar picard.jar TOOL ...`.
# Per-tool argument syntax is OPTION=value pairs handled after the
# subcommand; this completion lists the canonical tool names only.

# Picard: Java BAM/VCF utilities (Debian/Ubuntu wrapper script)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'MarkDuplicates:mark duplicate reads in a BAM'
  'SortSam:sort BAM by coordinate or query name'
  'MergeSamFiles:merge multiple BAMs'
  'MergeVcfs:merge multiple VCFs'
  'ValidateSamFile:validate BAM/SAM file'
  'BuildBamIndex:create .bai index'
  'AddOrReplaceReadGroups:edit RG tag'
  'CleanSam:fix MAPQ for unmapped reads'
  'FastqToSam:convert FASTQ to unaligned BAM'
  'SamToFastq:convert BAM to FASTQ'
  'CollectMultipleMetrics:run multiple metric tools'
  'CollectAlignmentSummaryMetrics:alignment metrics'
  'CollectInsertSizeMetrics:insert size distribution'
  'CollectWgsMetrics:WGS coverage metrics'
  'CollectRnaSeqMetrics:RNA-seq metrics'
  'CollectGcBiasMetrics:GC bias metrics'
  'CollectHsMetrics:hybrid-selection metrics'
  'CollectBaseDistributionByCycle:per-cycle base composition'
  'CollectQualityYieldMetrics:quality yield metrics'
  'EstimateLibraryComplexity:library complexity'
  'CreateSequenceDictionary:create .dict for FASTA'
  'NormalizeFasta:normalize FASTA line length'
  'GatherBamFiles:concatenate BAMs'
  'GatherVcfs:concatenate VCFs'
  'LiftoverVcf:liftover VCF coords between assemblies'
  'IndexVcf:index VCF for random access'
  'RenameSampleInVcf:rename sample in VCF'
  'BedToIntervalList:convert BED to Picard interval list'
  'IntervalListTools:manipulate interval lists'
  'ScatterIntervalsByNs:scatter intervals around N runs'
)

_arguments -C \
  '-h[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'Picard tool' commands && ret=0 ;;
esac

return ret
