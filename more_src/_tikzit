#compdef tikzit
# Documentation: https://man.archlinux.org/search?q=tikzit
# Reference accessed: 2026-05-16

# TikzIt: graph diagram editor producing TikZ output
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:TikZ file:_files -g "*.tikz"' && ret=0
return ret
