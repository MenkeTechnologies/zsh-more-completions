#compdef tikzit
# Documentation: https://github.com/tikzit/tikzit
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# TikzIt: graph diagram editor producing TikZ output
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:TikZ file:_files -g "*.tikz"' && ret=0
return ret
