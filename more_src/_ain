#compdef ain

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-b+[backend to use]:backend:(curl httpie wget)' \
  '--backend=[backend to use]:backend:(curl httpie wget)' \
  '-e+[environment variable]:name=value' \
  '--env=[environment variable]:name=value' \
  '-p[print request instead of executing]' \
  '--print[print request instead of executing]' \
  '-l[list available templates]' \
  '--list[list available templates]' \
  '*:template file:_files -g "*.ain(-.)"' && return 0
