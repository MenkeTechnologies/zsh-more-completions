#compdef smauvplt
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/smauvplt.html
# Make plots from a UV database on a PGPLOT device

local ret=1

_arguments -s \
  'vis=[input visibility file(s)]:dataset:_files' \
  'line=[standard linetype specification]:line' \
  'select=[visibility selection criteria]:select' \
  'stokes=[Stokes parameters or polarizations]:stokes' \
  'axis=[x and y axes (time, amplitude, phase, uu, vv, ...)]:axis' \
  'xrange=[plot range for x-direction]:xrange' \
  'yrange=[plot range for y-direction]:yrange' \
  'average=[averaging time in minutes]:average' \
  'hann=[Hanning smoothing length (odd, <15)]:hann' \
  'inc=[plot every INCth point]:inc' \
  'dotsize=[symbol size 1-201]:dotsize' \
  'title=[title content (BL,PO,FR,AV)]:title' \
  'device=[PGPLOT plot device/type]:device' \
  'nxy=[number of plots in x and y]:nxy' \
  'size=[PGPLOT character sizes for labels and symbols]:size' \
  'filelabel=[file name labeling (-1, 0, 1)]:filelabel' \
  'log=[output logfile name (default terminal)]:logfile:_files' \
  'comment=[one-line comment written to logfile]:comment' \
  'options=[nocal,nopol,nopass,nofqav,nobase,notitle,2pass,unwrap,rms,...]:options' \
  '*:dataset:_files' && ret=0

return ret
