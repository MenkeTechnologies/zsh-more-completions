#compdef zincsearch zinc
# Documentation: https://man.archlinux.org/search?q=zincsearch
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '-h[show help]' \
  '--version[show version]' \
  '-v[show version]' && ret=0

return ret
