#compdef zincsearch zinc
# Documentation: https://github.com/zincsearch/zincsearch
# Reference accessed: 2026-05-21
# Verified: upstream cmd/zincsearch/main.go only checks os.Args[1] == "version".
# STUB: ZincSearch binary takes no CLI flags; only a single positional
#   "version" subcommand exists. All other config is via environment
#   variables (ZINC_*) or config file.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1::subcommand:(version)' && ret=0

return ret
