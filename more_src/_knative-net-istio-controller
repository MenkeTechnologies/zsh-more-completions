#compdef knative-net-istio-controller
# _knative-net-istio-controller — Knative Serving Istio ingress integration controller (sharedmain)
# upstream: https://github.com/knative-extensions/net-istio
# Flags from cmd/controller/main.go + knative.dev/pkg sharedmain on tip.

_knative-net-istio-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-net-istio-controller "$@"
