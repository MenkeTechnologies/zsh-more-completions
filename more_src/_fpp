#compdef fpp

_arguments \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '-r[run command on selected files]:command' \
  '-c[command to execute]:command' \
  '--non-interactive[run in non-interactive mode]' \
  '(-nfc --no-file-checks)'{-nfc,--no-file-checks}'[do not check if files exist]' \
  '(-ko --keep-open)'{-ko,--keep-open}'[keep PathPicker open after executing command]' \
  '(-ai --all-input)'{-ai,--all-input}'[consider all input as candidate paths]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-ni --no-input)'{-ni,--no-input}'[do not read from stdin]'
