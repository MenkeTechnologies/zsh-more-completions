#compdef nnUNetv2_find_best_configuration
# Documentation: https://github.com/MIC-DKFZ/nnUNet/blob/master/documentation/how_to_use_nnunet.md
# nnU-Net v2 automatic best configuration and ensemble selection

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*-c[configurations to evaluate]:configuration:(2d 3d_fullres 3d_lowres 3d_cascade_fullres)' \
  '--disable_ensembling[do not test ensemble combinations]' \
  '*:dataset name or id:' && ret=0

return ret
