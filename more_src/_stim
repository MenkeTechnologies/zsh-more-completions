#compdef stim sinter
# _stim — Craig Gidney Stim and Sinter fast Clifford circuit simulator and decoder for quantum error correction (quantumlib team, C++/Python); custom argparse
# upstream: https://github.com/quantumlib/Stim

_stim() {
    local -a sub=(
        'sample:sample shots from a stim circuit'
        'detect:detect events from circuit'
        'measure:measure circuit observables'
        'analyze_errors:analyze a noisy circuit'
        'gen:generate a circuit from spec'
        'diagram:render a circuit as 3D ASCII or SVG'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--in=+[input file]:file:_files -g "*.stim *.txt"' \
        '--out=+[output file]:file:_files' \
        '--in_format=+[format]:f:(01 b8 dets hits r8 ptb64)' \
        '--out_format=+[format]:f:(01 b8 dets hits r8 ptb64)' \
        '--shots=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--measure_few_qubits[measure few qubits]' \
        '--frame_sampling[frame sampling]' \
        '--num_distinct_noise_locations=+[N]:n:' \
        '--num_distinct_anti_commutations=+[N]:n:' \
        '--circuit=+[circuit file]:file:_files' \
        '--reference_sample=+[file]:file:_files' \
        '--allow_gauge_detectors[allow gauge detectors]' \
        '--block_decompose_from_pauli_strings[block decompose]' \
        '--decompose_errors[decompose errors]' \
        '--fold_loops[fold loops]' \
        '--approximate_disjoint_errors=+[F]:f:' \
        '--ignore_decomposition_failures[ignore decomp failures]' \
        '--include_gauge_detectors[include gauge]' \
        '--analyze_errors_decompose_errors[decompose errors]' \
        '--analyze_errors_fold_loops[fold loops]' \
        '--code=+[code]:c:(repetition_code surface_code color_code)' \
        '--task=+[task]:t:(memory_x memory_z rotated_memory_x rotated_memory_z unrotated_memory_x unrotated_memory_z)' \
        '--distance=+[N]:n:' \
        '--rounds=+[N]:n:' \
        '--after_clifford_depolarization=+[F]:f:' \
        '--after_reset_flip_probability=+[F]:f:' \
        '--before_measure_flip_probability=+[F]:f:' \
        '--before_round_data_depolarization=+[F]:f:' \
        '--type=+[diagram type]:t:(timeline-svg timeline-text time-slice-svg detector-slice-svg detslice-svg interactive matchgraph-svg time-slice-svg-pretty interactive-html match-graph-svg)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stim subcommand' sub ;;
    esac
}

_stim "$@"
