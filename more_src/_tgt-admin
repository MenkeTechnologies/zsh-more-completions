#compdef tgt-admin
# Documentation: https://man.archlinux.org/search?q=tgt-admin
# Reference accessed: 2026-05-16

# tgt-admin: Linux iSCSI target administration wrapper around tgtadm
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '-e[execute config (push to running target)]' \
  '--execute[execute config (push to running target)]' \
  '-d[delete target]:target:' \
  '--delete=[delete target]:target:' \
  '-s[show targets]' \
  '--show[show targets]' \
  '-c[config file]:file:_files' \
  '--conf=[config file]:file:_files' \
  '--offline=[take target offline]:target:' \
  '--ready=[bring target online]:target:' \
  '--update[update connected initiators]:target:' \
  '--force[force operation]' \
  '--ignore-errors[continue on error]' \
  '-C[control port]:port:' \
  '--control-port=[control port]:port:' \
  '--dump[dump current config]' \
  '-v[verbose]' \
  '*::tgt-admin args:_files' && ret=0
return ret
