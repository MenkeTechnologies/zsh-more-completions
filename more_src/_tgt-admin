#compdef tgt-admin
# Documentation: https://manpages.debian.org/bookworm/tgt/tgt-admin.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# tgt-admin: Linux iSCSI target administration wrapper around tgtadm
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-e --execute)'{-e,--execute}'[read config and execute tgtadm commands]' \
  '(-d --delete)'{-d,--delete}'+[delete target]:target:' \
  '--offline=[take target offline]:target:' \
  '--ready=[bring target ready]:target:' \
  '--update=[update target]:target:' \
  '(-s --show)'{-s,--show}'[show all targets]' \
  '(-C --control-port)'{-C,--control-port}'+[control port]:port:' \
  '(-c --conf)'{-c,--conf}'+[alternate config file]:file:_files' \
  '--ignore-errors[continue on tgtadm failures]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-p --pretend)'{-p,--pretend}'[preview commands without executing]' \
  '--dump[output current tgtd configuration]' \
  '(-v --verbose)'{-v,--verbose}'[verbose command output]' \
  '*::tgt-admin args:_files' && ret=0
return ret
