#compdef tgt-admin

# tgt-admin: Linux SCSI target framework management (Perl wrapper around tgtadm)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-e --execute)'{-e,--execute}'[execute targets.conf]' \
  '(-d --delete)'{-d,--delete=}'[delete target by tid or "ALL"]:tid:' \
  '(-s --show)'{-s,--show}'[show current target config]' \
  '(-C --control-port)'{-C,--control-port=}'[control port]:port:' \
  '--update=[update existing target]:tid:' \
  '--offline=[take target offline]:tid:' \
  '--ready=[take target ready]:tid:' \
  '--dump[dump current config in targets.conf format]' \
  '-c[config file (default /etc/tgt/targets.conf)]:file:_files' \
  '-f[force operation]' \
  '-p[control port]:port:' \
  '--ignore-errors[continue past errors]' \
  '--no-bs-poll[do not poll backing store]' \
  '--pretend[show what would happen]' \
  '*::tgt-admin args:_files' && ret=0
return ret
