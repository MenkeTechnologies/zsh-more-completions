#compdef linuxsampler

# linuxsampler: standalone software sampler engine (LSCP control protocol)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '--lscp-addr=[LSCP listen address]:host:' \
  '--lscp-port=[LSCP listen port]:port:' \
  '--instruments-db-location=[instruments DB file]:file:_files' \
  '--instruments-db-backend=[DB backend]:backend:(sqlite)' \
  '--create-instruments-db[create new instruments DB]' \
  '--no-stacktrace[no stack trace on crash]' \
  '--profile[profiling mode]' \
  '--statistics[show runtime statistics]' \
  '--detach[run as daemon]' \
  '*::linuxsampler args:_files' && ret=0
return ret
