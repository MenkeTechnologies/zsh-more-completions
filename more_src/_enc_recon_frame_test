#compdef enc_recon_frame_test
# Documentation: https://man.archlinux.org/search?q=enc_recon_frame_test
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:encoder:' \
  '3:encoder options:' \
  '4::max frame count:' \
  '5::thread count:' \
  '6::thread type:' && ret=0

return ret
