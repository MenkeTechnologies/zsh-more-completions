#compdef fortio

# Zsh completion for fortio (load testing tool)

local curcontext="$curcontext" state line ret=1

_fortio_load_flags() {
  _arguments -s \
    '-qps[queries per second rate]:rate' \
    '-t[duration of the test]:duration' \
    '-n[number of requests]:count' \
    '-c[number of connections]:connections' \
    '-p[payload file]:file:_files' \
    '-payload[payload string]:string' \
    '-content-type[content type]:type' \
    '*-H[add header]:header' \
    '-keepalive[use keepalive]' \
    '-compression[enable compression]' \
    '-timeout[request timeout]:duration' \
    '-r[resolution of histogram]:resolution' \
    '-json[output JSON result to file]:file:_files' \
    '-labels[labels for the run]:string' \
    '-allow-initial-errors[allow initial errors]' \
    '-abort-on[abort on HTTP code]:code' \
    '-a[automatically save JSON result]' \
    '-loglevel[log level]:level:(verbose info warning error critical fatal)' \
    '-stdclient[use standard Go HTTP client]' \
    '-http1.0[use HTTP 1.0]' \
    '-http1.1[use HTTP 1.1]' \
    '-https-insecure[skip TLS verification]' \
    '-cert[TLS certificate file]:file:_files' \
    '-key[TLS key file]:file:_files' \
    '-cacert[CA certificate file]:file:_files' \
    '-resolve[resolve host\:port to addr]:host\:port\:addr' \
    '-payload-size[payload size in bytes]:bytes' \
    '-uniform[use uniform distribution for jitter]' \
    '-jitter[add jitter]' \
    '(- *)--help[show help]' \
    '*:url' && ret=0
}

_fortio_server_flags() {
  _arguments -s \
    '-http-port[HTTP port]:port' \
    '-grpc-port[gRPC port]:port' \
    '-redirect-port[redirect port]:port' \
    '-echo-server-default-params[default echo server params]:params' \
    '-cert[TLS certificate file]:file:_files' \
    '-key[TLS key file]:file:_files' \
    '(- *)--help[show help]' && ret=0
}

_fortio_curl_flags() {
  _arguments -s \
    '*-H[add header]:header' \
    '-content-type[content type]:type' \
    '-payload[payload string]:string' \
    '-p[payload file]:file:_files' \
    '-keepalive[use keepalive]' \
    '-timeout[request timeout]:duration' \
    '-https-insecure[skip TLS verification]' \
    '-cert[TLS certificate file]:file:_files' \
    '-key[TLS key file]:file:_files' \
    '-cacert[CA certificate file]:file:_files' \
    '-loglevel[log level]:level:(verbose info warning error critical fatal)' \
    '(- *)--help[show help]' \
    '*:url' && ret=0
}

_fortio() {
  local -a commands=(
    'load:run load test'
    'server:start echo/proxy server'
    'grpcping:ping gRPC server'
    'redirect:start redirect server'
    'report:generate report from JSON'
    'curl:single request like curl'
    'nc:netcat like connection'
  )

  _arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'fortio command' commands && ret=0
      ;;
    args)
      case $words[1] in
        load)
          _fortio_load_flags
          ;;
        server)
          _fortio_server_flags
          ;;
        curl)
          _fortio_curl_flags
          ;;
        *)
          _arguments '(- *)--help[show help]' '*:arguments'
          ;;
      esac
      ;;
  esac

  return ret
}

_fortio "$@"
