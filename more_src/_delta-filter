#compdef delta-filter
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/delta-filter.1.html
# filter a MUMmer delta alignment file

local ret=1

_arguments -s -S \
  '-h[display help information]' \
  '-1[1-to-1 alignment allowing for rearrangements]' \
  '-g[1-to-1 global alignment not allowing rearrangements]' \
  '-m[many-to-many alignment allowing for rearrangements]' \
  '-q[map each query position to its best reference hit]' \
  '-r[map each reference position to its best query hit]' \
  '-b[map duplications (XOR of -r and -q alignments)]' \
  '-i+[set the minimum alignment identity 0-100 (default 0)]:identity:' \
  '-l+[set the minimum alignment length (default 0)]:length:' \
  '-u+[set the minimum alignment uniqueness 0-100 (default 0)]:uniqueness:' \
  '-o+[set the maximum alignment overlap 0-100 (default 100)]:overlap:' \
  '-v[print the discarded alignments instead of those that pass]' \
  '*:delta file:_files' && ret=0

return ret
