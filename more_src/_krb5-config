#compdef krb5-config
# _krb5-config — MIT Kerberos Consortium krb5-config print compilation flags for Kerberos library users (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_krb5-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--all[show all configuration]' \
        '--version[show version]' \
        '--vendor[show vendor]' \
        '--prefix[show install prefix]' \
        '--exec-prefix[show exec prefix]' \
        '--cflags[show compilation flags]' \
        '--libs[show linking flags]' \
        '--defccname[show default credentials cache name]' \
        '--defktname[show default keytab name]' \
        '--defcktname[show default client keytab name]' \
        '*:library:(krb5 gssapi kadm-client kadm-server kdb)'
}

_krb5-config "$@"
