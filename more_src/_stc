#compdef stc
# Documentation: https://github.com/tenox7/stc
# stc: Syncthing command line status tool

local ret=1

_arguments -s \
  '--apikey=[Syncthing API key for authentication]:key' \
  '--target=[URL endpoint of the Syncthing service]:url' \
  '--homedir=[path to Syncthing home dir for autodiscovery]:dir:_files -/' \
  '--ignore_cert_errors[suppress TLS certificate validation errors]' \
  '--since=[limit quantity of items when returning lists]:id' \
  '--limit=[starting ID when returning lists]:id' \
  '*:command:(log restart json_dump events)' && ret=0

return ret
