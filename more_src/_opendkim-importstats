#compdef opendkim-importstats
# Documentation: https://man.archlinux.org/search?q=opendkim-importstats
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:arg:_files' && ret=0

return ret
