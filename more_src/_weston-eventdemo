#compdef weston-eventdemo
# _weston-eventdemo — Weston Wayland weston-eventdemo CLI demo client printing keyboard pointer touch tablet axis events focus enter leave button motion from the weston compositor wl_seat to stdout for input subsystem diagnostic verification of devices keymap layouts in development (Weston team, C); getopt
# upstream: https://gitlab.freedesktop.org/wayland/weston

_weston-eventdemo() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-w+[width]:n:' \
        '--width=+[w]:n:' \
        '-h+[height]:n:' \
        '--height=+[h]:n:' \
        '-n[no info]' \
        '--no-info[no info]' \
        '--pointer[print pointer events]' \
        '--keyboard[print keyboard events]' \
        '--touch[print touch events]' \
        '--no-output[no output]' \
        '*::'
}

_weston-eventdemo "$@"
