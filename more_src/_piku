#compdef piku
# Documentation: https://man.archlinux.org/search?q=piku
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'apps:list deployed apps'
  'config:show config for app'
  'config:get:get config value'
  'config:set:set config values'
  'config:unset:unset config values'
  'config:live:show live config'
  'deploy:deploy app'
  'destroy:destroy app'
  'logs:tail logs'
  'ps:show processes'
  'ps:scale:scale workers'
  'restart:restart app'
  'run:run command'
  'setup:initial setup'
  'setup:ssh:add SSH key'
  'stop:stop app'
  'scp:scp passthrough'
  'help:show help'
  'update:update piku'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'piku subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (setup:ssh) _arguments '*:public key:_files' && ret=0 ;;
      (apps|setup|update|help) ret=0 ;;
      (*) _arguments '*:app:' && ret=0 ;;
    esac
    ;;
esac

return ret
