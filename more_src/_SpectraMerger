#compdef SpectraMerger
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: merge spectra from an MS run

local ret=1

_arguments -s -S \
  '-in[input mzML file]:input file:_files' \
  '-out[output mzML file with merged spectra]:output file:_files' \
  '-merging_method[approach for spectrum combination]:method:(average_gaussian average_tophat precursor_method block_method)' \
  '-algorithm:mz_binning_width[minimum m/z distance for distinct data points]:value:' \
  '-algorithm:mz_binning_width_unit[unit for m/z distance]:unit:(Da ppm)' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
