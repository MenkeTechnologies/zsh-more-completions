#compdef corteca
# Documentation: https://man.archlinux.org/search?q=corteca
# Reference accessed: 2026-05-16

# Nokia corteca-cli — Go CLI for Corteca toolkit (https://github.com/nokia/corteca-cli). Typical verbs: init, build, deploy, publish.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'init:bootstrap Corteca application scaffold'
  'build:build container application bundle'
  'deploy:deploy to device profile'
  'publish:publish artifact to registry'
  'doctor:check toolchain prerequisites'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'corteca command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
