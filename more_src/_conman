#compdef conman
# _conman — LLNL ConMan console-management client; multiplexes serial-console connections through conmand
# upstream: https://github.com/dun/conman

_conman() {
    _arguments \
        '-h+[conmand host[:port]]:host:_hosts' \
        '-d+[conmand host[:port]]:host:_hosts' \
        '-e+[escape character]:char:' \
        '-q[query console list]' \
        '-m[monitor (read-only) mode]' \
        '-j[join existing session]' \
        '-f[force takeover (broadcast write)]' \
        '-F+[regex filter file]:file:_files' \
        '-r[search regex]:regex:' \
        '-l+[log file]:log:_files' \
        '-Q[quiet]' \
        '-v[verbose]' \
        '-V[show version]' \
        '*:console name:'
}

_conman "$@"
