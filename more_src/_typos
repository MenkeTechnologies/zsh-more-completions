#compdef typos

# Zsh completion for typos - source code spell checker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config}'[custom config file]:file:_files' \
  '--isolated[ignore implicit configuration files]' \
  '--diff[print a diff of what would change]' \
  '(-w --write-changes)'{-w,--write-changes}'[write fixes to files]' \
  '--force-exclude[respect excluded paths even for paths passed explicitly]' \
  '--format[output format]:format:(brief long json)' \
  '*'{-e,--exclude}'[glob pattern to exclude]:pattern' \
  '--hidden[search hidden files and directories]' \
  '--no-ignore[do not respect ignore files]' \
  '--locale[language locale]:locale:(en en-us en-gb en-au en-ca)' \
  '--type-list[list available file types]' \
  '--dump-config[dump effective config]' \
  '*'{-t,--type}'[only check files of specified type]:type' \
  '(-j --threads)'{-j,--threads}'[number of threads]:threads' \
  '--color[control when to use color]:when:(auto always never)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:path:_files' && ret=0

return ret
