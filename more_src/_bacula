#compdef bacula
# _bacula — Bacula network backup and recovery system CLI alias (bacula team, C++); custom argparse
# upstream: https://github.com/bacula/bacula

_bacula() {
    local -a sub=(
        'bconsole:bacula console'
        'bacula-dir:director daemon'
        'bacula-fd:file daemon'
        'bacula-sd:storage daemon'
        'bcopy:copy bacula volume'
        'bextract:extract from bacula volume'
        'bls:list bacula volume contents'
        'bscan:scan bacula volume'
        'bsmtp:bacula mail client'
        'btraceback:bacula traceback'
        'btape:test bacula tape'
        'dbcheck:check catalog database'
        'mtx-changer:tape changer script'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d+[debug level]:n:' \
        '-T[set traceback]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bacula subcommand' sub ;;
        args)
            case $words[1] in
                bconsole) _arguments \
                    '-c+[config file]:file:_files -g "bconsole.conf"' \
                    '-D+[director]:str:' \
                    '-l[list directors]' \
                    '-n[no conio]' \
                    '-s[no signals]' \
                    '-u+[timeout]:n:' \
                    '-t[test config]' ;;
                bacula-dir|bacula-fd|bacula-sd) _arguments \
                    '-c+[config file]:file:_files' \
                    '-d+[debug level]:n:' \
                    '-f[foreground]' \
                    '-g+[group]:_groups' \
                    '-m[mark debug]' \
                    '-r+[runjob]:str:' \
                    '-s[no signals]' \
                    '-t[test config]' \
                    '-u+[user]:_users' \
                    '-v[verbose]' ;;
                bls|bextract|bcopy|bscan|btape) _arguments \
                    '-c+[config file]:file:_files' \
                    '-d+[debug level]:n:' \
                    '-V+[volumes]:str:' \
                    '*:device or path:_files' ;;
            esac
            ;;
    esac
}

_bacula "$@"
