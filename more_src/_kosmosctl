#compdef kosmosctl
# Documentation: https://kosmos-io.github.io/kosmos-website/docs/getting-started/quick-start
# kosmosctl - deploy Kosmos components, add member clusters, and test network connectivity

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--cni=[CNI plugin to use (e.g. calico)]:cni' \
  '--default-nic=[network interface used to build the network tunnel]:nic' \
  '--name=[cluster name]:name' \
  '--enable-all[enable all features for the cluster]' \
  '1:command:(get install uninstall join unjoin logs check analysis import export image)' \
  '*::arg:->args' && ret=0

return ret
