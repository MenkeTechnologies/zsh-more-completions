#compdef gpick
# Documentation: https://www.mankier.com/1/gpick
# gpick - advanced color picker

local ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[print version information]' \
  '(-g --geometry)'{-g,--geometry}'[window geometry]:geometry:' \
  '(-p --pick)'{-p,--pick}'[enable color picking mode that stays running in the background]' \
  '(-s --single)'{-s,--single}'[pick one color and exit]' \
  '(-o --output)'{-o,--output}'[output picked color]' \
  '(-c --converter-name)'{-c,--converter-name}'[color format converter for floating picker mode]:converter:(color_web_hex color_css_rgb color_css_hsl)' \
  '--no-newline[output picked color without newline]' \
  '--no-start[do not start if not running already]' \
  '*:file:_files' && ret=0

return ret
