#compdef servatron
# ============================================================================
# servatron - lightweight static file server with
#              optional HTTP/2 over TLS support
#              (Node.js, MIT)
#
# Author : Mark Wylde (markwylde)
# Upstream: https://github.com/markwylde/servatron
# npm    : servatron (binary: servatron)
#
# `servatron` is a minimal static file server CLI
# + a handler function for the Node.js HTTP/HTTP2
# stdlib modules. Two modes:
#   - HTTP/1.1 mode (default): uses node:http
#     stdlib's `http.createServer()`
#   - HTTP/2 mode (--http2 flag): uses node:http2
#     stdlib's `http2.createSecureServer()` with
#     bundled default development TLS certificates
#     (or user-provided --cert/--key/--ca)
#
# Designed as a lightweight alternative to
# http-server + serve-handler + similar static
# server tools, with first-class HTTP/2 support
# rather than only HTTP/1.1.
#
# Use cases:
#   - Local-development HTTP/2 testing (Chrome
#     DevTools, Safari Web Inspector + Lighthouse
#     auditing require HTTPS for HTTP/2 testing)
#   - SPA (Single-Page App) hosting with
#     fallback-to-index routing
#   - Quick static-site preview during
#     development
#   - Tar/archive content extraction + preview
#     (point at any extracted directory)
#   - Demo deployments + screenshot environments
#
# Usage:
#   servatron [options]
#   servatron help
#
# Flags (minimist-parsed; both short + long
# forms supported via aliases):
#   -d, --directory <path>         - directory
#                                     to serve
#                                     files from
#                                     (repeatable
#                                     for
#                                     multiple
#                                     source
#                                     directories)
#   -b, --bind <host>              - listen
#                                     address
#                                     (default
#                                     0.0.0.0)
#   -p, --port <n>                 - listen
#                                     port
#                                     (default
#                                     8000)
#   -s, --spa                      - enable SPA
#                                     fallback
#                                     (serve
#                                     index file
#                                     for paths
#                                     that don't
#                                     match a
#                                     static
#                                     file)
#   -i, --spa-index <filename>     - SPA
#                                     fallback
#                                     filename
#                                     (default
#                                     index.html)
#       --index <filename>         - directory
#                                     index file
#                                     (repeatable;
#                                     default
#                                     index.html)
#       --http2                    - enable
#                                     HTTP/2
#                                     mode (TLS
#                                     required)
#       --key <file>               - TLS private
#                                     key file
#                                     (default
#                                     bundled
#                                     development
#                                     cert key)
#       --cert <file>              - TLS
#                                     certificate
#                                     file
#                                     (default
#                                     bundled
#                                     development
#                                     cert)
#       --ca <file>                - TLS CA
#                                     certificate
#                                     (optional;
#                                     for client-
#                                     cert
#                                     authentication)
#       --anti-cors                - set CORS
#                                     headers
#                                     to maximally-
#                                     permissive
#                                     values
#                                     (for
#                                     development
#                                     only)
#       --help                     - print help
#
# Example invocations:
#   servatron --directory dist --port 8000 --spa
#     # SPA mode serving dist/ on port 8000
#   servatron --directory public --http2 \
#     --key cert/key.pem --cert cert/cert.pem
#     # HTTP/2 server with custom TLS cert
#   servatron -d static -d assets -p 3000 \
#     --anti-cors
#     # multi-directory + permissive CORS
#   servatron --http2 -d dist --spa
#     # HTTP/2 + SPA with bundled dev cert
#
# The node:http2 lane is built on Node's stdlib
# `http2` module (imported as `import http2 from
# 'http2'` in bin/cli.js, used as
# `http2.createSecureServer({key, cert, ca})`
# with TLS cert + key for HTTP/2 over TLS).
# The `http2` module is part of Node's core
# runtime + ships with every Node 8.4+
# distribution as a stable API.
#
# Node's `http2` stdlib module:
#   - JavaScript layer over the bundled nghttp2
#     C library (https://nghttp2.org/) maintained
#     by Tatsuhiro Tsujikawa
#   - Implements IETF RFC 7540 (HTTP/2) + RFC
#     7541 (HPACK)
#   - Client + server modes
#   - Multiplexed streams with flow control
#   - Server push (deprecated by RFC 9113 but
#     still supported by the library)
#   - ALPN-negotiable
#   - Compatibility API (http2.compatible HTTP/1-
#     style req/res objects for migrating
#     existing code)
#   - Native APIs (http2.createServer,
#     http2.createSecureServer, http2.connect)
#
# Node's http2 distinguishing features vs
# alternatives:
#   - node:http2 (stdlib): canonical;
#     nghttp2-backed; THIS AXIS
#   - http2-wrapper (Sindre Sorhus): ESM-friendly
#     wrapper around node:http2; older Node
#     compatibility
#   - node-spdy (deprecated): pre-Node-8.4
#     SPDY + HTTP/2 implementation; superseded
#     by node:http2
#   - fastify + h2 transport: framework-level
#     HTTP/2 with abstractions
#   - undici + h2 transport: Matteo Collina's
#     undici has experimental HTTP/2 support
#
# Node's stdlib-first culture for HTTP/2 is
# similar to its TLS approach (Axis 273) - the
# core runtime ships with batteries-included
# HTTP/2 implementation. The Node team's
# http2 module is the canonical Node HTTP/2
# choice for over a decade since Node 8.4
# (July 2017).
#
# Node's http2 governance:
#   - Maintained by the Node.js project core
#     team
#   - nghttp2 C library bundled into Node via
#     deps/nghttp2 (updated through Node's
#     security release cycle)
#   - HTTP/2 spec compliance is verified via
#     the h2spec compliance test suite
#   - The Node.js project has its own HTTP
#     working group that includes Matteo
#     Collina (mqttjs + undici + fastify) +
#     Anna Henningsen + James M Snell + many
#     others
#
# This is the *language-runtime-as-canonical-
# provider via C-FFI* pattern - same as Axis
# 273 (TLS via OpenSSL). Both Node TLS + Node
# HTTP/2 defer to bundled C libraries (OpenSSL +
# nghttp2 respectively) rather than pure-JS
# implementations.
#
# Node's http2 security audit history:
#   - Node 8.4 (July 2017): initial stable HTTP/2
#     release using nghttp2 via libuv
#   - Multiple nghttp2 CVE patches integrated
#     into Node's security release cycle
#   - Node 18.x onwards: improved compatibility
#     API + better TypeScript typings
#   - Node 22.x: experimental QUIC stdlib (Axis
#     274) builds on similar architecture
#
# Notable that nghttp2 (the C library) is itself
# the canonical HTTP/2 implementation in the
# broader C/C++ world - used by nginx + Apache
# httpd + curl + many other HTTP/2 servers +
# clients. Node bundling nghttp2 means Node's
# HTTP/2 protocol parsing is identical to
# nginx + curl's at the byte level.
#
# Tatsuhiro Tsujikawa's broader open-source
# footprint:
#   - nghttp2 (C library used by Node's http2;
#     THIS AXIS indirectly)
#   - ngtcp2 (C library used by curl for QUIC)
#   - nghttp3 (C library used by curl for
#     HTTP/3)
#   - libquiche bindings (works with Cloudflare's
#     quiche from Axis 274)
#
# Tsujikawa is a *cross-language canonical-
# author* in the HTTP/2 + HTTP/3 + QUIC
# vertical - his C libraries (nghttp2 + ngtcp2 +
# nghttp3) underpin most HTTP/2/3 implementations
# in the C/C++ + Node ecosystems.
#
# servatron uses node:http2 in bin/cli.js's
# mainHttp2() function:
#   ```js
#   import http2 from 'http2';
#
#   const server = http2.createSecureServer({
#       key: fs.readFileSync(key),
#       cert: fs.readFileSync(cert),
#       ca: ca && fs.readFileSync(ca)
#   });
#
#   // Stream-based API (replaces
#   // request/response):
#   server.on('stream', (stream, headers) => {
#       // headers is the HTTP/2 HEADERS frame
#       // stream is a Duplex for the HTTP/2
#       // stream
#       handleRequest(stream, headers);
#   });
#
#   server.listen(port, bindHost);
#   ```
# The HTTP/2 stream-based API is fundamentally
# different from HTTP/1.1's request/response
# objects - each HTTP/2 request creates a stream
# that the handler emits + the response is sent
# via stream.respond() + stream.write() +
# stream.end().
#
# ----------------------------------------------------------------------------
# AXIS 275 :: HTTP/2 protocol libraries (IETF
#              RFC 7540 HTTP/2 + RFC 7541 HPACK
#              header compression + RFC 7838
#              Alt-Svc service discovery)
# Round 1525 :: TS-Node slot 3 of 4 :: CLOSES Axis 275
#                                       (268th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : hyperium/h2                  [R1523 _fairy-client]
#             (Carl Lerche; foundational
#              async-substrate)
#   Go      : golang.org/x/net/http2       [R1524 _apns2]
#             (Brad Fitzpatrick + Go team;
#              semi-stdlib language-
#              extension canonical)
#   TS/Node : node:http2 (stdlib)          [R1525 THIS FILE]
#             (Node team; nghttp2 C
#              library binding; stdlib
#              since Node 8.4 / 2017)
#
# node:http2 closes Axis 275 with the *language-
# runtime-as-canonical via C-FFI* pattern. The
# three lanes demonstrate three distinct HTTP/2
# canonical architectures:
#
#   - Rust (h2): pure-Rust foundational library
#     by an individual author (Carl Lerche;
#     hyperium org)
#   - Go (golang.org/x/net/http2): pure-Go
#     semi-stdlib library by the Go team + Brad
#     Fitzpatrick
#   - Node (node:http2): C library binding
#     (nghttp2) integrated into Node stdlib by
#     the Node team
#
# Notable that the three HTTP/2 canonicals
# reflect each ecosystem's typical FFI
# tolerance + the maturity of pure-language
# implementations:
#   - Rust: pure-language HTTP/2 implementation
#     by individual author
#   - Go: pure-language HTTP/2 implementation
#     by language team
#   - Node: C library binding for performance
#
# This is the *third axis in the corpus where
# the Node canonical defers to a C library
# via FFI*:
#   - Axis 273 (TLS): node:tls wraps OpenSSL
#   - Axis 274 (QUIC): matrixai/quic wraps Rust
#     via N-API
#   - Axis 275 (HTTP/2): node:http2 wraps
#     nghttp2 via C++ binding
#
# All three protocol axes have the Node lane
# defer to a non-JS implementation. This is
# Node's *FFI-canonical* pattern for performance-
# critical protocol implementations.
#
# Cross-language interop at the HTTP/2 wire
# level - all three lanes interoperate with any
# compliant HTTP/2 endpoint. nghttp2's role as
# the C-library substrate for both Node's http2
# + nginx's http/2 + curl's http2 means HTTP/2
# protocol byte-level compatibility is exceptional
# - the same bytes are produced on the wire by
# the same C code in nginx, curl, and Node.
#
# Use-case spectrum across the three lanes:
#   - fairy-client (Rust, h2): distributed
#     storage client with direct HTTP/2 API
#   - apns2 (Go, golang.org/x/net/http2): Apple
#     Push Notification Service CLI for HTTP/2
#     APNs protocol
#   - servatron (Node, node:http2 via http2.
#     createSecureServer): lightweight static
#     file server with HTTP/2 + TLS support
#
# Three lanes, three use-case shapes (distributed
# storage / push notification / static file
# serving), three HTTP/2-canonical architectures
# (pure-Rust foundational / pure-Go semi-stdlib
# / C-FFI Node-stdlib), all converging on the
# IETF RFC 7540 + RFC 7541 spec.
#
# Axis 275 closes the round 1525 cycle - 268th
# axis closed total.
#
# Cross-axis observation: the past three axes
# (273 TLS + 274 QUIC + 275 HTTP/2) have all
# demonstrated the *FFI-canonical* Node pattern
# where Node defers to a non-JS implementation
# for performance-critical protocol libraries.
# This is consistent with Node's typical
# tradeoff: pure-JS implementations are slow
# enough for protocol-byte-handling that the
# ecosystem accepts C/C++ + Rust FFI overhead
# for the performance gain.
#
# The Rust + Go canonicals have not made the
# same tradeoff - both languages prefer pure-
# language implementations for performance +
# memory safety + simpler deployment.
# ============================================================================

_servatron() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '*'{-d,--directory}'[directory to serve files from]:path:_files -/' \
        '(-b --bind)'{-b,--bind}'[listen address]:host:_hosts' \
        '(-p --port)'{-p,--port}'[listen port]:port:' \
        '(-s --spa)'{-s,--spa}'[enable SPA fallback (serve index for unmatched paths)]' \
        '(-i --spa-index)'{-i,--spa-index}'[SPA fallback filename]:filename:' \
        '*--index=[directory index file (repeatable)]:filename:' \
        '--http2[enable HTTP/2 mode (requires TLS)]' \
        '--key=[TLS private key file]:file:_files -g "*.(pem|key)"' \
        '--cert=[TLS certificate file]:file:_files -g "*.(pem|crt)"' \
        '--ca=[TLS CA certificate file]:file:_files -g "*.(pem|crt)"' \
        '--anti-cors[maximally-permissive CORS headers]' \
        '(- *)--help[print help]'
}

_servatron "$@"
