#compdef yadm

# Zsh completion for yadm - Yet Another Dotfiles Manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'add:Add file contents to the index'
  'alt:Create links and process templates'
  'bootstrap:Execute the configured bootstrap command'
  'checkout:Switch branches or restore working tree files'
  'clone:Clone an existing yadm repository'
  'commit:Record changes to the repository'
  'config:Get and set repository or global options'
  'decrypt:Decrypt files'
  'diff:Show changes between commits, commit and working tree, etc.'
  'encrypt:Encrypt files'
  'enter:Run a sub-shell with yadm environment set'
  'fetch:Download objects and refs from another repository'
  'gitconfig:Run git config on the yadm managed repo'
  'help:Display help information'
  'init:Initialize an empty yadm repository'
  'introspect:Report internal yadm data'
  'list:List tracked files'
  'log:Show commit logs'
  'merge:Join two or more development histories together'
  'pull:Fetch from and integrate with another repository'
  'push:Update remote refs along with associated objects'
  'remote:Manage set of tracked repositories'
  'rebase:Reapply commits on top of another base tip'
  'reset:Reset current HEAD to the specified state'
  'restore:Restore working tree files'
  'rm:Remove files from the working tree and from the index'
  'show:Show various types of objects'
  'stash:Stash the changes in a dirty working directory'
  'status:Show the working tree status'
  'submodule:Initialize, update or inspect submodules'
  'tag:Create, list, delete or verify a tag object'
  'transcrypt:Configure transparent encryption'
  'upgrade:Upgrade yadm repository to latest format'
  'version:Display the current yadm version'
)

_arguments -s -S \
  '--yadm-archive[override path to archive file]:file:_files' \
  '--yadm-bootstrap[override path to bootstrap file]:file:_files' \
  '--yadm-cipher[override cipher used for symmetric encryption]:cipher:' \
  '--yadm-dir[override the yadm directory]:dir:_files -/' \
  '--yadm-data[override the yadm data directory]:dir:_files -/' \
  '--yadm-encrypt[override path to encrypt file]:file:_files' \
  '--yadm-git[override path to git program]:path:_files' \
  '--yadm-repo[override path to yadm repository]:path:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      add|rm|checkout|diff|reset|restore|status)
        _arguments '*:tracked file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
