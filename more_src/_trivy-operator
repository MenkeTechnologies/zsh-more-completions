#compdef trivy-operator

# trivy-operator: Kubernetes-native Trivy security scanner controller
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--leader-elect[enable leader election]' \
  '--target-workloads=[target workloads]:list:' \
  '--vulnerability-scanner-enabled=[enable vuln scanner]:bool:(true false)' \
  '--config-audit-scanner-enabled=[enable config audit scanner]:bool:(true false)' \
  '--cluster-compliance-enabled=[enable cluster compliance]:bool:(true false)' \
  '--exposed-secret-scanner-enabled=[enable secrets scanner]:bool:(true false)' \
  '--rbac-assessment-scanner-enabled=[enable RBAC scanner]:bool:(true false)' \
  '--infra-assessment-scanner-enabled=[enable infra assessment scanner]:bool:(true false)' \
  '--target-namespaces=[target namespaces]:ns:' \
  '--exclude-namespaces=[exclude namespaces]:ns:' \
  '--scan-job-timeout=[scan job timeout]:duration:' \
  '--scan-job-failure-policy=[scan job failure policy]:policy:(retry ignore)' \
  '--operator-namespace=[operator namespace]:ns:' \
  '*::trivy-operator args:_files' && ret=0
return ret
