#compdef acpixtract
# Documentation: man acpixtract(1)
# Source: acpica/acpica source/tools/acpixtract/axmain.c (master) — extract ACPI tables from acpidump (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[extract all tables, not just DSDT/SSDT]' \
    '-f[force extraction even on errors]' \
    '-l[list table summaries only]' \
    '-m[extract DSDT/SSDTs to single file]' \
    '-s+[extract all tables with signature]:sig:_default' \
    '(-v -vd)-v[show version]' \
    '(-v -vd)-vd[show build date]' \
    '1:acpidump output file:_files' \
    && ret=0

return ret
