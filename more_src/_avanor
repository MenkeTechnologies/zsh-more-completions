#compdef avanor
# Documentation: https://man.archlinux.org/search?q=avanor
# Reference accessed: 2026-05-16

# Zsh completion for avanor
# Upstream: Quick-growing roguelike game with easy ADOM-like UI
# Conservative fallback — run `avanor --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
