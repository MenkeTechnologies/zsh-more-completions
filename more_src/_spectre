#compdef spectre
# _spectre — Maarten Billemont Spectre stateless password manager that derives site passwords from a master key (lyndir team, C); custom argparse
# upstream: https://github.com/lyndir/Spectre

_spectre() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-u+[full name]:str:' \
        '--user=+[full name]:str:' \
        '-U+[master password]:str:' \
        '--master=+[master password]:str:' \
        '-m+[master password]:str:' \
        '-M+[master key id]:str:' \
        '-t+[password type]:t:(maximum long medium basic short pin name phrase x max l m b s i n p)' \
        '--type=+[password type]:t:(maximum long medium basic short pin name phrase x max l m b s i n p)' \
        '-c+[counter]:n:' \
        '--counter=+[counter]:n:' \
        '-a+[algorithm version]:v:(0 1 2 3)' \
        '--algorithm=+[algorithm version]:v:(0 1 2 3)' \
        '-p+[purpose]:p:(authentication identification recovery a i r)' \
        '--purpose=+[purpose]:p:(authentication identification recovery a i r)' \
        '-C+[context]:str:' \
        '--context=+[context]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-Q+[redaction]:r:(true false)' \
        '-f+[format]:f:(none flat json)' \
        '--format=+[format]:f:(none flat json)' \
        '-F+[format]:f:(none flat json)' \
        '-R+[redirect output]:file:_files' \
        '*:site name:'
}

_spectre "$@"
