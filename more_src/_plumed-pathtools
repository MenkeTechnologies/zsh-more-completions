#compdef plumed-pathtools
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/pathtools.html
# plumed pathtools: construct paths from pdb data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--start=[PDB file with the initial frame structure]:file:_files -g "*.pdb"' \
  '--end=[PDB file with the final frame structure]:file:_files -g "*.pdb"' \
  '--path=[PDB file with an initial path]:file:_files -g "*.pdb"' \
  '--out=[filename for the output path]:file:_files' \
  '--metric=[distance measurement method between frames]:metric' \
  '--fixed=[frames to fix when reparameterizing]:frames' \
  '--nframes=[number of frames between start and end]:nframes' \
  '--nframes-before-start=[frames before first frame]:nframes' \
  '--nframes-after-end=[frames after last frame]:nframes' \
  '--tolerance=[convergence tolerance for reparameterization]:tol' \
  '--arg-fmt=[output format for argument values]:fmt' && ret=0

return ret
