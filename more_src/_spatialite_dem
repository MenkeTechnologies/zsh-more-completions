#compdef spatialite_dem
# Documentation: https://www.gaia-gis.it/fossil/spatialite-tools/wiki?name=spatialite_dem
# Reference accessed: 2026-05-16
# Verified: upstream gaia-gis fossil wiki for spatialite_dem. Wiki is
# narrative only; no formal flag specification exists. Only the most
# commonly documented options are listed.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# spatialite_dem: digital elevation model importer for spatialite
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--save_conf[save configuration]' \
  '-import_xyz[import XYZ DEM data]' \
  '-fetch_yx[fetch by Y/X coordinates]' \
  '-updatez[update Z values]' \
  '-sniff[show file format info]' \
  '-v[verbose output]' \
  '*:DEM file:_files' && ret=0
return ret
