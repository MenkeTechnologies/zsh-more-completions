#compdef vlib
# _vlib — Mentor Siemens EDA ModelSim/Questa vlib CLI creating a new logical Verilog/VHDL design library physical directory hierarchy initializing _info file mapping permissions architecture-specific library data structures (Siemens team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/simulation/advanced-simulator/

_vlib() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-modelsimini=+[ini file]:file:_files -g "*.ini"' \
        '-quiet[quiet]' \
        '-archive[archive library]' \
        '-shared[shared library]' \
        '-long[long header]' \
        '-short[short header]' \
        '-type=+[t]:t:(directory archive cdb)' \
        '-relax[relax checks]' \
        '*:library directory:_files -/'
}

_vlib "$@"
