#compdef sdx
# Documentation: https://wiki.tcl-lang.org/page/sdx
# Starkit Developer eXtension: create, browse, and unravel Starkits

local ret=1

_arguments -s \
  '1:command:->cmds' \
  '*::args:_files' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'qwrap:create a starkit from a single Tcl script'
      'wrap:create a starkit from a .vfs directory structure'
      'unwrap:reverse of wrap; dissect a starkit'
      'lsk:list the contents of a starkit'
      'version:calculate the version ID of a starkit'
      'mkpack:copy and optimally pack the Metakit data'
      'mksplit:split a starkit into .head and .tail parts'
      'help:show help for sdx or a command'
    )
    _describe -t commands 'sdx command' cmds && ret=0
    ;;
esac

return ret
