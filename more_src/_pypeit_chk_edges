#compdef pypeit_chk_edges
# Documentation: https://pypeit.readthedocs.io/en/release/scripts.html
# Display trace image and edge traces

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v,--verbosity}'[verbosity level 0, 1, or 2]:level:(0 1 2)' \
  '--log_file=[name for the log file]:file:_files' \
  '--log_level=[verbosity level for the log file]:level' \
  '--slits_file=[PypeIt Slits file for reference]:file:_files' \
  '--mpl[use matplotlib instead of ginga]' \
  '--try_old[attempt loading old datamodel versions]' \
  '*:trace file:_files -g "*.fits.gz"' && ret=0

return ret
