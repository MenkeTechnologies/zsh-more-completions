#compdef unicorn_rails
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/unicorn_rails.1.html
# script/server-like command to launch the Unicorn HTTP server for Rails

local ret=1

_arguments -s -S \
  '(-c --config-file)'{-c+,--config-file=}'[path to Unicorn config file]:config file:_files' \
  '(-D --daemonize)'{-D,--daemonize}'[run daemonized in the background]' \
  '(-E --env)'{-E+,--env=}'[run under the given RAILS_ENV]:env:(development production test)' \
  '(-l --listen)'{-l+,--listen=}'[listen on given address (HOST:PORT or PATH)]:address' \
  '(-N --no-default-middleware)'{-N,--no-default-middleware}'[disable middleware implied by RAILS_ENV]' \
  '(-o --host)'{-o+,--host=}'[listen on a TCP socket belonging to HOST]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[listen on the specified TCP PORT]:port' \
  '(-s --server)'{-s+,--server=}'[no-op, for script/server compatibility]:server' \
  '(-e --eval)'{-e+,--eval=}'[evaluate a LINE of Ruby code]:line' \
  '(-d --debug)'{-d,--debug}'[turn on debug mode, sets $DEBUG to true]' \
  '(-w --warn)'{-w,--warn}'[turn on verbose warnings, sets $VERBOSE to true]' \
  '*'{-I+,--include=}'[specify $LOAD_PATH directory additions]:path:_directories' \
  '*'{-r+,--require=}'[require a specified LIBRARY before execution]:library:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:rackup file:_files' && ret=0

return ret
