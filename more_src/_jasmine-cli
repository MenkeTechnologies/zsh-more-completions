#compdef jasmine-cli
# _jasmine-cli — Pivotal Jasmine BDD JavaScript test framework CLI alias (Pivotal Labs / Jasmine team, JavaScript); custom argparse
# upstream: https://github.com/jasmine/jasmine

_jasmine-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.json"' \
        '--reporter=+[reporter]:str:' \
        '--filter=+[filter]:str:' \
        '--fail-fast[fail fast]' \
        '--seed=+[seed]:n:' \
        '--random=+[random]:b:(true false)' \
        '--require=+[require module]:list:' \
        '--no-color[no color]' \
        '--color[color]' \
        '--parallel[parallel]' \
        '-P[parallel]' \
        '--num-workers=+[num workers]:n:' \
        '--help-output[show output help]' \
        '*:spec-file:_files -g "*Spec.js *.spec.js"'
}

_jasmine-cli "$@"
