#compdef icedove icedove-bin
# Documentation: https://man.archlinux.org/search?q=icedove
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-P+[use named profile]:profile:' \
  '--profile=[explicit profile path]:dir:_files -/' \
  '--no-remote[disable remote connections]' \
  '--new-instance[start a new instance]' \
  '--ProfileManager[show profile manager]' \
  '--compose=[compose new message TO=, SUBJECT=, BODY=]:opts:' \
  '--mail[open mail window]' \
  '--addressbook[open address book]' \
  '--calendar[open calendar]' \
  '--news[open newsgroups]' \
  '*:url_or_file:_files' && ret=0

return ret
