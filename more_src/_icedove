#compdef icedove icedove-bin
# Documentation: https://manpages.debian.org/testing/icedove/icedove.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# icedove: Debian's rebranded Mozilla Thunderbird mail/news client.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-v,-version}'[show version]' \
  '-P+[use named profile (Profile Manager if empty)]:profile:' \
  '-no-remote[disable remote connections]' \
  '-new-instance[start a new instance]' \
  '-compose[start with a message composition window]' \
  '-mail[open mail folder view]' \
  '-news[open newsgroup client]' \
  '-addressbook[open address book]' \
  '-options[open preferences dialog]' \
  '-file[open specified mail file]:file:_files' \
  '-safe-mode[disable extensions; debug mode]' \
  '-jsconsole[start with JavaScript console]' \
  '-migration[start migration wizard]' \
  '-setDefaultMail[set Icedove as system default mail handler]' \
  '-UILocale[set UI language]:locale:' \
  '*:url_or_file:_files' && ret=0

return ret
