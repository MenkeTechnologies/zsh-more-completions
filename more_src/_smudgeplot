#compdef smudgeplot
# Documentation: https://github.com/KamilSJaron/smudgeplot
# Smudgeplot: inference of genome ploidy and structure from k-mer pairs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'smudgeplot subcommand' \
      'hetmers[extract heterozygous k-mer pairs from a k-mer table]' \
      'all[run the full analysis and produce the smudgeplot]' \
      'plot[generate the smudgeplot from k-mer pairs]' \
      'cutoff[suggest coverage cutoffs from a k-mer histogram]' && ret=0
    _files
    ;;
esac

return ret
