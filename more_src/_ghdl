#compdef ghdl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze VHDL source files'
  'elaborate:elaborate a design'
  'run:run a simulation'
  'elab-run:elaborate and run a design'
  'bind:bind a design unit'
  'link:link a design unit'
  'list-link:list object files needed to link'
  'make:analyze and elaborate a design'
  'gen-makefile:generate a Makefile'
  'gen-depends:generate Makefile dependencies'
  'import:import VHDL files'
  'synth:synthesize a design'
  'clean:clean generated files'
  'remove:remove library'
  'copy:copy library'
  'disp-config:display configuration'
  'disp-standard:display standard package'
  'disp-tree:display design tree'
  'find:find a design unit'
  'xref:generate cross-reference'
  'xref-html:generate HTML cross-reference'
  '--version:show version'
  '--help:show help'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-a[analyze]' \
  '-e[elaborate]' \
  '-r[run]' \
  '-s[syntax check only]' \
  '-c[compile and analyze]' \
  '-m[make]' \
  '--std=[VHDL standard]:standard:(87 93 93c 00 02 08 19)' \
  '--ieee=[IEEE library]:library:(synopsys mentor none standard)' \
  '--work=[set work library name]:library name' \
  '--workdir=[set work library directory]:directory:_directories' \
  '-P+[add library search path]:directory:_directories' \
  '-fsynopsys[enable synopsys packages]' \
  '-frelaxed[relaxed rules]' \
  '-frelaxed-rules[relaxed rules]' \
  '-fexplicit[be explicit about overloading]' \
  '-fpsl[enable PSL assertions]' \
  '--warn-[enable warning]:warning:(binding body default-binding delayed-checks error hide library pure-passive others runtime-error shared specs static vital-generic)' \
  '--no-vital-checks[do not check vital compliance]' \
  '-g[generate debug information]' \
  '-O+[optimization level]:level:(0 1 2 3)' \
  '-o+[output file]:output file:_files' \
  '--VCD=[generate VCD output]:VCD file:_files -g "*.vcd"' \
  '--vcdgz=[generate compressed VCD output]:VCD.gz file:_files -g "*.vcd.gz"' \
  '--FST=[generate FST output]:FST file:_files -g "*.fst"' \
  '--GHW=[generate GHW output]:GHW file:_files -g "*.ghw"' \
  '--wave=[set waveform dump file]:wave file:_files' \
  '--stop-time=[stop simulation after time]:time' \
  '--stop-delta=[stop after delta cycles]:cycles' \
  '--assert-level=[assertion failure level]:level:(note warning error failure)' \
  '--disp-time[display simulation time]' \
  '--disp-tree=[display tree]:mode:(none inst port)' \
  '--trace-signals[trace signal activity]' \
  '--trace-processes[trace process activity]' \
  '--stats[display run-time statistics]' \
  '--unbuffered[unbuffered output]' \
  '--sdf=[set SDF file]:SDF config' \
  '*:VHDL file:_files -g "*.(vhd|vhdl)"' && ret=0

return ret
