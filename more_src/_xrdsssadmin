#compdef xrdsssadmin
# Documentation: https://man.archlinux.org/search?q=xrdsssadmin
# Reference accessed: 2026-05-16

# xrdsssadmin: xrootd SSS key admin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-k[keyfile]:file:_files' \
  '*:action:(add del list export import)' && ret=0
return ret
