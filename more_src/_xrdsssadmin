#compdef xrdsssadmin
# Documentation: https://manpages.opensuse.org/Leap-15.6/xrootd-server/xrdsssadmin.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# xrdsssadmin: xrootd SSS key admin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-k[keyfile]:file:_files' \
  '*:action:(add del list export import)' && ret=0
return ret
