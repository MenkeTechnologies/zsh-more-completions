#compdef flarestrings
# Documentation: https://github.com/fireeye/stringsifter
# flarestrings - StringSifter strings extractor (GNU strings-like)

local ret=1

_arguments -s -S \
  '(-n --min-len)'{-n,--min-len}'=[print sequences at least N characters long]:len' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file:_files' && ret=0

return ret
