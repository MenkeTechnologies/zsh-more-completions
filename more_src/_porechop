#compdef porechop
# Documentation: https://github.com/rrwick/Porechop
# adapter trimmer for Oxford Nanopore reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show program version]' \
  '(-i --input)'{-i,--input}'[FASTA/FASTQ input file or directory]:input:_files' \
  '(-o --output)'{-o,--output}'[output filename for trimmed reads]:output:_files' \
  '--format[output format]:format:(auto fasta fastq fasta.gz fastq.gz)' \
  '(-v --verbosity)'{-v,--verbosity}'[progress output level]:level:(0 1 2 3)' \
  '(-t --threads)'{-t,--threads}'[number of threads for adapter alignment]:threads:' \
  '(-b --barcode_dir)'{-b,--barcode_dir}'[directory for barcode-binned output]:dir:_files -/' \
  '--barcode_threshold[minimum identity to assign reads to barcodes]:percent:' \
  '--barcode_diff[minimum difference between top two barcode matches]:diff:' \
  '--require_two_barcodes[require strong barcode matches at both ends]' \
  '--untrimmed[bin reads without trimming them]' \
  '--discard_unassigned[discard reads not assigned to any barcode]' \
  '--adapter_threshold[minimum identity to identify adapter sets]:percent:' \
  '--check_reads[number of reads to scan for adapter detection]:count:' \
  '--scoring_scheme[alignment scores match,mismatch,gap open,gap extend]:scheme:' \
  '--end_size[base pairs to search at each read terminus]:size:' \
  '--min_trim_size[minimum adapter alignment size to process]:size:' \
  '--extra_end_trim[additional bases to remove beyond detected adapter]:bases:' \
  '--end_threshold[minimum identity for end adapter trimming]:percent:' \
  '--no_split[skip splitting reads at internal adapters]' \
  '--discard_middle[remove reads with internal adapters instead of splitting]' \
  '--middle_threshold[minimum identity for internal adapter detection]:percent:' \
  '--extra_middle_trim_good_side[extra bases removed on favored side]:bases:' \
  '--extra_middle_trim_bad_side[extra bases removed on unfavored side]:bases:' \
  '--min_split_read_size[minimum size for split read pieces to retain]:size:' && ret=0

return ret
