#compdef xonsh
# Documentation: https://manpages.debian.org/bookworm/xonsh/xonsh.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[execute a single command]:command:' \
  '(-i --interactive)'{-i,--interactive}'[force interactive mode]' \
  '(-l --login)'{-l,--login}'[run as login shell]' \
  '--rc=[run control files to load]:file:_files' \
  '--no-rc[do not load run control files]' \
  '--no-script-cache[disable script caching]' \
  '--cache-everything[cache all code]' \
  '-D+[define environment variable (NAME=VAL)]:item:' \
  '--shell-type=[override shell type]:type:(b best d dumb ptk prompt-toolkit prompt_toolkit rand random rl readline)' \
  '--timings[print timing information]' \
  '*:script file:_files -g "*.{xsh,py}"'
