#compdef xonsh

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c[execute a single command]:command' \
  '-i[force running in interactive mode]' \
  '-l[run as a login shell]' \
  '--login[run as a login shell]' \
  '--no-rc[do not load run control files]' \
  '--rc=[run control files to load]:file:_files' \
  '-D=[define environment variable]:var=value' \
  '--no-script-cache[do not cache scripts]' \
  '--cache-everything[cache all code]' \
  '--shell-type=[override shell type]:type:(none readline prompt_toolkit random best)' \
  '--timings[print timing for each xonsh command]' \
  '*:script file:_files -g "*.{xsh,py}"'
