#compdef uiua

_uiua_cmds() {
    local -a commands=(
        'run:run a Uiua file'
        'build:build a Uiua file to an assembly'
        'eval:evaluate an expression'
        'test:run tests'
        'watch:watch a file and re-run on changes'
        'fmt:format Uiua files'
        'repl:start a REPL'
        'init:initialize a new Uiua project'
        'doc:show documentation for a function'
        'find:find a function by name'
        'lsp:run the language server'
        'stand:create a standalone executable'
        'update:update Uiua'
        'module:manage modules'
        'help:print help information'
    )
    _describe -t commands 'uiua command' commands
}

_uiua() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '1:command:_uiua_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                run)
                    _arguments \
                        '--no-format[do not format before running]' \
                        '--no-color[disable color output]' \
                        '--time-instrs[show instruction timing]' \
                        '--mode=[execution mode]:mode:(all test)' \
                        '--limit=[set recursion limit]:limit' \
                        '1:file:_files'
                    ;;
                build)
                    _arguments \
                        '--output=[output file]:file:_files' \
                        '1:file:_files'
                    ;;
                eval)
                    _arguments \
                        '--no-color[disable color output]' \
                        '1:expression'
                    ;;
                test)
                    _arguments \
                        '--no-format[do not format before testing]' \
                        '--no-color[disable color output]' \
                        '1:file:_files'
                    ;;
                watch)
                    _arguments \
                        '--no-format[do not format before running]' \
                        '--no-color[disable color output]' \
                        '--clear[clear screen on re-run]' \
                        '1:file:_files'
                    ;;
                fmt)
                    _arguments \
                        '--io[format with IO comments]' \
                        '1:file:_files'
                    ;;
                doc)
                    _arguments '1:function-name'
                    ;;
                find)
                    _arguments '1:search-term'
                    ;;
                stand)
                    _arguments \
                        '--name=[name of the executable]:name' \
                        '--output=[output directory]:dir:_directories' \
                        '1:file:_files'
                    ;;
                module)
                    _arguments \
                        '1:action:(update list)'
                    ;;
            esac
            ;;
    esac
}

_uiua "$@"
