#compdef uiua
# Documentation: https://github.com/uiua-lang/uiua
# Reference accessed: 2026-05-21
# Verified: upstream src/main.rs clap definitions.

_uiua_cmds() {
    local -a commands=(
        'init:initialize a new main.ua file'
        'run:format and run a file (- for stdin)'
        'build:build an assembly (.uasm format)'
        'eval:evaluate an expression and print its output'
        'test:format and test a file'
        'watch:run .ua files in the current directory when they change'
        'fmt:format a Uiua file or all files in the current directory'
        'doc:show the documentation for a function, modifier, or constant'
        'check:check that Uiua files compile'
        'find:find some Uiua code that matches the given unformatted text'
        'repl:run the Uiua interpreter in a REPL'
        'update:update Uiua by installing with Cargo'
        'module:manage Git modules (requires Git)'
        'stand:create a standalone executable'
        'lsp:run the Language Server'
    )
    _describe -t commands 'uiua command' commands
}

_uiua() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '(-w --window)'{-w,--window}'[use a window for output instead of stdout]' \
        '1:command:_uiua_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                run)
                    _arguments \
                        '--no-format[do not format before running]' \
                        '--no-color[disable color output]' \
                        '--time-instrs[show instruction timing]' \
                        '(-l --limit)'{-l,--limit}'[set recursion limit]:limit' \
                        '(-i --stdin)'{-i,--stdin}'[read input from stdin]' \
                        '--mode=[execution mode]:mode' \
                        '(-w --window)'{-w,--window}'[use a window for output]' \
                        '--format-config=[formatter config file]:file:_files' \
                        '1:file:_files'
                    ;;
                build)
                    _arguments \
                        '1:file:_files'
                    ;;
                eval)
                    _arguments \
                        '--no-color[disable color output]' \
                        '(-x --experimental)'{-x,--experimental}'[allow experimental features]' \
                        '(-i --stdin)'{-i,--stdin}'[read input from stdin]' \
                        '1:expression'
                    ;;
                test)
                    _arguments \
                        '1:file:_files'
                    ;;
                watch)
                    _arguments \
                        '--no-format[do not format before running]' \
                        '--no-color[disable color output]' \
                        '--clear[clear screen on re-run]' \
                        '(-w --window)'{-w,--window}'[use a window for output]' \
                        '--stdin-file=[stdin file]:file:_files' \
                        '--format-config=[formatter config file]:file:_files' \
                        '1:file:_files'
                    ;;
                fmt)
                    _arguments \
                        '--io[format with IO comments]' \
                        '--format-config=[formatter config file]:file:_files' \
                        '1:file:_files'
                    ;;
                doc)
                    _arguments '1:function-name'
                    ;;
                check)
                    _arguments '1:file:_files'
                    ;;
                find)
                    _arguments \
                        '(-p --path)'{-p,--path}'[search path]:path:_files' \
                        '--raw[raw output]' \
                        '1:search-text'
                    ;;
                repl)
                    _arguments \
                        '(-p --persist)'{-p,--persist}'[persist REPL state]' \
                        '(-x --experimental)'{-x,--experimental}'[allow experimental features]' \
                        '--format-config=[formatter config file]:file:_files'
                    ;;
                stand)
                    _arguments \
                        '1:file:_files'
                    ;;
                module)
                    _arguments \
                        '1:subcommand:(list update clean)'
                    ;;
            esac
            ;;
    esac
}

_uiua "$@"
