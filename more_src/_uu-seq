#compdef uu-seq
# Documentation: https://man.archlinux.org/search?q=uu-seq
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-seq() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[Separator character (defaults to \\n)]: :_default' \
'--separator=[Separator character (defaults to \\n)]: :_default' \
'-t+[Terminator character (defaults to \\n)]: :_default' \
'--terminator=[Terminator character (defaults to \\n)]: :_default' \
'-f+[use printf style floating-point FORMAT]: :_default' \
'--format=[use printf style floating-point FORMAT]: :_default' \
'-w[Equalize widths of all numbers by padding with zeros]' \
'--equal-width[Equalize widths of all numbers by padding with zeros]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::numbers:_default' \
&& ret=0
}

(( $+functions[_uu-seq_commands] )) ||
_uu-seq_commands() {
    local commands; commands=()
    _describe -t commands 'uu-seq commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-seq" ]; then
    _uu-seq "$@"
else
    compdef _uu-seq uu-seq
fi
