#compdef cbtransfer
# Documentation: https://docs.couchbase.com/server/current/cli/cbtools/cbtransfer.html
# Couchbase data transfer tool (deprecated; use cbdatarecovery)

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-u --username)'{-u,--username}'+[source cluster username]:username:' \
  '(-p --password)'{-p,--password}'+[source cluster password]:password:' \
  '(-U --username-dest)'{-U,--username-dest}'+[destination cluster username]:username:' \
  '(-P --password-dest)'{-P,--password-dest}'+[destination cluster password]:password:' \
  '(-s --ssl)'{-s,--ssl}'[use SSL to connect to the source]' \
  '--no-ssl-verify[disable SSL certificate verification]' \
  '--cacert=[CA certificate file for SSL verification]:file:_files' \
  '(-b --bucket-source)'{-b,--bucket-source}'+[source bucket to transfer]:bucket:' \
  '(-B --bucket-destination)'{-B,--bucket-destination}'+[destination bucket to transfer to]:bucket:' \
  '(-i --id)'{-i,--id}'+[transfer only items of this vBucket id]:id:' \
  '(-k --key)'{-k,--key}'+[transfer only keys matching this regexp]:regexp:' \
  '--single-node[transfer from a single server node]' \
  '--source-vbucket-state=[source vBucket state to transfer]:state:(active replica)' \
  '--destination-vbucket-state=[destination vBucket state]:state:(active replica)' \
  '--destination-operation=[destination operation]:op:(set add get)' \
  '(-n --dry-run)'{-n,--dry-run}'[show what would be transferred without doing it]' \
  '(-t --threads)'{-t,--threads}'+[number of concurrent worker threads]:threads:' \
  '(-x --extra)'{-x,--extra}'+[extra config parameters]:params:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--silent[reduce output noise]' \
  '1:source:' \
  '2:destination:' && ret=0

return ret
