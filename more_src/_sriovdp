#compdef sriovdp
# _sriovdp — SR-IoV Network Device Plugin (k8snetworkplumbingwg/sriov-network-device-plugin)
# upstream: https://github.com/k8snetworkplumbingwg/sriov-network-device-plugin
# Flags from cmd/sriovdp/main.go on tip.

_sriovdp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-file=[device-plugin config JSON file]:file:_files' \
        '--resource-prefix=[Kubernetes resource prefix]:prefix:' \
        '--use-cdi[advertise resources via the Container Device Interface]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr[log to stderr]'
}

_sriovdp "$@"
