#compdef clipboard-cli
# Documentation: https://github.com/sindresorhus/clipboard-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# sindresorhus/clipboard-cli - accepts no explicit flags beyond help/version.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' && ret=0

return ret
