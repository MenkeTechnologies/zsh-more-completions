#compdef pywalfox
# Documentation: https://github.com/Frewacom/pywalfox
# Source: Frewacom/pywalfox — native messaging host for the Pywalfox Firefox add-on.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _pwf_cmds
_pwf_cmds=(
    'install:install the native messaging application + register manifest'
    'update:fetch pywal colors and broadcast the new theme'
    'uninstall:remove the native messaging manifest'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'pywalfox command' _pwf_cmds && ret=0
        ;;
    args)
        case $line[1] in
            install)
                _arguments -s -S \
                    '--manifest-path=[where to register the native messaging host]:dir:_files -/' \
                    '--profile-path=[browser profile directory (Firefox forks)]:dir:_files -/' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
