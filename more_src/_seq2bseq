#compdef seq2bseq
# Documentation: https://github.com/bluez/bluez/blob/master/tools/seq2bseq.c
# Source: BlueZ tools/seq2bseq.c — convert Atheros/Qualcomm firmware "seq" file to BlueZ binary "bseq" format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --output)'{-o+,--output=}'[firmware output file]:file:_files' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:input .seq:_files' \
    && ret=0

return ret
