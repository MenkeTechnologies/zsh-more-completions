_autokernel_main() {
    local -a subcmds
    subcmds=(
        'build:generate .config then build the kernel'
        'generate-config:generate .config from autokernel config'
        'satisfy:compute minimum dependency changes to enable a symbol'
        'info:show dependencies, dependees and default value of a symbol'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[autokernel config file (default /etc/autokernel/config.toml)]:config file:_files' \
        '(-k --kernel-dir)'{-k+,--kernel-dir=}'[kernel source directory (default /usr/src/linux)]:kernel dir:_files -/' \
        '(-b --bash)'{-b+,--bash=}'[bash interpreter for generated shebangs]:bash:_files' \
        '(-): :->cmd' \
        '*::arg:->args' && return 0

    case $state in
        cmd)
            _describe -t commands 'autokernel subcommand' subcmds
            ;;
        args)
            case $line[1] in
                build)
                    _arguments \
                        '(-c --clean)'{-c,--clean}'[run make clean before building]' \
                        '(-i --install)'{-i,--install}'[install resulting artifacts after building]'
                    ;;
                generate-config)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output .config file path]:output file:_files'
                    ;;
                satisfy)
                    _arguments \
                        '(-i --ignore-config)'{-i,--ignore-config}'[do not apply config; use defaults]' \
                        '(-r --recursive)'{-r,--recursive}'[recursively satisfy dependencies]' \
                        '1:symbol:' \
                        '2:value:(y m n)'
                    ;;
                info)
                    _arguments \
                        '(-i --ignore-config)'{-i,--ignore-config}'[do not apply config; use defaults]' \
                        '1:symbol:'
                    ;;
            esac
            ;;
    esac
}

_autokernel_index_main() {
    local -a subcmds
    subcmds=(
        'init-db:initialize the SQLite database schema'
        'kernel:index kernel symbols, metadata and default values'
        'values:index resolved symbol values after applying a kconf'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-k --kernel-dir)'{-k+,--kernel-dir=}'[kernel source directory (default /usr/src/linux)]:kernel dir:_files -/' \
        '(-b --bash)'{-b+,--bash=}'[bash interpreter]:bash:_files' \
        '(-d --db)'{-d+,--db=}'[sqlite database (default index.db)]:db file:_files' \
        '(-): :->cmd' \
        '*::arg:->args' && return 0

    case $state in
        cmd)
            _describe -t commands 'autokernel-index subcommand' subcmds
            ;;
        args)
            case $line[1] in
                values)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[configuration name]:name:' \
                        '(-a --arch)'{-a+,--arch=}'[target architecture]:arch:(x86_64 i386 arm64 arm riscv64 powerpc s390x mips)' \
                        '(-k --kconf)'{-k+,--kconf=}'[kconf file to apply before indexing]:kconf file:_files'
                    ;;
            esac
            ;;
    esac
}

case $service in
    autokernel-index) _autokernel_index_main "$@" ;;
    *) _autokernel_main "$@" ;;
esac
