#compdef jackseis
# Documentation: https://pyrocko.org/docs/current/apps/jackseis/
# Pyrocko jackseis: manipulate seismic waveform archives

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--format=[input data format]:format:(mseed sac text yaff gse2 from_extension detect)' \
  '--output-format=[output data format]:format:(mseed sac text yaff gse2)' \
  '--output-data-type=[output sample data type]:type:(same int32 int64 float32 float64)' \
  '--tmin=[start time]:time:' \
  '--tmax=[end time]:time:' \
  '--tinc=[output file length in seconds]:seconds:' \
  '--downsample=[downsample to RATE in Hz]:rate:' \
  '--output=[output filename template]:template:' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--rename-network=[rename network code]:net:' \
  '--rename-station=[rename station code]:sta:' \
  '--rename-location=[rename location code]:loc:' \
  '--rename-channel=[rename channel code]:cha:' \
  '--force[overwrite existing files]' \
  '*:file:_files' && ret=0

return ret
