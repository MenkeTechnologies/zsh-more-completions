#compdef vcom
# _vcom — Mentor Graphics Siemens ModelSim Questa vcom CLI for the VHDL compiler producing simulation libraries supporting VHDL-1987 VHDL-1993 VHDL-2002 VHDL-2008 IEEE std-logic synthesis-pragmas package-body (Mentor team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/

_vcom() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-quiet[quiet]' \
        '-modelsimini=+[file]:file:_files -g "*.ini modelsim.ini"' \
        '-87[VHDL-1987]' \
        '-93[VHDL-1993]' \
        '-2002[VHDL-2002]' \
        '-2008[VHDL-2008]' \
        '-explicit[explicit type bindings]' \
        '-implicit[implicit type bindings]' \
        '-novopt[no optimization]' \
        '-work+[library name]:str:' \
        '-O0[optimization level 0]' \
        '-O1[optimization level 1]' \
        '-O5[optimization level 5]' \
        '-debugVA[debug VA]' \
        '-source[print source]' \
        '-l+[log file]:file:_files' \
        '-logfile=+[log file]:file:_files' \
        '-pedanticerrors[pedantic errors]' \
        '-permit_unmatched_virtual_intf[permit unmatched virtual intf]' \
        '-suppress=+[csv]:str:' \
        '-warning=+[csv]:str:' \
        '-error=+[csv]:str:' \
        '-incr[incremental]' \
        '-just[just compile]' \
        '-noignoredvhdlfailures[no ignored VHDL failures]' \
        '-mixedsvvh[mixed SV/VHDL]' \
        '-time[print time]' \
        '-f+[command file]:file:_files' \
        '*:VHDL file:_files -g "*.vhd *.vhdl"'
}

_vcom "$@"
