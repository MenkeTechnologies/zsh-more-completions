#compdef alsamixer
# _alsamixer — ALSA ncurses mixer; interactive mixer for ALSA sound cards
# upstream: https://github.com/alsa-project/alsa-utils

_alsamixer() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --card)'{-c,--card}'+[card number or id]:card:' \
        '(-D --device)'{-D,--device}'+[device]:device:' \
        '(-V --view)'{-V,--view}'+[start view]:view:(playback capture all)' \
        '(-g --no-color)'{-g,--no-color}'[no color]' \
        '(-a --abstraction)'{-a,--abstraction}'+[mixer abstraction]:layer:(none basic)' \
        '(-B --no-mixer-color)'{-B,--no-mixer-color}'[no mixer color]'
}

_alsamixer "$@"
