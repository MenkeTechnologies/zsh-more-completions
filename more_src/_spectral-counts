#compdef spectral-counts
# Documentation: https://crux.ms/commands/spectral-counts.html
# Crux spectral-counts: quantify proteins/peptides by spectral counting.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--parsimony=[protein parsimony analysis]:mode:(none simple greedy)' \
  '--threshold=[PSM filtering threshold]:t' \
  '--threshold-type=[threshold filtering method]:type:(none qvalue custom)' \
  '--custom-threshold-name=[custom threshold field]:name' \
  '--custom-threshold-min=[custom threshold direction]:bool:(T F)' \
  '--input-ms2=[MS2 file for SIN measurement]:file:_files' \
  '--unique-mapping=[exclude peptides mapping to multiple proteins]:bool:(T F)' \
  '--quant-level=[quantification scope]:level:(protein peptide)' \
  '--measure=[analysis metric]:measure:(RAW NSAF dNSAF SIN EMPAI)' \
  '--mzid-use-pass-threshold=[use mzid passThreshold attribute]:bool:(T F)' \
  '--protein-database=[FASTA protein sequence file]:file:_files' \
  '--spectrum-parser=[MS/MS file parser]:parser:(pwiz mstoolkit)' \
  '--fileroot=[output filename prefix]:prefix' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--overwrite=[overwrite existing files]:bool:(T F)' \
  '--parameter-file=[parameter configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:input:_files' && ret=0

return ret
