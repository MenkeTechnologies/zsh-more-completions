#compdef bittwistb
# Documentation: http://www.huge-man-linux.net/man1/bittwistb.html
# pcap based ethernet bridge

local ret=1

_arguments -s -S \
  '(-h)-h[print version information and usage]' \
  '-d[print a list of network interfaces available]' \
  '-v[print forwarding information including destination and source MAC addresses]' \
  '-i+[comma separated list of 2 to 8 ethernet-type interfaces to bridge]:interfaces' && ret=0

return ret
