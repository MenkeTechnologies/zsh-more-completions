#compdef dspsr
# Documentation: https://dspsr.sourceforge.net/manuals/dspsr/
# DSPSR: coherent dedispersion and folding of baseband/filterbank pulsar data.

local ret=1

_arguments -s -S \
  '-order[order data optimally when possible]' \
  '-minram=[minimum RAM usage in MB]:mb:' \
  '-U+[upper limit on RAM usage (MB or minX)]:limit:' \
  '-B+[set bandwidth in MHz]:mhz:' \
  '-f+[set centre frequency in MHz]:mhz:' \
  '-k+[set telescope name]:telescope:' \
  '-N+[set source name]:name:' \
  '-C+[adjust clock by offset seconds]:offset:' \
  '-m+[set start MJD of observation]:mjd:' \
  '-2+[unpacker options (2-bit excision)]:code:' \
  '--skz[apply spectral kurtosis RFI zapping]' \
  '--noskz_too[also produce un-zapped output version]' \
  '--skzm=[samples to integrate for SK statistics]:samples:' \
  '--skzs=[std deviations for SK excisions]:stddevs:' \
  '--skz_start=[first channel where signal expected]:chan:' \
  '--skz_end=[last channel where signal expected]:chan:' \
  '--skz_no_fscr[do not use SKDetector Fscrunch]' \
  '--skz_no_tscr[do not use SKDetector Tscrunch]' \
  '--skz_no_ft[do not use SKDetector despeckeler]' \
  '--skzn=[CPU threads for SK filterbank]:threads:' \
  '--sk_fold[fold the SKFilterbank output]' \
  '-F+[create N-channel filterbank (<N>[:D])]:nchan:' \
  '-G+[create phase-locked filterbank]:nbin:' \
  '--cyclic=[form cyclic spectra with N channels]:n:' \
  '--cyclicoversample=[use M times as many lags]:m:' \
  '-D+[override dispersion measure]:dm:' \
  '-K[remove inter-channel dispersion delays]' \
  '-x+[override optimal transform length]:nfft:' \
  '-R[apply time-variable narrow-band RFI filter]' \
  '--pac=[PAC database for matrix convolution]:dbase:_files' \
  '--fft-bench[use benchmark data to choose FFT length]' \
  '-d+[detection mode (1-4)]:npol:' \
  '-n+[output dimensions when npol=4]:ndim:' \
  '-4[compute fourth-order moments]' \
  '-b+[number of phase bins in folded profile]:nbin:' \
  '-c+[folding period in seconds]:period:' \
  '--cepoch=[reference epoch for phase=0]:mjd:' \
  '-p+[reference phase of rising edge of bin zero]:phase:' \
  '-E+[pulsar ephemeris file]:file:_files' \
  '-P+[phase predictor file]:file:_files' \
  '-w+[phase predictors file]:file:_files' \
  '-X+[additional pulsar to be folded]:name:' \
  '--asynch-fold[fold on CPU while processing on GPU]' \
  '-A[output single archive with multiple integrations]' \
  '--nsub=[output archives with N integrations each]:n:' \
  '-s[create single pulse sub-integrations]' \
  '--turns=[create integrations of N spin periods]:n:' \
  '-L+[create integrations of duration (s)]:seconds:' \
  '--Lepoch=[start time of first sub-integration]:mjd:' \
  '--Lmin=[minimum integration length output]:seconds:' \
  '-y[output partially completed integrations]' \
  '-a+[output archive class name]:archive:' \
  '-e+[output filename extension]:ext:' \
  '-O+[output filename]:name:' \
  '-Y[output pdmp extras]' \
  '--no_dyn[disable dynamic extensions]' \
  '-j+[psrsh command run before output]:job:' \
  '-J+[psrsh script run before output]:file:_files' \
  '*:input data file:_files' && ret=0

return ret
