#compdef impacket-split
# Documentation: https://github.com/fortra/impacket/blob/master/examples/split.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-split: split a pcap file into per-connection pcap files (single positional pcap)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:pcap file:_files -g "*.(pcap|pcapng|cap)"' && ret=0
return ret
