#compdef rsgiscreateptsvec
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgiscreateptsvec RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'[Output vector path]:value:_files' \
  '(-l --lyr)'{-l,--lyr}'[Option layer name]:value:_files' \
  '(-f --format)'{-f,--format}'[The output vector format (default\: GeoJSON)]:value:_files' \
  '*:file:_files' && ret=0

return ret
