#compdef dh_listpackages
# _dh_listpackages — list binary packages debhelper will act on (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Only debhelper standard options.

_dh_listpackages() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:'
}

_dh_listpackages "$@"
