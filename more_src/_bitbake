#compdef bitbake

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  {-B,--bind}'[Bind to a specific address]:address' \
  {-f,--force}'[Force a specified target to be rerun]' \
  {-c,--cmd}'[Specify the task to execute]:task:(fetch unpack patch configure compile install package package_qa populate_sysroot do_rootfs clean cleansstate cleanall listtasks)' \
  {-C,--clear-stamp}'[Invalidate stamp for specified task and rerun]:task' \
  '--runall[Run specified task for all build-time providers]:task' \
  '--runonly[Run only the specified task]:task' \
  '--no-setscene[Do not run any setscene tasks]' \
  '--skip-setscene[Skip setscene tasks]' \
  {-e,--environment}'[Show the global or per-recipe environment]' \
  {-g,--graphviz}'[Save dependency tree as dot graph]' \
  {-I,--ignore-deps}'[Ignore dependencies of specified targets]:targets' \
  {-l,--log-domains}'[Show debug logging for specified domains]:domains' \
  {-u,--ui}'[User interface to use]:ui:(knotty ncurses taskexp)' \
  '--server-only[Run bitbake without UI]' \
  {-T,--token}'[Specify initial connection token]:token' \
  '--observe-only[Connect to server as observer only]' \
  {-p,--parse-only}'[Quit after parsing the BB recipes]' \
  '--profile[Profile the command and save report]' \
  '--revisions-changed[Set exit code if upstream floating revisions have changed]' \
  '--server-timeout[Server idle timeout in seconds]:seconds' \
  {-n,--dry-run}'[Do not execute tasks, just report]' \
  {-S,--dump-signatures}'[Dump signatures for specified signature handler]:handler:(none printdiff)' \
  {-r,--prefile}'[Read specified file before bitbake.conf]:file:_files' \
  {-R,--postfile}'[Read specified file after bitbake.conf]:file:_files' \
  {-v,--verbose}'[Enable verbose output]' \
  {-D,--debug}'[Increase debug level]' \
  {-q,--quiet}'[Decrease output verbosity]' \
  {-w,--write-log}'[Write build log to file]:file:_files' \
  {-k,--continue}'[Continue as much as possible after an error]' \
  '*:recipe' && ret=0

return ret
