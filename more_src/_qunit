#compdef qunit qunit-cli
# _qunit — jQuery Foundation qunit CLI QUnit JavaScript unit testing framework command-line runner supporting test module assertions QUnit.test QUnit.module QUnit.assert custom-config plugins-reporters html-reporter tap-reporter junit-reporter coverage-instrumentation for ESM CommonJS Node.js (jQuery Foundation team, JavaScript); custom argparse
# upstream: https://qunitjs.com/

_qunit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w[watch mode]' \
        '--watch[watch mode]' \
        '-f+[filter]:str:' \
        '--filter=+[regex]:str:' \
        '-m+[module]:str:' \
        '--module=+[name]:str:' \
        '-s+[seed]:str:' \
        '--seed=+[seed]:str:' \
        '-r+[reporter]:r:(tap junit console silent console-summary verbose)' \
        '--reporter=+[reporter]:r:(tap junit console silent console-summary verbose)' \
        '--require=+[file]:file:_files -g "*.js *.mjs *.cjs"' \
        '--no-config[ignore config files]' \
        '-c+[config file]:file:_files -g ".qunitrc.* qunit.config.js"' \
        '--config=+[file]:file:_files -g ".qunitrc.* qunit.config.js"' \
        '--timeout=+[ms]:n:' \
        '--bail[bail on first failure]' \
        '--no-source-maps[disable source maps]' \
        '-t+[test name]:str:' \
        '--test=+[name]:str:' \
        '*:test file:_files -g "*.test.js *.spec.js test/*.js tests/*.js"'
}

_qunit "$@"
