#compdef graylog-ctl
# Documentation: https://archivedocs.graylog.org/en/2.5/pages/configuration/graylog_ctl.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'reconfigure:run chef reconfigure'
  'reconfigure-as-server:reconfigure node as a Graylog server'
  'reconfigure-as-datanode:reconfigure node as a data node'
  'reconfigure-as-backend:reconfigure node as a backend'
  'reconfigure-as-webinterface:reconfigure node as web interface'
  'set-server-secret:apply server secret to other hosts'
  'set-mongodb-password:enable MongoDB auth and create/update user'
  'set-elasticsearch-password:set Elasticsearch password'
  'set-cluster-master:set the cluster master IP'
  'set-retention:configure retention'
  'set-timezone:set system timezone'
  'set-email-config:configure email settings'
  'set-admin-password:set admin password'
  'set-root-password:set root password'
  'enforce-ssl:enable HTTPS only'
  'show-config:show effective configuration'
  'start:start Graylog services'
  'stop:stop Graylog services'
  'restart:restart Graylog services'
  'status:show service status'
  'tail:tail service logs'
  'show-logs:print recent logs'
  'cleanse:remove all data'
  'uninstall:uninstall Graylog OVA components'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'graylog-ctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set-mongodb-password)
        _arguments \
          '-a+[admin user]:user:' \
          '-u+[username]:user:' \
          '-p+[password]:password:' && ret=0 ;;
      (set-retention)
        _arguments \
          '--journal=[max journal size GB]:n:' \
          '--time=[retention time]:duration:' \
          '--indices=[number of indices to keep]:n:' && ret=0 ;;
      (set-cluster-master)
        _arguments '*::ip:_hosts' && ret=0 ;;
      (set-server-secret|set-elasticsearch-password|set-admin-password|set-root-password)
        _arguments '*::password:' && ret=0 ;;
      (start|stop|restart|status|tail|show-logs)
        _arguments '*::service:(graylog-server graylog-web graylog-radio elasticsearch mongodb)' && ret=0 ;;
    esac ;;
esac

return ret
