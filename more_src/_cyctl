#compdef cyctl
# Documentation: https://cyclops-ui.com/docs/cyctl/
# Reference accessed: 2026-05-17
# Verified: cyclops-ui.com cyctl docs (Cyclops K8s UI CLI, Homebrew).
# Not Cyrus IMAP.
# Removed from prior file: bogus man.archlinux.org search URL;
# malformed brace expansion (would never parse correctly); stray
# `Cyclops Kubernetes UI CLI` line breaking zsh syntax.

# cyctl: Cyclops K8s UI CLI
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'create:create resource'
  'delete:delete resource'
  'describe:describe resource'
  'get:list/show resources'
  'init:initialize Cyclops in cluster'
  'serve:start local server'
  'update:update resource'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cyctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get|create|delete|describe|update)
        _values 'resource' 'modules' 'templates' 'templateauthrules' && ret=0
        ;;
    esac
    ;;
esac
return ret
