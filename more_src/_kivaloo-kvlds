#compdef kivaloo-kvlds
# _kivaloo-kvlds — kivaloo key-value log-structured B+tree daemon (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from kvlds/main.c (libcperciva GETOPT).

_kivaloo-kvlds() {
    _arguments \
        '(- *)--version[print version]' \
        '-s+[KVLDS listen socket]:socket:' \
        '-l+[LBS upstream socket]:socket:' \
        '-C+[B+tree page cache size in pages]:n:' \
        '-c+[B+tree page cache size in bytes]:size:' \
        '-1[run one request at a time]' \
        '-k+[maximum key length]:bytes:' \
        '-v+[maximum value length]:bytes:' \
        '-p+[pidfile]:file:_files' \
        '-S+[cost of storage per GB-month]:f:' \
        '-w+[commit delay time]:f:' \
        '-g+[min forced commit size]:size:'
}

_kivaloo-kvlds "$@"
