#compdef smath
# _libreoffice-math — LibreOffice smath / soffice --math (formula editor; --convert-to mml/pdf/odf/png, --outdir, --headless, --norestore; reads .odf/.mml/.smf natively and embeds into other LibreOffice apps as OLE formula objects)
# upstream: https://git.libreoffice.org/core
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-math() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--convert-to+[convert to format]:format:(pdf mml odf png svg)' \
        '--outdir+[output directory]:dir:_files -/' \
        '*-env+[env var]:key=value:' \
        '*:formula:_files -g "*.(odf|mml|smf)"'
}

_libreoffice-math "$@"
