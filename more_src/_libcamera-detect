#compdef libcamera-detect libcamera-jpeg libcamera-raw rpicam-detect rpicam-jpeg rpicam-raw
# Documentation: source-direct extraction from upstream
# raspberrypi/rpicam-apps core/options.cpp `options_->add_options()`
# block (base Options struct with ~100 common camera/image flags
# using boost::program_options) + core/still_options.hpp
# `StillOptions::add_options()` extensions + per-app sources
# apps/rpicam_{detect,jpeg,raw}.cpp. The 6-stem #compdef line
# covers both the legacy `libcamera-*` names (deprecated symlinks
# added by Raspberry Pi OS packaging) and the canonical
# `rpicam-*` names (per upstream apps/meson.build
# `executable('rpicam-jpeg', ...)` etc).
# Reference accessed: 2026-05-30 via gh api.
# Raspberry Pi rpicam-apps tail R148 — 3 binaries x 2 alias names
# = 6-stem multi-binary harvest of the rpicam-apps not previously
# covered (rpicam-still/rpicam-vid/rpicam-hello already covered
# in the existing libcamera-{still,vid,hello} multi-stem). The
# rpicam-detect binary specifically extends StillOptions with
# 3 detection-specific flags via the `DetectOptions: public
# StillOptions` C++ class chain.

# Shared 30+ base Options shared by all 6 binary aliases.
local -a _rpicam_base
_rpicam_base=(
  '(-h --help)'{-h,--help}'[print help message]'
  '--version[show build version]'
  '--list-cameras[list cameras attached to the system]'
  '--camera=[camera index to use (default 0)]:index:'
  '(-v --verbose)'{-v+,--verbose=}'[verbosity level (0=none/1=default/2=verbose)]:level:(0 1 2)'
  '(-c --config)'{-c+,--config=}'[long-form-options config file]:file:_files'
  '--info-text=[on-screen info text printf format]:fmt:'
  '--width=[output image width (0=default)]:px:'
  '--height=[output image height (0=default)]:px:'
  '(-t --timeout)'{-t+,--timeout=}'[run time (default 5sec; ms if no unit)]:time:'
  '(-o --output)'{-o+,--output=}'[output file name]:file:_files'
  '--post-process-file=[post-processing config JSON]:file:_files'
  '--post-process-libs=[custom location for post-processing .so files]:dir:_directories'
  '(-n --nopreview)'{-n,--nopreview}'[do not show a preview window]'
  '(-p --preview)'{-p+,--preview=}'[preview window x,y,width,height]:x,y,w,h:'
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen preview window]'
  '--qt-preview[use Qt-based preview window (heavy CPU)]'
  '--preview-libs=[custom location for preview library .so files]:dir:_directories'
  '--hflip[horizontal flip]'
  '--vflip[vertical flip]'
  '--rotation=[image rotation (0 or 180)]:deg:(0 180)'
  '--roi=[region of interest x,y,w,h fractions]:x,y,w,h:'
  '--shutter=[fixed shutter speed (default us)]:duration:'
  '(--analoggain)--gain=[fixed gain value]:gain:'
  '(--gain)--analoggain=[fixed analog gain (synonym for --gain)]:gain:'
  '--metering=[metering mode]:mode:(centre spot average matrix custom)'
  '--awb=[auto white-balance mode]:mode:(auto incandescent tungsten fluorescent indoor daylight cloudy custom)'
  '--awbgains=[manual AWB R,B gains (disables --awb)]:r,b:'
  '--brightness=[brightness -1.0 to 1.0]:value:'
  '--contrast=[contrast (>0; 1.0=normal)]:value:'
  '--saturation=[saturation (>0; 1.0=normal)]:value:'
  '--sharpness=[sharpness (>0; 1.0=normal)]:value:'
  '--ev=[exposure compensation EV (-10.0 to 10.0)]:ev:'
  '--exposure=[exposure mode]:mode:(normal sport long custom)'
  '--denoise=[denoise mode]:mode:(auto off cdn_off cdn_fast cdn_hq)'
  '--mode=[sensor mode W:H:bit-depth:packed]:mode:'
  '--buffer-count=[number of allocated buffers (default 6)]:n:'
  '--tuning-file=[camera tuning JSON file]:file:_files'
)

# Additional StillOptions used by jpeg/raw/detect (raw uses a
# subset; jpeg + detect use the whole set).
local -a _rpicam_still
_rpicam_still=(
  '(-q --quality)'{-q+,--quality=}'[JPEG quality (default 93)]:q:'
  '*'{-x+,--exif=}'[extra EXIF tag (KEY=VALUE; repeatable)]:KEY=VALUE:'
  '--timelapse=[time between timelapse captures (default ms)]:duration:'
  '--framestart=[initial frame counter (default 0)]:n:'
  '--datetime[use date format for output file names]'
  '--timestamp[use system timestamps for output file names]'
  '--restart=[JPEG restart interval (default 0)]:n:'
  '(-k --keypress)'{-k,--keypress}'[capture when ENTER pressed]'
  '(-s --signal)'{-s,--signal}'[capture on SIGUSR1/SIGUSR2]'
  '--thumb=[thumbnail spec width:height:quality or none]:spec:'
  '(-e --encoding)'{-e+,--encoding=}'[output encoding]:encoding:(jpg png rgb rgb24 rgb48 bmp yuv420)'
  '(-r --raw)'{-r,--raw}'[also save raw file in DNG format]'
  '--latest=[symbolic link name to most recent saved file]:name:_files'
  '--immediate[skip preview phase before first capture]'
  '--autofocus-on-capture[trigger AF scan just before capturing]'
)

case $service in

  libcamera-jpeg|rpicam-jpeg)
    # Single-shot JPEG capture.
    _arguments -s -S \
      "${_rpicam_base[@]}" \
      "${_rpicam_still[@]}"
    ;;

  libcamera-raw|rpicam-raw)
    # Raw video record (uses null encoder).
    _arguments -s -S \
      "${_rpicam_base[@]}" \
      '--framerate=[capture framerate]:fps:' \
      '--save-pts=[save presentation timestamps to file]:file:_files' \
      '--segment=[segment duration]:duration:'
    ;;

  libcamera-detect|rpicam-detect)
    # Object-detection-triggered still capture (uses TFLite via
    # post-process-file object_detect_tf.json). Extends
    # StillOptions with 3 detect-specific flags from
    # `struct DetectOptions : public StillOptions` in
    # apps/rpicam_detect.cpp.
    _arguments -s -S \
      "${_rpicam_base[@]}" \
      "${_rpicam_still[@]}" \
      '--object=[name of object to detect (matches the TFLite label)]:name:' \
      '--gap=[smallest gap between captures in frames (default 30)]:frames:' \
      '--timeformat=[strftime() format string (default %m%d%H%M%S)]:fmt:'
    ;;

esac
