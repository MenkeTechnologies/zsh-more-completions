#compdef openapi-typescript

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '--redocly=[redocly.yaml path]:file:_files' \
  '--additional-properties[allow additional properties]' \
  '--alphabetize[sort schemas alphabetically]' \
  '--array-length[generate length-typed arrays]' \
  '--default-non-nullable=[non-nullable defaults]:flag:(true false)' \
  '--properties-required-by-default[properties required by default]' \
  '--empty-objects-unknown[empty objects as unknown]' \
  '--enum[generate enums]' \
  '--enum-values[export enum values]' \
  '--conditional-enums[only emit x-enum-* metadata]' \
  '--dedupe-enums[dedupe enum values]' \
  '--check[CI freshness check]' \
  '--exclude-deprecated[exclude deprecated paths]' \
  '(-t --export-type)'{-t,--export-type}'[emit type instead of interface]' \
  '--immutable[readonly properties]' \
  '--path-params-as-types[path params as types]' \
  '--root-types[generate root types]' \
  '--root-types-no-schema-prefix[no schema prefix on root types]' \
  '--root-types-keep-casing[keep casing for root types]' \
  '--make-paths-enum[make paths enum]' \
  '--generate-path-params[generate path param types]' \
  '--read-write-markers[generate read/write markers]' \
  '*:input:_files'
