#compdef hmmscan
# Documentation: https://man.archlinux.org/search?q=hmmscan
# Reference accessed: 2026-05-16

# HMMER hmmscan: search a sequence against an HMM database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[direct output to file]:file:_files' \
  '--tblout[parseable per-sequence hits table]:file:_files' \
  '--domtblout[parseable per-domain hits table]:file:_files' \
  '--pfamtblout[Pfam-style table]:file:_files' \
  '--acc[show accessions, not names]' \
  '--noali[do not output alignments]' \
  '--notextw[no max width on text output]' \
  '--textw[max width of text output]:cols:' \
  '-E[report sequences <= this E-value]:Eval:' \
  '-T[report sequences with bit score >= this]:bits:' \
  '--domE[report domains <= this E-value]:Eval:' \
  '--domT[report domains with bit score >= this]:bits:' \
  '--incE[include sequences up to this E-value]:Eval:' \
  '--incT[include sequences at bit score >= this]:bits:' \
  '--incdomE[include domains up to this E-value]:Eval:' \
  '--incdomT[include domains at bit score >= this]:bits:' \
  '--cut_ga[use Pfam GA gathering cutoffs]' \
  '--cut_nc[use Pfam NC noise cutoffs]' \
  '--cut_tc[use Pfam TC trusted cutoffs]' \
  '--max[turn off heuristic filters]' \
  '--F1[stage 1 (MSV) threshold]:val:' \
  '--F2[stage 2 (Vit) threshold]:val:' \
  '--F3[stage 3 (Fwd) threshold]:val:' \
  '--nobias[turn off composition bias filter]' \
  '--seed[random seed]:n:' \
  '--qformat[input sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--cpu[number of CPU threads]:n:' \
  '*:HMM database and sequence file:_files' && ret=0
return ret
