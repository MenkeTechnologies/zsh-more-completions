#compdef py2puml
# Documentation: https://github.com/lucsorel/py2puml
# py2puml - generate PlantUML class diagrams from Python code

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show installed version]' \
  '(-p --path)'{-p,--path}'[path to the package or module to inspect]:path:_files' \
  '(-n --namespace)'{-n,--namespace}'[python namespace (derived from path if omitted)]:namespace' \
  '(-o --output-file)'{-o,--output-file}'[output file path (stdout if omitted)]:output:_files' && ret=0

return ret
