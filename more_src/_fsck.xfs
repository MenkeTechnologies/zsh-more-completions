#compdef fsck.xfs
# Documentation: man fsck.xfs(8)
# Source: xfsprogs scrub/fsck.xfs (sh) — stub for fsck-compatibility; real work in xfs_repair.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '-a[boot-time auto-check (accepted, no-op)]' \
    '-A[boot-time auto-check (accepted, no-op)]' \
    '-p[preen mode (accepted, no-op)]' \
    '-y[yes to questions (accepted, no-op)]' \
    '1:device:_files' \
    && ret=0

return ret
