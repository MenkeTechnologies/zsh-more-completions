#compdef buck buck2
# _buck — Facebook Buck/Buck2 polyglot build system (Meta/Facebook, Rust/Java); fast deterministic multi-language build
# upstream: https://github.com/facebook/buck2

_buck() {
    local -a sub=(
        'build:build targets'
        'audit:audit targets'
        'aquery:action query'
        'bxl:run BXL script'
        'cquery:configured query'
        'clean:clean output'
        'completion:print shell completion'
        'ctargets:configured targets'
        'debug:debug commands'
        'docs:open docs'
        'expand-external-cell:expand external cell'
        'explain:explain a build action'
        'help:show help'
        'init:initialize buck project'
        'install:build + install'
        'kill:kill server'
        'killall:kill all servers'
        'log:log subcommands'
        'lsp:run LSP server'
        'profile:profile a build'
        'query:dependency query (uquery)'
        'rage:upload rage report'
        'reload:reload daemon'
        'root:print project root'
        'run:build + run binary'
        'server:server commands'
        'starlark:starlark commands'
        'status:show server status'
        'subscribe:subscribe to events'
        'targets:show targets'
        'test:build + run tests'
        'uquery:unconfigured query'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-v+[verbosity]:n:' \
        '--verbose+[verbosity]:n:' \
        '--isolation-dir+[isolation dir]:dir:_files -/' \
        '--no-buckd[no buckd]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'buck subcommand' sub ;;
        args)
            case $words[1] in
                build|run|test|targets|query|uquery|cquery|aquery|bxl|install) _arguments \
                    '-c+[config override]:k=v:' \
                    '--config+[config override]:k=v:' \
                    '--target-platforms+[target platforms]:str:' \
                    '--host-platform+[host platform]:platform:' \
                    '--show-output[show output paths]' \
                    '--show-full-output[show full output paths]' \
                    '--show-simple-output[show simple output]' \
                    '--out+[output file]:file:_files' \
                    '--prefer-local[prefer local execution]' \
                    '--prefer-remote[prefer remote execution]' \
                    '--no-remote-cache[no remote cache]' \
                    '*:target:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_buck "$@"
