#compdef buildifier

_buildifier() {
  _arguments \
    '(- *)'{-h,-help}'[Show help message]' \
    '(- *)'{-v,-version}'[Show version]' \
    '-d[Diff mode: show diff instead of rewriting]' \
    '-format[Output format for lint warnings]:format:(text json)' \
    '-lint[Lint mode]:mode:(off warn fix)' \
    '-mode[Processing mode]:mode:(check diff fix print_if_changed)' \
    '-path[Use this path for file when reading from stdin]:path:' \
    '-r[Process files recursively]' \
    '-tables[Path to JSON table file]:file:_files -g "*.json"' \
    '-type[Type of file to format]:type:(auto build bzl workspace default module)' \
    '-warnings[Comma-separated list of warnings to enable]:warnings:' \
    '-add-tables[Path to additional JSON table file]:file:_files -g "*.json"' \
    '*:file:_files -g "*(BUILD|WORKSPACE|*.bzl|*.bazel)"'
}

_buildifier "$@"
