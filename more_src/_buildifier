#compdef buildifier
# Documentation: https://github.com/bazelbuild/buildtools/blob/master/buildifier/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_buildifier() {
  _arguments \
    '(- *)'{-h,-help}'[show help]' \
    '(- *)'{-v,-version}'[show version]' \
    '-d[diff mode: show diff instead of rewriting]' \
    '-format[output format for diagnostics]:format:(text json)' \
    '-lint[lint mode]:mode:(off warn fix)' \
    '-mode[processing mode]:mode:(check diff fix print_if_changed)' \
    '-path[path to use when reading from stdin]:path:' \
    '-r[process files recursively]' \
    '-tables[path to JSON table file]:file:_files -g "*.json"' \
    '-type[override automatic file type]:type:(auto build bzl workspace default module)' \
    '-warnings[comma-separated list of warnings (use all for every category)]:warnings:' \
    '-add-tables[path to additional JSON table file]:file:_files -g "*.json"' \
    '*:file:_files -g "*(BUILD|WORKSPACE|*.bzl|*.bazel)"'
}

_buildifier "$@"
