#compdef dicom2nifti
# Documentation: https://icometrix.github.io/dicom2nifti/readme.html
# Convert a directory of DICOM files to NIfTI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '-G[allow gantry tilted CT data (disable orthogonality validation)]' \
  '-r[enable resampling to orthogonal output]' \
  '-o[spline interpolation order for resampling]:resample order:' \
  '-p[padding value used during resampling]:resample padding:' \
  '-I[allow inconsistent slice increments]' \
  '-S[convert single-slice images]' \
  '1:input directory:_files -/' \
  '2:output directory:_files -/' && ret=0

return ret
