#compdef copernicusmarine
# Documentation: https://toolbox-docs.marine.copernicus.eu/en/stable/command-line-interface.html
# Copernicus Marine Toolbox CLI

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'copernicusmarine command' \
      'subset[download a subset of a dataset]' \
      'get[download original files of a dataset]' \
      'describe[print the catalogue metadata as JSON]' \
      'login[create configuration with credentials]' && ret=0
    ;;
  args)
    case $line[1] in
      subset)
        _arguments -s \
          '(-i --dataset-id)'{-i,--dataset-id}'=[dataset identifier]:id:' \
          '--dataset-version=[dataset version]:version:' \
          '--dataset-part=[dataset part]:part:' \
          '*'{-v,--variable}'=[variable to subset]:variable:' \
          '(-x --minimum-longitude)'{-x,--minimum-longitude}'=[minimum longitude]:lon:' \
          '(-X --maximum-longitude)'{-X,--maximum-longitude}'=[maximum longitude]:lon:' \
          '(-y --minimum-latitude)'{-y,--minimum-latitude}'=[minimum latitude]:lat:' \
          '(-Y --maximum-latitude)'{-Y,--maximum-latitude}'=[maximum latitude]:lat:' \
          '(-z --minimum-depth)'{-z,--minimum-depth}'=[minimum depth]:depth:' \
          '(-Z --maximum-depth)'{-Z,--maximum-depth}'=[maximum depth]:depth:' \
          '(-V --vertical-axis)'{-V,--vertical-axis}'=[depth or elevation]:axis:(depth elevation)' \
          '(-t --start-datetime)'{-t,--start-datetime}'=[start datetime]:datetime:' \
          '(-T --end-datetime)'{-T,--end-datetime}'=[end datetime]:datetime:' \
          '--coordinates-selection-method=[boundary selection behaviour]:method:' \
          '(-o --output-directory)'{-o,--output-directory}'=[output directory]:dir:_files -/' \
          '(-f --output-filename)'{-f,--output-filename}'=[output filename]:file:_files' \
          '--file-format=[output file format]:format:(netcdf zarr csv parquet)' \
          '--overwrite[overwrite existing output]' \
          '--skip-existing[skip download if output exists]' \
          '--netcdf-compression-level=[netcdf compression 0-9]:level:' \
          '--netcdf3-compatible[output netcdf3 compatible files]' \
          '--chunk-size-limit=[limit dask chunk size]:size:' \
          '--username=[Copernicus Marine username]:user:' \
          '--password=[Copernicus Marine password]:pass:' \
          '--credentials-file=[credentials file]:file:_files' \
          '(-s --service)'{-s,--service}'=[download service]:service:' \
          '--request-file=[JSON request configuration file]:file:_files' \
          '--create-template[create a request template file]' \
          '--dry-run[run the query without downloading]' \
          '(-r --response-fields)'{-r,--response-fields}'=[metadata fields to include]:fields:' \
          '--disable-progress-bar[hide progress indicators]' \
          '--log-level=[verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL QUIET)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      get)
        _arguments -s \
          '(-i --dataset-id)'{-i,--dataset-id}'=[dataset identifier]:id:' \
          '--dataset-version=[dataset version]:version:' \
          '--dataset-part=[dataset part]:part:' \
          '--username=[Copernicus Marine username]:user:' \
          '--password=[Copernicus Marine password]:pass:' \
          '--credentials-file=[credentials file]:file:_files' \
          '(-nd --no-directories)'{-nd,--no-directories}'[do not recreate directory structure]' \
          '(-o --output-directory)'{-o,--output-directory}'=[output directory]:dir:_files -/' \
          '--overwrite[overwrite existing output]' \
          '--skip-existing[skip download if output exists]' \
          '(--filter --filter-with-globbing-pattern)'{--filter,--filter-with-globbing-pattern}'=[globbing filter pattern]:pattern:' \
          '(--regex --filter-with-regular-expression)'{--regex,--filter-with-regular-expression}'=[regex filter pattern]:pattern:' \
          '--file-list=[file list of files to download]:file:_files' \
          '--create-file-list=[create a file list]:file:_files' \
          '--sync[synchronise local and remote files]' \
          '--sync-delete[delete local files not present remotely]' \
          '--dry-run[run the query without downloading]' \
          '--max-concurrent-requests=[max concurrent requests]:n:' \
          '--disable-progress-bar[hide progress indicators]' \
          '--log-level=[verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL QUIET)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      describe)
        _arguments -s \
          '--show-all-versions[include all dataset versions]' \
          '(-r --return-fields)'{-r,--return-fields}'=[metadata fields to include]:fields:' \
          '(-e --exclude-fields)'{-e,--exclude-fields}'=[metadata fields to exclude]:fields:' \
          '*'{-c,--contains}'=[filter products containing string]:string:' \
          '(-p --product-id)'{-p,--product-id}'=[filter by product id]:id:' \
          '(-i --dataset-id)'{-i,--dataset-id}'=[filter by dataset id]:id:' \
          '--max-concurrent-requests=[max concurrent requests]:n:' \
          '--disable-progress-bar[hide progress indicators]' \
          '--log-level=[verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL QUIET)' \
          '--raise-on-error[raise an error on failure]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      login)
        _arguments -s \
          '--username=[Copernicus Marine username]:user:' \
          '--password=[Copernicus Marine password]:pass:' \
          '--configuration-file-directory=[configuration file directory]:dir:_files -/' \
          '--force-overwrite[overwrite existing configuration file]' \
          '--check-credentials-valid[check stored credentials validity]' \
          '--credentials-file=[credentials file]:file:_files' \
          '--log-level=[verbosity]:level:(DEBUG INFO WARN ERROR CRITICAL QUIET)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
