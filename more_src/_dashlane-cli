#compdef dashlane-cli dcli
# _dashlane-cli — Dashlane password vault CLI (Dashlane team, Node); commander
# upstream: https://github.com/Dashlane/dashlane-cli

_dashlane-cli() {
    local -a sub=(
        'accounts:set-master-password:set master password'
        'accounts:whoami:show current user'
        'accounts:logout:logout'
        'accounts:list:list accounts'
        'accounts:list-devices:list devices'
        'accounts:remove-devices:remove devices'
        'sync:run a sync'
        'configure:configure CLI'
        'configure:disable-auto-sync:disable auto sync'
        'configure:enable-auto-sync:enable auto sync'
        'configure:disable-disk-cache:disable disk cache'
        'configure:enable-disk-cache:enable disk cache'
        'configure:save-master-password:save master password'
        'configure:forget-master-password:forget master password'
        'configure:set-current-team:set team'
        'devices:list devices'
        'devices:remove:remove device'
        'export:export vault'
        'import:import vault'
        'inject:inject secret refs'
        'password:get password'
        'note:get note'
        'otp:get otp'
        'team:audit-logs:show audit logs'
        'team:members:list members'
        'team:members:invite:invite member'
        'team:members:revoke:revoke member'
        'team:members:reactivate:reactivate member'
        'team:reports:list reports'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--no-color[no color]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dcli subcommand' sub ;;
        args)
            case $words[1] in
                password|note|otp) _arguments \
                    '1:filter:' \
                    '--output=+[output format]:o:(clipboard json password)' \
                    '-o+[output format]:o:(clipboard json password)' ;;
                export) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--format=+[format]:f:(json csv keychain html)' ;;
                import) _arguments \
                    '1:input file:_files' \
                    '--format=+[format]:f:(json csv keychain html)' ;;
                inject) _arguments \
                    '--in-file=+[input file]:file:_files' \
                    '-i+[input file]:file:_files' \
                    '--out-file=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_dashlane-cli "$@"
