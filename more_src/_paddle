#compdef paddle

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate to Paddle'
  'logout:remove credentials'
  'whoami:show current account'
  'product:product operations'
  'price:price operations'
  'transaction:transaction operations'
  'subscription:subscription operations'
  'customer:customer operations'
  'address:address operations'
  'business:business operations'
  'discount:discount operations'
  'event:event operations'
  'notification:notification settings'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--api-key=[Paddle API key]:key:' \
  '--sandbox[use sandbox env]' \
  '--production[use production env]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'paddle command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (product|price|transaction|subscription|customer|address|business|discount) _values 'subcommand' 'create' 'list' 'get' 'update' 'archive' 'restore' 'preview' 'invoice' 'cancel' 'pause' 'resume' && ret=0 ;;
      (event) _values 'subcommand' 'list' 'replay' && ret=0 ;;
      (notification) _values 'subcommand' 'list' 'create' 'update' 'delete' && ret=0 ;;
    esac ;;
esac

return ret
