#compdef brook

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'server:run as brook server'
      'client:run as brook client'
      'wsserver:run as brook WebSocket server'
      'wsclient:run as brook WebSocket client'
      'wssserver:run as brook WebSocket Secure server'
      'wssclient:run as brook WebSocket Secure client'
      'quicserver:run as brook QUIC server'
      'quicclient:run as brook QUIC client'
      'relayoverbrook:relay over brook'
      'dnsserveroverbrook:DNS server over brook'
      'link:generate brook link'
      'connect:connect via brook link'
      'relay:run as relay server'
      'socks5:run as SOCKS5 server'
      'socks5tohttp:convert SOCKS5 to HTTP proxy'
      'hijackhttps:hijack HTTPS connections'
      'pac:generate PAC file'
      'testsocks5:test SOCKS5 server'
      'testbrook:test brook server'
      'echoserver:run echo server'
      'echoclient:run echo client'
      'completion:generate shell completion'
      'mdpage:generate markdown page'
      'help:show help'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (server)
        _arguments \
          '-l+[listen address]:address:' \
          '-p+[password]:password:' \
          '--udpTimeout+[UDP timeout]:seconds:' \
          '--tcpTimeout+[TCP timeout]:seconds:' && ret=0
        ;;
      (client)
        _arguments \
          '-s+[server address]:address:' \
          '-p+[password]:password:' \
          '--socks5+[SOCKS5 listen address]:address:' \
          '--http+[HTTP proxy listen address]:address:' && ret=0
        ;;
    esac
    ;;
esac

return ret
