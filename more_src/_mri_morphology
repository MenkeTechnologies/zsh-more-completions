#compdef mri_morphology
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/mri_morphology/mri_morphology.cpp
# Apply morphological operations to a volume

local ret=1

_arguments -s -S \
  '-mask[load a mask volume to apply to output]:file:_files' \
  '-DEBUG_VOXEL[enable debugging for a specific voxel]:x:y:z:' \
  '-l[apply operations only to specified label]:label:' \
  '-U[display usage]' \
  '*::arg:->args' && ret=0

case $state in
  args)
    _values 'operation' open close dilate erode mode fill_holes erode_bottom dilate_thresh erode_thresh && ret=0
    _files && ret=0
    ;;
esac

return ret
