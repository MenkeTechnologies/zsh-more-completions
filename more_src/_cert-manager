#compdef cmctl cert-manager
# _cert-manager — kubectl plugin for cert-manager (cert-manager/cert-manager)
# upstream: https://github.com/cert-manager/cert-manager

_cert-manager() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--kubeconfig=[path to kubeconfig]:file:_files' \
        '--context=[kubeconfig context]:context:' \
        '(-n --namespace)'{-n,--namespace}'=[target namespace]:namespace:' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_cert_manager_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                approve|deny)
                    _arguments \
                        '--kubeconfig=[kubeconfig file]:file:_files' \
                        '--context=[kubeconfig context]:context:' \
                        '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace:' \
                        '--reason=[reason for approval/denial]:reason:' \
                        '--message=[message]:message:' \
                        '*:certificate request name:' && ret=0 ;;
                check)
                    _arguments \
                        '1: :(api)' && ret=0 ;;
                renew)
                    _arguments \
                        '--kubeconfig=[kubeconfig file]:file:_files' \
                        '--context=[kubeconfig context]:context:' \
                        '(-n --namespace)'{-n,--namespace}'=[namespace]:namespace:' \
                        '--all[renew all certificates in namespace]' \
                        '*:certificate name:' && ret=0 ;;
                status)
                    _arguments \
                        '1: :(certificate)' \
                        '*:name:' && ret=0 ;;
                create)
                    _arguments \
                        '1: :(certificaterequest)' \
                        '*:name:' && ret=0 ;;
                inspect)
                    _arguments \
                        '1: :(secret)' \
                        '*:name:' && ret=0 ;;
                convert|version|completion|help) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_cert_manager_commands] )) ||
_cert_manager_commands() {
    local -a commands
    commands=(
        'approve:approve a CertificateRequest'
        'deny:deny a CertificateRequest'
        'check:check cert-manager API'
        'convert:convert cert-manager resources'
        'create:create cert-manager resources'
        'inspect:inspect cert-manager resources'
        'renew:renew certificates'
        'status:get status of cert-manager resources'
        'version:print cert-manager version'
        'completion:generate shell completion'
        'help:show help'
    )
    _describe -t commands 'cert-manager command' commands
}

_cert-manager "$@"
