#compdef bsatool
# _bsatool — inspect and extract files from Bethesda BSA archives (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/bsatool/bsatool.cpp (boost::program_options).

_bsatool() {
    _arguments \
        '(- *)'{-h,--help}'[print help message]' \
        '(- *)'{-v,--version}'[print version information and quit]' \
        '(-l --long)'{-l,--long}'[include extra information in archive listing]' \
        '(-f --full-path)'{-f,--full-path}'[create directory hierarchy on extraction]' \
        '1:mode:(list extract extractall add create)' \
        '*:file:_files'
}

_bsatool "$@"
