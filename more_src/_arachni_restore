#compdef arachni_restore
# Documentation: https://github.com/Arachni/arachni/wiki/Executables
# Arachni suspended-scan restorer from AFS snapshot files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output this message]' \
  '--version[show version information]' \
  '*:AFS snapshot file:_files -g "*.afs"' && ret=0

return ret
