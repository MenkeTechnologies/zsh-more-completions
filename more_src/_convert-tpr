#compdef convert-tpr gmx-convert-tpr
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-convert-tpr.html
# gmx convert-tpr: make a modified run input file

local ret=1

_arguments -s \
  '-s[run input file to modify]:file:_files' \
  '-n[file containing additional index groups]:file:_files' \
  '-o[generated modified run input file]:file:_files' \
  '-extend[extend runtime by amount in ps]:time:' \
  '-until[extend runtime until this ending time in ps]:time:' \
  '-nsteps[change the number of remaining simulation steps]:int:' \
  '-generate_velocities[reassign velocities using seed]' \
  '-velocity_temp[temperature for velocity generation]:real:' \
  '-velocity_seed[random seed for velocities]:int:' && ret=0

return ret
