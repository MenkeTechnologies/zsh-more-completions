#compdef maid
# Documentation: https://github.com/egoist/maid
# maid - markdown task runner

local ret=1

_arguments -s -S \
  '--quiet[produce minimal log output]' \
  '--section[markdown section to use as tasks]:header' \
  '--path[custom maidfile path]:file:_files' \
  '*:task:_default' && ret=0

return ret
