#compdef mithril mithril-cli
# _mithril — Mithril.js Virtual DOM micro-framework CLI (Leo Horie); helper for scaffolding/dev-server projects
# upstream: https://github.com/MithrilJS/mithril.js

_mithril() {
    local -a sub=(
        'new:scaffold new project'
        'dev:run dev server'
        'build:build for production'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mithril subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments '1:dir:_files -/' ;;
                dev) _arguments '--port+[port]:port:' '--host+[host]:host:_hosts' ;;
            esac
            ;;
    esac
}

_mithril "$@"
