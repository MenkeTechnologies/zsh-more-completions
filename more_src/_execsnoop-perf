#compdef execsnoop-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/execsnoop.8
# trace process exec() with arguments (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-a+[max number of arguments to display]:argc' \
  '-d+[trace duration in seconds, use buffered output]:secs' \
  '-r[include re-execution events]' \
  '-t[include timestamp in seconds]' \
  '*:process name regex:' && ret=0

return ret
