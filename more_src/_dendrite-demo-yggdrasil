#compdef dendrite-demo-yggdrasil
# _dendrite-demo-yggdrasil — P2P Dendrite demo over Yggdrasil overlay (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/dendrite-demo-yggdrasil/main.go.

_dendrite-demo-yggdrasil() {
    _arguments \
        '-name=[instance name]:name:' \
        '-port=[client API port]:port:' \
        '-peer=[comma-separated static Yggdrasil peers]:peers:' \
        '-listen=[Yggdrasil peer listen addr (e.g. tls\://\:0)]:addr:' \
        '-dir=[directory for databases]:dir:_files -/' \
        '-config=[Dendrite config file]:file:_files -g "*.{yml,yaml}"'
}

_dendrite-demo-yggdrasil "$@"
