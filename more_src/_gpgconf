#compdef gpgconf
# Documentation: gpgconf --help on gpgconf (GnuPG) 2.5.20
# Source: GnuPG gpgconf — manage configuration options for tools of the GnuPG system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a gnupg_components
gnupg_components=(
    gpg gpgsm gpg-agent scdaemon dirmngr keyboxd pinentry tpm2daemon
)

_arguments -s \
    '(- *)--list-components[list all components]' \
    '(- *)--check-programs[check all programs]' \
    '(- *)--list-options[list options]:component:($gnupg_components)' \
    '--change-options[change options]:component:($gnupg_components)' \
    '--check-options[check options]:component:($gnupg_components)' \
    '--apply-defaults[apply global default values]' \
    '--apply-profile[update configs using FILE]:file:_files' \
    '(- *)'{-L,--list-dirs}'[get configuration directories for gpgconf]' \
    '(- *)--list-config[list global config file]' \
    '(- *)--check-config[check global config file]' \
    '(- *)--query-swdb[query software version database]' \
    '(-R --reload)'{-R,--reload}'[reload all or given component]:component:($gnupg_components)' \
    '--launch[launch given component]:component:($gnupg_components)' \
    '(-K --kill)'{-K,--kill}'[kill given component]:component:($gnupg_components)' \
    '(- *)'{-V,--show-versions}'[show versions]' \
    '(- *)'{-X,--show-configs}'[show configs]' \
    '(-o --output)'{-o,--output=}'[use as output file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[quiet]' \
    '(-n --dry-run)'{-n,--dry-run}'[do not make any changes]' \
    '(-r --runtime)'{-r,--runtime}'[activate changes at runtime if possible]' \
    '--status-fd=[write status info to this FD]:fd:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    && ret=0

return ret
