#compdef cupsenable cupsdisable
# Documentation: cupsenable / cupsdisable --help (CUPS 26)
# Source: enable / disable a CUPS destination (printer or class).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[encrypt connection to the server]' \
    '-h+[server[:port]]:server:_hosts' \
    '-r+[reason message]:reason:' \
    '-U+[username for authentication]:user:_users' \
    '--release[release previously held jobs]' \
    '*:destination:' \
    && ret=0

return ret
