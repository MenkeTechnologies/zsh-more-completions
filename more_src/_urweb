#compdef urweb
# =============================================================================
# urweb — the Ur/Web compiler.  Ur/Web is a strongly-typed functional web
#         programming language by Adam Chlipala (MIT) with an unusually rich
#         type system (dependent record types, type-level metaprogramming via
#         disjointness constraints, exhaustive row polymorphism, integrated
#         transactional SQL with statically-verified well-formedness) that
#         compiles entire web applications — server logic, database schemas,
#         client-side JavaScript, and CSS — from a single Ur/Web source tree
#         to native C, JavaScript, and SQL.  The Ur/Web type system catches
#         SQL injection, broken HTML, JS/server interface mismatches, and
#         dead-link routing at compile time.
#
# Author:  Adam Chlipala
# Source:  https://github.com/urweb/urweb
# CLI:     src/main.mlton.sml (entry point; hand-rolled Standard ML parser)
# Library: hand-rolled `flag_arity` SML datatype (ZERO / ONE / TWO)
# License: BSD-3-Clause
# Status:  Stable — 841+ stars, used in academic research at MIT and in
#          production at several Adam Chlipala-affiliated startups; the
#          compiler is itself written in Standard ML targeting MLton.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — UR/WEB IS NOW LANGUAGE 44
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 43 to 44 documented languages.  Ur/Web joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt, and
# now Ur/Web.  urweb is documented as the FIRST Ur/Web CLI library variant
# in the taxonomy (hand-rolled Standard ML `flag_arity` sum-type-encoded
# parser) — bringing the total to 197 cross-language CLI library variants.
#
# Note: although the urweb binary is itself implemented in STANDARD ML (not
# in Ur/Web — it would be impossible to bootstrap a compiler from a language
# that doesn't yet have a compiler), the binary IS the canonical Ur/Web
# distribution channel, so we document its CLI parser under the Ur/Web entry
# while noting that the parser pattern is canonical Standard ML.
# -----------------------------------------------------------------------------
#
# WHAT IS UR/WEB AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Ur/Web is a domain-specific dialect of "Ur" — Ur being a general-purpose
# functional programming language with a type system more expressive than ML
# or Haskell.  Ur is the work of Adam Chlipala at MIT (formerly CMU), an
# academic in programming-language theory and verified-systems research who
# also created the Bedrock Coq library, the Fiat synthesis framework, and
# the Frap textbook on formal reasoning.
#
# Ur's type system is distinctive on several fronts:
#
#   * DEPENDENT RECORD TYPES with FIELD NAMES at the TYPE LEVEL.  A record
#     `{Name : string, Age : int}` has a type that mentions the field names
#     explicitly; one can quantify over rows, project field types, and prove
#     row-disjointness at compile time.  This is more expressive than
#     Haskell's records (positional + name-mangling), OCaml's records
#     (name-mangled but not row-polymorphic in stdlib), or row-poly via OCaml
#     polymorphic variants.
#   * TYPE-LEVEL METAPROGRAMMING via DISJOINTNESS CONSTRAINTS.  A function
#     can be polymorphic over rows that DO NOT contain a particular field,
#     allowing safe row extension at the type level: `forall (r ::: {Type}).
#     [r ~ [Name = string]] => $r -> $(r ++ [Name = string])`.
#   * STATIC SQL EMBEDDING.  Ur/Web has a SQL DSL embedded in Ur's type
#     system; queries like `SELECT * FROM t WHERE t.A = {[3]}` are type-
#     checked against the database schema declared in the .urs file at
#     compile time.  SQL injection is impossible by construction — there is
#     no string concatenation; column-type-correctness is enforced statically.
#   * INTEGRATED TRANSACTIONAL SEMANTICS.  Every HTTP request runs inside
#     an SQL transaction by default; nested transactions and rollback are
#     expressed via Ur's effect system.
#   * ZERO-RUNTIME ABSTRACTION.  Ur/Web programs are MONOMORPHIZED across
#     records, types, and SQL queries at compile time; the resulting C
#     output has no closures, no boxes, no garbage collector (Ur/Web's
#     server runtime is bump-allocated per request and freed at request
#     end), and is competitive with hand-written C web servers in
#     benchmarks like TechEmpower Round 9.
#   * CLIENT-SIDE FUNCTIONAL REACTIVE UI compiled to JavaScript with the
#     same type system enforcing client-server interface contracts.
#
# Ur/Web is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language with INTEGRATED STATICALLY-TYPED
#     SQL where the type system understands SQL semantics (not just embeds
#     SQL strings).  No other documented language — including Haskell's
#     persistent/esqueleto, Scala's slick, Rust's diesel, OCaml's caqti —
#     has SQL queries that are SYNTACTICALLY part of the language with
#     dependent-type checking against schema declarations.
#   * It is the FIRST documented language designed around the WEB AS THE
#     DEPLOYMENT TARGET — Ur/Web has no other "main" beyond serving HTTP
#     requests with statically-routed URLs; the entire ecosystem assumes
#     web-server semantics.
#   * It compiles to NATIVE C for the server side with NO GARBAGE COLLECTOR
#     and PER-REQUEST BUMP ALLOCATION — every request gets a fresh arena
#     that is freed when the request completes.  This is closer to ATS or
#     SerenityOS-style memory management than to typical FP runtime designs.
#   * It has DISJOINTNESS CONSTRAINTS as a first-class type-system feature,
#     which no other documented language exposes at the type level.
#   * Its .urp PROJECT FILE FORMAT declares per-project compiler flags, file
#     ordering, and database schema in a single declarative manifest that
#     the compiler reads BEFORE parsing any .ur source.
#
# -----------------------------------------------------------------------------
# UR/WEB'S CLI LIBRARY — HAND-ROLLED STANDARD ML `flag_arity` SUM TYPE
# -----------------------------------------------------------------------------
#
# urweb's CLI parser is a small hand-rolled Standard ML implementation in
# src/main.mlton.sml.  It is the SECOND documented Standard-ML-implemented
# CLI parser pattern in the corpus's cross-language taxonomy and the FIRST
# documented "SUM-TYPE-ENCODED FLAG ARITY" approach.
#
# The defining datatype (verbatim from src/main.mlton.sml):
#
#     datatype flag_arity =
#           ZERO of (unit -> unit)
#         | ONE  of string * (string -> unit)
#         | TWO  of string * string * (string * string -> unit)
#
# Each flag is registered as a triple (name, arity, optional-description),
# where the arity wraps the flag's effectful callback together with the
# argument-name placeholders for usage text.  The parser then dispatches
# argument consumption based on the arity tag:
#
#     fun exec (_, ZERO f, _) args =
#             (f (); loop args)
#       | exec (_, ONE (_, f), _) (x :: args) =
#             (f x; loop args)
#       | exec (_, TWO (_, _, f), _) (x :: y :: args) =
#             (f (x, y); loop args)
#       | exec (flag, ONE _, _) [] =
#             raise Fail ("Flag "^flag^" is missing an argument, see -help")
#       | exec (flag, TWO _, _) [] =
#             raise Fail ("Flag "^flag^" is missing two arguments, see -help")
#       | exec (flag, TWO _, _) [_] =
#             raise Fail ("Flag "^flag^" is missing an argument, see -help")
#
# Distinctive properties of this CLI parser pattern:
#
#   * SINGLE-DASH FLAGS ONLY by default (-help, -version, -ccompiler PATH).
#     This matches the X11/Tcl tradition where single-dash long flags are
#     idiomatic, distinct from POSIX/GNU --long-flag convention.
#   * HELP-FLAG NORMALIZATION translates `-h`, `--h`, `--help` all into the
#     canonical `-help` before lookup — this is hand-coded normalization
#     because the underlying parser only knows about single-dash forms.
#   * TWO-ARGUMENT FLAGS (-path NAME VALUE, -root NAME PATH, -limit CLASS NUM)
#     are first-class via the TWO variant.  Most CLI libraries don't support
#     binary flags as a first-class concept — they fake it with `--path=K=V`
#     or by parsing two separate flags.  urweb's design captures the
#     two-argument case explicitly.
#   * EFFECTFUL CALLBACKS — every flag handler is `unit -> unit` (or its
#     curried equivalents), mutating global compiler state via SML refs.
#     This is canonical SML CLI style; functional purity is reserved for
#     the compiler internals, with CLI parsing as a thin imperative
#     scaffold.  Contrast with Argu (F#) where the parse result is a pure
#     value, or with clap-derive (Rust) where flags are struct fields.
#   * NO BUILT-IN VALUE PARSING — flag callbacks receive raw strings and do
#     their own conversion (Int.fromString, Settings.setDbms, etc.).
#     Errors during conversion are raised as `Fail` exceptions caught at
#     the top level.
#   * NO REPEATED-FLAG SEMANTICS — late values overwrite early ones via
#     ref-cell assignment; collecting multiple values requires the callback
#     to maintain its own list.
#   * USAGE TEXT GENERATED by iterating the flag table — the canonical
#     pattern of "data structure as documentation."
#
# CONTRAST WITH OTHER STANDARD ML / OCAML CLI PARSERS
#
#   * OCaml's stdlib `Arg` module — uses a record-of-callbacks pattern
#     similar to urweb's `flag_arity`, but Arg also handles arg parsing
#     (Arg.Int, Arg.Bool, Arg.String) inside the library.  urweb's parser
#     is more minimal: only ZERO/ONE/TWO arities, no type-aware parsing.
#   * MLton's own CLI — different hand-rolled parser, MLton-specific.
#   * Poly/ML's stdlib — has CommandLine module but no flag dispatch.
#   * SMLnj's util — has GetOpt module (Haskell-style) but rarely used.
#   * Mosml's stdlib — has Arg module (compatible with OCaml's Arg).
#
# urweb's parser is therefore CANONICAL for hand-rolled SML CLIs where the
# library author wants total control over flag dispatch and doesn't want
# to depend on Arg's type-aware variants.  It is also the parser pattern
# that compiler authors typically reach for when they want to expose a
# settings system controlled via ref-cell mutation.
#
# -----------------------------------------------------------------------------
# UR/WEB CLI SURFACE (verbatim from src/main.mlton.sml flag_info table)
# -----------------------------------------------------------------------------
#
# USAGE:
#   urweb daemon [stop|start]
#   urweb [flag ...] project-name
#
# Daemon mode keeps a persistent socket (.urweb_daemon) for incremental
# rebuilds.  Project-name is the basename of a .urp file (no extension).
#
# Flags (all SINGLE-DASH per urweb tradition):
#   -help                       Print overview (also: -h, --h, --help)
#   -version                    Print version string and exit
#   -numeric-version            Print numeric version and exit
#   -css                        Print categories of CSS properties
#   -print-ccompiler            Print C compiler and exit
#   -print-cinclude             Print directory of C headers and exit
#   -ccompiler <program>        Set the C compiler
#   -demo <prefix>              Render demo from prefix
#   -guided-demo <prefix>       Render guided demo
#   -tutorial                   Render HTML tutorials from .ur source
#   -protocol [http|cgi|fastcgi|static]   Set server protocol
#   -prefix <prefix>            Prefix used before all URIs
#   -db <string>                Database connection information
#   -dbms [sqlite|mysql|postgres]    Select database engine
#   -debug                      Save intermediate C files
#   -verbose                    Verbose compiler output
#   -timing                     Time compilation phases
#   -tc                         Stop after type checking
#   -dumpTypes                  Print kinds and types
#   -dumpTypesOnError           Print kinds and types if there is an error
#   -unifyMore                  Continue unification before type error
#   -dumpSource                 Print source of last intermediate program on error
#   -dumpVerboseSource          Verbose source dump
#   -output <file>              Output executable as <file>
#   -js <file>                  Serve JavaScript as <file>
#   -sql <file>                 Output SQL script as <file>
#   -endpoints <file>           Output exposed URL endpoints in JSON
#   -static                     Enable static linking
#   -stop <phase>               Stop compilation after <phase>
#   -path <name> <path>         Set path variable <name> to <path> (TWO-arg)
#   -root <name> <path>         Prefix modules in <path> with <name> (TWO-arg)
#   -boot                       Run from build tree, generate static executables
#   -sigfile <file>             Cryptographic signing keys file
#   -iflow                      Enable information-flow analysis
#   -sqlcache                   Enable SQL cache
#   -heuristic <h>              Set SQL cache heuristic
#   -moduleOf <file>            Print module name of <file> and exit
#   -startLspServer             Start Language Server Protocol server
#   -noEmacs                    Disable Emacs interop mode
#   -limit <class> <num>        Resource usage limit (TWO-arg)
#   -explainEmbed               Explain errors about embedding server-side
#                               values in client code
#
# Daemon subcommand:
#   urweb daemon start          Start daemon (background)
#   urweb daemon stop           Stop running daemon (rm socket file)
#
# =============================================================================

_urweb() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a flags daemon_subs protocols dbms_kinds

    flags=(
        '-help[print overview]'
        '-h[print overview (alias)]'
        '--h[print overview (alias)]'
        '--help[print overview (alias)]'
        '-version[print version and exit]'
        '-numeric-version[print numeric version and exit]'
        '-css[print categories of CSS properties]'
        '-print-ccompiler[print C compiler and exit]'
        '-print-cinclude[print directory of C headers and exit]'
        '-ccompiler[set the C compiler]:program:_command_names -e'
        '-demo[render demo from prefix]:prefix:'
        '-guided-demo[render guided demo from prefix]:prefix:'
        '-tutorial[render HTML tutorials from .ur source]'
        '-protocol[set server protocol]:protocol:(http cgi fastcgi static)'
        '-prefix[set URI prefix]:prefix:'
        '-db[database connection string]:dbstring:'
        '-dbms[select database engine]:dbms:(sqlite mysql postgres)'
        '-debug[save intermediate C files]'
        '-verbose[verbose compiler output]'
        '-timing[time compilation phases]'
        '-tc[stop after type checking]'
        '-dumpTypes[print kinds and types]'
        '-dumpTypesOnError[print kinds and types if there is an error]'
        '-unifyMore[continue unification before reporting type error]'
        '-dumpSource[print source of last intermediate program on error]'
        '-dumpVerboseSource[verbose source dump on error]'
        '-output[output executable]:file:_files'
        '-js[serve JavaScript file]:file:_files'
        '-sql[output SQL script]:file:_files'
        '-endpoints[output exposed URL endpoints as JSON]:file:_files'
        '-static[enable static linking]'
        '-stop[stop compilation after phase]:phase:(parse elaborate explify corify monoize fuse pathcheck shake mono jscomp checknest reduce specialize unpoly tag rpcify mark side cjrize cjr cgen oo c)'
        '-path[set path variable]:name: :path:_directories'
        '-root[prefix modules in path with name]:name: :path:_directories'
        '-boot[run from build tree, generate static executables]'
        '-sigfile[cryptographic signing keys file]:file:_files'
        '-iflow[enable information flow analysis]'
        '-sqlcache[enable SQL cache]'
        '-heuristic[set SQL cache heuristic]:heuristic:'
        '-moduleOf[print module name of file and exit]:file:_files'
        '-startLspServer[start Language Server Protocol server]'
        '-noEmacs[disable Emacs interop mode]'
        '-limit[resource usage limit (class num)]:class: :num:'
        '-explainEmbed[explain errors about embedding server-side values in client code]'
    )

    daemon_subs=(
        'start:start daemon (background)'
        'stop:stop running daemon (remove socket file)'
    )

    _arguments -C \
        '1: :->cmd_or_flag' \
        '*: :->rest' && ret=0

    case $state in
        (cmd_or_flag)
            if [[ -z $words[2] || $words[2] == "daemon" ]]; then
                _alternative \
                    'commands:command:((daemon\:start\\\:stop\\ daemon))' \
                    'flags:flag:(($flags))' \
                    'projects:project file (.urp):_files -g "*.urp"' \
                    && ret=0
            fi
            _arguments $flags '*:project (no extension):_files -g "*.urp"' && ret=0
            ;;
        (rest)
            if [[ $line[1] == "daemon" ]]; then
                _describe -t daemon_sub 'daemon subcommand' daemon_subs && ret=0
            else
                _arguments $flags '*:project (no extension):_files -g "*.urp"' && ret=0
            fi
            ;;
    esac

    return ret
}

_urweb "$@"
