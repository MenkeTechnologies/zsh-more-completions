#compdef swift-ring-builder

# swift-ring-builder: manage swift ring files
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a new ring builder'
  'add:add a device'
  'remove:remove a device'
  'set_weight:set device weight'
  'set_info:set device info'
  'set_replicas:set replica count'
  'set_min_part_hours:set minimum partition hours'
  'set_overload:set overload value'
  'rebalance:rebalance the ring'
  'write_ring:write the ring file'
  'write_builder:write the builder file'
  'pretend_min_part_hours_passed:pretend min_part_hours passed'
  'search:search for matching devices'
  'list_parts:list parts on a device'
  'dispersion:dispersion report'
  'validate:validate builder file'
  'warn:warn about issues'
  'default:show defaults'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '1:builder file:_files -g "*.builder"' \
  '2: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'swift-ring-builder command' commands && ret=0 ;;
esac
return ret
