#compdef swift-ring-builder
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/cli/ringbuilder.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a new ring builder file'
  'default:display ring and device information'
  'version:show ring serialization and build version'
  'search:search for matching devices'
  'list_parts:list partitions on matching devices'
  'add:add a device to the ring'
  'set_weight:set device weight'
  'set_region:set device region'
  'set_zone:set device zone'
  'set_info:update device info (ip, port, device, meta)'
  'remove:mark a device for removal'
  'rebalance:rebalance the ring'
  'dispersion:dispersion report'
  'validate:validate the ring builder file'
  'write_ring:write the ring.gz file'
  'write_builder:recreate the builder file from a ring file'
  'pretend_min_part_hours_passed:reset rebalance timing restrictions'
  'set_min_part_hours:set minimum partition movement interval'
  'set_replicas:change replica count'
  'set_overload:set the overload factor'
  'prepare_increase_partition_power:prepare for partition power increase'
  'increase_partition_power:execute partition power increase'
  'cancel_increase_partition_power:cancel partition power increase'
  'finish_increase_partition_power:complete partition power increase'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--yes[assume yes response to all prompts]' \
  '1:builder file:_files -g "*.builder"' \
  '2: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'swift-ring-builder command' commands && ret=0 ;;
esac
return ret
