#compdef pgloader
# Documentation: https://man.archlinux.org/search?q=pgloader
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-E --list-encodings)'{-E,--list-encodings}'[list encodings]' \
  '(-U --upgrade-config)'{-U,--upgrade-config}'[upgrade old config]' \
  '(-l --load-lisp-file)*'{-l+,--load-lisp-file=}'[lisp file]:file:_files -g "*.lisp"' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-S --summary)'{-S+,--summary=}'[summary file]:file:_files' \
  '(-L --logfile)'{-L+,--logfile=}'[log file]:file:_files' \
  '(--log-min-messages)--log-min-messages=[min log level]:l:(NOTICE WARNING ERROR LOG INFO DEBUG)' \
  '(--client-min-messages)--client-min-messages=[client min level]:l:(NOTICE WARNING ERROR LOG INFO DEBUG)' \
  '(-r --root-dir)'{-r+,--root-dir=}'[root dir]:dir:_files -/' \
  '(-D --dry-run)'{-D,--dry-run}'[dry run]' \
  '(-F --field-separator)'{-F+,--field-separator=}'[field separator]:s:' \
  '(--no-ssl-cert-verification)--no-ssl-cert-verification[no SSL cert verify]' \
  '(--regress)--regress[regression mode]' \
  '(--type)--type=[source type]:t:(csv mysql sqlite postgres ixf db3 mssql copy fixed)' \
  '(--with)*--with=[load option]:o:' \
  '(--field)*--field=[field spec]:f:' \
  '(--cast)*--cast=[cast rule]:c:' \
  '(--encoding)--encoding=[encoding]:e:' \
  '(--before)--before=[before SQL file]:file:_files' \
  '(--after)--after=[after SQL file]:file:_files' \
  '(--self-upgrade)--self-upgrade=[self upgrade dir]:dir:_files -/' \
  '(--no-ssl)--no-ssl[no SSL]' \
  '(--on-error-stop)--on-error-stop[stop on error]' \
  '(--on-error-resume-next)--on-error-resume-next[resume on error]' \
  '(--option)*--option=[option]:o:' \
  '(--set)*--set=[postgres SET option]:o:' \
  '(--target)--target=[target URI]:url:' \
  '*: :_files -g "*.load"' && ret=0

return ret
