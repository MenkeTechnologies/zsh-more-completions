#compdef tempo

_arguments -s \
  '-config.file=[config file]:file:_files -g "*.(yaml|yml)"' \
  '-config.expand-env[expand env vars in config]' \
  '-config.verify[verify config and exit]' \
  '-target=[target module]:target:(all distributor ingester querier query-frontend compactor metrics-generator scheduler block-builder single-binary)' \
  '-auth.enabled[enable multitenancy (deprecated)]' \
  '-mem-ballast-size-mbs=[memory ballast size in MB]:mb:' \
  '(- *)-version[show version]'
