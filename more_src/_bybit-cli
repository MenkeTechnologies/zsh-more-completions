#compdef bybit-cli bybit
# _bybit-cli — Bybit bybit-cli CLI command-line frontend wrapping the Bybit cryptocurrency exchange Spot Derivatives USDT-Perpetual USDC-Perpetual Inverse-Perpetual Inverse-Futures Options Copy-Trade Unified-Trading-Account API managing positions orders trades market kline tickers depth funding wallet asset transfer (Bybit team, Go); cobra
# upstream: https://www.bybit.com/

_bybit-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'wallet:wallet operations'
        'position:position operations'
        'order:order operations'
        'trade:trade operations'
        'kline:kline candlestick data'
        'ticker:ticker operations'
        'depth:order book depth'
        'funding:funding operations'
        'asset:asset operations'
        'transfer:transfer operations'
        'subaccount:sub-account management'
        'spot:spot operations'
        'derivative:derivative operations'
        'copy:copy trade operations'
        'unified:unified account operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--testnet[use testnet]' \
        '--category=+[c]:c:(spot linear inverse option)' \
        '--recv-window=+[ms]:n:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bybit-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all amend history)' \
                    '--symbol=+[sym]:str:' \
                    '--side=+[s]:s:(Buy Sell)' \
                    '--order-type=+[t]:t:(Market Limit)' \
                    '--qty=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '--time-in-force=+[t]:t:(GTC IOC FOK PostOnly)' \
                    '*:order id:' ;;
                position|wallet|account|trade|funding|asset|transfer|subaccount|spot|derivative|copy|unified) _arguments '1:op:(list get create update delete cancel)' '*:id:' ;;
                kline|ticker|depth) _arguments \
                    '--symbol=+[sym]:str:' \
                    '--interval=+[i]:i:(1 3 5 15 30 60 120 240 360 720 D W M)' \
                    '--limit=+[N]:n:' ;;
            esac
            ;;
    esac
}

_bybit-cli "$@"
