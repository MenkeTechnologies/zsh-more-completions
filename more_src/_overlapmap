#compdef overlapmap
# CCP4: average, combine, or correlate electron-density maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'MAPIN1[first input map]:map:_files -g "*.(map|ccp4)"' \
  'MAPIN2[second input map]:map:_files -g "*.(map|ccp4)"' \
  'MAPIN3[third input map]:map:_files -g "*.(map|ccp4)"' \
  'MAPOUT[output map]:map:_files' \
  '*:keyword:(MAP CORRELATE CHAIN PATTERSON END)' && ret=0

return ret
