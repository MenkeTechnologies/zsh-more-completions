#compdef dumb-init

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --single-child)'{-c,--single-child}'[run in single-child mode]' \
  '(-r --rewrite)'{-r,--rewrite}'[rewrite signal]:signal mapping (SRC\:DST)' \
  '(-v --verbose)'{-v,--verbose}'[print debugging information]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:_command_names -e' \
  '*::args:_normal' && ret=0

return ret
