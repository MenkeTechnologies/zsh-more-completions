#compdef heif-convert
# _heif-convert — Strukturag libheif heif-convert HEIF/HEIC decoder CLI (Struktur AG / strukturag, C++); custom argparse
# upstream: https://github.com/strukturag/libheif

_heif-convert() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quality=+[output quality]:n:' \
        '-q+[output quality]:n:' \
        '--decoder=+[decoder]:d:(libde265 dav1d default)' \
        '-d+[decoder]:d:(libde265 dav1d default)' \
        '--list-decoders[list decoders]' \
        '--with-aux[also write auxiliary images]' \
        '--with-xmp[write XMP metadata]' \
        '--with-exif[write EXIF metadata]' \
        '--no-colons[no colons in output filename]' \
        '--no-spaces[no spaces in output filename]' \
        '--png-compression-level=+[png compression]:n:' \
        '--no-output[no output]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--quiet[quiet]' \
        '*:file:_files -g "*.heic *.heif *.avif *.png *.jpg"'
}

_heif-convert "$@"
