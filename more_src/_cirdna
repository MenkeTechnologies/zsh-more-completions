#compdef cirdna

# EMBOSS cirdna: schematic circular DNA map (e.g. plasmid)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-inputfile=[cirdna input definition file]:file:_files' \
  '-maxgroups=[maximum number of groups]:n:' \
  '-maxlabels=[maximum number of labels]:n:' \
  '-ruler[show position ruler]' \
  '-blocktype=[block fill style]:style:(Open Filled Outline)' \
  '-originangle=[angle for sequence origin (degrees)]:angle:' \
  '-posticks=[label tick position]:pos:(In Out)' \
  '-posblocks=[block label position]:pos:(In Out)' \
  '-intersymbol=[symbol between blocks]:symbol:(Straight Up Down)' \
  '-intercolour=[colour between blocks]:colour:' \
  '-interticks[show ticks at block boundaries]' \
  '-tickheight=[tick height]:n:' \
  '-blockheight=[block height]:n:' \
  '-rangeheight=[range height]:n:' \
  '-gapgroup=[gap between groups]:n:' \
  '-postext=[position label text]:pos:(In Out Above Below)' \
  '-textheight=[text height]:n:' \
  '-textlength=[text length]:n:' \
  '-graphout=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:cirdna input file:_files' && ret=0
return ret
