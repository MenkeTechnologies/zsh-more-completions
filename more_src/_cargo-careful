#compdef cargo-careful

# Zsh completion for cargo-careful (careful Rust compilation with extra UB checks)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:Compile with extra careful checks'
      'run:Run a binary with extra careful checks'
      'test:Run tests with extra careful checks'
      'setup:Install the careful toolchain sysroot'
    )
    _describe -t commands 'cargo-careful command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build|run|test)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-p+[Package to build]:package' \
          '--package=[Package to build]:package' \
          '--all[Build all packages in the workspace]' \
          '--workspace[Build all packages in the workspace]' \
          '--release[Build in release mode]' \
          '--target=[Target triple]:target' \
          '--features=[Space or comma separated list of features]:features' \
          '--all-features[Activate all available features]' \
          '--no-default-features[Do not activate default features]' \
          '-j+[Number of parallel jobs]:jobs' \
          '--jobs=[Number of parallel jobs]:jobs' \
          '-v[Use verbose output]' \
          '--verbose[Use verbose output]' \
          '*:args' && ret=0
        ;;
      setup)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--target=[Target triple for sysroot]:target' && ret=0
        ;;
    esac
    ;;
esac

return ret
