#compdef cargo-careful
# Documentation: https://github.com/RalfJung/cargo-careful
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cargo-careful: run cargo test/run with extra checks against undefined behavior.
# Upstream documents only `test` and `run`; all standard cargo flags are passed through.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'test:run tests with extra careful checks'
      'run:run a binary with extra careful checks'
      'setup:install the careful sysroot (rebuilds std with checks)'
    )
    _describe -t commands 'cargo-careful command' commands && ret=0
    ;;
  args)
    # Forward to standard cargo test/run/build argument completion where possible.
    _arguments -s -S \
      '--target=[target triple]:target:' \
      '*: :_default' && ret=0
    ;;
esac

return ret
