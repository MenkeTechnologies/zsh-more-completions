#compdef rhofit
# Documentation: https://www.globalphasing.com/buster/manual/rhofit/manual/
# BUSTER rhofit - automated ligand fitting into difference electron density

local ret=1

_arguments -s -S \
  '(-h)-h[quick help message listing most important arguments]' \
  '-l[restraint dictionary for ligand (CCP4-style CIF or TNT)]:dictionary:_files' \
  '-keepH[keep hydrogen atoms in the fit]' \
  '-nochirals[ignore all CHIRAL cards; allow chiral centres to invert]' \
  '-scanchirals[try every possible permutation of chiralities]' \
  '-scanchiralsboth[sample only chiralities marked as both in dictionary]' \
  '-scanchiral[try explicit comma-separated list of chiral atom names]:atoms' \
  '-trustplanes[turn off plane-breaking and torsion-plateauing machinery]' \
  '-lp[seed rhofit with particular starting position]:ligand pdb:_files' \
  '-m[MTZ file for difference density]:mtz:_files' \
  '-p[PDB file for protein/ligand clash determination]:pdb:_files' \
  '-clusterweight[weight for difference density score]:weight' \
  '-clashweight[weight for ligand-protein clash score]:weight' \
  '-sctrimb[B range threshold for poorly placed side chains]:value' \
  '-xclusters[use best n clusters for ligand fitting]:n' \
  '-allclusters[find ligand binding fits for every cluster]' \
  '-c[filename of single cluster for ligand fitting]:cluster:_files' \
  '-C[filename of file containing list of clusters]:list:_files' \
  '-prf.c[control prep_rhofit significance cut-off values]:value' \
  '-prf.V[control volume used in prep_rhofit]:value' \
  '-thorough[run more trials than usual]' \
  '-quick[run three times fewer trials than usual]' \
  '-nocorrel[skip correlation coefficient assessment after fitting]' \
  '-correlsort[reorder hits by correlation coefficient alone]' \
  '-randskip[use different random number series for reruns]' \
  '-d[directory for final results]:dir:_files -/' \
  '-td[directory for temporary data during run]:dir:_files -/' \
  '-resnum[residue number for output files]:number' \
  '-hitmaxn[maximum number of hits to output]:n' \
  '-hitmaxd[distance threshold for identical hits]:angstroms' \
  '-hitfncut[function value cut-off for output hits]:value' \
  '*:file:_files' && ret=0

return ret
