#compdef cacheensembl
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/cacheensembl.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS cacheensembl: generate server cache file for ENSEMBL.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-servername=[ENSEMBL server name (EMBOSS resource)]:server:' \
  '-cachefile=[server cache output file]:file:_files' \
  '-outfile=[output report file]:file:_files' \
  '-odirectory=[output directory for -outfile]:dir:_files -/' \
  '-odirectory1=[output directory for -cachefile]:dir:_files -/' \
  '-odirectory_cachefile=[output directory for -cachefile]:dir:_files -/' \
  '-auto[turn off prompts]' \
  '-stdout[write first file to standard output]' \
  '-filter[read stdin, write stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug log to program.dbg]' \
  '-verbose[report command-line options]' \
  '-help[display help and exit]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report version and exit]' && ret=0

return ret
