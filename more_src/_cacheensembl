#compdef cacheensembl

# EMBOSS cacheensembl: build/refresh DRCAT entry cache file
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-outfile=[output cache filename]:file:_files' \
  '-servername=[server name to query]:server:' \
  '-cachefile=[cache file to write]:file:_files' \
  '-dbname=[database name]:database:' \
  '*:argument:' && ret=0

return ret
