#compdef dvilj dvilj2p dvilj4 dvilj4l dvilj6
# Documentation: dvilj usage (dviljk 2.6p5)
# Source: DVI to HP LaserJet PCL converter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[number of copies]:n:' \
    '-C+[compression mode for raster chars]:mode:(0 2 3)' \
    '-d+[duplex mode]:mode:(1\:long-edge 2\:short-edge)' \
    '-D-[doublepage output]:half:(1\:odd 2\:even)' \
    '-E[print in econo-mode]' \
    '-e+[output file]:file:_files' \
    '-f+[print from page number]:from:' \
    '-g[do not reset printer at begin of job]' \
    '-h+[name of header file]:file:_files' \
    '-l[landscape mode]' \
    '-M+[do not generate missing PK files]:flag:' \
    '-m+[magnification]:mag:(0 h 1 2 3 4 5)' \
    '-n[download fonts raw (default compressed)]' \
    '-p+[print N pages]:n:' \
    '-q[quiet operation]' \
    '-r[process pages in reverse order]' \
    '-R+[set resolution dpi]:dpi:(300 600)' \
    '-s+[paper size]:size:(letter legal a4 a3 b5)' \
    '-t+[print to end of page number]:to:' \
    '-w[do not print warnings]' \
    '-W+[minimum width of compressed chars (default 0)]:n:' \
    '-v[show which pixel-files are used]' \
    '-V+[vendor options]:vendor:(kyocera brother)' \
    '-x+[x-offset on printout in mm]:mm:' \
    '-y+[y-offset on printout in mm]:mm:' \
    '-X+[x page origin in dots]:dots:' \
    '-Y+[y page origin in dots]:dots:' \
    '-z[print test page with pagecounter after job]' \
    '1:dvi file:_files -g "*.dvi"' \
    && ret=0

return ret
