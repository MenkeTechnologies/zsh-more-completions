#compdef mris_compute_lgi
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/LGI
# Compute the local gyrification index (lGI) for a surface

local ret=1

_arguments -s -S \
  '--i[input surface file]:file:_files' \
  '--input[input surface file]:file:_files' \
  '--close_sphere_size[sphere size for morphological closing (mm)]:mm:' \
  '--smooth_iters[smoothing iterations for outer surface]:iters:' \
  '--step_size[vertex skip interval when computing lGI]:steps:' \
  '--dont_extract[disable main component extraction]' \
  '--help[display help]' \
  '--version[show version]' \
  '--echo[enable command echoing]' \
  '--debug[enable command echoing]' \
  '--dontrun[display commands without executing]' && ret=0

return ret
