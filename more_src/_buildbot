#compdef buildbot
# Documentation: https://docs.buildbot.net/latest/manual/cmdline.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (and master/buildbot/scripts/runner.py).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create-master:populate a directory as a buildmaster base'
  'upgrade-master:upgrade an existing buildmaster directory'
  'start:start a buildmaster'
  'stop:stop a buildmaster'
  'restart:restart a buildmaster'
  'reconfig:SIGHUP a buildmaster to re-read its config file'
  'sighup:SIGHUP a buildmaster to re-read its config file'
  'checkconfig:validate master.cfg'
  'sendchange:send a Change to a buildmaster'
  'try:run a build with your local changes'
  'tryserver:buildmaster-side try support function (internal)'
  'user:add/show/remove/update users'
  'cleanupdb:cleanup the database'
  'copy-db:copy data between two databases'
  'dataspec:output data api spec'
  'dev-proxy:run a fake web server serving the local ui frontend'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'buildbot command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create-master)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-r --relocatable)'{-r,--relocatable}'[generate paths relative to base]' \
          '--config=[master.cfg name]:file:_files' \
          '(-l --log-size)'{-l+,--log-size=}'[log file size before rotation]:n:' \
          '(-n --log-count)'{-n+,--log-count=}'[number of log files to keep]:n:' \
          '--db=[database connection URL]:url:' \
          '*::basedir:_files -/' && ret=0 ;;
      (start|restart)
        _arguments \
          '--nodaemon[do not daemonize]' \
          '--no_save[do not save master.cfg]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*::basedir:_files -/' && ret=0 ;;
      (stop)
        _arguments \
          '--clean[clean shutdown]' \
          '--no-wait[do not wait for shutdown]' \
          '*::basedir:_files -/' && ret=0 ;;
      (sendchange)
        _arguments \
          '(-m --master)'{-m+,--master=}'[master host:port]:host:' \
          '(-a --auth)'{-a+,--auth=}'[user:password]:auth:' \
          '(-W --who)'{-W+,--who=}'[changing user]:user:' \
          '(-R --revision)'{-R+,--revision=}'[revision]:rev:' \
          '(-b --branch)'{-b+,--branch=}'[branch]:branch:' \
          '(-C --category)'{-C+,--category=}'[change category]:category:' \
          '(-P --project)'{-P+,--project=}'[project]:project:' \
          '(-r --repository)'{-r+,--repository=}'[repository URL]:repo:' \
          '*--property=[name:value property]:kv:' \
          '*::files:_files' && ret=0 ;;
      (try)
        _arguments \
          '--connect=[connection method]:method:(ssh pb)' \
          '--master=[master host:port]:host:' \
          '--username=[username]:user:' \
          '--passwd=[password]:pwd:' \
          '--diff=[diff file]:file:_files' \
          '--patchlevel=[patch level]:n:' \
          '--baserev=[base revision]:rev:' \
          '*--builder=[builder to use]:builder:' \
          '*--properties=[k=v properties]:kv:' \
          '--get-builder-names[list builders and exit]' \
          '--wait[wait for build result]' && ret=0 ;;
      (user)
        _arguments \
          '*::sub:(add remove get update)' && ret=0 ;;
    esac ;;
esac

return ret
