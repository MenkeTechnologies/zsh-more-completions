#compdef weighttp
# Documentation: https://man.archlinux.org/search?q=weighttp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-n+[total requests]:n:' \
  '-c+[concurrent clients]:n:' \
  '-t+[threads]:n:' \
  '-k[use keep-alive]' \
  '-K+[connection close after N requests]:n:' \
  '-H+[add header]:header:' \
  '-C+[cookie]:cookie:' \
  '-A+[basic auth user:pass]:auth:' \
  '-P+[POST data file]:file:_files' \
  '-T+[content type]:type:' \
  '-X+[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
  '-6[use IPv6]' \
  '-q[quiet]' \
  '-d[show debug]' \
  '*:url:' && ret=0

return ret
