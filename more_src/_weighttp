#compdef weighttp
# Documentation: https://github.com/lighttpd/weighttp
# Reference accessed: 2026-05-21
# Verified: upstream src/weighttp.c show_help() at the URL above.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '-h[show help and exit]' \
  '-V[show version and exit]' \
  '-n+[number of requests (mandatory)]:num:' \
  '-t+[thread count]:num:' \
  '-c+[concurrent clients]:num:' \
  '-k[keep alive]' \
  '-K+[number of pipelined requests]:num:' \
  '-6[use IPv6]' \
  '-i[use HTTP HEAD method]' \
  '-m+[custom HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
  '*-H+[add header (label: value); repeatable]:header:' \
  '-b+[socket buffer sizes (SO_SNDBUF, SO_RCVBUF)]:size:' \
  '-B+[local address to bind to]:addr:' \
  '*-C+[add cookie (cookie-name=value); repeatable]:cookie:' \
  '-F[use TCP Fast Open (RFC 7413)]' \
  '-T+[Content-Type header for POST/PUT data]:type:' \
  '-A+[Basic WWW Authorization (user:pass)]:auth:' \
  '-P+[Basic Proxy-Authorization (user:pass)]:auth:' \
  '-X+[proxy host:port or unix socket path]:proxy:' \
  '-p+[POST request body file]:file:_files' \
  '-u+[PUT request body file]:file:_files' \
  '-d[do not report extended percentiles]' \
  '-S[do not show standard deviation confidence warnings]' \
  '-l[ignored (ab compatibility)]' \
  '-e+[output CSV file with percentage timings]:file:_files' \
  '-r[ignored (ab compatibility)]' \
  '-a+[max seconds to run benchmark]:seconds:' \
  '-s+[seconds to cutoff fails]:seconds:' \
  '-q[quiet: no version header or progress]' \
  '*:url:' && ret=0
return ret
