#compdef drsnoop drsnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/drsnoop.py argparse)
# Reference accessed: 2026-05-29
# drsnoop — trace direct memory reclaim events (alloc_pages slowpath) (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-U --print-uid)'{-U,--print-uid}'[print UID column]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-t --tid)'{-t,--tid=}'[trace this TID only]:tid:' \
  '(-u --uid)'{-u,--uid=}'[trace this UID only]:uid:' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace in seconds]:sec:' \
  '(-n --name)'{-n,--name=}'[only print process names containing this name]:name:' \
  '(-v --verbose)'{-v,--verbose}'[show system memory state]' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
