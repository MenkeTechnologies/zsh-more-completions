#compdef cbor-edn
# Documentation: https://man.archlinux.org/search?q=cbor-edn
# Reference accessed: 2026-05-16

# https://codeberg.org/chrysn/cbor-edn — src/bin/cbor-edn.rs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _cbor_cmds
    _cbor_cmds=(
      'diag2cbor:EDN to CBOR'
      'cbor2diag:CBOR to diagnostic notation'
      'diag2diag:normalize diagnostic notation'
    )
    _describe -t commands 'cbor-edn mode' _cbor_cmds && ret=0
    ;;
esac

return ret
