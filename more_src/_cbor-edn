#compdef cbor-edn
# Documentation: https://codeberg.org/chrysn/cbor-edn
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cbor-edn binary from the cbor-edn Rust crate
# Documented subcommand: diag2diag. Additional subcommands (diag2cbor, cbor2diag)
# are commonly available in the same family of tools and kept as completions.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _cbor_cmds
    _cbor_cmds=(
      'diag2cbor:EDN to CBOR'
      'cbor2diag:CBOR to diagnostic notation'
      'diag2diag:normalize diagnostic notation'
    )
    _describe -t commands 'cbor-edn mode' _cbor_cmds && ret=0
    ;;
esac

return ret
