#compdef bugsnag-cli
# _bugsnag — Bugsnag error monitoring CLI (bugsnag)
# upstream: https://github.com/bugsnag/bugsnag-cli

_bugsnag() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'upload:upload symbol/mapping files'
        'create-build:notify Bugsnag of a new build'
    )

    _arguments -C \
        '--api-key=[Bugsnag API key]:key:' \
        '--app-version=[application version]:version:' \
        '--builder-name=[builder name]:name:' \
        '--endpoint=[Bugsnag endpoint URL]:url:' \
        '--timeout=[request timeout]:seconds:' \
        '--retries=[number of retries]:n:' \
        '--overwrite[overwrite existing files]' \
        '--dry-run[simulate without uploading]' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'bugsnag-cli command' commands && ret=0 ;;
        args)
            case $line[1] in
                upload)
                    _arguments \
                        '--api-key=[Bugsnag API key]:key:' \
                        '--app-version=[application version]:version:' \
                        '--overwrite[overwrite existing files]' \
                        '--dry-run[simulate without uploading]' \
                        '*:file:_files' && ret=0 ;;
                create-build)
                    _arguments \
                        '--api-key=[Bugsnag API key]:key:' \
                        '--app-version=[application version]:version:' \
                        '--builder-name=[builder name]:name:' \
                        '--source-control-provider=[provider]:provider:(github gitlab bitbucket)' \
                        '--source-control-repository=[repo URL]:url:' \
                        '--source-control-revision=[revision]:rev:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_bugsnag "$@"
