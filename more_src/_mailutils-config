#compdef mailutils-config
# Documentation: https://manpages.debian.org/bullseye/libmailutils-dev/mailutils-config.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--compile[print compile flags]' \
  '--link[print linker flags]' \
  '--info[print Mailutils info]' \
  '--query=-[query a configuration variable]:variable:' && ret=0

return ret
