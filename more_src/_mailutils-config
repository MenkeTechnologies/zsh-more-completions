#compdef mailutils-config
# Documentation: https://man.archlinux.org/search?q=mailutils-config
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--compile[print compile flags]' \
  '--link[print linker flags]' \
  '--info[print Mailutils info]' \
  '--query=-[query a configuration variable]:variable:' && ret=0

return ret
