#compdef pwqfilter

_arguments -s \
  '--lookup[lookup mode]' \
  '--status[show status]' \
  '--create=[capacity]:n:' \
  '--insert[insert into existing]' \
  '--test-fp-rate[estimate FP rate]' \
  '--optimize-fp-rate[optimize FP rate]' \
  '--optimize-fp-rate-at-high-load[optimize at high load]' \
  '(-f --filter)'{-f,--filter}'=[input filter]:file:_files' \
  '(-o --output)'{-o,--output}'=[output filter]:file:_files' \
  '--pre-hashed[input hex hashes]' \
  '--hash-md4[MD4 hash]' \
  '--hash-ntlm-cp1252[NTLM hash]' \
  '(-c --count)'{-c,--count}'[count]' \
  '(-n --line-number)'{-n,--line-number}'[line number]' \
  '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
  '--verbose[verbose]' \
  '--version[show version]' \
  '(- *)'{-h,--help}'[show help]'
