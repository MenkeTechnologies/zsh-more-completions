#compdef carthage

# Zsh completion for Carthage - Cocoa dependency manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'archive:archive built frameworks into a zip file'
  'bootstrap:check out and build the projects dependencies'
  'build:build the projects dependencies'
  'checkout:check out the projects dependencies'
  'cleanup:clean up unused dependencies'
  'copy-frameworks:in a Run Script, copy linked Carthage frameworks'
  'fetch:clone or fetch a Git repository ahead of time'
  'outdated:check for compatible updates to dependencies'
  'update:update and rebuild the projects dependencies'
  'validate:validate Cartfile.resolved'
  'version:display the current version of Carthage'
  'help:show available commands or help for a command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'carthage command' commands && ret=0
    ;;
  (args)
    local -a common_build=(
      '--platform[platforms to build for]:platform:(all iOS macOS tvOS watchOS visionOS)'
      '--configuration[Xcode configuration to build]:configuration:(Debug Release)'
      '--derived-data[path to derived data folder]:path:_files -/'
      '--toolchain[toolchain to build with]:toolchain:'
      '--project-directory[directory in which to run command]:path:_files -/'
      '--log-path[path to log build output]:path:_files'
      '--use-xcframeworks[produce xcframework bundles]'
      '--no-use-xcframeworks[do not produce xcframework bundles]'
      '--use-netrc[use authentication credentials from .netrc]'
      '--use-ssh[use SSH for cloning]'
      '--use-submodules[add dependencies as Git submodules]'
      '--use-binaries[prefer downloadable binaries]'
      '--no-use-binaries[do not use downloadable binaries]'
      '--cache-builds[reuse cached builds when possible]'
      '--new-resolver[use the new resolver]'
      '--no-skip-current[build the current project too]'
      '--color[output colorization]:mode:(auto always never)'
      '--verbose[verbose output]'
      '--no-verbose[disable verbose output]'
      '--lock-timeout[timeout in seconds for locking]:seconds:'
      '--github-api-token[GitHub API token]:token:'
    )
    case $line[1] in
      (bootstrap|update|build)
        _arguments $common_build '*:dependency:' && ret=0
        ;;
      (checkout|fetch)
        _arguments \
          '--use-ssh[use SSH for cloning]' \
          '--project-directory[project directory]:path:_files -/' \
          '*:dependency:' && ret=0
        ;;
      (archive)
        _arguments \
          '--output[path to write the archive]:file:_files' \
          '--project-directory[project directory]:path:_files -/' \
          '--color[colorization]:mode:(auto always never)' \
          '*:framework name:' && ret=0
        ;;
      (outdated)
        _arguments \
          '--xcode-warnings[print as Xcode warnings]' \
          '--verbose[verbose output]' \
          '--project-directory[project directory]:path:_files -/' && ret=0
        ;;
      (copy-frameworks)
        _arguments '--use-xcframeworks[use xcframeworks]' && ret=0
        ;;
      (cleanup)
        _arguments \
          '--project-directory[project directory]:path:_files -/' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
