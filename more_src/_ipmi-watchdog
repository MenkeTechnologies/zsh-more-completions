#compdef ipmi-watchdog

# ipmi-watchdog: control IPMI watchdog timer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-D --driver-type)'{-D,--driver-type=}'[driver type]:type:(KCS SSIF OPENIPMI SUNBMC INTELDCMI)' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-s --start)'{-s,--start}'[start watchdog timer]' \
  '(-r --reset)'{-r,--reset}'[reset watchdog timer]' \
  '(-S --stop)'{-S,--stop}'[stop watchdog timer]' \
  '(-G --get)'{-G,--get}'[get current watchdog config]' \
  '(-c --clear)'{-c,--clear}'[clear watchdog status]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout (seconds)]:n:' \
  '(-T --timer-use)'{-T,--timer-use=}'[timer use]:use:(BIOS_FRB2 BIOS_POST OS_LOAD SMS_OS OEM)' \
  '(-a --action)'{-a,--action=}'[expiration action]:act:(NO_ACTION HARD_RESET POWER_DOWN POWER_CYCLE)' \
  '(-p --pretimeout-interval)'{-p,--pretimeout-interval=}'[pre-timeout (sec)]:n:' \
  '*::ipmi-watchdog args:_files' && ret=0
return ret
