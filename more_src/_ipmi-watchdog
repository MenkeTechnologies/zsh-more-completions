#compdef ipmi-watchdog
# Documentation: https://man.archlinux.org/search?q=ipmi-watchdog
# Reference accessed: 2026-05-16

# ipmi-watchdog: configure/heartbeat the BMC watchdog timer (FreeIPMI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-D[IPMI driver]:driver:(KCS SSIF OPENIPMI SUNBMC INTELDCMI)' \
  '--driver-type=[IPMI driver]:driver:(KCS SSIF OPENIPMI SUNBMC INTELDCMI)' \
  '--driver-address=[driver address]:addr:' \
  '--driver-device=[driver device]:dev:_files' \
  '--register-spacing=[register spacing]:n:' \
  '-s[start watchdog]' \
  '--start[start watchdog]' \
  '-S[stop watchdog]' \
  '--stop[stop watchdog]' \
  '-r[reset (heartbeat) watchdog]' \
  '--reset[reset (heartbeat) watchdog]' \
  '-g[get watchdog config]' \
  '--get[get watchdog config]' \
  '-c[clear (cancel) watchdog]' \
  '--clear[clear (cancel) watchdog]' \
  '-u[timer use]:use:(BIOSFRB2 BIOSPOST OSLOAD SMSOS OEM)' \
  '--timer-use=[timer use]:use:(BIOSFRB2 BIOSPOST OSLOAD SMSOS OEM)' \
  '-a[timer action on expire]:action:(NONE HARDRESET POWERDOWN POWERCYCLE)' \
  '--timer-action=[timer action on expire]:action:(NONE HARDRESET POWERDOWN POWERCYCLE)' \
  '-p[pre-timeout interrupt]:int:(NONE SMI NMI MSGINT)' \
  '--pre-timeout-interrupt=[pre-timeout interrupt]:int:(NONE SMI NMI MSGINT)' \
  '-P[pre-timeout interval seconds]:seconds:' \
  '--pre-timeout-interval=[pre-timeout interval seconds]:seconds:' \
  '-i[initial countdown seconds]:seconds:' \
  '--initial-countdown=[initial countdown seconds]:seconds:' \
  '--start-after-set[start watchdog after setting params]' \
  '--reset-after-set[reset watchdog after setting params]' \
  '--logfile=[log file]:file:_files' \
  '--no-logging[disable logging]' \
  '--daemon[run as daemon]' \
  '*::ipmi-watchdog args:_files' && ret=0
return ret
