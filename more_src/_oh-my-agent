#compdef oh-my-agent oma
# Documentation: https://github.com/first-fluke/oh-my-agent
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above; binary is `oma`.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'agent\:parallel:execute multiple agents in parallel'
  'agent\:spawn:launch a single agent with a task'
  'dashboard:monitor agents in real-time'
  'doctor:run installation health checks'
  'image:image subcommands'
  'link:regenerate native agent definitions from .agents/'
  'model\:check:detect mismatches between registered and live vendor models'
  'recap:summarize conversation history across tools'
  'retro:generate engineering retrospectives'
  'search:search subcommands'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'oh-my-agent command' commands && ret=0 ;;
  args)
    case $words[1] in
      recap)
        _arguments '--window=[time window for history]:duration' && ret=0
        ;;
      retro)
        _arguments '--compare[include trend analysis]' && ret=0
        ;;
      doctor)
        _arguments '--profile[show per-role model assignments]' && ret=0
        ;;
      image)
        _arguments '1:subcommand:(generate)' && ret=0
        ;;
      search)
        _arguments '1:subcommand:(fetch)' && ret=0
        ;;
    esac
    ;;
esac

return ret
