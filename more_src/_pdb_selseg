#compdef pdb_selseg
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Selects all segments matching the given segment id(s), e.g. -C or -C,D

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[segment id(s) to select, e.g. -C or -C,D]:segment id' \
  '*:PDB file:_files' && ret=0

return ret
