#compdef create-medusa-app
# Documentation: https://www.npmjs.com/package/create-medusa-app
# Reference accessed: 2026-05-23
# Verified: npx create-medusa-app --help.

# Zsh completion for create-medusa-app - Medusa commerce backend scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--plugin[create a plugin instead of a project]' \
  '--repo-url=[repository URL]:url:' \
  '--version=[Medusa package version]:version:' \
  '--seed[seed database with demo data]' \
  '--skip-db[skip database creation and migrations]' \
  '--db-url=[database URL]:url:' \
  '--no-migrations[skip migrations and admin setup]' \
  '--no-browser[do not open browser after creation]' \
  '--directory-path=[install directory]:dir:_directories' \
  '--with-nextjs-starter[install Next.js starter with backend]' \
  '--verbose[show underlying command logs]' \
  '--use-npm[use npm as package manager]' \
  '--use-yarn[use yarn as package manager]' \
  '--use-pnpm[use pnpm as package manager]' \
  ':project name:' && ret=0

return ret
