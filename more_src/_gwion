#compdef gwion
# =============================================================================
# gwion — Gwion/Gwion's "Gwion" programming
#   language — a STRONGLY-TIMED MUSIC-MAKING
#   language with FIRST-CLASS TIME as a base
#   type, deterministic preemptive scheduling
#   between concurrent "shreds" (lightweight
#   threads), and synchronous side-effects
#   against an audio I/O graph.  Strongly
#   inspired by ChucK (Stanford CCRMA's audio
#   programming language) but adding HIGH-
#   LEVEL features: templating, first-class
#   functions, operator overloading, optional/
#   unsafe types, pattern matching, async/
#   await on shred join, and a plugin-host
#   architecture for binding C audio
#   libraries.  Implementation is pure C with
#   a bytecode VM and a thread-pool-backed
#   shred scheduler.  129th language entry in
#   the corpus.
#
# 129TH LANGUAGE ENTRY — Gwion closes the 3+1
# micro-cycle started after Axis 49 (WebAssembly
# Runtime) closed at 1/1/1 three-language
# symmetry in R787 (TS-Node=104
# `_fastedge-build` on @bytecodealliance/jco
# v1.17.6 + R786 Go=104 `_grpcfedctl` on
# tetratelabs/wazero v1.10.1 + R785 Rust=104
# `_wassette` on wasmtime 36.0.5).
#
# Distinguishing Gwion from the 128 prior corpus
# languages — closest neighbours and their
# differences:
#   - CHUCK (`_chuck`): the parent language.
#     Same "strongly-timed" + "shred" concurrency
#     model, same synchronous audio-graph
#     binding via the `=>` chuck-operator.  But
#     ChucK is older (Stanford, 2002), single-
#     paradigm, no templates, no first-class
#     functions, no optional types.  Gwion is
#     ChucK-compatible (most ChucK code runs
#     under Gwion) but adds modern features
#   - SUPERCOLLIDER (`_sclang`, `_scsynth`,
#     `_supernova`): another live-coding
#     audio language.  SuperCollider is a
#     SmallTalk-derived OOP language with
#     a SEPARATE audio server.  Gwion is
#     C-syntax-derived with an EMBEDDED
#     audio thread.  SC's `s.boot` model
#     vs Gwion's `--driver coreaudio`
#   - SONIC PI (no _completion yet, Ruby-
#     based DSL on top of SuperCollider):
#     Ruby-flavoured wrapper for the same
#     SC audio engine.  Gwion is a standalone
#     compiler / VM, not a wrapper
#   - CSOUND (`_csound`): the original
#     domain-specific audio language.
#     Csound is text-rendered + offline-
#     compiled to audio files.  Gwion is
#     live-coded + real-time JIT
#   - FAUST (`_faust`): functional signal-
#     flow audio DSP language.  Faust
#     emits C++ / LLVM / WebAssembly,
#     used as a compile-time stage in
#     another host.  Gwion is the host
#     itself, with embedded audio
#     scheduling
#   - PUREDATA / MAX/MSP (`_pd-tilde-bin`):
#     visual-patcher audio environments.
#     Gwion is textual
#   - JANET (`_janet`): general-purpose
#     embeddable scripting in C.  Janet is
#     applicative Lisp.  Gwion is C-syntax
#     + shred-concurrent + audio-DSL
#   - LUA (`_lua`): general-purpose
#     embeddable scripting.  Lua has no
#     concept of time as a type.  Gwion's
#     base type `dur` (duration) +
#     time-advance operator `now =>`
#     are core language primitives
#
# KEY GWION LANGUAGE FEATURES:
#   - STRONGLY-TIMED SEMANTICS — every line
#     that includes a `=>` time-advance
#     advances the local shred's logical
#     time by the operand duration.  Audio
#     callbacks observe deterministic
#     sample-accurate timing of state
#     changes.  E.g.:
#       `1::second => now;`  advance now
#                            by 1 second
#       `dur d = 100::ms;`  declare a
#                            duration
#       `d => now;`         advance by it
#   - SHREDS — `spork ~` keyword launches
#     a new lightweight thread sharing the
#     same audio context.  Shreds preempt
#     by time, not by syscall — when a
#     shred reaches `=> now;` it yields
#     until enough wall-clock time has
#     passed, never before.  Deterministic
#     interleaving
#   - CHUCK OPERATOR — `expr => target;`
#     "chucks" expr into target.  For
#     audio nodes: `SinOsc s => dac;`
#     wires SinOsc into the audio output
#     graph.  For numerics: `2 => x;`
#     assigns 2 to x.  Overloadable
#     via `operator =>` definitions
#   - TEMPLATES — generic types parameterised
#     by type or value, like C++ templates.
#     `class Filter<T>` for typed buffers,
#     `class Buffer<int 1024>` for
#     fixed-capacity arrays
#   - FIRST-CLASS FUNCTIONS — closures + lambda
#     literals.  ChucK has function pointers
#     but no closures
#   - OPTIONAL TYPES — `int?` for nullable,
#     unwrap with `!` operator.  Compile-
#     time enforcement that nullables are
#     checked before use
#   - PATTERN MATCHING — `match` keyword
#     with destructuring patterns for
#     tagged unions and tuples
#   - OPERATOR OVERLOADING — user-defined
#     operators with custom precedence.
#     Used heavily by DSP libraries to
#     define filter-chain syntax
#   - PLUGIN ARCHITECTURE — `.so`/`.dylib`/
#     `.dll` shared objects compiled
#     against `libgwion-plug` API.
#     Bundled in `~/.gwplug/` by default
#     (override with `-p / --plugdir`).
#     Sample plugins ship at
#     github.com/Gwion/Gwion-plug
#   - SOUNDPIPE DSP LIBRARY — Gwion can
#     embed Paul Batchelor's soundpipe
#     C DSP library (oscillators,
#     filters, reverbs, granulars).
#     Compile-time feature flag
#     USE_DOUBLE for fp32/fp64
#   - PROGRAMMABLE COMPILER PASSES —
#     `-g/--passes` flag selects which
#     compiler passes run (parse, scan0,
#     scan1, scan2, check, emit, etc.).
#     Order is significant — used for
#     incremental compilation + plugin
#     macros
#   - INCREMENTAL COMPILATION — `--loop`
#     mode keeps the compiler/VM alive
#     and accepts new source files via
#     stdin.  Existing shreds continue
#     to run while new shreds spork in
#
# AUDIO DRIVER OPTIONS (`-d / --driver`):
#   * coreaudio   macOS native CoreAudio
#   * alsa        Linux ALSA
#   * pulse       Linux PulseAudio
#   * jack        JACK Audio Connection Kit
#                 (Linux + macOS pro audio)
#   * pipewire    Linux PipeWire
#   * wasapi      Windows WASAPI
#   * dummy       no audio output
#                 (compile + run silently;
#                 useful for offline render
#                 with --bbq batch mode)
#   * file        render audio to .wav /
#                 .aiff file
#   Driver-specific arguments are passed
#   colon-separated: `-d jack:client_name`
#   or `-d file:out.wav:samples=88200`
#
# CONFIG FILE: `~/.gwionrc` (parsed at
# startup; override with `-C <path>`).
# Same syntax as command-line flags, one
# per line, leading whitespace ignored.
#
# CRITICAL DEPENDENCIES (from Makefile +
# default.nix):
#   - libsndfile (optional)    — audio file
#                                I/O for the
#                                `file` driver
#   - soundpipe (optional)     — DSP
#                                primitives
#                                (oscillators,
#                                filters)
#   - jack / portaudio /       — backend-
#     pulseaudio / alsa /        specific
#     coreaudio runtime libs     audio
#                                drivers
#                                (pick one
#                                or more
#                                at build
#                                time via
#                                config.mk)
#   - pthread                  — shred
#                                thread-pool
#                                backend
#
# Pure C99.  Builds with gcc / clang.
# CII Best Practices badge.  Cross-platform:
# Linux, macOS, Windows (MSYS2 / MinGW),
# *BSD.  Nix flake provided.
#
# UPSTREAM:
#   * Source             : https://github.com/Gwion/Gwion
#   * Site               : https://gwion.github.io/Gwion/
#   * Plugins            : https://github.com/Gwion/Gwion-plug
#   * Tour               : https://github.com/Gwion/GwionTour
#   * Benchmarks         : https://gwion.github.io/Gwion/#Benchmarks/
#   * License            : GPL-3.0
#   * Maintainer         : Jérémie Astor (fennecdjay)
#
# INSTALL:
#   # From source
#   git clone --recursive https://github.com/Gwion/Gwion
#   cd Gwion
#   make
#   sudo make install
#
#   # Nix (flake)
#   nix shell github:Gwion/Gwion
#
#   # Build with double-precision floats
#   # (must match soundpipe build flag)
#   make USE_DOUBLE=1
#
# USAGE EXAMPLES:
#
#   # Compile + run a single file
#   gwion hello.gw
#
#   # Run multiple files in one VM (sporked
#   # shreds share state)
#   gwion lib.gw main.gw
#
#   # Pass arguments to the file (colon
#   # syntax: `file:arg1:arg2`)
#   gwion 'synth.gw:freq=440:dur=2'
#
#   # Read from stdin (REPL-ish)
#   echo '<<< "hello" >>>;' | gwion --stdin
#
#   # Live-coding loop mode (new files
#   # streamed in over stdin replace
#   # shreds without VM restart)
#   gwion --loop=true --stdin
#
#   # Pick an audio driver explicitly
#   gwion -d jack synth.gw
#   gwion --driver coreaudio synth.gw
#   gwion -d 'file:out.wav' offline.gw
#
#   # Set audio params
#   gwion -s 48000 -i 2 -o 2 synth.gw
#   gwion --samplerate 96000 \
#         --input 0 --output 2 synth.gw
#
#   # Load a plugin by name
#   gwion -P soundpipe synth.gw
#   gwion --plugin midi synth.gw
#
#   # Override the plugin search path
#   gwion -p /opt/gwion/plug synth.gw
#   gwion --plugdir ./local-plug synth.gw
#
#   # Activate a module with arguments
#   gwion -m 'http:port=8080' web.gw
#   gwion --module 'osc:port=5005' osc.gw
#
#   # Preprocessor: define / undef / include
#   gwion -D SAMPLE_RATE=48000 synth.gw
#   gwion --define DEBUG --undef NDEBUG synth.gw
#   gwion -I ./inc -I /usr/local/share/gwion synth.gw
#
#   # Debug bytecode + AST
#   gwion -G true synth.gw
#   gwion --debug --dump synth.gw
#
#   # Emit compiler documentation comments
#   gwion -H true synth.gw
#   gwion --cdoc=true synth.gw > docs.cdoc
#
#   # Tune the shred thread-pool
#   gwion -t 8 -q 32 polyphony.gw
#   gwion --thread_count 8 --queue_size 32 polyphony.gw
#
#   # Custom compiler pass pipeline
#   gwion -g 'parse,scan0,scan1,scan2,check,emit' synth.gw
#   gwion --passes 'parse,scan0,check' lint-only.gw
#
#   # Colour output
#   gwion --color always synth.gw
#   gwion -c never synth.gw
#
#   # Custom config file (overrides ~/.gwionrc)
#   gwion -C ./project.gwionrc synth.gw
#   gwion --config /etc/gwion/global.rc synth.gw
#
#   # Help + version (default cmdapp_t flags)
#   gwion --help
#   gwion --version
#
# SAMPLE PROGRAM:
#
#   // hello.gw — first synth
#
#   // SinOsc into the dac (audio output)
#   SinOsc osc => dac;
#   440 => osc.freq;
#   0.3 => osc.gain;
#
#   // Hold for 2 seconds then exit
#   2::second => now;
#
# OPTIONS (sourced directly from
# https://github.com/Gwion/Gwion/blob/master/src/arg.c setup_options()):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gwion_drivers
_gwion_drivers=(
    'coreaudio:macOS native CoreAudio driver'
    'alsa:Linux ALSA driver'
    'pulse:Linux PulseAudio driver'
    'jack:JACK Audio Connection Kit (Linux + macOS pro audio)'
    'pipewire:Linux PipeWire driver'
    'wasapi:Windows WASAPI driver'
    'dummy:no audio output (silent run)'
    'file:render audio to WAV/AIFF file (use file:path syntax)'
)

local -a _gwion_colors
_gwion_colors=(
    'never:never emit colour'
    'auto:emit colour if stdout is a tty (default)'
    'always:always emit colour regardless of tty'
)

local -a _gwion_bool
_gwion_bool=(
    'true:enable the option'
    'false:disable the option'
)

_arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-C --config)'{-C+,--config=}'[parse a config file]:path:_files' \
    '(-p --plugdir)'{-p+,--plugdir=}'[add directory to plugin search path]:directory:_files -/' \
    '*'{-m+,--module=}'[activate a module (repeatable, name[:args])]:module:args: ' \
    '(-l --loop)'{-l+,--loop=}'[set loop mode]:bool:->bool' \
    '(-g --passes)'{-g+,--passes=}'[comma-separated list of compiler passes to run]:passes: ' \
    '--stdin[read source from stdin]' \
    '(-c --color)'{-c+,--color=}'[when to use color]:when:->color' \
    '(-d --driver)'{-d+,--driver=}'[set audio driver (and arguments)]:driver:->driver' \
    '(-s --samplerate)'{-s+,--samplerate=}'[set the samplerate]:integer: ' \
    '(-i --input)'{-i+,--input=}'[number of input channels]:integer: ' \
    '(-o --output)'{-o+,--output=}'[number of output channels]:integer: ' \
    '*'{-P+,--plugin=}'[force-load a plugin (repeatable)]:plugin name: ' \
    '*'{-D+,--define=}'[define a preprocessor macro (repeatable)]:macro: ' \
    '*'{-U+,--undef=}'[undefine a preprocessor macro (repeatable)]:macro: ' \
    '*'{-I+,--include=}'[add directory to include path (repeatable)]:directory:_files -/' \
    '(-G --debug)'{-G+,--debug=}'[set/unset debug mode]:bool:->bool' \
    '(-B --dump)'{-B+,--dump=}'[set/unset bytecode dump]:bool:->bool' \
    '(-H --cdoc)'{-H+,--cdoc=}'[set/unset cdoc (documentation) mode]:bool:->bool' \
    '(-t --thread_count)'{-t+,--thread_count=}'[set number of threads in the shred pool]:integer: ' \
    '(-q --queue_size)'{-q+,--queue_size=}'[set threadpool queue size]:integer: ' \
    '*:Gwion source file:_files -g "*.(gw|ck)"' \
    && ret=0

case $state in
    driver)
        _describe -t drivers 'audio driver' _gwion_drivers && ret=0 ;;
    color)
        _describe -t colors 'colour mode' _gwion_colors && ret=0 ;;
    bool)
        _describe -t bools 'boolean' _gwion_bool && ret=0 ;;
esac

return ret
