#compdef fmerge
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fmerge.txt
# Merge common columns in two or more FITS file extensions

local ret=1

_arguments -s \
  "infiles=[list of input FITS files]:" \
  "outfile=[output FITS file]:file:_files" \
  "columns=[columns to merge]:" \
  "mextname=[name of merged extension]:" \
  "copyprime=[copy primary array]:bool:(yes no)" \
  "lastkey=[keep keywords from last file]:bool:(yes no)" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
