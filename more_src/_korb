#compdef korb
# Documentation: upstream cmd/root.go at github.com/BeryJu/korb
# Reference accessed: 2026-05-30 via direct flag inspection.
# BeryJu korb R63 — Kubernetes PVC migration tool. Move data between
# StorageClasses, rename PVCs, or move PVCs to different namespaces.
# Single-command CLI with 15 flags and 1-2 PVC name positional args.

local -a _strategies _access_modes
_strategies=( auto copy-twice-name copy-twice export )
_access_modes=( ReadWriteOnce ReadOnlyMany ReadWriteMany ReadWriteOncePod )

_arguments -s -S \
  '--kube-config=[absolute path to the kubeconfig file]:kubeconfig file:_files' \
  '--debug[enable debug logging]' \
  '--source-namespace=[namespace where the old PVCs reside]:namespace:' \
  '--new-pvc-storage-class=[storage class to use for the new PVC]:storage class:' \
  '--new-pvc-name=[name for the new PVC]:name:' \
  '--new-pvc-size=[size for the new PVC (e.g. 10Gi, 1Ti)]:size:' \
  '--new-pvc-namespace=[namespace for the new PVC to be created in]:namespace:' \
  '*--new-pvc-access-mode=[access mode(s) for the new PVC]:access mode:($_access_modes)' \
  '--force[ignore warnings that would normally halt validation]' \
  '--skip-pvc-bind-wait[skip waiting for PVC to be bound]' \
  '--tolerate-any-node[allow job to tolerate any node taints]' \
  '--container-image=[image to use for moving jobs]:image:' \
  '--strategy=[strategy to use (default: auto-select)]:strategy:($_strategies)' \
  '--timeout=[overwrite auto-generated startup timeout (default 60s)]:duration:' \
  '--copyTimeout=[overwrite auto-generated copy timeout (default 60s/GB)]:duration:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:PVC name:'
