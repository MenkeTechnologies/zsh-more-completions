#compdef purr-data
# Documentation: https://puredata.info/docs/faq/commandline
# Purr Data realtime audio/visual programming environment (Pure Data fork)

local ret=1

_arguments -s -S \
  '(-help)-help[print usage and exit]' \
  '-version[print version without running]' \
  '-gui[start the GUI]' \
  '-nogui[suppress starting the GUI]' \
  '-guiport[connect to a pre-existing GUI over a port]:port' \
  '-guicmd[start an alternative GUI program]:command' \
  '*-open[open patch file(s) on startup]:patch:_files -g "*.pd"' \
  '*-lib[load object library(s)]:library:_files' \
  '*-path[add to the file search path]:path:_files -/' \
  '-nostdpath[do not search the standard directory]' \
  '-stdpath[search the standard directory]' \
  '-helppath[add to the help file search path]:path:_files -/' \
  '-font-size[default font size in points]:points' \
  '-font-face[default font]:font' \
  '-font-weight[default font weight]:weight' \
  '-r[specify the sample rate]:rate' \
  '-audiodev[specify input and output devices]:device' \
  '-audioindev[audio input devices]:device' \
  '-audiooutdev[audio output devices]:device' \
  '-inchannels[audio input channels by device]:channels' \
  '-outchannels[audio output channels by device]:channels' \
  '-channels[specify both input and output channels]:channels' \
  '-audiobuf[audio buffer size in milliseconds]:ms' \
  '-blocksize[audio I/O block size in sample frames]:frames' \
  '-sleepgrain[milliseconds to sleep when idle]:ms' \
  '-nodac[suppress audio output]' \
  '-noadc[suppress audio input]' \
  '-noaudio[suppress audio input and output]' \
  '-callback[use callbacks if possible]' \
  '-nocallback[use polling-mode]' \
  '-listdev[list audio and MIDI devices]' \
  '-oss[use the OSS audio API]' \
  '-alsa[use the ALSA audio API]' \
  '-jack[use the JACK audio API]' \
  '-pa[use the Portaudio API]' \
  '-midiindev[MIDI input device list]:device' \
  '-midioutdev[MIDI output device list]:device' \
  '-mididev[specify MIDI input and output devices]:device' \
  '-nomidiin[suppress MIDI input]' \
  '-nomidiout[suppress MIDI output]' \
  '-nomidi[suppress MIDI input and output]' \
  '-alsamidi[use the ALSA MIDI API]' \
  '-verbose[extra printout on startup]' \
  '-noverbose[no extra printout]' \
  '-d[specify the debug level]:level' \
  '-loadbang[do not suppress loadbangs]' \
  '-noloadbang[suppress all loadbangs]' \
  '-stderr[send printout to standard error]' \
  '-nostderr[send printout to the GUI]' \
  '-send[send a message at startup]:message' \
  '-prefs[load preferences on startup]' \
  '-noprefs[suppress loading preferences]' \
  '(-rt -realtime)'{-rt,-realtime}'[use real-time priority]' \
  '-nrt[do not use real-time priority]' \
  '-sleep[sleep when idle]' \
  '-nosleep[spin when idle]' \
  '-schedlib[plug in an external scheduler]:file:_files' \
  '-batch[run offline as a batch process]' \
  '-nobatch[run interactively]' \
  '-compatibility[set back-compatibility version]:version' \
  '*:patch:_files -g "*.pd"' && ret=0

return ret
