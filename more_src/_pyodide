#compdef pyodide
# command line interface for the Pyodide project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:((
    build\:"build a Python package for Pyodide"
    build-recipes\:"build packages using yaml recipes without resolving dependencies"
    config\:"manage config variables used in Pyodide"
    py-compile\:"compile .py files to .pyc in a wheel, zip file, or folder"
    skeleton\:"add a new package build recipe or update an existing recipe"
    venv\:"create a Pyodide virtual environment"
    xbuildenv\:"manage the cross-build environment for building packages"
  ))' \
  '*::arg:_files' && ret=0

return ret
