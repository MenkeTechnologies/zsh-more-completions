#compdef swift-section
# Documentation: https://github.com/MxIris-Reverse-Engineering/MachOSwiftSection
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands
subcommands=(
  'dump:dump Swift information from a Mach-O file or dyld shared cache'
  'interface:generate a Swift interface file from a Mach-O file'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'swift-section subcommand' subcommands && ret=0
    ;;
  args)
    _arguments \
      '--sections=[sections to dump, comma-separated]:sections:' \
      '--output-path=[save output to file]:file:_files' \
      '--architecture=[CPU architecture slice (required for fat binaries)]:arch:(arm64 arm64e x86_64)' \
      '--uses-system-dyld-shared-cache[read from system dyld shared cache]' \
      '--cache-image-name=[image name in dyld shared cache]:name:' \
      '--dyld-shared-cache=[specific dyld shared cache file]:file:_files' \
      '--cache-image-path=[path to cache]:path:_files' \
      '*:Mach-O file:_files' && ret=0
    ;;
esac

return ret
