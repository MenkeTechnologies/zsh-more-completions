#compdef gittuf
# _gittuf — security layer for git using TUF (gittuf/gittuf)
# upstream: https://github.com/gittuf/gittuf
# Subcommands from internal/cmd/root/root.go (cobra).

_gittuf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--no-color[turn off colored output]' \
        '--verbose[verbose output]' \
        '--profile[enable profiling]' \
        '--cpu-profile-file=[write CPU profile to file]:file:_files' \
        '--memory-profile-file=[write memory profile to file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                addhooks:'install gittuf git hooks'
                attest:'create or update attestations'
                cache:'manage gittuf cache'
                clone:'clone a repository and gittuf metadata'
                dev:'developer subcommands'
                trust:'manage the root of trust'
                policy:'manage delegations and policy'
                rsl:'manage the reference state log'
                sync:'sync gittuf metadata with remote'
                verifymergeable:'verify a branch can be merged'
                verifynetwork:'verify the gittuf network state'
                verifyref:'verify a git ref'
                tui:'open the interactive TUI'
                version:'show version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_gittuf "$@"
