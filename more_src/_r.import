#compdef r.import
# Imports raster data into a GRASS raster map and reprojects on the fly

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-e[estimate resolution only]' \
  '-n[do not perform region cropping optimization]' \
  '-l[force Lat/Lon maps to fit into geographic coordinates]' \
  '-o[override projection check]' \
  '--overwrite[allow output files to overwrite existing files]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  'input=[name of GDAL dataset to be imported]:input:_files' \
  'output=[name for output raster map]:output:' \
  'band=[input band(s) to select]:band:' \
  'memory=[maximum memory in MB]:memory:' \
  'title=[title for resultant raster map]:title:' \
  'resample=[resampling method for reprojection]:resample:(nearest bilinear bicubic lanczos bilinear_f bicubic_f lanczos_f)' \
  'extent=[output raster map extent]:extent:(input region)' \
  'resolution=[resolution of output raster map]:resolution:(estimated value region)' \
  'resolution_value=[resolution value]:resolution_value:' \
  '*:param:' && ret=0

return ret
