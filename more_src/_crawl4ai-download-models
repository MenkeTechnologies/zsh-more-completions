# Zsh completion for crawl4ai-download-models - download Crawl4AI ML models

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--remove-existing[remove existing models before download]' && ret=0

return ret
