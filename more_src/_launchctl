#compdef launchctl
# Documentation: https://www.unix.com/man-page/osx/1/launchctl/
# Source: Apple macOS — launchd service-management CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'load:load configuration files (deprecated; prefer bootstrap)'
            'unload:unload configuration files (deprecated; prefer bootout)'
            'bootstrap:bootstrap a domain or load services into a domain'
            'bootout:unload services from a domain or bootstrap a domain out'
            'enable:enable a service in a domain'
            'disable:disable a service in a domain'
            'start:start the specified job by label (deprecated)'
            'stop:stop the specified job by label (deprecated)'
            'kickstart:force-kickstart a service'
            'list:display loaded jobs (PID / exit-status / label)'
            'print:print a domain or service description'
            'print-cache:print service-cache description'
            'print-disabled:print disabled-services list for a domain'
            'submit:run a program without a plist (deprecated)'
            'remove:remove job from launchd by label (deprecated)'
            'reboot:reboot the system'
            'reload:reload all plists in a directory'
            'config:read or write launchd config'
            'limit:display or configure resource limits'
            'getenv:print a launchd environment variable'
            'setenv:set a launchd environment variable'
            'unsetenv:unset a launchd environment variable'
            'export:export launchd env for shell eval'
            'log:get / set the syslog log-level mask'
            'bslist:list Mach bootstrap services'
            'manageruid:print UID of managing launchd'
            'dumpstate:dump state for diagnosis'
            'dumpjpcategory:dump jetsam-priority categories'
            'blame:print last responsible client for a service'
            'asuser:run as the given UID'
            'attach:attach to a service via the debugger'
            'examine:examine a service'
            'help:print help'
        )
        _describe -t subcmds 'launchctl command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            load|unload|reload)
                _files -g "*.plist"
                ;;
            bootstrap|bootout|enable|disable|kickstart|print|print-disabled|print-cache)
                local -a domains=(
                    'system:system domain'
                    'gui/$(id -u):current-user GUI domain'
                    'user/$(id -u):current-user user domain'
                    'pid/$$:current-PID domain'
                )
                _describe -t domains 'domain' domains
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac

return ret
