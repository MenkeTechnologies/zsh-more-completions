#compdef dropbearkey
# Documentation: https://man.archlinux.org/search?q=dropbearkey
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-t+[key type]:type:(rsa dss ecdsa ed25519)' \
  '-f+[output key file]:file:_files' \
  '-s+[key size in bits]:bits:(1024 2048 3072 4096 521 256 384)' \
  '-y[print public key and fingerprint]' \
  '*:file:_files' && ret=0

return ret
