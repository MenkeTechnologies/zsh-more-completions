#compdef thor
# _thor-bin — Thor Ruby command line toolkit (Yehuda Katz, Ruby); framework for building CLI scaffolds (used by Rails, Bundler)
# upstream: https://github.com/rails/thor

_thor-bin() {
    local -a sub=(
        'help:show help for task'
        'list:list tasks'
        'install:install task from URL'
        'installed:list installed tasks'
        'uninstall:uninstall task'
        'update:update a task'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'thor subcommand' sub ;;
    esac
}

_thor-bin "$@"
