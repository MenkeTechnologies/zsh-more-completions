#compdef R-CMD-Rdconv
# _R-CMD-Rdconv — R Core Team R CMD Rdconv convert R Rd documentation files to other formats text HTML LaTeX example examples (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Rdconv() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-t+[type]:t:(txt html latex example examples Rd HTML LaTeX)' \
        '--type=+[type]:t:(txt html latex example examples Rd HTML LaTeX)' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--package=+[name]:str:' \
        '--encoding=+[encoding]:str:' \
        '--no-preamble[no preamble]' \
        '--no-final-newline[no final newline]' \
        '*:Rd file:_files -g "*.Rd"'
}

_R-CMD-Rdconv "$@"
