#compdef gpssh-exkeys
# Documentation: https://techdocs.broadcom.com/us/en/vmware-tanzu/data-solutions/tanzu-greenplum/7/greenplum-database/utility_guide-ref-gpssh-exkeys.html
# Exchange SSH public keys between Greenplum Database hosts

local ret=1

_arguments -s -S \
  '-?[display online help]' \
  '--version[display the utility version]' \
  '-e[file of existing hosts in current Greenplum system (expansion)]:file:_files' \
  '-f[file of all configured hostnames and addresses]:file:_files' \
  '*-h[single hostname or address for SSH key exchange]:host:_hosts' \
  '-x[file of new segment hosts being added (expansion)]:file:_files' && ret=0

return ret
