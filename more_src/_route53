#compdef route53 cli53
# Documentation: https://github.com/barnybug/cli53
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. cli53 is the actual binary
# name; some users alias it to `route53`. The AWS CLI route53
# subcommand is `aws route53 ...`, not a standalone `route53` tool.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list hosted zones'
  'create:create a hosted zone'
  'delete:delete a hosted zone'
  'export:export a hosted zone as BIND zone file'
  'import:import a BIND zone file'
  'rrcreate:create record-set(s)'
  'rrdelete:delete a record-set'
  'rrlist:list record-sets'
  'rrpurge:purge all record-sets'
  'dscreate:create a reusable delegation set'
  'dslist:list reusable delegation sets'
  'dsdelete:delete a reusable delegation set'
)

_arguments -C \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  '--profile=[AWS credentials profile]:profile' \
  '--debug[Enable debug output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'route53/cli53 command' commands && ret=0 ;;
  args)
    case $line[1] in
      list|export|delete|rrlist|rrpurge)
        _arguments '*:hosted zone name' && ret=0 ;;
      create)
        _arguments \
          '--comment=[zone comment]:comment' \
          '--vpc-id=[private zone VPC ID]:vpc' \
          '--vpc-region=[private zone VPC region]:region' \
          '*:zone name' && ret=0 ;;
      import)
        _arguments \
          '--file=[input BIND file]:file:_files' \
          '--wait[wait for change to sync]' \
          '--editauth[edit SOA / NS records]' \
          '*:zone name' && ret=0 ;;
      rrcreate|rrdelete)
        _arguments \
          '--wait[wait for change to sync]' \
          '*:record' && ret=0 ;;
    esac ;;
esac

return ret
