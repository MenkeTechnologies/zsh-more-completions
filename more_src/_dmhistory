#compdef dmhistory
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmhistory.html
# Print the processing history of a Data Model file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file name]:infile:_files' \
  'tool=[name of tool whose history to extract]:tool:' \
  'outfile=[output file name]:outfile:_files' \
  'expand=[include stack names or file lists]:expand:(yes no)' \
  'action=[what to do with history]:action:(get put pset)' \
  'clobber=[remove output if it exists]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
