#compdef aur

# Zsh completion for aurutils (aur) - helper tools for the AUR

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build packages to a local repository'
  'chroot:build packages in a chroot'
  'depends:retrieve dependencies using aurweb'
  'fetch:fetch AUR packages with git'
  'graph:output dependency graph'
  'pkglist:list packages in the AUR'
  'query:query the AUR by package name'
  'repo:manage local repositories'
  'repo-filter:filter packages in a local repository'
  'search:search the AUR by name'
  'srcver:update .SRCINFO files'
  'sync:sync AUR packages'
  'vercmp:compare package versions'
  'view:inspect AUR packages'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'aur command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      sync)
        _arguments \
          '(-c --chroot)'{-c,--chroot}'[build in chroot]' \
          '(-d --database)'{-d,--database}'[set local repository]:repo' \
          '--ignore[ignore package]:package' \
          '--no-ver[disable version checks]' \
          '--no-view[do not inspect PKGBUILDs]' \
          '(-k --keep-going)'{-k,--keep-going}'[continue on build failure]' \
          '(-n --no-confirm)'{-n,--no-confirm}'[do not confirm]' \
          '(-u --upgrades)'{-u,--upgrades}'[update installed AUR packages]' \
          '*:package' && ret=0
        ;;
      build)
        _arguments \
          '(-a --arg-file)'{-a,--arg-file}'[read targets from file]:file:_files' \
          '(-d --database)'{-d,--database}'[set local repository]:repo' \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-c --chroot)'{-c,--chroot}'[build in chroot]' \
          '--makepkg-conf[makepkg config]:file:_files' \
          '--pacman-conf[pacman config]:file:_files' \
          '*:package directory:_files -/' && ret=0
        ;;
      search)
        _arguments \
          '--by[search by]:field:(name name-desc maintainer depends makedepends optdepends checkdepends)' \
          '-k[sort by]:field:(Name NumVotes Popularity FirstSubmitted LastModified)' \
          '-r[reverse sort order]' \
          '-v[verbose output]' \
          '-j[JSON output]' \
          '*:search term' && ret=0
        ;;
      query)
        _arguments \
          '-b[display base packages]' \
          '-d[display dependencies]' \
          '-i[display detailed info]' \
          '-t[query by package type]:type:(depends makedepends checkdepends optdepends)' \
          '*:package' && ret=0
        ;;
      repo)
        _arguments \
          '(-d --database)'{-d,--database}'[set local repository]:repo' \
          '--list[list packages in repo]' \
          '--path[show path to repo]' \
          '-S[sync repo]' \
          '-u[list upgradeable]' && ret=0
        ;;
    esac
    ;;
esac

return ret
