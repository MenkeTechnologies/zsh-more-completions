#compdef cloudquery

# Zsh completion for cloudquery (cloud asset inventory)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-v[Print version]' \
  '--version[Print version]' \
  '--log-level=[Log level]:level:(trace debug info warn error)' \
  '--log-format=[Log format]:format:(text json)' \
  '--log-console[Log to console]' \
  '--log-file-name=[Log file path]:file:_files' \
  '--no-log-file[Disable file logging]' \
  '--telemetry-level=[Telemetry level]:level:(none errors stats)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'sync:Sync resources from configured source to destination'
      'migrate:Run destination migrations'
      'tables:List supported tables for a source plugin'
      'login:Login to CloudQuery Cloud'
      'logout:Logout from CloudQuery Cloud'
      'plugin:Manage plugins'
      'addon:Manage addons'
      'switch:Switch between teams'
      'completion:Generate shell completions'
    )
    _describe -t commands 'cloudquery command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      sync)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--no-migrate[Skip auto-migration]' \
          '--summary[Print sync summary]' \
          '*:config-files:_files -g "*.yml"' && ret=0
        ;;
      migrate)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:config-files:_files -g "*.yml"' && ret=0
        ;;
      tables)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '--format=[Output format]:format:(json markdown)' \
          '--filter=[Filter tables]:filter' \
          '-o+[Output directory]:dir:_directories' \
          '--output-dir=[Output directory]:dir:_directories' \
          '*:config-files:_files -g "*.yml"' && ret=0
        ;;
      plugin)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:subcommand:(install list)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
