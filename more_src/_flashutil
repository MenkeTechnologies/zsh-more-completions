#compdef flashutil

# flashutil: vendor SPI flash utility (varies by hardware vendor)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-r[read flash]:file:_files' \
  '-w[write flash]:file:_files' \
  '-v[verify]:file:_files' \
  '-e[erase]' \
  '-d[device]:device:' \
  '*::flashutil args:_files' && ret=0
return ret
