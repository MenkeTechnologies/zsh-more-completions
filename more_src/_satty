#compdef satty

# Zsh completion for satty - screenshot annotation tool for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --filename)'{-f,--filename}'[load image from file]:file:_files -g "*.(png|jpg|jpeg|bmp|webp)"' \
  '--fullscreen[start in fullscreen mode]' \
  '--output-filename[set output filename]:file:_files' \
  '--save-after-copy[save after copying to clipboard]' \
  '--early-exit[exit after first save or copy]' \
  '--init-tool[set initial tool]:tool:(brush text arrow rectangle highlight line pixelate crop)' \
  '--copy-command[command to copy to clipboard]:command' \
  '--annotation-size-factor[annotation size factor]:factor' \
  '--font-family[font family]:font' \
  '--font-style[font style]:style'
