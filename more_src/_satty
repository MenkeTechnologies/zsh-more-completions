#compdef satty
# Documentation: https://github.com/gabm/Satty
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for satty - screenshot annotation tool for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--man[display manual page]' \
  '--license[show license information]' \
  '(-c --config)'{-c,--config}'+[configuration file]:file:_files' \
  '(-f --filename)'{-f,--filename}'+[load image from file (- for stdin)]:file:_files -g "*.(png|jpg|jpeg|bmp|webp)"' \
  '--fullscreen=[start in fullscreen mode]::mode:(all current-screen)' \
  '--floating-hack[attempt to enforce floating window mode]' \
  '--no-window-decoration[remove window title bar and borders]' \
  '(-o --output-filename)'{-o,--output-filename}'+[output filename or - for stdout]:file:_files' \
  '--early-exit[close after copy or save action]' \
  '--early-exit-save-as[close after save-as operation]' \
  '--save-after-copy[save file after clipboard copy]' \
  '--initial-tool=[initial tool]:tool:(pointer crop line arrow rectangle ellipse text marker blur highlight brush)' \
  '--annotation-size-factor=[annotation size factor]:factor' \
  '--corner-roundness=[rectangle corner radius]:value' \
  '--resize=[resize canvas]:mode_or_dims' \
  '(-d --default-hide-toolbars)'{-d,--default-hide-toolbars}'[hide toolbars initially]' \
  '--default-fill-shapes[fill shapes by default]' \
  '--zoom-factor=[zoom level (1.0 = no zoom)]:factor' \
  '--pan-step-size=[arrow key pan distance]:size' \
  '--font-family=[font family]:font' \
  '--font-style=[font style]:style' \
  '--text-move-length=[arrow key text movement distance]:length' \
  '--input-scale=[input image scale]:scale' \
  '--copy-command=[clipboard command]:command' \
  '--actions-on-enter=[actions triggered by Enter key]:actions' \
  '--actions-on-escape=[actions triggered by Escape key]:actions' \
  '--actions-on-right-click=[actions triggered by right click]:actions' \
  '--auto-copy[auto-copy after every annotation change]' \
  '--primary-highlighter=[primary highlighter mode]:mode:(block freehand)' \
  '--brush-smooth-history-size=[brush smoothing buffer size]:size' \
  '--disable-notifications[suppress notifications]' \
  '--profile-startup[print startup profiling data]' \
  '--title=[window title]:title' \
  '--app-id=[application ID]:id'
