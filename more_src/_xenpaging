#compdef xenpaging
# Documentation: https://github.com/xen-project/xen/blob/master/tools/xenpaging/xenpaging.c
# Reference accessed: 2026-05-21
# Verified: upstream xenpaging.c getopt_long lopts[] array quoted from source.
# Real long flags: --help, --verbose, --domain, --pagefile, --mru_size.
# Removed prior fabrications: --mfn-count, -D/daemonize (not present upstream).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug output]' \
  '(-d --domain)'{-d+,--domain=}'[numerical domain ID (required)]:domid:' \
  '(-f --pagefile)'{-f+,--pagefile=}'[pagefile path (required)]:file:_files' \
  '(-m --mru_size)'{-m+,--mru_size=}'[count of paged-in pages to retain]:count:' && ret=0
return ret
