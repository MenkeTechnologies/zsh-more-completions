#compdef xenpaging

# xenpaging: Xen guest memory paging to disk daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[domain ID]:domid:' \
  '--domain=[domain ID]:domid:' \
  '-f[pagefile]:file:_files' \
  '--pagefile=[pagefile]:file:_files' \
  '-m[mfn count to page out]:mfns:' \
  '--mfn-count=[mfn count to page out]:mfns:' \
  '-v[verbose]' \
  '-D[daemonize]' \
  '*::xenpaging args:_files' && ret=0
return ret
