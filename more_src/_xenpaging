#compdef xenpaging

# xenpaging: Xen memory paging tool (swap VM pages to disk)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[domain ID to manage]:domid:' \
  '-f[paging file path]:file:_files' \
  '-m[max memory to page out (MB)]:mb:' \
  '-r[memory threshold]:mb:' \
  '-v[verbose]' \
  '*::xenpaging args:_files' && ret=0
return ret
