#compdef simple_switch_grpc
# Documentation: https://github.com/p4lang/behavioral-model/tree/main/targets/simple_switch_grpc
# P4 bmv2 simple_switch with P4Runtime gRPC server

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help message]' \
  '*'{-i+,--interface=}'[attach network interface as port (PORT@IFACE)]:port@iface' \
  '--pcap=-[generate pcap files for interfaces]::directory:_files -/' \
  '--thrift-port=[TCP port for the Thrift runtime server]:port' \
  '--device-id=[device ID for IPC messages (default 0)]:id' \
  '--nanolog=[IPC socket for nanomsg pub/sub logs]:addr' \
  '--log-console[enable logging on stdout]' \
  '--log-file=[enable logging to given file]:file:_files' \
  '(-L --log-level)'{-L+,--log-level=}'[set log level]:level:(trace debug info warn error off)' \
  '--log-flush[flush logger to disk after every message]' \
  '--notifications-addr=[nanomsg address for notifications]:addr' \
  '--debugger[activate debugger]' \
  '--debugger-addr=[nanomsg address for debugger communication]:addr' \
  '--restore-state=[restore state from file]:file:_files' \
  '--dump-packet-data=[bytes of packet data to dump per packet]:bytes' \
  '--no-p4[start the switch without an input configuration]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '--json-version[display max bmv2 JSON version supported]' \
  '--disable-swap[disable JSON swapping at runtime]' \
  '--grpc-server-addr=[bind gRPC server to given address (default 0.0.0.0:9559)]:addr' \
  '--grpc-server-ssl[enable SSL/TLS for gRPC server]' \
  '--grpc-server-cacert=[pem file holding CA cert to verify peer]:file:_files' \
  '--grpc-server-cert=[pem file holding server certificate]:file:_files' \
  '--grpc-server-key=[pem file holding server key]:file:_files' \
  '--grpc-server-with-client-auth[require client cert for mutual authentication]' \
  '--cpu-port=[CPU port used for packet-in/packet-out]:port' \
  '--drop-port=[numerical value for the drop port (default 511)]:port' \
  '--dp-grpc-server-addr=[bind dataplane packet gRPC server to address]:addr' \
  '--priority-queues=[number of priority queues (default 1)]:count' \
  '--max-mc-groups=[maximum multicast groups]:count' \
  '--max-l1-entries=[maximum L1 multicast entries]:count' \
  '--max-l2-entries=[maximum L2 multicast entries]:count' \
  '*:P4 JSON:_files' && ret=0

return ret
