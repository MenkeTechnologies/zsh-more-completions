#compdef goa-daemon
# Documentation: https://man.archlinux.org/search?q=goa-daemon
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--replace[replace existing instance]' && ret=0

return ret
