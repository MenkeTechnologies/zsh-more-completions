#compdef goa-daemon
# Documentation: https://man.archlinux.org/man/goa-daemon.8.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above. goa-daemon is the GNOME Online Accounts daemon; accepts only --help/--replace.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--replace[replace existing instance]' && ret=0

return ret
