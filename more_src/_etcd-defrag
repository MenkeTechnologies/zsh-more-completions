#compdef etcd-defrag
# _etcd-defrag — etcd cluster defragmentation tool
# upstream: https://github.com/ahrtr/etcd-defrag
# Flags from internal/config/config.go on tip.

_etcd-defrag() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoints=[csv of etcd endpoints]:csv:' \
        '--dial-timeout=[gRPC dial timeout]:dur:' \
        '--command-timeout=[gRPC command timeout]:dur:' \
        '--keepalive-time=[keepalive ping interval]:dur:' \
        '--keepalive-timeout=[keepalive timeout]:dur:' \
        '--cacert=[TLS CA cert file]:file:_files' \
        '--cert=[TLS client cert file]:file:_files' \
        '--key=[TLS client key file]:file:_files' \
        '--insecure-transport=[disable TLS]:bool:(true false)' \
        '--insecure-skip-tls-verify=[skip TLS verification]:bool:(true false)' \
        '--cluster=[defrag all cluster members]:bool:(true false)' \
        '(-d --discovery-srv)'{-d,--discovery-srv=}'[DNS SRV discovery domain]:domain:' \
        '--discovery-srv-name=[DNS SRV service name]:name:' \
        '--insecure-discovery=[allow insecure discovery]:bool:(true false)' \
        '--user=[etcd auth username]:user:' \
        '--password=[etcd auth password]:pw:' \
        '--compaction=[run compaction before defrag]:bool:(true false)' \
        '--continue-on-error=[continue on member error]:bool:(true false)' \
        '--defrag-rule=[CEL rule controlling defrag]:expr:' \
        '--dry-run=[do not perform defrag]:bool:(true false)' \
        '--etcd-storage-quota-bytes=[storage quota (bytes)]:n:' \
        '--exclude-localhost=[exclude localhost endpoints]:bool:(true false)' \
        '--move-leader=[move leader before defragging a leader]:bool:(true false)' \
        '--wait-between-defrags=[delay between member defrags]:dur:' \
        '--skip-healthcheck-cluster-endpoints=[skip per-endpoint health check]:bool:(true false)' \
        '--version[print version and exit]'
}

_etcd-defrag "$@"
