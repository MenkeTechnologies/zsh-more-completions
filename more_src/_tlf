#compdef tlf
# Documentation: https://man.archlinux.org/search?q=tlf
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-d[debug mode]' \
  '-f+[logfile]:file:_files' \
  '-s[silent mode]' \
  '-w+[work dir]:dir:_files -/' && ret=0

return ret
