#compdef tlf
# Documentation: https://github.com/tlf/tlf/blob/master/tlf.1.in
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[print options summary]' \
  '(- *)'{-V,--version}'[print version information]' \
  '(- *)--usage[print short usage message]' \
  '(-f --config)'{-f+,--config=}'[non-default configuration file]:file:_files' \
  '(-d --debug)'{-d+,--debug=}'[debug logging level]:level:(1 2 3 4)' \
  '(-i --import)'{-i,--import}'[import Cabrillo file and generate logs]' \
  '(-l --list)'{-l,--list}'[list all built-in contests]' \
  '(-n --no-cluster)'{-n,--no-cluster}'[start without packet/cluster connection]' \
  '(-r --no-rig)'{-r,--no-rig}'[start without radio control]' \
  '(-s --sync)'{-s+,--sync=}'[synchronize log with another node]:user\:password@host/dir/logfile:' \
  '(-v --verbose)'{-v,--verbose}'[verbose startup output]' && ret=0

return ret
