#compdef relion_autopick
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: automated particle picking (template, LoG, topaz, helical)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[micrograph STAR file OR filenames to autopick from]:file:_files' \
  '--pickname=[rootname for coordinate STAR files]:name' \
  '--odir=[output directory for coordinate files]:dir:_files -/' \
  '--angpix=[pixel size of the micrographs (A)]:value' \
  '--particle_diameter=[diameter of circular mask on images (A)]:value' \
  '--shrink_particle_mask=[shrink the particle mask by this many pixels]:value' \
  '--outlier_removal_zscore=[remove pixels this many sigma from the mean]:value' \
  '--write_fom_maps[write probability-ratio maps to disc]' \
  '--no_fom_limit[ignore default maximum of 30 fom maps]' \
  '--read_fom_maps[skip calculations, re-read precalculated maps]' \
  '--skip_optimise_scale[skip optimisation of micrograph scale for FFTs]' \
  '--only_do_unfinished[only autopick micrographs without coordinate files]' \
  '--gpu[use GPU acceleration when available]' \
  '--ref=[STAR with reference names, MRC stack, or "gauss"]:file:_files' \
  '--angpix_ref=[pixel size of the references (A)]:value' \
  '--invert[density in micrograph is inverted vs template]' \
  '--ang=[angular sampling (degrees); 360 for no rotations]:value' \
  '--lowpass=[lowpass filter (A) for the references]:value' \
  '--highpass=[highpass filter (A) for the micrographs]:value' \
  '--ctf[perform CTF correction on the references]' \
  '--ctf_intact_first_peak[ignore CTFs until their first peak]' \
  '--healpix_order=[healpix order for projecting a 3D reference]:value' \
  '--sym=[symmetry point group for a 3D reference]:group' \
  '--LoG[use Laplacian-of-Gaussian filter-based picking]' \
  '--LoG_diam_min=[smallest particle diameter (A) for LoG detection]:value' \
  '--LoG_diam_max=[largest particle diameter (A) for LoG detection]:value' \
  '--LoG_neighbour=[avoid neighbouring particles within this percent]:value' \
  '--LoG_adjust_threshold=[adjust picking threshold (+ fewer, - more)]:value' \
  '--LoG_upper_threshold=[upper limit of the picking threshold]:value' \
  '--LoG_use_ctf[use CTF until first peak in LoG picker]' \
  '--topaz_train[use wrapper to the topaz train command]' \
  '--topaz_extract[use wrapper to the topaz extract command]' \
  '--topaz_nr_particles=[expected number of particles per micrograph]:value' \
  '--topaz_threshold=[minimum threshold for topaz picking]:value' \
  '--topaz_train_picks=[name of picking coordinates for topaz training]:file:_files' \
  '--topaz_train_parts=[particle star file for topaz training]:file:_files' \
  '--topaz_model=[saved model from topaz train for topaz extract]:file:_files' \
  '--topaz_args=[additional arguments to be passed to topaz]:args' \
  '--fn_topaz_exe=[topaz executable]:file:_files' \
  '--helix[references are 2D helical segments]' \
  '--helical_tube_kappa_max=[factor of max curvature relative to a circle]:value' \
  '--helical_tube_outer_diameter=[tube diameter (A)]:value' \
  '--helical_tube_length_min=[minimum tube length (A)]:value' \
  '--amyloid[activate specific algorithm for amyloid picking]' \
  '--threshold=[fraction of expected probability ratio for peaks]:value' \
  '--min_distance=[minimum distance (A) between any two particles]:value' \
  '--max_stddev_noise=[maximum stddev in noise area for picking peaks]:value' \
  '--min_avg_noise=[minimum average in noise area for picking peaks]:value' \
  '--skip_side=[extra pixels to keep away from micrograph edge]:value' \
  '--verb=[verbosity]:value' \
  '--pad=[padding factor for Fourier transforms]:value' \
  '--random_seed=[number for the random seed generator]:value' \
  '--shrink=[reduce micrograph to this fraction size]:value' \
  '*:file:_files' && ret=0

return ret
