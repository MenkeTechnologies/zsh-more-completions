#compdef sugazmig
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/migration_inversion/sugazmig.c
# Gazdag phase-shift migration of zero-offset SU data

local ret=1

_arguments -s -S \
  'dt=[time sampling interval]:dt' \
  'dx=[midpoint sampling interval]:dx' \
  'ft=[first time sample]:ft' \
  'ntau=[number of migrated time samples]:ntau' \
  'dtau=[migrated time sampling interval]:dtau' \
  'ftau=[first migrated time sample]:ftau' \
  'tmig=[times corresponding to interval velocities in vmig]:tmig' \
  'vmig=[interval velocities corresponding to times in tmig]:vmig' \
  'vfile=[file containing velocities]:file:_files' \
  'Q=[quality factor]:Q' \
  'ceil=[gain ceiling beyond which migration ceases]:ceil' \
  'verbose=[verbose=1 echoes information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
