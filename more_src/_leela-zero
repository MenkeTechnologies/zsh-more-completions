#compdef leela-zero leelaz
# Documentation: https://github.com/leela-zero/leela-zero/blob/next/src/Leela.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (boost::program_options definitions).

# leela-zero: Go playing engine (GTP)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-g --gtp)'{-g,--gtp}'[enable GTP mode]' \
  '(-w --weights)'{-w+,--weights=}'[network weights file]:file:_files' \
  '(-p --playouts)'{-p+,--playouts=}'[limit playouts per move (requires --noponder)]:n:' \
  '(-v --visits)'{-v+,--visits=}'[limit visits per move]:n:' \
  '(-r --resignpct)'{-r+,--resignpct=}'[resign threshold percent 0-100]:pct:' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-b --lagbuffer)'{-b+,--lagbuffer=}'[time-usage safety margin (centiseconds)]:cs:' \
  '--batchsize=[max batch size (OpenCL builds)]:n:' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[disable diagnostic output]' \
  '(-n --noise)'{-n,--noise}'[enable policy network randomization]' \
  '--noponder[disable pondering on opponent time]' \
  '(-m --randomcnt)'{-m+,--randomcnt=}'[random moves for first N moves]:n:' \
  '(-s --seed)'{-s+,--seed=}'[random seed]:n:' \
  '(-d --dumbpass)'{-d,--dumbpass}'[disable smart passing heuristics]' \
  '--gpu=[OpenCL GPU device id]:n:' \
  '--full-tuner[run full OpenCL tuner]' \
  '--tune-only[tune only, do not play]' \
  '--cpu-only[force CPU-only]' \
  '--precision=[NN precision]:precision:(single half auto)' \
  '--puct=[PUCT parameter (tuner only)]:value:' \
  '*:sgf file:_files -g "*.sgf(-.)"' && ret=0
return ret
