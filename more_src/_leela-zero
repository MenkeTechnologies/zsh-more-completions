#compdef leela-zero leelaz
# Documentation: https://man.archlinux.org/search?q=leela-zero
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-w --weights)'{-w,--weights}'+[network weights]:file:_files' \
  '(-g --gtp)'{-g,--gtp}'[enable GTP mode]' \
  '(-t --threads)'{-t,--threads}'+[threads]:n:' \
  '(-p --playouts)'{-p,--playouts}'+[playouts per move]:n:' \
  '(-v --visits)'{-v,--visits}'+[visits per move]:n:' \
  '(-m --randomcnt)'{-m,--randomcnt}'+[random moves]:n:' \
  '(-r --resignpct)'{-r,--resignpct}'+[resign threshold]:pct:' \
  '(-s --seed)'{-s,--seed}'+[random seed]:n:' \
  '(-d --dumbpass)'{-d,--dumbpass}'[no thinking on pass]' \
  '(-n --noponder)'{-n,--noponder}'[no pondering]' \
  '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--noise[enable noise]' \
  '--cpu-only[CPU only]' \
  '--full-tuner[full tuner]' \
  '--gpu=+[gpu]:n:' \
  '--batchsize=+[batch size]:n:' \
  '*:sgf file:_files -g "*.sgf"' && ret=0

return ret
