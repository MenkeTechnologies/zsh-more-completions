#compdef revshellgen
# Documentation: https://github.com/t0thkr1s/revshellgen
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: https://github.com/rsherstnev/zshcompletions/blob/104351539ca29288a402ade731889a8824bb72aa/_revshellgen
# Repository: rsherstnev/zshcompletions (_revshellgen)

local types=('netcat' 'bash' 'file' 'python' 'awk' 'lua' 'php' 'perl' 'ruby' 'socat' 'openssl' 'powershell')

_arguments -C \
	'1:select address:_hosts' \
	'2:select port:_ports' \
	'3:select reverse shell type:_values type $types' \
&& return 0
