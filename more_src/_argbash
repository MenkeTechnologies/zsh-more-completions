#compdef argbash
# Documentation: https://github.com/matejak/argbash (bin/argbash argument parser)
# Reference accessed: 2026-05-29
# Bash argument parser generator. Requires autom4te from GNU autoconf.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output=}'[output filename (- = stdout)]:file:_files' \
  '(-i --in-place)'{-i,--in-place}'[update bash script in-place]' \
  '(-t --type)'{-t,--type=}'[output format]:format:(bash-script posix-script manpage manpage-defs completion docopt excised)' \
  '--library[treat input as pure parsing library]' \
  '--strip=[content level to strip]:level:(none user-content all)' \
  '--check-typos=[validate argbash macro spelling]:bool:(on off)' \
  '(-c --commented)'{-c,--commented}'[include explanatory comments in output]' \
  '*'{-I,--search=}'[directory to search for wrapped scripts]:dir:_directories' \
  '*--debug=[trace specified macro (developer)]:macro:' \
  '*:input template:_files' && ret=0

return ret
