#compdef minica
# Documentation: https://github.com/jsha/minica
# Reference accessed: 2026-05-19
# Verified: upstream source main.go at the URL above.
# Prior file invented --domain (real: --domains), --ip-address (real:
# --ip-addresses), --ecdsa, --version; missed --ca-alg and --reuse-keys.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--domains=[comma-separated domain names for SAN]:domains' \
  '--ip-addresses=[comma-separated IP addresses for SAN]:ips' \
  '--ca-cert=[root certificate filename]:ca cert file:_files -g "*.pem"' \
  '--ca-key=[root private key filename]:ca key file:_files -g "*.pem"' \
  '--ca-alg=[algorithm for new keypairs]:alg:(rsa ecdsa)' \
  '--reuse-keys[reuse existing key file when cert file is missing]' \
  '-h[show help]' && ret=0

return ret
