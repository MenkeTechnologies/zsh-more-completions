#compdef minica

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--domain=[domain names to include in certificate]:domain' \
  '--ip-address=[IP addresses to include in certificate]:ip address' \
  '--ca-cert=[path to CA certificate]:ca cert file:_files -g "*.pem"' \
  '--ca-key=[path to CA key]:ca key file:_files -g "*.pem"' \
  '--ecdsa[generate ECDSA key instead of RSA]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
