#compdef diff-pdf
# Documentation: https://github.com/vslavik/diff-pdf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# vslavik/diff-pdf — visually compare two PDF files (wxCmdLineEntryDesc in diff-pdf.cpp)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-s --skip-identical)'{-s,--skip-identical}'[exclude unchanged pages from output]' \
  '(-m --mark-differences)'{-m,--mark-differences}'[highlight differences on the left side]' \
  '(-g --grayscale)'{-g,--grayscale}'[render unchanged areas in gray]' \
  '--output-diff=[write diff PDF to file]:file:_files -g "*.pdf"' \
  '--channel-tolerance=[color channel tolerance]:n:' \
  '--per-page-pixel-tolerance=[max differing pixels per page]:n:' \
  '--dpi=[rasterization DPI (default 300)]:dpi:' \
  '--view[open viewer window]' \
  '1:first PDF:_files -g "*.pdf"' \
  '2:second PDF:_files -g "*.pdf"' && ret=0

return ret
