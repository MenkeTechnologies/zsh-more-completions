#compdef diff-pdf
# Documentation: https://man.archlinux.org/search?q=diff-pdf
# Reference accessed: 2026-05-16

# Zsh completion for diff-pdf
# Upstream: Visually compare two PDF files
# Conservative fallback — run `diff-pdf --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
