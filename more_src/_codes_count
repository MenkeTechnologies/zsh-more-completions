#compdef codes_count
# Documentation: https://confluence.ecmwf.int/display/ECC/codes_count
# Source: ecmwf/eccodes tools/codes_count.cc — count messages in GRIB/BUFR files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose: print per-file counts]' \
    '-f[do not fail on error]' \
    '*:input file or directory:_files' \
    && ret=0

return ret
