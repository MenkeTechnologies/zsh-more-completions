#compdef fabber
# Documentation: https://fsl.fmrib.ox.ac.uk/fsl/docs/task_fmri/fabber.html
# fabber - approximate Bayesian inference using generative signal models

local ret=1

_arguments -s -S \
  '--data=[input data file]:file:_files' \
  '--mask=[mask image specifying which voxels to process]:file:_files' \
  '--method=[inference method (vb/spatialvb/nlls)]:method:(vb spatialvb nlls)' \
  '--model=[forward model name]:model:' \
  '--noise=[noise model (white/ar)]:noise:(white ar)' \
  '--output=[output directory]:dir:_files -/' \
  '--num-echoes=[number of echoes in the data]:n:' \
  '--param-spatial-priors=[spatial prior specification string]:spec:' \
  '--save-residuals[output 4D residuals dataset]' \
  '--save-model-fit[output 4D model fit dataset]' \
  '--allow-bad-voxels[skip numerically failing voxels with a warning]' \
  '--overwrite[overwrite existing output directory]' \
  '--help[show help]' && ret=0

return ret
