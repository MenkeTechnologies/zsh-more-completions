#compdef volcano-controller-manager vc-controller-manager
# _volcano-controller-manager — Volcano controller manager (reconciles Job, Queue, PodGroup, Command, JobFlow CRs)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/controller-manager/app/options/options.go on tip.

_volcano-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[k8s API server address (overrides kubeconfig)]:url:_urls' \
        '--kubeconfig=[kubeconfig file path]:file:_files' \
        '--ca-cert-file=[x509 CA cert for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--lock-object-namespace=[leader-election lock object namespace]:ns:' \
        '--kube-api-qps=[QPS to k8s apiserver]:n:' \
        '--kube-api-burst=[burst to k8s apiserver]:n:' \
        '--version[show version and exit]' \
        '--max-requeue-num=[max times a job/queue/command is requeued]:n:' \
        '--healthz-address=[health check server listen address]:addr:' \
        '--enable-healthz[enable health check endpoint]' \
        '--enable-metrics[enable metrics endpoint]' \
        '--listen-address=[HTTP request listen address]:addr:' \
        '--inherit-owner-annotations=[inherit owner annotations for pods on podgroup create]:bool:(true false)' \
        '--log-flush-frequency=[max seconds between log flushes]:dur:'
}

_volcano-controller-manager "$@"
