#compdef eigrpctl
# _eigrpctl — OpenBSD eigrpctl (control + introspect the running eigrpd(8) Cisco-style EIGRP routing daemon; show neighbors/interfaces/topology/rib/fib, fib couple/decouple, reload)
# upstream: https://github.com/openbsd/src (usr.sbin/eigrpctl)
# Flags + commands from usr.sbin/eigrpctl/eigrpctl.8 on tip.

_eigrpctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /var/run/eigrpd.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'eigrpctl command' \
                '(show:show subsystem state fib:fib couple/decouple/reload reload:reload eigrpd config log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(summary interfaces neighbor topology rib fib stats)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple reload)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_eigrpctl "$@"
