#compdef gencodeVersionForGenes
# UCSC kent: figure out which version of GENCODE best matches a list of genes

local ret=1

_arguments -s -S \
  '-bed=[create bed file mapping genes to genome via best gencode fit]:file:_files -g "*.bed"' \
  '-upperCase[force genes to uppercase]' \
  '-allBed=[output beds for all versions in geneSymVer.tsv]:dir:_files -/' \
  '-geneToId=[output two-column file with symbol and gencode gene names]:file:_files -g "*.tsv"' \
  '-miss=[write unassigned genes here, one per line]:file:_files' \
  '-target=[specify assembly (e.g. hg38, hg19)]:ucscDb' \
  '1:genes file:_files' \
  '2:geneSymVer tsv:_files -g "*.tsv"' && ret=0

return ret
