#compdef orca_2mkl
# Documentation: https://www.faccts.de/docs/orca/6.0/manual/contents/detailed/utilities.html
# ORCA utility to convert GBW files to/from MKL (ASCII) and Molden formats

local ret=1

_arguments -s -S \
  '-molden[write a Molden format file]' \
  '-mkl[write an MKL (ASCII) format file]' \
  '-gbw[reverse conversion back to GBW]' \
  '-anyorbs[convert QRO, UNO or natural orbitals]' \
  '*:base name:_files' && ret=0

return ret
