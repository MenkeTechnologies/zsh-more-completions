#compdef farpd
# Documentation: https://manpages.debian.org/unstable/farpd/farpd.8.en.html
# Fake ARP daemon: reply to ARP requests for a destination net

local ret=1

_arguments -s \
  '-d[do not daemonize and enable verbose debugging messages]' \
  '-i[listen on interface]:interface:_net_interfaces' \
  '*:net:' && ret=0

return ret
