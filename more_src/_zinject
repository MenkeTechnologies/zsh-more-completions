#compdef zinject
# _zinject — OpenZFS zinject (in-kernel fault injector for ZFS test suite + diagnostics; -a inject after txg, -c handle clear, -d device path, -t inject type (data|mos|mosdir|metadnode|dnode|ddt|zilog|bptree|...), -e error (io|nxio|ecksum), -p panic instead of error, -l label, -L label-level, -m bps mask, -q query)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zinject/zinject.c on tip.

_zinject() {
    _arguments \
        '-h[show help]' \
        '-a+[txg]:txg:' \
        '-c+[handle id (clear)]:id:' \
        '-d+[device]:device:_files -g "/dev/*"' \
        '-t+[type]:type:(data dnode mos mosdir metadnode zilog ddt bptree spacemap)' \
        '-e+[error]:error:(io checksum dtl nxio)' \
        '-p+[panic action]:panic:(fatal continue)' \
        '-l+[label]:label:' \
        '-L+[label level]:level:' \
        '-f+[frequency]:freq:' \
        '-T+[type filter]:type:' \
        '-m+[bp mask]:mask:' \
        '-r+[range]:range:' \
        '-q[query]' \
        '-u[unload module after]' \
        '*:pool:'
}

_zinject "$@"
