#compdef gamemoderun
# Documentation: https://man.archlinux.org/search?q=gamemoderun
# Reference accessed: 2026-05-16

# Zsh completion for gamemoderun - run a game with GameMode optimizations

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-):command: _command_names -e' \
  '*::arguments: _normal' && ret=0

return ret
