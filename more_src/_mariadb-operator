#compdef mariadb-operator
# _mariadb-operator — MariaDB Kubernetes operator and helper subcommands
# upstream: https://github.com/mariadb-operator/mariadb-operator
# Subcommands + flags from cmd/controller/main.go rootCmd + cert_controller/webhook/agent/backup/init/pitr on tip.

_mariadb-operator() {
    local context state state_descr line
    typeset -A opt_args

    local -a persistent=(
        '--metrics-addr=[metrics bind host\:port]:host\:port:'
        '--health-addr=[health probe bind host\:port]:host\:port:'
        '--leader-elect[enable leader election]'
        '--log-level=[log level]:level:(debug info warn error)'
        '--log-time-encoder=[log time encoder]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)'
        '--log-dev[enable development logs]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        $persistent \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'cert-controller:rotate/issue webhook CA + serving certificates'
                'webhook:run the admission/conversion webhook server'
                'backup:upload/restore MariaDB backups to S3/Azure'
                'pitr:point-in-time-recovery from binlog archives'
                'init:initialize MariaDB state directory (galera, replication)'
                'agent:in-pod HTTP agent for MariaDB lifecycle ops'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                cert-controller)
                    _arguments \
                        '--ca-secret-name=[CA secret name]:name:' \
                        '--ca-secret-namespace=[CA secret namespace]:ns:' \
                        '--ca-common-name=[CA certificate common name]:cn:' \
                        '--ca-lifetime=[CA certificate lifetime]:dur:' \
                        '--cert-secret-name=[serving cert secret name]:name:' \
                        '--cert-secret-namespace=[serving cert secret namespace]:ns:' \
                        '--cert-lifetime=[serving cert lifetime]:dur:' \
                        '--renew-before-percentage=[% of lifetime before renew]:n:' \
                        '--service-name=[webhook Service name]:name:' \
                        '--service-namespace=[webhook Service namespace]:ns:' \
                        '--requeue-duration=[requeue interval]:dur:'
                    ;;
                webhook)
                    _arguments \
                        '--ca-cert-path=[CA cert file path]:file:_files' \
                        '--cert-dir=[serving cert directory]:dir:_files -/' \
                        '--dns-name=[serving cert DNS name]:host:' \
                        '--port=[webhook bind port]:port:' \
                        '--validate-cert=[validate serving cert]:bool:(true false)'
                    ;;
                backup)
                    _arguments \
                        '--path=[backup files directory]:dir:_files -/' \
                        '--target-file-path=[backup target manifest path]:file:_files' \
                        '--backup-content-type=[backup content type]:type:(logical physical)' \
                        '--cleanup-target-file=[remove target manifest after use]:bool:(true false)' \
                        '--s3=[enable S3 backup storage]:bool:(true false)' \
                        '--s3-bucket=[S3 bucket name]:name:' \
                        '--s3-endpoint=[S3 API endpoint (no scheme)]:host:' \
                        '--s3-region=[S3 region]:region:' \
                        '--s3-tls=[enable S3 TLS]:bool:(true false)' \
                        '--s3-ca-cert-path=[S3 CA cert file]:file:_files' \
                        '--s3-prefix=[S3 key prefix]:prefix:' \
                        '--abs=[enable Azure Blob backup storage]:bool:(true false)' \
                        '--abs-container=[Azure Blob container]:name:' \
                        '--abs-service-url=[Azure Blob service URL]:url:_urls' \
                        '--abs-tls=[enable Azure Blob TLS]:bool:(true false)'
                    ;;
                pitr)
                    _arguments \
                        '--path=[binlog directory]:dir:_files -/' \
                        '--target-file-path=[binlog target manifest path]:file:_files' \
                        '--start-gtid=[start GTID]:gtid:' \
                        '--target-time=[target recovery time]:rfc3339:' \
                        '--strict-mode=[fail on missing binlogs]:bool:(true false)' \
                        '--s3=[enable S3 binlog storage]:bool:(true false)' \
                        '--s3-bucket=[S3 bucket]:name:' \
                        '--s3-prefix=[S3 key prefix]:prefix:' \
                        '--s3-endpoint=[S3 API endpoint]:host:' \
                        '--s3-region=[S3 region]:region:' \
                        '--s3-tls=[enable S3 TLS]:bool:(true false)' \
                        '--s3-ca-cert-path=[S3 CA cert file]:file:_files'
                    ;;
                init)
                    _arguments \
                        '--config-dir=[MariaDB config directory]:dir:_files -/' \
                        '--state-dir=[MariaDB state directory]:dir:_files -/' \
                        '1: :(galera replication)'
                    ;;
                agent)
                    _arguments \
                        '--addr=[HTTP(s) API bind host\:port]:host\:port:' \
                        '--probe-addr=[probe HTTP bind host\:port]:host\:port:' \
                        '--config-dir=[MariaDB config directory]:dir:_files -/' \
                        '--state-dir=[MariaDB state directory]:dir:_files -/' \
                        '--compress-level=[HTTP compression level]:n:' \
                        '--rate-limit-requests=[requests in the rate-limit bucket]:n:' \
                        '--rate-limit-duration=[rate-limit window]:dur:' \
                        '--graceful-shutdown-timeout=[graceful shutdown timeout]:dur:' \
                        '--kubernetes-auth=[enable Kubernetes TokenReview auth]:bool:(true false)' \
                        '--kubernetes-trusted-name=[trusted SA name]:name:' \
                        '--kubernetes-trusted-namespace=[trusted SA namespace]:ns:' \
                        '--basic-auth=[enable HTTP basic auth]:bool:(true false)' \
                        '--basic-auth-username=[basic auth username]:user:' \
                        '--basic-auth-password-path=[basic auth password file]:file:_files' \
                        '--binary-log-archival=[enable binlog archival]:bool:(true false)'
                    ;;
                *)
                    _arguments \
                        '--log-maxscale[enable MaxScale API request logs]' \
                        '--log-sql[enable SQL resource logs]' \
                        '--kube-api-qps=[K8s API QPS]:f:' \
                        '--kube-api-burst=[K8s API burst]:n:' \
                        '--max-concurrent-reconciles=[max concurrent reconciles]:n:' \
                        '--mariadb-max-concurrent-reconciles=[MariaDB reconciler concurrency]:n:' \
                        '--maxscale-max-concurrent-reconciles=[MaxScale reconciler concurrency]:n:' \
                        '--physicalbackup-max-concurrent-reconciles=[PhysicalBackup reconciler concurrency]:n:' \
                        '--requeue-connection=[Connection requeue interval]:dur:' \
                        '--requeue-sql=[SQL object requeue interval]:dur:' \
                        '--requeue-sql-max-offset=[SQL requeue jitter]:dur:' \
                        '--requeue-sqljob=[SqlJob requeue interval]:dur:' \
                        '--requeue-maxscale=[MaxScale requeue interval]:dur:' \
                        '--sync-period=[watched-resource resync interval]:dur:' \
                        '--cache-sync-timeout=[cache sync timeout]:dur:' \
                        '--webhook[enable webhook server]' \
                        '--webhook-port=[webhook bind port]:port:' \
                        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
                        '--pprof[enable pprof HTTP server]' \
                        '--pprof-addr=[pprof bind host\:port]:host\:port:' \
                        '--feature-maxscale-suspend[feature: enable MaxScale suspension]'
                    ;;
            esac
            ;;
    esac
}

_mariadb-operator "$@"
