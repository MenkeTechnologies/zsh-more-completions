#compdef crossplane

# Zsh completion for Crossplane CLI

local curcontext="$curcontext" state line ret=1

local -a crossplane_commands
crossplane_commands=(
  'build:build Crossplane packages'
  'install:install Crossplane packages'
  'push:push Crossplane packages'
  'update:update Crossplane packages'
  'xpkg:manage Crossplane packages'
  'beta:commands in beta'
)

local -a crossplane_global_flags
crossplane_global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '-v[print verbose output]'
  '--verbose[print verbose output]'
  '--version[show version]'
)

_arguments -s -S \
  $crossplane_global_flags \
  '1:command:_describe -t commands command crossplane_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      build)
        _arguments -s -S \
          $crossplane_global_flags \
          'configuration[build a configuration package]' \
          'provider[build a provider package]' \
          'function[build a function package]' \
          '-f=[path to package directory]:directory:_directories' \
          '--package-root=[path to package directory]:directory:_directories' \
          '-o=[output file path]:output file:_files' \
          '--package-file=[output file path]:output file:_files' \
          '-e=[file patterns to include]:pattern:' \
          '--embed-runtime-image=[embed a runtime image]:image:' \
          '--embed-runtime-image-tarball=[embed a runtime image tarball]:tarball:_files' \
          '--ignore=[file patterns to ignore]:pattern:' \
          '*:path:_files' && ret=0
        ;;
      install)
        _arguments -s -S \
          $crossplane_global_flags \
          'configuration[install a configuration package]' \
          'provider[install a provider package]' \
          'function[install a function package]' \
          '-n=[name for the installed package]:name:' \
          '--name=[name for the installed package]:name:' \
          '--package=[package image]:image:' \
          '-w=[wait for installation]:duration:' \
          '--wait=[wait for installation]:duration:' \
          '--revision-history-limit=[revision history limit]:limit:' \
          '--manual-activation[require manual activation of revisions]' \
          '1:package image:' && ret=0
        ;;
      push)
        _arguments -s -S \
          $crossplane_global_flags \
          'configuration[push a configuration package]' \
          'provider[push a provider package]' \
          'function[push a function package]' \
          '-f=[path to package file]:package file:_files' \
          '--package-file=[path to package file]:package file:_files' \
          '1:package image tag:' && ret=0
        ;;
      update)
        _arguments -s -S \
          $crossplane_global_flags \
          'configuration[update a configuration package]' \
          'provider[update a provider package]' \
          'function[update a function package]' \
          '-n=[name of the installed package]:name:' \
          '--name=[name of the installed package]:name:' \
          '1:new package image:' && ret=0
        ;;
      xpkg)
        local -a xpkg_commands
        xpkg_commands=(
          'build:build a Crossplane package'
          'init:initialize a Crossplane package'
          'install:install a Crossplane package'
          'login:log in to a package registry'
          'logout:log out of a package registry'
          'push:push a Crossplane package'
          'update:update a Crossplane package'
        )
        _arguments -s -S \
          $crossplane_global_flags \
          '1:xpkg command:_describe -t commands command xpkg_commands' \
          '*::xpkg args:->xpkg_args' && ret=0
        case "$state" in
          xpkg_args)
            case "${line[1]}" in
              build)
                _arguments -s -S \
                  $crossplane_global_flags \
                  '-f=[path to package directory]:directory:_directories' \
                  '--package-root=[path to package directory]:directory:_directories' \
                  '-o=[output file path]:output file:_files' \
                  '--package-file=[output file path]:output file:_files' \
                  '-e=[file patterns to include]:pattern:' \
                  '--embed-runtime-image=[embed a runtime image]:image:' \
                  '--embed-runtime-image-tarball=[embed a tarball]:tarball:_files' \
                  '--ignore=[file patterns to ignore]:pattern:' && ret=0
                ;;
              init)
                _arguments -s -S \
                  $crossplane_global_flags \
                  '-d=[directory for the new package]:directory:_directories' \
                  '--directory=[directory for the new package]:directory:_directories' \
                  '-t=[type of package]:type:(configuration provider function)' \
                  '--type=[type of package]:type:(configuration provider function)' \
                  '1:package name:' && ret=0
                ;;
              login)
                _arguments -s -S \
                  $crossplane_global_flags \
                  '-u=[username]:username:' \
                  '--username=[username]:username:' \
                  '-p=[password]:password:' \
                  '--password=[password]:password:' \
                  '-t=[access token]:token:' \
                  '--token=[access token]:token:' \
                  '-a=[registry domain]:domain:' \
                  '--domain=[registry domain]:domain:' \
                  '--profile=[profile name]:profile:' && ret=0
                ;;
              push)
                _arguments -s -S \
                  $crossplane_global_flags \
                  '-f=[path to package file]:package file:_files' \
                  '--package-file=[path to package file]:package file:_files' \
                  '1:package image tag:' && ret=0
                ;;
              *)
                _arguments -s -S $crossplane_global_flags '*:args:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      beta)
        local -a beta_commands
        beta_commands=(
          'convert:convert Crossplane resources'
          'render:render a composition'
          'trace:trace a Crossplane resource'
          'top:display resource utilization'
          'validate:validate Crossplane resources'
          'xpkg:manage packages (beta)'
        )
        _arguments -s -S \
          $crossplane_global_flags \
          '1:beta command:_describe -t commands command beta_commands' \
          '*::beta args:' && ret=0
        ;;
      *)
        _arguments -s -S $crossplane_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
