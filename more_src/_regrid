#compdef regrid
# Documentation: http://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss168.html
# KAPPA: apply a geometrical transformation to an NDF

local ret=1

_arguments -s \
  'AXES=[indices of pixel axes to re-grid]:axes' \
  'CONSERVE=[preserve total data value]:conserve:(TRUE FALSE)' \
  'IN=[input NDF to be transformed]:NDF:_files' \
  'LBOUND=[lower pixel-index bounds of output]:lbound' \
  'MAPPING=[file containing the Mapping]:file:_files' \
  'METHOD=[sampling or binning scheme]:method' \
  'NORM=[normalize by contributing pixels]:norm:(TRUE FALSE)' \
  'OUT=[output transformed NDF]:NDF:_files' \
  'PARAMS=[interpolation-method parameters]:params' \
  'REBIN=[use rebinning instead of resampling]:rebin:(TRUE FALSE)' \
  'SCALE=[axis scaling factors]:scale' \
  'TITLE=[title for the output NDF]:title' \
  'TOL=[maximum geometrical distortion in pixels]:tol' \
  'UBOUND=[upper pixel-index bounds of output]:ubound' \
  'WLIM=[minimum good pixels for valid output]:wlim' \
  '*:NDF:_files' && ret=0

return ret
