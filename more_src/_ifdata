#compdef ifdata
# Documentation: ifdata --help / man ifdata (moreutils)
# Source: print network-interface configuration and statistics.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-e[interface existence (exit code)]' \
    '-p[print whole config]' \
    '-pe[print yes/no for existence]' \
    '-pa[print address]' \
    '-pn[print netmask]' \
    '-pN[print network address]' \
    '-pb[print broadcast address]' \
    '-pm[print MTU]' \
    '-ph[print hardware address]' \
    '-pf[print flags]' \
    '-si[print all input statistics]' \
    '-sip[input packets]' '-sib[input bytes]' '-sie[input errors]' \
    '-sid[input drops]' '-sif[input fifo errors]' '-sic[input compressed]' \
    '-sim[input multicast]' \
    '-so[print all output statistics]' \
    '-sop[output packets]' '-sob[output bytes]' '-soe[output errors]' \
    '-sod[output drops]' '-sof[output fifo errors]' '-sox[output collisions]' \
    '-soc[output carrier errors]' '-som[output multicast]' \
    '-bips[both in+out packets/sec]' '-bops[both in+out bytes/sec]' \
    '1:interface:_net_interfaces' \
    && ret=0

return ret
