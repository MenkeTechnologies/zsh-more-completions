#compdef dkimproxy dkimproxy.in dkimproxy.out
# Documentation: https://dkimproxy.sourceforge.net/manual/dkimproxy.out.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--conf_file=[config file]:file:_files' \
  '--listen=[listen address LISTENADDR:PORT]:addr' \
  '--relay=[relay address RELAYADDR:PORT]:addr' \
  '--reject-error[reject messages on processing errors]' \
  '--reject-fail[reject messages when verification/signing fails]' \
  '--hostname=[hostname for Authentication-Results header (dkimproxy.in)]:host' \
  '--signature=[signature type (dkimproxy.out)]:type:(dkim domainkeys)' \
  '--keyfile=[private key file (dkimproxy.out)]:file:_files' \
  '--selector=[key selector name (dkimproxy.out)]:selector' \
  '--method=[canonicalization (dkimproxy.out)]:method:(simple nowsp relaxed nofws)' \
  '--domain=[domain(s) to sign for (dkimproxy.out)]:domain' \
  '--sender_map=[sender-to-signature mapping file]:file:_files' \
  '--daemonize[run as a daemon]' \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--pidfile=[PID file]:file:_files' \
  '--min_servers=[number of processes to spawn]:n' && ret=0

return ret
