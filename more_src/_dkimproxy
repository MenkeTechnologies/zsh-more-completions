#compdef dkimproxy dkimproxy.in dkimproxy.out
# Documentation: https://man.archlinux.org/search?q=dkimproxy
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--conf_file=+[config file]:file:_files' \
  '--user=+[user]:user:_users' \
  '--group=+[group]:group:_groups' \
  '--pidfile=+[pid file]:file:_files' \
  '--background[run as daemon]' \
  '--no-background[run in foreground]' \
  '--debug[debug logging]' \
  '--listen=+[listen address]:addr:' \
  '--relay=+[relay address]:addr:' \
  '--domain=+[domain list]:domains:' \
  '--keyfile=+[private key]:file:_files' \
  '--selector=+[DKIM selector]:selector:' \
  '--method=+[signing method]:method:(relaxed simple)' \
  '--reject_fail[reject on signing fail]' && ret=0

return ret
