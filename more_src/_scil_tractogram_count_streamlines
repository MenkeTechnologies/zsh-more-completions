#compdef scil_tractogram_count_streamlines
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_count_streamlines.html
# Count streamlines in a tractogram

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--print_count_alone[output only the numeric result]' \
  '--indent=[indentation level for JSON formatting]:indent' \
  '--sort_keys[sort keys alphabetically in the output JSON]' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '1:in_tractogram:_files' && ret=0

return ret
