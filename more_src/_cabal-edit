#compdef cabal-edit
# Documentation: https://github.com/sdiehl/cabal-edit
# Add, remove, and upgrade dependencies in a .cabal file from the command line

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--inplace[edit the cabal file in place]' \
  '1:command:((
    add\:"add dependency to cabal file"
    list\:"list available versions from Hackage"
    upgrade\:"upgrade bounds for given package"
    remove\:"remove a given package"
    latest\:"get the latest version of a given package"
    rebuild\:"rebuild cache"
    upgradeall\:"upgrade all dependencies"
    format\:"format cabal file"
    extensions\:"list all default language extensions pragmas"
    lint\:"lint dependency bounds"
  ))' \
  '*::package:' && ret=0

return ret
