#compdef pg-online-schema-change pg-osc
# _pg-online-schema-change — Postgres zero-downtime schema changes (shayonj/pg-osc)
# upstream: https://github.com/shayonj/pg-osc
# Subcommands & flags from lib/pg_online_schema_change/cli.rb (Thor).

_pg-online-schema-change() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'perform:apply schema change with minimal locks'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                perform)
                    _arguments \
                        '(-a --alter-statement)'{-a+,--alter-statement=}'[ALTER statement]:sql:' \
                        '(-s --schema)'{-s+,--schema=}'[schema (default public)]:schema:' \
                        '(-d --dbname)'{-d+,--dbname=}'[database name]:db:' \
                        '--host=[server host]:host:_hosts' \
                        '(-u --username)'{-u+,--username=}'[database user]:user:_users' \
                        '(-p --port)'{-p+,--port=}'[database port (default 5432)]:port:' \
                        '(-v --verbose)'{-v,--verbose}'[debug logs]' \
                        '(-f --drop)'{-f,--drop}'[drop original table after swap]' \
                        '(-k --kill-backends)'{-k,--kill-backends}'[kill competing backends for lock]' \
                        '(-w --wait-time-for-lock)'{-w+,--wait-time-for-lock=}'[lock wait/retry duration]:secs:' \
                        '(-c --copy-statement)'{-c+,--copy-statement=}'[custom copy .sql]:file:_files -g "*.sql"' \
                        '(-b --pull-batch-count)'{-b+,--pull-batch-count=}'[rows per replay batch]:n:' \
                        '(-e --delta-count)'{-e+,--delta-count=}'[remaining rows before swap]:n:' \
                        '(-o --skip-foreign-key-validation)'{-o,--skip-foreign-key-validation}'[skip FK validation after swap]'
                    ;;
            esac
            ;;
    esac
}

_pg-online-schema-change "$@"
