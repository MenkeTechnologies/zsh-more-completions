#compdef bfgminer
# _bfgminer — Luke-Jr bfgminer multi-threaded FPGA/ASIC mining CLI fork of cgminer adding extended hardware support BitFury Drillbit Klondike Avalon BIGPIC Cointerra Hashbuster pools failover Stratum getwork dynamic frequency (luke-jr team, C); getopt
# upstream: https://github.com/luke-jr/bfgminer

_bfgminer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf bfgminer.conf"' \
        '--config=+[config file]:file:_files -g "*.conf bfgminer.conf"' \
        '-o+[pool url]:str:' \
        '--url=+[pool url]:str:' \
        '-u+[user.worker]:str:' \
        '--user=+[user.worker]:str:' \
        '-p+[password]:str:' \
        '--pass=+[password]:str:' \
        '-O+[user:password]:str:' \
        '--userpass=+[user:password]:str:' \
        '-q+[N]:n:' \
        '--queue=+[N]:n:' \
        '-l+[seconds]:n:' \
        '--log=+[seconds]:n:' \
        '-d+[device list]:str:' \
        '--device=+[device list]:str:' \
        '-S+[scan serial]:str:' \
        '--scan-serial=+[scan serial]:str:' \
        '-T[text only]' \
        '--text-only[text only]' \
        '-D[debug]' \
        '--debug[debug]' \
        '--protocol-dump[protocol dump]' \
        '--log-show-date[log show date]' \
        '--api-listen[enable API server]' \
        '--api-port=+[port]:n:' \
        '--api-network[allow API from network]' \
        '--api-groups=+[csv]:str:' \
        '--api-allow=+[csv]:str:' \
        '--api-description=+[text]:str:' \
        '--no-restart[no restart]' \
        '--no-show-procs[no show procs]' \
        '--no-pool-disable[no pool disable]' \
        '--syslog[use syslog]' \
        '--scan-time=+[seconds]:n:' \
        '--monitor=+[command]:str:' \
        '--shares=+[N]:n:' \
        '--failover-only[failover only]' \
        '--socks-proxy=+[host:port]:str:' \
        '--load-balance[load balance]' \
        '--round-robin[round robin]' \
        '--coinbase-addr=+[addr]:str:' \
        '--coinbase-sig=+[text]:str:' \
        '--cmd-idle=+[cmd]:str:' \
        '--cmd-sick=+[cmd]:str:' \
        '--cmd-dead=+[cmd]:str:' \
        '--lowmem[low memory]' \
        '--worktime[work time]' \
        '--enable-icarus[enable Icarus]' \
        '--enable-jingtian[enable Jingtian]' \
        '--enable-modminer[enable Modminer]' \
        '--enable-modminer-clock=+[N]:n:' \
        '--enable-x6500[enable X6500]'
}

_bfgminer "$@"
