#compdef fastx_renamer
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fastx_renamer.1.en.html
# FASTX-Toolkit: rename the sequence identifiers in a FASTA/Q file

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-n+[rename type]:type:(SEQ COUNT)' \
  '-v[verbose: report number of sequences]' \
  '-z[compress output with GZIP]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
