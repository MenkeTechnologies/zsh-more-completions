#compdef suwellrf
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/well_logs/suwellrf.c
# SUWELLRF - convert well log depth/velocity/density into reflectivity

local ret=1

_arguments -s -S \
  'dvrfile=[file of depth, velocity and density values]:f:_files' \
  'dvfile=[file of depth and velocity values]:f:_files' \
  'drfile=[file of depth and density values]:f:_files' \
  'dfile=[file of depth values]:f:_files' \
  'vfile=[file of velocity log values]:f:_files' \
  'rhofile=[file of density log values]:f:_files' \
  'nval=[number of triplets/pairs/values]:n:' \
  'dtout=[desired output time sampling interval (sec)]:d:' \
  'ntr=[number of traces to output]:n:' \
  '*:SU file:_files' && ret=0

return ret
