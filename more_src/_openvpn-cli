#compdef openvpn-cli
# _openvpn-cli — OpenVPN community SSL/TLS VPN solution CLI alias (openvpn team, C); custom argparse
# upstream: https://github.com/OpenVPN/openvpn

_openvpn-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.ovpn"' \
        '--remote=+[host port]:str:' \
        '--remote-random[randomize remote]' \
        '--port=+[port]:port:' \
        '--proto=+[protocol]:p:(udp tcp tcp-server tcp-client)' \
        '--lport=+[local port]:port:' \
        '--rport=+[remote port]:port:' \
        '--dev=+[device]:str:' \
        '--dev-type=+[type]:t:(tun tap)' \
        '--dev-node=+[node]:file:_files' \
        '--mtu-disc=+[mode]:m:(yes no maybe)' \
        '--ifconfig=+[local remote]:str:' \
        '--ifconfig-pool=+[start end]:str:' \
        '--server=+[network netmask]:str:' \
        '--client[client mode]' \
        '--ca=+[ca file]:file:_files -g "*.{crt,pem}"' \
        '--cert=+[cert file]:file:_files -g "*.{crt,pem}"' \
        '--key=+[key file]:file:_files -g "*.{key,pem}"' \
        '--dh=+[dh file]:file:_files -g "*.{pem,dh}"' \
        '--tls-auth=+[ta file]:file:_files' \
        '--tls-crypt=+[file]:file:_files' \
        '--tls-server[tls server mode]' \
        '--tls-client[tls client mode]' \
        '--auth-user-pass=+[file]:file:_files' \
        '--auth-nocache[do not cache auth]' \
        '--auth=+[auth alg]:str:' \
        '--cipher=+[cipher]:c:(AES-128-CBC AES-192-CBC AES-256-CBC AES-128-GCM AES-256-GCM CHACHA20-POLY1305 BF-CBC DES-EDE3-CBC)' \
        '--data-ciphers=+[ciphers]:str:' \
        '--data-ciphers-fallback=+[cipher]:str:' \
        '--tun-mtu=+[mtu]:n:' \
        '--link-mtu=+[mtu]:n:' \
        '--fragment=+[bytes]:n:' \
        '--mssfix=+[bytes]:n:' \
        '--ping=+[seconds]:n:' \
        '--ping-restart=+[seconds]:n:' \
        '--ping-exit=+[seconds]:n:' \
        '--keepalive=+[ping ping-restart]:str:' \
        '--persist-tun[persist tun device]' \
        '--persist-key[persist key file]' \
        '--persist-remote-ip[persist remote ip]' \
        '--persist-local-ip[persist local ip]' \
        '--explicit-exit-notify=+[n]:n:' \
        '--reneg-sec=+[seconds]:n:' \
        '--user=+[user]:_users' \
        '--group=+[group]:_groups' \
        '--script-security=+[level]:n:' \
        '--verb=+[level]:n:' \
        '--mute=+[count]:n:' \
        '--log=+[log file]:file:_files' \
        '--log-append=+[log file]:file:_files' \
        '--syslog=+[name]:str:' \
        '--status=+[file [n]]:file:_files' \
        '--writepid=+[file]:file:_files' \
        '--daemon[run as daemon]' \
        '--nice=+[level]:n:' \
        '--chroot=+[dir]:dir:_files -/' \
        '--cd=+[dir]:dir:_files -/' \
        '--up=+[script]:file:_files' \
        '--down=+[script]:file:_files' \
        '--pull[client pull mode]' \
        '--push=+[option]:str:' \
        '--route=+[network netmask gateway metric]:str:' \
        '--route-gateway=+[gateway]:str:' \
        '--redirect-gateway=+[flags]:str:' \
        '--redirect-private=+[flags]:str:' \
        '--block-outside-dns[block outside dns]' \
        '--dhcp-option=+[type value]:str:' \
        '--client-config-dir=+[dir]:dir:_files -/' \
        '--ccd-exclusive[clients require ccd]' \
        '--mode=+[mode]:m:(server p2p)' \
        '--topology=+[topology]:t:(net30 p2p subnet)' \
        '--compress=+[alg]:a:(lzo lz4 lz4-v2 stub stub-v2)' \
        '--comp-lzo=+[mode]:m:(yes no adaptive)' \
        '--mlock[lock memory]' \
        '--show-tls[show available TLS ciphers]' \
        '--show-ciphers[show available ciphers]' \
        '--show-digests[show available digests]' \
        '--show-engines[show OpenSSL engines]' \
        '--genkey[generate static key]' \
        '--secret=+[file]:file:_files' \
        '*:arg:'
}

_openvpn-cli "$@"
