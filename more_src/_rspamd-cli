#compdef rspamd-cli
# Documentation: https://man.archlinux.org/search?q=rspamd-cli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'scan:scan email with rspamd'
  'learn-spam:teach spam example'
  'learn-ham:teach ham example'
  'stat:show statistics'
  'config:show config'
  'reload:reload config'
  'counters:show counters'
  'history:show history'
  'sync:sync fuzzy storage'
  'lua:run lua script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-H --host)'{-H,--host}'+[connection target]:host:_hosts' \
  '(-P --password)'{-P,--password}'+[controller password]:pw:' \
  '(-t --timeout)'{-t,--timeout}'+[timeout sec]:sec:' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rspamd-cli command' commands && ret=0 ;;
esac

return ret
