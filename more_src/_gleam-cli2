#compdef gleam-cli2 gleam2
# _gleam-cli2 — Louis Pilfold Gleam Lang gleam-cli2 CLI command-line frontend wrapping the Gleam friendly programming language for the Erlang BEAM open-source written in Rust originally Louis Pilfold pure functional statically typed compiles to Erlang and JavaScript LSP language server included build new check run test format add remove update clean shell publish help fix hex docs login deps download remove run lsp completions help update build target javascript erlang BEAM OTP supervisor (Louis Pilfold Gleam Lang team Hayleigh Thompson, Rust); clap
# upstream: https://gleam.run/

_gleam-cli2() {
    local -a sub=(
        'add:Add new project dependencies'
        'build:Build the project'
        'check:Type check the project'
        'clean:Clean build artifacts'
        'completion:Generate shell completion'
        'deps:Work with dependency packages'
        'docs:Render HTML documentation'
        'export:Export information from a project'
        'fix:Update source code for a new Gleam version'
        'format:Format source code'
        'hex:Work with the Hex package manager'
        'help:Print help'
        'lsp:Run the language server'
        'new:Create a new project'
        'publish:Publish the project to Hex'
        'remove:Remove dependency packages'
        'run:Build and run the project'
        'shell:Start an Erlang shell'
        'test:Run the project tests'
        'update:Update dependency packages to latest'
        'version:Print version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--target=+[t]:t:(erlang javascript)' \
        '-t+[target]:t:(erlang javascript)' \
        '--runtime=+[r]:r:(node deno bun)' \
        '--package=+[name]:str:' \
        '-p+[package]:str:' \
        '--module=+[name]:str:' \
        '-m+[module]:str:' \
        '--name=+[name]:str:' \
        '--description=+[text]:str:' \
        '--skip-git[skip git init]' \
        '--skip-github[skip GitHub config]' \
        '--template=+[t]:t:(lib bin)' \
        '--dev[add as dev dep]' \
        '--replace[replace existing files]' \
        '--check[check only]' \
        '--stdin[read from stdin]' \
        '--all-targets[all targets]' \
        '--all-shells[all shells]' \
        '--shell=+[s]:s:(bash zsh fish powershell)' \
        '--mode=+[m]:m:(dev release)' \
        '--no-print-progress[no print progress]' \
        '--copy-from=+[dir]:dir:_files -/' \
        '--module=+[name]:str:' \
        '--repo-host=+[host]:_hosts' \
        '--no-build[no build]' \
        '--token=+[token]:str:' \
        '--no-confirm[no confirm]' \
        '-y[yes/no confirm]' \
        '--replace[replace]' \
        '--filter=+[name]:str:' \
        '*--filter=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gleam subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments '*:dir:_files -/' ;;
                run|test|shell|build|check|clean|deps|docs|format|update|publish|hex|fix) _arguments '*:arg:' ;;
                add|remove) _arguments '*:package:' ;;
                deps) _arguments '1:op:(list download update)' '*:arg:' ;;
                hex) _arguments '1:op:(authenticate)' '*:arg:' ;;
                docs) _arguments '1:op:(build publish remove)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                export) _arguments '1:type:(erlang-shipment hex-tarball javascript-prelude typescript-prelude package-interface package-information)' '*:arg:' ;;
            esac
            ;;
    esac
}

_gleam-cli2 "$@"
