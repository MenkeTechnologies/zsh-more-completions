#compdef fisher

# Zsh completion for fisher (Fish shell plugin manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'install:install plugins'
      'remove:remove plugins'
      'update:update plugins'
      'list:list installed plugins'
    )
    _describe -t commands 'fisher subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      install|remove|update)
        _message 'plugin (owner/repo or URL)' && ret=0
        ;;
    esac
    ;;
esac

return ret
