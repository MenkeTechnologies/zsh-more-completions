#compdef ssmanager

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.json"' \
  '-u[UDP only]' \
  '-U[TCP and UDP]' \
  '(-b --outbound-bind-addr --bind-addr)'{-b,--outbound-bind-addr,--bind-addr}'=[outbound bind addr]:addr:' \
  '--outbound-bind-interface=[outbound iface]:iface:_net_interfaces' \
  '--manager-addr=[manager address]:addr:' \
  '--manager-address=[manager address]:addr:' \
  '--plugin=[SIP003 plugin]:plugin:' \
  '--plugin-mode=[plugin mode]:mode:(tcp udp tcp_and_udp)' \
  '--plugin-opts=[plugin options]:opts:' \
  '-6[prefer IPv6]' \
  '--tcp-no-delay[TCP no-delay]' \
  '--no-delay[TCP no-delay]' \
  '--tcp-fast-open[TCP fast open]' \
  '--fast-open[TCP fast open]' \
  '--tcp-multipath[multipath TCP]' \
  '--mptcp[multipath TCP]' \
  '*-v[verbose]' \
  '--log-without-time[no timestamps in log]' \
  '--log-config=[log config file]:file:_files' \
  '(-d --daemonize)'{-d,--daemonize}'[daemonize]' \
  '--daemonize-pid=[pid file]:file:_files' \
  '--manager-server-mode=[server mode]:mode:' \
  '--manager-server-working-directory=[working dir]:dir:_files -/' \
  '(-n --nofile)'{-n,--nofile}'=[nofile rlimit]:n:' \
  '--outbound-fwmark=[outbound fwmark]:n:' \
  '--outbound-user-cookie=[outbound user cookie]:n:' \
  '--single-threaded[single threaded runtime]' \
  '--worker-threads=[worker threads]:n:' \
  '(-a --user)'{-a,--user}'=[run as user]:user:_users' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
