#compdef ormolu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[mode of operation]:mode:(stdout inplace check)' \
  '--mode=[mode of operation]:mode:(stdout inplace check)' \
  '-o+[Ormolu option]:option:' \
  '--ghc-opt=[GHC option]:option:' \
  '-p+[fixity info]:package:' \
  '--package=[fixity info]:package:' \
  '-d+[fixity declaration]:fixity:' \
  '--fixity=[fixity declaration]:fixity:' \
  '-c[check mode (like --mode check)]' \
  '--check-idempotence[check that formatting is idempotent]' \
  '--no-cabal[do not use .cabal file for configuration]' \
  '--stdin-input-file=[file path for stdin input]:file:_files' \
  '--color=[colorize output]:when:(auto always never)' \
  '--start-line=[start line for partial formatting]:line:' \
  '--end-line=[end line for partial formatting]:line:' \
  '*:Haskell source files:_files -g "*.hs"' && ret=0

return ret
