#compdef smug

_smug_start() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-w,--windows}'[specify windows to start]:windows:' \
    {-a,--attach}'[attach to session after start]' \
    {-d,--debug}'[enable debug mode]' \
    '--inside-current-session[start inside current tmux session]' \
    ':project name:'
}

_smug_stop() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-w,--windows}'[specify windows to stop]:windows:' \
    {-d,--debug}'[enable debug mode]' \
    ':project name:'
}

_smug_print() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-d,--debug}'[enable debug mode]' \
    ':project name:'
}

_smug() {
  local -a commands
  commands=(
    'new:create a new project'
    'start:start a project'
    'stop:stop a project'
    'edit:edit a project'
    'list:list projects'
    'print:print project configuration'
    'help:show help'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'smug command' commands
      ;;
    arguments)
      case "$words[1]" in
        start) _smug_start ;;
        stop) _smug_stop ;;
        print) _smug_print ;;
        new|edit) _arguments ':project name:' ;;
      esac
      ;;
  esac
}

_smug "$@"
