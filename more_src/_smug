#compdef smug
# Documentation: https://github.com/ivaaaan/smug
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_smug_start() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-w,--windows}'[specify windows to start (repeatable)]:windows:' \
    {-a,--attach}'[attach to session after start]' \
    {-i,--inside-current-session}'[create windows in existing session]' \
    {-d,--debug}'[log all commands]' \
    '--detach[detach session]' \
    ':project name:'
}

_smug_stop() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-w,--windows}'[specify windows to stop (repeatable)]:windows:' \
    {-d,--debug}'[log all commands]' \
    ':project name:'
}

_smug_print() {
  _arguments \
    {-f,--file}'[specify project file]:file:_files' \
    {-d,--debug}'[log all commands]' \
    ':project name:'
}

_smug() {
  local -a commands
  commands=(
    'new:create a new project'
    'start:start a project'
    'stop:kill an active session'
    'edit:edit a project'
    'list:list all available projects'
    'print:print project configuration'
  )

  _arguments \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'smug command' commands
      ;;
    arguments)
      case "$words[1]" in
        start) _smug_start ;;
        stop) _smug_stop ;;
        print) _smug_print ;;
        new|edit) _arguments ':project name:' ;;
      esac
      ;;
  esac
}

_smug "$@"
