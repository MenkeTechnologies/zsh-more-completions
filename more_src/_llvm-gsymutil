#compdef llvm-gsymutil
# _llvm-gsymutil — LLVM GSYM symbolicator (LLVM project, C++); convert DWARF to compact GSYM and lookup addresses
# upstream: https://github.com/llvm/llvm-project

_llvm-gsymutil() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--convert=+[input file to convert]:file:_files' \
        '--out-file=+[output file]:file:_files' \
        '--arch=+[arch]:arch:' \
        '--num-threads=+[num threads]:n:' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '--verify[verify GSYM]' \
        '--segment-size=+[segment size]:n:' \
        '--address=+[address]:addr:' \
        '--addresses-from-stdin[read addresses from stdin]' \
        '--lookup=+[lookup address]:addr:' \
        '--merged-functions[show merged functions]' \
        '--json-summary-file=+[json summary file]:file:_files' \
        '--callsites-yaml-file=+[callsites yaml file]:file:_files' \
        '*:file:_files'
}

_llvm-gsymutil "$@"
