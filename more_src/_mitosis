#      description: 'Compile a Mitosis component',
#      run: async (toolbox: GluegunToolbox) => {
#        const { parameters, print, filesystem } = toolbox
#
#        // parameters.options is the parsed flag dict
#        const from = parameters.options.f ?? parameters.options.from
#        const to = parameters.options.t ?? parameters.options.to
#        const config = parameters.options.config ?? parameters.options.c
#
#        // parameters.array is positionals
