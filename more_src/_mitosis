#    module.exports = command
#
#  gluegun distinctive features:
#    - TOOLBOX PATTERN: each command's `run(toolbox)` receives a
#      pre-populated helper bag (filesystem/system/print/prompt/
#      template/patching/strings/http/semver/packageManager/meta)
#      — caller pulls what they need via destructuring
#    - PLUGIN SYSTEM with NPM PACKAGE PATTERN discovery — `.plugins
#      ('./node_modules', { matching: 'foo-*' })` finds + loads
#      plugin packages by name glob; plugins contribute commands
#      AND extend toolbox via `module.exports = (toolbox) => {
#      toolbox.myHelper = ... }`
#    - FILE-SYSTEM-DISCOVERED COMMANDS: `.src(__dirname)` scans
#      `commands/*.ts` and registers each as a subcommand
#      automatically — no manual `addCommand()` calls
#    - COMMAND OBJECTS: `{ name, alias?, description?, hidden?,
#      run(toolbox) }` shape; minimal ceremony
#    - PARAMETERS API on toolbox.parameters:
#      * `parameters.options` — flat flag-value dict (from minimist-
#        style parser internally)
#      * `parameters.first` — first positional
#      * `parameters.second` — second positional
#      * `parameters.array` — all positionals as array
#      * `parameters.string` — full unparsed string
#      * `parameters.command` — matched subcommand name
#      * `parameters.argv` — raw argv
#    - FILESYSTEM helpers: `read/readAsync/write/writeAsync/copy/
#      copyAsync/move/exists/dir/cwd/path/append/prepend/inspectTree`
#    - PRINT helpers: `info/warn/error/success/debug/divider/table/
#      newline/spin (spinner)/colors`
#    - PROMPT helpers (delegates to enquirer/inquirer): `ask/
#      confirm/multiSelect/autocomplete`
#    - TEMPLATE helpers: `generate({template, target, props})` —
#      ejs-style template rendering with prop substitution
#    - PATCHING helpers: `patch(file, opts)`, `replace(file,
#      pattern, replacement)`, `append(file, content)`, `prepend
#      (file, content)`, `update(file, fn)`
#    - STRINGS helpers: `camelCase/snakeCase/kebabCase/pascalCase/
#      sentenceCase/dotCase/pathCase` (uses lodash internally)
#    - PACKAGE MANAGER helpers: `packageManager.add/remove/install/
#      has` — auto-detects yarn/npm/pnpm
#    - SYSTEM helpers: `system.exec/run/which/spawn`
#    - AUTO --help / --version generation via `.help()` / `.version()`
#      chained-builder calls
#    - INSPIRED BY ignite-cli (Infinite Red's React Native
#      generator) which gluegun was ABSTRACTED OUT OF — ignite is
#      essentially a gluegun CLI with React Native specific plugins
#  Distinct from R236 commander (TJ Holowaychuk's chained-builder
#  with subcommand-tree — Vue CLI/jest/ngx), R237 oclif (Heroku/
#  Salesforce enterprise framework with plugin-discovery; oclif
#  is gluegun's CLOSEST RIVAL since both have plugins — but oclif
#  uses classes + decorators while gluegun uses functions +
#  toolbox), yargs (Bash-style yargs-parser framework — npm/jest),
#  R398 meow (Sindre Sorhus zero-config using minimist), R399
#  substack/minimist (the ORIGINAL micro-arg-parser), R400 cac
#  (Anthony Fu — uses mri internally), R403 clipanion (Yarn's
#  class-based CLI with `@Command()` decorators), R406 vercel/arg
#  (spec-object schema with built-in type coercion functions),
#  R409 mri (lukeed minimal parser — what cac/sade use internally),
#  R412 citty (UnJS TypeScript-first DECLARATIVE-SCHEMA), R415
#  cmd-ts (Schniz's PARSER COMBINATOR algebra borrowed from
#  Haskell's optparse-applicative).  TypeScript-Node documented
#  libraries so far: commander, oclif, yargs, meow, minimist, cac,
#  clipanion, arg, mri, sade, citty, cmd-ts, gluegun (this
#  round)... 14.  gluegun's distinguishing feature vs all other
#  TS-Node libs: gluegun is the ONLY ONE that uses the TOOLBOX
#  PATTERN where commands receive a PRE-POPULATED HELPER BAG —
#  every other lib focuses purely on arg parsing and leaves
#  filesystem/template/prompt helpers to the caller.  gluegun's
#  approach: TOOLBOX-PATTERN framework with `build().brand(name).
#  src(dir).plugins(dir, opts).help().version().exclude().create()`
#  chained-builder runtime + file-system-discovered `commands/*.ts`
#  + `GluegunCommand{name, alias, description, run(toolbox)}`
#  per-command shape + RICH toolbox helpers (parameters/filesystem/
#  system/print/prompt/template/patching/strings/http/semver/
#  packageManager/meta) + NPM PACKAGE PATTERN plugin discovery
#  (`.plugins('./node_modules', { matching: 'mitosis-*' })`) +
#  AUTO --help/--version + INSPIRED BY ignite-cli that gluegun
#  was abstracted out of — corpus's **first documented toolbox-
#  pattern TypeScript-Node CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 157; TypeScript-Node
#  ecosystem now has 14 documented CLI libraries — TYING WITH
#  RUST AND GO at the top of the cross-language taxonomy in a
#  THREE-WAY TIE at 14.
#
#  Surface (verbatim from `packages/cli/src/cli.ts` build()
#  configuration + `packages/cli/src/commands/{build,compile,new}.ts`
#  GluegunCommand exports):
#
#  Usage:
#    mitosis <subcommand> [options]
#
#  Subcommands (file-system-discovered from `commands/`):
#    build (b)                      Build all components per
#                                   mitosis.config.js (reads
#                                   `targets` from config and
#                                   compiles every component)
#    compile (c)                    Compile a single component
#                                   file (one-off, doesn't need
#                                   mitosis.config.js to drive
#                                   targets)
#    new (n)                        Scaffold a new Mitosis project
#                                   (npm init + installs
#                                   @builder.io/mitosis + tsc)
#    help (h)                       Show help (auto from
#                                   .help() in cli.ts)
#
#  Auto from `.version()`/`.help()`:
#    -h, --help                     Show help
#    -v, --version                  Show version
#
#  mitosis build (b) options:
#    -c, --config <PATH>            Path to mitosis.config.js
#                                   (default: ./mitosis.config.js)
#        --targets <LIST>           Comma-separated targets list
#                                   to ADD to config's targets
#        --excludeTargets <LIST>    Comma-separated targets list
#                                   to EXCLUDE from config's targets
#
#  mitosis compile (c) options:
#    -c, --config <PATH>            Path to config
#    -f, --from <SYNTAX>            Input syntax (default: mitosis;
#                                   options: mitosis | svelte |
#                                   builder)
#    -t, --to <TARGET>              Output target (REQUIRED;
#                                   options: react | vue | qwik |
#                                   solid | angular | svelte |
#                                   stencil | liquid | html |
#                                   alpine | builder | rsc |
#                                   webcomponents | template)
#    -o, --out <FILE>               Output file (single-input only)
#        --outDir <DIR>             Output directory (multi-input)
#    -n, --dryRun                   Dry run (don't write files)
#        --force                    Force overwrite existing output
#    -l, --list                     List available targets and exit
#        --prettier                 Run prettier on output (default:
#                                   true)
#        --format <FMT>             Output format (target-specific)
#        --prefix <PFX>             Symbol prefix
#        --includeIds               Include component IDs in output
#        --styles <TYPE>            Styles type (target-specific:
#                                   styled-components | css-modules
#                                   | css)
#        --state <TYPE>             State type (target-specific)
#        --type <TYPE>              Output type variant
#        --api <API>                Target API style
#        --cssNamespace <NS>        CSS namespace
#        --builderComponents        Keep Builder.io component refs
#                                   (default: compile away)
#        --header <HDR>             Custom header text on output files
#
#  mitosis new (n) options:
#    (no flags — interactive scaffolder)
#
#  Examples:
#    mitosis new                                            # Scaffold new project
#    mitosis build                                          # Build per config targets
#    mitosis build --targets react,vue                      # Add targets to build
#    mitosis build --excludeTargets svelte                  # Exclude svelte from build
#    mitosis compile -f mitosis -t react -o Button.jsx Button.lite.tsx
#    mitosis compile -t vue -o Button.vue Button.lite.tsx   # Compile to Vue
#    mitosis compile -t qwik --outDir dist-qwik src/*.lite.tsx
#    mitosis compile -t react -n src/Button.lite.tsx        # Dry-run preview
#    mitosis compile -l                                     # List supported targets
#    mitosis compile -t react --prettier --includeIds Button.lite.tsx
#    mitosis -v                                             # Show version
#    mitosis help                                           # Auto-gen help banner
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also gluegun users):
#    - ignite-cli (IN CORPUS via _ignite-cli + _ignite — THE
#      FLAGSHIP gluegun user; Infinite Red's React Native
#      generator; gluegun was abstracted out of ignite)
#    - create-expo-stack (IN CORPUS via _create-expo-stack — 2,556
#      stars React Native + Expo scaffolder)
#    - solidarity (infinitered/solidarity 640 stars — Infinite
#      Red's project audit; FUTURE candidate)
#    - graph-cli (graphprotocol/graph-tooling 423 stars — The
#      Graph Protocol Web3 CLI; FUTURE candidate)
#    - warthog (goldcaddy77/warthog 364 stars — GraphQL framework;
#      FUTURE candidate)
#    - flame (jamonholmgren/flame 308 stars — Flame AI RN
#      upgrader; FUTURE candidate)
# ============================================================================

_mitosis() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'build:build all components per mitosis.config.js'
        'b:build all components per mitosis.config.js (alias)'
        'compile:compile a single component file'
        'c:compile a single component file (alias)'
        'new:scaffold a new Mitosis project'
        'n:scaffold a new Mitosis project (alias)'
        'help:show help'
        'h:show help (alias)'
      )
      _describe -t subcommands 'mitosis subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        build|b)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'[path to mitosis.config.js]:file:_files -g "*.js"' \
            '--targets[comma-separated targets to add]:targets:' \
            '--excludeTargets[comma-separated targets to exclude]:targets:'
          ;;
        compile|c)
          _arguments -s -S \
            '(-c --config)'{-c,--config}'[path to config]:file:_files -g "*.js"' \
            '(-f --from)'{-f,--from}'[input syntax]:syntax:(mitosis svelte builder)' \
            '(-t --to)'{-t,--to}'[output target (REQUIRED)]:target:(react vue qwik solid angular svelte stencil liquid html alpine builder rsc webcomponents template)' \
            '(-o --out)'{-o,--out}'[output file]:file:_files' \
            '--outDir[output directory]:dir:_directories' \
            '(-n --dryRun)'{-n,--dryRun}'[dry run (do not write files)]' \
            '--force[force overwrite existing output]' \
            '(-l --list)'{-l,--list}'[list available targets and exit]' \
            '--prettier[run prettier on output]' \
            '--format[output format]:format:' \
            '--prefix[symbol prefix]:prefix:' \
            '--includeIds[include component IDs in output]' \
            '--styles[styles type]:styles:(styled-components css-modules css)' \
            '--state[state type]:state:' \
            '--type[output type variant]:type:' \
            '--api[target API style]:api:' \
            '--cssNamespace[CSS namespace]:namespace:' \
            '--builderComponents[keep Builder.io component refs]' \
            '--header[custom header text on output files]:header:' \
            '*:file:_files -g "*.(lite.tsx|svelte|tsx|jsx)"'
          ;;
      esac
      ;;
  esac
}

_mitosis "$@"
