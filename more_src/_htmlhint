#compdef htmlhint
# Documentation: https://github.com/HTMLHint/HTMLHint
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# htmlhint - the static code analysis tool for HTML.

_arguments -s -S \
  '(-l --list)'{-l,--list}'[list all available rules]' \
  '(-c --config)'{-c,--config}'[custom configuration file]:file:_files' \
  '(-r --rules)'{-r,--rules}'[set rules (comma-separated)]:rules' \
  '(-f --format)'{-f,--format}'[output format]:format:(default json junit checkstyle unix markdown compact)' \
  '--nocolor[disable color output]' \
  '(-i --ignore)'{-i,--ignore}'[add file patterns to ignore]:pattern' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:files:_files -g "*.html"' && return 0
