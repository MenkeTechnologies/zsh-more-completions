#compdef halign
# Documentation: https://github.com/malabz/HAlign-3
# HAlign 3 - fast multiple sequence alignment of large nucleotide datasets

local ret=1

_arguments -s -S \
  '-o[output aligned file]:file:_files' \
  '-t[number of threads (default half of cores)]:threads' \
  '-c[centre sequence index, 0-based]:index' \
  '-s[output alignments without sequence identifiers]' \
  '(-h)-h[display help message and exit]' \
  '(-v)-v[display version information and exit]' \
  '*:file:_files' && ret=0

return ret
