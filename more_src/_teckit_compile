#compdef teckit_compile
# Documentation: teckit_compile --help (TECkit)
# Source: SIL TECkit — compile text-encoding mapping (.map) to compiled table (.tec).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-u[read source as UTF-8 even without BOM]' \
    '(-x -z)-x[generate XML representation instead of compiled table]' \
    '(-x -z)-z[generate uncompressed table format]' \
    '-o+[output compiled table (- = stdout)]:file:_files -g "*.tec"' \
    '1:mapping description (.map) file:_files -g "*.map"' \
    && ret=0

return ret
