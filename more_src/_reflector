#compdef reflector

# Zsh completion for reflector - Arch Linux mirror list manager

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--age[max mirror age in hours]:hours' \
  '--cache-timeout[cache timeout in seconds]:seconds' \
  '--completion-percent[min completion percent]:percent' \
  '--connection-timeout[connection timeout in seconds]:seconds' \
  '--country[filter by country]:country' \
  '--delay[max sync delay in hours]:hours' \
  '--download-timeout[download timeout in seconds]:seconds' \
  '--fastest[return N fastest mirrors]:count' \
  '--include[include mirrors matching pattern]:pattern' \
  '--exclude[exclude mirrors matching pattern]:pattern' \
  '--info[print mirror information]' \
  '--isos[include ISO mirrors only]' \
  '--ipv4[include IPv4 mirrors]' \
  '--ipv6[include IPv6 mirrors]' \
  '--latest[limit to N most recently synced]:count' \
  '--list-countries[list available countries]' \
  '--number[limit to N mirrors]:count' \
  '--protocol[filter by protocol]:protocol:(http https ftp rsync)' \
  '--save[save output to file]:file:_files' \
  '--score[limit to N top scored mirrors]:count' \
  '--sort[sort by]:key:(age rate country score delay)' \
  '--threads[number of threads for rating]:threads' \
  '--url[add a custom mirror URL]:URL' \
  '--verbose[enable verbose output]'
