#compdef workload
# Documentation: upstream cmd/workload/{main,testsuite,filtertest,historytestgen,tracetestgen,prooftestgen,filtertestperf,filtertestfuzz}.go
# at github.com/ethereum/go-ethereum
# Reference accessed: 2026-05-30
# Continuation of go-ethereum sister-binary R43. workload runs RPC-test
# suites against a live node (mainnet + sepolia coverage). Ships
# alongside the previously-covered _geth/_abigen/_clef/_devp2p/_ethkey/
# _rlpdump/_blsync/_era/_evm/_fetchpayload binaries.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'test:run workload tests against an RPC endpoint'
  'historygen:generate history-test JSON queries'
  'filtergen:generate filter-test JSON queries'
  'tracegen:generate trace-test JSON queries + result outputs'
  'proofgen:generate proof-test JSON queries + result outputs'
  'filterperf:run filter performance benchmarks'
  'filterfuzz:fuzz filter queries against an RPC endpoint'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'workload subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      test)
        _arguments \
          '--run=[run only tests matching pattern]:pattern:' \
          '--tap[TAP-format output]' \
          '--slow[include slow tests]' \
          '--archive[include archive-mode tests]' \
          '--sepolia[run Sepolia testnet tests]' \
          '--mainnet[run mainnet tests]' \
          '--queries=[filter-test JSON queries file]:file:_files -g "*.json"' \
          '--history-tests=[history-test JSON queries file]:file:_files -g "*.json"' \
          '--trace-tests=[trace-test JSON queries file]:file:_files -g "*.json"' \
          '--proof-tests=[proof-test JSON queries file]:file:_files -g "*.json"' \
          '--trace-invalid=[trace-test invalid output directory]:directory:_directories' \
          '--proof-invalid=[proof-test invalid output directory]:directory:_directories' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      historygen)
        _arguments \
          '--history-tests=[history-test JSON queries file]:file:_files -g "*.json"' \
          '--earliest=[earliest block to test (default 0)]:N:' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      filtergen)
        _arguments \
          '--queries=[filter-test JSON queries file (default filter_queries.json)]:file:_files -g "*.json"' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      tracegen)
        _arguments \
          '--trace-tests=[trace-test JSON queries file (default trace_tests.json)]:file:_files -g "*.json"' \
          '--trace-output=[trace-result output directory]:directory:_directories' \
          '--trace-start=[start block (inclusive)]:N:' \
          '--trace-end=[end block (exclusive)]:N:' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      proofgen)
        _arguments \
          '--proof-tests=[proof-test JSON queries file (default proof_tests.json)]:file:_files -g "*.json"' \
          '--proof-output=[proof-result output directory]:directory:_directories' \
          '--proof-states=[number of states to generate proof against (default 10000)]:N:' \
          '--proof-start=[start block (inclusive)]:N:' \
          '--proof-end=[end block (exclusive)]:N:' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      filterperf)
        _arguments \
          '--sepolia[run Sepolia testnet]' \
          '--mainnet[run mainnet]' \
          '--queries=[filter-test JSON queries file]:file:_files -g "*.json"' \
          '--errors=[failed-filter-queries output file]:file:_files -g "*.json"' \
          '*:RPC endpoint URL:' && ret=0
        ;;
      filterfuzz)
        _arguments \
          '*:RPC endpoint URL:' && ret=0
        ;;
    esac
    ;;
esac

return ret
