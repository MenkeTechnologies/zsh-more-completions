#compdef tf2onnx
# Documentation: https://github.com/onnx/tensorflow-onnx
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tf2onnx: convert TensorFlow/Keras models to ONNX
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--input=[input graphdef file]:file:_files' \
  '--graphdef=[graphdef file]:file:_files' \
  '--saved-model=[SavedModel dir]:dir:_files -/' \
  '--checkpoint=[checkpoint .meta file]:file:_files' \
  '--tflite=[TFLite model]:file:_files' \
  '--tfjs=[TF.js model]:file:_files' \
  '--output=[target ONNX file]:file:_files' \
  '--inputs=[input node names]:inputs:' \
  '--outputs=[output node names]:outputs:' \
  '--inputs-as-nchw=[transpose inputs nhwc to nchw]:inputs:' \
  '--outputs-as-nchw=[transpose outputs nhwc to nchw]:outputs:' \
  '--signature_def=[signature def within tag]:sig:' \
  '--tag=[SavedModel tag]:tag:' \
  '--concrete_function=[concrete function index]:n:' \
  '--opset=[ONNX opset version]:n:' \
  '--target=[platform target list]:targets:' \
  '--dequantize[produce float32 from quantized tflite]' \
  '--large_model[enable external tensor storage]' \
  '--continue_on_error[report all errors before failing]' \
  '--verbose[verbose diagnostic output]' \
  '--ignore_default=[ignore PlaceholderWithDefault]:list:' \
  '--use_default=[use PlaceholderWithDefault]:list:' \
  '--custom-ops=[custom ops domain map]:ops:' \
  '--extra_opset=[additional opset specs]:opset:' \
  '--load_op_libraries=[load TF plugin libraries]:libs:' \
  '--output_frozen_graph=[save frozen TF graph for debugging]:file:_files' \
  '*::tf2onnx args:_files' && ret=0
return ret
