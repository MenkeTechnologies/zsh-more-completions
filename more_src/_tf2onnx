#compdef tf2onnx

# tf2onnx: convert TensorFlow/Keras models to ONNX
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--input=[input frozen graph]:file:_files' \
  '--graphdef=[graph_def file]:file:_files' \
  '--saved-model=[SavedModel dir]:dir:_files -/' \
  '--checkpoint=[Checkpoint dir]:dir:_files -/' \
  '--tflite=[TFLite model]:file:_files' \
  '--tfjs=[TF.js model]:file:_files' \
  '--output=[output .onnx]:file:_files' \
  '--inputs=[input tensors]:inputs:' \
  '--outputs=[output tensors]:outputs:' \
  '--signature_def=[signature def]:sig:' \
  '--tag=[saved model tag]:tag:' \
  '--concrete_function=[concrete function index]:n:' \
  '--opset=[ONNX opset]:n:' \
  '--target=[runtime target list]:targets:' \
  '--continue_on_error[continue on error]' \
  '--verbose[verbose]' \
  '--debug[debug]' \
  '--custom-ops=[custom ops]:ops:' \
  '--extra_opset=[extra opset]:opset:' \
  '--load_op_libraries=[op libs to load]:libs:' \
  '--rename-inputs=[rename inputs]:list:' \
  '--rename-outputs=[rename outputs]:list:' \
  '--use-graph-names[preserve original input names]' \
  '*::tf2onnx args:_files' && ret=0
return ret
