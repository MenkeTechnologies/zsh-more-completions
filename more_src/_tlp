#compdef tlp

# Zsh completion for tlp - Linux Advanced Power Management

local -a commands=(
  'start:apply power saving settings'
  'bat:apply battery settings (ignoring AC state)'
  'true:same as bat'
  'ac:apply AC settings (ignoring battery state)'
  'false:same as ac'
  'usb:enable autosuspend for all USB devices'
  'bayoff:turn off optical drive in UltraBay/MediaBay'
  'setcharge:change battery charge thresholds temporarily'
  'fullcharge:charge battery to full capacity'
  'chargeonce:charge battery to upper threshold once'
  'discharge:force battery discharge'
  'recalibrate:battery recalibration'
  'diskid:show disk device IDs'
  'stat:show power management status'
)

_arguments \
  '(- *)--help[show help message]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:argument' && return 0

case $state in
  commands)
    _describe -t commands 'tlp command' commands
    ;;
esac
