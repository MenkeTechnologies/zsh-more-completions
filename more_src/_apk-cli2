#compdef apk-cli2 apk2
# _apk-cli2 — Alpine Linux apk-cli2 CLI command-line frontend wrapping the apk Alpine Package Keeper the package management system used by Alpine Linux and similar distributions open-source written in C originally Natanael Copa now Alpine Linux Initd developers fast simple primary package manager of Alpine Linux Wolfi Chimera Pis ALD-based-on-Alpine add del fix update upgrade cache info list dot policy search stats verify version manifest fetch index audit del dot mkndx mkpkg vertest mkdb mkrepo rsa-find usr signdb fix index aports apkindex (Alpine Linux Initd Natanael Copa Timo Teräs Łukasz Skoczeń, C); custom argparse
# upstream: https://alpinelinux.org/

_apk-cli2() {
    local -a sub=(
        'add:add packages'
        'audit:audit changes'
        'cache:cache operations'
        'del:remove packages'
        'dot:write dot graph'
        'fetch:fetch packages'
        'fix:repair installed packages'
        'index:create package index'
        'info:show package info'
        'list:list packages'
        'manifest:show file manifest'
        'mkndx:create new-format index'
        'mkpkg:create a package'
        'policy:show install policy'
        'search:search packages'
        'stats:show statistics'
        'update:update repos'
        'upgrade:upgrade packages'
        'verify:verify packages'
        'version:show package version'
        'vertest:test version compare'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '--print-arch[print arch]' \
        '--print-rpaths[print rpaths]' \
        '--purge[purge config]' \
        '-p+[root]:dir:_files -/' \
        '--root=+[dir]:dir:_files -/' \
        '-X+[repository]:str:' \
        '*-X+[repository]:str:' \
        '--repository=+[uri]:str:' \
        '*--repository=+[uri]:str:' \
        '--repositories-file=+[file]:file:_files -g "repositories *.list"' \
        '-U[update cache]' \
        '--update-cache[update cache]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--keys-dir=+[dir]:dir:_files -/' \
        '--no-cache[no cache]' \
        '--cache-max-age=+[min]:n:' \
        '--cache-predownload[predownload cache]' \
        '-f[force]' \
        '--force[force]' \
        '--force-binary-stdout[force binary stdout]' \
        '--force-broken-world[force broken world]' \
        '--force-non-repository[force non-repo]' \
        '--force-old-apk[force old apk]' \
        '--force-overwrite[force overwrite]' \
        '--force-refresh[force refresh]' \
        '--allow-untrusted[allow untrusted]' \
        '--keys-dir=+[dir]:dir:_files -/' \
        '--no-network[no network]' \
        '--no-progress[no progress]' \
        '--progress[progress]' \
        '--progress-fd=+[fd]:n:' \
        '--no-scripts[no scripts]' \
        '--no-commit-hooks[no commit hooks]' \
        '-c+[chroot]:dir:_files -/' \
        '--chroot=+[dir]:dir:_files -/' \
        '--clean-protected[clean protected]' \
        '--keep-tmp[keep tmp]' \
        '--initdb[initialize DB]' \
        '--available[available]' \
        '-a[available]' \
        '--installed[installed]' \
        '-I[installed]' \
        '--upgradable[upgradable]' \
        '-u[upgradable]' \
        '--virtual=+[name]:str:' \
        '-t+[virtual]:str:' \
        '--virtual-clean[virtual clean]' \
        '--no-self-upgrade[no self upgrade]' \
        '--prune[prune]' \
        '--depth=+[N]:n:' \
        '-d+[depth]:n:' \
        '--errors[errors]' \
        '-e[errors]' \
        '--orphaned[orphaned]' \
        '-O[orphaned]' \
        '--available-stamp[available stamp]' \
        '--latest[latest]' \
        '-l[latest]' \
        '--rdepends[reverse depends]' \
        '-r[reverse depends]' \
        '--description[show description]' \
        '-d[description]' \
        '--from=+[s]:s:(repositories none system installed)' \
        '--no-network[no network]' \
        '--print-arch[print arch]' \
        '--simulate[simulate]' \
        '-s[simulate]' \
        '--world=+[file]:file:_files' \
        '--wait=+[sec]:n:' \
        '--exact[exact]' \
        '-e[exact]' \
        '--all[all]' \
        '-a[all]' \
        '--triggers[triggers]' \
        '-t[triggers]' \
        '--check[check]' \
        '-c[check]' \
        '--allowed-vendors=+[list]:str:' \
        '--allowed-repositories=+[list]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apk subcommand' sub ;;
        args)
            case $words[1] in
                add|del|fix|fetch|info|search|verify|version|policy|manifest|dot|list) _arguments '*:package:' ;;
                cache) _arguments '1:op:(download clean purge revdep stats sync)' '*:arg:' ;;
            esac
            ;;
    esac
}

_apk-cli2 "$@"
