#compdef del-cli
# Documentation: https://github.com/sindresorhus/del-cli
# del-cli - delete files and directories (cross-platform)

local ret=1

_arguments -s -S \
  '(-f --force)'{-f,--force}'[allow deleting the current working directory and outside]' \
  '(-d --dry-run)'{-d,--dry-run}'[list what would be deleted instead of deleting]' \
  '(-v --verbose)'{-v,--verbose}'[print the absolute path of files as they are deleted]' \
  '*:path:_files' && ret=0

return ret
