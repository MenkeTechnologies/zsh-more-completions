#compdef py2json
# Documentation: https://github.com/remarshal-project/remarshal
# convert Python to JSON (remarshal wrapper)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--indent=[JSON and YAML indentation level]:n:' \
  '--width=[Python and YAML line width]:n:' \
  '(-s --sort-keys)'{-s,--sort-keys}'[sort JSON, Python, and TOML keys]' \
  '(-k --stringify)'{-k,--stringify}'[convert booleans, nulls, date-times to strings]' \
  '--multiline=[minimum items for multiline TOML arrays]:n:' \
  '--max-values=[maximum input values allowed]:n:' \
  '--wrap=[wrap non-dict data in dictionary with key]:key:' \
  '--unwrap=[extract value under key from output]:key:' \
  '--starlark=[transform data with Starlark expression]:code:' \
  '--starlark-file=[read Starlark program from file]:file:_files' \
  '--starlark-max-steps=[Starlark CPU limit]:n:' \
  '--starlark-max-allocs=[Starlark memory limit in bytes]:n:' \
  '--yaml-expand-aliases[expand YAML aliases instead of generating anchors]' \
  '--yaml-style=[YAML formatting style]:style:' \
  '--yaml-style-newline=[YAML style override for strings with newlines]:style:' \
  '--yaml-tags[treat YAML tags as single-key mappings]' \
  '--verbose[print debug info on errors]' \
  '*:file:_files' && ret=0

return ret
