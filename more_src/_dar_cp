#compdef dar_cp
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/dar_cp.1.html
# dar_cp - "cp" clone that copes with truncated slices, accepts full filenames only

local ret=1

_arguments -s \
  '-h[display help usage]' \
  '-V[display version information]' \
  '1:source file:_files' \
  '2:destination file:_files' && ret=0

return ret
