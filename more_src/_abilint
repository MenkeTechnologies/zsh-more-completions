#compdef abilint
# Documentation: https://sourceware.org/libabigail/manual/abilint.html
# libabigail tool to validate an ABI XML representation

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug-info-dir[debug info directory]:dir:_files -/' \
  '--diff[compare reloaded ABI against original]' \
  '--noout[do not emit anything]' \
  '*--suppressions[suppression specification file]:file:_files' \
  '--headers-dir[public headers directory]:dir:_files -/' \
  '--header-file[public header file]:file:_files' \
  '--stdin[read input from standard input]' \
  '--tu[expect a single translation unit]' \
  '--ctf[read ABI from CTF debug info]' \
  '--annotate[annotate the output XML]' \
  '--verbose[enable verbose logging]' \
  '*:file:_files' && ret=0

return ret
