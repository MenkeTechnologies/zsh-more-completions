#compdef oha
# Documentation: https://man.archlinux.org/search?q=oha
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-n)-n+[number of requests]:n:' \
  '(-c)-c+[concurrent connections]:n:' \
  '(-p)-p+[connections per HTTP/2 connection]:n:' \
  '(-q)-q+[query rate per second]:n:' \
  '(-z)-z+[duration]:t:' \
  '(-t)-t+[timeout]:t:' \
  '(-m --method)'{-m+,--method=}'[HTTP method]:m:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '*-H+[header]:h:' \
  '(-A --accept-header)'{-A+,--accept-header=}'[Accept]:a:' \
  '(-d --body-string)'{-d+,--body-string=}'[body]:b:' \
  '(-D --body-path)'{-D+,--body-path=}'[body file]:file:_files' \
  '(-T --content-type)'{-T+,--content-type=}'[content type]:c:' \
  '(-a --basic-auth)'{-a+,--basic-auth=}'[user:pass]:auth:' \
  '(--http-version)--http-version=[HTTP version]:v:(0.9 1.0 1.1)' \
  '--http2[force HTTP/2]' \
  '--host=[host header]:h:' \
  '--disable-compression[disable compression]' \
  '(-r --redirect)'{-r+,--redirect=}'[max redirects]:n:' \
  '--disable-keepalive[disable keep-alive]' \
  '--no-pre-lookup[no DNS prelookup]' \
  '--ipv6[force IPv6]' \
  '--ipv4[force IPv4]' \
  '--insecure[skip TLS verify]' \
  '(-x)-x+[proxy URL]:url:' \
  '(--proxy-http-version)--proxy-http-version=[proxy HTTP version]:v:' \
  '(--proxy-http2)--proxy-http2[proxy HTTP/2]' \
  '--rand-regex-url[regex URL]' \
  '--max-repeat=[max regex repeat]:n:' \
  '--dump-urls=[dump URLs]:file:_files' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '--latency-correction[latency correction]' \
  '--no-tui[no TUI]' \
  '--fps=[FPS]:n:' \
  '--debug[debug]' \
  '(-o --output-format)'{-o+,--output-format=}'[output format]:f:(json csv)' \
  '*--connect-to=[host:port:host:port]:c:' \
  '--burst-delay=[burst delay]:t:' \
  '--burst-rate=[burst rate]:n:' \
  '--rand-regex-method=[method regex]:m:' \
  '--db-url=[SQLite db url]:url:' \
  '*: :_urls' && ret=0

return ret
