#compdef oha-cli
# Documentation: https://github.com/hatoo/oha/blob/master/src/lib.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap derive in src/lib.rs at the URL above.
# Note: there is no separate 'oha-cli' binary; this delegates to the oha
# completion if installed, otherwise mirrors the verified oha flag set.

if (( $+functions[_oha] )); then
  _oha "$@"
  return
fi

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-n+[number of requests]:n:' \
  '-c+[concurrent connections]:n:' \
  '-p+[parallel HTTP/2 requests per connection]:n:' \
  '-z+[duration]:duration:' \
  '-q+[rate (QPS)]:rate:' \
  '(-m --method)'{-m+,--method=}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '*-H+[custom HTTP header]:header:' \
  '-t+[request timeout]:timeout:' \
  '-A+[Accept header]:accept:' \
  '-d+[request body]:body:' \
  '-D+[request body file]:file:_files' \
  '-T+[Content-Type]:content-type:' \
  '-a+[basic auth user:password]:auth:' \
  '--http-version=[HTTP version]:v:(0.9 1.0 1.1 2 3)' \
  '--http2[use HTTP/2]' \
  '--host=[Host header]:host:_hosts' \
  '(-r --redirect)'{-r+,--redirect=}'[max redirects]:n:' \
  '--disable-keepalive[disable keep-alive]' \
  '--ipv6[lookup only IPv6]' \
  '--ipv4[lookup only IPv4]' \
  '--insecure[accept invalid certs]' \
  '-x+[HTTP proxy]:url:' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '--no-tui[disable TUI]' \
  '--latency-correction[correct latency]' \
  '*:url:_urls' && return 0
