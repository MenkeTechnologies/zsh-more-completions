#compdef CreateDTICohort
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/CreateDTICohort.cxx — simulate a synthetic DTI cohort (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3)' \
    '(-a --dti-atlas)'{-a+,--dti-atlas=}'[input DTI atlas]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-x --label-mask-image)'{-x+,--label-mask-image=}'[mask image or lower threshold function]:spec:_default' \
    '(-n --noise-sigma)'{-n+,--noise-sigma=}'[noise sigma (default 18)]:n:_default' \
    '(-p --pathology)'{-p+,--pathology=}'[pathology spec]:spec:_default' \
    '(-w --dwi-parameters)'{-w+,--dwi-parameters=}'[DWI params [B0Image,directionFile,bvalue] or [B0Image,schemeFile]]:spec:_default' \
    '(-r --registered-population)'{-r+,--registered-population=}'[text file with population filenames]:file:_files -g "*.txt"' \
    '(-o --output)'{-o+,--output=}'[output cohort filename prefix]:file:_files' \
    '(- *)'{-v,--version}'[print version]' \
    '--verbose=[verbosity level]:n:(0 1 2)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
