#compdef CollectGcBiasMetrics
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#CollectGcBiasMetrics
# Picard: collect metrics on GC bias in sequencing coverage

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input SAM or BAM file]:bam:_files -g "*.(bam|sam)"' \
  {-O=,--OUTPUT=}'[output metrics file]:file:_files' \
  '--CHART_OUTPUT=[PDF file to render the chart to]:pdf:_files -g "*.pdf"' \
  '--SUMMARY_OUTPUT=[text file to write summary metrics to]:file:_files' \
  '--SCAN_WINDOW_SIZE=[size of scanning windows on the reference]:int:' \
  '--MINIMUM_GENOME_FRACTION=[exclude GC windows below this genome fraction]:float:' \
  '--IS_BISULFITE_SEQUENCED=[whether data is bisulfite sequenced]:bool:(true false)' \
  '--METRIC_ACCUMULATION_LEVEL=[level at which to accumulate metrics]:level:(ALL_READS SAMPLE LIBRARY READ_GROUP)' \
  '--ALSO_IGNORE_DUPLICATES=[also produce results excluding duplicates]:bool:(true false)' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence FASTA]:fasta:_files -g "*.(fa|fasta)"' \
  '--ASSUME_SORTED=[assume input is coordinate sorted]:bool:(true false)' \
  '--STOP_AFTER=[stop after processing N reads]:int:' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam file:_files -g "*.(bam|sam)"' && ret=0

return ret
