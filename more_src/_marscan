#compdef marscan
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/marscan.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS marscan: find MAR/SAR (matrix/scaffold attachment region) sites
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:DNA USA:_files' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(embl genbank gff pir swiss dasgff debug listfile dbmotif diffseq draw restrict excel feattable motif nametable regions seqtable simple srs table tagseq)' \
  '-rname=[base filename for output]:name:' \
  '-rextension=[file extension]:ext:' \
  '-rdirectory=[output directory]:dir:_files -/' \
  '-raccshow[display accession numbers]' \
  '-rdesshow[display descriptions]' \
  '-rscoreshow[display scores]' \
  '-rstrandshow[display nucleotide strand]' \
  '-rusashow[display full USA]' \
  '-rmaxall=[max total hits]:n:' \
  '-rmaxseq=[max hits per sequence]:n:' \
  '*:DNA USA:_files' && ret=0
return ret
