#compdef cargo-autoinherit
# Documentation: https://crates.io/crates/cargo-autoinherit
# automatically centralize dependencies as workspace dependencies

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--prefer-simple-dotted[prefer simple dotted syntax for inherited deps]' \
  '*'{-e,--exclude-members}'[workspace member to exclude]:package' && ret=0

return ret
