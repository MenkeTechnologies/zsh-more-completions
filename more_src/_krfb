#compdef krfb
# Documentation: https://invent.kde.org/network/krfb/-/blob/master/krfb/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream krfb/main.cpp QCommandLineParser - one custom option
# (--nodialog) plus KAboutData/QCommandLineParser standard options.
# Removed Qt5-era options (--style/--stylesheet/--platform/--display/
# --platformpluginpath/--graphicssystem/--reverse/--help-qt/--help-kde/
# --author/--license) not added by upstream parser.

# KRfb: KDE desktop sharing (VNC server)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nodialog[do not show the invitations management dialog at startup]' && ret=0
return ret
