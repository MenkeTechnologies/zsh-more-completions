#compdef nova

# fairwindsops/nova: subcommands share persistent flags; find adds scan flags.

_arguments -s -S \
  '--config=[config file]:file:_files' \
  '--output-file=[write output to path]:file:_files' \
  '(-n --namespace)'{-n,--namespace}'=[namespace (empty = cluster-wide)]:ns:' \
  '--format=[output]:format:(table json)' \
  '*'{-d,--desired-versions}'+[chart=version override]:pair:' \
  '*'{-u,--url}'+[helm repo URL]:url:_urls' \
  '--poll-artifacthub[poll Artifact Hub for charts]' \
  '--no-poll-artifacthub[disable Artifact Hub]' \
  '--context=[kube context]:ctx:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--wide[extra columns]' \
  '(-a --include-all)'{-a,--include-all}'[show charts even if latest unknown]' \
  '--show-old[only show outdated charts]' \
  '1:subcommand:(find generate-config)' \
  '--containers[find: scan container images instead of helm]' \
  '--helm[find: include helm output]' \
  '--show-non-semver[find: include non-semver tags]' \
  '--show-errored-containers[find: show registry errors]' \
  '(-t --timeout)'{-t,--timeout}'=[find: image scan timeout seconds]:seconds' \
  '*--release-ignore-list=[find: helm release to skip]:release:' \
  '*--chart-ignore-list=[find: chart name to skip]:chart:' \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]'
