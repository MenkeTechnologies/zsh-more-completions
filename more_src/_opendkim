#compdef opendkim
# Documentation: https://linux.die.net/man/8/opendkim
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# opendkim: DKIM milter (signing/verification daemon)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-A[autorestart]' \
  '-b[milter behavior options]:opts:' \
  '-c[canonicalization]:mode:(simple/simple simple/relaxed relaxed/simple relaxed/relaxed)' \
  '-C[config file]:file:_files' \
  '-x[config file]:file:_files' \
  '-d[debug level]:n:' \
  '-D[domains]:list:' \
  '-f[run in foreground]' \
  '-k[key file]:file:_files' \
  '-K[keep tempfiles]' \
  '-l[log to syslog]' \
  '-L[max sig age]:n:' \
  '-n[print config and exit]' \
  '-P[PID file]:file:_files' \
  '-p[milter socket]:path:_files' \
  '-q[quiet]' \
  '-Q[query method]:method:' \
  '-r[required header check]:val:(strict relaxed)' \
  '-s[signing domain]:domain:' \
  '-S[selector]:sel:' \
  '-t[trust list]:list:' \
  '-T[test mode]' \
  '-u[run as user]:user:_users' \
  '-v[verbose]' \
  '*::opendkim args:_files' && ret=0
return ret
