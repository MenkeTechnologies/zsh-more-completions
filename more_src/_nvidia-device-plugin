#compdef nvidia-device-plugin
# Documentation: https://github.com/NVIDIA/k8s-device-plugin
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-device-plugin: NVIDIA Kubernetes device plugin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--mig-strategy=[MIG strategy]:strategy:(none single mixed)' \
  '--fail-on-init-error=[fail on init error]:bool:(true false)' \
  '--device-list-strategy=[device list strategy]:strategy:(envvar volume-mounts cdi-annotations cdi-cri)' \
  '--device-id-strategy=[device id strategy]:strategy:(index uuid)' \
  '--pass-device-specs=[pass device specs]:bool:(true false)' \
  '--config-file=[config file]:file:_files' \
  '--cdi-annotation-prefix=[CDI annotation prefix]:prefix:' \
  '--driver-root=[driver root]:dir:_files -/' \
  '--nvidia-driver-root=[driver root (alias)]:dir:_files -/' \
  '--dev-root=[dev root]:dir:_files -/' \
  '--nvidia-dev-root=[dev root (alias)]:dir:_files -/' \
  '--gdrcopy-enabled=[enable GDRCopy]:bool:(true false)' \
  '--gds-enabled=[enable GDS]:bool:(true false)' \
  '--mofed-enabled=[enable MOFED]:bool:(true false)' \
  '--nvidia-cdi-hook-path=[nvidia CDI hook binary path]:file:_files' \
  '--nvidia-ctk-path=[nvidia-ctk binary path (alias)]:file:_files' \
  '--driver-root-ctr-path=[driver root path in container]:dir:_files -/' \
  '--container-driver-root=[container driver root (alias)]:dir:_files -/' \
  '--mps-root=[MPS root directory]:dir:_files -/' \
  '--device-discovery-strategy=[device discovery strategy]:strategy:' \
  '--imex-channel-ids=[IMEX channel IDs]:ids:' \
  '--imex-required=[require IMEX]:bool:(true false)' \
  '--kubelet-socket=[kubelet socket path]:file:_files' \
  '--cdi-feature-flags=[CDI feature flags]:flags:' \
  '*::nvidia-device-plugin args:_files' && ret=0
return ret
