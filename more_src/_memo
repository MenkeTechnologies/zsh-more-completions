#compdef memo
# Documentation: https://github.com/mattn/memo
# memo - Memo Life For You, a markdown note/memo CLI

local ret=1
local line

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds
    cmds=(
      'new:create memo'
      'n:create memo'
      'list:list memo'
      'l:list memo'
      'edit:edit memo'
      'e:edit memo'
      'delete:delete memo'
      'd:delete memo'
      'grep:grep memo'
      'g:grep memo'
      'cat:view memo'
      'v:view memo'
      'config:configure'
      'c:configure'
      'serve:start http server'
      's:start http server'
    )
    _describe -t commands 'memo command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      list|l)
        _arguments -s \
          '--fullpath[show file path]' \
          '--format=[print result using a Go template string]:template:' && ret=0
        ;;
    esac
    ;;
esac

return ret
