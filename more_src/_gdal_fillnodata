#compdef gdal_fillnodata gdal_fillnodata.py

_arguments -s -S \
  '-q[quiet mode, suppress progress output]' \
  '-md[maximum distance in pixels to search for interpolation]:max distance:' \
  '-si[number of smoothing iterations]:iterations:' \
  '-o[output creation option]:name=value:' \
  '-b[band number to fill]:band number:' \
  '-of[output format]:format:(GTiff HFA VRT netCDF)' \
  '-nomask[do not use a validity mask]' \
  '-mask[use specified file as validity mask]:mask file:_files' \
  '1:source file:_files' \
  '2:destination file:_files'
