#compdef pdb_selatom
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Selects all atoms matching the given name in the PDB file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[atom name(s) to select, e.g. -CA or -CA,N,C,O]:atom name' \
  '*:PDB file:_files' && ret=0

return ret
