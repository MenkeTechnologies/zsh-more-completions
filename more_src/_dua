# Documentation: source-direct extraction from upstream
# Byron/dua-cli src/options.rs (clap v4 derive; binary
# `dua` from crate `dua-cli`):
#   src/options.rs lines 5-14 (ByteFormat ValueEnum with
#     7 variants: Metric / Binary / Bytes / GB / Gib /
#     MB / Mib)
#   src/options.rs lines 30-36 (dft_format() runtime
#     default fn — returns Metric on Apple, Binary
#     elsewhere via `cfg!(target_vendor = "apple")`)
#   src/options.rs lines 40-44 (DEFAULT_THREADS const
#     with `#[cfg(target_os = "macos")]` giving 3 on
#     macOS and 0 elsewhere)
#   src/options.rs lines 47-103 (Args Parser struct with
#     7 global flags including `override_usage` attribute)
#   src/options.rs lines 93 (`#[cfg_attr(target_os =
#     "linux", clap(default_values = &["/proc", "/dev",
#     "/sys", "/run"]))]` — platform-specific
#     default_values)
#   src/options.rs lines 105-140 (Command Subcommand
#     enum: Interactive (cfg-gated tui-crossplatform) /
#     Aggregate / Completions / Config)
#   src/options.rs lines 142-148 (ConfigCommand: single
#     Edit variant)
# Reference accessed: 2026-05-30 via gh api.
# **REWRITTEN source-direct from R260** (previous version
# was URL-cited 37 lines incomplete; missing `--count-hard-
# links/-l`, `--log-file`, `completions`/`config`
# subcommands, all 7 env vars, the 7 ByteFormat values).
#
# dua (binary from crate `dua-cli`) is the **disk usage
# analyzer** — `du`-replacement with interactive TUI
# navigation, parallel traversal, and human-friendly byte
# formatting.  Pivots from performance benchmarking
# (R259 hyperfine) into the **filesystem-analysis tooling
# cluster**.  Sister to dust, ncdu, fclones (all in
# corpus).
#
# Critical extraction note: dua uses **`override_usage =
# "dua [FLAGS] [OPTIONS] [SUBCOMMAND] [INPUT]..."`** at
# options.rs:49 on the top-level Args Parser struct.
# This replaces clap's auto-generated usage line in
# `--help` output with a custom string.  Documents the
# **`override_usage` attribute** — useful when the auto-
# generated usage doesn't capture the intended use (e.g.
# when subcommand is optional and trailing positionals
# differ from defaults).  Corpus's **first documented
# `override_usage` attribute**.  Distinct from
# `next_line_help` / `help_expected` / `max_term_width`
# which are also Command builder controls (R259 hyperfine).
#
# Critical extraction note: dua uses **platform-specific
# `const DEFAULT_THREADS`** at options.rs:40-44 via
# `#[cfg(target_os = "macos")]` and `#[cfg(not(target_os
# = "macos"))]`.  Plus a runtime `dft_format()` fn at
# options.rs:30-36 returning `Metric` on Apple (via
# `cfg!(target_vendor = "apple")`) and `Binary` elsewhere.
# Documents **platform-specific default values** via TWO
# methods: (a) compile-time `const` with `#[cfg]` (works
# for `default_value_t = CONST`); (b) runtime
# `cfg!(...)` check inside a fn (works for `default_value_t
# = fn()`).  Corpus's **first documented platform-specific
# defaults** — distinct from R249 cairo-profiler's
# `version = generate_version()` (no platform check) and
# R257 pop-cli's `about = about_build()` (feature check,
# not platform check).  Documents the **cfg-vs-cfg!**
# distinction in Rust: `#[cfg(...)]` is compile-time
# erasure; `cfg!(...)` is a runtime-constant macro.
#
# Critical extraction note: dua uses
# **`#[cfg_attr(target_os = "linux", clap(default_values
# = &["/proc", "/dev", "/sys", "/run"]))]`** at
# options.rs:93 on `--ignore-dirs/-i` — the
# `default_values` ARRAY attribute is applied ONLY on
# Linux.  On macOS / BSD / Windows, there's no default;
# `--ignore-dirs` starts empty.  Documents the
# **platform-specific default_values via cfg_attr-clap-
# attribute pairing** — the cfg_attr applies the
# `default_values` attribute conditionally.  Distinct
# from R255 fuel-core's `#[cfg_attr(feature = "X",
# clap(flatten))]` (feature-gated flatten); R260 dua
# does PLATFORM-gated default_values.  Corpus's **first
# documented platform-gated default_values attribute**.
# The `/proc`, `/dev`, `/sys`, `/run` paths are Linux-
# only mount points that almost always should be
# excluded from disk usage analysis.
#
# Critical extraction note: dua uses **`ignore_case =
# true`** on `--format/-f` at options.rs:65 — the
# ValueEnum's case-insensitive matching means `--format
# METRIC` / `--format metric` / `--format Metric` all
# work.  Documents the **`ignore_case` ValueEnum
# attribute** — corpus's first documented occurrence.
# Distinct from clap's default ValueEnum behavior
# (case-sensitive).  Useful when CLI users may type
# values in mixed case.
#
# Critical extraction note: dua uses **7 global flags
# with systematic `DUA_*` env var prefixes**: `--threads/-t`
# (env: DUA_THREADS), `--format/-f` (env: DUA_FORMAT),
# `--apparent-size/-A` (env: DUA_APPARENT_SIZE),
# `--count-hard-links/-l` (env: DUA_COUNT_HARD_LINKS),
# `--stay-on-filesystem/-x` (env: DUA_STAY_ON_FILESYSTEM),
# `--ignore-dirs/-i` (env: DUA_IGNORE_DIRS), `--log-file`
# (env: DUA_LOG_FILE).  Documents the **systematic env-
# var prefix convention** for a CLI's configuration
# surface — every flag has an env var named `DUA_<FIELD>`.
# Distinct from R252 saya's `#[clap(long, env)]` shorthand
# (auto-derived names) — dua uses EXPLICIT `env =
# "DUA_FOO"` to match the convention even when it
# matches the field name (defensive consistency).
#
# Critical extraction note: dua's `Args` struct has
# **`Option<Command>` as the subcommand** at options.rs:52
# — running `dua` without a subcommand is valid (defaults
# to launching the TUI / aggregating cwd, depending on
# build features).  Plus the `input: Vec<PathBuf>`
# positional is `global = true` at options.rs:97 — the
# input paths apply to subcommands too, not just bare
# `dua`.  Documents the **global = true on Vec<>
# positional** pattern — `dua interactive /home /root`
# and `dua /home /root` both work because input is
# global.  Continues R258 bevy's `global = true` on
# positional documentation.
#
# Critical extraction note: dua's `Interactive` variant
# is **feature-gated** by `#[cfg(feature = "tui-
# crossplatform")]` at options.rs:108 — when the TUI
# feature is disabled, the `dua interactive` subcommand
# doesn't exist.  Documents the **variant-level feature
# gating** pattern already covered by R201/R250 sozo's
# Walnut variant.

local curcontext="$curcontext" state line ret=1

# 4 subcommands decoded source-direct from Command enum
# at options.rs lines 106-140.
local -a subcommands=(
  'interactive:launch the terminal user interface (FEATURE-GATED: tui-crossplatform; visible alias: i)'
  'i:visible alias for `interactive`'
  'aggregate:aggregate consumed space of dirs/files (visible alias: a)'
  'a:visible alias for `aggregate`'
  'completions:generate shell completions'
  'config:configuration related commands (sub: edit)'
)

local -a config_subs=(
  'edit:open the configuration file in $EDITOR (created if missing)'
)

# ByteFormat ValueEnum at options.rs:5-14.  Case-
# insensitive via `ignore_case = true`.
local -a byte_formats=(
  'metric:SI metric (1000-based; e.g. 1.5 MB; default on Apple)'
  'binary:binary (1024-based; e.g. 1.5 MiB; default off-Apple)'
  'bytes:raw bytes count (no formatting)'
  'GB:gigabytes (forced; 1000-based)'
  'Gib:gibibytes (forced; 1024-based)'
  'MB:megabytes (forced; 1000-based)'
  'Mib:mebibytes (forced; 1024-based)'
)

local -a completion_shells=(bash zsh fish powershell elvish)

# Global flags (all `global = true`; applicable to all
# subcommands).
local -a global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-t --threads)'{-t+,--threads=}'[thread count (default: 3 on macOS / 0 = logical CPUs elsewhere; env: DUA_THREADS)]:n:'
  '(-f --format)'{-f+,--format=}'[byte format (case-insensitive; env: DUA_FORMAT; default: Metric on Apple / Binary elsewhere)]:format:(($byte_formats))'
  '(-A --apparent-size)'{-A,--apparent-size}'[display apparent size instead of disk usage (env: DUA_APPARENT_SIZE)]'
  '(-l --count-hard-links)'{-l,--count-hard-links}'[count hard-linked files each time seen (env: DUA_COUNT_HARD_LINKS)]'
  '(-x --stay-on-filesystem)'{-x,--stay-on-filesystem}'[do not cross filesystems or traverse mount points (env: DUA_STAY_ON_FILESYSTEM)]'
  '*'{-i+,--ignore-dirs=}'[absolute dirs to ignore during traversal (Linux default: /proc /dev /sys /run; env: DUA_IGNORE_DIRS)]:dir:_files -/'
  '--log-file=[write debug log file (includes panics; env: DUA_LOG_FILE)]:file:_files'
)

_arguments -C \
  $global_flags \
  '1: :->subcmd_or_path' \
  '*::args:->args' && ret=0

case $state in
  subcmd_or_path)
    # Override_usage: `dua [FLAGS] [OPTIONS] [SUBCOMMAND]
    # [INPUT]...` — the first positional may be a subcommand
    # OR an input path (since `Option<Command>` makes
    # subcommand optional).
    _alternative \
      'subcommands:dua subcommand:_describe -t subcommands "subcommand" subcommands' \
      'paths:input path:_files' && ret=0
    ;;
  args)
    case $words[1] in
      interactive|i)
        _arguments \
          $global_flags \
          '(-e --no-entry-check)'{-e,--no-entry-check}'[do not check entries for presence when listing dirs (avoid slow-filesystem lag)]' \
          '*:input path:_files' && ret=0
        ;;
      aggregate|a)
        _arguments \
          $global_flags \
          '--stats[print additional statistics about the file traversal to stderr]' \
          '--no-sort[print paths in CLI-occurrence order (default: sorted by size ascending)]' \
          '--no-total[do not compute total column for multiple inputs]' \
          '*:input path:_files' && ret=0
        ;;
      completions)
        # Inline struct variant: `Completions { shell:
        # clap_complete::Shell }`.
        _arguments '1:shell:($completion_shells)' && ret=0
        ;;
      config)
        if (( CURRENT == 2 )); then
          _describe -t config-subs 'config verb' config_subs && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
