#compdef pslxToFa
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert pslx (with sequence) to fasta file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-liftTarget=[lift target lft file]:file:_files' \
  '-liftQuery=[lift query lft file]:file:_files' \
  ':in psl:_files' \
  ':out fa:_files' && ret=0

return ret
