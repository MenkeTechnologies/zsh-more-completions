#compdef podget
# Documentation: https://manpages.ubuntu.com/manpages/noble/en/man7/podget.7.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[name of configuration file]:file:_files' \
  '--create-config[create configuration file and exit]' \
  '(-C --cleanup)'{-C,--cleanup}'[skip downloading and only run cleanup loop]' \
  '--cleanup_days=[cleanup files older than N days]:days' \
  '--cleanup_simulate[simulate cleanup loop]' \
  '--dir_config=[directory of configuration files]:dir:_files -/' \
  '--dir_session=[directory of session files]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[force download even if already downloaded]' \
  '(-l --library)'{-l+,--library=}'[directory to store downloaded files]:dir:_files -/' \
  '(-n --no-playlist)'{-n,--no-playlist}'[do not create M3U playlist]' \
  '(-p --playlist-asx)'{-p,--playlist-asx}'[also create ASX playlists]' \
  '--playlist-per-podcast[create a playlist per feed]' \
  '(-r --recent)'{-r+,--recent=}'[fetch only the N most recent items]:n' \
  '--serverlist=[server list file]:file:_files' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '--verbosity=[set verbosity level]:level' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--import_opml=[import OPML file]:file:_files' \
  '--export_opml=[export OPML file]:file:_files' \
  '--import_pcast=[import iTunes pcast file]:file:_files' && ret=0

return ret
