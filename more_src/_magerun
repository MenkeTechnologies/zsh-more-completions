#compdef magerun n98-magerun
# _magerun — netz98 n98-magerun CLI for Magento 1 administration shell-fast cache flush index reindex admin user customer media catalog db access EAV attribute dump store config (netz98 team, PHP); Symfony Console
# upstream: https://github.com/netz98/n98-magerun

_magerun() {
    local -a sub=(
        'admin:admin operations'
        'cache:cache operations'
        'config:config operations'
        'customer:customer operations'
        'category:category operations'
        'cron:cron operations'
        'db:database operations'
        'dev:development operations'
        'eav:EAV operations'
        'extension:extension operations'
        'index:index operations'
        'install:install operations'
        'media:media operations'
        'open-browser:open browser'
        'shell:run shell'
        'sys:system operations'
        'list:list commands'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no interaction]' \
        '--no-interaction[no interaction]' \
        '--root-dir=+[dir]:dir:_files -/' \
        '--skip-config[skip config]' \
        '--skip-root-check[skip root check]' \
        '--skip-magento-compatibility-check[skip mage compat check]' \
        '--skip-core-commands=+[csv]:str:' \
        '--ansi[force ansi]' \
        '--no-ansi[disable ansi]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'magerun subcommand' sub ;;
        args)
            case $words[1] in
                cache) _arguments \
                    '1:action:(flush clean disable enable list view)' \
                    '*:cache type:' ;;
                admin) _arguments \
                    '1:action:(user create delete list change-password)' \
                    '*:username:' ;;
                customer) _arguments \
                    '1:action:(create info list change-password delete)' \
                    '*:email:' ;;
                index) _arguments \
                    '1:action:(reindex list)' \
                    '*:index code:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_magerun "$@"
