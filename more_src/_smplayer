#compdef smplayer smplayer2
# _smplayer — Ricardo Villalba SMPlayer complete Qt media player front-end for mpv and MPlayer with thumbnail seek bar and YouTube support (smplayer team, C++/Qt); Qt argparse
# upstream: https://www.smplayer.info/

_smplayer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--mini[mini GUI]' \
        '--mpv[force mpv]' \
        '--mplayer[force MPlayer]' \
        '--config-path=+[path]:dir:_files -/' \
        '-c+[config-path]:dir:_files -/' \
        '--send-action=+[action]:str:' \
        '--actions=+[csv]:str:' \
        '--sub=+[file]:file:_files -g "*.srt *.ass *.ssa *.sub *.vtt *.idx"' \
        '--sub-file=+[file]:file:_files -g "*.srt *.ass *.ssa *.sub *.vtt *.idx"' \
        '--media-title=+[title]:str:' \
        '--pos=+[X Y]:str:' \
        '--size=+[W H]:str:' \
        '--fullscreen[fullscreen]' \
        '--minimized[minimized]' \
        '--close-at-end[close at end]' \
        '--no-close-at-end[no close at end]' \
        '--add-to-playlist[add to playlist]' \
        '--no-gui[no GUI]' \
        '--ontop[ontop]' \
        '--no-ontop[no ontop]' \
        '--volume=+[0-100]:n:' \
        '--start=+[seconds]:f:' \
        '--stop[stop]' \
        '--quit[quit]' \
        '--reset-all-settings[reset settings]' \
        '--no-load-config[no load config]' \
        '--instance-id=+[id]:str:' \
        '--new-window[new window]' \
        '--no-new-window[no new window]' \
        '*:media file:_files -g "*.mp4 *.mkv *.webm *.avi *.mov *.ogv *.flac *.mp3 *.wav *.ogg *.opus *.m4a *.aac *.ts *.m2ts *.flv *.m3u8 *.m3u *.pls"'
}

_smplayer "$@"
