#compdef codes_export_resource
# Documentation: https://confluence.ecmwf.int/display/ECC/codes_export_resource
# Source: ecmwf/eccodes tools/codes_export_resource.cc — export a definition or sample resource (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(-d)-s[extract from samples directory]' \
    '(-s)-d[extract from definitions directory]' \
    '1:resource path:_default' \
    '2:output file:_files' \
    && ret=0

return ret
