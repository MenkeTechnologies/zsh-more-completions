#compdef flvmeta
# Documentation: https://manpages.debian.org/testing/flvmeta/flvmeta.1.en.html
# manipulate or extract metadata in Adobe Flash Video files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage help]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-D --dump)'{-D,--dump}'[output metadata tag as text]' \
  '(-F --full-dump)'{-F,--full-dump}'[output entire file contents as text]' \
  '(-C --check)'{-C,--check}'[analyze file for errors and incompatibilities]' \
  '(-U --update)'{-U,--update}'[insert computed metadata into file]' \
  '(-d --dump-format)'{-d,--dump-format}'+[dump format]:format:(xml json raw yaml)' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-x --xml)'{-x,--xml}'[output as XML]' \
  '(-y --yaml)'{-y,--yaml}'[output as YAML]' \
  '(-r --raw)'{-r,--raw}'[output as raw format]' \
  '(-e --event)'{-e,--event}'+[event to dump]:event:' \
  '(-l --level)'{-l,--level}'+[filter messages by severity]:level:(info warning error fatal)' \
  '(-q --quiet)'{-q,--quiet}'[suppress output, return status only]' \
  '(-m --print-metadata)'{-m,--print-metadata}'[display updated metadata to stdout]' \
  '(-a --add)'{-a,--add}'+[append custom metadata NAME=VALUE]:nameval:' \
  '(-s --no-lastsecond)'{-s,--no-lastsecond}'[omit onLastSecond tag creation]' \
  '(-p --preserve)'{-p,--preserve}'[keep existing metadata tags]' \
  '(-f --fix)'{-f,--fix}'[correct invalid tags]' \
  '(-i --ignore)'{-i,--ignore}'[skip invalid tags without stopping]' \
  '(-t --reset-timestamps)'{-t,--reset-timestamps}'[reset timestamps to zero]' \
  '(-k --all-keyframes)'{-k,--all-keyframes}'[index all keyframes including duplicates]' \
  '(-v --verbose)'{-v,--verbose}'[display informative messages]' \
  '*:file:_files -g "*.flv"' && ret=0

return ret
