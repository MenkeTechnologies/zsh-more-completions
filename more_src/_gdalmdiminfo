#compdef gdalmdiminfo
# Documentation: https://gdal.org/en/stable/programs/gdalmdiminfo.html
# Report structure and content of a multidimensional dataset

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '--help-general[show generic GDAL options]' \
  '-detailed[most verbose output, report attribute data types and array values]' \
  '-nopretty[output as single line without indentation]' \
  '-array[restrict output to specified array]:array_name' \
  '-limit[limit displayed array values per dimension]:number' \
  '-stats[read and display array statistics]' \
  '*-oo[dataset open option]:name=value' \
  '*-if[input format/driver to attempt]:format' \
  '*-arrayoption[filter arrays via format-specific options]:name=value' \
  '*:dataset:_files' && ret=0

return ret
