#compdef ytt

# Zsh completion for ytt - YAML Templating Tool (Carvel)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '*-f[specify input file or directory]:file:_files' \
  '(-v --data-value)'{-v,--data-value}'[set data value (key=value)]:key=value' \
  '--data-value-yaml[set data value as YAML (key=value)]:key=value' \
  '--data-value-file[set data value from file (key=path)]:key=path:_files' \
  '--data-values-env[set data values from environment variables with prefix]:prefix' \
  '--data-values-file[set data values from YAML file]:file:_files' \
  '--file-mark[set file mark (path\:key=value)]:mark' \
  '(-o --output)'{-o,--output}'[output to specified directory]:directory:_directories' \
  '--output-files[output to specified directory]:directory:_directories' \
  '--strict[enable strict mode]' \
  '--ignore-unknown-comments[ignore unknown comments]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'fmt:Format YAML templates'
      'template:Process YAML templates'
      'version:Print version information'
    )
    _describe -t commands 'ytt command' commands && ret=0
    ;;
esac

return ret
