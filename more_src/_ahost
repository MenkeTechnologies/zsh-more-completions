#compdef ahost
# Documentation: ahost (c-ares 1.34.6)
# Source: c-ares DNS A/AAAA resolver test tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-d[debug output]' \
    '-D+[search domain]:domain:' \
    '-s+[DNS server to query]:server:_hosts' \
    '-t+[record type]:type:(a aaaa u)' \
    '*:host or address:_hosts' \
    && ret=0

return ret
