#compdef run_pepper_margin_deepvariant
# Documentation: https://github.com/kishwarshafin/pepper
# PEPPER-Margin-DeepVariant long-read variant calling and assembly polishing

local ret=1

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:(call_variant polish_assembly)' \
  '(-b --bam)'{-b,--bam}'=[input BAM file]:bam:_files' \
  '(-f --fasta)'{-f,--fasta}'=[reference FASTA file]:fasta:_files' \
  '(-o --output_dir)'{-o,--output_dir}'=[output directory]:dir:_files -/' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:int:' \
  '--ont_r9_guppy5_sup[preset for ONT R9.4.1 Guppy 5 Sup basecaller]' \
  '--ont_r10_q20[preset for ONT R10.4 Q20 reads]' \
  '--hifi[preset for PacBio-HiFi reads]' \
  '*::args:_files' && ret=0

return ret
