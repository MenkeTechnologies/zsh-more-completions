#compdef koji
# Documentation: https://docs.pagure.org/koji/using_the_koji_build_system/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/cococonscious/koji — clap (src/bin/main.rs). Optional: koji completions <bash|elvish|fish|powershell|zsh>
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--autocomplete=-[suggest scopes from commit history]::bool:(true false)' \
  '--breaking-changes=-[BREAKING CHANGE footer prompts]::bool:(true false)' \
  '(-c --config)'{-c,--config}'=-[config file path]:file:_files' \
  '--emoji=-[prepend type emoji]::bool:(true false)' \
  '--hook[write message to COMMIT_EDITMSG (git hook)]' \
  '--stdout[print message to stdout]' \
  '--issues=-[issue footer prompts]::bool:(true false)' \
  '(-S --sign)'{-S,--sign}'=-[GPG-sign commit]::bool:(true false)' \
  '(-a --all)'{-a,--all}'[stage all tracked changes]' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' \
  '(-C --current-workdir)'{-C,--current-workdir}'=-[run as if in directory]:dir:_directories' \
  '*::free arg:_default'
