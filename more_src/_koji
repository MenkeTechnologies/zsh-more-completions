#compdef koji
# Documentation: https://raw.githubusercontent.com/cococonscious/koji/main/src/bin/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap Args struct in src/bin/main.rs
# (cococonscious/koji, interactive conventional-commit CLI).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[print help]' \
  '--autocomplete=-[enable scope autocomplete via commit history]::enable:(true false)' \
  '--breaking-changes=-[enable breaking change prompts]::enable:(true false)' \
  '(-c --config)'{-c,--config}'=[path to a custom config file]:file:_files' \
  '--emoji=-[prepend commit summary with relevant emoji]::enable:(true false)' \
  '--hook[run as a git hook, writing to COMMIT_EDITMSG]' \
  '--stdout[output the commit message to stdout]' \
  '--issues=-[enable issue prompts for issue footer]::enable:(true false)' \
  '(-S --sign)'{-S,--sign}'=-[GPG-sign the commit]::enable:(true false)' \
  '(-a --all)'{-a,--all}'[stage all tracked modified or deleted files]' \
  '(-y --yes)'{-y,--yes}'[skip the confirmation prompt]' \
  '-C+[run as if koji was started in <path>]:dir:_directories' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'completions:generate shell completions'
    )
    _describe -t commands 'koji command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      completions)
        _arguments '1:shell:(bash elvish fish nushell powershell zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
