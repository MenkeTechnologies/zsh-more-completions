#compdef sushw
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/sushw.c
# SUSHW - set one or more header words

local ret=1

_arguments -s -S \
  'key=[header key word(s) to set]:k:' \
  'a=[value(s) on first trace]:a:' \
  'b=[increment(s) within group]:b:' \
  'c=[group increment(s)]:c:' \
  'd=[trace number shift(s)]:d:' \
  'j=[number of elements in group]:j:' \
  'infile=[binary file of values for fields]:f:_files' \
  '*:SU file:_files' && ret=0

return ret
