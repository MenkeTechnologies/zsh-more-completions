#compdef sndfile-info sndfile-play sndfile-convert sndfile-cmp sndfile-deinterleave sndfile-interleave sndfile-metadata-get sndfile-metadata-set sndfile-resample sndfile-jackplay sndfile-mix-to-mono sndfile-salvage sndfile-spectrogram
# _libsndfile — Erik de Castro Lopo libsndfile suite of utilities for inspecting and converting audio files via sndfile library (libsndfile team, C); getopt
# upstream: https://github.com/libsndfile/libsndfile

_libsndfile() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i[show info]' \
        '--instrument[show instrument]' \
        '-c+[channels]:n:' \
        '--channels=+[channels]:n:' \
        '-r+[sample rate]:n:' \
        '--samplerate=+[sample rate]:n:' \
        '-f+[output format]:f:(wav aiff aifc au snd raw paf svx nist voc ircam w64 mat4 mat5 pvf xi htk caf wve mpc2k rf64 mpeg ogg flac alac)' \
        '--format=+[output format]:f:(wav aiff au flac ogg alac mpeg)' \
        '-s+[subtype]:t:(pcm_s8 pcm_16 pcm_24 pcm_32 pcm_u8 float double ulaw alaw ima_adpcm ms_adpcm gsm610 g721_32 g723_24 g723_40 dwvw_12 dwvw_16 dwvw_24 dpcm_8 dpcm_16 vorbis opus alac_16 alac_20 alac_24 alac_32 mpeg_layer_I mpeg_layer_II mpeg_layer_III)' \
        '--subtype=+[subtype]:t:(pcm_s8 pcm_16 pcm_24 pcm_32 float double ulaw alaw ima_adpcm ms_adpcm gsm610 vorbis opus)' \
        '-e+[endian]:e:(file little big cpu)' \
        '--endian=+[endian]:e:(file little big cpu)' \
        '-N+[normalize to dB]:f:' \
        '--normalize=+[normalize to dB]:f:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l[show licence]' \
        '--licence[show licence]' \
        '-d[debug]' \
        '--debug[debug]' \
        '*:audio file:_files -g "*.wav *.aiff *.flac *.ogg *.au *.snd *.raw *.aif *.opus *.alac *.mp3 *.m4a *.mka *.mat *.caf"'
}

_libsndfile "$@"
