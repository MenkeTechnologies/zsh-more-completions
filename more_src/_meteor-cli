#compdef meteor
# _meteor-cli — Meteor full-stack JavaScript platform CLI (MDG/Meteor Software); MongoDB + DDP isomorphic apps
# upstream: https://github.com/meteor/meteor

_meteor-cli() {
    local -a sub=(
        'add:add packages'
        'admin:admin commands'
        'build:build app for deploy'
        'create:create new app'
        'debug:start in debug mode'
        'deploy:deploy to Galaxy or other'
        'help:show help'
        'list:list installed packages'
        'lint:run package linter'
        'logout:logout'
        'login:login to Meteor account'
        'logs:show logs for deployed app'
        'mongo:open mongo shell'
        'node:run app within Node REPL'
        'npm:run app-scoped npm'
        'pnpm:run app-scoped pnpm'
        'profile:profile build'
        'publish:publish a package'
        'publish-for-arch:publish prebuilt arch'
        'publish-release:publish a Meteor release'
        'remove:remove packages'
        'reset:reset app database'
        'run:run dev server (default)'
        'search:search Atmosphere packages'
        'shell:open server console'
        'show:show package info'
        'test:run app tests'
        'test-packages:test packages'
        'update:update Meteor + packages'
        'version:show version'
        'whoami:print current user'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--release+[meteor release]:release:' \
        '--no-release-check[skip release check]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meteor subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '--mobile-server+[mobile server URL]:url:_urls' \
                    '--cordova-server-port+[cordova port]:port:' \
                    '--settings+[settings file]:file:_files' \
                    '--release+[release]:release:' \
                    '--production[production env]' \
                    '--raw-logs[raw logs]' \
                    '--no-lint[skip lint]' \
                    '--inspect[node --inspect]' \
                    '--inspect-brk[node --inspect-brk]' \
                    '--allow-superuser[allow running as root]' \
                    '--exclude-archs+[arch excludes]:arches:' \
                    '--extra-packages+[extra packages]:packages:' ;;
                create) _arguments \
                    '--list[list templates]' \
                    '--bare[bare template]' \
                    '--blaze[Blaze app]' \
                    '--minimal[minimal app]' \
                    '--full[full app]' \
                    '--react[react app]' \
                    '--svelte[svelte app]' \
                    '--vue[vue app]' \
                    '--apollo[Apollo GraphQL]' \
                    '--typescript[TypeScript app]' \
                    '--example+[example template]:template:' \
                    '--package[create package]' \
                    '*:dir:_files -/' ;;
                deploy) _arguments \
                    '(-D --delete)'{-D,--delete}'[delete deployment]' \
                    '--debug[debug build]' \
                    '--settings+[settings file]:file:_files' \
                    '--owner+[owner account]:account:' \
                    '--free[free Galaxy tier]' \
                    '--mongo[create mongo db]' \
                    '--plan+[plan]:plan:(professional essentials)' \
                    '--container-size+[container size]:size:(tiny compact essentials professional double quad octa twelve)' \
                    '*:site:' ;;
            esac
            ;;
    esac
}

_meteor-cli "$@"
