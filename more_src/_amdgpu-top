#compdef amdgpu-top amdgpu_top
# Documentation: https://github.com/Umio-Yasuno/amdgpu_top
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --dump)'{-d,--dump}'[dump mode, no TUI]' \
  '(-J --json)'{-J,--json}'[output in JSON format]' \
  '(-i --pci)'{-i,--pci}'[select GPU by PCI bus]:PCI bus ID: ' \
  '(-s --refresh)'{-s,--refresh}'[refresh period in milliseconds]:period (ms): ' \
  '(-n --iterations)'{-n,--iterations}'[number of updates then exit]:count: ' \
  '--single[single GPU mode]' \
  '--gui[launch GUI mode]' \
  '--smi[SMI-like output mode]'
