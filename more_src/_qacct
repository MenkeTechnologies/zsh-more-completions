#compdef qacct
# Documentation: http://gridscheduler.sourceforge.net/htmlman/htmlman1/qacct.html
# Grid Engine: report and account for Grid Engine usage

local ret=1

_arguments -s \
  '-help[display help information]' \
  '-ar+[summarize usage for the given advance reservation id]:ar id' \
  '-A+[account for jobs charged to the given account]:account' \
  '-b+[earliest start time of jobs to summarize]:begin time' \
  '-d+[number of days to summarize]:days' \
  '-e+[latest start time of jobs to summarize]:end time' \
  '-f+[accounting file to use]:file:_files' \
  '-g+[restrict to job owners in the given group]:group' \
  '-h+[host on which accounting information is requested]:host:_hosts' \
  '-j+[accounting info for the given job name/id/pattern]:job' \
  '-l+[resource requirement that must be met by queues]:resource' \
  '-o+[restrict to jobs owned by the given owner]:owner' \
  '-pe+[summarize usage for the given parallel environment]:pe' \
  '-q+[summarize usage for the given queue expression]:queue' \
  '-slots+[summarize usage for the given slot count]:slots' \
  '-t+[array job task range (with -j)]:task range' \
  '-P+[summarize usage for the given project]:project' \
  '-D+[summarize usage for the given department]:department' && ret=0

return ret
