#compdef sftahwrite
# Documentation: http://www.ahay.org/RSF/sftahwrite.html
# Madagascar: write trace-and-header (tah) data to separate RSF files

local ret=1

_arguments -s \
  'output=[output trace filename (required)]:file:_files' \
  'outheaders=[output trace header file name]:file:_files' \
  'mode=[output ordering: mapped or seq]:mode:(mapped seq)' \
  'verbose=[print level: 0 terse 1 info 2 chatty 3 debug]:level:(0 1 2 3)' \
  '*:rsf file:_files' && ret=0

return ret
