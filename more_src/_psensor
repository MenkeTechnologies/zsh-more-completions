#compdef psensor
# _psensor — GTK+ application for monitoring hardware sensors (jeanfi/psensor)
# upstream: https://gitlab.com/jeanfi/psensor
# Flags from psensor(1) man page.

_psensor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-u --url)'{-u+,--url=}'[psensor-server URL]:url:' \
        '(-n --new-instance)'{-n,--new-instance}'[force creation of a new instance]' \
        '(-d --debug)'{-d+,--debug=}'[debug level (0-3)]:level:(0 1 2 3)'
}

_psensor "$@"
