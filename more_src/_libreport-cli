#compdef libreport-cli

# libreport-cli: CLI front-end for libreport (ABRT problem reporter)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'list:list problem dirs'
  'list-not-reported:list problems not yet reported'
  'analyze:run analyze step'
  'collect:run collect step'
  'report:run report step'
  'info:show problem info'
  'remove:remove problem dir'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-y[answer yes]' \
  '--yes[answer yes]' \
  '-r[release name]:release:' \
  '--release=[release name]:release:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'libreport-cli command' commands && ret=0 ;;
esac
return ret
