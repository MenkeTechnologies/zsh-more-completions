#compdef octavia

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:scaffold an Octavia project directory'
  'list:list workspace resources or connector definitions'
  'get:fetch a remote resource configuration'
  'generate:generate a source/destination/connection skeleton'
  'apply:apply local YAML configurations to Airbyte'
  'import:import remote resources into the local project'
  'delete:delete a resource'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--airbyte-url=[Airbyte URL]:url:' \
  '--airbyte-username=[Airbyte basic-auth username]:user:' \
  '--airbyte-password=[Airbyte basic-auth password]:pass:' \
  '--workspace-id=[Airbyte workspace id]:id:' \
  '--api-http-headers-file=[YAML file with custom HTTP headers]:file:_files' \
  '--enable-telemetry[opt in to telemetry]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'octavia command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        local -a list_subs=(
          'connectors:list available connector definitions'
          'workspace:list workspace resources'
        )
        _describe -t lcmds 'list subcommand' list_subs && ret=0
        case $words[2] in
          (connectors)
            _arguments '*::sub:(sources destinations)' && ret=0 ;;
          (workspace)
            _arguments '*::sub:(sources destinations connections)' && ret=0 ;;
        esac ;;
      (get)
        local -a resources=(
          'source:source resource'
          'destination:destination resource'
          'connection:connection resource'
        )
        _describe -t res 'resource' resources && ret=0 ;;
      (generate)
        _arguments \
          '--source=[source path]:path:_files' \
          '--destination=[destination path]:path:_files' \
          '*::sub:(source destination connection)' && ret=0 ;;
      (apply)
        _arguments \
          '*'{-f+,--file=}'[apply specific config file]:file:_files -g "*.{yaml,yml}"' \
          '--force[skip diff confirmation]' && ret=0 ;;
      (import)
        _arguments \
          '*::sub:(all source destination connection)' && ret=0 ;;
      (delete)
        _arguments \
          '--force[skip confirmation]' \
          '*::sub:(source destination connection)' && ret=0 ;;
    esac ;;
esac

return ret
