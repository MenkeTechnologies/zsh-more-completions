#compdef gefyra

# Zsh completion for gefyra - Kubernetes bridge for local development

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'up:start Gefyra'
      'down:stop Gefyra'
      'run:run a container locally'
      'bridge:bridge a container to the cluster'
      'unbridge:remove a bridge'
      'list:list active bridges and containers'
      'check:check cluster prerequisites'
      'status:show Gefyra status'
      'telemetry:manage telemetry settings'
      'version:show version'
    )
    _describe -t commands 'gefyra command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      up)
        _arguments -s -S \
          '--endpoint=[cluster endpoint]:endpoint' \
          '--operator-image=[operator image]:image' \
          '--stunt-image=[stunt image]:image' \
          '--minikube[use minikube tunnel]' \
          '--connection-name=[connection name]:name' \
          '--kubeconfig=[kubeconfig path]:kubeconfig:_files' \
          '--context=[kubernetes context]:context' \
          '--namespace=[namespace]:namespace' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--image=[container image]:image' \
          '--name=[container name]:name' \
          '(-N --namespace)'{-N,--namespace}'[namespace]:namespace' \
          '--command=[command to run]:command' \
          '*--env=[environment variable]:env (KEY=VALUE)' \
          '*--volume=[volume mount]:volume' \
          '*--port=[port mapping]:port' \
          '--detach[run in background]' && ret=0
        ;;
      bridge)
        _arguments -s -S \
          '--name=[local container name]:name' \
          '--deployment=[target deployment]:deployment' \
          '--container=[target container]:container' \
          '*--port=[port mapping]:port' \
          '(-N --namespace)'{-N,--namespace}'[namespace]:namespace' \
          '--target=[target workload]:target' \
          '--connection-name=[connection name]:name' && ret=0
        ;;
    esac
    ;;
esac

return ret
