#compdef gschem
# Documentation: https://man.archlinux.org/search?q=gschem
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-r --rcfile)'{-r,--rcfile}'+[rc file]:file:_files' \
  '(-L --library-path)'{-L,--library-path}'+[Scheme library path]:dir:_files -/' \
  '(-s --script)'{-s,--script}'+[Scheme script to load]:file:_files' \
  '(-c --command)'{-c,--command}'+[Scheme command]:cmd:' \
  '(-o --output)'{-o,--output}'+[output filename]:file:_files' \
  '(-p --place-as)'{-p,--place-as}'+[geometry]:geom:' \
  '*:schematic_file:_files -g "*.sch"' && ret=0

return ret
