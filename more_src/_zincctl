#compdef zincctl zincsearch-cli
# _zincctl — lightweight Elasticsearch alternative server flags (zincsearch/zincsearch)
# upstream: https://github.com/zincsearch/zincsearch
# `zincsearch` is the server binary; runtime configuration is environment-driven, with these CLI flags.

_zincctl() {
    local -a args
    args=(
        '--first-admin-user=[first admin user (overrides ZINC_FIRST_ADMIN_USER)]:user:'
        '--first-admin-password=[first admin password (overrides ZINC_FIRST_ADMIN_PASSWORD)]:password:'
        '--data-path=[data path (overrides ZINC_DATA_PATH)]:dir:_files -/'
        '--storage-type=[storage backend]:type:(disk s3 minio)'
        '--server.address=[server bind address]:addr:'
        '--server.port=[server port]:port:'
        '--server.mode=[server mode]:mode:(node cluster)'
        '--ingest-buffer-size=[in-memory ingest buffer size]:bytes:'
        '--ingest-buffer-flush-interval=[flush interval]:duration:'
        '--prometheus-enable[enable Prometheus metrics endpoint]'
        '--telemetry[enable anonymous telemetry]'
        '--no-telemetry[disable anonymous telemetry]'
        '--shards-num=[number of shards per index]:n:'
        '--profile-enable[enable pprof profiling endpoint]'
        '--profile-port=[pprof profiling port]:port:'
        '--max-document-size=[max document size in bytes]:bytes:'
        '--node-id=[node id within the cluster]:id:'
        '--cluster.node.role=[role within a cluster]:role:(coordinator data ingest)'
        '--sentry[enable Sentry error reporting]'
        '--no-sentry[disable Sentry error reporting]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_zincctl "$@"
