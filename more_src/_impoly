#compdef impoly
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/impoly.html
# MIRIAD impoly - fit and subtract a polynomial baseline from an image

local ret=1

_arguments -s -S \
  'in=[input image (no default)]:in:_files' \
  'out=[output image (no default)]:out:_files' \
  'order=[degree of highest polynomial term (default 0)]:order' \
  'coeffs=[display fitted polynomial coefficients]:coeffs' \
  'region=[region of the image to fit]:region' \
  '*:image:_files' && ret=0

return ret
