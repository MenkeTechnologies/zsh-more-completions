#compdef process
# Documentation: https://www.globalphasing.com/autoproc/manual/autoPROC4.html
# autoPROC process - automated diffraction data processing

local ret=1

_arguments -s -S \
  '-h[show usage information]' \
  '-checkdeps[check for all external dependencies and stop]' \
  '-check[check for external dependencies and stop on error]' \
  '-M[use a pre-defined combination of parameter settings via a macro]:macro or file:_files' \
  '-I[directory with data images]:image directory:_files -/' \
  '-d[output written to sub-directory instead of current directory]:dir:_files -/' \
  '-R[low- and high-resolution limits]:reslow:_message reslow' \
  '-ANO[treat Bijvoet pairs as separate during processing and scaling]' \
  '-noANO[do not treat Bijvoet pairs as separate]' \
  '-B[running in batch mode (no highlighting on standard output)]' \
  '-ref[reference MTZ for spacegroup, cell, indexing and test-set flags]:mtz:_files' \
  '-free[reference MTZ for test-set only]:mtz:_files' \
  '-Id[override automatic definition of identifiers/scans]:id,dir,template,from,to' \
  '-h5[Eiger/HDF5 dataset master file]:master.h5:_files' \
  '-nthreads[number of threads for parallelized steps]:threads' \
  '*:parameter or file:_files' && ret=0

return ret
