#compdef cramino
# Documentation: https://github.com/wdecoster/cramino
# cramino - fast quality assessment of CRAM and BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-t --threads)'{-t,--threads}'=[number of decompression threads]:threads' \
  '--reference=[reference for CRAM decompression]:file:_files' \
  '(-m --min-read-len)'{-m,--min-read-len}'=[minimal read length considered]:len' \
  '--hist=[generate histograms to file]:file:_files' \
  '--scaled[scale histogram bins by total basepairs]' \
  '--hist-count=[output histogram bin counts as TSV]:file:_files' \
  '--arrow=[write data to arrow file]:file:_files' \
  '--karyotype[normalized number of reads per chromosome]' \
  '--phased[calculate metrics for phased reads]' \
  '--spliced[provide metrics for spliced data]' \
  '--ubam[provide metrics for unaligned reads]' \
  '--format=[output format]:format:(text json tsv)' \
  '*:input:_files' && ret=0

return ret
