#compdef caveman-code caveman
# Documentation: https://github.com/JuliusBrussee/caveman-code
# Reference accessed: 2026-05-22
# Verified: packages/coding-agent/src/cli/args.ts and main.ts command routing.

# Zsh completion for caveman-code - terminal coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--provider[LLM provider name]:provider:' \
  '--model[model pattern or provider/id:thinking]:model:' \
  '--api-key[API key for provider]:key:' \
  '--system-prompt[system prompt text]:text:' \
  '--append-system-prompt[append text or file to system prompt]:text:' \
  '--mode[output mode]:mode:(text json rpc)' \
  '(-p --print)'{-p,--print}'[non-interactive mode]' \
  '(-c --continue)'{-c,--continue}'[continue previous session]' \
  '(-r --resume)'{-r,--resume}'[select session to resume]' \
  '--session[use specific session file]:session:' \
  '--fork[fork session file or partial UUID]:session:' \
  '--session-dir[session storage directory]:directory:_directories' \
  '--no-session[do not save session]' \
  '--models[comma-separated model patterns for Ctrl+P cycling]:models:' \
  '--no-tools[disable all built-in tools]' \
  '--tools[comma-separated tools to enable]:tools:(read bash edit write grep find ls)' \
  '--thinking[thinking level]:level:(off minimal low medium high xhigh)' \
  '--extension[load extension file]:file:_files' \
  '--no-extensions[disable extension discovery]' \
  '--skill[load skill file or directory]:path:_files' \
  '--no-skills[disable skills discovery]' \
  '--export[export session to HTML]:file:_files' \
  '--list-models[list available models]' \
  '--verbose[force verbose startup]' \
  '--offline[disable startup network operations]' \
  '--watch[start watch mode]' \
  '--max-turns[cap assistant turns]:count:' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'caveman-code command' \
      'doctor[run environment diagnostics]' \
      'login[authenticate providers]' \
      'self-update[update caveman-code binary]' \
      'selfupdate[alias for self-update]' \
      'serve[start daemon server]' \
      'sessions[list daemon sessions]' \
      'ps[alias for sessions]' \
      'attach[attach to daemon session over WebSocket]' \
      'worker[manage remote-worker registry]' \
      'watch[file watcher for comment triggers]' \
      'exec[non-interactive single-shot CI mode]' \
      'goal[autonomous goal loop driver]' \
      'plugin[plugin marketplace]' \
      'run-recipe[run Goose-style YAML recipe]' \
      'rollback[shadow-git checkpoint rollback]' \
      'models[provider and model registry]' \
      'mcp[MCP server commands]' \
      'install[install extension source]' \
      'remove[remove extension source]' \
      'uninstall[alias for remove]' \
      'update[update installed extensions]' \
      'list[list installed extensions]' \
      'config[open TUI to enable package resources]' && ret=0
    ;;
  args)
    case $line[1] in
      run-recipe)
        _arguments '--list[list available recipes]' '1:recipe file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
