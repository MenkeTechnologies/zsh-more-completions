#compdef guppy
# _guppy — Storacha Network CLI (storacha/guppy)
# upstream: https://github.com/storacha/guppy
# Subcommands from cmd/ (cobra).

_guppy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--data-dir=[data/config directory]:dir:_files -/' \
        '--config=[config file]:file:_files -g "*.toml"' \
        '--ui[use the guppy UI]' \
        '(-n --network)'{-n+,--network=}'[network preset]:preset:(forge forge-test hot warm-staging)' \
        '--upload-service-did=[upload service DID override]:did:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'login:authenticate with a Storacha account'
                'ls:list uploads in a space'
                'reset:reset agent state'
                'retrieve:download data by CID'
                'verify:verify uploaded data'
                'version:show version'
                'whoami:show authenticated account'
                'account:manage Storacha accounts'
                'blob:manage blobs'
                'delegation:manage UCAN delegations'
                'gateway:gateway commands'
                'proof:manage proofs'
                'space:manage Storacha spaces'
                'upload:upload data to a space'
                'unixfs:UnixFS commands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                login) _arguments '1:account email:' ;;
                retrieve) _arguments '1:CID:' ;;
                upload) _arguments '*:path:_files' ;;
            esac
            ;;
    esac
}

_guppy "$@"
