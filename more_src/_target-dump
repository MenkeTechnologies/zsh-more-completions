#compdef target-dump
# Documentation: https://github.com/fox-it/dissect.target/blob/main/dissect/target/tools/dump.py
# dissect.target dump tool - dump plugin output records to disk

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --compression)'{-c,--compression}'=[compression method]:method' \
  '--restart[restart the session and overwrite the state file if it exists]' \
  '(-s --serialization)'{-s,--serialization}'=[serialization method]:method' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '--limit=[limit number of records produced]:n' \
  '(-f --function)'{-f,--function}'=[comma separated functions to execute]:function' \
  '(-xf --excluded-functions)'{-xf,--excluded-functions}'=[functions to exclude from execution]:function' \
  '(-l --list)'{-l,--list}'=[list matching available plugins and loaders]::filter' \
  '--dry-run[print which functions would be executed without running them]' \
  '(-K --keychain-file)'{-K,--keychain-file}'=[keychain file in CSV format]:file:_files' \
  '(-Kv --keychain-value)'{-Kv,--keychain-value}'=[passphrase, recovery key or key file path value]:value' \
  '(-L --loader)'{-L,--loader}'=[select a specific loader]:loader' \
  '--child=[load child of target by path or index]:child' \
  '--children[include children]' \
  '--list-children[list children indices and paths, then exit]' \
  '--recursive[make --(list-)children behave recursively]' \
  '*'{-v,--verbose}'[increase output verbosity]' \
  '--version[print version]' \
  '(-q --quiet)'{-q,--quiet}'[do not output logging information]' \
  '--plugin-path=[a file or directory containing plugins and extensions]:path:_files' \
  '*:target:_files' && ret=0

return ret
