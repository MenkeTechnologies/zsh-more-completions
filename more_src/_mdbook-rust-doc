#compdef mdbook-rust-doc
# _mdbook-rust-doc — pull rustdoc into mdBook chapters (mythmon/mdbook-rust-doc)
# upstream: https://github.com/mythmon/mdbook-rust-doc
# Subcommand from src/main.rs (clap derive).

_mdbook-rust-doc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1:command:(supports)' \
        '2:renderer:(html epub markdown latex)'
}

_mdbook-rust-doc "$@"
