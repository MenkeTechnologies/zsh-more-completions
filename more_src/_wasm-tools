#compdef wasm-tools

_wasm_tools_commands() {
  local -a commands=(
    'parse:Parse WAT to Wasm binary'
    'print:Print Wasm binary as WAT'
    'validate:Validate a Wasm binary'
    'smith:Generate random valid Wasm'
    'shrink:Shrink a Wasm test case'
    'dump:Dump Wasm binary sections'
    'objdump:Disassemble Wasm binary'
    'strip:Strip custom sections'
    'demangle:Demangle Wasm names'
    'compose:Compose Wasm components'
    'component:Component model tools'
    'metadata:Manipulate metadata'
    'addr2line:Map addresses to source'
    'json-from-wast:Convert WAST to JSON'
    'wast:Run a WAST test script'
  )
  _describe 'command' commands
}

_wasm-tools() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '--version[Print version]' \
    '1:command:_wasm_tools_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        parse)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '1:input WAT file:_files -g "*.wat *.wast"'
          ;;
        print)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '--skeleton[Print skeleton only]' \
            '1:input Wasm file:_files -g "*.wasm"'
          ;;
        validate)
          _arguments \
            '--features[Enable features]:features:' \
            '1:input Wasm file:_files -g "*.wasm"'
          ;;
        smith)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '--fuel[Fuel for generation]:fuel:' \
            '--min-funcs[Minimum functions]:n:' \
            '--max-funcs[Maximum functions]:n:' \
            '1:seed file:_files'
          ;;
        shrink)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '--attempts[Max attempts]:n:' \
            '1:input Wasm file:_files -g "*.wasm"' \
            '2:predicate script:_files'
          ;;
        dump|objdump)
          _arguments '1:input Wasm file:_files -g "*.wasm"'
          ;;
        strip)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '--all[Strip all custom sections]' \
            '(-d --delete)'{-d,--delete}'[Section to delete]:section:' \
            '1:input Wasm file:_files -g "*.wasm"'
          ;;
        compose)
          _arguments \
            '(-o --output)'{-o,--output}'[Output file]:file:_files' \
            '(-c --config)'{-c,--config}'[Config file]:file:_files -g "*.yml *.yaml"' \
            '(-d --definitions)'{-d,--definitions}'[Definitions]:defs:_files' \
            '1:input Wasm file:_files -g "*.wasm"'
          ;;
        component)
          local -a subcmds=(
            'new:Create a component from a module'
            'wit:Extract WIT from a component'
            'embed:Embed WIT into a module'
            'targets:List world targets'
          )
          _describe 'component subcommand' subcmds
          ;;
        metadata)
          local -a subcmds=(
            'show:Show metadata'
            'add:Add metadata'
          )
          _describe 'metadata subcommand' subcmds
          ;;
      esac
      ;;
  esac
}

_wasm-tools "$@"
