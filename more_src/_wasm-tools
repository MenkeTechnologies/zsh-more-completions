#compdef wasm-tools
# Documentation: https://github.com/bytecodealliance/wasm-tools (src/bin/wasm-tools/main.rs)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_wasm_tools_commands() {
  local -a commands=(
    'parse:Parse the WebAssembly text format into binary'
    'validate:Validate a WebAssembly binary'
    'print:Print a WebAssembly binary in text format'
    'smith:Generate a random valid WebAssembly module'
    'shrink:Shrink a wasm file while preserving a predicate'
    'mutate:Mutate an input wasm file into a new valid wasm file'
    'dump:Print debugging information about the binary format'
    'objdump:Print debugging information about section headers'
    'strip:Remove custom sections from a WebAssembly file'
    'compose:Compose WebAssembly components together (deprecated)'
    'demangle:Demangle Rust and C++ symbols in the name section'
    'component:WebAssembly component model tooling'
    'metadata:Manipulate name and producer metadata'
    'wit-smith:Generate a random valid WIT document'
    'wit-dylib:WIT-defined dynamic library tooling'
    'addr2line:Translate wasm offsets to filename/line numbers with DWARF'
    'completion:Generate shell completion scripts'
    'json-from-wast:Convert a WAST file into JSON commands'
    'wast:Validate the structure of a *.wast file'
  )
  _describe 'command' commands
}

_wasm-tools() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-v --verbose)*'{-v,--verbose}'[use verbose output]' \
    '--color=[colorize output]:when:(auto always never)' \
    '1:command:_wasm_tools_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        parse|wat2wasm)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '*:input WAT/WAST file:_files -g "*.(wat|wast)"'
          ;;
        print|wasm2wat)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--skeleton[print only the skeleton of the module]' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        validate)
          _arguments \
            '*--features=[enable WebAssembly features]:features' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        smith)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--ensure-termination[ensure produced module terminates]' \
            '*:seed file:_files'
          ;;
        shrink)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--attempts=[maximum number of shrink attempts]:n' \
            '1:predicate script:_files' \
            '2:input wasm file:_files -g "*.wasm"'
          ;;
        mutate)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--seed=[mutation seed]:n' \
            '--reduce[only generate reduced modules]' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        dump|objdump)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        strip)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '--all[remove all custom sections]' \
            '*'{-d+,--delete=}'[regex of section names to delete]:section' \
            '*'{-k+,--keep=}'[regex of section names to keep]:section' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        demangle)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        compose)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yml|yaml)"' \
            '*'{-d+,--definitions=}'[component definitions]:file:_files' \
            '1:input wasm file:_files -g "*.wasm"'
          ;;
        component)
          local -a subcmds=(
            'new:Create a component from a core wasm binary'
            'wit:Extract the interface (WIT) from a component'
            'embed:Embed component-type custom sections into a core wasm module'
            'targets:Check whether a component conforms to a world'
            'link:Link multiple modules and adapters into a component'
            'semver-check:Check the semver compatibility of two components'
            'unbundle:Extract core wasm modules from a component'
          )
          _describe 'component subcommand' subcmds
          ;;
        metadata)
          local -a subcmds=(
            'show:Show name and producer metadata'
            'add:Add name or producer metadata to a wasm file'
          )
          _describe 'metadata subcommand' subcmds
          ;;
        addr2line)
          _arguments \
            '--code-section-offset=[wasm code section offset]:n' \
            '*:address:'
          ;;
        wit-smith)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
            '*:seed file:_files'
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish powershell elvish)'
          ;;
        json-from-wast|wast2json)
          _arguments \
            '(-o --output)'{-o+,--output=}'[output JSON file]:file:_files' \
            '1:input WAST file:_files -g "*.wast"'
          ;;
        wast)
          _arguments \
            '1:input WAST file:_files -g "*.wast"'
          ;;
      esac
      ;;
  esac
}

_wasm-tools "$@"
