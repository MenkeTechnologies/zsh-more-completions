#compdef mednafen

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-cdrom-debug[CD-ROM debug mode]' \
  '-fps.autoenable=[auto enable fps display]:bool:(0 1)' \
  '-fps.position=[fps display pos]:pos:(upper_left upper_right lower_left lower_right center)' \
  '-fps.scale=[fps font scale]:n:' \
  '-fps.bgcolor=[fps bg color]:hex:' \
  '-fps.textcolor=[fps text color]:hex:' \
  '-loadstate=[load saved state]:file:_files' \
  '-savestate=[save state file]:file:_files' \
  '-mouse_sensitivity=[mouse sensitivity]:n:' \
  '-netplay.host=[netplay host]:host:_hosts' \
  '-netplay.port=[netplay port]:port:' \
  '-netplay.password=[netplay password]:pw:' \
  '-netplay.localplayers=[local players]:n:' \
  '-netplay.nick=[nickname]:nick:' \
  '-netplay.gamekey=[game key]:key:' \
  '-cheats=[enable cheats]:bool:(0 1)' \
  '-autosave=[auto save state]:bool:(0 1)' \
  '-fs=[fullscreen]:bool:(0 1)' \
  '-video.fs=[video fullscreen]:bool:(0 1)' \
  '-video.driver=[video driver]:drv:(default opengl softfb)' \
  '-video.glvsync=[GL vsync]:bool:(0 1)' \
  '-vsync=[vsync]:bool:(0 1)' \
  '-sound=[enable sound]:bool:(0 1)' \
  '-sound.driver=[sound driver]:drv:(default sdl alsa openbsd jack oss dummy)' \
  '-sound.device=[sound device]:dev:' \
  '-sound.rate=[sample rate]:hz:' \
  '-sound.volume=[volume 0-150]:n:' \
  '-mute=[mute]:bool:(0 1)' \
  '-input.autofireperiod=[autofire period]:ticks:' \
  '-input.joystick.global_focus=[joystick global focus]:bool:(0 1)' \
  '-snapformat=[screenshot format]:fmt:(png pcx jpeg)' \
  '-config[show all config settings]' \
  '-dump-modules-def[dump module defs]' \
  '-mednafen.autosave=[autosave on exit]:bool:(0 1)' \
  '-soundrecord=[record sound to wav]:file:_files' \
  '-qtrecord=[record video to qt]:file:_files' \
  '-mov.cmpr=[movie compression]:n:' \
  '-mov.dim.x=[movie dim x]:n:' \
  '-mov.dim.y=[movie dim y]:n:' \
  '*:ROM file:_files' && ret=0

return ret
