#compdef universal-apk
# Documentation: https://github.com/codemagic-ci-cd/cli-tools/tree/master/docs/universal-apk
# Codemagic CLI tools - generate universal APK files from Android App Bundles

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--no-color[disable colored output]' \
  '--log-stream=[log output destination]:stream:(stderr stdout)' \
  '1:command:(generate)' \
  '*::args:->args' && ret=0

return ret
