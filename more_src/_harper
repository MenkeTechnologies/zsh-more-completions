#compdef harper-cli harper-ls

# Zsh completion for harper - grammar checker / language server

local curcontext="$curcontext" state line ret=1

if [[ $service == harper-ls ]]; then
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--stdio[communicate via stdio]' && ret=0
  return ret
fi

local -a subcommands=(
  'lint:lint a file for grammar errors'
  'parse:parse a file and show the token tree'
  'count:count the number of words in a file'
  'words:list all the words in a file'
  'sentences:list all the sentences in a file'
  'help:print help information'
)

_arguments -s -S \
  '1:subcommand:->subcmd' \
  '*::args:->args' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'harper-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (lint|parse|count|words|sentences)
        _arguments \
          '--language[file language]:language:(plaintext markdown rust typescript javascript python html toml go c cpp ruby java gitcommit)' \
          '1:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
