#compdef play-on-linux playonlinux
# Documentation: https://github.com/PlayOnLinux/POL-POM-4/blob/master/playonlinux
# Reference accessed: 2026-05-16
# Verified: launcher script /playonlinux (bash) lines 57-80, 93-96.
# The launcher only handles -h/--help, --version, and "--run <shortcut> [file]".
# Anything else falls through to mainwindow.py "$@" (Python GUI), which has no
# additional documented CLI options.
# Removed from prior file: --debug (not in source), --shutdown (not in source).

# PlayOnLinux: GUI wrapper around Wine for installing Windows apps
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--run[run a shortcut]:shortcut name:: :_files' \
  '*:file:_files -g "*.(exe|msi|bat|com)"' && ret=0
return ret
