#compdef play-on-linux playonlinux
# Documentation: https://www.playonlinux.com/en/documentation.html
# Reference accessed: 2026-05-16

# PlayOnLinux: GUI wrapper around Wine for installing Windows apps
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--run=[run a shortcut]:name:' \
  '--debug[debug mode]' \
  '--shutdown[shutdown all running apps]' \
  '*:Windows installer:_files -g "*.(exe|msi)"' && ret=0
return ret
