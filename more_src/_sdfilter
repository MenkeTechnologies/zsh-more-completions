#compdef sdfilter
# Documentation: https://rdock.github.io/documentation/html_docs/reference-guide/programs.html
# sdfilter - rDock filter SD records by data fields/attributes.

local ret=1

_arguments -s -S \
  '-f+[filter expression or filter file]:filter:' \
  '-s+[summary field for pseudo _COUNT]:field:' \
  '*:file:_files' && ret=0

return ret
