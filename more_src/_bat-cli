#compdef bat-cli
# _bat-cli — sharkdp bat cat clone with syntax highlighting CLI alias (David Peter / sharkdp, Rust); clap-rs
# upstream: https://github.com/sharkdp/bat

_bat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--show-all[show all]' \
        '-A[show all]' \
        '--plain[plain mode]' \
        '-p[plain mode]' \
        '--language=+[language]:l:(actionscript ada apache asp assembly awk bash batch bibtex c clojure cmake cobol coffee cpp crystal csharp css d dart diff docker dockerfile elixir elm erlang fish forth fortran fsharp gleam go groovy haskell html ini java javascript json jsx julia kotlin less log lua makefile markdown nim nix nsis objc objc++ ocaml pascal perl php powershell prolog properties protobuf puppet purescript python r racket reason ruby rust scala scheme sh sql svelte swift terraform tex toml ts tsx typescript vala verilog vhdl viml vimscript vue x86asm xml yaml zig)' \
        '-l+[language]:l:(actionscript ada apache asp assembly awk bash batch bibtex c clojure cmake cobol coffee cpp crystal csharp css d dart diff docker dockerfile elixir elm erlang fish forth fortran fsharp gleam go groovy haskell html ini java javascript json jsx julia kotlin less log lua makefile markdown nim nix nsis objc objc++ ocaml pascal perl php powershell prolog properties protobuf puppet purescript python r racket reason ruby rust scala scheme sh sql svelte swift terraform tex toml ts tsx typescript vala verilog vhdl viml vimscript vue x86asm xml yaml zig)' \
        '--list-languages[list languages]' \
        '-L[list languages]' \
        '--list-themes[list themes]' \
        '--theme=+[theme]:t:(1337 Coldark-Cold Coldark-Dark DarkNeon Dracula GitHub Monokai\\ Extended Monokai\\ Extended\\ Bright Monokai\\ Extended\\ Light Monokai\\ Extended\\ Origin Nord OneHalfDark OneHalfLight Solarized\\ (dark) Solarized\\ (light) Sublime\\ Snazzy TwoDark Visual\\ Studio\\ Dark+ ansi base16 base16-256 gruvbox-dark gruvbox-light zenburn)' \
        '--style=+[style]:list:(auto full plain changes header header-filename header-filesize grid rule numbers snip)' \
        '--paging=+[paging]:p:(auto never always)' \
        '--pager=+[pager command]:str:' \
        '--wrap=+[wrap mode]:m:(auto never character)' \
        '--terminal-width=+[terminal width]:n:' \
        '--color=+[color]:c:(auto never always)' \
        '--decorations=+[decorations]:d:(auto never always)' \
        '--italic-text=+[italic text]:i:(always never)' \
        '--tabs=+[tab width]:n:' \
        '--line-range=+[line range start:end]:str:' \
        '-r+[line range start:end]:str:' \
        '--highlight-line=+[highlight line]:list:' \
        '-H+[highlight line]:list:' \
        '--diff[diff against staged]' \
        '-d[diff against staged]' \
        '--diff-context=+[diff context lines]:n:' \
        '--file-name=+[file name]:list:' \
        '--map-syntax=+[map syntax]:str:' \
        '--ignored-suffix=+[ignored suffix]:list:' \
        '--list-file-cache[list file cache]' \
        '--clear-file-cache[clear file cache]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--config-file=+[config file]:file:_files' \
        '--generate-config-file[generate config file]' \
        '--no-config[no config]' \
        '--no-custom-assets[no custom assets]' \
        '--show-cache-and-exit[show cache and exit]' \
        '--show-tab-stops[show tab stops]' \
        '--strip-ansi=+[strip ansi]:m:(auto always never)' \
        '--unbuffered[unbuffered]' \
        '-u[unbuffered]' \
        '--squeeze-blank[squeeze blank lines]' \
        '-s[squeeze blank lines]' \
        '--squeeze-limit=+[squeeze limit]:n:' \
        '--lessopen[respect LESSOPEN]' \
        '--no-lessopen[ignore LESSOPEN]' \
        '--paging-only[paging only]' \
        '--force-colorization[force colorization]' \
        '-f[force colorization]' \
        '--list-syntax-themes[list syntax themes]' \
        '--no-paging[no paging]' \
        '-P[no paging]' \
        '--print-pager-name[print pager name]' \
        '--lang-by-ext=+[lang by ext]:str:' \
        '--print-files[print files]' \
        '*:file:_files'
}

_bat-cli "$@"
