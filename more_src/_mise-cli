#compdef mise

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate:print activation script for shell'
  'alias:manage aliases'
  'asdf:asdf-compatible commands'
  'backends:list/manage backends'
  'bin-paths:print bin paths'
  'cache:cache management'
  'completion:print shell completion'
  'config:show/edit config'
  'current:show currently active versions'
  'deactivate:print deactivation script'
  'direnv:direnv integration'
  'doctor:check setup'
  'env:print env vars'
  'env-vars:set/unset env vars'
  'exec:exec command with mise envs'
  'generate:generate config files'
  'global:set global versions'
  'hook-env:print hook for env vars'
  'hook-not-found:print not-found hook'
  'implode:remove mise from system'
  'install:install tool versions'
  'latest:show latest version of a tool'
  'link:create symlink to local tool'
  'local:set local versions'
  'ls:list installed tool versions'
  'ls-remote:list available tool versions'
  'outdated:show outdated tools'
  'plugins:plugin management'
  'prune:prune unused versions'
  'registry:show plugin registry'
  'reshim:rebuild shims'
  'run:run a task'
  'self-update:update mise itself'
  'set:set environment variables'
  'settings:show or edit settings'
  'shell:set tool versions for current shell'
  'sync:sync from asdf/nodenv/etc'
  'tasks:manage tasks'
  'test-tool:test a tool installation'
  'tool:show tool info'
  'trust:trust mise.toml file'
  'uninstall:uninstall a tool version'
  'unset:unset env vars'
  'unuse:remove tools from config'
  'upgrade:upgrade installed tools'
  'usage:print usage spec'
  'use:install and add tool to config'
  'version:show version'
  'watch:run task on file changes'
  'where:print install path of tool'
  'which:print path to tool binary'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-q[quiet]' \
  '*--quiet[quiet]' \
  '*-v[verbose]' \
  '*--verbose[verbose]' \
  '*--no-color[no color]' \
  '*--cd=[change dir]:dir:_files -/' \
  '*--profile=[profile]:p:' \
  '*--silent[silent]' \
  '*--trace[trace]' \
  '*--debug[debug]' \
  '*--yes[auto-answer yes]' \
  '*-y[auto-answer yes]' \
  '*--log-level=[log level]:l:(trace debug info warn error)' \
  '*-E+[env]:env:' \
  '*--env=[env]:env:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'mise command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (use|u)
        _arguments \
          '(-g --global)'{-g,--global}'[global]' \
          '(-e --env)'{-e+,--env=}'[env]:e:' \
          '(-p --path)'{-p+,--path=}'[config path]:file:_files' \
          '(--pin)--pin[pin version]' \
          '(--fuzzy)--fuzzy[fuzzy version]' \
          '(--remove)*--remove=[remove tool]:t:' \
          '(-f --force)'{-f,--force}'[force install]' \
          '(--jobs -j)'{-j+,--jobs=}'[parallel jobs]:n:' \
          '(--raw)--raw[raw output]' \
          '*:tool:' && ret=0 ;;
      (install|i)
        _arguments \
          '(-f --force)'{-f,--force}'[force install]' \
          '(--jobs -j)'{-j+,--jobs=}'[jobs]:n:' \
          '(--raw)--raw[raw output]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '*:tool:' && ret=0 ;;
      (uninstall|rm)
        _arguments \
          '(--all -a)'{-a,--all}'[all versions]' \
          '(--dry-run -n)'{-n,--dry-run}'[dry run]' \
          '*:tool:' && ret=0 ;;
      (ls)
        _arguments \
          '(-c --current)'{-c,--current}'[current versions]' \
          '(-g --global)'{-g,--global}'[global]' \
          '(-i --installed)'{-i,--installed}'[installed only]' \
          '(-J --json)'{-J,--json}'[JSON output]' \
          '(-m --missing)'{-m,--missing}'[missing only]' \
          '(--prefix)--prefix=[prefix]:p:' \
          '(--no-header)--no-header[no header]' \
          '(--offline)--offline[offline]' \
          '(--outdated)--outdated[outdated]' \
          '*:tool:' && ret=0 ;;
      (ls-remote)
        _arguments \
          '(--all)--all[all versions]' \
          '(--installed)--installed[installed only]' \
          '*:tool:' && ret=0 ;;
      (run)
        _arguments \
          '(-C --cd)'{-C+,--cd=}'[chdir]:dir:_files -/' \
          '(-c --continue-on-error)'{-c,--continue-on-error}'[continue on error]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-f --force)'{-f,--force}'[force]' \
          '(-i --interleave)'{-i,--interleave}'[interleave outputs]' \
          '(-j --jobs)'{-j+,--jobs=}'[jobs]:n:' \
          '(-o --output)'{-o+,--output=}'[output]:o:(prefix interleave keep-order replacing-cr quiet silent)' \
          '(-p --prefix)'{-p,--prefix}'[prefix output]' \
          '(-r --raw)'{-r,--raw}'[raw]' \
          '(-s --shell)'{-s+,--shell=}'[shell]:shell:' \
          '(--shell-quote)--shell-quote[quote shell]' \
          '(-t --tool)*'{-t+,--tool=}'[tool override]:t:' \
          '(--timings)--timings[show timings]' \
          '*:task:' && ret=0 ;;
      (exec|x)
        _arguments \
          '(-c --command)*'{-c+,--command=}'[command]:c:' \
          '(-j --jobs)'{-j+,--jobs=}'[jobs]:n:' \
          '(--raw)--raw[raw]' \
          '*: :_command_names -e' && ret=0 ;;
      (env|e)
        _arguments \
          '(-J --json)'{-J,--json}'[JSON]' \
          '(--shell -s)'{-s+,--shell=}'[shell]:shell:(bash zsh fish elvish nu xonsh pwsh)' \
          '*:tool:' && ret=0 ;;
      (which)
        _arguments \
          '(--plugin)--plugin[show plugin]' \
          '(--version)--version[show version]' \
          '(--tool)--tool=[tool]:t:' \
          '*: :_command_names -e' && ret=0 ;;
      (where)
        _arguments \
          '*:tool:' && ret=0 ;;
      (settings)
        _arguments \
          '1:subcommand:(add get ls set unset)' \
          '*: :' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(generate get ls set unset edit)' \
          '*: :' && ret=0 ;;
      (alias)
        _arguments \
          '1:subcommand:(get ls set unset)' \
          '*: :' && ret=0 ;;
      (plugins)
        _arguments \
          '1:subcommand:(install link list ls-remote uninstall update)' \
          '*: :' && ret=0 ;;
      (tasks)
        _arguments \
          '1:subcommand:(add deps edit info ls run)' \
          '*: :' && ret=0 ;;
      (cache)
        _arguments \
          '1:subcommand:(clear ls prune)' \
          '*: :' && ret=0 ;;
      (backends)
        _arguments \
          '1:subcommand:(ls)' \
          '*: :' && ret=0 ;;
      (registry)
        _arguments \
          '*:plugin:' && ret=0 ;;
      (activate)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[quiet]' \
          '(--shims)--shims[print shim activation]' \
          '(--no-hook-env)--no-hook-env[no hook env]' \
          '1:shell:(bash zsh fish elvish nu xonsh pwsh)' \
          '*: :' && ret=0 ;;
      (completion)
        _arguments \
          '(--include-bash-completion-lib)--include-bash-completion-lib[include bash compl lib]' \
          '1:shell:(bash zsh fish)' \
          '*: :' && ret=0 ;;
      (generate)
        _arguments \
          '1:subcommand:(bootstrap config-stub git-pre-commit github-action task-docs task-stubs)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
