#compdef rawtherapee rawtherapee-cli RawTherapee
# _rawtherapee — Gábor Horváth RawTherapee professional non-destructive raw image processing application (Beep6581 team, C++); custom argparse
# upstream: https://github.com/Beep6581/RawTherapee

_rawtherapee() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[input files csv]:str:' \
        '-w+[wait for queue completion]' \
        '-o+[output file or dir]:file:_files' \
        '-O+[output file or dir]:file:_files' \
        '-q[quick processing]' \
        '-s[use sidecar profile]' \
        '-S[use specific sidecar profile]' \
        '-p+[profile file]:file:_files -g "*.pp3"' \
        '-d[use default profile]' \
        '-j+[JPEG quality 0-100]:n:' \
        '-js+[JPEG subsampling]:m:(1 2 3)' \
        '-t+[uncompressed TIFF]:b:(z)' \
        '-tz+[zip TIFF]:b:(z)' \
        '-b8[8-bit output]' \
        '-b16[16-bit output]' \
        '-b16f[16-bit float output]' \
        '-b32f[32-bit float output]' \
        '-n[no overwrite]' \
        '-Y[overwrite]' \
        '-progress[show progress]' \
        '-r[recursive]' \
        '-R[recursive]' \
        '-mt[multi-threading]' \
        '-mst[max simultaneous tasks]:n:' \
        '-cl[command-line mode]' \
        '-gimp[GIMP plugin mode]' \
        '-gimp-version=+[version]:n:' \
        '-XY[crop XY]:str:' \
        '-WH[width height]:str:' \
        '-RT-CACHE[cache dir]:dir:_files -/' \
        '-RT-SETTINGS[settings dir]:dir:_files -/' \
        '*:RAW image:_files -g "*.raw *.cr2 *.cr3 *.nef *.arw *.dng *.rw2 *.orf *.raf *.pef *.sr2 *.x3f *.crw *.kdc *.dcs *.mrw *.tif *.tiff *.jpg *.jpeg *.png *.pp3"'
}

_rawtherapee "$@"
