#compdef exaile
# Documentation: https://manpages.debian.org/trixie/exaile/exaile.1.en.html
# Reference accessed: 2026-05-17
# Verified: Debian trixie exaile(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --moduledir/--eprefs/--showgui/--current-volume/
# --set-volume/--gui-test (not in upstream manpage); -V is not the
# version short — version is --version only.

# exaile: GTK music player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-n --next)'{-n,--next}'[next track]' \
  '(-p --prev)'{-p,--prev}'[previous track]' \
  '(-s --stop)'{-s,--stop}'[stop]' \
  '(-a --play)'{-a,--play}'[play]' \
  '(-u --pause)'{-u,--pause}'[pause]' \
  '(-t --play-pause)'{-t,--play-pause}'[toggle play/pause]' \
  '--stop-after-current[stop after current track]' \
  '--add=[add location to playlist]:loc:' \
  '--export-playlist=[export current playlist]:loc:_files' \
  '(-q --query)'{-q,--query}'[print info and quit]' \
  '--format-query=[query format]:fmt:' \
  '--format-query-tags=[query format tags]:tags:' \
  '--gui-query[GUI query]' \
  '--get-title[print current title]' \
  '--get-album[print current album]' \
  '--get-artist[print current artist]' \
  '--get-length[print current length]' \
  '--set-rating=[set rating]:n:' \
  '--get-rating[print current rating]' \
  '--current-position[print current position]' \
  '--current-progress[print current progress]' \
  '(-v --volume)'{-v+,--volume=}'[set volume]:n:' \
  '(-i --increase-vol)'{-i+,--increase-vol=}'[increase volume]:n:' \
  '(-l --decrease-vol)'{-l+,--decrease-vol=}'[decrease volume]:n:' \
  '(-m --toggle-mute)'{-m,--toggle-mute}'[toggle mute]' \
  '--get-volume[print current volume]' \
  '--new[start new instance]' \
  '--start-minimized[start minimized]' \
  '--toggle-visible[toggle visibility]' \
  '--safemode[safe mode]' \
  '--force-import[force collection import]' \
  '--no-import[skip collection import]' \
  '--start-anyway[start despite errors]' \
  '--use-lang=[UI language]:lang:' \
  '--datadir=[data directory]:dir:_files -/' \
  '--all-data-dir=[all data dir]:dir:_files -/' \
  '--modulefilter=[module filter]:mod:' \
  '--levelfilter=[level filter]:level:' \
  '--debug[debug logging]' \
  '--eventdebug[event debug]' \
  '--eventdebug-full[full event debug]' \
  '--threaddebug[thread debug]' \
  '--eventfilter=[event filter]:type:' \
  '--quiet[quiet logging]' \
  '--no-dbus[disable DBus]' \
  '--no-hal[disable HAL]' \
  '*:audio file:_files -g "*.(mp3|ogg|flac|wav|aac|m4a|opus)(-.)"' && ret=0
return ret
