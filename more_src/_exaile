#compdef exaile
# Documentation: https://man.archlinux.org/search?q=exaile
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--datadir=+[data directory]:dir:_files -/' \
  '--moduledir=+[module directory]:dir:_files -/' \
  '--debug[debug mode]' \
  '--quiet[quiet]' \
  '--eprefs[edit preferences]' \
  '--showgui[show GUI]' \
  '--toggle-pause[toggle pause]' \
  '--play[play]' \
  '--stop[stop]' \
  '--next[next track]' \
  '--prev[previous track]' \
  '--get-title[current title]' \
  '--get-album[current album]' \
  '--get-artist[current artist]' \
  '--current-position[current position]' \
  '--current-volume[current volume]' \
  '--increase-vol=+[increase volume]:n:' \
  '--decrease-vol=+[decrease volume]:n:' \
  '--set-volume=+[set volume]:n:' \
  '--play-pause[toggle play/pause]' \
  '--query[print info and quit]' \
  '--gui-test[gui test]' \
  '*:audio file:_files -g "*.{mp3,ogg,flac,wav,aac,m4a,opus}"' && ret=0

return ret
