#compdef capi cluster-api-cli
# _capi — Kubernetes SIG Cluster Lifecycle capi CLI alternative client launcher for the Cluster API project providing declarative Kubernetes-style APIs for provisioning upgrading operating multiple Kubernetes clusters across AWS Azure GCP Docker vSphere OpenStack BareMetal-providers infrastructure-bootstrap-provider-control-plane (Kubernetes team, Go); cobra
# upstream: https://cluster-api.sigs.k8s.io/

_capi() {
    local -a sub=(
        'init:initialize a CAPI management cluster'
        'generate:generate config'
        'get:get cluster details'
        'describe:describe a cluster'
        'move:move CAPI resources between clusters'
        'upgrade:upgrade providers'
        'delete:delete a cluster'
        'rollout:rollout management'
        'topology:topology operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--kubeconfig-context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--infrastructure=+[name]:str:' \
        '--bootstrap=+[name]:str:' \
        '--control-plane=+[name]:str:' \
        '--core=+[name]:str:' \
        '--ipam=+[name]:str:' \
        '--addon=+[name]:str:' \
        '--target-namespace=+[name]:str:' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-o+[output]:f:(yaml json table)' \
        '--list-images[list required container images]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'capi subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments '1:type:(cluster machine-deployment yaml provider)' ;;
                describe|delete|get) _arguments '*:cluster name:' ;;
                rollout) _arguments '1:op:(restart undo pause resume)' '*:resource:' ;;
            esac
            ;;
    esac
}

_capi "$@"
