#compdef fasm2

# fasm2: flat assembler 2 (g/expanded variant of fasm)
# Documentation: https://flatassembler.net/docs.php?article=manual
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-m[memory limit (KB)]:n:' \
  '-p[passes limit]:n:' \
  '-d[predefine a symbol]:symbol=value:' \
  '-s[generate symbols dump]:file:_files' \
  '1:source file:_files -g "*.asm"' \
  '2:output file:_files' && ret=0
return ret
