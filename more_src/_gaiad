# Documentation: https://github.com/cosmos/gaia
# Reference accessed: 2026-05-17 (initial 13 stems); 2026-05-30 R76
# multi-stem expansion (+18 verified Cosmos SDK chain daemons via
# `gh api .../contents/cmd` directory inspection on each upstream
# repo).
# Verified: every added stem has been confirmed as the actual built
# binary by reading the `cmd/<name>/` directory of its upstream repo
# (archway-network/archway, axone-protocol/axoned, bandprotocol/chain,
# celestiaorg/celestia-app, crypto-org-chain/chain-main,
# crescent-network/crescent, CudoVentures/cudos-node,
# dymensionxyz/dymension, fetchai/fetchd, KiFoundation/ki-tools,
# lavanet/lava, neutron-org/neutron, noble-assets/noble,
# quasar-finance/quasar, regen-network/regen-ledger, Sifchain/sifnode,
# terpnetwork/terp-core, umee-network/umee).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialise validator and node configuration'
  'start:run the daemon'
  'export:export state to JSON'
  'status:query node status'
  'version:print version'
  'config:create or query config'
  'keys:keyring management'
  'query:query blockchain state'
  'tx:create and broadcast transactions'
  'genesis:genesis file commands'
  'collect-gentxs:collect genesis transactions'
  'gentx:generate a genesis transaction'
  'add-genesis-account:add account to genesis'
  'validate-genesis:validate genesis file'
  'rollback:rollback state by one block'
  'snapshots:state snapshot management'
  'tendermint:Tendermint subcommands'
  'comet:CometBFT subcommands'
  'debug:debug helpers'
  'prune:prune app db state'
  'testnet:create local testnet'
  'help:show help'
  'completion:generate shell completions'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--home=[application home directory]:dir:_files -/' \
  '--log_level=[log level]:lvl:(debug info warn error)' \
  '--log_format=[log format]:fmt:(plain json)' \
  '--trace[print stack traces on errors]' \
  '--keyring-backend=[keyring backend]:b:(os file kwallet pass test memory)' \
  '--chain-id=[chain id]:id:' \
  '--node=[node RPC URL]:url:' \
  '--output=[output format]:fmt:(text json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'cosmos daemon command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--moniker=[node name]:name:' \
          '--p2p.laddr=[P2P listen addr]:addr:' \
          '--rpc.laddr=[RPC listen addr]:addr:' \
          '--rpc.grpc_laddr=[gRPC laddr]:addr:' \
          '--grpc.address=[gRPC server address]:addr:' \
          '--grpc.enable=[enable gRPC]:bool:(true false)' \
          '--grpc-web.address=[gRPC-web addr]:addr:' \
          '--grpc-web.enable=[enable gRPC-web]:bool:(true false)' \
          '--api.address=[API listen address]:addr:' \
          '--api.enable=[enable REST API]' \
          '--api.swagger=[enable swagger]' \
          '--minimum-gas-prices=[min gas prices]:prices:' \
          '--pruning=[pruning strategy]:s:(default nothing everything custom)' \
          '--pruning-keep-recent=[recent blocks to keep]:n:' \
          '--pruning-interval=[pruning interval blocks]:n:' \
          '--db_backend=[db backend]:b:(goleveldb cleveldb badgerdb boltdb rocksdb pebbledb)' \
          '--state-sync.snapshot-interval=[snapshot interval]:n:' \
          '--state-sync.snapshot-keep-recent=[recent snapshots]:n:' \
          '--abci=[ABCI transport]:t:(socket grpc)' \
          '--halt-height=[halt at height]:n:' \
          '--halt-time=[halt at unix time]:n:' \
          '--inter-block-cache=[enable inter-block cache]:bool:(true false)' \
          '--mempool.size=[mempool size]:n:' \
          '--unsafe-skip-upgrades=[skip upgrades csv]:list:' \
          '--x-crisis-skip-assert-invariants[skip invariants check]' \
          '--with-comet[use CometBFT]:bool:(true false)' && ret=0 ;;
      (keys) _values 'subcommand' 'add' 'delete' 'export' 'import' 'list' 'list-key-types' 'migrate' 'mnemonic' 'parse' 'rename' 'show' 'unsafe-export-eth-key' 'unsafe-import-eth-key' && ret=0 ;;
      (query|q) _values 'module' 'auth' 'authz' 'bank' 'distribution' 'evidence' 'feegrant' 'gov' 'group' 'ibc' 'ibc-transfer' 'mint' 'params' 'slashing' 'staking' 'tendermint-validator-set' 'tx' 'txs' 'upgrade' 'wasm' 'block' 'tendermint' 'comet' && ret=0 ;;
      (tx) _values 'subcommand' 'auth' 'authz' 'bank' 'broadcast' 'crisis' 'decode' 'distribution' 'encode' 'evidence' 'feegrant' 'gov' 'group' 'ibc' 'ibc-transfer' 'multi-sign' 'multisign-batch' 'sign' 'sign-batch' 'slashing' 'staking' 'validate-signatures' 'vesting' 'wasm' && ret=0 ;;
      (genesis) _values 'subcommand' 'add-genesis-account' 'collect-gentxs' 'gentx' 'migrate' 'validate-genesis' 'export' && ret=0 ;;
      (snapshots) _values 'subcommand' 'list' 'load' 'restore' 'export' 'dump' 'delete' && ret=0 ;;
    esac ;;
esac

return ret
