#compdef spipe
# _spipe — encrypted pipe client for spiped (Tarsnap/spiped)
# upstream: https://github.com/Tarsnap/spiped
# Flags from spipe/main.c (libcperciva GETOPT).

_spipe() {
    _arguments \
        '(- *)-v[show version]' \
        '-t+[target socket (path or host:port)]:target:' \
        '-k+[key file (- for stdin)]:file:_files' \
        '-b+[bind address]:addr:' \
        '(-g)-f[fast/weak handshaking (no DH)]' \
        '(-f)-g[require perfect forward secrecy]' \
        '-j[disable transport layer keep-alives]' \
        '-o+[connection timeout (seconds)]:seconds:'
}

_spipe "$@"
