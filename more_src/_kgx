#compdef kgx gnome-console
# Documentation: https://man.archlinux.org/search?q=kgx
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-e --command)'{-e,--command}'+[command to run]:cmd:_command_names' \
  '--working-directory=+[working directory]:dir:_files -/' \
  '(-T --title)'{-T,--title}'+[window title]:title:' \
  '--wait[wait for child to exit]' \
  '--tab[open in tab]' \
  '--window[open new window]' \
  '*:argument:' && ret=0

return ret
