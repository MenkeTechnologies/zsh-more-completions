#compdef mautrix-linkedin linkedin-matrix
# _mautrix-linkedin — Matrix↔LinkedIn Messages puppeting bridge (beeper/linkedin)
# upstream: https://github.com/beeper/linkedin
# Flags from mautrix.bridge.Bridge + mautrix.util.program (argparse).

_mautrix-linkedin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(yml|yaml)"' \
        '(-n --no-update)'{-n,--no-update}'[do not save updated config to disk]' \
        '(-g --generate-registration)'{-g,--generate-registration}'[generate registration and quit]' \
        '(-r --registration)'{-r+,--registration=}'[appservice registration path]:file:_files -g "*.(yml|yaml)"' \
        '--ignore-unsupported-database[run even if DB schema is too new]' \
        '--ignore-foreign-tables[run even if DB contains tables from other programs]'
}

_mautrix-linkedin "$@"
