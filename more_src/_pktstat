#compdef pktstat

_arguments -s \
  '-1[single shot batch mode]' \
  '*-a[abbreviation]:abbrev:' \
  '-A[abbreviation file]:file:_files' \
  '-B[bytes per second]' \
  '-c[no combine flows]' \
  '-F[full hostnames]' \
  '-i[interface]:iface:_net_interfaces' \
  '-k[keep stale seconds]:n:' \
  '-l[sort by last seen]' \
  '-m[max bps]:n:' \
  '-n[no DNS]' \
  '-p[packet counts]' \
  '-P[no promiscuous]' \
  '-t[top mode]' \
  '-T[totals]' \
  '-w[refresh seconds]:n:' \
  '*:filter:'
