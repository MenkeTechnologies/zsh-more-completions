#compdef frr

local curcontext="$curcontext" state line ret=1
local -a subcommands daemons

subcommands=(
  'start:start FRR daemons'
  'stop:stop FRR daemons'
  'restart:restart FRR daemons'
  'reload:reload FRR config'
  'force-reload:force reload'
  'status:show daemon status'
)

daemons=(zebra bgpd ospfd ospf6d ripd ripngd isisd pimd pim6d ldpd nhrpd eigrpd babeld sharpd staticd bfdd fabricd vrrpd pathd)

_arguments -C \
  '1: :->subcommand' \
  '2:daemon:->daemon' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'frr action' subcommands && ret=0
    ;;
  (daemon)
    _describe -t daemons 'FRR daemon' daemons && ret=0
    ;;
esac

return ret
