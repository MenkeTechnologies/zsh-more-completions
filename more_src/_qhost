#compdef qhost
# Documentation: http://gridscheduler.sourceforge.net/htmlman/htmlman1/qhost.html
# Grid Engine: show the status of the available hosts, queues and jobs

local ret=1

_arguments -s \
  '-help[print a listing of all options]' \
  '-F+[detailed listing of resource availability per host]:resources' \
  '-cb[show NSOC and NCOR socket/core binding columns]' \
  '-h+[print only hosts in the given host list]:hosts' \
  '-j[print all jobs running on the shown hosts]' \
  '-l+[restrict to hosts granting the given resources]:resource' \
  '-q[show queue instances on the displayed hosts]' \
  '-u+[restrict to jobs/queues of the given users]:users' \
  '-xml[produce XML output]' && ret=0

return ret
