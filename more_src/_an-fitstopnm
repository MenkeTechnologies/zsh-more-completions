#compdef an-fitstopnm
# Documentation: https://astrometry.net/
# Source: dstndstn/astrometry.net util/an-fitstopnm.c — convert FITS images to PNM with stretching.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-i+[input FITS file]:file:_files -g "*.(fits|fit|fts)(-.)"' \
    '-o+[output PNM file (default stdout)]:file:_files -g "*.(pnm|pgm|ppm)(-.)"' \
    '-e+[FITS extension number (default 0)]:n:_default' \
    '-p+[image plane number (default 0)]:n:_default' \
    '-m+[pixel margin at image edges (default 0)]:n:_default' \
    '-O[enable ordinal transform mode]' \
    '-L+[low percentile for black point (default 25)]:pct:_default' \
    '-H+[high percentile for white point (default 95)]:pct:_default' \
    '-I[invert black-on-white imagery]' \
    '-X+[input value mapping to white]:value:_default' \
    '-N+[input value mapping to black]:value:_default' \
    '-x[use observed maximum as upper bound]' \
    '-n[use observed minimum as lower bound]' \
    '-r[apply both -x and -n]' \
    '-s[output 16-bit image data]' \
    '-M[compute and display median value]' \
    '*-v[verbose (stackable)]' \
    && ret=0

return ret
