#compdef mbutil
# MBTiles utility for importing/exporting map tile archives

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'export:export MBTiles to directory'
      'import:import directory to MBTiles'
      'merge:merge multiple MBTiles files'
    )
    _describe -t commands 'mbutil command' commands && ret=0
    ;;
  args)
    _arguments \
      '--scheme[tile scheme]:scheme:(tms xyz)' \
      '--image_format[tile image format]:format:(png jpg pbf)' \
      '--grid_callback[grid callback name]:callback:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
