#compdef xnotify
# Documentation: https://github.com/phillbush/xnotify/blob/master/xnotify.1
# Source: phillbush/xnotify — stdin-driven X11 notification daemon.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-b+[mouse action button number (1-3)]:button:(1 2 3)' \
    '-G+[gravity (NE/SW/C/etc)]:gravity:(N S E W NE NW SE SW C)' \
    '-g+[geometry per XParseGeometry(3)]:geometry:_default' \
    '-h+[maximum notification window height in pixels]:height:_default' \
    '-m+[monitor number]:monitor:_default' \
    '-o[only one notification at a time]' \
    '-r[watch notifications on the root window name]' \
    '-s+[seconds before notification is removed]:seconds:_default' \
    '-w[let window manager control notification windows]' \
    && ret=0

return ret
