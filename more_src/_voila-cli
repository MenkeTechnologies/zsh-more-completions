#compdef voila-cli voila2
# _voila-cli — Voila Project voila-cli CLI command-line frontend wrapping the Voila Project that turns Jupyter notebooks into standalone web applications by stripping the notebook of code cells and rendering only the outputs providing port host template strip-source theme browser autoreload no-browser preheat (Voila Project team, Python); jupyter
# upstream: https://voila.readthedocs.io/

_voila-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--no-browser[do not open browser]' \
        '--debug[debug]' \
        '--strip-sources=+[bool]:s:(true false)' \
        '--autoreload=+[bool]:s:(true false)' \
        '--template=+[name]:str:' \
        '--theme=+[t]:t:(light dark JupyterLab)' \
        '--base-url=+[path]:str:' \
        '--server-url=+[url]:str:' \
        '--enable-nbextensions=+[bool]:s:(true false)' \
        '--preheat-kernel=+[bool]:s:(true false)' \
        '--pool-size=+[N]:n:' \
        '--kernel-name=+[name]:str:' \
        '--show-tracebacks=+[bool]:s:(true false)' \
        '--config=+[file]:file:_files -g "*.py *.json"' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-config[no config]' \
        '--root-dir=+[dir]:dir:_files -/' \
        '--MultiKernelManager.default_kernel_name=+[name]:str:' \
        '--KernelManager.cull-idle-timeout=+[sec]:n:' \
        '--Voila.allow_remote_access=+[bool]:s:(true false)' \
        '--Voila.ip=+[host]:_hosts' \
        '--Voila.tornado_settings=+[json]:str:' \
        '*:notebook:_files -g "*.ipynb"'
}

_voila-cli "$@"
