#compdef ogrmerge

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:file:_files' \
  '-f+[output format]:format:' \
  '-single[merge into a single layer]' \
  '-nln+[output layer name]:name:' \
  '-field_strategy+[field strategy]:strategy:(FirstLayer Union Intersection)' \
  '-src_geom_type+[source geometry type]:type:(GEOMETRY POINT LINESTRING POLYGON MULTIPOINT MULTILINESTRING MULTIPOLYGON GEOMETRYCOLLECTION)' \
  '*-dsco+[dataset creation option]:NAME=VALUE:' \
  '*-lco+[layer creation option]:NAME=VALUE:' \
  '-update[update existing dataset]' \
  '-overwrite_ds[overwrite existing dataset]' \
  '-overwrite_layer[overwrite existing layer]' \
  '-append[append to existing layer]' \
  '-progress[display progress]' \
  '-skipfailures[skip failures]' \
  '-a_srs+[assign SRS]:srs:' \
  '-s_srs+[source SRS]:srs:' \
  '-t_srs+[target SRS]:srs:' \
  '*:input vector file:_files' && ret=0

return ret
