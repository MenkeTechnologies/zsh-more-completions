#compdef containerd-stress
# _containerd-stress — containerd stress-test load generator
# upstream: https://github.com/containerd/containerd
# Flags from cmd/containerd-stress/main.go on tip.

_containerd-stress() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--debug[enable debug logging]' \
        '--address=[containerd socket address]:path:_files' \
        '--concurrent=[concurrent worker count]:n:' \
        '--cri[use CRI client instead of containerd client]' \
        '--duration=[stress test duration]:dur:' \
        '--exec[exec into running containers as the workload]' \
        '--image=[image to use for stress workloads]:image:' \
        '--json=[emit JSON metrics on completion]:bool:(true false)' \
        '--metrics=[Prometheus metrics bind host\:port]:host\:port:' \
        '--runtime=[container runtime to use]:runtime:' \
        '--snapshotter=[snapshotter to use]:snapshotter:'
}

_containerd-stress "$@"
