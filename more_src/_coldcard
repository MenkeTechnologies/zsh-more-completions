#compdef coldcard ckcc
# _coldcard — Coinkite Coldcard ckcc CLI for the Mk3 Mk4 Q Coldcard air-gapped hardware-only Bitcoin signer managing PSBT signing message-signing xpub generation passphrase upgrade firmware multisig (Coldcard team, Python); argparse
# upstream: https://github.com/Coldcard/ckcc-protocol

_coldcard() {
    local -a sub=(
        'addr:display address on screen'
        'auth:authenticate to wallet'
        'backup:backup the wallet'
        'bag:show bag number'
        'chain:show or set chain'
        'devtest:devtest mode'
        'eval:evaluate Python on Coldcard'
        'exec:execute Python file on Coldcard'
        'export:export bookkeeping data'
        'file:write file to SD card'
        'help:show help'
        'list:list connected devices'
        'local-conf:get local conf'
        'logout:logout'
        'message:sign a message'
        'msg:sign a message'
        'multisig:export multisig wallet info'
        'pass:set BIP39 passphrase'
        'sign:sign PSBT'
        'show:display various device info'
        'start:start firmware upgrade'
        'unlock:unlock the seed'
        'upload:upload firmware'
        'upgrade:upgrade firmware'
        'usb:USB operations'
        'version:show version'
        'wipe:wipe device'
        'xpub:show xpub'
        'xfp:show fingerprint'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[device ix]:n:' \
        '--device-ix=+[device ix]:n:' \
        '-s+[serial number]:str:' \
        '--serial=+[serial number]:str:' \
        '--testnet[testnet]' \
        '--ledger[use ledger format]' \
        '--mnemonic[use mnemonic]' \
        '--xprv[use xprv]' \
        '--simulator[connect to simulator]' \
        '--prompt[prompt for password]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coldcard subcommand' sub ;;
        args)
            case $words[1] in
                sign) _arguments \
                    '-f+[finalize]' \
                    '--finalize[finalize PSBT]' \
                    '--visualize[visualize PSBT]' \
                    '*:psbt:_files -g "*.psbt *.txn"' ;;
                addr) _arguments \
                    '-q[quiet]' \
                    '*:derivation path:' ;;
                msg|message) _arguments \
                    '-d+[path]:str:' \
                    '--derivation=+[path]:str:' \
                    '*:message:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_coldcard "$@"
