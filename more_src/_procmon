#compdef procmon
# Documentation: https://github.com/Sysinternals/ProcMon-for-Linux (src/configuration/procmon_configuration.cpp)
# Reference accessed: 2026-05-30
# procmon — Microsoft Sysinternals Process Monitor for Linux. Requires sudo.
# Note: This is the LINUX port. Output filename pattern: procmon_[date]_[time].db when collecting headless.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage]' \
  '(-p --pids)'{-p,--pids=}'[CSV list of process IDs to monitor (capped at MAX_PIDS)]:pids:_pids' \
  '(-s --storageEngine)'{-s,--storageEngine=}'[storage backend for trace data]:engine:' \
  '(-e --events)'{-e,--events=}'[CSV list of syscalls to trace (default: all)]:syscalls:' \
  '(-c --collect)'{-c,--collect=}'[headless mode (output file optional)]:file:_files' \
  '(-f --file)'{-f,--file=}'[load existing procmon trace file]:file:_files -g "*.db"' \
  '(-l --log)'{-l,--log=}'[debug trace file path]:file:_files' \
  && ret=0

return ret
