#compdef jira
# Documentation: https://github.com/ankitpokhrel/jira-cli
# Reference accessed: 2026-05-19
# Verified: upstream cobra root.go at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config=}'[config file]:config file:_files' \
  '(-p --project)'{-p,--project=}'[default project key]:project' \
  '--debug[enable debug output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'board:manage boards'
      'completion:generate shell completion'
      'epic:manage epics'
      'init:initialize jira config'
      'issue:manage issues'
      'man:generate man pages'
      'me:show current user info'
      'open:open issue in browser'
      'project:manage projects'
      'release:manage releases'
      'serverinfo:show server info'
      'sprint:manage sprints'
      'version:show version'
    )
    _describe -t commands 'jira command' commands && ret=0
    ;;
  args)
    case $line[1] in
      issue)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(assign clone comment create delete edit link list move view watch worklog)' && ret=0
        ;;
      sprint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add list)' && ret=0
        ;;
      epic)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(add create list remove)' && ret=0
        ;;
      board)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list)' && ret=0
        ;;
      project)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list)' && ret=0
        ;;
      open)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:issue key' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--server=[Jira server URL]:url' \
          '--login=[login email]:email' \
          '--board=[default board ID]:board' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
