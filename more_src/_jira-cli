#compdef jira-cli
# _jira-cli — interactive Jira CLI (ankitpokhrel/jira-cli)
# upstream: https://github.com/ankitpokhrel/jira-cli

_jira_cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--config=[config file]:file:_files' \
        '--project=[project key]:project:' \
        '--debug[enable debug output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'board:manage Jira boards'
                'completion:generate shell completions'
                'epic:manage epics'
                'init:initialize jira-cli configuration'
                'issue:manage issues'
                'man:display manual for a command'
                'me:show current user info'
                'open:open issue in browser'
                'project:manage projects'
                'sprint:manage sprints'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                issue)
                    _arguments -C \
                        '1:subcommand:(create list view edit move comment link assign delete clone watch worklog)' \
                        '*:: :->issue_args'

                    case $state in
                        issue_args)
                            _arguments \
                                '(-t --type)'{-t,--type=}'[issue type]:type:(Bug Story Task Epic Sub-task)' \
                                '(-s --summary)'{-s,--summary=}'[issue summary]:summary:' \
                                '(-b --body)'{-b,--body=}'[issue description]:body:' \
                                '(-p --priority)'{-p,--priority=}'[priority]:priority:(Highest High Medium Low Lowest)' \
                                '(-a --assignee)'{-a,--assignee=}'[assignee]:user:' \
                                '(-l --label)'{-l,--label=}'[label]:label:' \
                                '(-c --component)'{-c,--component=}'[component]:component:' \
                                '--parent=[parent issue key]:key:' \
                                '--no-input[disable interactive input]' \
                                '--web[open in browser after creation]' \
                                '*:issue key:'
                            ;;
                    esac
                    ;;
                sprint)
                    _arguments \
                        '1:subcommand:(list add)' \
                        '--board=[board ID]:board:' \
                        '--state=[sprint state]:state:(future active closed)' \
                        '*:arguments:'
                    ;;
                epic)
                    _arguments \
                        '1:subcommand:(create list add remove)' \
                        '*:arguments:'
                    ;;
                board)
                    _arguments \
                        '1:subcommand:(list)' \
                        '--type=[board type]:type:(scrum kanban)'
                    ;;
                open)
                    _arguments '1:issue key:'
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_jira_cli "$@"
