#compdef dep-scan
# OWASP dependency and risk audit tool

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--src[source directory]:dir:_files -/' \
  '--type[project type]:type:(nodejs python java go ruby rust php dotnet)' \
  '--bom[BOM file to use]:file:_files' \
  '--report_file[output report file]:file:_files' \
  '--report_template[report template]:template:' \
  '--no-banner[suppress banner]' \
  '--no-error[do not fail on vulnerabilities]' \
  '--deep[enable deep scan]' \
  '--no-vuln-table[suppress vulnerability table]' \
  '--server-url[vulnerability server URL]:url:' \
  && return 0
