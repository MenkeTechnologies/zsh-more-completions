#compdef simple-http-server
# Documentation: https://github.com/TheWaWaR/simple-http-server
# Reference accessed: 2026-05-21
# Verified: upstream README and `--help` output.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --certpass (uses --cert-pass is not present either),
# --auth-message (no realm message option), --color/--no-color,
# --root-dir, --upload-size-limit (the flag is -l/--upload-size-limit
# in upstream), --redirect-to (real flag is --redirect),
# --header (no multi-header flag), -l/--index (upstream uses -i/--index).

_arguments -s -S \
  '(-i --index)'{-i,--index}'[enable automatic render of index.html / index.htm]' \
  '(-u --upload)'{-u,--upload}'[enable file upload]' \
  '--csrf=[custom CSRF token for uploads]:token' \
  '--redirect=[HTTP 301 redirect URL]:url' \
  '--nosort[disable directory sorting]' \
  '--nocache[disable HTTP caching]' \
  '--norange[disable partial (range) request support]' \
  '--cert=[PKCS#12 TLS/SSL certificate file]:file:_files' \
  '--cors[enable CORS headers]' \
  '--coop[add Cross-Origin-Opener-Policy header]' \
  '--coep[add Cross-Origin-Embedder-Policy header]' \
  '--certpass=[TLS certificate password]:password' \
  '(-l --upload-size-limit)'{-l,--upload-size-limit}'=[upload size limit in bytes]:size' \
  '--ip=[bind IP address]:address' \
  '(-p --port)'{-p,--port}'=[port number]:port' \
  '(-a --auth)'{-a,--auth}'=[HTTP Basic Auth user:pass]:credentials' \
  '(-c --compress)'{-c,--compress}'=[file extensions to gzip/deflate compress]:extensions' \
  '(-t --threads)'{-t,--threads}'=[worker thread count]:n' \
  '--try-file=[SPA fallback file for missing paths]:file:_files' \
  '(-s --silent)'{-s,--silent}'[suppress all output]' \
  '(-o --open)'{-o,--open}'[open in default browser]' \
  '(-b --base-url)'{-b,--base-url}'=[base URL prefix]:path' \
  '1:root directory:_directories'
