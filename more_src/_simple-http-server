#compdef simple-http-server

# Zsh completion for simple-http-server - Rust HTTP file server

_arguments -s -S \
  '(-i --ip)'{-i,--ip}'[bind address]:address' \
  '(-p --port)'{-p,--port}'[port number]:port' \
  '(-l --index)'{-l,--index}'[enable directory index]' \
  '--upload[enable file upload]' \
  '--nocache[disable cache headers]' \
  '--norange[disable range requests]' \
  '--nosort[disable directory sorting]' \
  '--cors[enable CORS headers]' \
  '--compress[enable gzip/deflate compression]' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '--try-file=[fallback file for SPA]:file:_files' \
  '--try-file-404=[custom 404 file]:file:_files' \
  '--cert=[TLS certificate file]:cert file:_files' \
  '--certpass=[TLS certificate password]:password' \
  '--key=[TLS key file]:key file:_files' \
  '--auth=[basic auth credentials]:user\:password' \
  '--auth-message=[auth realm message]:message' \
  '(-o --open)'{-o,--open}'[open browser after starting]' \
  '(-s --silent)'{-s,--silent}'[disable all output]' \
  '--color[force colorized output]' \
  '--no-color[disable colorized output]' \
  '--root-dir=[root directory to serve]:directory:_directories' \
  '--upload-size-limit=[maximum upload size in bytes]:size' \
  '--redirect-to=[redirect URL]:url' \
  '*--header=[add custom header]:header' \
  '--base-url=[base URL prefix]:url' \
  '1:directory:_directories'
