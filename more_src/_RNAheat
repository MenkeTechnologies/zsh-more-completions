#compdef RNAheat
# Documentation: https://man.archlinux.org/search?q=RNAheat
# Reference accessed: 2026-05-16

# ViennaRNA RNAheat: calculate specific heat (melting profile) of RNA
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-T --Tmin)'{-T,--Tmin=}'[minimum temperature in C]:temp:' \
  '--Tmax=[maximum temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[circular RNA]' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '(-s --stepsize)'{-s,--stepsize=}'[temperature step in C]:step:' \
  '(-i --ipoints)'{-i,--ipoints=}'[number of integration points]:n:' \
  '--paramFile=[parameter file]:file:_files' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
