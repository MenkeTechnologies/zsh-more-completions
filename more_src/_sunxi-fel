#compdef sunxi-fel
# Documentation: https://manpages.debian.org/unstable/sunxi-tools/sunxi-fel.1.en.html
# Control the USB BootROM (FEL) protocol for Allwinner CPUs

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging of FEL protocol]' \
  '(-p --progress)'{-p,--progress}'[show progress for transfers]' \
  '(-l --list)'{-l,--list}'[enumerate connected FEL devices]' \
  '--list-socs[list known SoCs]' \
  '(-d --dev)'{-d,--dev}'=[use specific USB bus and device number]:bus\:dev' \
  '--sid[print 128-bit security ID]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'command' \
      'spl[load and execute U-Boot SPL]' \
      'uboot[load SPL and start U-Boot]' \
      'hex[hexdump memory region]' \
      'hexdump[hexdump memory region]' \
      'dump[binary memory dump]' \
      'exe[call function at address]' \
      'execute[call function at address]' \
      'read[write memory contents to file]' \
      'write[store file contents into memory]' \
      'readl[read 32-bit value from memory]' \
      'writel[write 32-bit value to memory]' \
      'reset64[reset into 64-bit at address]' \
      'wdreset[reset via watchdog]' \
      'memmove[copy memory region]' \
      'ver[show BROM version]' \
      'version[show BROM version]' \
      'sid[show security ID]' \
      'clear[fill memory with zeroes]' \
      'fill[fill memory with byte value]' \
      'spiflash-info[show SPI flash chip info]' \
      'spiflash-read[read from SPI flash to file]' \
      'spiflash-write[write file to SPI flash]' && ret=0
    ;;
  args)
    case $words[1] in
      spl|uboot|read|write|dump|spiflash-read|spiflash-write) _files && ret=0 ;;
      *) _arguments ':address:' ':length:' && ret=0 ;;
    esac
    ;;
esac

return ret
