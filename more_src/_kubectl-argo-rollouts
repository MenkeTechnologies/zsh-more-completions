#compdef kubectl-argo-rollouts

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'abort:abort a rollout'
  'completion:generate completion script'
  'create:create a Rollout/Experiment/AnalysisTemplate/AnalysisRun'
  'dashboard:start UI dashboard'
  'get:get details about rollouts and experiments'
  'lint:lint and validate a Rollout'
  'list:list rollouts or experiments'
  'notifications:manage notifications settings'
  'pause:pause a rollout'
  'promote:promote a rollout'
  'restart:restart pods of a rollout'
  'retry:retry a rollout or experiment'
  'set:update values on resources'
  'status:show status of a rollout'
  'terminate:terminate AnalysisRun or Experiment'
  'undo:undo a rollout'
  'version:print version'
)

_arguments -C \
  '--as=[user to impersonate]:user:' \
  '--as-group=[group to impersonate]:group:' \
  '--as-uid=[UID to impersonate]:uid:' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '--certificate-authority=[CA cert file]:file:_files' \
  '--client-certificate=[client cert file]:file:_files' \
  '--client-key=[client key file]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--context=[kubeconfig context]:context:' \
  '--disable-compression[disable response compression]' \
  '(- *)'{-h,--help}'[show help]' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '(-v --kloglevel)'{-v,--kloglevel=}'[klog level]:level:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--loglevel=[log level]:level:(trace debug info warn error)' \
  '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
  '--request-timeout=[request timeout]:duration:' \
  '(-s --server)'{-s,--server=}'[Kubernetes API server]:server:' \
  '--tls-server-name=[TLS server name]:name:' \
  '--token=[bearer token]:token:' \
  '--user=[kubeconfig user]:user:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kubectl-argo-rollouts subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (get)
        _values 'resource' 'rollout' 'experiment' && ret=0
        ;;
      (set)
        _values 'set target' 'image' && ret=0
        ;;
      (create)
        _arguments \
          '(-f --filename)'{-f,--filename=}'[file]:file:_files' \
          '--no-color[disable color output]' \
          '(-w --watch)'{-w,--watch}'[watch]' && ret=0
        ;;
      (promote)
        _arguments '--full[fully promote rollout]' && ret=0
        ;;
      (dashboard)
        _arguments \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '--root-path=[root path]:path:' && ret=0
        ;;
      (status)
        _arguments \
          '(-t --timeout)'{-t,--timeout=}'[timeout]:duration:' \
          '(-w --watch)'{-w,--watch}'[watch]' && ret=0
        ;;
    esac
    ;;
esac

return ret
