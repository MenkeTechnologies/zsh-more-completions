# hp-makecopies: HPLIP copy maker (flatbed copy interface)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d+,--device=}'[device URI]:uri:' \
  '(-p --printer)'{-p+,--printer=}'[printer name]:printer:_printers' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '(-m --copies --num)'{-m+,--copies=,--num=}'[number of copies 1-99]:n:' \
  '(-r --reduction --enlargement)'{-r+,--reduction=,--enlargement=}'[scale percent 25-400]:pct:' \
  '(-q --quality)'{-q+,--quality=}'[quality level]:quality:(fast draft normal presentation best)' \
  '(-c --contrast)'{-c+,--contrast=}'[contrast -5 to 5]:value:' \
  '(-f --fittopage --fit)'{-f,--fittopage,--fit}'[fit to page (flatbed only, overrides -r)]' && ret=0
return ret
