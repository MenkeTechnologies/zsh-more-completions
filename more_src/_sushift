#compdef sushift
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/stretching_moveout_resamp/sushift.c
# SUSHIFT - shifted/windowed traces in time

local ret=1

_arguments -s -S \
  'tmin=[min time to pass (seconds)]:t:' \
  'tmax=[max time to pass (seconds)]:t:' \
  'dt=[sample rate in microseconds]:d:' \
  'fill=[value to place in padded samples]:f:' \
  'verbose=[1 echos parameters to stdout]:v:(0 1)' \
  '*:SU file:_files' && ret=0

return ret
