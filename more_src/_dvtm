#compdef dvtm
# Documentation: https://man.archlinux.org/search?q=dvtm
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '-v[print version information]'
  '-M[toggle default mouse grabbing]'
  '-m[set modifier key]:modifier key:(^g ^a ^b ^c ^t ^z)'
  '-d[delay for status bar updates in seconds]:seconds:'
  '-h[lines for scrollback buffer]:lines:'
  '-c[path to configuration file]:config file:_files'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
