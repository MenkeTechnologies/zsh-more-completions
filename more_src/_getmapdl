#compdef getmapdl
# Documentation: getmapdl source (TeX getmap package)
# Source: TeX getmap getmapdl — download OpenStreetMap / Google Maps tiles.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--SERVER=[map service]:server:(googlev3 osm openstreetmap googlestaticmaps)' \
    '--LOCATION=[location address or coordinates]:address:' \
    '--XSIZE=[image width in pixels]:px:' \
    '--YSIZE=[image height in pixels]:px:' \
    '--ZOOM=[zoom level 0..21]:n:' \
    '--SCALE=[image scale factor]:n:' \
    '--IMAGETYPE=[output image format]:fmt:(png jpg gif)' \
    '--FILENAME=[output filename base]:name:' \
    '--MARKER=[map marker spec]:spec:' \
    '--MARKERS=[multiple markers]:spec:' \
    '--PATH=[map path spec]:spec:' \
    '--PATHS=[multiple paths]:spec:' \
    '--LANGUAGE=[map language code]:lang:' \
    '--MAPTYPE=[Google Maps maptype]:type:(roadmap satellite hybrid terrain)' \
    '--FORMAT=[Google Maps format]:fmt:(png jpg gif)' \
    '--KEY=[API key]:key:' \
    '--NUMBER=[number of tiles to fetch]:n:' \
    '(- *)--help[show help]' \
    && ret=0

return ret
