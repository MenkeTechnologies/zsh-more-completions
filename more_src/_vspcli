#compdef vspcli
# Documentation: https://github.com/artagon/artagon-vscode-profiles/blob/main/scripts/vspcli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (the script's usage() block
# is the canonical CLI surface).
# Removed from prior file: entire bash script body that was erroneously
# committed in place of a zsh completion; bogus man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1
local -a commands

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-l,--list}'[list available profiles]' \
  '(-o --open)'{-o,--open}'[open path with profile]:profile: :path:_files' \
  '(-i --install)'{-i,--install}'[install declared extensions for profile]:profile:' \
  '(-E --install-ext)'{-E,--install-ext}'[install a single extension into profile]:profile: :extension:' \
  '(-G --install-groups)'{-G,--install-groups}'[install extension groups for profile]:profile: *:group:(AI CMake Java Rust General)' \
  '(-c --compose)'{-c,--compose}'[compose settings (all if none provided)]:*:profile:' \
  '(-x --export)'{-x,--export}'[export profiles]:*:profile:' \
  '(-O --open-profiles)'{-O,--open-profiles}'[run open-profiles.sh]:*:profile:' \
  '--skip-install[skip extension installs with --open-profiles]' \
  '(-p --profile-import)'{-p,--profile-import}'[import a .code-profile bundle]:profile: :file:_files -g "*.code-profile"' \
  '--completion=[print completion script]:shell:(bash zsh fish)' && ret=0

return ret
