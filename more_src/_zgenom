#compdef zgenom

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'load:load a plugin'
      'bin:add a binary from a plugin to PATH'
      'ohmyzsh:load an Oh My Zsh plugin or theme'
      'prezto:load a Prezto module'
      'compile:compile zsh files'
      'apply:apply changes'
      'reset:clear zgenom init script'
      'save:save current plugins to init script'
      'saved:check if init script exists'
      'list:list loaded plugins'
      'update:update all plugins'
      'clean:remove unused plugins'
      'selfupdate:update zgenom itself'
      'autoupdate:enable auto updates'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (load)
        _arguments \
          '1:repository:' \
          '2:subdirectory:' && ret=0
        ;;
      (ohmyzsh)
        _arguments \
          '1:component type:(plugins themes lib)' \
          '2:name:' && ret=0
        ;;
      (prezto)
        _arguments '1:module:' && ret=0
        ;;
      (bin)
        _arguments \
          '1:repository:' \
          '2:binary:' && ret=0
        ;;
      (compile)
        _arguments '*:file:_files -g "*.zsh"' && ret=0
        ;;
    esac
    ;;
esac

return ret
