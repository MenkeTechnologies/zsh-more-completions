#compdef vipsdisp
# Documentation: https://github.com/libvips/vipsdisp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and src/main.c in
# libvips/vipsdisp master. vipsdisp uses GApplication with no custom
# CLI flags; only GApplication/GTK built-in options apply.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all help]' \
  '--help-gtk[show GTK options]' \
  '--display=[X display]:display:' \
  '*:image:_files' && ret=0
return ret
