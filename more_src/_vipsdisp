#compdef vipsdisp
# Documentation: https://github.com/libvips/vipsdisp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# vipsdisp: libvips image display GTK viewer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '--help-all[show all GTK help]' \
  '--help-gtk[show GTK options]' \
  '--display=[X display]:display:' \
  '*:image:_files -g "*.(v|vips|jpg|jpeg|png|tif|tiff|webp|svg|gif|ppm|pgm|fits|exr|hdr|nii|niigz|svs|ndpi|scn|mrxs|vms|vmu|tiff)"' && ret=0
return ret
