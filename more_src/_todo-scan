(( $+functions[_todo-scan_commands] )) ||
_todo-scan_commands() {
    local commands; commands=(
'list:' \
'diff:' \
'context:Show code context around a TODO at FILE\:LINE' \
'init:Generate a .todo-scan.toml configuration file' \
'completions:Generate shell completions' \
'blame:Show git blame metadata for TODO comments' \
'stats:' \
'brief:Compressed summary of TODO landscape (2-4 lines)' \
'search:Search TODO comments by message text or issue reference' \
'check:' \
'watch:Watch filesystem for TODO changes in real-time' \
'clean:Find stale issue references and duplicate TODOs' \
'report:Generate an HTML technical debt dashboard report' \
'tasks:Export TODOs as Claude Code Tasks (Claude Code-specific; not compatible with other coding agents)' \
'workspace:Manage and inspect workspace packages' \
'relate:Discover relationships between TODO comments' \
'lint:Lint TODO comment formatting against configurable rules' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'todo-scan commands' commands "$@"
}
