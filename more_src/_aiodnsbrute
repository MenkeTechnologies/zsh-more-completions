#compdef aiodnsbrute
# Documentation: https://github.com/blark/aiodnsbrute
# Python 3.5+ DNS asynchronous brute force utility

local ret=1

_arguments -s -S \
  '(-w --wordlist)'{-w,--wordlist}'[wordlist to use for brute force]:wordlist:_files' \
  '(-t --max-tasks)'{-t,--max-tasks}'[maximum number of tasks to run asynchronously]:tasks' \
  '(-r --resolver-file)'{-r,--resolver-file}'[file with list of DNS resolvers, one per line]:resolver file:_files' \
  '*'{-v,--verbosity}'[increase output verbosity]' \
  '(-o --output)'{-o,--output}'[output results to DOMAIN.csv/json]:format:(csv json off)' \
  '(-f --outfile)'{-f,--outfile}'[output filename (use - for stdout)]:outfile:_files' \
  '--query[use DNS query lookup (faster, no CNAME)]' \
  '--gethostbyname[use gethostbyname lookup]' \
  '--wildcard[enable wildcard detection]' \
  '--no-wildcard[disable wildcard detection]' \
  '--verify[verify domain name before starting]' \
  '--no-verify[skip domain name verification]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:domain' && ret=0

return ret
