#compdef s6-svscanctl

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-p[reload services]' \
  '-r[reap zombies]' \
  '-a[run alarm on all services]' \
  '-b[abort - exit immediately]' \
  '-n[nuke - kill all services]' \
  '-i[interrupt scan]' \
  '-t[terminate]' \
  '-z[reap zombies]' \
  '-s[stop]' \
  '-Q[exit svscan]' \
  '1:scandir:_files -/' && ret=0

return ret
