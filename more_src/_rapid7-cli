#compdef rapid7-cli rapid7 insightidr-cli insightvm-cli nexpose-cli
# _rapid7-cli — Rapid7 rapid7-cli CLI command-line frontend wrapping the Rapid7 Insight Platform InsightVM Nexpose vulnerability management InsightIDR SIEM SOAR XDR DivvyCloud InsightCloudSec MetaSploit cybersecurity platform CLI providing login logout whoami site asset scan report scan-template scan-engine vulnerability tag policy investigation event alert detection rule user role org tag asset-group user-group log custom-alert log-search analytics (Rapid7 team Tas Giakouminakis, Go); cobra
# upstream: https://www.rapid7.com/

_rapid7-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'site:site operations'
        'asset:asset operations'
        'asset-group:asset group operations'
        'scan:scan operations'
        'scan-template:scan template operations'
        'scan-engine:scan engine operations'
        'vulnerability:vulnerability operations'
        'policy:policy operations'
        'tag:tag operations'
        'report:report operations'
        'investigation:investigation operations'
        'event:event operations'
        'alert:alert operations'
        'detection:detection operations'
        'rule:rule operations'
        'user:user operations'
        'role:role operations'
        'org:organization operations'
        'user-group:user group operations'
        'log:log operations'
        'log-set:log set operations'
        'custom-alert:custom alert operations'
        'log-search:log search operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us us2 us3 us4 eu eu2 ca au ap jp)' \
        '--insightvm-url=+[url]:str:' \
        '--insightvm-user=+[user]:_users' \
        '--insightvm-password=+[password]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rapid7 subcommand' sub ;;
        args)
            case $words[1] in
                site|asset|asset-group|scan|scan-template|scan-engine|vulnerability|policy|tag|report|investigation|event|alert|detection|rule|user|role|org|user-group|log|log-set|custom-alert) _arguments '1:op:(list get create update delete start stop pause resume close in-progress acknowledge)' '*:id:' ;;
                log-search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_rapid7-cli "$@"
