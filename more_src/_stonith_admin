#compdef stonith_admin
# Documentation: https://man.archlinux.org/search?q=stonith_admin
# Reference accessed: 2026-05-16

# stonith_admin: manage Pacemaker fencing devices (stonithd)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '-L[list fencing devices]' \
  '--list-registered[list fencing devices]' \
  '-l[list nodes fenced by device]:device:' \
  '--list=[list nodes fenced by device]:device:' \
  '-I[list installed fencing agents]' \
  '--installed[list installed fencing agents]' \
  '-M[show metadata for fencing agent]' \
  '--metadata[show metadata for fencing agent]' \
  '-Q[query device state]' \
  '--query[query device state]' \
  '-F[fence node]:node:' \
  '--fence=[fence node]:node:' \
  '-U[unfence node (un-cordon)]:node:' \
  '--unfence=[unfence node (un-cordon)]:node:' \
  '-B[reboot node]:node:' \
  '--reboot=[reboot node]:node:' \
  '-O[off node]:node:' \
  '--off=[off node]:node:' \
  '-C[confirm node fenced]:node:' \
  '--confirm=[confirm node fenced]:node:' \
  '-H[show history of fence events for node]:node:' \
  '--history=[show history of fence events for node]:node:' \
  '-c[cleanup history]:node:' \
  '--cleanup[cleanup history]' \
  '-r[register device]:device:' \
  '--register=[register device]:device:' \
  '-d[deregister device]:device:' \
  '--deregister=[deregister device]:device:' \
  '-a[fencing agent type]:agent:' \
  '--agent=[fencing agent type]:agent:' \
  '-o[set device parameter]:name=value:' \
  '--option=[set device parameter]:name=value:' \
  '-e[XML output]' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '-t[operation timeout]:seconds:' \
  '--timeout=[operation timeout]:seconds:' \
  '*::stonith_admin args:_files' && ret=0
return ret
