#compdef stonith_admin

# Pacemaker stonith_admin: STONITH (node fencing) administration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet (no output)]' \
  '(-B --reboot)'{-B,--reboot=}'[reboot a node]:node:' \
  '(-F --fence)'{-F,--fence=}'[fence a node]:node:' \
  '(-U --unfence)'{-U,--unfence=}'[unfence a node]:node:' \
  '(-C --confirm)'{-C,--confirm=}'[manually confirm node is fenced]:node:' \
  '(-L --list-registered)'{-L,--list-registered}'[list registered fence devices]' \
  '(-l --list)'{-l,--list=}'[list nodes a fence device can fence]:device:' \
  '(-H --history)'{-H,--history=}'[show fencing history for node]:node:' \
  '(-K --kick)'{-K,--kick}'[trigger STONITH for any pending requests]' \
  '(-Q --metadata)'{-Q,--metadata=}'[show fence agent metadata]:agent:' \
  '(-R --register)'{-R,--register=}'[register fence device]:id:' \
  '(-D --deregister)'{-D,--deregister=}'[deregister fence device]:id:' \
  '(-r --register-level)'{-r,--register-level=}'[register fence topology level]:level:' \
  '(-d --deregister-level)'{-d,--deregister-level=}'[deregister fence level]:level:' \
  '(-i --index)'{-i,--index=}'[topology level index]:n:' \
  '(-v --device)'{-v,--device=}'[fence device(s)]:devices:' \
  '(-o --option)'{-o,--option=}'[option name=value]:opt:' \
  '(-a --agent)'{-a,--agent=}'[fence agent type]:agent:' \
  '(-t --timeout)'{-t,--timeout=}'[operation timeout (sec)]:sec:' \
  '(-T --as-node)'{-T,--as-node=}'[perform as named node]:node:' \
  '(--tolerance)--tolerance=[reuse fence within N seconds]:sec:' \
  '(-O --output)'{-O,--output=}'[output to file]:file:_files' \
  '(--output-as)--output-as=[output format]:fmt:(text xml html)' \
  '*::stonith_admin args:_files' && ret=0
return ret
