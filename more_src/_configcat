#compdef configcat
# _configcat — ConfigCat feature flag CLI (configcat/cli)
# upstream: https://github.com/configcat/cli
# Subcommands from src/ConfigCat.Cli/Commands/*.cs (System.CommandLine).

_configcat() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
        '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'setup:configure CLI credentials'
                'config:manage configs'
                'product:manage products'
                'environment:manage environments'
                'segment:manage segments'
                'flag:manage feature flags'
                'tag:manage tags'
                'member:manage organization members'
                'permission-group:manage permission groups'
                'webhook:manage webhooks'
                'sdk-key:retrieve SDK keys'
                'config-json:manage config-json (download/convert/lock)'
                'eval:evaluate feature flags'
                'scan:scan a codebase for flag references'
                'list-all:list resources for an account'
                'workspace:manage CLI workspaces'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_configcat "$@"
