#compdef t.info
# GRASS GIS: list information about space time datasets and maps

local ret=1

_arguments -s -S \
  '--help[print usage summary]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  '--ui[force launching GUI dialog]' \
  '-g[print in shell script style]' \
  '-h[print history information in human readable shell style]' \
  '-d[print information about the temporal DBMI interface and exit]' \
  'input=[name of an existing space time dataset or map]:input' \
  'type=[type of the input space time dataset]:type:(strds str3ds stvds raster raster_3d vector)' && ret=0

return ret
