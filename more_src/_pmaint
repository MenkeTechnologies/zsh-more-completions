#compdef pmaint
# pkgcore package maintenance tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'copy:copy packages between repositories'
  'digest:update package manifests'
  'env-update:update environment'
  'mirror:mirror packages'
  'regen:regenerate metadata cache'
  'sync:sync repository'
)

_arguments -s -S \
  '1:command:->command' \
  '--config=[specify configuration file]:config:_files' \
  '--color=[enable/disable color]:color:(true false)' \
  '--debug[enable debug mode]' \
  '-q[quiet mode]' \
  '-v[verbose mode]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'pmaint command' commands && ret=0
    ;;
esac

return ret
