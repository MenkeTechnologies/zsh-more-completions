#compdef build_lmer_table
# Documentation: https://github.com/Dfam-consortium/RepeatScout/blob/main/build_lmer_table.c
# RepeatScout: build a frequency table of l-mers from a sequence

local ret=1

_arguments -s \
  '-l[length of l-mers to look at (default: auto)]:length:' \
  '-sequence[input fasta sequence file]:file:_files' \
  '-freq[output l-mer frequency table]:file:_files' \
  '-tandem[tandem distance window (default 500)]:dist:' \
  '-min[smallest number of required l-mers (default 3)]:n:' \
  '-sort[sort the output table]' \
  '-start[start position]:pos:' \
  '-stop[stop position]:pos:' \
  '-v[output debugging information]' && ret=0

return ret
