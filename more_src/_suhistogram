#compdef suhistogram
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/attributes_parameter_estimation/suhistogram.c
# Create histogram of input amplitudes

local ret=1

_arguments -s -S \
  'min=[minimum bin]:min' \
  'max=[maximum bin]:max' \
  'bins=[number of bins]:bins' \
  'trend=[=0 1-D; =1 2-D picks on cumulate; =2 2-D in trace format]:trend:(0 1 2)' \
  'clip=[threshold value to drop outliers]:clip' \
  'dt=[sample rate in feet or milliseconds]:dt' \
  'datum=[header key to get datum shift if desired]:datum' \
  '*:file:_files' && ret=0

return ret
