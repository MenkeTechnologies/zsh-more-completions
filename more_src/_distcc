#compdef distcc
# Documentation: https://man.archlinux.org/search?q=distcc
# Reference accessed: 2026-05-16

# Zsh completion for distcc - distributed C/C++ compiler

_arguments \
  '--help[show help message]' \
  '--version[show version]' \
  '--show-hosts[show host list]' \
  '--show-principal[show current principal]' \
  '-j[number of jobs]:number of jobs:' \
  '*::compiler arguments:_dispatch cc cc'
