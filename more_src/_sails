#compdef sails
# Documentation: https://sailsjs.com/documentation/reference/command-line-interface
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Sails.js CLI

_sails() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'new:create a new Sails app'
    'generate:generate a Sails component'
    'lift:start the Sails app'
    'console:launch an interactive Node.js shell with your app loaded'
    'inspect:inspect the Sails app'
    'debug:run the Sails app in debug mode'
    'version:display Sails version'
    'help:display help'
  )

  _arguments -s -S \
    '(- *)--version[display Sails version]' \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sails command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new)
          _arguments -s -S \
            '--no-frontend[create API-only project]' \
            '--fast[skip npm install]' \
            '--without=[comma-separated list of generators to skip]:generators:' \
            '1:app name:' \
            && ret=0
          ;;
        generate)
          _arguments -s -S \
            '1:type:(api model controller helper action page hook generator response adapter sails.io.js etc)' \
            '2:name:' \
            && ret=0
          ;;
        lift)
          _arguments -s -S \
            '--port=[port]:port:' \
            '--prod[lift in production mode]' \
            '--verbose[verbose output]' \
            '--silly[extra verbose output]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_sails "$@"
