#compdef sails

# Zsh completion for Sails.js CLI

_sails() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'new:create a new Sails app'
    'generate:generate a Sails component'
    'lift:start the Sails app'
    'console:open the Sails console'
    'inspect:inspect the Sails app'
    'debug:run the Sails app in debug mode'
    'www:build static assets'
    'version:display Sails version'
    'help:display help'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'sails command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new)
          _arguments -s -S \
            '--no-frontend[create API-only project]' \
            '--fast[skip npm install]' \
            '--without=[comma-separated list of generators to skip]:generators:' \
            '1:app name:' \
            && ret=0
          ;;
        generate)
          _arguments -s -S \
            '1:type:(api model controller helper action page)' \
            '2:name:' \
            && ret=0
          ;;
        lift)
          _arguments -s -S \
            '--port=[port]:port:' \
            '--prod[lift in production mode]' \
            '--verbose[verbose output]' \
            '--silly[extra verbose output]' \
            '--safe[safe mode - do not migrate]' \
            '--drop[drop all data and recreate tables]' \
            '--alter[auto-migrate existing data]' \
            && ret=0
          ;;
        console)
          _arguments -s -S \
            '--dontLift[do not lift the app]' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_sails "$@"
