#compdef snowflake-proxy

# snowflake-proxy: volunteer proxy for Snowflake
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-broker=[broker URL]:url:' \
  '-relay=[relay URL]:url:' \
  '-stun=[STUN server]:url:' \
  '-capacity=[max concurrent clients]:n:' \
  '-nat-probe-server=[NAT probe server]:url:' \
  '-poll-interval=[broker poll interval]:duration:' \
  '-keep-local-addresses[keep local IPs in SDPs]' \
  '-summary-interval=[stats summary interval]:duration:' \
  '-unsafe-logging[unsafe logging]' \
  '-log=[log file]:file:_files' \
  '-allowed-relay-hostname-pattern=[allowed relay hostname pattern (regex)]:regex:' \
  '-ephemeral-ports-range=[ephemeral ports range]:range:' \
  '-disable-stats[disable stats reporting]' \
  '*::snowflake-proxy args:_files' && ret=0
return ret
