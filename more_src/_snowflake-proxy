#compdef snowflake-proxy

# snowflake-proxy: standalone Snowflake bridge proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-broker[broker URL]:url:' \
  '-relay[relay URL]:url:' \
  '-stun[comma list of STUN server URLs]:urls:' \
  '-keep-local-addresses[do not strip private IPs from ICE]' \
  '-log[log file]:file:_files' \
  '-unsafe-logging[allow sensitive info in logs]' \
  '-capacity[max concurrent clients]:n:' \
  '-nat-probe-server[NAT probe server URL]:url:' \
  '-allowed-relay-pattern[regex for relay URLs]:regex:' \
  '-outbound-address[outbound IP]:ip:' \
  '-ephemeral-ports-range[ephemeral ports range]:range:' \
  '-poll-interval[broker poll interval]:sec:' \
  '*::snowflake-proxy args:_files' && ret=0
return ret
