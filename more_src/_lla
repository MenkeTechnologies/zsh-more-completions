#compdef lla

# chaqchase/lla — `ls` replacement (clap)

local ret=1
_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '-a[show dotfiles]' \
  '-l[long mode]' \
  '-t[sort by time]' \
  '-r[reverse sort]' \
  '--tree[tree view]' \
  '--icons[show icons]' \
  '*::path:_files -/' && ret=0
return ret
