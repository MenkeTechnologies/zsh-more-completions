#compdef lla
# Documentation: https://github.com/chaqchase/lla
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# chaqchase/lla — `ls` replacement (clap)

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --long)'{-l,--long}'[detailed metadata view]' \
  '--tree[hierarchical directory view]' \
  '(-T --table)'{-T,--table}'[structured table layout]' \
  '(-g --grid)'{-g,--grid}'[grid format]' \
  '(-S --sizemap)'{-S,--sizemap}'[visual disk usage]' \
  '--timeline[chronological grouping]' \
  '(-G --git)'{-G,--git}'[git status information]' \
  '(-F --fuzzy)'{-F,--fuzzy}'[interactive fuzzy finder]' \
  '(-R --recursive)'{-R,--recursive}'[deep directory exploration]' \
  '(-s --sort)'{-s,--sort=}'[sort field]:field:(name size date)' \
  '(-r --sort-reverse)'{-r,--sort-reverse}'[reverse sort]' \
  '--sort-dirs-first[sort directories first]' \
  '--sort-natural[natural sort]' \
  '--sort-case-sensitive[case-sensitive sort]' \
  '(-f --filter)'{-f,--filter=}'[filter expression]:filter:' \
  '--preset=[named filter preset]:preset:' \
  '--size=[filter by size]:size:' \
  '--modified=[filter by modified time]:time:' \
  '--created=[filter by created time]:time:' \
  '(-c --case-sensitive)'{-c,--case-sensitive}'[case sensitive filter]' \
  '(-d --depth)'{-d,--depth=}'[max depth]:n:' \
  '--search=[search expression]:query:' \
  '--search-context=[search context]:context:' \
  '--dirs-only[only directories]' \
  '--files-only[only files]' \
  '--symlinks-only[only symlinks]' \
  '--dotfiles-only[only dotfiles]' \
  '--no-dirs[exclude directories]' \
  '--no-files[exclude files]' \
  '--no-symlinks[exclude symlinks]' \
  '--no-dotfiles[exclude dotfiles]' \
  '--respect-gitignore[respect .gitignore]' \
  '--icons[show icons]' \
  '--no-icons[hide icons]' \
  '--no-color[disable color]' \
  '--permission-format=[permission display format]:format:' \
  '--include-dirs[include directories in size calc]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'diff:compare directories or files'
      'jump:bookmark navigation'
      'install:install plugins'
      'use:interactive plugin manager'
      'update:update plugins'
      'plugin:execute plugin actions'
      'shortcut:manage command shortcuts'
      'init:setup wizard'
      'config:view or edit configuration'
      'theme:theme manager'
      'completion:generate shell completions'
      'clean:remove invalid plugins'
    )
    _describe -t commands 'lla command' commands
    _files -/
    ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
