#compdef dmctl
# _dmctl — DM cluster control CLI (pingcap/tiflow / Data Migration)
# upstream: https://github.com/pingcap/tiflow/tree/master/dm
# Subcommands + flags from dm/ctl/ctl.go (cobra).

_dmctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-s --source)'{-s+,--source=}'[MySQL source ID (repeatable, comma-separated)]:source:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_dmctl_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_dmctl_commands] )) ||
_dmctl_commands() {
    local -a commands
    commands=(
        'start-task:start a task as defined in the YAML file'
        'stop-task:stop a task'
        'pause-task:pause a paused task'
        'resume-task:resume a paused / failed task'
        'check-task:check the configuration of a task'
        'query-status:query task status'
        'show-ddl-locks:show un-resolved DDL locks'
        'unlock-ddl-lock:unlock a DDL lock'
        'pause-relay:pause the relay unit on the given source'
        'resume-relay:resume the relay unit on the given source'
        'purge-relay:purge relay log files'
        'operate-source:create / stop / show a source config'
        'offline-member:offline a master/worker from the cluster'
        'operate-leader:evict / cancel-evict the master leader'
        'list-member:list cluster members (master / worker / leader)'
        'operate-schema:get / set / remove a table schema'
        'get-config:get config of source / task / master / worker'
        'handle-error:skip / replace / revert a DDL or DML error'
        'transfer-source:transfer a source to another worker'
        'start-relay:start the relay unit on workers for a source'
        'stop-relay:stop the relay unit on workers for a source'
        'binlog:replace / inject / skip / revert binlog events'
        'shard-ddl-lock:show / unlock shard-ddl locks'
        'binlog-schema:get / set / remove binlog schema (alias of operate-schema)'
        'config:show / set / restore master / worker / source / task config'
        'validation:start / stop / show task data-validation results'
        'encrypt:encrypt a plaintext password to ciphertext'
        'help:get help about any command'
    )
    _describe -t commands 'dmctl command' commands
}

_dmctl "$@"
