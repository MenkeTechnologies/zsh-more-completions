#compdef awslocal

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)help[show help]' \
  '--endpoint-url=[override endpoint URL]:url:' \
  '--no-verify-ssl[do not verify SSL certificates]' \
  '--no-paginate[disable automatic pagination]' \
  '--output=[output format]:format:(json text table yaml yaml-stream)' \
  '--query=[JMESPath query]:query:' \
  '--profile=[AWS profile]:profile:' \
  '--region=[AWS region]:region:' \
  '--color=[color output]:when:(on off auto)' \
  '--no-sign-request[do not sign requests]' \
  '--ca-bundle=[CA certificate bundle]:ca bundle:_files' \
  '--cli-connect-timeout=[connection timeout]:seconds:' \
  '--cli-read-timeout=[read timeout]:seconds:' \
  '--debug[enable debug logging]' \
  '1:service:->services' \
  '*::arg:->args' && ret=0

case $state in
  services)
    local -a services=(
      's3:Simple Storage Service'
      's3api:S3 API'
      'sqs:Simple Queue Service'
      'sns:Simple Notification Service'
      'lambda:Lambda Functions'
      'dynamodb:DynamoDB'
      'kinesis:Kinesis'
      'firehose:Kinesis Firehose'
      'apigateway:API Gateway'
      'cloudwatch:CloudWatch'
      'logs:CloudWatch Logs'
      'events:EventBridge'
      'stepfunctions:Step Functions'
      'iam:Identity and Access Management'
      'sts:Security Token Service'
      'secretsmanager:Secrets Manager'
      'ssm:Systems Manager'
      'ses:Simple Email Service'
      'ec2:Elastic Compute Cloud'
      'ecs:Elastic Container Service'
      'ecr:Elastic Container Registry'
      'cloudformation:CloudFormation'
      'route53:Route 53'
      'acm:Certificate Manager'
      'kms:Key Management Service'
      'cognito-idp:Cognito User Pools'
      'rds:Relational Database Service'
      'elasticache:ElastiCache'
      'opensearch:OpenSearch'
      'redshift:Redshift'
      'athena:Athena'
      'glue:Glue'
    )
    _describe -t services 'AWS service' services && ret=0
    ;;
esac

return ret
