#compdef bigWigCluster
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# cluster bigWigs using a hacTree

local ret=1

_arguments -s -S \
  '-labels=[tab separated file with path and label fields]:file:_files' \
  '-precalc=[tab separated file with file1 file2 distance columns]:file:_files' \
  '-threads=[number of threads to use (default 10)]:n' \
  '-tmpDir=[place to put temp files (default current dir)]:dir:_files -/' \
  '1:input list:_files' \
  '2:chrom sizes:_files' \
  '3:output json:_files' \
  '4:output tab:_files' && ret=0

return ret
