#compdef chsrc
# Documentation: https://man.archlinux.org/search?q=chsrc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a __ch=(
  '-ipv6[use IPv6 where applicable]'
  '-local[deprecated: same as -scope project]'
  '(-scope)-scope+[scope (two-token form)]:scope:(default project user system)'
  '-scope=-set scope with -scope=:scope:(default project user system)'
  '-en[English output]'
  '-english[English output]'
  '-dry[print commands without running them]'
  '(-no-color -no-colour)'{-no-color,-no-colour}'[disable ANSI color]'
  '(- *)'{-h,-help,--help}'[usage]'
  '(- *)'{-v,-ver,-version,--version}'[print version]'
)

_arguments -C \
  $__ch \
  '1: :->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd)
    local -a sub=(
      'help:usage'
      'list:list mirrors, menus, or target configuration'
      'measure:measure mirror speeds for a target'
      'get:print current source for a target'
      'set:set mirror (code or URL) for a target'
      'reset:restore the upstream default source'
      'issue:print upstream issue tracker links'
    )
    _describe -t commands 'chsrc command' sub && ret=0
    ;;
  (args)
    case $line[1] in
      (help|h|-h|issue|issues|isue|i)
        _arguments -s -S $__ch && ret=0
        ;;
      (list|l|ls)
        _arguments -s -S $__ch \
          '2::category, menu, or target:_default' && ret=0
        ;;
      (measure|mea|m|cesu|ce|c|get|g)
        _arguments -s -S $__ch \
          '2:target:_default' && ret=0
        ;;
      (set|s)
        _arguments -s -S $__ch \
          '2:target:_default' \
          '3::mirror code or URL:_default' && ret=0
        ;;
      (reset|rest|r)
        _arguments -s -S $__ch \
          '2:target:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
