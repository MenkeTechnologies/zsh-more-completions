#compdef clevis-luks-list
# Documentation: https://github.com/latchset/clevis/blob/master/src/luks/clevis-luks-list
# Reference accessed: 2026-05-16
# Verified: upstream src/luks/clevis-luks-list getopts ":d:s:p".

# clevis-luks-list: list clevis-bound LUKS slots
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[LUKS device]:device:_files -g "/dev/*"' \
  '-s[specific slot number]:slot:' \
  '-p[print only sorted space-separated pins]' && ret=0
return ret
