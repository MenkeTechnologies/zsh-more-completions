#compdef bumpp
# Documentation: https://github.com/antfu-collective/bumpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# antfu-collective/bumpp — interactive CLI to bump package versions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r+[version to release]:version:(major minor patch premajor preminor prepatch prerelease)' \
  '--release=[version to release]:version:(major minor patch premajor preminor prepatch prerelease)' \
  '--preid=[prerelease identifier]:identifier:(alpha beta rc)' \
  '--all[bump all packages in monorepo]' \
  '-c+[commit message]:message' \
  '--commit=[commit message]:message' \
  '--no-commit[skip commit]' \
  '--tag=[tag format]:format' \
  '--no-tag[skip tag]' \
  '--push[push to remote]' \
  '--no-push[skip push]' \
  '-y[skip confirmation]' \
  '--yes[skip confirmation]' \
  '--dry[dry run]' \
  '--execute=[command to execute before commit]:command' \
  '-x+[command to execute before commit]:command' \
  '--recursive[recursively bump packages]' \
  '*:explicit version' && ret=0

return ret
