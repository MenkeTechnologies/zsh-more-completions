#compdef apollo-router-cli
# _apollo-router-cli — Apollo Router subcommand-style admin CLI alias (Apollo GraphQL, Rust); clap-rs
# upstream: https://github.com/apollographql/router

_apollo-router-cli() {
    local -a sub=(
        'config:work with config'
        'serve:start the router'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--log=+[log level]:level:(off error warn info debug trace)' \
        '--log-format=+[log format]:fmt:(pretty json json-pretty stderr)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apollo-router subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '1:cmd:(experimental schema upgrade)' \
                    '*:arg:' ;;
                serve) _arguments \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--supergraph=+[supergraph schema]:file:_files' \
                    '-s+[supergraph schema]:file:_files' \
                    '--listen=+[listen address]:str:' \
                    '--apollo-key=+[apollo key]:str:' \
                    '--apollo-graph-ref=+[apollo graph ref]:str:' ;;
            esac
            ;;
    esac
}

_apollo-router-cli "$@"
