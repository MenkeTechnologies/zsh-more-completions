#compdef pants-cli
# _pants-cli — Pants Build Toolchain v2 monorepo build system CLI alias (Pants Build, Python/Rust); custom argparse
# upstream: https://github.com/pantsbuild/pants

_pants-cli() {
    local -a sub=(
        'check:type-check sources'
        'count-loc:count lines of code'
        'dependencies:list dependencies'
        'dependees:list dependees'
        'deploy:deploy'
        'experimental-bsp:BSP server'
        'export:export build environments'
        'export-codegen:export generated code'
        'filedeps:list source files'
        'fmt:run formatters'
        'generate-lockfiles:regenerate lockfiles'
        'help:show help'
        'help-advanced:show advanced help'
        'help-all:show all options'
        'list:list targets'
        'lint:run linters'
        'package:produce assets/archives'
        'paths:show paths between targets'
        'peek:dump target metadata'
        'publish:publish artifacts'
        'roots:show source roots'
        'run:run a target'
        'tailor:scaffold BUILD files'
        'test:run tests'
        'update-build-files:update BUILD files'
        'validate:validate config'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-colors[no colors]' \
        '--debug[debug]' \
        '--no-cache[no cache]' \
        '--no-dynamic-ui[no dynamic ui]' \
        '--no-spinner[no spinner]' \
        '--keep-sandboxes=+[keep sandboxes]:k:(never always on_failure)' \
        '--changed-since=+[changed since]:str:' \
        '--changed-include-dependees=+[changed include dependees]:b:(true false)' \
        '--changed-dependees=+[changed dependees]:b:(none direct transitive)' \
        '--print-stacktrace[print stacktrace]' \
        '--config=+[config file]:file:_files -g "pants.toml *.toml"' \
        '-c+[config file]:file:_files -g "pants.toml *.toml"' \
        '--no-pantsd[no pants daemon]' \
        '--pantsd[pants daemon]' \
        '--pants-version=+[pants version]:str:' \
        '--filter-target-type=+[filter target type]:list:' \
        '--filter-address-regex=+[filter address regex]:list:' \
        '--filter-tag-regex=+[filter tag regex]:list:' \
        '--tag=+[filter tag]:list:' \
        '--colors=+[colors]:b:(true false)' \
        '--remote-cache-read[remote cache read]' \
        '--remote-cache-write[remote cache write]' \
        '--remote-execution[remote execution]' \
        '--no-remote-execution[no remote execution]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pants subcommand' sub ;;
        args)
            case $words[1] in
                test|run|lint|fmt|check|package|publish|export|tailor|peek|paths|filedeps|list|dependencies|dependees) _arguments '*:target:' ;;
                help|help-advanced|help-all) _arguments '*:topic:' ;;
                generate-lockfiles) _arguments \
                    '--resolve=+[resolve]:list:' ;;
                update-build-files) _arguments \
                    '--check[check]' \
                    '--diff[diff]' \
                    '--fmt[fmt]' \
                    '--fix[fix]' ;;
                deploy) _arguments \
                    '--watch[watch]' ;;
            esac
            ;;
    esac
}

_pants-cli "$@"
