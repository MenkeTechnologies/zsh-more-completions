#compdef cnfsheadconf
# Documentation: man cnfsheadconf(8)
# Source: InterNetNews/inn frontends/cnfsheadconf.in — manipulate cycbuff header (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[cycbuff name]:cycbuff:_default' \
    '(- *)-h[show help]' \
    '-w[write changes to cycbuff header]' \
    && ret=0

return ret
