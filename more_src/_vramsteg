#compdef vramsteg
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/vramsteg.1.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS man page at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--min=[minimum value representing 0% progress]:integer:' \
  '--max=[maximum value representing 100% progress]:integer:' \
  '--current=[current progress position]:integer:' \
  '--remove[eliminate the displayed progress bar]' \
  '--now[return current time in epoch format]' \
  '--start=[previously captured start time]:time:' \
  '--elapsed[display elapsed time]' \
  '--estimate[show projected remaining time]' \
  '--width=[custom display width]:integer:' \
  '--percentage[display completion percentage]' \
  '--label=[descriptive text at start of progress bar]:text:' \
  '--style=[select alternate visual rendering]:style-name:' \
  '*::arguments:_default'
