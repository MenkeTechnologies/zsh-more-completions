#compdef openroad
# _openroad — OpenROAD Project openroad autonomous physical chip design with no-human-in-the-loop RTL-to-GDSII (the-openroad-project team, C++/Tcl); custom argparse
# upstream: https://github.com/The-OpenROAD-Project/OpenROAD

_openroad() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-version[show version]' \
        '--version[show version]' \
        '-no_init[no init script]' \
        '-no_splash[no splash banner]' \
        '-exit[exit after script]' \
        '-gui[start GUI]' \
        '--gui[start GUI]' \
        '-no_gui[no GUI]' \
        '-batch[batch mode]' \
        '-log+[log file]:file:_files -g "*.log"' \
        '--log=+[log file]:file:_files -g "*.log"' \
        '-metrics+[metrics file]:file:_files -g "*.json *.yaml *.yml"' \
        '--metrics=+[metrics file]:file:_files -g "*.json *.yaml *.yml"' \
        '-python[python mode]' \
        '--python[python mode]' \
        '-threads+[N]:n:' \
        '--threads=+[N]:n:' \
        '-design+[design file]:file:_files -g "*.def *.lef *.v *.sv"' \
        '--design=+[design file]:file:_files -g "*.def *.lef *.v *.sv"' \
        '-script+[Tcl script]:file:_files -g "*.tcl"' \
        '--script=+[Tcl script]:file:_files -g "*.tcl"' \
        '-no_settings[no settings]' \
        '*:input file:_files -g "*.tcl *.py *.def *.lef *.v *.sv *.lib *.sdc *.gds"'
}

_openroad "$@"
