#compdef djpegli
# Documentation: https://man.archlinux.org/search?q=djpegli
# Reference accessed: 2026-05-16

_arguments -s \
  '--disable_output[do not write output]' \
  '--bitdepth=[output bit depth]:n:(8 16)' \
  '--num_reps=[decode N times]:n:' \
  '--quiet[quiet]' \
  '1:input:_files -g "*.jpg *.jpeg"' \
  '2:output:_files'
