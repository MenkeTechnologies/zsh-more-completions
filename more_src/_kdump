#compdef kdump
# _kdump — OpenBSD kdump (display a ktrace(1) binary dump in human-readable form; default reads ktrace.out; -p/-P filter by pid/program, -t filters by trace string, -R prints relative timestamps)
# upstream: https://github.com/openbsd/src (usr.bin/kdump)
# Flags from usr.bin/kdump/kdump.1 on tip.

_kdump() {
    _arguments \
        '-d[decimal output]' \
        '-H[no human-readable conversions]' \
        '-l[follow file]' \
        '-n[no syscall name lookups]' \
        '-R[relative timestamps]' \
        '-T[absolute timestamps]' \
        '-X[hex dump strings]' \
        '-x[hex dump system call args]' \
        '-f+[trace file]:file:_files' \
        '-m+[maxdata bytes]:bytes:' \
        '-P+[program name filter]:program:' \
        '-p+[pid filter]:pid:_pids' \
        '-t+[trace selectors]:trstr:' \
        '-u+[trace label filter]:label:'
}

_kdump "$@"
