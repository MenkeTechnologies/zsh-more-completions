#compdef gost

# Zsh completion for gost - GO Simple Tunnel

local -a arguments

arguments=(
  '*-L[listen address specification (e.g. socks5://:1080)]:listen spec'
  '*-F[forward/proxy chain specification (e.g. http://:8080)]:forward spec'
  '-C[configuration file]:config file:_files'
  '-D[enable debug logging]'
)

_arguments -s -S $arguments
