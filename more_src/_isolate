#compdef isolate
# Documentation: https://github.com/ioi/isolate (isolate.c getopt_long table)
# Reference accessed: 2026-05-29
# IOI sandbox for grading competitive programming submissions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[display version info]' \
  '(- *)--help[show usage information]' \
  '--init[initialize sandbox]' \
  '--run[execute command in sandbox]' \
  '--cleanup[clean up sandbox]' \
  '--check-config[validate configuration]' \
  '--print-cg-root[print cgroup root path]' \
  '(-b --box-id)'{-b,--box-id=}'[unique sandbox identifier for parallel use]:id:' \
  '(-c --chdir)'{-c,--chdir=}'[change working directory before execution]:dir:_directories' \
  '--cg-mem=[limit control group memory (KB)]:KB:' \
  '--core=[limit core files (KB, default 0)]:KB:' \
  '*'{-d,--dir=}'[expose directory inside sandbox]:dir:_directories' \
  '*'{-E,--env=}'[inherit or set environment variable]:var[=val]:' \
  '(-f --fsize)'{-f,--fsize=}'[max file size (KB)]:KB:' \
  '(-i --stdin)'{-i,--stdin=}'[redirect stdin]:file:_files' \
  '(-k --stack)'{-k,--stack=}'[stack size limit (KB)]:KB:' \
  '(-m --mem)'{-m,--mem=}'[address space limit (KB)]:KB:' \
  '(-M --meta)'{-M,--meta=}'[output process info]:file:_files' \
  '(-n --open-files)'{-n,--open-files=}'[open file limit (default 64)]:max:' \
  '(-o --stdout)'{-o,--stdout=}'[redirect stdout]:file:_files' \
  '(-p --processes)'{-p,--processes=-}'[enable multiple processes (optional max)]::max:' \
  '(-q --quota)'{-q,--quota=}'[disk quota blocks,inodes]:blk,ino:' \
  '(-r --stderr)'{-r,--stderr=}'[redirect stderr]:file:_files' \
  '(-t --time)'{-t,--time=}'[run time limit (seconds)]:seconds:' \
  '(-w --wall-time)'{-w,--wall-time=}'[wall clock limit (seconds)]:seconds:' \
  '(-x --extra-time)'{-x,--extra-time=}'[extra timeout before kill]:seconds:' \
  '--as-uid=[act on behalf of user (root only)]:uid:' \
  '--as-gid=[act on behalf of group (root only)]:gid:' \
  '(-D --no-default-dirs)'{-D,--no-default-dirs}'[disable default directory rules]' \
  '(-e --full-env)'{-e,--full-env}'[inherit full parent environment]' \
  '(-s --silent)'{-s,--silent}'[suppress status messages]' \
  '*'{-v,--verbose}'[increase verbosity (stackable)]' \
  '--cg[enable control groups]' \
  '--share-net[share network namespace]' \
  '--inherit-fds[inherit parent file descriptors]' \
  '--stderr-to-stdout[redirect stderr to stdout]' \
  '--tty-hack[allow interactive programs]' \
  '--special-files[keep non-regular files in sandbox]' \
  '--wait[wait if sandbox busy (vs. refuse)]' \
  '*::command:_command_names -e' && ret=0

return ret
