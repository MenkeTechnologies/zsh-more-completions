#compdef milvus_cli milvus-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'calc:calculate distance between two vector arrays'
  'clear:clear the screen'
  'connect:connect to a Milvus instance'
  'create:create collection, partition, alias, user, role, or index'
  'delete:delete collection, partition, alias, user, role, index, or entities'
  'describe:describe collection, partition, or index'
  'exit:exit the CLI'
  'help:show help'
  'import:import data from a CSV (with header) into a collection'
  'list:list collections, partitions, aliases, users, roles, or indexes'
  'load:load a collection or partitions into memory'
  'query:run a query with a boolean expression'
  'release:release a collection or partitions from memory'
  'search:run a vector similarity search'
  'show:show connection / loading_progress / index_progress'
  'use:select a database to use'
  'version:print CLI version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'milvus_cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create|delete|describe|list)
        _values 'object' \
          'collection' 'partition' 'index' 'alias' 'user' 'role' 'database' && ret=0
        ;;
      (show)
        _values 'show target' \
          'connection' 'index_progress' 'loading_progress' 'collection' 'collections' \
          'partition' 'partitions' 'index' 'query_segment' && ret=0
        ;;
      (load|release)
        _values 'target' \
          'collection' 'partition' && ret=0
        ;;
    esac
    ;;
esac

return ret
