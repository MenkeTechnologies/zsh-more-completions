#compdef milvus_cli
# Documentation: https://man.archlinux.org/search?q=milvus_cli
# Reference accessed: 2026-05-16

_milvus_cli() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Display help for any command]'
        '--version[Show the version number]'
    )

    subcmds=(
        'connect:Establish connection to Milvus'
        'create:Create resources (collection, database, etc.)'
        'list:List resources'
        'show:View details/status'
        'delete:Remove resources'
        'load:Load collection/partition into memory'
        'release:Release collection/partition from memory'
        'insert:Insert entities from file or row'
        'upsert:Upsert entities from file or row'
        'query:Expression-based data retrieval'
        'search:Vector similarity search'
        'help:Display help'
        'version:Show version'
        'exit:Exit the CLI'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'milvus_cli commands' subcmds
            ;;
        args)
            case $line[1] in
                connect)
                    _arguments \
                        '(-uri --uri)'{-uri,--uri}'[Server URI]:uri:' \
                        '(-t --token)'{-t,--token}'[API key or username:password]:token:' \
                        '-tls[TLS mode (0, 1, 2)]:mode:(0 1 2)'
                    ;;
                create|list|show|delete)
                    local -a resource_subcmds
                    resource_subcmds=(
                        'collection:Manage collections'
                        'database:Manage databases'
                        'index:Manage indexes'
                        'partition:Manage partitions'
                        'user:Manage users'
                        'role:Manage roles'
                        'alias:Manage aliases'
                    )
                    _describe -t commands 'resource subcommands' resource_subcmds
                    ;;
                load|release)
                    local -a mem_subcmds
                    mem_subcmds=(
                        'collection:Target a collection'
                        'partition:Target a partition'
                    )
                    _describe -t commands 'memory subcommands' mem_subcmds
                    ;;
            esac
            ;;
    esac
}

_milvus_cli "$@"
