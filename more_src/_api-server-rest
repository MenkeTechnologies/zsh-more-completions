#compdef api-server-rest
# _api-server-rest — Confidential Containers guest REST API gateway in front of attestation-agent + confidential-data-hub
# upstream: https://github.com/confidential-containers/guest-components
# Flags from api-server-rest/src/main.rs Args on tip (clap).

_api-server-rest() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-b --bind)'{-b,--bind}'=[bind address for the REST API server]:addr:' \
        '(-f --features)'{-f,--features}'=[enabled API surface]:feature:(resource attestation all)' \
        '(-c --cdh_addr)'{-c,--cdh_addr}'=[confidential-data-hub TTRPC socket]:uri:' \
        '(-a --aa_addr)'{-a,--aa_addr}'=[attestation-agent TTRPC socket]:uri:'
}

_api-server-rest "$@"
