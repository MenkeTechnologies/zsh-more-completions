#compdef ig

# Zsh completion for Inspektor Gadget (ig) - eBPF-based observability

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-r+[runtime to use]:runtime:(docker containerd cri-o podman)' \
  '--runtime=[runtime to use]:runtime:(docker containerd cri-o podman)' \
  '--runtime-protocol=[runtime protocol]:protocol:(internal cri)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list-columns:list available columns for a gadget'
      'run:run a gadget'
      'snapshot:take a snapshot'
      'top:show top-like output'
      'trace:trace events'
      'profile:profile system activity'
      'advise:provide recommendations'
      'audit:audit for security issues'
      'version:show version'
      'completion:generate shell completions'
    )
    _describe -t commands 'ig command' commands && ret=0
    ;;
  args)
    case $line[1] in
      trace)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[container name filter]:container' \
          '--containername=[container name filter]:container' \
          '-o+[output mode]:mode:(columns json jsonpretty yaml)' \
          '--output=[output mode]:mode:(columns json jsonpretty yaml)' \
          '--timeout=[timeout]:seconds' \
          '1:gadget:(bind dns exec mount network open signal sni tcp tcpconnect tcpdrop tcpretrans)' && ret=0
        ;;
      top)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[container name filter]:container' \
          '--containername=[container name filter]:container' \
          '--max-rows=[max rows]:rows' \
          '--sort-by=[sort column]:column' \
          '--interval=[update interval]:seconds' \
          '1:gadget:(block-io ebpf file tcp)' && ret=0
        ;;
      snapshot)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[container name filter]:container' \
          '--containername=[container name filter]:container' \
          '-o+[output mode]:mode:(columns json jsonpretty yaml)' \
          '--output=[output mode]:mode:(columns json jsonpretty yaml)' \
          '1:gadget:(process socket)' && ret=0
        ;;
      profile)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[container name filter]:container' \
          '--containername=[container name filter]:container' \
          '-K[include kernel stacks]' \
          '--kernel-stacks-only[include kernel stacks only]' \
          '-U[include user stacks]' \
          '--user-stacks-only[include user stacks only]' \
          '1:gadget:(block-io cpu)' && ret=0
        ;;
    esac
    ;;
esac

return ret
