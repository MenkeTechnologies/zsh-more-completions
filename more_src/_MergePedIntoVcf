#compdef MergePedIntoVcf
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/arrays/MergePedIntoVcf.java
# Merge a single-sample ped file from zCall into a single-sample VCF

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--ORIGINAL_VCF -VCF)'{--ORIGINAL_VCF,-VCF}'=[input VCF file]:value:_files' \
  '(--PED_FILE -PED)'{--PED_FILE,-PED}'=[input ped file]:value:_files' \
  '(--MAP_FILE -MAP)'{--MAP_FILE,-MAP}'=[input map file]:value:_files' \
  '(--ZCALL_THRESHOLDS_FILE -ZCALL_T_FILE)'{--ZCALL_THRESHOLDS_FILE,-ZCALL_T_FILE}'=[zCall thresholds file]:value:_files' \
  '--ZCALL_VERSION=[zCall version]:value:' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[output VCF file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
