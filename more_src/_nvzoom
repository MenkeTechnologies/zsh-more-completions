#compdef nvzoom
# Documentation: https://www.systutorials.com/docs/linux/man/1-nvzoom/
# NVIDIA Texture Tools: resize images

local ret=1

_arguments -s -S \
  '-s[resize scale factor (default 0.5)]:scale' \
  '-g[gamma correction (default 2.2)]:gamma' \
  '-f[resampling filter]:filter:(box triangle quadratic bspline mitchell lanczos kaiser)' \
  '-w[edge handling mode]:mode:(mirror repeat clamp)' \
  '1:input:_files' \
  '2:output:_files' && ret=0

return ret
