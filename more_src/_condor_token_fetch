#compdef condor_token_fetch
# _condor_token_fetch — HTCondor condor_token_fetch (ask a Condor daemon (the master/collector specified via -pool / -addr / -name) to issue an IDTOKEN for the current user via the on-the-wire OAUTH2-style flow; -identity preferred identity, -lifetime seconds, -authz comma list, -file output)
# upstream: https://github.com/htcondor/htcondor
# Flags from HTCondor src/condor_tools/token_fetch on tip.

_condor_token_fetch() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '-identity+[identity hint]:identity:' \
        '-lifetime+[seconds]:seconds:' \
        '-authz+[authz csv]:authz:(READ WRITE ADMINISTRATOR ADVERTISE_STARTD ADVERTISE_SCHEDD ADVERTISE_MASTER NEGOTIATOR DAEMON)' \
        '-name+[daemon name]:name:' \
        '-pool+[collector]:host:_hosts' \
        '-addr+[address]:addr:' \
        '-type+[daemon type]:type:(master collector schedd startd negotiator credd)' \
        '-file+[output file]:file:_files'
}

_condor_token_fetch "$@"
