#compdef makeflow_monitor
# Documentation: https://cctools.readthedocs.io/en/latest/man_pages/makeflow_monitor/
# makeflow_monitor - monitor the progress of a Makeflow workflow from its log

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-f[output format]:format' \
  '-t[refresh timeout]:timeout' \
  '-m[minimum number of tasks to show a workflow]:num' \
  '-S[sort order for displayed workflows]:sort' \
  '-P[parse mode]' \
  '-H[only display currently running workflows]' \
  '*:makeflow log:_files' && ret=0

return ret
