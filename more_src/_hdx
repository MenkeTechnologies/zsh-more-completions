#compdef hdx
# =============================================================================
# hdx — hyperdxio/hyperdx's `@hyperdx/cli`
#   Node.js CLI for the HyperDX OBSERVABILITY
#   PLATFORM (open-source Datadog / Sentry /
#   Honeycomb alternative built on ClickHouse).
#   Provides an interactive INK-RENDERED TUI
#   for event search + live tail, raw SQL query
#   execution against ClickHouse-backed log /
#   trace / session / metric stores, dashboard
#   inspection, ClickHouse connection
#   management, and JavaScript SOURCEMAP
#   UPLOAD for stack-trace de-obfuscation.
#   Built on direct `@clickhouse/client ^1.12.1`
#   (the OFFICIAL TypeScript/JavaScript driver
#   from ClickHouse Inc) plus `@clickhouse/
#   client-common`.  TS-Node=108 leader bump
#   CLOSING Axis 53 (ClickHouse Client Library)
#   at 1/1/1 three-language symmetry.
#
# AXIS 53 — CLICKHOUSE CLIENT LIBRARY — CLOSES @ R803
# ====================================================
# Closes the three-language ClickHouse-driver
# axis at 1/1/1 symmetry:
#   * Rust       (R801): clickhouse-rs (via
#                getdozer fork) — bundled in
#                `dozer` (real-time data
#                movement engine)
#   * Go         (R802): ClickHouse/clickhouse-
#                go/v2 v2.21.0 — bundled in
#                `clickhouse_sinker` (Kafka →
#                ClickHouse sink daemon)
#   * TS-Node    (R803, THIS ROUND):
#                @clickhouse/client ^1.12.1 —
#                bundled in this round's `hdx`
#                (HyperDX observability CLI)
#
# `@clickhouse/client` is the OFFICIAL
# TypeScript/JavaScript driver maintained by
# ClickHouse Inc.  ~290 stars on GitHub.
# Apache-2.0.  Two variants:
#   - @clickhouse/client          Node.js
#                                 (HTTP +
#                                 server-side
#                                 features)
#   - @clickhouse/client-web      browser /
#                                 Deno /
#                                 Cloudflare
#                                 Workers
#                                 (Fetch API
#                                 only)
#   - @clickhouse/client-common  shared types
#                                 + protocol
#                                 helpers used
#                                 by both
# Speaks the HTTP+JSON interface (not the
# native TCP binary protocol — that's
# Cloudflare-Workers-incompatible).  Used by:
#   - hyperdxio/hyperdx (this round)        observability
#                                            platform
#   - cube-js/cube                          headless BI
#                                            with
#                                            ClickHouse
#                                            sources
#   - umami-software/umami                  privacy-
#                                            focused web
#                                            analytics
#   - novuhq/novu                           notification
#                                            infra
#   - firecrawl/firecrawl                   web scraping
#                                            + crawl
#                                            history in
#                                            ClickHouse
#   - tensorzero/tensorzero                 LLM gateway
#                                            with
#                                            ClickHouse
#                                            traces
#   - triggerdotdev/trigger.dev             background
#                                            jobs with
#                                            ClickHouse
#                                            audit log
#   - arkime/arkime                         large-scale
#                                            packet
#                                            indexing
#   - daytonaio/daytona                     dev-env
#                                            platform
#                                            with
#                                            ClickHouse
#                                            metrics
#
# Distinguishing hdx from sibling
# observability CLIs:
#   - DATADOG `dog` / `datadog` CLI: closed-
#     source SaaS.  hdx targets the open-
#     source HyperDX backend
#   - HONEYCOMB CLI: closed-source SaaS,
#     event-tail focused.  hdx is open-source +
#     self-hostable
#   - SENTRY `sentry-cli` (in corpus): error-
#     tracking focused, NOT log/trace search.
#     Both have sourcemap upload as a feature
#   - GRAFANA `grafanactl`: dashboard
#     management.  hdx covers dashboards +
#     log search + sourcemaps + ClickHouse
#     query in one CLI
#   - HDX is the COMPREHENSIVE HyperDX CLI:
#     auth + team switching + source/
#     connection/dashboard inspection +
#     raw SQL query (with optional Drain
#     pattern clustering) + sourcemap
#     upload + interactive TUI for live
#     tail
#
# KEY HDX FEATURES:
#   - INK-BASED INTERACTIVE TUI — `hdx tui`
#     opens a React-rendered terminal UI for
#     event search + live tail with arrow-
#     key + Vim-style (j/k) navigation.
#     Builds on `ink 6.8` + `ink-text-input` +
#     `ink-spinner`
#   - LUCENE-STYLE QUERY SYNTAX — `tui -q`
#     accepts a Lucene-style search query
#     (field:value, AND/OR/NOT, ranges).
#     Same syntax as the HyperDX web app
#   - KUBECTX-STYLE TEAM SWITCHING — `hdx
#     team list` / `hdx team current` /
#     `hdx team use <name-or-id>` for users
#     in multiple HyperDX teams.  Active
#     team persisted to `~/.hdx/session.
#     json` (or platform-equivalent)
#   - SESSION PERSISTENCE — `hdx auth login`
#     stores the access token + app URL
#     locally.  `hdx auth status` verifies
#     the session is still valid.  `hdx
#     auth logout` clears it
#   - NON-INTERACTIVE LOGIN — `hdx auth
#     login -e <email> -p <password> -a
#     <app-url>` for CI/scripting (skips
#     the interactive Ink prompt flow)
#   - RAW SQL ESCAPE HATCH — `hdx query
#     --connection-id <id> --sql '...'` runs
#     a raw SQL query against the chosen
#     ClickHouse connection.  Returns the
#     rows in tabular text (or JSON via
#     `--json`)
#   - DRAIN LOG PATTERN CLUSTERING — `hdx
#     query --patterns` post-processes the
#     SQL result rows through the DRAIN
#     algorithm (a hierarchical-template-
#     mining technique) and clusters them
#     into recurring log patterns.  Uses
#     `@hyperdx/common-utils/drain.
#     TemplateMiner` internally
#   - SOURCEMAP UPLOAD — `hdx upload-source
#     maps` walks a directory (typically
#     `.next/` or `dist/`) and uploads
#     every `.js.map` to HyperDX so that
#     errored stack traces in
#     production resolve to source-level
#     locations.  `HYPERDX_SERVICE_KEY`
#     env var avoids putting the API key
#     on the command line
#   - JSON OUTPUT EVERYWHERE — every list-
#     style subcommand (`sources`,
#     `connections`, `dashboards`, `team
#     list`, `team current`) supports
#     `--json` for programmatic
#     consumption (jq pipelines, CI gates)
#   - BUN COMPILE TARGETS — the package
#     ships `compile:linux`, `compile:macos`,
#     `compile:macos-x64` scripts that
#     produce statically-linked Bun-
#     compiled binaries.  Distribution
#     option for users without npm
#
# CRITICAL DIRECT DEPENDENCIES (from
# packages/cli/package.json):
#   - @clickhouse/client ^1.12.1
#                              — Node.js
#                                ClickHouse
#                                client
#                                [AXIS 53 LIBRARY]
#   - @clickhouse/client-common ^1.12.1
#                              — shared
#                                protocol
#                                helpers
#   - @hyperdx/common-utils ^0.20
#                              — shared
#                                HyperDX
#                                utilities
#                                (incl.
#                                Drain
#                                TemplateMiner)
#   - commander ^12.1          — CLI parser
#   - ink 6.8                  — React-for-
#                                terminals
#                                (TUI
#                                renderer)
#   - ink-text-input ^6.0      — text-input
#                                widget
#   - ink-spinner ^5.0         — loading
#                                spinner
#   - react ^19.0              — React core
#                                (for Ink)
#   - chalk ^5.3               — terminal
#                                colour
#   - crypto-js ^4.2           — client-
#                                side
#                                token
#                                crypto
#   - sqlstring ^2.3           — SQL value
#                                escaping
#   - glob ^13.0               — sourcemap
#                                directory
#                                walk
#   - react-devtools-core ^7.0 — Ink dev
#                                tools
#                                support
#
# Node 22.16.0+ MSRV (or Bun 1.3.11) per
# `package.json.engines`.
#
# UPSTREAM:
#   * Source             : https://github.com/hyperdxio/hyperdx
#   * CLI subdir         : https://github.com/hyperdxio/hyperdx/tree/main/packages/cli
#   * HyperDX docs       : https://www.hyperdx.io/docs
#   * @clickhouse/client : https://github.com/ClickHouse/clickhouse-js
#   * Drain algorithm    : https://github.com/logpai/Drain3
#   * License            : MIT
#   * Maintainer         : HyperDX Inc
#
# INSTALL:
#   # Global npm install
#   npm install -g @hyperdx/cli
#
#   # Or npx
#   npx -p @hyperdx/cli hdx [COMMAND]
#
#   # Bun-compiled standalone binary
#   # (download from GitHub releases)
#   # https://github.com/hyperdxio/hyperdx/releases
#
# USAGE EXAMPLES:
#
#   # Interactive login (Ink TUI flow)
#   hdx auth login
#
#   # Non-interactive login (CI-friendly)
#   hdx auth login \
#       -a https://app.hyperdx.io \
#       -e me@example.com \
#       -p 'sup3r-s3cr3t!'
#
#   # Show auth status
#   hdx auth status
#
#   # Logout
#   hdx auth logout
#
#   # Interactive TUI for event search + live
#   # tail
#   hdx tui
#
#   # TUI starting with a Lucene query +
#   # follow mode
#   hdx tui -q 'level:error AND service:web' -f
#
#   # TUI for a specific source (skip picker)
#   hdx tui --source 'production-logs'
#
#   # List teams + show active team
#   hdx team list
#   hdx team current
#
#   # Switch active team
#   hdx team use 'platform-engineering'
#   hdx team use t_abc123
#
#   # List data sources with ClickHouse
#   # schemas
#   hdx sources
#   hdx sources --json | jq '.[] | .name'
#
#   # List ClickHouse connections
#   hdx connections
#   hdx connections --json
#
#   # List dashboards
#   hdx dashboards
#
#   # Run raw SQL
#   hdx query \
#       --connection-id <id> \
#       --sql 'SELECT count() FROM logs WHERE level=\"error\"'
#
#   # Run SQL + cluster results into Drain
#   # log patterns
#   hdx query \
#       --connection-id <id> \
#       --sql 'SELECT body FROM logs LIMIT 10000' \
#       --patterns
#
#   # Upload sourcemaps (CI build step)
#   hdx upload-sourcemaps \
#       --serviceKey "$HYPERDX_SERVICE_KEY" \
#       --apiUrl https://api.hyperdx.io \
#       --path .next \
#       --releaseId "$GIT_SHA"
#
#   # Sourcemap upload with env var
#   HYPERDX_SERVICE_KEY="$KEY" \
#       hdx upload-sourcemaps --path dist
#
#   # Help (commander default)
#   hdx --help
#   hdx help <command>
#   hdx <command> --help
#
# OPTIONS (sourced directly from
# https://github.com/hyperdxio/hyperdx/blob/main/packages/cli/src/cli.tsx commander program):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _hdx_commands
_hdx_commands=(
    'tui:Interactive TUI for event search and tail'
    'auth:Manage authentication (login/logout/status)'
    'team:Manage active team (kubectx-style switching)'
    'sources:List data sources (log/trace/session/metric) with ClickHouse table schemas'
    'connections:List ClickHouse connections (id, name, host)'
    'dashboards:List dashboards with tile summaries'
    'query:Run raw SQL against a ClickHouse connection (optionally cluster via Drain patterns)'
    'upload-sourcemaps:Upload JavaScript source maps for stack-trace de-obfuscation'
    'help:Print help for a command'
)

local -a _hdx_auth_actions
_hdx_auth_actions=(
    'login:Sign in to your HyperDX account'
    'logout:Log out from your HyperDX account'
    'status:Show authentication status'
)

local -a _hdx_team_actions
_hdx_team_actions=(
    'list:List all teams the authenticated user belongs to'
    'current:Show the currently active team'
    'use:Switch the active team by name or ID'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'hdx command' _hdx_commands && ret=0
        ;;
    args)
        case $line[1] in
            tui)
                _arguments \
                    '(- *)'{-h,--help}'[show help for tui]' \
                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                    '(-q --query)'{-q+,--query=}'[initial Lucene search query]:query: ' \
                    '--source=[source name (skips picker)]:source: ' \
                    '(-f --follow)'{-f,--follow}'[start in follow/live-tail mode]' \
                    && ret=0
                ;;
            auth)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for auth]' \
                    '1::action:->aaction' \
                    '*:: :->aargs' \
                    && ret=0
                case $state in
                    aaction)
                        _describe -t actions 'auth action' _hdx_auth_actions && ret=0 ;;
                    aargs)
                        case $line[1] in
                            login)
                                _arguments \
                                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                                    '(-e --email)'{-e+,--email=}'[email address]:email: ' \
                                    '(-p --password)'{-p+,--password=}'[password]:password: ' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            team)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for team]' \
                    '1::action:->taction' \
                    '*:: :->targs' \
                    && ret=0
                case $state in
                    taction)
                        _describe -t actions 'team action' _hdx_team_actions && ret=0 ;;
                    targs)
                        case $line[1] in
                            list|current)
                                _arguments \
                                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                                    '--json[output as JSON]' \
                                    && ret=0 ;;
                            use)
                                _arguments \
                                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                                    '1:name-or-id:' \
                                    && ret=0 ;;
                        esac
                        ;;
                esac
                ;;
            sources|connections|dashboards)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                    '--json[output as JSON]' \
                    && ret=0
                ;;
            query)
                _arguments \
                    '(- *)'{-h,--help}'[show help for query]' \
                    '(-a --app-url)'{-a+,--app-url=}'[HyperDX app URL]:url: ' \
                    '--connection-id=[ClickHouse connection ID (required)]:id: ' \
                    '--sql=[SQL query to execute (required)]:sql: ' \
                    '--patterns[cluster results into Drain log patterns]' \
                    '--json[output as JSON]' \
                    && ret=0
                ;;
            upload-sourcemaps)
                _arguments \
                    '(- *)'{-h,--help}'[show help for upload-sourcemaps]' \
                    '(-k --serviceKey)'{-k+,--serviceKey=}'[HyperDX service account API key (or HYPERDX_SERVICE_KEY env)]:key: ' \
                    '(-p --path)'{-p+,--path=}'[directory containing sourcemaps (default .)]:dir:_files -/' \
                    '(-u --apiUrl)'{-u+,--apiUrl=}'[HyperDX API URL (required for self-hosted)]:url: ' \
                    '(-rid --releaseId)'{-rid+,--releaseId=}'[release ID to associate with the sourcemaps]:id: ' \
                    '(-bp --basePath)'{-bp+,--basePath=}'[base path for the uploaded sourcemaps]:path: ' \
                    && ret=0
                ;;
            help)
                _arguments \
                    '1:command:->helpcmd' \
                    && ret=0
                case $state in
                    helpcmd)
                        _describe -t commands 'hdx command' _hdx_commands && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
