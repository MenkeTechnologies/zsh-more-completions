#compdef tkregister2
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/TkRegister2Guide
# tkregister2 - view and edit a registration between two volumes

local ret=1

_arguments -s -S \
  '--mov[movable volume]:file:_files' \
  '--targ[target volume]:file:_files' \
  '--reg[input/output registration file]:file:_files' \
  '--s[set subject id]:subject:' \
  '--sd[use dir as SUBJECTS_DIR]:dir:_files -/' \
  '--surf[load a surface for visual inspection]:surf:' \
  '--regheader[compute registration from headers]' \
  '--fstarg[target is a FreeSurfer volume]' \
  '--fslregout[output FSL-style registration matrix]:file:_files' \
  '--noedit[do not open edit window (for conversions)]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
