#compdef solomon
# Documentation: https://www.ccp4.ac.uk/html/solomon.html
# CCP4: solvent flipping density modification

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'MAPIN[input electron density map]:map:_files -g "*.(map|ccp4)"' \
  'MAPOUT[output modified density map]:map:_files' \
  'RMSMAP[output local standard deviation map]:map:_files' \
  '*:keyword:(SLVFRC RADIUS MULSOLV TRUNC SLVMASK SLVDENS PTOS EXTRUDE MSKIN TRANS CSYM ASMASK VERBOSE END)' && ret=0

return ret
