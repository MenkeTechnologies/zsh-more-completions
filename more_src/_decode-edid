#compdef decode-edid
# Documentation: i2c-tools decode-edid
# Source: i2c-tools eeprom/decode-edid (master) — decode EDID EEPROM data (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1::I2C bus:_default' \
    '2::EEPROM address (default 0x50):_default' \
    && ret=0

return ret
