#compdef fork
# Documentation: https://man.archlinux.org/search?q=fork
# Reference accessed: 2026-05-16
# Source: https://github.com/zoppo/zoppo/blob/0a776afa36e24ec15dd249066abe6425da043b73/lib/functions/_fork
# Repository: zoppo/zoppo (lib/functions/_fork)

setopt localoptions extended_glob
local environ e cmd cpp
local -a _comp_priv_prefix
local -A opt_args
zstyle -a ":completion:${curcontext}:" environ environ
for e in "${environ[@]}"
do
    local -x "$e"
done
cmd="$words[1]"
cpp='_comp_priv_prefix=(
    $cmd -n
    ${(kv)opt_args[@]}
)'

_arguments -s -S "(-)1: :{ $cpp; _command_names -e }" "*:: :{ $cpp; _normal }"

