#compdef dotnet-counters

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'collect:periodically collect counters and export'
  'monitor:live refreshing display of counters'
  'ps:list dotnet processes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-counters subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (collect|monitor)
        _arguments \
          '(-p --process-id)'{-p,--process-id=}'[process id]:pid:' \
          '(-n --name)'{-n,--name=}'[process name]:name:' \
          '--diagnostic-port=[diagnostic port address]:port:' \
          '--refresh-interval=[refresh interval seconds]:secs:' \
          '--counters=[counters spec]:counters:' \
          '--format=[output format]:format:(csv json)' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
