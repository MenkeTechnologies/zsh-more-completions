#compdef iota
# Documentation: https://docs.iota.org/references/cli
# iota - IOTA Rebased command-line interface (Move/Sui-style)

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'client:client for interacting with the IOTA network'
  'keytool:IOTA keystore tool'
  'validator:tool for validators and validator candidates'
  'move:build and test Move applications'
  'name:manage names registered in IOTA-Names'
  'console:start the IOTA console'
  'start:start a local IOTA network'
  'genesis:create the genesis configuration'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'iota command' sub && ret=0 ;;
  args)
    case $words[1] in
      client) _arguments '1:client cmd:(active-address active-env addresses balance call chain-identifier dynamic-field envs faucet gas new-address new-env object objects pay pay-all-iota pay-iota merge-coin split-coin ptb publish upgrade switch transfer transaction-block verify-source verify-bytecode-meter)' && ret=0 ;;
      move) _arguments '1:move cmd:(build test new coverage disassemble prove manage-package migrate)' && ret=0 ;;
      keytool) _arguments '1:keytool cmd:(generate import export list show sign convert decode-or-verify-tx zk-login-sign-and-execute-tx)' && ret=0 ;;
    esac
    ;;
esac

return ret
