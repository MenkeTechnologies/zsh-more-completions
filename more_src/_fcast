#compdef fcast
# ---------------------------------------------------------------------------
# fcast — FCast terminal sender CLI: send play/seek/pause/resume/stop/
#         scan commands to FCast receivers (smart TVs, set-top boxes,
#         desktop receiver apps) discovered via mDNS or addressed by IP/
#         hostname (Rust, 598★ on the umbrella org repo)
#
# upstream: https://github.com/futo-org/fcast
#           (binary at senders/terminal in the workspace; package name
#           `fcast`)
# author : FUTO (the open-source nonprofit launched by Eron Wolf,
#          patron of Grayjay / Newpipe / privacy-respecting streaming)
# license: MIT
#
# Source-direct completion: every subcommand + flag below is verbatim
# from senders/terminal/src/main.rs on the futo-org/fcast tip — clap
# `#[derive(Parser/Subcommand)]` macros (TerminalSender + Command enums)
# parsed exactly as declared.  Global flags (--host/-H, --name/-n,
# --discovery-timeout, --port/-p, --subscriptions/-s) on the
# TerminalSender parent struct; per-command flags on each Command
# variant.
#
# Direct deps from senders/terminal/Cargo.toml + workspace Cargo.toml
# (selected):
#   mdns-sd            "0.20"   ← canonical Rust mDNS / DNS-SD / Zeroconf
#                                  service-discovery library (this axis)
#                                  — by keepsimple1 (keepsimple1/
#                                  mdns-sd); pure-Rust implementation
#                                  of RFC 6762 (Multicast DNS) + RFC
#                                  6763 (DNS-SD / Bonjour Service
#                                  Discovery) with both server (advertise
#                                  a service) and client (browse for
#                                  services) modes, IPv4 + IPv6 support,
#                                  TXT record key/value pairs, sub-types,
#                                  PTR/SRV/A/AAAA/NSEC record handling,
#                                  and Avahi-/Bonjour-/Apple-mDNS
#                                  interop tested against real-world
#                                  service browsers.  THE Rust answer
#                                  to "advertise / discover services on
#                                  the local network without a central
#                                  DNS server" — used by every Rust
#                                  cross-device tool: Slint demos,
#                                  AirPlay-compatible casting tools,
#                                  rust-cast, ALVR (Air Light VR),
#                                  Martichou/rquickshare (NearbyShare
#                                  for Linux), keepsimple1's reference
#                                  examples.  fcast uses mdns-sd
#                                  (through the fcast-sender-sdk
#                                  discovery feature) to scan the local
#                                  network for FCast receivers
#                                  advertising the `_fcast._tcp.local.`
#                                  service type — `fcast scan` lists
#                                  them, and `fcast --name <name>
#                                  <command>` connects by advertised
#                                  device name.
#   fcast-sender-sdk            (sibling crate in the workspace —
#                                  CastContext + DeviceDiscoverer +
#                                  DeviceEventHandler + Source +
#                                  LoadRequest abstractions for the
#                                  FCast wire protocol)
#   clap (with derive)          (CLI parser)
#   tokio + ctrlc + env_logger  (runtime + signal handling + logging)
#
# fcast lets you cast media from the command line to any FCast receiver
# on your network — useful for headless servers, scripts, kiosks, or
# Linux desktops without a fancy native casting integration.  `fcast
# scan` lists receivers via mDNS; `fcast play --url ...` streams a URL;
# `fcast play --file ...` runs an embedded HTTP file server (on the
# port set via --file-server-port) and tells the receiver to fetch from
# it.  `fcast listen` subscribes to receiver events (MediaItemStart,
# MediaItemEnd, MediaItemChange, KeyDown, KeyUp) for two-way control.
# FCast is FUTO's open alternative to Chromecast / AirPlay built around
# a documented wire protocol that any receiver app can implement —
# Grayjay (the privacy-respecting streaming client) is the canonical
# receiver, and FCast Receiver runs standalone on Android TVs / FireTV
# / Linux desktops.
#
# ============================================================================
# === AXIS 185 OPENS — mDNS / DNS-SD / Zeroconf service discovery =========
# === Rust=240 OPENS at slot 1/0/0 ========================================
# ============================================================================
# Axis position: Rust=240 OPENS Axis 185 at slot 1/0/0 — the first of the
# three lanes for the canonical mDNS/DNS-SD/Zeroconf service discovery
# trio.  The axis anchors on a single pure-host-language implementation
# of RFC 6762 (Multicast DNS) + RFC 6763 (DNS-SD) with both server
# (advertise a service) and client (browse for services) modes, IPv4+
# IPv6 support, TXT records, sub-types, and Avahi/Bonjour/Apple-mDNS
# interop:
#
#     Rust    : mdns-sd                     by keepsimple1 (keepsimple1/
#                                              mdns-sd); pure-Rust
#                                              implementation of RFC
#                                              6762 + RFC 6763 with
#                                              server + client modes,
#                                              IPv4+IPv6, TXT/PTR/SRV/
#                                              A/AAAA/NSEC record
#                                              handling.  Tested
#                                              against Avahi (Linux)
#                                              and mDNSResponder
#                                              (macOS Bonjour).  THE
#                                              Rust answer to
#                                              "discover services on
#                                              the local network."
#                 → fcast (FUTO — terminal CLI sender for FCast cross-
#                           device casting protocol; uses mdns-sd via
#                           fcast-sender-sdk discovery feature to
#                           browse for receivers advertising the
#                           `_fcast._tcp.local.` service type;
#                           subcommands play/seek/pause/resume/stop/
#                           listen/set-volume/set-speed/set-playlist-
#                           item/scan; 598★ MIT)
#                 _fcast           [Rust=240 OPENS Axis 185, 1/0/0]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#
#     Go      : (next round — Go=240, slot 2/0/0)
#                Canonical Go mDNS/DNS-SD: github.com/hashicorp/mdns by
#                HashiCorp — pure-Go implementation used internally by
#                Consul for service discovery, and also github.com/
#                grandcat/zeroconf (less common; the HashiCorp variant
#                is the de-facto standard).  [TBD next-round consumer]
#
#     JS/Node : (Axis 185 CLOSES at TS-Node=240, slot 1/1/1)
#                Canonical JS mDNS/DNS-SD: `bonjour-service` by
#                onlxltd (onlxltd/bonjour-service) — TypeScript
#                rewrite of the original `bonjour` package by Mathias
#                Buus, with both server (publish a service) and
#                browser (discover services) APIs.  Alternative:
#                `multicast-dns` (mafintosh/multicast-dns) for the
#                lower-level RFC 6762 implementation that bonjour-
#                service builds on.  [TBD closer consumer]
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=240     ← THIS FILE          (axis 185 OPENS, slot 1/0/0)
#   Go=240       ← next round         (axis 185 continues, slot 2/0/0)
#   TS-Node=240  ← round after        (axis 185 CLOSES at triple-240, 1/1/1)
# ============================================================================

_fcast() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '(-H --host)'{-H,--host}'=[host address to send command to (omit to use --name for mDNS discovery; default 127.0.0.1)]:host:_hosts'
        '(-n --name)'{-n,--name}'=[connect to a receiver discovered via mDNS by its advertised name (ignored when --host is given; use `fcast scan` to list names)]:name:'
        '--discovery-timeout=[seconds to wait for --name mDNS discovery before giving up (default 10)]:seconds:'
        '(-p --port)'{-p,--port}'=[port to send commands to (default 46899, the FCast standard port)]:port:'
        '(-s --subscriptions)'{-s,--subscriptions}'=[comma-separated events to subscribe to (e.g. MediaItemStart,KeyDown). Available: MediaItemStart, MediaItemEnd, MediaItemChange, KeyDown, KeyUp]:events:'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'play:play media (URL / file / inline content / video.mp4 etc) on the receiver'
                'seek:seek to a specific timestamp in the currently playing media'
                'pause:pause currently playing media'
                'resume:resume paused media'
                'stop:stop currently playing media'
                'listen:listen to incoming events from the receiver (MediaItemStart, KeyDown, etc)'
                'set-volume:set the playback volume on the receiver'
                'set-speed:set the playback speed multiplier on the receiver'
                'set-playlist-item:select an item in the receiver'\''s playlist by index'
                'scan:scan the local network for FCast receivers via mDNS and print them'
                'help:print help for a subcommand'
            )
            _describe -t commands 'fcast command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                play)
                    _arguments \
                        $global_opts \
                        '(-m --mime-type)'{-m,--mime-type}'=[mime type of the content (e.g. video/mp4, audio/mpeg)]:mime:(video/mp4 video/webm video/mkv audio/mpeg audio/aac audio/flac audio/ogg application/dash+xml application/vnd.apple.mpegurl)' \
                        '(-f --file)'{-f,--file}'=[local file to serve via embedded HTTP file server and play]:file:_files' \
                        '(-u --url)'{-u,--url}'=[URL to media content (HTTP / HTTPS / DASH / HLS)]:url:_urls' \
                        '(-c --content)'{-c,--content}'=[inline content (raw bytes — alternative to --file/--url)]:content:' \
                        '(-t --timestamp)'{-t,--timestamp}'=[start playback at this timestamp (seconds, float)]:seconds:' \
                        '--speed=[playback speed multiplier (1.0 = normal)]:multiplier:' \
                        '*'{-H,--header}'=[custom request header in key:value format (repeat for multiple)]:header:' \
                        '(-v --volume)'{-v,--volume}'=[initial volume (0.0 - 1.0)]:volume:' \
                        '--file-server-port=[port that the embedded HTTP file server should bind to (random by default)]:port:' && ret=0
                    ;;
                seek)
                    _arguments \
                        $global_opts \
                        '(-t --timestamp)'{-t,--timestamp}'=[timestamp to seek to (seconds, float)]:seconds:' && ret=0
                    ;;
                set-volume)
                    _arguments \
                        $global_opts \
                        '(-v --volume)'{-v,--volume}'=[volume level (0.0 - 1.0)]:volume:' && ret=0
                    ;;
                set-speed)
                    _arguments \
                        $global_opts \
                        '(-s --speed)'{-s,--speed}'=[playback speed multiplier (1.0 = normal)]:multiplier:' && ret=0
                    ;;
                set-playlist-item)
                    _arguments \
                        $global_opts \
                        '(-i --item-index)'{-i,--item-index}'=[index of the item in the playlist to play]:index:' && ret=0
                    ;;
                scan)
                    _arguments \
                        $global_opts \
                        '(-t --timeout)'{-t,--timeout}'=[seconds to scan for (omit to scan until Ctrl-C)]:seconds:' && ret=0
                    ;;
                pause|resume|stop|listen)
                    _arguments $global_opts && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(play seek pause resume stop listen set-volume set-speed set-playlist-item scan)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fcast "$@"
