#compdef stu
# Documentation: https://github.com/lusingander/stu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-r --region)'{-r+,--region=}'[AWS region]:region:' \
  '(-e --endpoint-url)'{-e+,--endpoint-url=}'[AWS endpoint URL]:url:' \
  '(-p --profile)'{-p+,--profile=}'[AWS profile name]:profile:' \
  '(-b --bucket)'{-b+,--bucket=}'[target bucket name]:bucket:' \
  '(-P --prefix)'{-P+,--prefix=}'[object key prefix]:prefix:' \
  '--path-style=[path style type]:type:(auto always never)' \
  '--no-sign-request[disable request signing]' \
  '--debug[enable debug logging]' && ret=0

return ret
