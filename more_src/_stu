#compdef stu

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-r+[AWS region]:region:' \
  '--region=[AWS region]:region:' \
  '-e+[endpoint URL]:url:' \
  '--endpoint-url=[endpoint URL]:url:' \
  '-p+[AWS profile]:profile:' \
  '--profile=[AWS profile]:profile:' \
  '-b+[initial bucket name]:bucket:' \
  '--bucket=[initial bucket name]:bucket:' \
  '--path-style[use path-style access]' \
  '--debug[enable debug logging]' && ret=0

return ret
