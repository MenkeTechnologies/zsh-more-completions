# Zsh completion for vifm - vi file manager

_arguments \
  '(- *)'{-h,--help}'[display command summary]' \
  '(- *)'{-v,--version}'[show version information]' \
  '--no-configs[skip reading vifmrc and vifminfo configuration files]' \
  '--select[open parent of given path and select file]:path:_files' \
  '-f[write selection to $VIFM/vimfiles and quit]' \
  '--choose-dir[write last visited directory to file]:file:_files' \
  '--choose-files[write selected files to file]:file:_files' \
  '--delimiter[set output separator for written paths]:delimiter:' \
  '--on-choose[command to run on chosen files]:command:' \
  '*-c[run command-line mode <command> on startup]:command:' \
  '--logging=-[log operational details (optional startup log path)]::file:_files' \
  '--server-list[list available server instances and exit]' \
  '--server-name[set target/instance server name]:name:' \
  '--remote[send the rest of the command line to another instance]' \
  '--remote-expr[evaluate expression in remote instance]:expression:' \
  '*--plugins-dir[additional plugin directory]:dir:_files -/' \
  '*+[run command-line mode <command> on startup]:command:' \
  '*:directory:_directories'
