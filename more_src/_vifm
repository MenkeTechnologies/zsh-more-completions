#compdef vifm

# Zsh completion for vifm - vi file manager

_arguments \
  '(-)--help[display help information]' \
  '(-)--version[display version information]' \
  '--no-configs[skip reading configuration files]' \
  '--select[select specified path]:path:_files' \
  '-f[start in file picker mode]' \
  '--choose-dir[write last visited directory to file]:file:_files' \
  '--choose-files[write selected files to file]:file:_files' \
  '--delimiter[set output delimiter]:delimiter' \
  '--on-choose[command to run on chosen files]:command' \
  '*-c[execute command on startup]:command' \
  '--logging[enable logging]' \
  '--server-list[list available server names]' \
  '--server-name[set server name]:name' \
  '--remote[send commands to existing instance]' \
  '--remote-expr[evaluate expression in remote instance]:expression' \
  '*+[execute command on startup]:command' \
  '*:directory:_directories'
