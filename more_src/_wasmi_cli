#compdef wasmi_cli
# Documentation: https://github.com/wasmi-labs/wasmi/blob/main/crates/cli/src/commands/run.rs
# wasmi CLI: efficient and versatile WebAssembly interpreter runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--dir=[host directory to pre-open for the guest to use]:dir:_files -/' \
  '*--tcplisten=[socket address provided to the module]:addr:' \
  '*--env=[environment variable pair made available for the program]:name=val:' \
  '--invoke=[function to invoke]:func:' \
  '--compilation-mode=[select wasmi mode of compilation]:mode:(eager lazy lazy-translation)' \
  '--fuel=[execution fuel metering with N units]:units:' \
  '--verbose[enable informational messages beyond warnings or errors]' \
  '*:wasm module and args:_files' && ret=0

return ret
