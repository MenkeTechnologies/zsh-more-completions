#compdef cockpit-ws
# Documentation: https://man.archlinux.org/search?q=cockpit-ws
# Reference accessed: 2026-05-16

# cockpit-ws: cockpit web service (HTTP/WebSocket endpoint)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '-p[listen port]:port:' \
  '--port=[listen port]:port:' \
  '-a[listen address]:address:' \
  '--address=[listen address]:address:' \
  '-D[do not daemonize]' \
  '--no-daemonize[do not daemonize]' \
  '--no-tls[disable TLS entirely]' \
  '--local-ssh[handle local SSH login fallback]' \
  '--local-session=[command for local session]:command:' \
  '--for-tls-proxy[expect cockpit-tls in front]' \
  '*::extra args:_files' && ret=0
return ret
