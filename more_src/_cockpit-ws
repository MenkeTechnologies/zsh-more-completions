#compdef cockpit-ws
# Documentation: https://cockpit-project.org/guide/latest/cockpit-ws.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cockpit-ws: cockpit web service (HTTP/WebSocket endpoint)

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--port=[serve HTTP on PORT instead of 9090]:port:' \
  '--address=[bind to a particular address]:address:' \
  '--no-tls[disable http to https redirection]' \
  '--for-tls-proxy[expect cockpit-tls in front (TLS termination)]' \
  '--local-ssh[authenticate via local SSH instead of cockpit-session/PAM]' \
  '--local-session=[skip auth and launch a local bridge (or - for stdio)]:command:' \
  '*::extra args:_files' && ret=0
return ret
