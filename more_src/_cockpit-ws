#compdef cockpit-ws

# cockpit-ws: Cockpit web server (front-end to cockpit-bridge)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--port=[listen port (default 9090)]:port:' \
  '--address=[bind address]:host:' \
  '--no-tls[disable HTTPS]' \
  '--local-ssh[direct local SSH login]' \
  '--for-tls-proxy[behind TLS-terminating proxy]' \
  '*::cockpit-ws args:_files' && ret=0
return ret
