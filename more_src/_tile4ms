#compdef tile4ms
# Documentation: https://mapserver.org/utilities/tile4ms.html
# Create a tile index shapefile for MapServer's TILEINDEX feature

local ret=1

_arguments -s \
  '1:meta-file (list of shapefile names):_files' \
  '2:tile-file (output shapefile of extent rectangles):_files' \
  '-tile-path-only[store only the path to the shapefiles in the LOCATION field]' && ret=0

return ret
