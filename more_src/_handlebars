#compdef handlebars
# Documentation: https://man.archlinux.org/search?q=handlebars
# Reference accessed: 2026-05-16

_arguments -s \
  '(-f --output)'{-f,--output}'=[output file]:file:_files' \
  '--map=[source map file]:file:_files' \
  '(-a --amd)'{-a,--amd}'[AMD style]' \
  '(-c --commonjs)'{-c,--commonjs}'=[CommonJS path]:path:' \
  '(-h --handlebarPath)'{-h,--handlebarPath}'=[handlebars.js path]:path:' \
  '*'{-k,--known}'=[known helper]:helper:' \
  '(-o --knownOnly)'{-o,--knownOnly}'[known only]' \
  '(-m --min)'{-m,--min}'[minimize]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace]:ns:' \
  '(-s --simple)'{-s,--simple}'[simple output]' \
  '(-N --name)'{-N,--name}'=[template name]:name:' \
  '*'{-i,--string}'=[template string]:str:' \
  '(-r --root)'{-r,--root}'=[root]:path:' \
  '(-p --partial)'{-p,--partial}'[partial template]' \
  '(-d --data)'{-d,--data}'[include data]' \
  '(-e --extension)'{-e,--extension}'=[extension]:ext:' \
  '(-b --bom)'{-b,--bom}'[remove BOM]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--help[show help]' \
  '*:template:_files'
