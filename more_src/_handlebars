#compdef handlebars
# Documentation: https://github.com/handlebars-lang/handlebars.js
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (bin/handlebars).

_arguments -s \
  '(-f --output)'{-f+,--output=}'[output file]:file:_files' \
  '--map=[source map file]:file:_files' \
  '(-a --amd)'{-a,--amd}'[exports AMD style (require.js)]' \
  '(-c --commonjs)'{-c+,--commonjs=}'[exports CommonJS, path to Handlebars module]:path:' \
  '(-h --handlebarPath)'{-h+,--handlebarPath=}'[path to handlebars.js (AMD-style only)]:path:' \
  '*'{-k+,--known=}'[known helper]:helper:' \
  '(-o --knownOnly)'{-o,--knownOnly}'[known helpers only]' \
  '(-m --min)'{-m,--min}'[minimize output]' \
  '(-n --namespace)'{-n+,--namespace=}'[template namespace]:ns:' \
  '(-s --simple)'{-s,--simple}'[output template function only]' \
  '(-N --name)'{-N+,--name=}'[name of passed string templates]:name:' \
  '*'{-i+,--string=}'[generate template from CLI argument (- for stdin)]:str:' \
  '(-r --root)'{-r+,--root=}'[template root stripped from names]:path:' \
  '(-p --partial)'{-p,--partial}'[compiling a partial template]' \
  '(-d --data)'{-d,--data}'[include data when compiling]' \
  '(-e --extension)'{-e+,--extension=}'[template extension]:ext:' \
  '(-b --bom)'{-b,--bom}'[remove BOM from template start]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--help[show help]' \
  '*:template:_files'
