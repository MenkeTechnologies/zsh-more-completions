#compdef faToTab
# convert fa file to tab separated file

local ret=1

_arguments -s -S \
  '-type=[sequence type, dna or protein (default dna)]:type:(dna protein)' \
  '-keepAccSuffix[do not strip dot version off sequence id]' \
  '1:in file:_files -g "*.(fa|fasta)"' \
  '2:out file:_files' && ret=0

return ret
