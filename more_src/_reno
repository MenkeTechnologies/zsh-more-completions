#compdef reno
# Documentation: https://docs.openstack.org/reno/latest/user/usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'new:create a new release note file'
  'list:list release notes'
  'report:generate a release notes report'
  'cache:produce a cache file from release notes'
  'lint:lint release notes for syntax errors'
  'linked-file-diff:check for changes that should bump a version'
  'semver-next:compute next semantic version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--rel-notes-dir=[release notes directory]:dir:_directories' \
  '1:subcommand:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'reno subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--edit[open new note in editor]' \
          '--from-template=[template file]:file:_files' \
          ':slug:' && ret=0
        ;;
      report)
        _arguments \
          '--branch=[git branch]:branch:' \
          '--version=[limit to version]:version:' \
          '--collapse-pre-releases[collapse pre-releases]' \
          '--no-collapse-pre-releases[do not collapse pre-releases]' \
          '--earliest-version=[earliest version]:version:' \
          '--stop-at-branch-base[stop scanning at branch base]' \
          '--no-stop-at-branch-base[do not stop at branch base]' \
          '--ignore-cache[bypass cache]' \
          '--title=[report title]:title:' \
          '--output=[output file]:file:_files' \
          ':repository:_directories' && ret=0
        ;;
      lint)
        _arguments ':repository:_directories' && ret=0
        ;;
      list)
        _arguments \
          '--branch=[git branch]:branch:' \
          '--version=[limit to version]:version:' \
          ':repository:_directories' && ret=0
        ;;
      cache)
        _arguments \
          '--branch=[git branch]:branch:' \
          '--output=[output cache file]:file:_files' \
          ':repository:_directories' && ret=0
        ;;
      semver-next|linked-file-diff)
        _arguments ':repository:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
