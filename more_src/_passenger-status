#compdef passenger-status
# Documentation: https://manpages.org/passenger-status/8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# passenger-status: query Phusion Passenger instance status
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--show=[output format]:type:(server xml pool requests)' \
  '--verbose[verbose output]' \
  '*:Passenger PID:' && ret=0
return ret
