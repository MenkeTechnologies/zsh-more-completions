#compdef es
# _es-shell — extensible shell (Paul Haahr, Byron Rakitzis); rc-syntax shell with first-class functions and lexical bindings
# upstream: https://github.com/wryun/es-shell

_es-shell() {
    _arguments \
        '-c+[command]:code:' \
        '-e[errexit]' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-n[parse only]' \
        '-p[paranoid mode]' \
        '-s[read from stdin]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '-d[debug]' \
        '-I[skip init]' \
        '-o+[option]:option:' \
        '*:script:_files'
}

_es-shell "$@"
