#compdef mob
# Documentation: https://github.com/remotemobprogramming/mob
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_mob_commands() {
  local -a commands=(
    'start:Start mob session'
    'next:Hand over to next person'
    'done:Complete mob session'
    'reset:Reset mob session'
    'clean:Remove all orphan wip branches'
    'status:Show mob session status'
    'fetch:Fetch remote changes'
    'branch:Show mob branch'
    'config:Show configuration'
    'timer:Start a timer'
    'break:Start a break timer'
    'goal:Display or manage timer room goal'
    'moo:Moo (easter egg)'
    'version:Print version'
    'help:Show help'
  )
  _describe -t commands 'mob command' commands
}

_mob() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '--debug[Enable verbose logging]' \
    '1:command:_mob_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start)
          _arguments \
            '(-i --include-uncommitted-changes)'{-i,--include-uncommitted-changes}'[Move uncommitted changes to wip branch]' \
            '(-d --discard-uncommitted-changes)'{-d,--discard-uncommitted-changes}'[Discard uncommitted changes]' \
            '(-b --branch)'{-b,--branch}'[Set custom wip branch postfix]:postfix:' \
            '(-c --create)'{-c,--create}'[Create the remote branch]' \
            '--room[Set timer room name]:room:' \
            '1:timer minutes:'
          ;;
        next)
          _arguments \
            '(-m --message)'{-m,--message}'[Override commit message]:message:' \
            '(-s --stay)'{-s,--stay}'[Stay on wip branch (default)]' \
            '(-r --return-to-base-branch)'{-r,--return-to-base-branch}'[Return to base branch]'
          ;;
        done)
          _arguments \
            '--no-squash[Squash no commits, only merge wip branch]' \
            '--squash[Squash all commits from wip branch]' \
            '--squash-wip[Squash wip commits, keep manual commits]'
          ;;
        reset)
          _arguments \
            '(-b --branch)'{-b,--branch}'[wip branch postfix]:postfix:'
          ;;
        goal)
          _arguments \
            '--delete[Delete the goal]' \
            '1:goal text:'
          ;;
        timer)
          _arguments '1:minutes:'
          ;;
        break)
          _arguments '1:minutes:'
          ;;
        clean)
          _arguments
          ;;
      esac
      ;;
  esac
}

_mob "$@"
