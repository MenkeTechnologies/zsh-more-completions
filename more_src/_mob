#compdef mob

_mob_commands() {
  local -a commands=(
    'start:Start mob session'
    'next:Hand over to next person'
    'done:Complete mob session'
    'reset:Reset mob session'
    'status:Show mob session status'
    'fetch:Fetch remote changes'
    'branch:Show mob branch'
    'config:Show configuration'
    'timer:Start a timer'
    'break:Start a break timer'
    'moo:Moo'
    'clean:Remove mob session branches'
    'version:Print version'
    'help:Show help'
  )
  _describe -t commands 'mob command' commands
}

_mob() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version]' \
    '1:command:_mob_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start)
          _arguments \
            '--include-uncommitted-changes[Include uncommitted changes]' \
            '--branch[Use custom branch name]:branch:' \
            '--create[Create the mob branch]' \
            '--room[Room name]:room:' \
            '1:timer minutes:'
          ;;
        next)
          _arguments \
            '--message[Commit message]:message:' \
            '--stay[Stay on mob branch]'
          ;;
        done)
          _arguments \
            '--no-squash[Do not squash commits]' \
            '--squash[Squash commits]' \
            '--squash-wip[Squash WIP commits only]' \
            '--message[Final commit message]:message:'
          ;;
        timer)
          _arguments '1:minutes:'
          ;;
        break)
          _arguments '1:minutes:'
          ;;
        clean)
          _arguments
          ;;
      esac
      ;;
  esac
}

_mob "$@"
