#compdef mongodb-readiness
# _mongodb-readiness — MongoDB Community Operator readiness probe (reads the agent status file and translates it into the readiness exit code used by the agent container)
# upstream: https://github.com/mongodb/mongodb-kubernetes-operator
# Source: cmd/readiness/main.go on tip; no CLI flags — runtime config is env-driven (HEADLESS_AGENT, AGENT_STATUS_FILEPATH, MONGODB_LOG_LEVEL).

_mongodb-readiness() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_mongodb-readiness "$@"
