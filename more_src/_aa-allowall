#compdef aa-allowall
# _aa-allowall — AppArmor aa-allowall (set every AppArmor profile in /etc/apparmor.d/ to permissive complain mode so an admin can audit-log all attempted denials before tightening to enforce; -d profile dir, --version, --help; positional argument is an optional profile name to limit the scope)
# upstream: https://gitlab.com/apparmor/apparmor
# Flags from apparmor/apparmor utils/aa-allowall on tip.

_aa-allowall() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[profile dir]:dir:_files -/' \
        '*:profile:_files -g "*.profile"'
}

_aa-allowall "$@"
