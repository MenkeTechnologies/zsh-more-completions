#compdef binvox2bt
# Documentation: https://github.com/OctoMap/octomap/blob/devel/octomap/src/binvox2bt.cpp
# Convert binvox voxel files into an OctoMap binary octree (.bt)

local ret=1

_arguments -s -S \
  '-o[output filename]:bt:_files -g "*.bt"' \
  '--mark-free[mark unoccupied cells as free rather than unknown]' \
  '--rotate[rotate left by 90 degrees for Webots exports]' \
  '--bb[force a specific bounding box]:minx miny minz maxx maxy maxz' \
  '--offset[apply a coordinate offset to final map data]:x y z' \
  '*:binvox:_files -g "*.binvox"' && ret=0

return ret
