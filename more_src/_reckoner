#compdef reckoner
# Documentation: https://man.archlinux.org/search?q=reckoner
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --run-all)'{-a,--run-all}'[install every release in the course file]' \
  '(-o --only)'{-o+,--only+}'[limit to these releases]:release:' \
  '--dry-run[delegate to helm dry-run mode]' \
  '--create-namespaces[allow namespace creation]' \
  '--no-color[disable ANSI colors]' \
  '*--helm-args=[extra helm arguments]:arg:' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      plot:'install or upgrade releases from the course'
      template:'render manifests without applying'
      diff:'compare desired manifests with cluster state'
      lint:'validate course schema'
      convert:'migrate a course file to the v2 schema'
      get-manifests:'dump live manifests referenced by the course'
      update:'install only when changes are detected'
      import:'print an import stanza for a legacy release'
      version:'print reckoner version'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    case $words[1] in
      convert)
        _arguments -s -S \
          '(-i --in-place)'{-i,--in-place}'[rewrite course file on disk]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:course file:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          '--namespace=[release namespace]:namespace' \
          '--release_name=[helm release]:release' \
          '--repository=[chart repository URL]:url' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      template)
        _arguments -s -S \
          '--output-dir=[write manifests under this directory]:dir:_directories' \
          '(- *)'{-h,--help}'[show help]' \
          '1:course file:_files' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--continue-on-error[keep processing releases after failures]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:course file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
