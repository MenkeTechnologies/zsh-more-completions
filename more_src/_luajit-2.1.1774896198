#compdef luajit-2.1.1774896198

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-e+[execute chunk]:chunk:' \
  '*-l+[require library]:lib:' \
  '*-b[save or list bytecode]' \
  '-j+[LuaJIT control command]:cmd:' \
  '-O+[control optimizations]:opt:' \
  '-i[enter interactive mode after script]' \
  '-v[show version information]' \
  '-E[ignore environment variables]' \
  '*:script:_files -g "*.lua"' && ret=0

return ret
