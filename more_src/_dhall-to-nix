#compdef dhall-to-nix
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-nix
# Source: dhall-lang/dhall-haskell dhall-nix/exec/Main.hs — compile Dhall to Nix.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
