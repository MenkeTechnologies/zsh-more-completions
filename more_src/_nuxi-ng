#compdef nuxi-ng
# Documentation: https://www.npmjs.com/package/@nuxt/cli
# Reference accessed: 2026-05-23
# Verified: npx nuxi-ng --help (@nuxt/cli bin).

# Zsh completion for nuxi-ng - Nuxt CLI (@nuxt/cli nuxi-ng bin)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add Nuxt modules'
  'add-template:create a new template file'
  'analyze:analyze production bundle'
  'build:build Nuxt for production'
  'cleanup:clean generated files and caches'
  'dev:run Nuxt development server'
  'devtools:enable or disable Nuxt devtools'
  'generate:build and prerender all routes'
  'info:get Nuxt project information'
  'init:initialize a fresh project'
  'module:manage Nuxt modules'
  'prepare:prepare Nuxt for development or build'
  'preview:launch Nitro server after build'
  'start:launch Nitro server after build'
  'test:run tests'
  'typecheck:run vue-tsc type checking'
  'upgrade:upgrade Nuxt'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--cwd=[working directory]:dir:_directories' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'nuxi-ng command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
