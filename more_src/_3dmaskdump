#compdef 3dmaskdump
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dmaskdump.html
# AFNI: dump dataset values within a mask to text

local ret=1

_arguments -s -S \
  '-mask[mask dataset; only nonzero voxels included]:dataset:_files' \
  '-mrange[restrict mask values to a range]:lower:' \
  '-index[write out dataset index values]' \
  '-noijk[omit i,j,k coordinate values]' \
  '-xyz[include x,y,z coords in RAI/DICOM order]' \
  '-o[output to file instead of stdout]:file:_files' \
  '-cmask[3dcalc-like computational mask]:expr:' \
  '-xbox[mask region in dataset mm coords]:coords:' \
  '-dbox[mask region in RAI/DICOM coords]:coords:' \
  '-nbox[mask region in LPI/SPM coords]:coords:' \
  '-ibox[mask region by voxel indices]:coords:' \
  '-xball[spherical mask at dataset coords]:coords:' \
  '-dball[spherical mask at RAI/DICOM coords]:coords:' \
  '-nball[spherical mask at LPI/SPM coords]:coords:' \
  '-nozero[skip output lines that are all zero]' \
  '-n_rand[randomly select a subset of voxels]:count:' \
  '-n_randseed[random seed]:seed:' \
  '-niml[output in XML/NIML format]:name:' \
  '-quiet[suppress progress messages]' \
  '*:dataset:_files' && ret=0

return ret
