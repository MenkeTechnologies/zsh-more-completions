#compdef plasmashell
# Documentation: https://linuxcommandlibrary.com/man/plasmashell
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --replace)'{-r,--replace}'[replace existing instance]' \
  '(-n --no-respawn)'{-n,--no-respawn}'[do not respawn on crash]' \
  '(-p --shell-plugin)'{-p,--shell-plugin}'+[force shell plugin]:plugin:(org.kde.plasma.desktop org.kde.plasma.mobile)' \
  '--standalone[run in standalone mode]' \
  '--test[run in test mode]' \
  '--no-fixed[allow custom geometry]' \
  '--no-respawn[do not respawn]' \
  '--display=[X display]:display:' && ret=0

return ret
