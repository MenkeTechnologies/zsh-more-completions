#compdef cargo-checkmate
# _cargo-checkmate — run the standard validation pipeline for a Rust crate (cargo-checkmate/cargo-checkmate)
# upstream: https://github.com/cargo-checkmate/cargo-checkmate
# Subcommands from src/options.rs, src/phase.rs, src/{githook,gh}.rs (clap).

_cargo-checkmate() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run validations (all phases if none given)'
                'list:list validation phases in order'
                'git-hook:git pre-commit hook management'
                'gh:GitHub CI workflow management'
                'readme:manage README badge'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run) _arguments '1:phase:(check format build test doc clippy)' ;;
                git-hook) _arguments '1:sub:(install uninstall run path print)' ;;
                gh) _arguments '1:sub:(install uninstall path print)' ;;
            esac
            ;;
    esac
}

_cargo-checkmate "$@"
