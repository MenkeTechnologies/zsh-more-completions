#compdef contentful

# Zsh completion for Contentful CLI

_contentful() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'login:log in to Contentful'
    'logout:log out from Contentful'
    'space:manage and interact with spaces'
    'content-type:interact with content types'
    'entry:interact with entries'
    'extension:manage UI extensions'
    'config:manage configuration'
    'merge:merge content types and editor interfaces'
    'migration:run migration scripts'
    'organization:manage organizations'
    'help:display help for a command'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'contentful command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        space)
          _arguments -s -S \
            '1:subcommand:(accesstoken alias create delete environment export generate import list migration seed use)' \
            '--space-id=[space ID]:space ID:' \
            '--management-token=[management API token]:token:' \
            && ret=0
          ;;
        content-type)
          _arguments -s -S \
            '1:subcommand:(get list)' \
            '--space-id=[space ID]:space ID:' \
            '--environment-id=[environment ID]:environment:' \
            '--management-token=[management API token]:token:' \
            && ret=0
          ;;
        migration)
          _arguments -s -S \
            '--space-id=[space ID]:space ID:' \
            '--environment-id=[environment ID]:environment:' \
            '--management-token=[management API token]:token:' \
            '--yes[skip confirmation]' \
            '1:migration file:_files -g "*.{js,ts}"' \
            && ret=0
          ;;
        config)
          _arguments -s -S \
            '1:subcommand:(add list remove)' \
            && ret=0
          ;;
        login)
          _arguments -s -S \
            '--management-token=[management API token]:token:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            '--version[display version]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_contentful "$@"
