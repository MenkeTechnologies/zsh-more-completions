#compdef @Install_NIH_Marmoset
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/@Install_NIH_Marmoset.html
# Download and install the NIH Marmoset template/atlas

local ret=1

_arguments -s \
  '(-wget -curl)-wget[use wget to download archive]' \
  '(-wget -curl)-curl[use curl to download archive]' \
  '-help[display usage information]' && ret=0

return ret
