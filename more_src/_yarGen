#compdef yarGen yarGen.py
# Documentation: https://github.com/Neo23x0/yarGen
# yarGen - YARA rule generator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-m[path to scan for malware]:directory:_directories' \
  '-y[minimum string length to consider]:length' \
  '-z[minimum score to consider]:score' \
  '-x[score for highly specific string]:score' \
  '-w[minimum string overlap for super rules]:count' \
  '-s[maximum string length to consider]:length' \
  '-rc[maximum number of strings per rule]:count' \
  '--excludegood[force exclude all goodware strings]' \
  '-o[output file for rules]:file:_files' \
  '-e[output directory for string exports]:directory:_directories' \
  '-a[author name]:author' \
  '-r[reference string or text file]:reference' \
  '-l[license specification]:license' \
  '-p[prefix for rule description]:prefix' \
  '-b[text file to read identifier from]:file:_files' \
  '--score[show string scores as comments]' \
  '--strings[show strings in export file]' \
  '--nosimple[skip simple rule creation]' \
  '--nomagic[do not include magic header condition]' \
  '--nofilesize[do not include filesize condition]' \
  '-fm[filesize condition multiplier]:multiplier' \
  '--globalrule[create global rules]' \
  '--nosuper[do not create super rules]' \
  '--update[update local databases from online]' \
  '-g[path to scan for goodware]:directory:_directories' \
  '-u[update local goodware database]' \
  '-c[create new local goodware database]' \
  '-i[identifier for new databases]:identifier' \
  '--dropzone[monitor directory for new samples]' \
  '--nr[do not recursively scan directories]' \
  '--oe[only scan executable extensions]' \
  '-fs[max file size to analyze in MB]:size' \
  '--noextras[do not use Imphash or PE headers]' \
  '--debug[debug output mode]' \
  '--trace[trace output mode]' \
  '--opcodes[use the OpCode feature]' \
  '-n[number of opcodes to add]:num' \
  '--ai[generate AI-tailored rules]' && ret=0

return ret
