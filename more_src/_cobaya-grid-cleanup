#compdef cobaya-grid-cleanup
# Documentation: https://cobaya.readthedocs.io/en/latest/grids.html
# cobaya: delete output files from a grid

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dist[only affect getdist output files]' \
  '*--ext=[file extensions to delete]:extension' \
  '--empty[only remove empty files]' \
  '--confirm[actually delete the files]' \
  '--chainnum=[specific chain number]:number' \
  '1:grid directory:_files -/' && ret=0

return ret
