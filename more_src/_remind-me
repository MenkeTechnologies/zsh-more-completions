_remind-me() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'me:create a reminder with natural-language time (e.g., "remind me in two hours to take a break")'
        'list:list all upcoming reminders and their times'
        'cancel:delete a reminder by id (NOT YET IMPLEMENTED upstream)'
        'edit:open ~/.remind-me/reminders.json in $EDITOR'
        'config:open ~/.remind-me/config.json in $EDITOR'
        'sweep:internal sweep / maintenance command'
    )

    _arguments -C \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'remind-me command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                me)
                    # Free-form natural-language input parsed by chrono-node
                    _message 'reminder text (chrono-node natural-language input, e.g., "to take a break in 2 hours")' && ret=0
                    ;;
                cancel)
                    _message 'reminder id (cancel NOT YET IMPLEMENTED upstream — use `remind edit`)' && ret=0
                    ;;
                list|edit|config|sweep)
                    ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_remind-me "$@"
