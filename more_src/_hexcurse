#compdef hexcurse
# Documentation: https://man.archlinux.org/search?q=hexcurse
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r[open file readonly]' \
  '-d[decimal mode]' \
  '-o[octal mode]' \
  '-x[hexadecimal mode]' \
  '*:file:_files' && ret=0

return ret
