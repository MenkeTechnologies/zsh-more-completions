#compdef hexcurse
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/hexcurse.1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,-help}'[show help]' \
  '-a[display addresses in decimal initially]' \
  '-r[bytes per line]:rnum:' \
  '-o[output file]:file:_files' \
  '-i[input file]:file:_files' \
  '*:file:_files' && ret=0

return ret
