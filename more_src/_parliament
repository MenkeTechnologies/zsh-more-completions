#compdef parliament

# Zsh completion for parliament - AWS IAM linting

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--string=[IAM policy as a string]:policy string' \
  '--file=[IAM policy file]:file:_files -g "*.json"' \
  '--directory=[directory of IAM policy files]:directory:_directories' \
  '--include_community_auditors[include community auditors]' \
  '--private[run private auditors only]' \
  '--minimum_severity=[minimum severity to report]:severity:(INFO LOW MEDIUM HIGH CRITICAL)' \
  '--json[output in JSON format]' \
  '--config=[config file]:config:_files -g "*.{yml,yaml,json}"' \
  && ret=0

return ret
