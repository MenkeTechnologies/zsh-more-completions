#compdef argo
# _argo-workflows — Argo Workflows argo CLI (Kubernetes-native workflow engine; subcommands: submit, lint, list, get, describe, logs, retry, terminate, stop, suspend, resume, watch, delete, archive, cron, template, completion, cluster-template, executor-plugin; --namespace, --kubeconfig, --context, --token, --certificate-authority, --serviceaccount; -p parameter, -f file)
# upstream: https://github.com/argoproj/argo-workflows
# Subcommands from argoproj/argo-workflows cmd/argo on tip.

_argo-workflows() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--context+[kube context]:context:' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--token+[bearer token]:token:' \
        '--certificate-authority+[CA file]:file:_files' \
        '--serviceaccount+[service account]:sa:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--user+[user]:user:_users' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'argo command' '(submit lint list ls get describe logs retry terminate stop suspend resume watch delete archive cron template completion cluster-template executor-plugin version help)' ;;
        args)
            case $line[1] in
                submit|lint) _arguments '*-f+[file]:file:_files -g "*.(yml|yaml)"' '*-p+[parameter]:KEY=VALUE:' '--watch[watch]' '--wait[wait]' '--dry-run[dry run]' '*:file:_files -g "*.(yml|yaml)"' ;;
                cron|template|cluster-template|archive) _describe -t commands 'subcommand' '(list get create delete suspend resume update lint)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_argo-workflows "$@"
