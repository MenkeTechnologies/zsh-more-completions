#compdef bubblewrap-cli bwrap-cli
# _bubblewrap-cli — Flatpak Project bubblewrap-cli bwrap-cli CLI alternative wrapper around bwrap the unprivileged sandboxing tool used by Flatpak underpinning sandbox-app runtime container low-level user-namespace mount-namespace network-namespace pid-namespace creation file-bind setuid-helper sandbox-setup utility (Flatpak team, C); getopt
# upstream: https://github.com/containers/bubblewrap

_bubblewrap-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--args=+[fd]:n:' \
        '--unshare-all[unshare all namespaces]' \
        '--unshare-user[unshare user]' \
        '--unshare-ipc[unshare IPC]' \
        '--unshare-pid[unshare PID]' \
        '--unshare-net[unshare network]' \
        '--unshare-uts[unshare UTS]' \
        '--unshare-cgroup[unshare cgroup]' \
        '--share-net[share network]' \
        '--uid=+[uid]:n:' \
        '--gid=+[gid]:n:' \
        '--hostname=+[name]:str:' \
        '--chdir=+[dir]:dir:_files -/' \
        '--setenv=+[var=value]:str:' \
        '--unsetenv=+[var]:str:' \
        '--ro-bind=+[src dst]:str:' \
        '--bind=+[src dst]:str:' \
        '--bind-try=+[src dst]:str:' \
        '--dev-bind=+[src dst]:str:' \
        '--remount-ro=+[dst]:str:' \
        '--proc=+[dst]:dir:_files -/' \
        '--dev=+[dst]:dir:_files -/' \
        '--tmpfs=+[dst]:dir:_files -/' \
        '--mqueue=+[dst]:dir:_files -/' \
        '--dir=+[dst]:dir:_files -/' \
        '--file=+[fd dst]:str:' \
        '--bind-data=+[fd dst]:str:' \
        '--ro-bind-data=+[fd dst]:str:' \
        '--symlink=+[src dst]:str:' \
        '--exec-label=+[label]:str:' \
        '--file-label=+[label]:str:' \
        '--die-with-parent[die with parent]' \
        '--as-pid-1[become PID 1]' \
        '--info-fd=+[fd]:n:' \
        '--json-status-fd=+[fd]:n:' \
        '--block-fd=+[fd]:n:' \
        '--userns-block-fd=+[fd]:n:' \
        '--seccomp=+[fd]:n:' \
        '--cap-add=+[cap]:str:' \
        '--cap-drop=+[cap]:str:' \
        '--clearenv[clear environment]' \
        '*::'
}

_bubblewrap-cli "$@"
