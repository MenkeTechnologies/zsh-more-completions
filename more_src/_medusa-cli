#compdef medusa-cli medusa2
# _medusa-cli — JoMo-Kun Foofus Networks medusa-cli CLI parallel multi-protocol network login brute-force tool modular architecture supporting AFP CVS FTP HTTP IMAP MS-SQL MySQL NCP NNTP PCAnywhere POP3 PostgreSQL rexec rlogin rsh SMB SMTP SNMP SSHv2 SVN Telnet VMauthd VNC web-form (Foofus team, C); getopt
# upstream: https://foofus.net/goons/jmk/medusa/medusa.html

_medusa-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[show all modules]' \
        '-h+[target host]:_hosts' \
        '-H+[host list]:file:_files' \
        '-u+[user]:str:' \
        '-U+[user list]:file:_files' \
        '-p+[password]:str:' \
        '-P+[password list]:file:_files' \
        '-C+[combo file user:pass]:file:_files' \
        '-O+[output file]:file:_files' \
        '-e+[empty/single mode]:m:(n s ns)' \
        '-M+[module name]:m:(afp cvs ftp http imap mssql mysql ncp nntp pcanywhere pop3 postgres rexec rlogin rsh smbnt smtp-auth smtp-vrfy snmp ssh svn telnet vmauthd vnc web-form wrapper)' \
        '-m+[module-args]:str:' \
        '-n+[port]:n:' \
        '-s[SSL]' \
        '-g+[timeout sec]:n:' \
        '-r+[retry time sec]:n:' \
        '-R+[retries]:n:' \
        '-t+[threads per host]:n:' \
        '-T+[hosts in parallel]:n:' \
        '-L[parallel users per pass]' \
        '-f[stop after first success]' \
        '-F[stop after success per host]' \
        '-b[no banner]' \
        '-q[show module-args quote]' \
        '-v+[verbosity]:l:(0 1 2 3 4 5 6)' \
        '-w+[error verbosity]:l:(0 1 2 3 4 5 6)' \
        '-Z+[resume hostid:userid:passid]:str:' \
        '-c+[combo separator]:str:' \
        '*::'
}

_medusa-cli "$@"
