#compdef claude-squad
# Documentation: https://github.com/smtg-ai/claude-squad
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-y --autoyes)'{-y,--autoyes}'[automatically accept prompts (experimental)]' \
  '(-p --program)'{-p,--program}'=[program to run in new instances]:program' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    local -a commands
    commands=(
      'completion:Generate shell completion script'
      'debug:Print debug information'
      'help:Show help'
      'reset:Reset all stored instances'
      'version:Print version'
    )
    _describe -t commands 'claude-squad command' commands && ret=0
    ;;
  rest)
    case $line[1] in
      completion) _values 'shell' bash zsh fish powershell && ret=0 ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
