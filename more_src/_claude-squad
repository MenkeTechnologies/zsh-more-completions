#compdef claude-squad

# smtg-ai/claude-squad (Node/oclif-like); Homebrew: Formula/c/claude-squad.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'claude-squad command' compadd -- start stop list attach fork status reset
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
