#compdef btrfs
# _btrfs-progs — btrfs filesystem administration; subvolumes, snapshots, balance, scrub, send/receive
# upstream: https://github.com/kdave/btrfs-progs

_btrfs-progs() {
    local -a sub=(
        'subvolume:subvolume operations'
        'filesystem:fs-level operations'
        'balance:run/pause/cancel/status balance'
        'device:device operations'
        'scrub:run scrub'
        'check:check fs (offline)'
        'rescue:rescue ops'
        'restore:restore from broken fs'
        'inspect-internal:internal info'
        'property:get/set properties'
        'send:send incremental snapshot stream'
        'receive:receive snapshot stream'
        'quota:quota operations'
        'qgroup:qgroup ops'
        'replace:replace device'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--format+[output format]:format:(text json)' \
        '--full[full output]' \
        '--log+[log level]:level:(default quiet verbose debug)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'btrfs subcommand' sub ;;
        args)
            case $words[1] in
                subvolume) _arguments '1:subvol cmd:(create delete list show snapshot find-new get-default set-default sync find-orphan)' '*:path:_files -/' ;;
                filesystem) _arguments '1:fs cmd:(df show usage sync defragment resize label mkswapfile)' '*:path:_files -/' ;;
                balance) _arguments '1:balance cmd:(start pause cancel resume status)' '*:path:_files -/' ;;
                device) _arguments '1:device cmd:(add remove delete scan ready stats usage)' '*:path:_files' ;;
                scrub) _arguments '1:scrub cmd:(start cancel resume status)' '*:path:_files -/' ;;
            esac
            ;;
    esac
}

_btrfs-progs "$@"
