#compdef dox
# ============================================================================
#  _dox — dox: Haxe documentation generator (official HaxeFoundation tool)
#
#  Source-direct extraction from
#    https://github.com/HaxeFoundation/dox/blob/master/src/dox/Dox.hx
#    https://github.com/Simn/hxargs (the hxargs library by Simon
#    Krajewski, Haxe Foundation core developer)
#
#  Maintained by HaxeFoundation (HaxeFoundation/dox).  153 GH stars.
#  dox is THE OFFICIAL HAXE DOCUMENTATION GENERATOR — every Haxe
#  library published to lib.haxe.org has its auto-generated docs
#  built by dox.  Reads XML output from `haxe -xml` (RTTI/reflection
#  type information dumped by the Haxe compiler), generates HTML
#  documentation with cross-linked types, themes, markdown rendering,
#  and search.  Sister tools: rust-docs (Rust), godoc (Go),
#  hexdocs (Elixir, IN CORPUS), pkgdown (R, IN CORPUS), sphinx
#  (Python, IN CORPUS), TypeDoc (TypeScript), JSDoc, Doxygen
#  (C/C++, IN CORPUS), Javadoc (Java).
#
#  CLI library taxonomy update: 1st Haxe entry — Simon Krajewski's
#  **hxargs** library (Simn/hxargs).  Haxe is a FIRST-TIME addition
#  to the cross-language CLI library taxonomy.
#
#  hxargs (Simn/hxargs) is "a really small command line parser" by
#  Simon Krajewski — Haxe Foundation core developer and lead Haxe
#  compiler author.  Distributed as a Haxelib package (`haxelib
#  install hxargs`).  Used by `dox` (official Haxe docs generator),
#  `dts2hx` (TypeScript .d.ts → Haxe externs converter, 143 stars),
#  `dtshxe haxe-formatter` (78 stars), `hxgithub` (HaxeFoundation),
#  `RoadmapExporter`, `vshaxe-build` (VS Code Haxe extension build),
#  `DashDox`, `hx-minifier`, `hxbuilds`, `flatbuffers-haxe` compiler,
#  `wtri`, `GPUText`, `archillect-search`, and many official Haxe
#  Foundation tooling repos.  hxargs is the **idiomatic Haxe CLI
#  library** in the Haxe Foundation ecosystem.
#
#  hxargs API:
#    var argHandler = hxargs.Args.generate([
#      @doc("Output file")
#      ["-o", "--output"] => function(path:String) {
#        config.output = path;
#      },
#
#      @doc("Verbose output")
#      ["-v", "--verbose"] => function() {
#        config.verbose = true;
#      },
#
#      @doc("Number of threads")
#      ["-j", "--jobs"] => function(n:Int) {
#        config.jobs = n;
#      },
#
#      @doc("Repository specifier (owner + name)")
#      ["-r", "--repository"] => function(owner:String, name:String) {
#        config.repoOwner = owner;
#        config.repoName = name;
#      },
#
#      @doc("Key=value defines")
#      ["-D", "--define"] => function(key:String, value:String) {
#        config.defines[key] = value;
#      },
#
#      @doc("Help")
#      ["-h", "--help"] => function() {
#        Sys.println(argHandler.getDoc());
#        Sys.exit(0);
#      },
#
#      _ => function(arg:String) throw "Unknown command: " + arg
#    ]);
#
#    argHandler.parse(args);
#
#  hxargs distinctive features:
#    - HAXE MACRO-GENERATED PARSER — `hxargs.Args.generate([...])` is
#      a Haxe BUILD MACRO that inspects the array literal AT COMPILE
#      TIME and generates a typed parser function from the entries
#    - HAXE `=>` FAT-ARROW SYNTAX for KEY-VALUE MAPPING — `["-o",
#      "--output"] => function(path:String) { ... }` binds the
#      key array (short + long aliases) to a callback function
#    - SHORT + LONG aliases as a SINGLE HAXE ARRAY LITERAL `["-o",
#      "--output"]` — allows arbitrary number of aliases per option
#      (e.g. `["-i", "--input", "--in", "--src"]`)
#    - CALLBACK PARAMETER TYPES determine VALUE PARSING — Haxe
#      static typing inspects the callback signature:
#      `function():Void` → no-value flag (boolean toggle)
#      `function(s:String):Void` → string value
#      `function(n:Int):Void` → integer with parsing
#      `function(f:Float):Void` → float with parsing
#      `function(a:T1, b:T2):Void` → MULTI-VALUE option (consumes N
#                                    args; classic `-r OWNER NAME`)
#    - `@doc("...")` HAXE METADATA ANNOTATION on each entry — provides
#      auto-generated help text; `argHandler.getDoc()` returns the
#      compiled doc string
#    - CATCHALL via `_ => function(arg:String) ...` — special `_`
#      key matches ANY unknown argument; callback receives the
#      unmatched arg as String (caller decides to throw, ignore,
#      or accumulate)
#    - `argHandler.parse(args)` — entry point taking `Array<String>`
#      (typically `Sys.args()`)
#    - `argHandler.getDoc()` — returns FORMATTED help string from
#      compiled `@doc` annotations
#    - COMPILE-TIME TYPE SAFETY — invalid type coercion (e.g. passing
#      "foo" to `function(n:Int)`) is caught at the boundary; Haxe
#      compiler enforces the callback signature shape
#    - NO global state — each `hxargs.Args.generate` call produces
#      an independent parser
#    - NO automatic --help injection — caller defines `--help` as
#      an entry that calls `getDoc()`
#    - NO automatic --version injection — caller defines manually
#    - NO subcommand support — caller hand-rolls subcommand dispatch
#      (typical pattern: dispatch on `args[0]` to multiple Args.generate
#      handlers)
#  Distinct from R272 C POSIX getopt (low-level char-by-char), R382
#  GNU argp (struct argp_option array + parser callback), R277 picocli
#  (Java annotations), R275 Rust clap-derive (struct + macros), R270
#  Haskell optparse-applicative (applicative combinators), R368
#  PowerShell `param()` block (language feature), R381 Crystal Cling
#  (class inheritance), R346 Scala mainargs (method annotations).
#  hxargs's approach: HAXE BUILD MACRO + `=>` FAT-ARROW KEY-VALUE
#  MAPPING + SHORT+LONG aliases as ARRAY LITERAL + CALLBACK PARAMETER
#  TYPES drive VALUE PARSING (Haxe static typing) + `@doc` METADATA
#  ANNOTATION + `_` CATCHALL for unknown args + `argHandler.parse()` +
#  `argHandler.getDoc()` + COMPILE-TIME TYPE SAFETY — corpus's
#  **first documented Haxe-macro-with-fat-arrow-callback CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 122;
#  Haxe added to the documented-CLI-language set.
#
#  Surface (verbatim from `src/dox/Dox.hx` argHandler entries):
#
#  Options:
#    -o, --output-path PATH         Output path for generated pages
#                                   (directory or a .zip file)
#    -i, --input-path PATH          Set the xml input path (file names
#                                   correspond to platform names)
#    -t, --template-path PATH       Add template directory
#    -res, --resource-path DIR      Add a resource directory whose
#                                   contents are copied to the output
#    -in, --include REGEX           Add a path include filter
#    -ex, --exclude REGEX           Add a path exclude filter
#    --title TITLE                  Set the page main title
#    --toplevel-package PACKAGE     Set the package which serves as
#                                   top-level
#    --no-markdown                  Disable markdown rendering
#    --include-private              Include private fields and types
#    --keep-field-order             Don't sort fields alphabetically
#    -theme NAME_OR_PATH            Set the theme name or path
#    -D, --define KEY VALUE         Set define (MULTI-VALUE: takes 2
#                                   args via Haxe multi-param callback)
#    -help, --help                  Display this list of options
#
#  Available defines for the default theme (-D KEY VALUE):
#    version <version>              Version shown on default index.html
#    source-path <url>              Base URL used for 'View Source'
#                                   buttons
#    themeColor <color>             Background color of header/footer
#                                   (default 0xFAFAFA)
#    textColor <color>              Text color of header/footer
#    website <url>                  URL to website for logo and footer
#    logo <path>                    Path to logo image for the header
#    description <text>             Paragraph at landing page /
#                                   toplevel package view
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Haxe-based or hxargs users):
#    - haxe / haxelib (BOTH IN CORPUS — Haxe compiler + package
#      manager; haxe uses its own hand-rolled arg parsing in OCaml,
#      not hxargs; haxelib uses simple imperative parsing)
#    - lix (IN CORPUS via _lix — alternative Haxe package manager)
#    - dts2hx (haxiomic/dts2hx 143 stars — TypeScript .d.ts → Haxe
#      externs converter, FUTURE candidate)
#    - haxe-formatter (HaxeCheckstyle 78 stars — Haxe code formatter,
#      smaller community than dox)
#    - hx-minifier (markknol 5 stars — niche)
#    - hxfetch (bwkam 0 stars — early-stage)
#    - pman (DavisDevelopment 35 stars — desktop media player, uses
#      different ArgParser library not hxargs)
#    - Helm (MattTuttle 3 stars — Haxe package manager; BLACKLISTED
#      conflict with Kubernetes Helm)
# ============================================================================

_dox() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-o --output-path)'{-o,--output-path}'=[output path (dir or .zip)]:path:_files' \
    '(-i --input-path)'{-i,--input-path}'=[xml input path]:path:_files' \
    '*'{-t,--template-path}'=[add template directory]:dir:_directories' \
    '*'{-res,--resource-path}'=[add resource directory (copied to output)]:dir:_directories' \
    '*'{-in,--include}'=[add path include filter (regex)]:regex' \
    '*'{-ex,--exclude}'=[add path exclude filter (regex)]:regex' \
    '--title=[page main title]:title' \
    '--toplevel-package=[top-level package]:package' \
    '--no-markdown[disable markdown rendering]' \
    '--include-private[include private fields and types]' \
    '--keep-field-order[do not sort fields alphabetically]' \
    '-theme=[theme name or path]:theme' \
    '*'{-D,--define}'=[set define KEY VALUE]:key:->define_key' \
    '(-help --help)'{-help,--help}'[display this list of options]'

  case $state in
    define_key)
      local -a defines=(
        'version:version shown on default index.html'
        'source-path:base URL for View Source buttons'
        'themeColor:header/footer background (default 0xFAFAFA)'
        'textColor:header/footer text color'
        'website:URL to website for logo and footer'
        'logo:path to logo image for header'
        'description:paragraph at landing page'
      )
      _describe -t defines 'theme define' defines
      ;;
  esac
}

_dox "$@"
