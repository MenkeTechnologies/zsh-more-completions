#compdef hcledit

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--update[Apply updates to defaults]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      block:'filter blocks'
      attribute:'filter attributes'
      fmt:'format HCL'
      version:'print version'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
