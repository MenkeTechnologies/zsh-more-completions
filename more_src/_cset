#compdef cset
# cpuset management utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'set:manage cpusets'
  'proc:manage processes in cpusets'
  'shield:set up CPU shielding'
)

_arguments -s -S \
  '1:command:->command' \
  '-l[list cpusets]' \
  '-m[machine readable output]' \
  '-x[extended output]' \
  '-v[verbose output]' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:argument:' && ret=0

case $state in
  (command)
    _describe -t commands 'cset command' commands && ret=0
    ;;
esac

return ret
