#compdef gfal-ls

# gfal-ls: list directory via GFAL
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  "-l[long listing]" "--long[long listing]" "-a[show hidden]" "--all[show hidden]" "-d[directory entries only]" "-X[show extended attrs]" "--xattr[show extended attrs]" \\\n   \
  '--config-file=[config file]:file:_files' \
  '--cert=[user cert]:file:_files' \
  '--key=[user key]:file:_files' \
  '*:URL:_files' && ret=0
return ret
