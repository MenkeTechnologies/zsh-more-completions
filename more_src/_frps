#compdef frps

# Zsh completion for frp server (Fast Reverse Proxy)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[config file path]:config:_files -g "*.{toml,ini,yaml,yml,json}"' \
  '--bind-addr=[bind address]:address' \
  '--bind-port=[bind port]:port' \
  '--kcp-bind-port=[KCP bind port]:port' \
  '--proxy-bind-addr=[proxy bind address]:address' \
  '--vhost-http-port=[vhost HTTP port]:port' \
  '--vhost-https-port=[vhost HTTPS port]:port' \
  '--dashboard-addr=[dashboard address]:address' \
  '--dashboard-port=[dashboard port]:port' \
  '--dashboard-user=[dashboard user]:user' \
  '--dashboard-pwd=[dashboard password]:password' \
  '--log-file=[log file]:file:_files' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--log-max-days=[max log days]:days' \
  '--token=[auth token]:token' \
  '--max-pool-count=[max pool count]:count' \
  '--max-ports-per-client=[max ports per client]:count' \
  '--subdomain-host=[subdomain host]:host' \
  '--tls-only[only accept TLS connections]' \
  '--strict-config[exit on unknown fields in config]' && ret=0

return ret
