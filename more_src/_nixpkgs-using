#compdef nixpkgs-using

# https://github.com/uncenter/nixpkgs-using — flake package ↔ nixpkgs PR cross-check

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --flake)'{-f,--flake}'=[path to flake to evaluate]:flake:_files' \
  '(-c --configuration)'{-c,--configuration}'=[nixdarwin/home-manager configuration attr]:config:' \
  '(-u --username)'{-u,--username}'=[username for Home Manager package detection]:user:_users' \
  '--json[JSON output]' \
  '1: :_nixpkgs_using_cmds' \
  '*:: :->args' && ret=0

_nixpkgs_using_cmds() {
  local -a cmds=(
    'list:list packages detected from the flake'
    'prs:list nixpkgs pull requests touching those packages'
  )
  _describe -t commands 'nixpkgs-using command' cmds
}

case $state in
  args)
    case $words[1] in
      list)
        _message -e 'no extra arguments for list' && ret=0
        ;;
      prs)
        _arguments -s -S \
          '(-t --token)'{-t,--token}'=[GitHub API token]:token:' \
          '(-r --repository)'{-r,--repository}'=[owner/repo for PR queries]:repo:' \
          '--new[only PRs newer than last cached run]' \
          '--updates[only PR titles that look like version bumps]' && ret=0
        ;;
    esac
    ;;
esac

return ret
