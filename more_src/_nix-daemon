#compdef nix-daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--daemon[run as daemon]' \
  '--stdio[use stdio instead of socket]' \
  '--force-trusted[force trusted user mode]' \
  '--default-trust=[default trust level]:level:(trusted untrusted)' && ret=0

return ret
