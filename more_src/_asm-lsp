#compdef asm-lsp
# Documentation: https://man.archlinux.org/search?q=asm-lsp
# Reference accessed: 2026-05-16

# Zsh completion for asm-lsp (Assembly language LSP server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--stdio[use stdio transport for LSP communication]' && ret=0

return ret
