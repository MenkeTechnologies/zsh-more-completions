#compdef lms
# Documentation: https://lmstudio.ai/docs/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_lms() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '(-h --help)'{-h,--help}'[Display help for the command]'
        '(-v --version)'{-v,--version}'[Show the version and exit]'
    )

    subcmds=(
        'status:Prints the current status of LM Studio and the server'
        'ls:Lists all models downloaded to your local disk'
        'ps:Lists models currently loaded into memory'
        'get:Search for and download models from Hugging Face'
        'load:Loads a specific model into memory'
        'unload:Unloads a model from memory'
        'chat:Starts an interactive chat session in the terminal'
        'create:Create a new project with LM Studio SDK'
        'import:Import a model file'
        'server:Commands to start, stop, or check the local API server'
        'log:Streams logs to inspect raw LLM inputs/outputs'
        'daemon:Manage the LM Studio headless daemon'
        'runtime:Manage and update the inference runtime'
        'link:Manage LM Link device connections'
        'clone:Clone artifacts from LM Studio Hub'
        'dev:Start the plugin development server'
        'push:Upload artifacts to LM Studio Hub'
        'login:Authenticate with LM Studio'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'lms commands' subcmds
            ;;
        args)
            case $line[1] in
                load)
                    _arguments \
                        '--gpu=[Set GPU offload percentage]:gpu:(max auto)' \
                        '--context-length=[Set the context window size]:length:' \
                        '--identifier=[Assign a custom alias to the model]:name:' \
                        '--ttl=[Time-to-live in seconds]:seconds:' \
                        '-y[Skip confirmation prompts]'
                    ;;
                unload)
                    _arguments \
                        '--all[Unload every model currently in memory]'
                    ;;
                chat)
                    _arguments \
                        '(-p --prompt)'{-p,--prompt}'[Send a one-off prompt and exit]:prompt:' \
                        '(-s --system-prompt)'{-s,--system-prompt}'[Set a custom system instruction]:text:' \
                        '--stats[Display token usage and prediction speed]' \
                        '--ttl=[Seconds to keep model loaded after chat ends]:seconds:'
                    ;;
                server)
                    local -a server_subcmds
                    server_subcmds=(
                        'start:Start the local API server'
                        'stop:Stop the local API server'
                        'status:Check the server status'
                    )
                    _describe -t commands 'server subcommands' server_subcmds
                    ;;
                get)
                    _arguments \
                        '--mlx[Filter search results by MLX model format]' \
                        '--gguf[Filter search results by GGUF model format]' \
                        '(-n --limit)'{-n,--limit}'=[Limit the number of search results shown]:number:' \
                        '--always-show-all-results[Show all search options even with exact matches]' \
                        '(-a --always-show-download-options)'{-a,--always-show-download-options}'[Prompt for quantization selection]'
                    ;;
                ls)
                    _arguments \
                        '--json[Output the list of local models in JSON format]'
                    ;;
            esac
            ;;
    esac
}

_lms "$@"
