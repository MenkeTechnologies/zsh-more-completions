#compdef youki

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--log-format=[set log format]:format:(text json)' \
  '--root-path=[set root path]:path:_directories' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'create:create a container'
      'start:start a created container'
      'run:create and start a container'
      'delete:delete a container'
      'state:show container state'
      'kill:send a signal to a container'
      'spec:generate a default OCI spec'
      'pause:pause a running container'
      'resume:resume a paused container'
      'exec:execute a process in a running container'
      'list:list containers'
      'ps:show processes running in a container'
      'events:display container events'
      'update:update container resource limits'
      'features:show enabled features'
      'info:show system information'
      'completion:generate shell completions'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      create)
        _arguments -s -S \
          '--bundle=[path to OCI bundle]:bundle:_directories' \
          '--console-socket=[path to console socket]:socket:_files' \
          '--pid-file=[path to write container PID]:pid file:_files' \
          '--no-pivot[do not use pivot_root]' \
          '--preserve-fds=[number of fds to preserve]:count' \
          '1:container id' && ret=0
        ;;
      start)
        _arguments '1:container id' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--bundle=[path to OCI bundle]:bundle:_directories' \
          '--console-socket=[path to console socket]:socket:_files' \
          '--pid-file=[path to write container PID]:pid file:_files' \
          '--no-pivot[do not use pivot_root]' \
          '--preserve-fds=[number of fds to preserve]:count' \
          '1:container id' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[force deletion]' \
          '1:container id' && ret=0
        ;;
      kill)
        _arguments -s -S \
          '--all[send signal to all processes in container]' \
          '1:container id' \
          '2:signal:(SIGTERM SIGKILL SIGHUP SIGINT SIGUSR1 SIGUSR2 SIGSTOP SIGCONT)' && ret=0
        ;;
      exec)
        _arguments -s -S \
          '--console-socket=[path to console socket]:socket:_files' \
          '--pid-file=[path to write process PID]:pid file:_files' \
          '--cwd=[working directory]:directory:_directories' \
          '--user=[user in format uid\:gid]:user' \
          '--tty[allocate a pseudo-TTY]' \
          '--env=[set environment variable]:VAR=VALUE' \
          '--process=[path to process.json]:process json:_files' \
          '--detach[detach from the process]' \
          '--preserve-fds=[number of fds to preserve]:count' \
          '1:container id' \
          '*:command:_command_names -e' && ret=0
        ;;
      list)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(table json)' \
          '(-q --quiet)'{-q,--quiet}'[only show container IDs]' && ret=0
        ;;
      update)
        _arguments -s -S \
          '--blkio-weight=[block IO weight]:weight' \
          '--cpu-period=[CPU CFS period in us]:period' \
          '--cpu-quota=[CPU CFS quota in us]:quota' \
          '--cpu-share=[CPU share]:share' \
          '--cpuset-cpus=[CPU set]:cpus' \
          '--cpuset-mems=[memory set]:mems' \
          '--memory=[memory limit]:limit' \
          '--memory-swap=[memory+swap limit]:limit' \
          '--memory-reservation=[memory reservation]:limit' \
          '--pids-limit=[PID limit]:limit' \
          '1:container id' && ret=0
        ;;
    esac
    ;;
esac

return ret
