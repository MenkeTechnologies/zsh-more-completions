#compdef cbm
# Documentation: https://man.archlinux.org/search?q=cbm
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-i+[refresh interval ms]:ms:' \
  '-c[disable colors]' \
  '-b+[show bits as Mb/s]:flag:' \
  '-B+[show bytes as MB/s]:flag:' && ret=0

return ret
