#compdef cbm
# Documentation: https://github.com/resurrecting-open-source-projects/cbm
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Connection Bandwidth Monitor (resurrecting-open-source-projects/cbm).
# cbm(1) documents only --help and --version; runtime keys (q, +, -, etc.)
# are handled inside the curses UI, not as CLI flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show version and exit]' \
  && ret=0

return ret
