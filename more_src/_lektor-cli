#compdef lektor-cli lektor
# _lektor-cli — Armin Ronacher Lektor static content management system CLI alias (lektor team, Python); click
# upstream: https://github.com/lektor/lektor

_lektor-cli() {
    local -a sub=(
        'build:build the project'
        'clean:remove build artifacts'
        'content-file-info:show info about a content file'
        'deploy:deploy the website'
        'dev:command-group:developer commands'
        'dev:browser-test:open page in browser'
        'dev:list-pages:list page paths'
        'dev:new-plugin:scaffold a new plugin'
        'dev:new-theme:scaffold a new theme'
        'dev:publish-plugin:publish a plugin'
        'dev:shell:open a python shell'
        'dev:trans-tool:translation tooling'
        'plugins:add:add a plugin'
        'plugins:flush-cache:flush plugin cache'
        'plugins:list:list installed plugins'
        'plugins:reinstall:reinstall plugins'
        'plugins:remove:remove a plugin'
        'project-info:show project info'
        'quickstart:create a new project'
        'server:run development server'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--language=+[language]:l:(en de fr)' \
        '--project=+[project path]:dir:_files -/' \
        '-p+[project path]:dir:_files -/' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lektor subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--output-path=+[output]:dir:_files -/' \
                    '-O+[output]:dir:_files -/' \
                    '--watch[watch for changes]' \
                    '--prune[prune unused files]' \
                    '--no-prune[do not prune]' \
                    '--profile[profile build]' \
                    '--source-info-only[only source info]' \
                    '--buildstate-path=+[buildstate dir]:dir:_files -/' \
                    '-e+[buildstate dir]:dir:_files -/' \
                    '--extra-flag=+[flag]:str:' \
                    '-f+[flag]:str:' \
                    '--concurrency=+[concurrency]:n:' ;;
                server) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '-h+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--no-prune[no prune]' \
                    '--prune[prune]' \
                    '--no-watcher[disable watcher]' \
                    '--output-path=+[output]:dir:_files -/' \
                    '-O+[output]:dir:_files -/' \
                    '--extra-flag=+[flag]:str:' \
                    '-f+[flag]:str:' \
                    '--browse[open in browser]' ;;
                deploy) _arguments \
                    '1:target name:' \
                    '--username=+[username]:user:_users' \
                    '-u+[username]:user:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--key-file=+[ssh key]:file:_files' \
                    '-K+[ssh key]:file:_files' \
                    '--key=+[ssh key contents]:str:' \
                    '-k+[ssh key contents]:str:' \
                    '--extra-flag=+[flag]:str:' \
                    '-f+[flag]:str:' ;;
                quickstart) _arguments \
                    '--name=+[name]:str:' \
                    '--path=+[path]:dir:_files -/' ;;
                plugins:add|plugins:remove) _arguments '1:plugin:' ;;
            esac
            ;;
    esac
}

_lektor-cli "$@"
