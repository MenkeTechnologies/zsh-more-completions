#compdef cobjnew cobjnew-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/cobjnew.sh wraps `uobjnew.py -l c "$@"`)
# Reference accessed: 2026-05-29
# cobjnew — bash wrapper that pins `uobjnew -l c` for C-only allocation tracing (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

# Inherits uobjnew flag set MINUS -l/--language (hardcoded to "c" upstream).
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --top-count)'{-C,--top-count=}'[number of most frequently allocated types to print]:N:' \
  '(-S --top-size)'{-S,--top-size=}'[number of largest types by allocated bytes to print]:N:' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  '2:interval (seconds, optional):' \
  && ret=0

return ret
