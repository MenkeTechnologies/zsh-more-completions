#compdef create-vite-extra
# Documentation: https://github.com/bluwy/create-vite-extra#readme
# Scaffold extra Vite SSR/Deno/library templates

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --template)'{-t,--template}'[use a specific template]:template:(ssr-vanilla ssr-vanilla-ts ssr-vue ssr-vue-ts ssr-vue-streaming ssr-vue-streaming-ts ssr-react ssr-react-ts ssr-react-streaming ssr-react-streaming-ts ssr-react-compiler ssr-react-compiler-ts ssr-react-compiler-streaming-ts ssr-preact ssr-preact-ts ssr-svelte ssr-svelte-ts deno-vanilla deno-vanilla-ts deno-vue deno-vue-ts deno-react deno-react-ts deno-preact deno-preact-ts deno-lit deno-lit-ts deno-svelte deno-svelte-ts library library-ts ssr-transform)' \
  '--overwrite[remove existing files if target directory is not empty]' \
  '(-i --immediate)'{-i,--immediate}'[scaffold immediately without prompts]' \
  '--interactive[force interactive prompts]' \
  '*:target directory:_files -/' && ret=0

return ret
