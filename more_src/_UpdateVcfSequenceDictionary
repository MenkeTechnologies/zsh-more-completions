#compdef UpdateVcfSequenceDictionary
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#UpdateVcfSequenceDictionary
# Picard: replace the sequence dictionary in a VCF header

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[input VCF]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[output VCF to be written]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-SD=,--SEQUENCE_DICTIONARY=}'[sequence dictionary source (SAM/BAM/VCF/BCF/IntervalList/Fasta/Dict)]:dict:_files' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
