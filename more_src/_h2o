#compdef h2o

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --conf)'{-c,--conf}'=[config file]:config:_files -g "*.conf"' \
  '(-m --mode)'{-m,--mode}'=[running mode]:mode:(worker master daemon test)' \
  '-t[test configuration]' \
  '*:config file:_files' && ret=0

return ret
