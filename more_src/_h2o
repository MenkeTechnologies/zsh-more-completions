#compdef h2o
# Documentation: https://h2o.examp1e.net/configure/command_options.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --conf)'{-c+,--conf=}'[config file]:config:_files -g "*.conf"' \
  '(-m --mode)'{-m+,--mode=}'[running mode]:mode:(worker master daemon test)' \
  '(-t --test)'{-t,--test}'[test configuration (alias for --mode=test)]' && ret=0

return ret
