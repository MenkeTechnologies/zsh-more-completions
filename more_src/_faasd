#compdef faasd
# Documentation: https://man.archlinux.org/search?q=faasd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:start the OpenFaaS faasd providers'
  'provider:run as the OpenFaaS provider'
  'install:install systemd units (legacy)'
  'collect:collect functions for inspection'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'faasd command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (up)
        _arguments \
          '--file=[docker-compose YAML]:file:_files -g "*.{yaml,yml}"' \
          '--working-dir=[working directory]:dir:_files -/' && ret=0 ;;
      (provider)
        _arguments \
          '--pull-policy=[image pull policy]:policy:(IfNotPresent Always Never)' && ret=0 ;;
      (install)
        _arguments \
          '--working-dir=[working directory]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
