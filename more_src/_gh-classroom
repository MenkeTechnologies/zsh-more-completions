#compdef gh-classroom
# Documentation: https://docs.github.com/en/education/manage-coursework-with-github-classroom/teach-with-github-classroom/using-github-classroom-with-github-cli
# gh-classroom - GitHub CLI extension for GitHub Classroom

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:(list view assignments assignment accepted-assignments clone)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      clone)
        _arguments -s -S \
          '1:target:(starter-repo student-repos)' \
          '--directory=[directory to clone into]:directory:_files -/' \
          '(-a --assignment-id)'{-a,--assignment-id}'=[assignment id]:id:' \
          '--page=[page of results to retrieve]:page:' \
          '--per-page=[results per page]:n:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      list|view|assignments|assignment|accepted-assignments)
        _arguments -s -S \
          '(-c --classroom-id)'{-c,--classroom-id}'=[classroom id]:id:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
