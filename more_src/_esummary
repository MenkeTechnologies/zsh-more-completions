#compdef esummary
# Documentation: https://man.archlinux.org/search?q=esummary
# Reference accessed: 2026-05-16

# NCBI EDirect esummary: retrieve document summaries for a query/set
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-db=[database name]:db:(pubmed protein nucleotide gene structure pmc taxonomy snp dbvar)' \
  '-id=[UID(s) to summarise]:list:' \
  '-format=[output format]:format:(xml json text docsum native)' \
  '-mode=[output mode]:mode:(xml json text)' \
  '-version=[esummary version]:version:(1.0 2.0)' \
  '-WebEnv=[reuse WebEnv]:env:' \
  '-query_key=[reuse query_key]:key:' \
  '-retmax=[max results to return]:n:' \
  '-retstart=[starting index]:n:' \
  '-target=[target database]:db:' \
  '*::ids:' && ret=0
return ret
