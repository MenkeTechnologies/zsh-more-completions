#compdef dry
# Documentation: https://github.com/moncho/dry
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dry (Docker container manager TUI)

_arguments -s -S \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '-H+[Docker daemon socket to connect to]:docker host:' \
  '--docker-host=[Docker daemon socket to connect to]:docker host:' \
  '-T+[color theme]:theme:(dark light)' \
  '--workspace[launch experimental workspace layout]' \
  '-p[enable pprof profiling]' && return 0
