#compdef dry

# Zsh completion for dry (Docker container manager TUI)

_arguments -s -S \
  '-h[Show help]' \
  '--help[Show help]' \
  '-v[Show version]' \
  '--version[Show version]' \
  '-H+[Docker daemon socket to connect to]:docker host:' \
  '--docker-host=[Docker daemon socket to connect to]:docker host:' \
  '-e+[Docker API version to use]:api version:' \
  '--docker-api-version=[Docker API version to use]:api version:' \
  '--env-file=[Read env vars from file]:env file:_files' \
  '-c+[Use TLS and verify remote]:tls cert path:_directories' \
  '--docker-certpath=[Use TLS and verify remote]:tls cert path:_directories' \
  '--docker-tls-verify=[TLS verify remote]:verify:(true false)' \
  '-l+[Set log level]:level:(debug info warn error)' \
  '--log-level=[Set log level]:level:(debug info warn error)' && return 0
