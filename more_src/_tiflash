#compdef tiflash
# Documentation: https://docs.pingcap.com/tidb/stable/tiflash-command-line-flags
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:start the TiFlash server'
  'dttool:DTFile management helper'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tiflash command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--config-file=[TiFlash configuration file path]:file:_files -g "*.toml"' && ret=0 ;;
      (dttool)
        local -a sub=(
          'migrate:migrate DTFile format'
          'bench:I/O speed test for DTFile'
          'inspect:validate DTFile integrity'
        )
        _arguments \
          '1: :->dtcmd' \
          '*::dtarg:->dtargs' && ret=0
        case $state in
          (dtcmd) _describe -t sub 'dttool subcommand' sub && ret=0 ;;
          (dtargs)
            case $line[2] in
              (migrate)
                _arguments \
                  '--imitative[avoid config file and PD connection when encryption unused]' \
                  '--version=[target DTFile version]:version:(1 2 3)' \
                  '--algorithm=[hash algorithm]:alg:(xxh3 city128 crc32 crc64 none)' \
                  '--frame=[validation frame size]:n:' \
                  '--compression=[target compression algorithm]:alg:(LZ4 LZ4HC zstd none)' \
                  '--level=[compression level]:n:' \
                  '--config-file=[configuration file path]:file:_files' \
                  '--file-id=[DTFile ID number]:id:' \
                  '--workdir=[parent directory of dmf_xxx]:dir:_files -/' \
                  '--dry[dry run mode (output only)]' \
                  '--nokeep[remove original data (default keeps as dmf_xxx.old)]' && ret=0 ;;
              (bench)
                _arguments \
                  '--version=[DTFile version]:version:(1 2 3)' \
                  '--algorithm=[hash algorithm]:alg:(xxh3 city128 crc32 crc64 none)' \
                  '--frame=[validation frame size]:n:' \
                  '--column=[test table columns (default 100)]:n:' \
                  '--size=[test table rows (default 1000)]:n:' \
                  '--field=[field length limit (default 1024)]:n:' \
                  '--random=[random seed]:n:' \
                  '--encryption[enable encryption feature]' \
                  '--repeat=[test repetitions (default 5)]:n:' \
                  '--workdir=[temp directory (default /tmp/test)]:dir:_files -/' && ret=0 ;;
              (inspect)
                _arguments \
                  '--config-file=[configuration file path]:file:_files' \
                  '--check[perform hash validation]' \
                  '--file-id=[DTFile ID]:id:' \
                  '--imitative[imitate database context]' \
                  '--workdir=[data directory path]:dir:_files -/' && ret=0 ;;
            esac ;;
        esac ;;
    esac ;;
esac

return ret
