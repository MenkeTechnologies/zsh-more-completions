#compdef tiflash
# Documentation: https://man.archlinux.org/search?q=tiflash
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:start the TiFlash server'
  'client:start the TiFlash interactive client'
  'version:show TiFlash version'
  'dttool:DTFile migration helper'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config-file=[main TOML config file]:file:_files -g "*.toml"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tiflash command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (server)
        _arguments \
          '--config-file=[main TOML config file]:file:_files -g "*.toml"' \
          '--daemon[run as daemon]' \
          '--http_port=[HTTP server port]:port:' \
          '--tcp_port=[TCP server port]:port:' \
          '--listen_host=[listen host]:host:_hosts' \
          '--data_dir=[data directory]:dir:_files -/' \
          '--log_dir=[log directory]:dir:_files -/' && ret=0 ;;
      (client)
        _arguments \
          '--host=[server host]:host:_hosts' \
          '--port=[server port]:port:' \
          '--user=[user]:user:' \
          '--password=[password]:password:' \
          '--database=[database]:db:' \
          '--query=[query string]:query:' && ret=0 ;;
      (dttool)
        _arguments \
          '*::sub:(migrate inspect)' \
          '--workdir=[working directory]:dir:_files -/' \
          '--file-id=[DTFile id]:id:' \
          '--version=[target file format version]:version:' \
          '--frame=[frame size]:n:' && ret=0 ;;
    esac ;;
esac

return ret
