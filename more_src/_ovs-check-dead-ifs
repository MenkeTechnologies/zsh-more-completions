#compdef ovs-check-dead-ifs
# _ovs-check-dead-ifs — Open vSwitch ovs-check-dead-ifs find OVS interfaces that reference no-longer-existent Linux network devices (openvswitch team, Python); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-check-dead-ifs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]'
}

_ovs-check-dead-ifs "$@"
