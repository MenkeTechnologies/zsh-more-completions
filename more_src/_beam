#compdef beam
# Documentation: https://man.archlinux.org/search?q=beam
# Reference accessed: 2026-05-16
# Source: cargo binstall beamcli@0.5.0
# Probed via: completions zsh
# Repository: https://github.com/MichaelMandel26/beam

autoload -U is-at-least

_beam() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-p+[The profile to use]:PROFILE: ' \
'--profile=[The profile to use]:PROFILE: ' \
'-u+[The user which will be used to connect to the host. (default is the current system user)]:USER: ' \
'--user=[The user which will be used to connect to the host. (default is the current system user)]:USER: ' \
'--proxy=[The proxy to use]:PROXY: ' \
'--auth=[The auth to use]:AUTH: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'-V[Print version information]' \
'--version[Print version information]' \
'-c[Whether to clear the cache]' \
'--clear-cache[Whether to clear the cache]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
":: :_beam_commands" \
"*::: :->beam" \
&& ret=0
    case $state in
    (beam)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:beam-command-$line[1]:"
        case $line[1] in
            (connect)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
':host -- The host to connect to:' \
&& ret=0
;;
(profile)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
":: :_beam__profile_commands" \
"*::: :->profile" \
&& ret=0

    case $state in
    (profile)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:beam-profile-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
'::profile -- The profile to configure:' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
'::profile -- The profile to remove:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'--tsh[output the tsh command, that would be used to connect to the node]' \
'*::subcommand -- The subcommand whose help message to display:' \
&& ret=0
;;
        esac
    ;;
esac
;;
(list)
_arguments "${_arguments_options[@]}" \
'-f+[The format to use for the output]:FORMAT: ' \
'--format=[The format to use for the output]:FORMAT: ' \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
':shell -- The shell to generate completions for:' \
&& ret=0
;;
(configure)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
":: :_beam__configure_commands" \
"*::: :->configure" \
&& ret=0

    case $state in
    (configure)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:beam-configure-command-$line[1]:"
        case $line[1] in
            (profile)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
':profile -- The profile to configure:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'--tsh[output the tsh command, that would be used to connect to the node]' \
'*::subcommand -- The subcommand whose help message to display:' \
&& ret=0
;;
        esac
    ;;
esac
;;
(login)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
&& ret=0
;;
(logout)
_arguments "${_arguments_options[@]}" \
'-h[Print help information]' \
'--help[Print help information]' \
'--tsh[output the tsh command, that would be used to connect to the node]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
'--tsh[output the tsh command, that would be used to connect to the node]' \
'*::subcommand -- The subcommand whose help message to display:' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_beam_commands] )) ||
_beam_commands() {
    local commands; commands=(
'connect:' \
'profile:' \
'list:' \
'completions:' \
'configure:' \
'login:' \
'logout:' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'beam commands' commands "$@"
}
(( $+functions[_beam__profile__add_commands] )) ||
_beam__profile__add_commands() {
    local commands; commands=()
    _describe -t commands 'beam profile add commands' commands "$@"
}
(( $+functions[_beam__completions_commands] )) ||
_beam__completions_commands() {
    local commands; commands=()
    _describe -t commands 'beam completions commands' commands "$@"
}
(( $+functions[_beam__configure_commands] )) ||
_beam__configure_commands() {
    local commands; commands=(
'profile:Configure profile' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'beam configure commands' commands "$@"
}
(( $+functions[_beam__connect_commands] )) ||
_beam__connect_commands() {
    local commands; commands=()
    _describe -t commands 'beam connect commands' commands "$@"
}
(( $+functions[_beam__configure__help_commands] )) ||
_beam__configure__help_commands() {
    local commands; commands=()
    _describe -t commands 'beam configure help commands' commands "$@"
}
(( $+functions[_beam__help_commands] )) ||
_beam__help_commands() {
    local commands; commands=()
    _describe -t commands 'beam help commands' commands "$@"
}
(( $+functions[_beam__profile__help_commands] )) ||
_beam__profile__help_commands() {
    local commands; commands=()
    _describe -t commands 'beam profile help commands' commands "$@"
}
(( $+functions[_beam__list_commands] )) ||
_beam__list_commands() {
    local commands; commands=()
    _describe -t commands 'beam list commands' commands "$@"
}
(( $+functions[_beam__login_commands] )) ||
_beam__login_commands() {
    local commands; commands=()
    _describe -t commands 'beam login commands' commands "$@"
}
(( $+functions[_beam__logout_commands] )) ||
_beam__logout_commands() {
    local commands; commands=()
    _describe -t commands 'beam logout commands' commands "$@"
}
(( $+functions[_beam__configure__profile_commands] )) ||
_beam__configure__profile_commands() {
    local commands; commands=()
    _describe -t commands 'beam configure profile commands' commands "$@"
}
(( $+functions[_beam__profile_commands] )) ||
_beam__profile_commands() {
    local commands; commands=(
'add:Getting a configuration value' \
'remove:Setting a configuration value' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'beam profile commands' commands "$@"
}
(( $+functions[_beam__profile__remove_commands] )) ||
_beam__profile__remove_commands() {
    local commands; commands=()
    _describe -t commands 'beam profile remove commands' commands "$@"
}

_beam "$@"
