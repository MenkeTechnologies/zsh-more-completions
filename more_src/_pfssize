#compdef pfssize
# Documentation: http://pfstools.sourceforge.net/man1/pfssize.1.html
# pfstools: resize frames in a pfs stream

local ret=1

_arguments -s -S \
  '(-x --x)'{-x,--x}'=[new x resolution in pixels]:width' \
  '(-y --y)'{-y,--y}'=[new y resolution in pixels]:height' \
  '(-r --ratio)'{-r,--ratio}'=[resize width and height by ratio]:ratio' \
  '--minx=[ensure result has at least this width]:min_width' \
  '--miny=[ensure result has at least this height]:min_height' \
  '--maxx=[ensure result has at most this width]:max_width' \
  '--maxy=[ensure result has at most this height]:max_height' \
  '(-f --filter)'{-f,--filter}'=[upsampling filter]:filter:(BOX LINEAR MITCHELL)' \
  '--help[print list of command line options]' && ret=0

return ret
