# _ambertools — Amber Project AmberTools tleap antechamber cpptraj sander pmemd Open MM tools for biomolecular simulation (amber-md team, C/Fortran); custom argparse
# upstream: https://github.com/Amber-MD

_ambertools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-f+[input file]:file:_files -g "*.in *.txt *.parm7 *.prmtop *.rst7 *.inpcrd *.nc *.dcd *.mol2 *.pdb"' \
        '--input=+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-p+[topology file]:file:_files -g "*.parm7 *.prmtop *.top"' \
        '--topology=+[topology file]:file:_files -g "*.parm7 *.prmtop *.top"' \
        '-c+[coordinate file]:file:_files -g "*.rst7 *.inpcrd *.crd *.nc *.dcd *.pdb"' \
        '--coords=+[coordinate file]:file:_files -g "*.rst7 *.inpcrd *.crd *.nc *.dcd *.pdb"' \
        '-r+[restart file]:file:_files' \
        '--restart=+[restart file]:file:_files' \
        '-x+[trajectory file]:file:_files -g "*.nc *.crd *.mdcrd *.dcd"' \
        '--trajectory=+[trajectory file]:file:_files -g "*.nc *.crd *.mdcrd *.dcd"' \
        '-v+[velocity file]:file:_files' \
        '-e+[energy file]:file:_files -g "*.en *.energy"' \
        '-y+[ref file]:file:_files' \
        '-ref=+[ref file]:file:_files' \
        '-O[overwrite output]' \
        '-A[append output]' \
        '-i+[input script]:file:_files -g "*.in *.txt"' \
        '-l+[log file]:file:_files -g "*.log"' \
        '-mdout=+[md output file]:file:_files' \
        '-mdinfo=+[md info file]:file:_files' \
        '-rev[reverse]' \
        '-suffix=+[suffix]:str:' \
        '-prefix=+[prefix]:str:' \
        '-resname=+[residue name]:str:' \
        '-resid=+[residue id]:n:' \
        '-charge=+[F]:f:' \
        '-spin=+[N]:n:' \
        '-rn=+[residue name]:str:' \
        '-fi+[input format]:f:(amber sybyl mol2 pdb)' \
        '-fo+[output format]:f:(amber sybyl mol2 pdb)' \
        '-s+[serial]:n:' \
        '-at+[atom type]:str:' \
        '-nc+[net charge]:n:' \
        '-m+[multiplicity]:n:' \
        '-am1bcc-tj-batch[am1bcc batch mode]' \
        '-rn+[residue name]:str:' \
        '-an+[atom names]:str:' \
        '-cl+[cluster cutoff]:f:' \
        '*:Amber input file:_files'
}

_ambertools "$@"
