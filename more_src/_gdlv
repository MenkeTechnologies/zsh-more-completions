#compdef gdlv
# Documentation: https://github.com/aarzilli/gdlv
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-d+[working directory for the target program]:dir:_files -/' \
  '-tags=[build tags for the target program]:tags:' \
  '-r+[redirect stdin/stdout/stderr (e.g. stdout:/path)]:redirect:' \
  '*:program or package:_files'
