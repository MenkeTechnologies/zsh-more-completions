#compdef gdlv
# Documentation: https://man.archlinux.org/search?q=gdlv
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-H --headless)'{-H,--headless}'[headless (remote attach only)]' \
  '-listen=[listen address for headless mode]:addr' \
  '*-r=[redirect to running delve server]:hostport' \
  '*:program or package:_files'
