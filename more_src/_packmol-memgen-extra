#compdef packmol-memgen-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools packmol-memgen: generate membrane systems with Packmol

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--pdb[input protein PDB to pack]:file:_files' \
  '*--lipids[colon-separated lipid composition]:lipids:' \
  '--ratio[colon-separated lipid ratio]:ratio:' \
  '--distxy_fix[fix x and y box length]:length:' \
  '--xygauss[gaussian membrane curvature parameters]:params:' \
  '--dims[box dimensions x y z]:dims:' \
  '--tight_box[use a tight box]' \
  '--parametrize[parametrize the system in LEaP]' \
  '--keep[keep intermediate files]' \
  '--minimize[minimize the system]' \
  '--nottrim[do not trim protein hydrogens]' \
  '--notprotonate[do not reprotonate protein]' \
  '--solvate[solvate the system]' \
  '--cubic[use a cubic box]' \
  '--solute[solute PDB to add]:file:_files' \
  '--solute_con[solute concentration]:conc:' \
  '--solvents[colon-separated solvent composition]:solvents:' \
  '--solvent_ratio[colon-separated solvent ratio (v/v)]:ratio:' \
  '--solvent_parm[extra solvent parameter file]:file:_files' \
  '--available_solvents[list available solvents]' \
  '--ligand_param[lib and frcmod files for ligands]:file:_files' \
  '*:file:_files' && ret=0

return ret
