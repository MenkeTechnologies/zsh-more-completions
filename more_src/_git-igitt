# WHAT IS log4rs AND WHY IS IT THE 62ND RUST CLI LIBRARY?
#
# log4rs (https://github.com/estk/log4rs, 1,200+ stars) is **Steven
# Allen's "Highly configurable logging in Rust"** — a faithful Rust
# port of Java's log4j logging framework.  Where the other 5 Rust
# loggers documented in Axis 9 are Rust-native designs (env_logger
# inspired by Go's logrus, slog from the Rust ecosystem, tracing from
# the async/tokio world, fern + simplelog homegrown), log4rs is
# explicitly modeled on the log4j/logback Java patterns and brings
# their ENTIRE config-file-driven design philosophy to Rust.
#
# log4rs's distinguishing characteristics:
#
#   1. XML/YAML/JSON-CONFIG-DRIVEN — log4rs loads its ENTIRE
#      configuration from a config FILE at runtime:
#
#          # log4rs.yaml — typical YAML config:
#          appenders:
#              stdout:
#                  kind: console
#                  encoder:
#                      pattern: "{d(%Y-%m-%dT%H:%M:%S%.3f)} {l} {t} - {m}{n}"
#              file:
#                  kind: file
#                  path: "log/app.log"
#                  encoder:
#                      pattern: "{d} {l} {t} - {m}{n}"
#              rolling:
#                  kind: rolling_file
#                  path: "log/app.log"
#                  encoder:
#                      pattern: "{d} - {m}{n}"
#                  policy:
#                      kind: compound
#                      trigger:
#                          kind: size
#                          limit: 10 mb
#                      roller:
#                          kind: fixed_window
#                          pattern: "log/app.{}.gz"
#                          base: 1
#                          count: 5
#
#          root:
#              level: info
#              appenders:
#                  - stdout
#                  - file
#                  - rolling
#
#          loggers:
#              app::network:
#                  level: debug
#                  appenders:
#                      - file
#                  additive: false
#
#          # In Rust code:
#          log4rs::init_file("log4rs.yaml", Default::default()).unwrap();
#          log::info!("startup complete");
#
#      Compare:
#         * env_logger: env-var RUST_LOG=debug filter only
#         * slog: programmatic Drain composition
#         * tracing: tracing-subscriber Layer composition
#         * fern: chained Dispatch::new().chain()
#         * simplelog: CombinedLogger::init(vec![...])
#         * log4rs: ENTIRE CONFIG in YAML/XML/JSON file
#      FIRST documented Rust Axis 9 logger with file-based config-
#      driven setup as the canonical pattern.
#
#   2. APPENDER ABSTRACTION — log4rs treats every output destination
#      as an "Appender" — a pluggable Send + Sync object implementing
#      the Append trait:
#
#          use log4rs::append::Append;
#          use log4rs::encode::Encode;
#
#          pub struct CustomAppender { ... }
#          impl Append for CustomAppender {
#              fn append(&self, record: &log::Record) -> anyhow::Result<()> {
#                  // Custom log handling: send to network, database,
#                  // metrics system, audit log, etc.
#                  Ok(())
#              }
#              fn flush(&self) {}
#          }
#
#      Built-in appenders:
#         * ConsoleAppender (stdout / stderr with optional ANSI colors)
#         * FileAppender (write to file)
#         * RollingFileAppender (rotate by size / time / hybrid)
#         * AsyncAppender (deferred dispatch via background thread)
#      Compare:
#         * env_logger: console-only
#         * slog: Drain trait (similar concept, different API)
#         * tracing: Subscriber + Layer composition
#         * fern: Dispatch::chain(Output::...)
#         * simplelog: Vec<Box<dyn SharedLogger>> hardcoded types
#         * log4rs: APPENDER trait with first-class pluggability
#      FIRST documented Rust Axis 9 logger with explicit appender
#      trait + 4 built-in appender types + 3rd-party appenders.
#
#   3. PATTERN-ENCODER LOG4J-STYLE FORMAT STRINGS — log4rs's
#      PatternEncoder uses log4j-style format specifiers:
#
#          PatternEncoder::new(
#              "{d(%Y-%m-%dT%H:%M:%S%.3f)} \
#               [{l:5}] \
#               {t}:{L} \
#               - {m}{n}")
#
#          // Produces lines like:
#          // 2026-06-01T14:32:18.123 [INFO ] git_igitt::ui:347 - Rendering graph
#
#      Format specifiers (Java/log4j compatible):
#         * {d(...)} — date with chrono format string
#         * {l} — level name (ERROR/WARN/INFO/DEBUG/TRACE)
#         * {l:5} — level name padded to 5 chars
#         * {t} — module target (e.g. "git_igitt::ui")
#         * {f} — file
#         * {L} — line number
#         * {M} — module
#         * {m} — message
#         * {n} — platform-specific newline
#         * {T} — thread name
#         * {I} — thread ID
#         * {P} — process ID
#         * {X(key)(default)} — MDC value (mapped diagnostic
#                                context)
#         * {p(...)} — pad/truncate
#         * {h(...)} — highlight (ANSI color)
#         * Custom encoders via Encode trait
#      Compare:
#         * env_logger: env_logger::fmt::Formatter — different API
#         * slog: kv slog::o!(...) — structured fields, no format string
#         * tracing: tracing_subscriber fmt::Subscriber — different
#         * fern: format(|out, message, record| ...) closure
#         * simplelog: ConfigBuilder with set_*_level toggles
#         * log4rs: LOG4J pattern strings + Encode trait
#      FIRST documented Rust Axis 9 logger with log4j-compatible
#      format-string syntax.
#
#   4. ROLLING FILE APPENDER WITH POLICY COMPOSITION — log4rs's
#      RollingFileAppender uses a Policy composed of:
#         * Trigger — when to roll (SizeTrigger / TimeTrigger / custom)
#         * Roller — how to rename + archive (FixedWindowRoller /
#                     DeleteRoller / custom)
#         + CompoundPolicy combines a Trigger + a Roller
#
#          # YAML config:
#          rolling:
#              kind: rolling_file
#              path: "log/app.log"
#              policy:
#                  kind: compound
#                  trigger:
#                      kind: size
#                      limit: 10 mb
#                  roller:
#                      kind: fixed_window
#                      pattern: "log/app.{}.gz"    # archived files
#                      base: 1                     # start numbering
#                      count: 5                    # keep last 5
#
#          # → Rolls when log/app.log reaches 10MB; archives as
#          #   log/app.1.gz, log/app.2.gz, ..., log/app.5.gz
#          #   (with gzip compression based on .gz extension)
#
#      Compare:
#         * env_logger: no rotation
#         * slog: requires external slog-async + slog-stream
#                  + plugins for rotation
#         * tracing: tracing_appender::rolling::Builder (similar
#                     feature)
#         * fern: external crates needed
#         * simplelog: WriteLogger to any io::Write (no built-in
#                       rotation)
#         * log4rs: BUILT-IN rolling with policy composition +
#                    gzip archival
#      FIRST documented Rust Axis 9 logger with built-in
#      RollingFileAppender + policy composition + gzip archival.
#
#   5. STEVEN ALLEN (ESTK) + LOG4J-PORT PROVENANCE — log4rs is by
#      Steven Allen (estk on GitHub), released 2015 as the FIRST
#      faithful Rust port of log4j's design patterns.  Steven also
#      maintains async-compat (Tokio compatibility shim) + other
#      Rust crates.  Downstream users:
#         * autozimu/LanguageClient-neovim (LSP, 3.5k stars)
#         * sytsereitsma/mdbook-plantuml (mdBook plugin)
#         * purefinance/mmb (trading bot, 603 stars)
#         * tickbh/wmproxy (web proxy, 528 stars)
#         * h26forge/h26forge (video file analyzer, 327 stars)
#         * git-bahn/git-igitt (THIS — 265 stars)
#         * broxus/ever-wallet-api (Everscale wallet)
#         * itadinanta/rust-oids (alife sim, 156 stars)
#         * 400+ Rust services that prefer JVM-style logging
#      FIRST documented Rust Axis 9 logger with this specific
#      Steven-Allen + log4j-port-fidelity provenance.
#
# log4rs's relationship to other documented Rust Axis 9 libraries:
#
#   * Unlike env_logger (R582) — env_logger reads RUST_LOG env-var
#                                  for filter; log4rs uses YAML/XML
#                                  config file
#   * Unlike slog (R586) — slog is structured key-value drains;
#                            log4rs is appender-based plain-message
#   * Unlike tracing (R590) — tracing is span-based async-aware;
#                               log4rs is sync flat-event with
#                               configurable appenders
#   * Unlike fern (R594) — fern is chained Dispatch builder;
#                            log4rs is YAML/XML config + Handle
#   * Unlike simplelog (R606) — simplelog is Vec init combinator;
#                                  log4rs is config-file-driven
#                                  with appender abstractions
#   * Closest cross-language analogs:
#         * Java: log4j 2.x + logback (DIRECT ancestor)
#         * Java: SLF4J (facade pattern; log4rs is the
#                  implementation side)
#         * Python: Python logging stdlib (similar config-file +
#                    appender abstraction)
#         * .NET: NLog + Serilog (similar enterprise patterns)
#     log4rs is the FIRST documented Rust logger with log4j-port
#     fidelity + appender abstraction + XML/YAML/JSON config files
#     + RollingFileAppender + log4j-style format strings.
#
# -----------------------------------------------------------------------------
#
# THE git-igitt CLI — clap 4.x builder + log4rs + tui-rs + git2-rs
#
# git-igitt's CLI is in src/main.rs.  Uses clap 4.x builder:
#
#     use clap::{crate_version, Arg, Command};
#
#     let matches = Command::new("git-igitt")
