#         .arg(Arg::new("reverse").long("reverse").short('r').num_args(0))
#         .arg(Arg::new("sparse").long("sparse").short('S').num_args(0))
#         .arg(Arg::new("log-level").long("log-level").num_args(1))
#         .arg(Arg::new("color").long("color").num_args(1))
#         .arg(Arg::new("no-color").long("no-color").num_args(0))
#         .arg(Arg::new("style").long("style").short('s').num_args(1))
#         .arg(Arg::new("tab-width").long("tab-width").num_args(1))
