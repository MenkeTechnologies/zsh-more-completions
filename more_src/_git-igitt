local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _igitt_models _igitt_styles _igitt_formats _igitt_colors _igitt_log_levels _igitt_cmds
_igitt_models=(
    'simple:simple linear branching model'
    'git-flow:git-flow branching model (default)'
    'none:no branching model'
)
_igitt_styles=(
    'normal:normal box-drawing'
    'thin:thin lines (alias for normal)'
    'round:rounded corners'
    'bold:bold lines'
    'double:double lines'
    'ascii:ASCII-only'
)
_igitt_formats=(
    'oneline:single-line commit format (default)'
    'short:short format'
    'medium:medium format'
    'full:full format'
)
_igitt_colors=(
    'auto:auto-detect TTY (default)'
    'always:force colors'
    'never:disable colors'
)
_igitt_log_levels=(
    'error:error-level only'
    'warn:warn-level and above'
    'info:info-level and above'
    'debug:debug-level and above'
    'trace:all messages'
    'off:no logging (default)'
)
_igitt_cmds=(
    'model:get/set/list branching model for repository'
)

_arguments -C \
    '(-p --path)'{-p+,--path=}'[repository path (default .)]:repo path:_directories' \
    '(-n --max-count)'{-n+,--max-count=}'[max number of commits]:n:_default' \
    '(-m --model)'{-m+,--model=}'[branching model]:model:(simple git-flow none)' \
    '(-l --local)'{-l,--local}'[show only local branches]' \
    '(-r --reverse)'{-r,--reverse}'[show commits in reverse order]' \
    '(-S --sparse)'{-S,--sparse}'[less compact graph (merge lines to target)]' \
    '--log-level=[output log to file (log.txt)]:level:(error warn info debug trace off)' \
    '--color=[when to use colors]:when:(auto always never)' \
    '--no-color[disable colors (overrides --color)]' \
    '(-s --style)'{-s+,--style=}'[graph box-drawing style]:style:(normal thin round bold double ascii)' \
    '--tab-width=[tab width for diffs (default 4)]:width:_default' \
    '(-f --format)'{-f+,--format=}'[commit format]:format:(oneline short medium full)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'git-igitt subcommand' _igitt_cmds && ret=0
        ;;
    args)
        case $words[1] in
            model)
                _arguments \
                    '(-l --list)'{-l,--list}'[list all available branching models]' \
                    '1:model name:(simple git-flow none)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
