#compdef suabshw
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/suabshw.c
# SUABSHW - replace header key word by its absolute value

local ret=1

_arguments -s -S \
  'key=[header key word (default offset)]:k:' \
  '*:SU file:_files' && ret=0

return ret
