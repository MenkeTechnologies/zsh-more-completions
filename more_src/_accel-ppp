#compdef accel-pppd accel-ppp
# _accel-ppp — accel-ppp (high-performance PPP+PPPoE+PPTP+L2TP+IPoE/SSTP/RADIUS BNG daemon for ISPs; -c config file, -p pidfile, -d daemonize, --conf alternative config path, --pid alternative pidfile, --debug debug log level, --no-warns, --custom-args extra; reads /etc/accel-ppp.conf by default and exposes a telnet/CLI for live admin)
# upstream: https://accel-ppp.org/
# Flags from accel-ppp accel-pppd/main.c on tip.

_accel-ppp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--conf+[config file]:file:_files -g "*.conf"' \
        '-p+[pidfile]:file:_files' \
        '--pid+[pidfile]:file:_files' \
        '-d[daemonize]' \
        '--debug+[debug level]:level:(emerg alert crit err warning notice info debug)' \
        '--no-warns[hide warnings]'
}

_accel-ppp "$@"
