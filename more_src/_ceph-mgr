#compdef ceph-mgr

# Ceph manager daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[id (without daemon prefix)]:id:' \
  '--id=[id (without daemon prefix)]:id:' \
  '-n[name (type.id)]:name:' \
  '--name=[name (type.id)]:name:' \
  '-m[monitor addresses]:mon:' \
  '--monmap=[monmap file]:file:_files' \
  '--keyring=[keyring file]:file:_files' \
  '-k[keyring file]:file:_files' \
  '--keyfile=[key file]:file:_files' \
  '-d[run in foreground (debug)]' \
  '-f[run in foreground]' \
  '--foreground[run in foreground]' \
  '--debug-ms=[message debug level]:n:' \
  '--debug=[debug level]:n:' \
  '--log-file=[log file]:file:_files' \
  '--osd-data=[osd data dir]:dir:_files -/' \
  '--mon-data=[mon data dir]:dir:_files -/' \
  '--mgr-data=[mgr data dir]:dir:_files -/' \
  '--public-addr=[public address]:addr:' \
  '--cluster-addr=[cluster address]:addr:' \
  '*::ceph-mgr args:_files' && ret=0
return ret
