#compdef varnishtest
# Documentation: https://manpages.debian.org/testing/varnish/varnishtest.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-b+[internal buffer size (default 1M)]:size:' \
  '-D+[define macro for use in scripts]:name=val:' \
  '-i[set PATH and vmod_path to find varnish binaries in build tree]' \
  '-j+[run this many tests in parallel]:jobs:' \
  '-k[continue on test failure]' \
  '-L[always leave temporary vtc.*]' \
  '-l[leave temporary vtc.* if test fails]' \
  '-n+[run tests this many times]:iterations:' \
  '-p+[pass parameter to all varnishd command lines]:name=val:' \
  '-q[quiet mode (report only failures)]' \
  '-t+[test timeout duration (default 60s)]:duration:' \
  '-v[verbose mode (always report test log)]' \
  '*:vtc file:_files -g "*.vtc"' && ret=0

return ret
