#compdef loops

# Zsh completion for Loops.so CLI
# https://github.com/loops-so/cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:Manage authentication'
  'send:Send a transactional email'
  'events:Trigger events'
  'contacts:Manage audience members'
  'lists:Manage mailing lists'
)

_arguments -s -S \
  '-o[output format]:format:(json)' \
  '--team[switch between authenticated teams]:team:' \
  '--help[show help message]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'loops command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (auth)
        _arguments -s -S '1:subcommand:(login)' && ret=0
        ;;
      (send)
        _arguments -s -S \
          '--email=[recipient email address]:email:' \
          '--data=[JSON data variables]:json:' \
          '--data-file=[path to JSON data file]:file:_files' \
          '--attach=[path to attachment file]:file:_files' \
          '1:template-id:' && ret=0
        ;;
      (events)
        _arguments -s -S \
          '--email=[recipient email address]:email:' \
          '--props=[path to event properties JSON file]:file:_files' \
          '1:event-name:' && ret=0
        ;;
      (contacts)
        _arguments -s -S \
          '1:subcommand:(create update find delete)' \
          '--email=[contact email address]:email:' \
          '--first-name=[contact first name]:name:' \
          '--last-name=[contact last name]:name:' && ret=0
        ;;
      (lists)
        _arguments -s -S '1:subcommand:(list)' && ret=0
        ;;
    esac
    ;;
esac

return ret
