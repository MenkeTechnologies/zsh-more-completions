#compdef discus
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/discus.1.html
# discus - pretty version of df with graphs and color

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help summary]' \
  '(-v --version)'{-v,--version}'[show program version]' \
  '-c[disable color output]' \
  '-d[show device names instead of graphs]' \
  '-p[set decimal place digits]:digits' \
  '-s[disable smart formatting]' \
  '-t[display in terabytes]' \
  '-g[display in gigabytes]' \
  '-m[display in megabytes]' \
  '-k[display in kilobytes]' \
  '-r[include reserved root space in calculations]' && ret=0

return ret
