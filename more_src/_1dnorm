#compdef 1dnorm
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dnorm.html
# AFNI: normalize columns of an AFNI .1D file (L2 by default)

local ret=1

_arguments -s -S \
  '-norm1[L1 normalization (sum of abs = 1)]' \
  '-normx[Linf normalization (max abs = 1)]' \
  '(-demed)-demean[remove each column mean before normalizing]' \
  '(-demean)-demed[remove each column median before normalizing]' \
  '*:1D file:_files' && ret=0

return ret
