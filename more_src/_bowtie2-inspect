#compdef bowtie2-inspect bowtie2-inspect-s bowtie2-inspect-l
# _bowtie2-inspect — Ben Langmead bowtie2-inspect CLI Bowtie 2 reference-FASTA reconstructor inspecting and outputting raw reference sequences names lengths summary statistics from prebuilt bt2 BT2 Bowtie 2 indexes for downstream debugging verification of index integrity (Ben Langmead team, C++); custom argparse
# upstream: https://bowtie-bio.sourceforge.net/bowtie2/

_bowtie2-inspect() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s[summary only]' \
        '--summary[summary only]' \
        '-n[show only names]' \
        '--names[show only names]' \
        '-a+[wrap length]:n:' \
        '--across=+[N]:n:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--large-index[force large-index]' \
        '*:basename:_files'
}

_bowtie2-inspect "$@"
