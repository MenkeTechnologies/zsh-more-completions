#compdef mudraw
# render PDF/XPS/CBZ documents to image or vector files

local ret=1

_arguments -s -S \
  '-p+[password for an encrypted file]:password' \
  '-o+[output file name (use %d for page number)]:output:_files' \
  '-F+[enforce a specific output format]:format' \
  '-R+[rotate clockwise by given number of degrees]:angle' \
  '-r+[render at the specified resolution (default 72 dpi)]:resolution' \
  '-w+[render at the specified width]:width' \
  '-h+[render at the specified height]:height' \
  '-f[fit exactly; ignore aspect ratio when matching width/height]' \
  '-B+[render in banded mode with given max band height]:bandheight' \
  '-c+[render in the specified colorspace]:colorspace:(mono gray grayalpha rgb rgbalpha cmyk cmykalpha)' \
  '-G+[apply gamma correction]:gamma' \
  '-I[invert colors]' \
  '-s+[show information (m glyph cache/memory, f features, t times, 5 md5)]:flags' \
  '-A+[bits of anti-aliasing to use (default 8)]:bits' \
  '-D[disable use of display lists]' \
  '-i[ignore errors]' \
  '-L[low memory mode (clear cache after each page)]' \
  '-P[run interpretation and rendering at the same time]' \
  '-W+[page width in points for EPUB layout]:width' \
  '-H+[page height in points for EPUB layout]:height' \
  '-S+[font size in points for EPUB layout]:size' \
  '-U+[user CSS stylesheet for EPUB layout]:file:_files' \
  '-X[disable document styles for EPUB layout]' \
  '*:file:_files' && ret=0

return ret
