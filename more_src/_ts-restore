#compdef ts-restore
# Documentation: https://github.com/timescale/timescaledb-backup
# Restore a TimescaleDB database (pg_restore wrapper)

local ret=1

_arguments -s -S \
  '-db-URI=[PostgreSQL URI to connect to]:uri' \
  '-dump-dir=[directory to restore from]:dump dir:_files -/' \
  '-jobs=[number of parallel jobs (0 to disable parallelism)]:jobs' \
  '-verbose=[whether verbose output is requested]:bool:(true false)' \
  '-do-update=[upgrade to default installed TimescaleDB version (false leaves at dumped version)]:bool:(true false)' && ret=0

return ret
