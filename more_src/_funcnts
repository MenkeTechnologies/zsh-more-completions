#compdef funcnts
# Documentation: https://github.com/ericmandel/funtools/blob/master/man/man1/funcnts.1
# Count photons in specified regions with background subtraction

local ret=1

_arguments -s -S \
  '-e[source/bkgd FITS exposure image using matching files]' \
  '-w[source/bkgd FITS exposure image using WCS transform]' \
  '-t[source/bkgd time correction value or header param]' \
  '-g[output using nice g format for floats]' \
  '-G[output using %.14g format for max precision]' \
  '-i[column-based intervals]' \
  '-m[match individual source and bkgd regions]' \
  '-p[output in pixels even when WCS is present]' \
  '-r[output inner/outer radii (and angles) for annuli]' \
  '-s[table of summed background-subtracted values]' \
  '-v[src and bkgd value columns for tables]' \
  '-T[output in starbase/rdb format with tabs]' \
  '-z[include regions with zero area in output]' \
  '*:source file:_files' && ret=0

return ret
