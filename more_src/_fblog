#compdef fblog

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[additional keys to show]:keys' \
  '--additional-value=[additional keys to show]:keys' \
  '-a[show all keys]' \
  '--all-keys[show all keys]' \
  '-m+[message key name]:key' \
  '--message-key=[message key name]:key' \
  '-t+[time key name]:key' \
  '--time-key=[time key name]:key' \
  '-l+[level key name]:key' \
  '--level-key=[level key name]:key' \
  '--main-line-format=[format for main log line]:format' \
  '--additional-value-format=[format for additional values]:format' \
  '-p+[prefix for output]:prefix' \
  '--prefix=[prefix for output]:prefix' \
  '-c+[color mode]:mode:(auto always never)' \
  '--color=[color mode]:mode:(auto always never)' \
  '--no-pager[do not use pager]' \
  '-f+[filter expression]:filter' \
  '--filter=[filter expression]:filter' \
  '*:log file:_files' && ret=0

return ret
