#compdef spotifyd

# Zsh completion for spotifyd - Spotify daemon

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-daemon[do not detach from console]' \
  '--config-path[path to config file]:file:_files -g "*.toml"' \
  '--pid[path to PID file]:file:_files' \
  '(-u --username)'{-u,--username}'[Spotify username]:username' \
  '(-p --password)'{-p,--password}'[Spotify password]:password' \
  '--backend[audio backend]:backend:(pulseaudio alsa rodio portaudio)' \
  '--device[audio device]:device' \
  '--device-name[device name on Spotify Connect]:name' \
  '--bitrate[bitrate]:bitrate:(96 160 320)' \
  '--cache-path[path to cache]:directory:_files -/' \
  '--no-audio-cache[disable audio cache]' \
  '--initial-volume[initial volume percentage]:volume' \
  '--volume-normalisation[enable volume normalisation]' \
  '--normalisation-pregain[normalisation pregain in dB]:dB' \
  '--zeroconf-port[Zeroconf port]:port' \
  '--proxy[HTTP proxy]:proxy URL' \
  '--device-type[device type]:type:(computer tablet smartphone speaker tv avr stb audiodongle)' \
  '--on-song-change-hook[command to run on song change]:command:_files' \
  '--use-mpris[enable MPRIS support]' \
  '--dbus-type[D-Bus type]:type:(session system)'
