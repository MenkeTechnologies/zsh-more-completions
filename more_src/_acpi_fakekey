#compdef acpi_fakekey
# Documentation: https://manpages.debian.org/testing/acpi-fakekey/acpi_fakekey.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# acpi_fakekey: inject fake ACPI keypress event (acpid helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:keycode (decimal):' && ret=0
return ret
