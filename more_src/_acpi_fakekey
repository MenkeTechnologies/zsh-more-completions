#compdef acpi_fakekey
# Documentation: https://man.archlinux.org/search?q=acpi_fakekey
# Reference accessed: 2026-05-16

# acpi_fakekey: inject fake ACPI keypress event (acpid helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:keycode (decimal):' && ret=0
return ret
