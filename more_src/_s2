#compdef s2
# Source: cargo binstall s2-simple-secrets@1.7.0
# Probed via: completions zsh
# Repository: https://github.com/ags-slc/s2

autoload -U is-at-least

_s2() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_s2_commands" \
"*::: :->s2" \
&& ret=0
    case $state in
    (s2)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:s2-command-$line[1]:"
        case $line[1] in
            (exec)
_arguments "${_arguments_options[@]}" : \
'*-f+[Secret files to load]:FILE:_files' \
'*--file=[Secret files to load]:FILE:_files' \
'*-k+[Only inject these keys (comma-separated)]:KEYS:_default' \
'*--keys=[Only inject these keys (comma-separated)]:KEYS:_default' \
'-p+[Use a named profile from config]:PROFILE:_default' \
'--profile=[Use a named profile from config]:PROFILE:_default' \
'--clean-env[Start with a clean environment (only secrets + minimal vars)]' \
'-h[Print help]' \
'--help[Print help]' \
'*::cmd -- Command and arguments to execute:_default' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
'*-f+[Secret files to load]:FILE:_files' \
'*--file=[Secret files to load]:FILE:_files' \
'-p+[Use a named profile from config]:PROFILE:_default' \
'--profile=[Use a named profile from config]:PROFILE:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'*-f+[Secret files to load]:FILE:_files' \
'*--file=[Secret files to load]:FILE:_files' \
'-p+[Use a named profile from config]:PROFILE:_default' \
'--profile=[Use a named profile from config]:PROFILE:_default' \
'-h[Print help]' \
'--help[Print help]' \
'*::keys -- Keys to check for:_default' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'--no-encrypt[Create as plaintext instead of encrypted]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Path for the new file (default\: .env):_files' \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
'-f+[Target file]:FILE:_files' \
'--file=[Target file]:FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
':key -- Key name:_default' \
&& ret=0
;;
(migrate)
_arguments "${_arguments_options[@]}" : \
'-f+[Target secret file (defaults to first entry in config.default_files)]:FILE:_files' \
'--file=[Target secret file (defaults to first entry in config.default_files)]:FILE:_files' \
'--ssm=[Rewrite each value as an SSM URI under the given path prefix (e.g. \`--ssm /prod/myapp\` produces \`KEY=ssm\:///prod/myapp/KEY\`). Source values are discarded — useful for converting a plaintext \`.env\` into a reference file whose real values live in SSM]:PREFIX:_default' \
'-h[Print help]' \
'--help[Print help]' \
':source -- Source .env file to import from (absolute or relative path):_files' \
&& ret=0
;;
(unset)
_arguments "${_arguments_options[@]}" : \
'-f+[Target file]:FILE:_files' \
'--file=[Target file]:FILE:_files' \
'-h[Print help]' \
'--help[Print help]' \
':key -- Key name:_default' \
&& ret=0
;;
(encrypt)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- File to encrypt:_files' \
&& ret=0
;;
(decrypt)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- File to decrypt:_files' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':path -- Encrypted file to edit:_files' \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
'--entropy=[Shannon entropy threshold for medium-confidence detection (default\: 4.5)]:ENTROPY:_default' \
'--learn=[Test coverage against a file of known secrets and suggest new rules]:FILE:_files' \
'*--allow=[Add finding hashes to the allowlist file (see --allowlist / .s2allowlist)]:HASH:_default' \
'(--allow --learn --list-rules)*--allow-with-context=[Add finding hashes to the allowlist with source context comments (runs a scan first to look up file, line, rule, and description)]:HASH:_default' \
'--allowlist=[Allowlist file (precedence\: this flag > S2_ALLOWLIST env > \[scan\].allowlist > .s2allowlist)]:FILE:_files' \
'--staged[Only scan git staged files (pre-commit hook mode)]' \
'--no-ignore[Include files ignored by .gitignore and hidden dotfiles like .env (vendored directories like node_modules/ and target/ are still skipped)]' \
'--json[Output as JSON (one finding per line)]' \
'--list-rules[List all built-in and custom scan rules, then exit]' \
'-h[Print help]' \
'--help[Print help]' \
'*::paths -- Files or directories to scan (default\: current directory):_files' \
&& ret=0
;;
(hook)
_arguments "${_arguments_options[@]}" : \
'--format=[Agent hook format]:FORMAT:((claude\:"Claude Code / GitHub Copilot"
copilot\:"GitHub Copilot (alias for claude)"
cursor\:"Cursor IDE"))' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(redact)
_arguments "${_arguments_options[@]}" : \
'*-f+[Secret files to load (values become redaction patterns)]:FILE:_files' \
'*--file=[Secret files to load (values become redaction patterns)]:FILE:_files' \
'-p+[Use a named profile from config]:PROFILE:_default' \
'--profile=[Use a named profile from config]:PROFILE:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_s2__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:s2-help-command-$line[1]:"
        case $line[1] in
            (exec)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(migrate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(unset)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(encrypt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(decrypt)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(scan)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(hook)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(redact)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_s2_commands] )) ||
_s2_commands() {
    local commands; commands=(
'exec:Load secrets and exec a command with them in the environment' \
'list:List secret key names (never values)' \
'check:Check if keys exist (exit 0 = all present, exit 1 = missing)' \
'init:Create a new secret file (encrypted by default)' \
'set:Set a secret (reads value from stdin, NEVER from arguments)' \
'migrate:Import every KEY=value from a .env-style file into a secret file' \
'unset:Remove a secret from a file' \
'encrypt:Encrypt a file with age (passphrase stored in system keychain)' \
'decrypt:Decrypt an age-encrypted file' \
'edit:Decrypt a file, open in \$EDITOR, re-encrypt on save' \
'scan:Scan files for secrets (pattern matching + entropy analysis)' \
'hook:AI agent PreToolUse hook (reads JSON from stdin, emits JSON to stdout)' \
'completions:Generate shell completion scripts' \
'redact:Pipe filter\: replace secret values with \[REDACTED\]' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 's2 commands' commands "$@"
}
