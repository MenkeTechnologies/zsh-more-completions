#compdef xbps-checkvers

_arguments -s \
  '(-C --config)'{-C,--config}'=[config dir]:dir:_files -/' \
  '(-D --distdir)'{-D,--distdir}'=[distdir]:dir:_files -/' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-e --removed)'{-e,--removed}'[show removed packages]' \
  '(-f --format)'{-f,--format}'=[format string]:format:' \
  '(-i --ignore-conf-repos)'{-i,--ignore-conf-repos}'[ignore configured repos]' \
  '(-I --installed)'{-I,--installed}'[only show installed]' \
  '(-m --manual)'{-m,--manual}'[show only manually installed]' \
  '*'{-R,--repository}'=[repository URL]:url:' \
  '(-r --rootdir)'{-r,--rootdir}'=[rootdir]:dir:_files -/' \
  '(-s --show-all)'{-s,--show-all}'[show all packages]' \
  '--staging[include staging repos]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:pkg: '
