autoload -U is-at-least

_envroll() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--format=[Output format for read commands. JSON output uses a stable schema documented in \`docs/json-schemas/\`]:FORMAT:(human json)' \
'--log=[Diagnostic verbosity. \`debug\` includes full anyhow chains]:LOG:(off error warn info debug)' \
'--passphrase-env=[Override the env-var name used as the passphrase fallback. Default\: \`ENVROLL_PASSPHRASE\`]:NAME:_default' \
'--vault=[Override the vault root directory. Testing escape hatch — not documented in the user-facing README. Multi-vault topologies are explicitly unsupported]:PATH:_files' \
'--yes[Auto-confirm destructive prompts. Required for \`rm\`, \`--force\` overrides, and other actions that would otherwise pause for input]' \
'--no-color[Disable ANSI colors in human output. Also honored\: \`NO_COLOR\` env var]' \
'--passphrase-stdin[Read the passphrase from stdin to EOF instead of prompting. Mutually exclusive with a TTY stdin]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_envroll_commands" \
"*::: :->envroll" \
&& ret=0
    case $state in
    (envroll)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:envroll-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--id=[Override project ID derivation. Use when the auto-derived ID would collide (monorepo subdirs sharing an origin) or when reattaching a renamed project]:ID:_default' \
'--id-input=[Optional override for the persisted \`id_input\` field (e.g., the origin URL string when \`id_source = "manual"\`). Rare]:STRING:_default' \
'--target=[Override the working-copy filename inside the project root. Defaults to \`.env\` (Node, Python, Ruby, Go conventions). Set to \`.env.local\` for Next.js / Vite / Astro / Remix / Nuxt projects, or any other relative filename your stack reads from]:FILENAME:_default' \
'--format=[Output format for read commands. JSON output uses a stable schema documented in \`docs/json-schemas/\`]:FORMAT:(human json)' \
