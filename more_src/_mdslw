#compdef mdslw
# ============================================================================
# mdslw - markdown semantic line-wrapper for easy
#          diffing (Rust, GPL-3.0)
#
# Author : Torsten Long (razziel89)
# Upstream: https://github.com/razziel89/mdslw
# crates : mdslw (binary: mdslw)
#
# `mdslw` ("markdown semantic line wrapper") rewrites
# markdown files so each sentence lives on its own
# line. The motivating use case is producing diff-
# friendly markdown: instead of paragraph-level
# reflow churning every line on every edit, mdslw's
# one-sentence-per-line wrapping makes line-based
# diffs reflect the actual semantic change. Combined
# with `delta` or `git diff --word-diff`, mdslw
# transforms markdown review from "the entire paragraph
# changed" to "the third sentence changed".
#
# The wrapping is language-aware - mdslw includes
# pre-built end-of-sentence detection lists for
# English (default), German, French, Spanish, Italian,
# Portuguese, and several other languages. The user
# can override the end-marker set via `--end-markers`
# or extend it via `--suppressions` (preventing line
# breaks after specific tokens).
#
# Usage:
#   mdslw [OPTIONS] [PATHS...]
#   mdslw -m check FILE.md           # check only
#   mdslw -m format FILE.md          # rewrite in place
#   mdslw -m both FILE.md            # pre-commit hook
#                                     mode
#
# Flags (clap derive Parser):
#
# Operation:
#   -m, --mode <mode>            - operation mode:
#                                   format / check /
#                                   both (default
#                                   format)
#   -r, --report <mode>          - report mode:
#                                   none / changed /
#                                   diff
#   -d, --diff-pager <cmd>       - pager command for
#                                   `--report diff`
#                                   (e.g. "delta
#                                   --side-by-side")
#       --stdin-filepath <path>  - synthetic filename
#                                   for stdin input
#                                   (for config + format
#                                   detection)
#
# Wrapping:
#   -w, --max-width <n>          - max line width
#                                   (default 0 = wrap
#                                   on sentence
#                                   boundary only)
#   -e, --end-markers <chars>    - end-of-sentence
#                                   markers (default
#                                   "?!:.")
#   -l, --lang <code>            - language code
#                                   (en / ac / de / fr /
#                                   ...)
#   -s, --suppressions <list>    - tokens that
#                                   suppress sentence
#                                   break
#   -i, --ignores <list>         - tokens to remove
#                                   from suppressions
#                                   list
#   -c, --case <mode>            - case sensitivity:
#                                   ignore / keep
#
# Files:
#       --extension <.ext>       - extension to find
#                                   markdown files
#                                   (default .md)
#
# Upstream formatter:
#   -u, --upstream <cmd>         - run upstream
#                                   formatter before
#                                   parsing
#       --upstream-command <cmd> - upstream command
#                                   (alternate)
#       --upstream-separator <s> - command separator
#
# Features:
#       --features <list>        - comma-separated
#                                   feature flags
#
# Parallelism:
#   -j, --jobs <n>               - parallel worker
#                                   count (default
#                                   logical cores)
#
# Config:
#       --default-config         - print default TOML
#                                   config to stdout +
#                                   exit
#       --completion <shell>     - print shell
#                                   completion script
#                                   to stdout + exit
#                                   (bash / zsh / fish
#                                   / elvish /
#                                   powershell)
#
# Misc:
#   -v, --verbose                - increase log level
#                                   (repeatable)
#   -h, --help                   - print help
#   -V, --version                - print version
#
# Configuration file `.mdslw.toml` is auto-discovered
# in the input file's directory (or any parent
# directory). All flags are also configurable via
# environment variables (MDSLW_MODE, MDSLW_MAX_WIDTH,
# MDSLW_LANG, MDSLW_END_MARKERS, ...).
#
# The similar lane is built on `similar = "2"` (declared
# verbatim at upstream Cargo.toml HEAD as a direct dep,
# imported from src/diff.rs for the `--report diff`
# output mode), the canonical Rust diffing library by
# Armin Ronacher (mitsuhiko, also the Flask + Jinja2 +
# Click author) - github.com/mitsuhiko/similar, 1300+
# stars.
#
# similar implements multiple diff algorithms:
#   - Myers diff (the classic 1986 algorithm used by
#     git diff)
#   - Patience diff (the slower but cleaner-output
#     algorithm Bram Cohen wrote for Bazaar in 2007)
#   - LCS (longest common subsequence)
#   - Histogram diff (the algorithm git switched to
#     by default in 2010 for `git diff --histogram`)
#
# The crate also provides high-level adapters for
# common output formats (unified diff, side-by-side
# diff, character-grained inline diff for word-level
# highlighting). Multi-algorithm + multi-format
# coverage makes similar the de-facto Rust diffing
# library - depended on by:
#   - insta (snapshot testing)
#   - difftastic (semantic diff for code)
#   - cargo-insta (insta's cargo plugin)
#   - rustfmt (--check output formatting)
#   - mdslw (THIS BINARY)
#
# mdslw uses similar's Myers diff in src/diff.rs to
# produce the per-file change report when
# `--report diff` is selected: the original markdown
# + the rewrapped markdown are diffed at line
# granularity, and the resulting unified diff is
# piped through the configured `--diff-pager`
# (typically `delta --side-by-side`).
#
# ----------------------------------------------------------------------------
# AXIS 252 :: Diffing libraries (Myers / Patience /
#              LCS algorithms with multi-format output)
# Round 1454 :: Rust slot 1 of 4 :: OPENS Axis 252
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : mitsuhiko/similar          - Armin Ronacher's
#                                          multi-algorithm
#                                          Rust diff
#                                          library (Myers
#                                          + Patience +
#                                          LCS + Histogram);
#                                          depended on by
#                                          insta + cargo-
#                                          insta +
#                                          difftastic +
#                                          rustfmt
#   Go      : sergi/go-diff              - Sergi Mansilla's
#                                          Go port of
#                                          Google's
#                                          diff-match-patch
#                                          library; the
#                                          de-facto Go
#                                          diffing library;
#                                          depended on by
#                                          most Go diff
#                                          tools
#   TS/Node : kpdecker/jsdiff            - Kevin Decker's
#                                          (npm: `diff`)
#                                          pure-JS
#                                          Myers + LCS
#                                          implementation;
#                                          ~50M weekly
#                                          npm downloads;
#                                          depended on by
#                                          jest + mocha +
#                                          chai + most JS
#                                          assertion
#                                          libraries
#
# Diffing is a clean algorithm-bound axis - the Myers
# 1986 paper, Patience 2007 Cohen post, and Histogram
# 2010 git switch all define algorithms with deterministic
# output for the same input. Compliant implementations
# produce byte-identical diffs at the structural level
# (the set of insertions + deletions is identical;
# only the formatting of the output differs).
#
# Axis 252 opens with the Rust slot at the multi-
# algorithm `similar` canonical.
# ============================================================================

_mdslw() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-m --mode)'{-m,--mode}'[operation mode]:mode:(format check both)' \
        '(-r --report)'{-r,--report}'[report mode]:mode:(none changed diff)' \
        '(-d --diff-pager)'{-d,--diff-pager}'[pager command for --report diff]:cmd:' \
        '--stdin-filepath[synthetic filename for stdin input]:path:_files' \
        '(-w --max-width)'{-w,--max-width}'[max line width (0 = sentence-only)]:n:' \
        '(-e --end-markers)'{-e,--end-markers}'[end-of-sentence markers]:chars:' \
        '(-l --lang)'{-l,--lang}'[language code]:lang:(en ac de fr es it pt nl)' \
        '(-s --suppressions)'{-s,--suppressions}'[tokens that suppress sentence break]:list:' \
        '(-i --ignores)'{-i,--ignores}'[tokens to remove from suppressions]:list:' \
        '(-c --case)'{-c,--case}'[case sensitivity]:mode:(ignore keep)' \
        '--extension[extension to find markdown files]:ext:' \
        '(-u --upstream)'{-u,--upstream}'[run upstream formatter before parsing]:cmd:' \
        '--upstream-command[upstream formatter command]:cmd:' \
        '--upstream-separator[upstream command separator]:sep:' \
        '--features[comma-separated feature flags]:flags:' \
        '(-j --jobs)'{-j,--jobs}'[parallel worker count]:n:' \
        '--default-config[print default TOML config + exit]' \
        '--completion[print shell completion + exit]:shell:(bash zsh fish elvish powershell)' \
        '*'{-v,--verbose}'[increase log level (repeatable)]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '*:path:_files -g "*.md"'
}

_mdslw "$@"
