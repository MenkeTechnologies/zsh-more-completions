#compdef pb_mpi
# Documentation: https://github.com/bayesiancook/pbmpi/blob/master/sources/PB.cpp
# PhyloBayes-MPI: MCMC sampler for Bayesian phylogeny. Flags mirror PB.cpp argv parsing.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-d[data alignment file (phylip/nexus)]:data:_files' \
  '-t[starting/fixed tree file]:tree:_files' \
  '-T[fixed topology]:tree:_files' \
  '-x[saving frequency and number of points]:every:' \
  '-s[save entire chain]' \
  '-S[save substitution mappings]' \
  '-f[force overwrite existing chain]' \
  '-cat[CAT mixture model]' \
  '-catfix[fixed predefined profile mixture]:profile:' \
  '-ncat[number of mixture categories]:ncat:' \
  '-dp[infinite Dirichlet process mixture]' \
  '-sbdp[stick-breaking Dirichlet process]' \
  '-gtr[GTR exchangeabilities]' \
  '-poisson[Poisson (F81) exchangeabilities]' \
  '-uni[uniform exchangeabilities]' \
  '-wag[WAG empirical matrix]' \
  '-lg[LG empirical matrix]' \
  '-jtt[JTT empirical matrix]' \
  '-mtrev[mtREV empirical matrix]' \
  '-mtmam[mtMAM empirical matrix]' \
  '-mtart[mtART empirical matrix]' \
  '-mtzoa[mtZOA empirical matrix]' \
  '-dgam[discrete gamma rate categories]:ncat:' \
  '-dc[remove constant sites]' \
  '-mutsel[mutation-selection model]' \
  '-iscodon[codon model]' \
  '-fixomega[fix omega]' \
  '-freeomega[free omega]' \
  '-nni[nearest-neighbour interchange topology moves]' \
  '-spr[subtree-prune-regraft topology moves]' \
  '-topoburnin[topology burn-in cycles]:n:' \
  '-ss[stepping-stone sampling]' \
  '-sis[sequential importance sampling]' \
  '-rnd[random seed]:seed:' \
  '*:chain name:' && ret=0

return ret
