#compdef aerc
# Documentation: https://git.sr.ht/~rjarry/aerc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# completions for aerc terminal email client

local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)'{-v,--version}'[show version and exit]'
  '--accounts=[comma-separated list of accounts to load]:accounts'
  '*:mailto URI:'
)

_arguments -s -S $arguments
