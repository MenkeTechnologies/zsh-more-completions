#compdef kapp

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'app-change:app change commands'
  'app-group:app group commands'
  'config:show config'
  'delete:delete an app'
  'deploy:deploy an app'
  'inspect:inspect resources'
  'label:label resources'
  'list:list apps'
  'logs:print logs'
  'rename:rename an app'
  'tools:tools commands'
  'completion:generate completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '*--debug[debug]' \
  '*--column=[columns csv]:list:' \
  '*--json[JSON output]' \
  '*--no-color[no color]' \
  '*--tty=[force TTY]:b:(true false)' \
  '*--kubeconfig=[kubeconfig]:file:_files' \
  '*--kubeconfig-context=[context]:c:' \
  '*--kubeconfig-yaml=[yaml]:y:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kapp command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-a --app)'{-a+,--app=}'[app name]:n:' \
          '(-f --file)*'{-f+,--file=}'[file or URL]:file:_files' \
          '(-y --yes)'{-y,--yes}'[auto approve]' \
          '(-c --diff-changes)'{-c,--diff-changes}'[show diff]' \
          '--diff-context=[context lines]:n:' \
          '--diff-mask=[diff mask]:b:(true false)' \
          '--diff-summary=[diff summary]:b:(true false)' \
          '--apply-check=[apply check]:b:' \
          '--apply-concurrency=[apply concurrency]:n:' \
          '--apply-default-update-strategy=[strategy]:s:' \
          '--apply-ignored=[apply ignored]:b:' \
          '--apply-timeout=[apply timeout]:t:' \
          '--apply-wait-timeout=[wait timeout]:t:' \
          '--into-ns=[namespace]:ns:' \
          '--map-ns=[ns mapping]:m:' \
          '--existing-non-labeled-resources-check=[check]:b:' \
          '--app-changes-max-to-keep=[max changes]:n:' \
          '--logs[stream logs]' \
          '*: :_files' && ret=0 ;;
      (delete)
        _arguments \
          '(-a --app)'{-a+,--app=}'[app name]:n:' \
          '(-y --yes)'{-y,--yes}'[auto approve]' \
          '--apply-timeout=[apply timeout]:t:' \
          '--apply-wait-timeout=[wait timeout]:t:' \
          '*: :' && ret=0 ;;
      (inspect)
        _arguments \
          '(-a --app)'{-a+,--app=}'[app name]:n:' \
          '--filter=[filter]:f:' \
          '--filter-kind=[kind]:k:' \
          '--filter-name=[name]:n:' \
          '--filter-ns=[ns]:ns:' \
          '--raw[raw output]' \
          '--status[show status]' \
          '--tree[tree view]' \
          '*: :' && ret=0 ;;
      (logs)
        _arguments \
          '(-a --app)'{-a+,--app=}'[app name]:n:' \
          '(-f --follow)'{-f,--follow}'[follow]' \
          '--since=[since]:t:' \
          '--container=[container]:c:' \
          '--lines=[lines]:n:' \
          '*: :' && ret=0 ;;
      (list|app-group|config)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
