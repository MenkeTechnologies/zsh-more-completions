#compdef orbtop
# _orbtop — orbuculum project orbtop CLI ncurses top-style live profiler client connecting to orbuculum daemon decoding ARM PC sample interrupt event ITM exception trace packets per-function CPU percentage cycles count exception entry/exit ranking (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbtop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-c+[N entries]:n:' \
        '-D[no demangle]' \
        '-e+[elf file]:file:_files -g "*.elf *.axf *.out"' \
        '-E[no exception report]' \
        '-f+[interval ms]:n:' \
        '-g+[graph filename]:file:_files' \
        '-I+[indent]:n:' \
        '-l[lines mode]' \
        '-m+[max symbols]:n:' \
        '-n[no inlined]' \
        '-O+[objdump path]:file:_files' \
        '-p+[protocol]:p:(itm tpiu etm)' \
        '-r+[record file]:file:_files' \
        '-R[reset]' \
        '-s+[server:port]:host:port:' \
        '-t+[tag]:str:' \
        '-T[TPIU framing]' \
        '*:elf file:_files -g "*.elf *.axf"'
}

_orbtop "$@"
