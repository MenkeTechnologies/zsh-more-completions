#compdef pms
# Documentation: https://man.archlinux.org/search?q=pms
# Reference accessed: 2026-05-16

# Zsh completion for pms - Practical Music Search (MPD client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--host[connect to MPD host]:host:_hosts' \
  '--port[connect to MPD port]:port:' \
  '--password[MPD password]:password:' \
  '--debug[print debug info to stderr]' \
  && ret=0

return ret
