#compdef ecflow_server
# Documentation: https://ecflow.readthedocs.io/en/develop/ug/user_manual/ecflow_server/
# ecflow_server - the ecFlow workflow scheduler server daemon

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and environment variable documentation]' \
  '(-v --version)'{-v,--version}'[show ecflow version, boost and compiler info, then exit]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--port=[socket/port the server listens to (1024-49151, default 3141)]:port' \
  '--ecfinterval=[submit jobs interval (1-60), DEBUG/Test only]:interval' \
  '--v6[use IPv6 TCP protocol (default IPv4)]' \
  '--ssl[enable SSL communication]' \
  '--http[enable server/client HTTP communication]' \
  '--dis_job_gen[disable job generation, DEBUG/Test only]' && ret=0

return ret
