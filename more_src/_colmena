#compdef colmena

# Zsh completion for colmena (NixOS deployment tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --config)'{-f,--config}'[path to hive.nix or flake]:config:_files' \
  '--show-trace[show Nix trace on error]' \
  '--impure[allow impure Nix expressions]' \
  '--nix-option[set Nix option]:key value' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'apply:apply configurations to remote machines'
      'apply-local:apply configuration to local machine'
      'build:build configurations without applying'
      'eval:evaluate the configuration'
      'exec:execute a command on remote machines'
      'introspect:introspect the hive'
      'nix-info:show Nix information'
      'repl:start interactive REPL'
      'upload-keys:upload secret keys to remote machines'
    )
    _describe -t commands 'colmena command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (apply)
        _arguments \
          '--on[select nodes]:node pattern' \
          '--parallel[number of parallel deployments]:count' \
          '--eval-node-limit[max nodes to evaluate at once]:count' \
          '--keep-result[keep build results]' \
          '--no-keys[do not upload keys]' \
          '--reboot[reboot after activation]' \
          '--no-substitute[do not use substitutes]' \
          '--no-gzip[do not compress when copying]' \
          '--force-replace-unknown-profiles[force replace unknown profiles]' \
          '--evaluator[evaluator to use]:evaluator:(chunked streaming)' \
          '--goal[deployment goal]:goal:(build push switch boot test dry-activate keys)' && ret=0
        ;;
      (apply-local)
        _arguments \
          '--sudo[use sudo for activation]' \
          '--goal[deployment goal]:goal:(build switch boot test dry-activate keys)' \
          '--no-keys[do not upload keys]' && ret=0
        ;;
      (build)
        _arguments \
          '--on[select nodes]:node pattern' \
          '--parallel[number of parallel builds]:count' \
          '--eval-node-limit[max nodes to evaluate at once]:count' \
          '--no-substitute[do not use substitutes]' \
          '--evaluator[evaluator to use]:evaluator:(chunked streaming)' && ret=0
        ;;
      (eval)
        _arguments \
          '--on[select nodes]:node pattern' \
          '--instantiate[only instantiate, do not evaluate]' \
          '-E[Nix expression to evaluate]:expression' && ret=0
        ;;
      (exec)
        _arguments \
          '--on[select nodes]:node pattern' \
          '--parallel[number of parallel executions]:count' \
          '--:' \
          '*:command' && ret=0
        ;;
    esac
    ;;
esac

return ret
