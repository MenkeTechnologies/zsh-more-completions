#compdef winefile winefile.exe
# Documentation: https://man.archlinux.org/search?q=winefile
# Reference accessed: 2026-05-16

# winefile: Wine's Explorer-style file manager (Windows binary)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help and exit]' \
  '*:starting path:_files -/' && ret=0

return ret
