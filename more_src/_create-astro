#compdef create-astro

# Completion for create-astro - Create a new Astro project

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--template=[template name or GitHub URL]:template' \
  '--ref=[git ref for template]:ref' \
  '--install[install dependencies]' \
  '--no-install[skip dependency installation]' \
  '--git[initialize a git repository]' \
  '--no-git[skip git initialization]' \
  '--typescript[use TypeScript]' \
  '--no-typescript[skip TypeScript]' \
  {-y,--yes}'[accept all defaults]' \
  '--skip-houston[skip Houston animation]' \
  '--dry-run[walk through steps without executing]' \
  '--fancy[enable fancy terminal output]' \
  '1:project directory:_directories' && ret=0

return ret
