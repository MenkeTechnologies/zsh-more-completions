#compdef zoekt-archive-index zoekt-index zoekt-merge-index zoekt-mirror-github zoekt-mirror-gitlab zoekt-webserver
# Documentation: upstream cmd/{zoekt-archive-index,zoekt-index,zoekt-merge-index,zoekt-mirror-github,zoekt-mirror-gitlab,zoekt-webserver}/main.go
# at github.com/sourcegraph/zoekt
# Reference accessed: 2026-05-30
# Sourcegraph zoekt R57 — 6-stem multi-binary harvest from the zoekt
# fast-source-code-search family. Sister-binaries to the already-covered
# _zoekt + _zoekt-git-index. Source-direct flag.X extraction from
# per-binary main.go files.

local curcontext="$curcontext" state line ret=1

case $service in

  zoekt-archive-index)
    # sourcegraph/zoekt zoekt-archive-index — index an archive download.
    _arguments -s -S \
      '-incremental[skip if index up-to-date (default true)]' \
      '-name=[repository name]:name:' \
      '-url=[repository URL]:url:' \
      '-branch=[branch name]:branch:__git_branch_names' \
      '-commit=[commit SHA]:commit:' \
      '-strip_components=[remove N leading path elements]:N:' \
      '-download-limit-mbps=[restrict download speed (Mbps)]:N:' \
      '*:archive URL or file:_files' \
      && ret=0
    ;;

  zoekt-index)
    # sourcegraph/zoekt zoekt-index — index a local directory.
    _arguments -s -S \
      '-cpu_profile=[write CPU profile to file]:file:_files' \
      '-ignore_dirs=[comma-separated directories to ignore (default .git,.hg,.svn)]:dirs:' \
      '-meta=[.meta JSON file with repository description]:file:_files -g "*.json"' \
      '*:directory:_directories' \
      && ret=0
    ;;

  zoekt-merge-index)
    # sourcegraph/zoekt zoekt-merge-index — merge or explode index shards.
    local -a _subcmds
    _subcmds=(
      'merge:merge multiple shards into a compound shard'
      'explode:split a compound shard into its parts'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'zoekt-merge-index subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        _arguments '*:shard:_files' && ret=0
        ;;
    esac
    ;;

  zoekt-mirror-github)
    # sourcegraph/zoekt zoekt-mirror-github — mirror GitHub repos.
    local -a _visibilities
    _visibilities=(public private internal)
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-url=[GitHub Enterprise URL (default github.com)]:url:' \
      '-org=[organization to mirror]:org:' \
      '-user=[user to mirror]:user:' \
      '-token=[API-token file (default $HOME/.github-token)]:file:_files' \
      '-forks[also mirror forks]' \
      '-delete[delete missing repos]' \
      '-name=[only clone repos matching regex]:regex:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '*-topic=[only clone repos with topic (repeatable)]:topic:' \
      '*-exclude_topic=[exclude repos with topic (repeatable)]:topic:' \
      '-no_archived[mirror only non-archived projects]' \
      '*-visibility=[filter by visibility (repeatable)]:visibility:($_visibilities)' \
      && ret=0
    ;;

  zoekt-mirror-gitlab)
    # sourcegraph/zoekt zoekt-mirror-gitlab — mirror GitLab repos.
    _arguments -s -S \
      '-dest=[destination directory]:directory:_directories' \
      '-url=[GitLab API URL (default https://gitlab.com/api/v4/)]:url:' \
      '-token=[API-token file]:file:_files' \
      '-membership[only mirror repos this user is a member of]' \
      '-public[only mirror public repos]' \
      '-delete[delete missing repos]' \
      '-exclude_user[exclude user repos]' \
      '-name=[only clone repos matching regex]:regex:' \
      '-exclude=[exclude repos matching regex]:regex:' \
      '-last_activity_after=[only mirror repos active since (date)]:date:' \
      '-no_archived[mirror only non-archived projects]' \
      && ret=0
    ;;

  zoekt-webserver)
    # sourcegraph/zoekt zoekt-webserver — HTTP + RPC web frontend.
    _arguments -s -S \
      '-log_dir=[log directory (instead of stderr)]:directory:_directories' \
      '-log_refresh=[log rotation interval (default 24h)]:duration:' \
      '-listen=[listen address (default :6070)]:address:' \
      '-index=[index directory]:directory:_directories' \
      '-html[enable HTML interface (default true)]' \
      '-rpc[enable go/net RPC]' \
      '-indexserver_proxy[proxy requests matching /indexserver/]' \
      '-print[enable local result URLs]' \
      '-pprof[enable remote profiling]' \
      '-ssl_cert=[SSL certificate .pem]:file:_files' \
      '-ssl_key=[SSL key .pem]:file:_files' \
      '-host_customization=[per-host customization (HOST1=QUERY,HOST2=QUERY)]:mapping:' \
      '-template_dir=[custom .html.tpl template directory]:directory:_directories' \
      '-dump_templates[dump templates into --template_dir and exit]' \
      '-cors_origin=[allowed CORS origin]:origin:' \
      '-version[show version]' \
      && ret=0
    ;;

esac

return ret
