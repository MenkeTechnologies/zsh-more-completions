#compdef mask
# Documentation: https://man.archlinux.org/search?q=mask
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --maskfile)'{-m,--maskfile}'[path to maskfile]:maskfile:_files' \
  '--introspect=[output format for commands]:format:(json)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*::task and arguments' && ret=0

return ret
