#compdef mix

local curcontext="$curcontext" state line ret=1
local -a tasks

tasks=(
  'app.config:configure registered apps'
  'app.start:start applications'
  'app.tree:print application dependency tree'
  'archive:list installed archives'
  'archive.build:archive a project as a .ez file'
  'archive.install:install an archive locally'
  'archive.uninstall:uninstall an archive'
  'clean:remove build artifacts'
  'cmd:execute the given command'
  'compile:compile source files'
  'compile.app:write the .app file after compile'
  'compile.elixir:compile Elixir source files'
  'compile.erlang:compile Erlang source files'
  'compile.leex:compile Leex source files'
  'compile.protocols:consolidate protocols'
  'compile.xref:perform cross-reference checks'
  'compile.yecc:compile Yecc source files'
  'deps:list project dependencies'
  'deps.clean:delete dependencies'
  'deps.compile:compile dependencies'
  'deps.get:get all out-of-date dependencies'
  'deps.tree:print dependency tree'
  'deps.unlock:unlock the given dependencies'
  'deps.update:update the given dependencies'
  'do:execute multiple tasks'
  'escript:list installed escripts'
  'escript.build:build an escript for the project'
  'escript.install:install an escript locally'
  'escript.uninstall:uninstall an escript'
  'eval:evaluate Elixir code'
  'format:format Elixir source files'
  'help:show help'
  'loadconfig:load and persist configuration'
  'local:list local archives and scripts'
  'local.hex:install Hex'
  'local.phx:install Phoenix new project generator'
  'local.public_keys:manage public keys'
  'local.rebar:install rebar locally'
  'new:create a new Elixir project'
  'profile.cprof:profile a code path with cprof'
  'profile.eprof:profile a code path with eprof'
  'profile.fprof:profile a code path with fprof'
  'profile.tprof:profile a code path with tprof'
  'release:assemble a self-contained release'
  'release.init:create release configuration files'
  'run:run the current application'
  'test:run a project test suite'
  'test.coverage:build report from exported test coverage'
  'xref:perform cross-reference checks'
  'hex:print hex help'
  'hex.audit:audit dependencies for security advisories'
  'hex.build:build a new package'
  'hex.config:show or modify Hex config'
  'hex.docs:fetch or open documentation'
  'hex.info:show package or system info'
  'hex.organization:manage Hex organizations'
  'hex.outdated:show outdated dependencies'
  'hex.owner:manage package owners'
  'hex.package:manage Hex packages'
  'hex.publish:publish a new package version'
  'hex.registry:manage local Hex registries'
  'hex.repo:manage Hex repos'
  'hex.retire:retire a package version'
  'hex.search:search Hex packages'
  'hex.sponsor:show package sponsors'
  'hex.user:manage Hex user account'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->task' \
  '*::arg:_files' && ret=0

case $state in
  (task)
    _describe -t tasks 'mix task' tasks && ret=0
    ;;
esac

return ret
