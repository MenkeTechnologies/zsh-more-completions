#compdef fstatistic
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fstatistic.txt
# Compute statistics for a given column in a FITS table

local ret=1

_arguments -s \
  "infile=[input FITS file and extension]:file:_files" \
  "colname=[name of column to analyze]:" \
  "rows=[range of rows to use]:" \
  "outfile=[output file for results]:file:_files" \
  "maxval=[upper bound for included values]:" \
  "minval=[lower bound for included values]:" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
