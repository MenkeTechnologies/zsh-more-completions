#compdef dirname-cli
# _dirname-cli — GNU coreutils dirname strip last component from file name CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_dirname-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-z[NUL terminator]' \
        '--zero[NUL terminator]' \
        '*:names:_files'
}

_dirname-cli "$@"
