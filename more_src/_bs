#compdef bs
# Documentation: man bs(6)
# Source: openbsd/src games/bs/bs.c — battleship (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '(-b -s)-b[blitz mode]' \
    '(-b -s)-s[salvo mode]' \
    '-c[closely-packed ships]' \
    && ret=0

return ret
