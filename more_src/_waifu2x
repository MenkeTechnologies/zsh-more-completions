#compdef waifu2x waifu2x-caffe waifu2x-converter
# _waifu2x — nagadomi waifu2x image upscaler/denoiser CLI alias (nagadomi / waifu2x team, Torch/Lua + C++ ports); custom argparse
# upstream: https://github.com/nagadomi/waifu2x

_waifu2x() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--mode=+[mode]:m:(noise scale noise_scale auto)' \
        '-m+[mode]:m:(noise scale noise_scale auto)' \
        '--noise_level=+[noise level]:n:(0 1 2 3)' \
        '-n+[noise level]:n:(0 1 2 3)' \
        '--scale_factor=+[scale factor]:f:' \
        '-s+[scale factor]:f:' \
        '--scale_width=+[scale width]:n:' \
        '--scale_height=+[scale height]:n:' \
        '--scale_ratio=+[scale ratio]:f:' \
        '--input=+[input file or dir]:file:_files' \
        '-i+[input file or dir]:file:_files' \
        '--output=+[output file or dir]:file:_files' \
        '-o+[output file or dir]:file:_files' \
        '--output_quality=+[output quality]:n:' \
        '--output_depth=+[output depth]:n:' \
        '--output_extension=+[output ext]:str:' \
        '--process=+[process]:p:(cpu gpu cudnn)' \
        '-p+[process]:p:(cpu gpu cudnn)' \
        '--gpu=+[gpu id]:n:' \
        '-g+[gpu id]:n:' \
        '--tta=+[tta]:n:(0 1)' \
        '--tta_level=+[tta level]:n:' \
        '--crop_size=+[crop size]:n:' \
        '--batch_size=+[batch size]:n:' \
        '--model_dir=+[model dir]:dir:_files -/' \
        '--model=+[model]:str:' \
        '--depth_dimension=+[depth dimension]:n:' \
        '--auto_split_size=+[auto split size]:n:' \
        '--auto_split_overlap=+[auto split overlap]:n:' \
        '--alpha[preserve alpha]' \
        '--max_color=+[max color value]:n:' \
        '--anime[anime style]' \
        '--photo[photo style]' \
        '--art[art style]' \
        '--save_format=+[save format]:fmt:(png jpg webp bmp)' \
        '--recursive[recursive]' \
        '-r[recursive]' \
        '*:file:_files'
}

_waifu2x "$@"
