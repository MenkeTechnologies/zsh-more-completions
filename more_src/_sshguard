#compdef sshguard

# Zsh completion for sshguard (protect hosts from brute-force attacks)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[Number of attacks before blocking]:attacks' \
  '-b+[Blacklist threshold and optional file (thresh:file)]:threshold\:file' \
  '-e+[Extra attack score for command]:command and score' \
  '-i+[Path to the PID file]:file:_files' \
  '-l+[Log source to monitor]:source:_files' \
  '-p+[Block duration in seconds]:seconds' \
  '-s+[Forgive attacks after seconds]:seconds' \
  '-w+[Whitelist address or file]:address or file:_files' \
  '-h[Print help]' \
  '-v[Print version]' && ret=0

return ret
