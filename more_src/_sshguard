#compdef sshguard
# Documentation: https://manpages.debian.org/trixie/sshguard/sshguard.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sshguard (protect hosts from brute-force attacks).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[block attackers when attack score exceeds threshold (default 30)]:threshold' \
  '-b+[blacklist threshold and file (thresh:file)]:threshold\:file' \
  '-i+[write PID to pidfile]:file:_files' \
  '-p+[block first-time attackers for seconds (default 120)]:seconds' \
  '-s+[reset attack score after seconds (default 1800)]:seconds' \
  '*-w+[whitelist address, hostname, block, or file]:address or file:_files' \
  '-h[print usage]' \
  '-v[print version]' && ret=0

return ret
