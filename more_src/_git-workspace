#compdef git-workspace
# Documentation: https://github.com/orf/git-workspace
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --workspace)'{-w+,--workspace=}'[workspace directory]:dir:_files -/' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'add:configure providers (GitHub, GitLab, Gitea)'
      'archive:move deleted repositories to an archive directory'
      'fetch:run git fetch across all projects in parallel'
      'help:display help information'
      'list:display all repository names in the workspace'
      'lock:fetch repositories from providers and write lockfile'
      'run:execute git commands across all repositories'
      'switch-and-pull:pull changes on primary branch for all repos'
      'update:synchronize workspace (clone new, remove deleted)'
    )
    _describe -t commands 'git-workspace command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (add)
        _arguments -s -S \
          '*--include=[filter repositories by pattern]:pattern:' \
          '*--exclude=[exclude repositories by pattern]:pattern:' \
          '--url=[self-hosted instance URL]:url:' && ret=0
        ;;
    esac
    ;;
esac

return ret
