#compdef nvidia-ctk

# nvidia-ctk: NVIDIA Container Toolkit CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'cdi:CDI device generation'
  'config:configure runtime'
  'hook:hook commands'
  'info:print driver/device info'
  'runtime:configure container runtime (docker/containerd/cri-o)'
  'system:system commands'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-d[enable debug logging]' \
  '--debug[enable debug logging]' \
  '--quiet[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nvidia-ctk command' commands && ret=0 ;;
esac
return ret
