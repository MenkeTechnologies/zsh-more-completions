#compdef sukfilter
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/sukfilter.c
# radially symmetric K-domain, sin^2-tapered, polygonal

local ret=1

_arguments -s -S \
  'k=[k]:k:' \
  'amps=[amps]:amps:' \
  'd1=[d1]:d1:' \
  'd2=[d2]:d2:' \
  'nyq=[nyq]:nyq:' \
  '*:file:_files' && ret=0

return ret
