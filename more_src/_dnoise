#compdef dnoise
# Csound noise reduction by spectral subtraction

local ret=1

_arguments -s -S \
  '-i+[input reference noise soundfile]:noise file:_files' \
  '-o+[output soundfile]:output:_files' \
  '-N+[number of bandpass filters]:fnum' \
  '-w+[filter overlap factor (do not use with -M)]:fovlp' \
  '-M+[analysis window length]:awlen' \
  '-L+[synthesis window length]:swlen' \
  '-D+[decimation factor]:dfac' \
  '-b+[begin time in noise reference]:btim' \
  '-B+[starting sample in noise reference]:smpst' \
  '-e+[end time in noise reference]:etim' \
  '-E+[final sample in noise reference]:smpend' \
  '-t+[threshold above noise reference in dB]:thr' \
  '-S+[sharpness of noise-gate turnoff (1-5)]:gfact' \
  '-m+[minimum gain of noise-gate when off in dB]:mingain' \
  '-n+[number of FFT frames to average over]:numfrm' \
  '-A[AIFF output format]' \
  '-W[WAV output format]' \
  '-c[8-bit signed char samples]' \
  '-s[short integer samples]' \
  '-f[float samples]' \
  '-V[verbose status info]' \
  '-R[verbose status info]' \
  '-H+[print a heartbeat character]:heartbeat' \
  '*:soundfile:_files' && ret=0

return ret
