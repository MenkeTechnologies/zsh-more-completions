_enventory() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--help[show help (--help detailed for detailed variant)]' \
        '1: :_enventory_sections' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                completion)
                    _arguments '1:shell:(zsh)' && ret=0 ;;
                env)
                    _arguments \
                        '1:env subcommand:(create delete list update show)' \
                        '*: :' && ret=0 ;;
                shell)
                    _arguments \
                        '1:shell:(zsh)' \
                        '*::arg:->shell_args'
                    case $state in
                        shell_args)
                            _arguments \
                                '1:zsh subcommand:(chdir init export unexport)' \
                                '*: :' && ret=0 ;;
                    esac
                    ;;
                var)
                    _arguments \
                        '1:var subcommand:(create delete show update ref)' \
                        '*::arg:->var_args'
                    case $state in
                        var_args)
                            case $words[1] in
                                ref)
                                    _arguments \
                                        '1:ref subcommand:(create delete show update)' \
                                        '*: :' && ret=0 ;;
                                *)
                                    _arguments '*: :' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
                exec)
                    _arguments \
                        '1:command:_command_names -e' \
                        '*::command args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_enventory_sections] )) ||
_enventory_sections() {
    local -a sections
    sections=(
        'completion:print zsh completion script'
        'env:environment commands (create/delete/list/update/show)'
        'shell:manipulate the current shell (zsh hooks)'
        'var:vars owned by a given environment'
        'exec:run a command with environment vars injected'
    )
    _describe -t sections 'enventory section' sections
}

_enventory "$@"
