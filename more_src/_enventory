#   starter, influxdata/flux, integr8ly/integreatly-operator,
#   koderover/zadig, ritikchawla/k8s-operator-framework,
#   srdtrk/go-codegen, and dozens of other production Go
#   applications that emit OTLP telemetry).  opentelemetry-go
#   exposes the typed `otel.Tracer("module.name")` factory
#   returning a `trace.Tracer`, the typed
#   `tracer.Start(ctx, "span.name", trace.WithAttributes(...),
#   trace.WithSpanKind(trace.SpanKindServer))` constructor
#   returning `(context.Context, trace.Span)`, the typed
#   `span.SetAttributes(attribute.String("k", "v"))` /
#   `span.SetStatus(codes.Error, "message")` /
#   `span.RecordError(err)` /
#   `span.AddEvent("event.name", trace.WithAttributes(...))` /
#   `span.End()` lifecycle, the typed
#   `trace.SpanContextFromContext(ctx)` extractor, the
#   `trace.SpanFromContext(ctx)` accessor, the typed
#   `otel.GetTextMapPropagator()` /
#   `propagation.TraceContext{}.Inject(ctx, carrier)` /
