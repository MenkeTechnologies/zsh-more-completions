#compdef 0x
# Zsh completion for 0x - Node.js flamegraph profiler
# https://github.com/davidmarkclements/0x

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-o[open flamegraph in browser after profiling]' \
  '-p+[profile a running process by PID]:PID:_pids' \
  '-P+[set port for on-port]:port:' \
  '-D+[set output directory]:directory:_files -/' \
  '-n+[set profile name]:name:' \
  '-q[quiet mode]' \
  '--title=[set flamegraph title]:title:' \
  '--theme=[set flamegraph theme]:theme:(dark light)' \
  '--langs=[show languages in flamegraph]:language:(js c)' \
  '--tiers[separate flamegraph into tiers]' \
  '--exclude=[exclude regex from stacks]:regex:' \
  '--include=[include only matching stacks]:regex:' \
  '--kernel-tracing[include kernel-level stacks]' \
  '--output-dir=[set output directory]:directory:_files -/' \
  '--output-html=[save flamegraph HTML to file]:file:_files' \
  '--visualize-only=[visualize existing profile data]:data dir:_files -/' \
  '--collect-only[only collect stacks, do not visualize]' \
  '--cmd=[specify the Node.js command]:command:' \
  '--delay=[delay between starting and profiling in ms]:delay:' \
  '--on-port=[run script when port is listening]:script:' \
  '--timestamp-profiles[add timestamps to profile folder names]' \
  '*:node script and arguments:_files -g "*.js(-.)"'
