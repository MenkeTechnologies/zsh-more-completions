#compdef blhost
# Issue commands to an NXP MCU bootloader (SPSDK/blhost)

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-p --port)'{-p,--port}'[UART serial port connection]:port:_files' \
  '(-u --usb)'{-u,--usb}'[USB HID connection (vid,pid)]:usb:' \
  '--buspal[connect via BusPal bus translator]:buspal:' \
  '(-l --lpcusbsio)'{-l,--lpcusbsio}'[use LPCUSBSIO adapter]:lpcusbsio:' \
  '(-j --json)'{-j,--json}'[output in JSON format]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-t --timeout)'{-t,--timeout}'[command timeout in ms]:ms:' \
  '*'{-v,--verbose}'[enable verbose output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:command:(get-property set-property read-memory write-memory fill-memory flash-erase-region flash-erase-all flash-erase-all-unsecure receive-sb-file reset call execute configure-memory flash-security-disable flash-read-resource flash-program-once flash-read-once efuse-read-once efuse-program-once key-provisioning load-image generate-key-blob list-memory reliable-update)' && ret=0

return ret
