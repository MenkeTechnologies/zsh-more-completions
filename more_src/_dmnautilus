#compdef dmnautilus
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmnautilus.html
# Adaptively bin a 2D image based on signal-to-noise

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input 2D image]:infile:_files' \
  'outfile=[output adaptive binned image]:outfile:_files' \
  'snr=[signal-to-noise ratio threshold]:snr:' \
  'method=[SNR threshold method]:method:(0 1 2 3 4)' \
  'inerrfile=[input error image]:inerrfile:_files' \
  'outmaskfile=[output grouping mask image]:outmaskfile:_files' \
  'outsnrfile=[output SNR image]:outsnrfile:_files' \
  'outareafile=[output area image]:outareafile:_files' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
