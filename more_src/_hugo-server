#compdef hugo-server

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--appendPort[append port to baseURL]' \
  '-b+[hostname and path to the root]:url' \
  '--baseURL=[hostname and path to the root]:url' \
  '--bind=[interface to which the server will bind]:address' \
  '-D[include drafts]' \
  '--buildDrafts[include drafts]' \
  '-E[include expired content]' \
  '--buildExpired[include expired content]' \
  '-F[include future-dated content]' \
  '--buildFuture[include future-dated content]' \
  '--cacheDir=[cache directory]:directory:_directories' \
  '-c+[content directory]:directory:_directories' \
  '--contentDir=[content directory]:directory:_directories' \
  '--disableFastRender[enable full re-renders on changes]' \
  '--disableLiveReload[disable live reload]' \
  '-e+[build environment]:environment' \
  '--environment=[build environment]:environment' \
  '--enableGitInfo[add git revision to pages]' \
  '--forceSyncStatic[force sync static]' \
  '--gc[enable cleanup of unused cache]' \
  '--ignoreCache[ignore cache]' \
  '-l+[layout directory]:directory:_directories' \
  '--layoutDir=[layout directory]:directory:_directories' \
  '--liveReloadPort=[live reload port]:port' \
  '--meminterval=[memory stats interval]:interval' \
  '--memstats=[log memory stats to file]:file:_files' \
  '--minify[minify output]' \
  '--navigateToChanged[navigate to changed content file on live reload]' \
  '--noHTTPCache[prevent HTTP caching]' \
  '-p+[port]:port' \
  '--port=[port]:port' \
  '--renderToDisk[render to disk, serve from disk]' \
  '--renderStaticToDisk[render static to disk, serve rest from memory]' \
  '-s+[source directory]:directory:_directories' \
  '--source=[source directory]:directory:_directories' \
  '-t+[theme]:theme' \
  '--theme=[theme]:theme' \
  '-w[watch filesystem for changes]' \
  '--watch[watch filesystem for changes]' && return 0
