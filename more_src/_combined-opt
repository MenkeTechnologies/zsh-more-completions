#compdef combined-opt
# Documentation: https://mooseframework.inl.gov/application_usage/command_line_usage.html
# MOOSE-based finite-element application: command-line options

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display CLI usage statement]' \
  '(-v --version)'{-v,--version}'[print application version]' \
  '*-i+[specify input file(s); multiple files are merged]:input file:_files -g "*.i"' \
  '--n-threads=[number of threads per MPI process]:int' \
  '--mesh-only=[setup and output the input mesh only]::mesh file:_files' \
  '--split-mesh=[split the mesh into the given number of pieces]:splits' \
  '--use-split[use pre-split distributed mesh files]' \
  '--distributed-mesh[force the use of a distributed mesh]' \
  '--recover=[recover a solve that died, from optional checkpoint base]::file base:_files' \
  '--force-restart[force restart even with mismatched mesh]' \
  '--check-input[check the input file and quit]' \
  '(-e --error-unused)'{-e,--error-unused}'[error if unused parameters or syntax found]' \
  '(-w --allow-unused)'{-w,--allow-unused}'[warn (do not error) on unused parameters]' \
  '(-o --error-override)'{-o,--error-override}'[error on parameter override]' \
  '--error[turn all warnings into errors]' \
  '--error-deprecated[turn deprecated code messages into errors]' \
  '--no-color[disable coloring of all console outputs]' \
  '--redirect-stdout[redirect each processor stdout to its own file]' \
  '--keep-cout[keep standard output from all ranks when redirecting]' \
  '(-t --timing)'{-t,--timing}'[enable all performance logging for timing purposes]' \
  '--no-timing[disabled performance logging]' \
  '--trap-fpe[trap floating point exceptions]' \
  '--no-trap-fpe[disable trapping floating point exceptions]' \
  '--dump[show a dump of available input file syntax]' \
  '--yaml[dump all input file syntax in YAML format]' \
  '--json[dump all input file syntax in JSON format]' \
  '--syntax[dump the associated Action syntax paths only]' \
  '--registry[list all known objects and actions]' \
  '--registry-hit[list all known objects and actions in hit format]' \
  '--show-input[show the parsed input file before running]' \
  '--show-outputs[show output execution time information]' \
  '--show-controls[show the Control logic available and executed]' \
  '--show-type[return the name of the application object]' \
  '--show-capabilities[dump the capability registry in JSON format]' \
  '--list-constructed-objects[list all moose object type names constructed]' \
  '--start-in-debugger=[start application in the given debugger]:debugger' \
  '--suppress-header[suppress the output of the header]' \
  '*:input file:_files -g "*.i"' && ret=0

return ret
