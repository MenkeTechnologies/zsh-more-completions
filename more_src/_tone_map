#compdef tone_map

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-m+,--max_nits=}'[maximum luminance in image]:nits:' \
  {-t+,--target_nits=}'[peak luminance of target display]:nits:' \
  {-s+,--preserve_saturation=}'[preserve saturation over luminance (0..1)]:value:' \
  {-p,--pq}'[write output with absolute luminance using PQ]' \
  '1:input image:_files' \
  '2:output image:_files' && ret=0

return ret
