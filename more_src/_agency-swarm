#compdef agency-swarm
# Documentation: https://github.com/VRSEN/agency-swarm
# Reference accessed: 2026-05-22
# Verified: src/agency_swarm/cli/main.py argparse subcommands.

# Zsh completion for agency-swarm - Agency Swarm agent scaffolding CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agency-swarm command' \
      'create-agent-template[create agent template folder]' \
      'migrate-agent[generate agent from settings.json]' \
      'import-tool[import built-in tool into project]' && ret=0
    ;;
  args)
    case $line[1] in
      create-agent-template)
        _arguments \
          '--description[agent role description]:text:' \
          '--model[OpenAI model]:model:(gpt-5.4)' \
          '--reasoning[reasoning effort]:level:(low medium high)' \
          '--max-tokens[max completion tokens]:n:' \
          '--temperature[model temperature]:float:' \
          '--instructions[custom agent instructions]:text:' \
          '--use-txt[use .txt for instructions instead of .md]' \
          '--path[output directory]:directory:_directories' \
          '1:agent name:' && ret=0
        ;;
      migrate-agent)
        _arguments \
          '--output-dir[output directory]:directory:_directories' \
          '1:settings.json:_files' && ret=0
        ;;
      import-tool)
        _arguments \
          '--directory[destination directory]:directory:_directories' \
          '--list[list available built-in tools]' \
          '1:tool name:(IPythonInterpreter PersistentShellTool):' && ret=0
        ;;
    esac
    ;;
esac

return ret
