#compdef diffoscope

# Zsh completion for diffoscope (in-depth comparison tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--debug[display debug messages]' \
  '--debugger[open interactive debugger on error]' \
  '--html[write HTML report]:output file:_files -g "*.html"' \
  '--html-dir[write multi-page HTML report]:output directory:_files -/' \
  '--text[write plain text report]:output file:_files' \
  '--json[write JSON report]:output file:_files -g "*.json"' \
  '--markdown[write Markdown report]:output file:_files -g "*.md"' \
  '--restructuredtext[write reStructuredText report]:output file:_files -g "*.rst"' \
  '--output-empty[write output even if no differences]' \
  '--max-text-report-size[max size of text report]:bytes' \
  '--max-report-size[max size of report]:bytes' \
  '--max-report-child-size[max size of child report]:bytes' \
  '--max-diff-block-lines[max number of lines per diff block]:lines' \
  '--max-diff-input-lines[max number of lines fed to diff]:lines' \
  '--max-container-depth[max depth of container unpacking]:depth' \
  '--max-page-size[max size for HTML pages]:bytes' \
  '--max-page-diff-block-lines[max diff block lines per page]:lines' \
  '--fuzzy-threshold[similarity threshold for fuzzy matching]:threshold' \
  '--new-file[treat absent files as empty]' \
  '--exclude[exclude files matching pattern]:pattern' \
  '--exclude-command[exclude commands matching pattern]:pattern' \
  '--exclude-directory-metadata[exclude directory metadata]:option:(auto yes no)' \
  '--extended-description-url[url to extended description]:url' \
  '--tool[specify external tool]:tool' \
  '--force-details[always show details]' \
  '--no-default[disable default diff]' \
  '--css[path to custom CSS]:css file:_files -g "*.css"' \
  '--jquery[path to jQuery]:jquery file:_files -g "*.js"' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0

return ret
