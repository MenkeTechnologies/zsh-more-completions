#compdef criu
# _criu — CRIU (Checkpoint/Restore In Userspace; subcommands: dump (checkpoint a PID), pre-dump (incremental), restore (resurrect), show (read image dir), check (kernel features), exec (run command after restore), service (RPC mode), swrk (subprocess mode), cpuinfo (record/check); --tree pid, --images-dir / -D, --leave-stopped, --leave-running, --shell-job, --tcp-established, --link-remap, --action-script)
# upstream: https://github.com/checkpoint-restore/criu
# Subcommands from criu crtools/cr-service.c on tip.

_criu() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'criu command' '(dump pre-dump restore show check exec cpuinfo lazy-pages page-server service swrk dedup gen-key)' ;;
        args)
            _arguments \
                '--tree+[root pid]:pid:_pids' \
                '-t+[root pid]:pid:_pids' \
                '-D+[images directory]:dir:_files -/' \
                '--images-dir+[images directory]:dir:_files -/' \
                '-W+[work directory]:dir:_files -/' \
                '--work-dir+[work directory]:dir:_files -/' \
                '-o+[log file]:file:_files' \
                '--log-file+[log file]:file:_files' \
                '--log-pid[per-pid log files]' \
                '--leave-running[leave processes running]' \
                '--leave-stopped[stop processes after dump]' \
                '--shell-job[ignore session leaders]' \
                '--tcp-established[allow established TCP]' \
                '--evasive-devices[allow unknown devices]' \
                '--ext-unix-sk[external unix sockets]' \
                '--link-remap[allow link remapping]' \
                '--action-script+[script]:file:_files' \
                '--manage-cgroups[manage cgroups]' \
                '--cgroup-root+[root cgroup]:cgroup:' \
                '--config+[config file]:file:_files' \
                '--cpu-cap+[cpu cap]:caps:(fpu all none cpu fpu ins fpu+ins)' \
                '*::extra:_files'
            ;;
    esac
}

_criu "$@"
