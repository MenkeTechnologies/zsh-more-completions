#compdef stackprof
# Documentation: https://github.com/tmm1/stackprof
# sampling call-stack profiler report viewer for Ruby

local ret=1

_arguments -s -S \
  '--text[display results in tabular text format]' \
  '--json[export profile data as JSON]' \
  '--files[display file-level aggregation]' \
  '--method=[show detailed analysis for a specific method]:method' \
  '--walk[interactive stack traversal mode]' \
  '--flamegraph[create flamegraph data from results]' \
  '--flamegraph-viewer=[print shell command to view a flamegraph]:file:_files' \
  '--d3-flamegraph[generate an interactive HTML d3 flamegraph]' \
  '--graphviz[output in Graphviz format]' \
  '--callgrind[export data in callgrind format]' \
  '--limit=[restrict results to top N entries]:n' \
  '--sort-total[sort by total samples rather than self]' \
  '--select-files=[include frames matching filename]:pattern' \
  '--reject-files=[exclude frames matching filename]:pattern' \
  '--select-names=[include frames matching method name]:pattern' \
  '--reject-names=[exclude frames matching method name]:pattern' \
  '*:dump file:_files' && ret=0

return ret
