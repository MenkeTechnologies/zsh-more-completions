#compdef coveralls
# Documentation: https://github.com/TheKevJames/coveralls-python/blob/master/coveralls/cli.py
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# coveralls (coveralls-python). Options defined in coveralls/cli.py via typer.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--service=[alternative CI service name to submit]:service:(travis-ci travis-pro circleci jenkins github github-actions gitlab buildkite drone semaphore appveyor)' \
  '--rcfile=[configuration file path]:file:_files' \
  '--basedir=[base directory of source code]:dir:_directories' \
  '--srcdir=[source directory]:dir:_directories' \
  '--output=[write payload to file instead of uploading]:file:_files' \
  '--submit=[upload a previously generated file]:file:_files' \
  '--merge=[merge report from file when submitting]:file:_files' \
  '--finish[notify Coveralls all parallel jobs are done]' \
  '--verbose[verbose output]' \
  '1: :->cmd' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'debug:output JSON payload to stdout without submitting'
    )
    _describe -t commands 'coveralls subcommand' commands && ret=0
    ;;
esac

return ret
