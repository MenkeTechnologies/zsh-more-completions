#compdef coveralls
# Documentation: https://man.archlinux.org/search?q=coveralls
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--rcfile=[coverage configuration file]:file:_files -g ".coveragerc"' \
  '--service=[CI service name]:service:(travis-ci travis-pro circleci jenkins github gitlab buildkite codeship semaphore appveyor drone codefresh)' \
  '--service-name=[CI service name (alt)]:service:' \
  '--service-job-id=[CI service job id]:id:' \
  '--service-build-url=[CI service build URL]:url:' \
  '--service-branch=[git branch]:branch:' \
  '--service-pull-request=[pull request number]:n:' \
  '--repo-token=[Coveralls repo token]:token:' \
  '--repo_token=[Coveralls repo token (alt)]:token:' \
  '--basedir=[base directory of source]:dir:_files -/' \
  '--data_file=[coverage data file]:file:_files' \
  '--config_file=[config file]:file:_files' \
  '--coveralls_yaml=[Coveralls YAML config]:file:_files -g "*.{yaml,yml}"' \
  '--coveralls_url=[Coveralls upload URL]:url:' \
  '--merge_file=[merge coverage from file]:file:_files' \
  '--nogit[do not collect git metadata]' \
  '--ignore-errors[ignore upload errors]' \
  '--finish[mark parallel build finished]' \
  '--debug[do not upload, print payload]' \
  '--output=[output to file instead of uploading]:file:_files' \
  '--submit-coverage[force submission]' \
  '*::passthrough:' && ret=0

return ret
