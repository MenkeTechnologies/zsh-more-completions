#compdef mkbootfs
# Documentation: https://android.googlesource.com/platform/system/core/+/master/mkbootfs/mkbootfs.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mkbootfs: Android bootfs/cpio archive creator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dirname)'{-d+,--dirname=}'[fs-config directory]:dir:_files -/' \
  '(-f --file)'{-f+,--file=}'[canned configuration file]:file:_files' \
  '(-n --nodes)'{-n+,--nodes=}'[dev nodes description file]:file:_files' \
  '*:directory:_files -/' && ret=0
return ret
