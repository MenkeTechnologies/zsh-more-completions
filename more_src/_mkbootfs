#compdef mkbootfs
# Documentation: https://man.archlinux.org/search?q=mkbootfs
# Reference accessed: 2026-05-16

# mkbootfs: Android bootfs/cpio archive creator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[base dir]:dir:_files -/' \
  '-f[file_contexts file]:file:_files' \
  '*:directory:_files -/' && ret=0
return ret
