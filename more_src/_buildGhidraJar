#compdef buildGhidraJar
# _buildGhidraJar — build a single Ghidra jar from an installation (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra

_buildGhidraJar() {
    _arguments \
        '-output=[output jar file]:file:_files -g "*.jar"' \
        '-bin=[binary include path]:path:' \
        '-src[include source files]' \
        '-extra=[extra module to include]:module:' \
        '*:input jar:_files -g "*.jar"'
}

_buildGhidraJar "$@"
