#compdef spiderfoot sf
# _spiderfoot — Steve Micallef spiderfoot CLI open-source OSINT automation platform discovering domain hostname IP email phone employee identity-leak passive DNS BGP reverse-IP-whois certificate-transparency PGP search-engine-paste-vault-breach-dump SHODAN-Censys-XL platform 200+ modules CLI scan reporting (Steve Micallef team, Python); argparse
# upstream: https://www.spiderfoot.net/

_spiderfoot() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[listen]:str:' \
        '--listen=+[host:port]:str:' \
        '-s+[scan target]:str:' \
        '--scan=+[target]:str:' \
        '-m+[modules]:str:' \
        '--modules=+[list]:str:' \
        '-t+[event types]:str:' \
        '--types=+[list]:str:' \
        '-u+[use-case]:c:(all footprint investigate passive)' \
        '--use-case=+[case]:c:(all footprint investigate passive)' \
        '-x[disable storage]' \
        '--no-store[disable storage]' \
        '-o+[output format]:f:(tab csv json gexf)' \
        '--output=+[format]:f:(tab csv json gexf)' \
        '-f+[filter]:str:' \
        '--filter=+[expr]:str:' \
        '-r+[restrict subdomains]:str:' \
        '--restrict-subdomains=+[list]:str:' \
        '-w+[wait sec]:n:' \
        '--wait=+[sec]:n:' \
        '-L+[log file]:file:_files' \
        '--logfile=+[file]:file:_files' \
        '--config=+[file]:file:_files -g "*.cfg *.ini"' \
        '--correlate=+[ruleset]:str:' \
        '--load=+[json]:file:_files -g "*.json"' \
        '--listmodules[list modules]' \
        '--listtypes[list event types]' \
        '*:target:'
}

_spiderfoot "$@"
