#compdef goalign

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'addid:add identifier to sequences'
  'append:append alignments'
  'clean:clean sequences'
  'codonalign:align codon sequences'
  'compute:compute alignment statistics'
  'concat:concatenate alignments'
  'consensus:compute consensus sequence'
  'dedup:deduplicate sequences'
  'diff:compare two alignments'
  'divide:divide alignment into sub-alignments'
  'draw:draw alignment as image'
  'identical:print identical sequences'
  'mask:mask alignment sites'
  'mutate:add mutations to alignment'
  'phase:phase sequences using reference'
  'phasent:phase nucleotide sequences'
  'random:generate random alignment'
  'reformat:reformat alignment'
  'rename:rename sequences'
  'replace:replace characters in sequences'
  'sample:sample sequences or sites'
  'shuffle:shuffle alignment'
  'sort:sort sequences'
  'split:split alignment by partition'
  'stats:print alignment statistics'
  'subseq:extract subsequence'
  'subset:extract subset of sequences'
  'sw:Smith-Waterman alignment'
  'translate:translate nucleotide to protein'
  'trim:trim alignment'
  'unalign:remove gaps from alignment'
)

local -a global_flags=(
  '(-i --input)'{-i,--input}'[input alignment file]:input file:_files'
  '(-o --output)'{-o,--output}'[output alignment file]:output file:_files'
  '--input-strict[strict input format parsing]'
  '--auto-detect[auto-detect input format]'
  '--no-block[do not use block output format]'
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:'
  '--seed[random seed]:seed:'
)

_arguments -s -S \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'goalign subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (compute)
        local -a compute_cmds=(
          'entropy:compute entropy'
          'pssm:compute position-specific scoring matrix'
          'distances:compute pairwise distances'
        )
        _describe -t subcommands 'compute subcommand' compute_cmds && ret=0
        ;;
      (reformat)
        local -a reformat_cmds=(
          'fasta:reformat as FASTA'
          'clustal:reformat as Clustal'
          'nexus:reformat as Nexus'
          'phylip:reformat as Phylip'
          'tnt:reformat as TNT'
        )
        _describe -t subcommands 'reformat subcommand' reformat_cmds && ret=0
        ;;
      (*)
        _arguments -s -S $global_flags '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
