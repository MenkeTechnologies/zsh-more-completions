#compdef watcher-status
# Documentation: https://docs.openstack.org/watcher/latest/ (cli/index)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above; subcommand verified in
# https://opendev.org/openstack/watcher/src/branch/master/watcher/cmd/status.py
# (uses oslo_upgradecheck framework with single 'upgrade check' command).

# watcher-status: upgrade pre-flight checks.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:upgrade-related checks (use: upgrade check)'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "*--config-file=[path to config file]:file:_files" \
  "*--config-dir=[path to config dir]:dir:_files -/" \
  "(-d --debug)"{-d,--debug}"[set log level to DEBUG]" \
  "--nodebug[unset --debug]" \
  "--log-config-append=[external logging config file]:file:_files" \
  "--log-date-format=[log date format]:fmt" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--rate-limit-burst=[max logged messages per rate-limit-interval]:n" \
  "--rate-limit-except-level=[log level exempt from rate limiting]:level:(CRITICAL ERROR INFO WARNING DEBUG)" \
  "--rate-limit-interval=[log rate-limit interval seconds]:n" \
  "--rpc-conn-pool-size=[RPC connection pool size]:n" \
  "--rpc-response-timeout=[RPC response timeout seconds]:n" \
  "--syslog-log-facility=[syslog facility]:facility" \
  "--transport-url=[messaging transport URL]:url" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'watcher-status command' commands && ret=0 ;;
  args)
    case $line[1] in
      upgrade)
        _arguments '1:subcommand:(check)' && ret=0 ;;
    esac ;;
esac
return ret
