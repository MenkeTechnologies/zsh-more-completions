#compdef stevents
# _stevents — tail Syncthing REST API events (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stevents/main.go (stdlib flag).

_stevents() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-target=[target Syncthing instance host:port]:host\:port:'
        '-types=[comma-separated event types to filter]:types:'
        '-apikey=[Syncthing API key]:apikey:'
    )
    _arguments -s $args
}

_stevents "$@"
