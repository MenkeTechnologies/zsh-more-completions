#compdef spark-cli spark-submit2 sparkctl
# _spark-cli — Apache Spark spark-cli CLI alternative ergonomic command-line frontend wrapping the Apache Spark spark-submit Distributed-Computing-Engine providing application submission deploy-mode client cluster master spark-yarn-kubernetes-mesos-standalone driver-cores executor-memory executor-cores num-executors py-files-files-jars-conf properties (Apache Spark team, Scala); custom argparse
# upstream: https://spark.apache.org/

_spark-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--master=+[url]:str:' \
        '--deploy-mode=+[m]:m:(client cluster)' \
        '--class=+[name]:str:' \
        '--name=+[name]:str:' \
        '--jars=+[list]:str:' \
        '--packages=+[list]:str:' \
        '--exclude-packages=+[list]:str:' \
        '--repositories=+[list]:str:' \
        '--py-files=+[list]:str:' \
        '--files=+[list]:str:' \
        '--archives=+[list]:str:' \
        '--conf=+[k=v]:str:' \
        '--properties-file=+[file]:file:_files -g "*.properties *.conf"' \
        '--driver-memory=+[mem]:str:' \
        '--driver-java-options=+[opts]:str:' \
        '--driver-library-path=+[path]:str:' \
        '--driver-class-path=+[path]:str:' \
        '--executor-memory=+[mem]:str:' \
        '--driver-cores=+[N]:n:' \
        '--executor-cores=+[N]:n:' \
        '--num-executors=+[N]:n:' \
        '--total-executor-cores=+[N]:n:' \
        '--principal=+[principal]:str:' \
        '--keytab=+[file]:file:_files' \
        '--queue=+[name]:str:' \
        '--proxy-user=+[user]:_users' \
        '--kill=+[submission id]:str:' \
        '--status=+[submission id]:str:' \
        '--supervise[supervise driver]' \
        '*:application:_files -g "*.jar *.py *.r *.scala"'
}

_spark-cli "$@"
