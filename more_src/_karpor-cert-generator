#compdef karpor-cert-generator cert-generator
# _karpor-cert-generator — KusionStack Karpor in-cluster CA + kubeconfig bootstrapper (writes a Secret + ConfigMap that karpor-server / karpor-syncer consume)
# upstream: https://github.com/KusionStack/karpor
# Flags from cmd/cert-generator/option.go on tip.

_karpor-cert-generator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[print version and exit]' \
        '--kubeconfig=[path to kubeconfig]:file:_files' \
        '--namespace=[namespace to store the CA secret and kubeconfig configmap]:ns:' \
        '--ca-name=[name of the Secret holding the CA certificate]:name:' \
        '--kubeconfig-name=[name of the ConfigMap holding the kubeconfig]:name:'
}

_karpor-cert-generator "$@"
