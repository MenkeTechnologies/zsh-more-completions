#compdef llvm-cas

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--help-list[show option list]' \
  '(- *)--version[show version]' \
  '--color[use colors in output]' \
  '--all-trees[print all trees for ls-tree-recursive]' \
  '--allow-recovery[allow recovery of cas data]' \
  '--cas=[path to CAS on disk]:path:_files -/' \
  '--casid-file[input is a CASID file]' \
  '--dump[dump internal contents]' \
  '--print-kind[print kind]' \
  '--cat-blob[cat blob]' \
  '--cat-node-data[cat node data]' \
  '--diff-graphs[diff graphs]' \
  '--traverse-graph[traverse graph]' \
  '--make-blob[make blob]' \
  '--make-node[make node]' \
  '--ls-tree[list tree]' \
  '--ls-tree-recursive[list tree recursive]' \
  '--ls-node-refs[list node refs]' \
  '--ingest[ingest filesystem]' \
  '--merge[merge paths or cas-ids]' \
  '--get-cas-id[get CAS id for file]' \
  '--import[import objects from another CAS]' \
  '--put-cache-key[set a value for a cache key]' \
  '--get-cache-result[get the result value from a cache key]' \
  '--validate[validate ObjectStore]' \
  '--validate-object[validate the object for CASID]' \
  '--validate-if-needed[validate cas contents if needed]' \
  '--prune[prune local cas storage]' \
  '--check-hash[check all hashes during validation]' \
  '--data=[path to data, - for stdin]:path:_files' \
  '*--fcas-plugin-option=[plugin CAS option]:option:' \
  '--fcas-plugin-path=[plugin CAS library]:path:_files' \
  '--force[force validation]' \
  '--in-process[validate in-process]' \
  '--prefix-map=[prefix map (BEFORE=AFTER)]:map:' \
  '--upstream-cas=[path to another CAS]:path:_files -/' \
  '*:input object:_files' && ret=0

return ret
