#compdef plotCoverage
# Documentation: https://deeptools.readthedocs.io/en/latest/content/tools/plotCoverage.html
# deepTools: assess sequencing depth and plot coverage distribution across BAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-b --bamfiles)'{-b,--bamfiles}'[indexed BAM files]:bam:_files -g "*.bam"' \
  '(-o --plotFile)'{-o,--plotFile}'[output plot filename]:file:_files' \
  '(-l --labels)'{-l,--labels}'[custom sample labels]:labels:' \
  '--smartLabels[auto-generate labels from filenames]' \
  '(-T --plotTitle)'{-T,--plotTitle}'[plot title]:title:' \
  '--skipZeros[skip zero-coverage regions]' \
  '(-n --numberOfSamples)'{-n,--numberOfSamples}'[number of samples]:n:' \
  '--BED[BED files for region limits]:file:_files' \
  '--outRawCounts[output raw counts filename]:file:_files' \
  '--outCoverageMetrics[output coverage metrics filename]:file:_files' \
  '(-ct --coverageThresholds)'{-ct,--coverageThresholds}'[coverage thresholds (repeatable)]:n:' \
  '--plotHeight[plot height in cm]:cm:' \
  '--plotWidth[plot width in cm]:cm:' \
  '--plotFileFormat[output file format]:format:(png pdf svg eps plotly)' \
  '(-r --region)'{-r,--region}'[genomic region to process]:region:' \
  '(-bl --blackListFileName)'{-bl,--blackListFileName}'[BED/GTF file of regions to exclude]:file:_files' \
  '(-p --numberOfProcessors)'{-p,--numberOfProcessors}'[number of processors]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-e --extendReads)'{-e,--extendReads}'[extend reads to fragment length]:length:' \
  '--ignoreDuplicates[count duplicate reads only once]' \
  '--minMappingQuality[minimum mapping quality threshold]:qual:' \
  '--centerReads[center reads by fragment length]' \
  '--samFlagInclude[include reads matching SAM flag]:flag:' \
  '--samFlagExclude[exclude reads matching SAM flag]:flag:' \
  '--minFragmentLength[minimum fragment length]:length:' \
  '--maxFragmentLength[maximum fragment length]:length:' && ret=0

return ret
