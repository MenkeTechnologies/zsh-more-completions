#compdef SHLIB
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/SHLIB.html
# R CMD SHLIB: build a shared object for dynamic loading

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '(-o --output)'{-o,--output=}'[use LIB as full name for the built library]:lib:_files' \
  '(-c --clean)'{-c,--clean}'[remove files created during compilation]' \
  '--preclean[remove files created during a previous run]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run, showing commands that would be used]' \
  '--use-LTO[use Link-Time Optimization]' \
  '--no-use-LTO[do not use Link-Time Optimization]' \
  '--use-C17[use a C standard at most C17]' \
  '--use-C23[use a C standard at least C23]' \
  '*:file:_files' && ret=0

return ret
