#compdef qacToQa
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert from compressed to uncompressed quality score format

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-name=[restrict output to just this sequence name]:name:' \
  ':in qac:_files' \
  ':out qa:_files' && ret=0

return ret
