#compdef autohint psautohint
# _autohint — Adobe afdko psautohint CLI applying PostScript T1/T2 stem hinting to UFO and OTF source fonts using AC autohint engine for Type 1 hint dictionary generation (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/psautohint

_autohint() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output font]:file:_files -g "*.otf *.ufo *.cff"' \
        '--output=+[output font]:file:_files -g "*.otf *.ufo *.cff"' \
        '-r[force re-autohint]' \
        '--reference=+[reference font]:file:_files -g "*.otf *.ufo"' \
        '-g+[csv glyph list]:str:' \
        '--glyph-list=+[csv glyph list]:str:' \
        '-gf+[file]:file:_files' \
        '--glyph-file=+[file]:file:_files' \
        '-x+[csv exclude]:str:' \
        '--exclude-glyph-list=+[csv exclude]:str:' \
        '-xf+[file]:file:_files' \
        '--exclude-glyph-file=+[file]:file:_files' \
        '-cf+[psfont file]:file:_files' \
        '--info[show info]' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-D[decimal]' \
        '--decimal[decimal]' \
        '-a[hint all]' \
        '--all[hint all]' \
        '-q+[mode]:m:(0 1 2 3)' \
        '--no-flex[no flex]' \
        '--no-zones-stems[no zones stems]' \
        '--no-hint-sub[no hint substitution]' \
        '--allow-changes[allow changes]' \
        '--report-only[report only]' \
        '--write-to-default-layer[write to default layer]' \
        '--processes=+[N]:n:' \
        '*:font file:_files -g "*.otf *.ufo *.cff *.ttf"'
}

_autohint "$@"
