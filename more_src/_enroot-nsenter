#compdef enroot-nsenter
# Documentation: https://github.com/NVIDIA/enroot/blob/main/bin/enroot-nsenter.c
# enroot helper: run a command in the namespaces of a target process.

local ret=1

_arguments -s -S \
  '--target[target PID whose namespaces to enter]:pid:_pids' \
  '--user[enter the user namespace]' \
  '--mount[enter the mount namespace]' \
  '--pid[enter the PID namespace]' \
  '--net[enter the network namespace]' \
  '--ipc[enter the IPC namespace]' \
  '--uts[enter the UTS namespace]' \
  '--remap-root[map current user to root in the new user namespace]' \
  '--envfile[read environment from FILE]:file:_files' \
  '--envfd[read environment from file descriptor FD]:fd:' \
  '--workdir[set the working directory]:dir:_files -/' \
  '*:::command:_command_names -e' && ret=0

return ret
