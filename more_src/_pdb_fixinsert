#compdef pdb_fixinsert
# Documentation: http://www.bonvinlab.org/pdb-tools/
# Fixes insertion codes by renumbering residues, e.g. -A9,B12

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-[residues to fix, e.g. -A9,B12]:residues' \
  '*:PDB file:_files' && ret=0

return ret
