#compdef botan

# Botan CLI — see `botan help <cmd>`; common utilities
# https://botan.randombit.net/

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'version:print library version'
  'config:print build configuration'
  'hash:hash files (many algorithms)'
  'rng:emit random bytes'
  'timing_test:run internal timing tests'
  'bench:benchmark primitives'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'botan command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
