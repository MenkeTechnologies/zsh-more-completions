#compdef botan
# Documentation: https://botan.randombit.net/handbook/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'version:print library version'
  'config:print build configuration'
  'cpuid:print supported CPU instruction set extensions'
  'hash:hash files (many algorithms)'
  'hmac:compute HMAC tag'
  'rng:emit random bytes'
  'uuid:generate a UUID'
  'speed:benchmark primitives'
  'cipher:encrypt or decrypt files'
  'keygen:generate PKCS#8 private key'
  'pkcs8:open/manage PKCS#8 keys'
  'sign:digital signature'
  'verify:verify signature'
  'pk_encrypt:public key encrypt'
  'pk_decrypt:public key decrypt'
  'fingerprint:calculate key fingerprint'
  'gen_dl_group:generate DL group'
  'dl_group_info:show DL group info'
  'ec_group_info:elliptic curve parameters'
  'gen_pkcs10:generate PKCS#10 CSR'
  'gen_self_signed:generate self-signed certificate'
  'sign_cert:sign certificate (CA)'
  'cert_info:show cert info'
  'cert_verify:verify cert chain'
  'ocsp_check:OCSP check'
  'trust_roots:print trust roots'
  'tls_client:TLS client'
  'tls_server:TLS server'
  'tls_ciphers:list TLS ciphersuites'
  'tls_http_server:TLS HTTP server'
  'tls_proxy:TLS proxy'
  'gen_argon2:Argon2 hash'
  'check_argon2:verify Argon2 hash'
  'gen_bcrypt:bcrypt hash'
  'check_bcrypt:verify bcrypt hash'
  'pbkdf_tune:tune PBKDF'
  'is_prime:primality test'
  'factor:factor integer'
  'gen_prime:generate prime'
  'mod_inverse:modular inverse'
  'tss_split:secret sharing split'
  'tss_recover:secret sharing recover'
  'base32_encode:base32 encode'
  'base32_decode:base32 decode'
  'base58_encode:base58 encode'
  'base58_decode:base58 decode'
  'base64_encode:base64 encode'
  'base64_decode:base64 decode'
  'hex_encode:hex encode'
  'hex_decode:hex decode'
  'fec_encode:FEC encode'
  'fec_decode:FEC decode'
  'fec_info:FEC info'
  'compress:compress data'
  'decompress:decompress data'
  'help:show help'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'botan command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
