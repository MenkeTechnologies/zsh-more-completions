#compdef coda
# Documentation: https://github.com/bobthecow/coda-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bobthecow/coda-cli: opens files in Panic's Coda editor from the shell.
# The binary is a small shell wrapper around osascript with no documented
# flags beyond standard --help/--version; fall through to file completion.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '*:file:_files' && return 0
