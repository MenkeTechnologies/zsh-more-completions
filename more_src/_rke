#compdef rke

# Zsh completion for rke (Rancher Kubernetes Engine)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'up:bring the cluster up'
      'remove:tear down the cluster'
      'version:show cluster Kubernetes version'
      'config:setup cluster configuration'
      'etcd:etcd snapshot management'
      'cert:certificate management'
      'encrypt:manage cluster encryption provider config'
      'util:various utilities'
    )
    _describe -t commands 'rke command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (up)
        _arguments \
          '--config[cluster configuration file]:config:_files -g "*.{yml,yaml}"' \
          '--local[deploy using local node only]' \
          '--dind[deploy using docker-in-docker]' \
          '--update-only[update YAML only]' \
          '--disable-port-check[disable port check]' \
          '--init[initialize a new cluster]' \
          '--cert-dir[certificate directory]:dir:_files -/' \
          '--custom-certs[use custom certificates]' \
          '--ssh-agent-auth[use SSH agent authentication]' \
          '--ignore-docker-version[ignore Docker version check]' && ret=0
        ;;
      (remove)
        _arguments \
          '--config[cluster configuration file]:config:_files -g "*.{yml,yaml}"' \
          '--force[force removal]' \
          '--local[remove local cluster]' \
          '--dind[remove docker-in-docker cluster]' \
          '--ssh-agent-auth[use SSH agent authentication]' && ret=0
        ;;
      (etcd)
        local -a subcmds=(
          'snapshot-save:take an etcd snapshot'
          'snapshot-restore:restore from etcd snapshot'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'etcd subcommand' subcmds && ret=0
            ;;
          (subargs)
            _arguments \
              '--config[cluster configuration file]:config:_files -g "*.{yml,yaml}"' \
              '--name[snapshot name]:name' \
              '--ssh-agent-auth[use SSH agent authentication]' && ret=0
            ;;
        esac
        ;;
      (cert)
        local -a subcmds=(
          'rotate:rotate cluster certificates'
          'generate-csr:generate CSRs'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'cert subcommand' subcmds && ret=0
            ;;
        esac
        ;;
      (config)
        _arguments \
          '--name[cluster name]:name' \
          '--empty[generate empty config]' \
          '--print[print config]' \
          '--system-images[print system images]' \
          '--all[list all options]' && ret=0
        ;;
    esac
    ;;
esac

return ret
