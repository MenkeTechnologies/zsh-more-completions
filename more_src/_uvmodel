#compdef uvmodel
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/uvmodel.html
# MIRIAD uvmodel - operate on visibility data using a model

local ret=1

_arguments -s -S \
  'vis=[input visibility data file]:vis:_files' \
  'model=[input model cube (Jy/pixel)]:model:_files' \
  'select=[uv selection subcommands]:select' \
  'options=[add,subtract,multiply,divide,replace,flag,unflag,mosaic,mfs,zero]:options' \
  'clip=[pixel threshold level]:clip' \
  'flux=[point source flux in Jy]:flux' \
  'offset=[RA and DEC offsets in arcsec]:offset' \
  'line=[visibility line type]:line' \
  'sigma=[threshold in sigmas for flagging]:sigma' \
  'out=[output visibility file name]:out:_files' \
  '*:visibility data:_files' && ret=0

return ret
