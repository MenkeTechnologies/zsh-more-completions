#compdef pslCat
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: concatenate psl files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-check[parse input, detect more errors but slower]' \
  '-nohead[omit psl header]' \
  '-dir[files are directories, concatenate all in dirs]' \
  '-out=[put output to file rather than stdout]:file:_files' \
  '-ext=[limit directory files to this extension]:ext:' \
  '*:psl file:_files' && ret=0

return ret
