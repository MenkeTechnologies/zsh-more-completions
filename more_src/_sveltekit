#compdef svelte-kit

# Zsh completion for SvelteKit internal CLI

_sveltekit() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'sync:synchronize generated files'
    'env:read environment variables'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'svelte-kit command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        sync)
          _arguments -s -S \
            '--mode=[Vite mode]:mode:(development production)' \
            && ret=0
          ;;
        env)
          _arguments -s -S \
            '--mode=[Vite mode]:mode:(development production)' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_sveltekit "$@"
