#compdef convert2blastmask
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# BLAST+ tool to convert lowercase-masked FASTA into BLAST mask data
# Flags from NCBI C++ Toolkit src/app/blastdb/convert2blastmask.cpp

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-in=[input file name (- for stdin)]:file:_files' \
  '-out=[output file name (- for stdout)]:file:_files' \
  '-outfmt=[output file format]:format:(maskinfo_asn1_bin maskinfo_asn1_text seqloc_asn1_bin seqloc_asn1_text)' \
  '-masking_algorithm=[masking algorithm name]:algo:(dust seg windowmasker repeat other)' \
  '-masking_options=[free-text options used to create the masking]:options:' \
  '-parse_seqids[parse Seq-ids in FASTA input]' && ret=0

return ret
