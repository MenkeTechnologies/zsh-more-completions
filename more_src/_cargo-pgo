#compdef cargo-pgo

# Zsh completion for cargo-pgo (profile-guided optimization for Rust)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'build:Build with PGO instrumentation or optimization'
      'run:Run PGO-instrumented binary to gather profile data'
      'test:Run tests with PGO instrumentation'
      'bench:Run benchmarks with PGO instrumentation'
      'optimize:Build with PGO optimization using gathered profiles'
      'instrument:Build with PGO instrumentation'
      'bolt:Optimize with BOLT post-link optimizer'
      'info:Display PGO configuration info'
    )
    _describe -t commands 'cargo-pgo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build|optimize|instrument)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-p+[Package to build]:package' \
          '--package=[Package to build]:package' \
          '--release[Build in release mode]' \
          '--target=[Target triple]:target' \
          '--features=[Features to enable]:features' \
          '--all-features[Activate all available features]' \
          '--no-default-features[Do not activate default features]' \
          '--profile-dir=[Directory for profile data]:dir:_directories' \
          '-v[Verbose output]' \
          '--verbose[Verbose output]' \
          '*:args' && ret=0
        ;;
      run|test|bench)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '-p+[Package]:package' \
          '--package=[Package]:package' \
          '--release[Use release mode]' \
          '--target=[Target triple]:target' \
          '--features=[Features to enable]:features' \
          '*:args' && ret=0
        ;;
      bolt)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:subcommand:(instrument optimize)' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
