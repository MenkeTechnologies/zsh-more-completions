#compdef cargo-pgo
# Documentation: https://github.com/Kobzol/cargo-pgo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for cargo-pgo (profile-guided optimization for Rust)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-h[Print help]' \
  '--help[Print help]' \
  '-V[Print version]' \
  '--version[Print version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'info:Check PGO/BOLT environment setup'
      'instrument:Build a binary instrumented for PGO'
      'build:Build instrumented or optimized binary'
      'run:Run an instrumented binary to gather profiles'
      'test:Generate profiles via tests'
      'bench:Generate profiles via benchmarks'
      'optimize:Build PGO-optimized binary from gathered profiles'
      'bolt:BOLT post-link optimizer subcommands'
    )
    _describe -t commands 'cargo-pgo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      build|optimize|instrument|run|test|bench)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '*:cargo args' && ret=0
        ;;
      bolt)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' \
          '1:subcommand:(build optimize)' \
          '--with-pgo[Combine BOLT optimization with existing PGO profiles]' \
          '*:cargo args' && ret=0
        ;;
      *)
        _arguments -s -S \
          '-h[Print help]' \
          '--help[Print help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
