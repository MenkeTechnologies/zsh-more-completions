#compdef cvc5

_arguments -s \
  '(-i --incremental)'{-i,--incremental}'[incremental solving]' \
  '(-L --input-language)'{-L,--input-language=}'[input language]:lang:(smt2 sygus2 tptp)' \
  '*'{-o,--output=}'[output tag]:tag:' \
  '--output-language=[output format]:lang:' \
  '(-m --produce-models)'{-m,--produce-models}'[generate models]' \
  '--produce-proofs[generate proofs]' \
  '--produce-unsat-cores[generate unsat cores]' \
  '--check-models[verify model correctness]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '(-s --seed)'{-s,--seed=}'[random seed]:n:' \
  '--tlimit=[time limit ms]:ms:' \
  '--rlimit=[resource limit]:n:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:input file:_files -g "*.(smt2|sy|p)"'
