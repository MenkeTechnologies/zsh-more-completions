#compdef jar
# _jar — OpenJDK jar archive tool (Oracle/OpenJDK, Java); custom argparse
# upstream: https://github.com/openjdk/jdk

_jar() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-extra[show extra help]' \
        '--version[show version]' \
        '-c[create archive]' \
        '--create[create archive]' \
        '-i+[generate index info]:file:_files' \
        '--generate-index=+[generate index info]:file:_files' \
        '-t[list archive contents]' \
        '--list[list archive contents]' \
        '-u[update archive]' \
        '--update[update archive]' \
        '-x[extract from archive]' \
        '--extract[extract from archive]' \
        '-d[describe module]' \
        '--describe-module[describe module]' \
        '--validate[validate archive]' \
        '-C+[change to dir]:dir:_files -/' \
        '-f+[archive file]:file:_files -g "*.(jar|war|ear|zip)"' \
        '--file=+[archive file]:file:_files -g "*.(jar|war|ear|zip)"' \
        '-0[no compression]' \
        '--no-compress[no compression]' \
        '-m+[manifest file]:file:_files -g "*.mf MANIFEST.MF"' \
        '--manifest=+[manifest file]:file:_files -g "*.mf MANIFEST.MF"' \
        '-M[do not create manifest]' \
        '--no-manifest[do not create manifest]' \
        '-e+[main-class entry point]:str:' \
        '--main-class=+[main-class entry point]:str:' \
        '-n[normalize archive]' \
        '--normalize[normalize archive]' \
        '--module-version=+[module version]:ver:' \
        '--hash-modules=+[hash modules]:str:' \
        '-p+[module path]:list:_files' \
        '--module-path=+[module path]:list:_files' \
        '--do-not-resolve-by-default[do not resolve by default]' \
        '--warn-if-resolved=+[warn if resolved]:list:' \
        '--release=+[release version]:n:' \
        '-P[preserve files]' \
        '--no-validate[no validate]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[no manifest stamping with timestamps]' \
        '*:file:_files'
}

_jar "$@"
