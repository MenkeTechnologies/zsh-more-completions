#compdef bchctl
# _bchctl — Bitcoin Cash bchctl JSON-RPC client CLI for the bchd alternative Go-based Bitcoin Cash full-node implementation issuing getblockchaininfo getblock getbalance listunspent sendtoaddress generate slp queries (gcash team, Go); flag
# upstream: https://github.com/gcash/bchd

_bchctl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files -g "*.conf bchctl.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf bchctl.conf"' \
        '-s+[rpc server host:port]:str:' \
        '--rpcserver=+[rpc server host:port]:str:' \
        '-u+[rpc user]:str:' \
        '--rpcuser=+[rpc user]:str:' \
        '-P+[rpc password]:str:' \
        '--rpcpass=+[rpc password]:str:' \
        '--rpccert=+[ca cert file]:file:_files -g "*.cert *.pem"' \
        '--notls[no TLS]' \
        '--proxy=+[host:port]:str:' \
        '--proxyuser=+[user]:str:' \
        '--proxypass=+[password]:str:' \
        '--testnet[use testnet]' \
        '--testnet4[use testnet4]' \
        '--simnet[use simnet]' \
        '--regtest[use regtest]' \
        '--wallet[connect to wallet]' \
        '--skipverify[skip server cert verification]' \
        '-l[list commands]' \
        '--listcommands[list commands]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent sendtoaddress getnewaddress validateaddress dumpprivkey importprivkey generate generatetoaddress getrawtransaction sendrawtransaction getslpparsedscript checkslptoken getslptokenmetadata getslptxburns getslpmempooltxidsbyhash addnode getpeerinfo setgenerate help stop)'
}

_bchctl "$@"
