#compdef dav1d
# Documentation: dav1d -help (VideoLAN AV1 decoder)
# Source: AV1 reference decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version]' \
    '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output file (%n/%w/%h templates)]:file:_files' \
    '--demuxer=[force demuxer type]:name:(ivf section5 annexb)' \
    '--muxer=[force muxer type]:name:(md5 yuv yuv4mpeg2 null frame)' \
    '(-q --quiet)'{-q,--quiet}'[disable status messages]' \
    '--frametimes=[dump frame times to file]:file:_files' \
    '(-l --limit)'{-l+,--limit=}'[stop after N frames]:n:' \
    '(-s --skip)'{-s+,--skip=}'[skip first N frames]:n:' \
    '--realtime=-[limit framerate (optional fract override)]::fract:' \
    '--realtimecache=[realtime cache size]:n:' \
    '--threads=[number of threads (0 auto)]:n:' \
    '--framedelay=[max frame delay (0 default; 1 = low latency)]:n:' \
    '--filmgrain=[film-grain application 0/1]:n:(0 1)' \
    '--oppoint=[scalable AV1 operating point 0..31]:n:' \
    '--alllayers=[output all spatial layers 0/1]:n:(0 1)' \
    '--sizelimit=[stop if frame size exceeds limit]:n:' \
    '--strict=[abort on non-decoding standard violations 0/1]:n:(0 1)' \
    '--verify=[verify decoded MD5]:md5:' \
    '--cpumask=[restrict CPU instruction sets]:mask:(0 neon dotprod i8mm)' \
    '--negstride[use negative picture strides]' \
    '--outputinvisible=[output invisible alt-ref frames 0/1]:n:(0 1)' \
    '--inloopfilters=[in-loop filters]:str:(none deblock nodeblock cdef nocdef restoration norestoration all)' \
    '--decodeframetype=[frame types to decode]:str:(reference intra key all)' \
    && ret=0

return ret
