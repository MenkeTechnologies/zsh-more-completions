local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--threads=[concurrent threads (default #cpus)]:N:' \
    '--debug[enable debug logs]' \
    '--maximum-file-size=[max file size to process in KB (default 256)]:N:' \
    '--temp-directory=[directory to store repos/matches]:dir:_directories' \
    '--local=[local directory to scan recursively]:dir:_directories' \
    '--host-mount-path=[host mount path for path exclusions]:path:_directories' \
    '--config-path=[YAML config path]:file:_files' \
    '--rules-path=[YARA rules path (default /home/deepfence/usr)]:dir:_directories' \
    '--fail-warning[fail if compilation warning]' \
    '--enable-updater[download rules at runtime if not present]' \
    '--merge-configs[merge --config-path files into default config]' \
    '--image-name=[Docker image name+tag to scan for secrets]:image:' \
    '--multi-match[output multiple matches of same pattern in one file]' \
    '--max-multi-match=[max matches of same pattern per file (default 3)]:N:' \
    '--max-secrets=[max secrets to find per image/fs (default 1000)]:N:' \
    '--container-id=[ID of existing container to scan]:id:' \
    '--container-ns=[namespace of existing container]:ns:' \
    '--workers-per-scan=[concurrent workers per scan (default 1)]:N:' \
    '--inactive-threshold=[inactive scan threshold in seconds (default 600)]:N:' \
    '--output=[output format]:format:(json table)' \
    '--console-url=[Deepfence Management Console URL]:url:' \
    '--console-port=[Deepfence Management Console port (default 443)]:port:' \
    '--deepfence-key=[Deepfence key for auth]:key:' \
    '--fail-on-count=[exit 1 if total secrets >= N (default -1)]:N:' \
    '--fail-on-high-count=[exit 1 if high secrets >= N (default -1)]:N:' \
    '--fail-on-medium-count=[exit 1 if medium secrets >= N (default -1)]:N:' \
    '--fail-on-low-count=[exit 1 if low secrets >= N (default -1)]:N:' \
    '--socket-path=[gRPC server unix socket path]:file:_files' \
    && ret=0

return ret
