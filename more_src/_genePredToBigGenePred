#compdef genePredToBigGenePred
# UCSC kent: convert a genePred file to a bigGenePred input file

local ret=1

_arguments -s -S \
  '-known[input file is a genePred in knownGene format]' \
  '-score=[two column file mapping ids to scores]:file:_files' \
  '-geneNames=[three column file mapping ids to two gene names]:file:_files' \
  '-colors=[four column file mapping ids to r,g,b]:file:_files' \
  '-cds=[five column file mapping ids to cds status codes and exonFrames]:file:_files' \
  '-geneType=[two column file mapping ids to geneType]:file:_files' \
  '1:input genePred:_files' \
  '2:output file:_files' && ret=0

return ret
