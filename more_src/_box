#compdef box

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'artifacts:manage CommandBox artifacts cache'
  'cflint:run CFLint linter'
  'coldbox:ColdBox project commands'
  'config:manage CommandBox configuration'
  'contentbox:ContentBox project commands'
  'docbox:DocBox commands'
  'embeddedserver:embedded server commands'
  'exec:execute a command in a server'
  'forgebox:ForgeBox commands (install, search, publish)'
  'h:show help (alias for help)'
  'help:show help'
  'info:show CommandBox info'
  'init:initialize a package in current directory'
  'install:install a package'
  'list:list installed packages'
  'log:show server log'
  'outdated:show outdated packages'
  'package:package management commands'
  'recipe:run a recipe'
  'repl:start REPL'
  'run:execute a CFML script'
  'run-script:run a script defined in box.json'
  'search:search ForgeBox'
  'server:server management (start, stop, list, status, log)'
  'task:run a task runner'
  'testbox:TestBox testing commands'
  'tower:CommandBox Tower commands'
  'uninstall:uninstall a package'
  'update:update installed packages'
  'upgrade:upgrade CommandBox itself'
  'version:show version'
  'watch:watch files and run a script on change'
  'system-log:show CommandBox system log'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'box subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (server)
        _values 'server command' \
          'start' 'stop' 'list' 'status' 'log' 'console' \
          'restart' 'info' 'forget' 'open' 'show' && ret=0
        ;;
      (forgebox)
        _values 'forgebox command' \
          'install' 'search' 'publish' 'login' 'logout' \
          'whoami' 'register' 'unpublish' 'show' 'list' && ret=0
        ;;
      (package)
        _values 'package command' \
          'init' 'install' 'set' 'show' 'list' 'clear' \
          'update' && ret=0
        ;;
      (config)
        _values 'config command' 'set' 'show' 'clear' && ret=0
        ;;
      (install|run|run-script)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
