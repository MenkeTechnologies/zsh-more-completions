#compdef greasyspoon
# _greasyspoon — Greasyspoon ICAP server CLI (open-source ICAP server that rewrites HTTP responses / requests via JS or Java scripts; subcommands: start, stop, status, reload, debug, install, uninstall, version, help; -c config file, -p pidfile, -l log file, -d debug, --port listen port, --java-home JDK path, -V version, -h help)
# upstream: https://sourceforge.net/projects/greasyspoon/
# Subcommands from greasyspoon bin/greasyspoon on tip.

_greasyspoon() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-l+[log file]:file:_files' \
        '-d[debug]' \
        '--port+[port]:port:' \
        '--java-home+[JDK dir]:dir:_files -/' \
        '1::command:(start stop status reload debug install uninstall version)'
}

_greasyspoon "$@"
