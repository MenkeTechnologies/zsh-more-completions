#compdef codedown
# Documentation: https://github.com/earldouglas/codedown
# codedown - extract code blocks from Markdown by language

local ret=1

_arguments -s -S \
  '--separator=[string inserted between code blocks]:separator:' \
  '--section=[extract code from a section number or heading]:section:' \
  '*:language:' && ret=0

return ret
