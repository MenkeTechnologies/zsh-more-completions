#compdef runpod-cli runpod
# _runpod-cli — RunPod runpod-cli CLI command-line frontend wrapping the RunPod cloud GPU compute platform REST GraphQL API managing pods endpoints templates network-volumes ssh launching deploying serverless functions GPU-instances on-demand spot interruptible community-cloud secure-cloud Stable-Diffusion-LLM AI inference (RunPod team, Go); cobra
# upstream: https://www.runpod.io/

_runpod-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'pod:pod operations'
        'template:template operations'
        'endpoint:endpoint operations'
        'network-volume:network volume operations'
        'ssh:SSH operations'
        'gpus:list available GPUs'
        'project:project operations'
        'serverless:serverless operations'
        'event:event operations'
        'metric:metric operations'
        'image:image operations'
        'image-build:build a serverless image'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--secure-cloud[secure cloud]' \
        '--community-cloud[community cloud]' \
        '--spot[spot instance]' \
        '--gpu-count=+[N]:n:' \
        '--gpu-type=+[type]:str:' \
        '--memory=+[GB]:n:' \
        '--vcpu=+[N]:n:' \
        '--container-disk=+[GB]:n:' \
        '--volume-disk=+[GB]:n:' \
        '--ports=+[list]:str:' \
        '--env=+[k=v]:str:' \
        '--image-name=+[image]:str:' \
        '--name=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'runpod-cli subcommand' sub ;;
        args)
            case $words[1] in
                pod|template|endpoint|network-volume|project|serverless|event|metric|image) _arguments '1:op:(list get create update delete start stop restart resume terminate logs status connect)' '*:id:' ;;
                ssh) _arguments '*:pod id:' ;;
            esac
            ;;
    esac
}

_runpod-cli "$@"
