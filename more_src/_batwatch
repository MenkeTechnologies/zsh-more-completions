#compdef batwatch
# Documentation: https://github.com/eth-p/bat-extras/blob/master/doc/batwatch.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# batwatch (bat-extras): watch files / run commands with bat output

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'[watch a file for changes]:file:_files' \
  '(-x --command)'{-x,--command}'[execute a command on an interval]' \
  '--watcher=[file watcher backend]:backend:(entr poll)' \
  '--interval=[poll interval seconds]:seconds' \
  '--clear[clear screen before output (default)]' \
  '--no-clear[do not clear screen before output]' \
  '--color[force colored output]' \
  '--no-color[disable colored output]' \
  '*:file:_files' && ret=0

return ret
