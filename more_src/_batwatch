#compdef batwatch

# Zsh completion for batwatch (bat-extras - watch files with bat)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--paging=[paging mode]:mode:(auto always never)' \
  '--color=[colorize output]:when:(auto always never)' \
  '--theme=[bat theme]:theme' \
  '--style=[output style]:style' \
  '-n[poll interval]:seconds' \
  '--interval=[poll interval]:seconds' \
  '--watcher=[watcher backend]:backend:(auto poll entr)' \
  '--command[run as command]' \
  '*:file:_files' && ret=0

return ret
