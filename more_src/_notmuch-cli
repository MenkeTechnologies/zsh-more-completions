#compdef notmuch-cli
# _notmuch-cli — Carl Worth notmuch fast tag-based mail indexer/searcher CLI alias (notmuch team, C); custom argparse
# upstream: https://git.notmuchmail.org/git/notmuch

_notmuch-cli() {
    local -a sub=(
        'setup:configure notmuch'
        'help:show help'
        'new:incorporate new messages'
        'address:output addresses'
        'config:get/set config'
        'count:count matching messages'
        'dump:dump tags database'
        'emacs-mua:start emacs notmuch interface'
        'git:tag synchronization via git'
        'insert:add a message to the database'
        'reindex:reindex matching messages'
        'reply:create a reply template'
        'restore:restore tags from dump'
        'search:search messages'
        'show:show messages matching query'
        'tag:add/remove tags'
        'compact:compact database'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--uuid=+[uuid]:str:' \
        '--config=+[config file]:file:_files -g ".notmuch-config*"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'notmuch subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments \
                    '--format=+[format]:f:(json sexp text text0)' \
                    '--format-version=+[version]:n:' \
                    '--output=+[output]:o:(summary threads messages files tags addresses senders recipients)' \
                    '--sort=+[sort]:s:(newest-first oldest-first)' \
                    '--offset=+[offset]:n:' \
                    '--limit=+[limit]:n:' \
                    '--exclude=+[mode]:m:(true false all flag)' \
                    '--duplicate=+[n]:n:' \
                    '*:query:' ;;
                show) _arguments \
                    '--entire-thread=+[bool]:b:(true false)' \
                    '--format=+[format]:f:(text json sexp mbox raw)' \
                    '--format-version=+[version]:n:' \
                    '--part=+[n]:n:' \
                    '--verify[verify signatures]' \
                    '--decrypt=+[mode]:m:(true false nostash auto)' \
                    '--exclude=+[mode]:m:(true false)' \
                    '--body=+[bool]:b:(true false)' \
                    '--include-html[include html]' \
                    '--duplicate=+[n]:n:' \
                    '*:query:' ;;
                tag) _arguments \
                    '--remove-all[remove all tags]' \
                    '--input=+[file]:file:_files' \
                    '--batch[batch mode]' \
                    '*:tag specs and query:' ;;
                count) _arguments \
                    '--output=+[mode]:m:(messages threads files)' \
                    '--exclude=+[mode]:m:(true false all)' \
                    '--lastmod[show last mod]' \
                    '--batch[batch mode]' \
                    '--input=+[file]:file:_files' \
                    '*:query:' ;;
                dump) _arguments \
                    '--gzip[compress]' \
                    '--format=+[format]:f:(sup batch-tag)' \
                    '--include=+[mode]:m:(all config properties tags)' \
                    '--output=+[file]:file:_files' \
                    '*:query:' ;;
                restore) _arguments \
                    '--input=+[file]:file:_files' \
                    '--format=+[format]:f:(auto sup batch-tag)' \
                    '--accumulate[accumulate]' \
                    '--include=+[mode]:m:(all config properties tags)' ;;
                reply) _arguments \
                    '--reply-to=+[mode]:m:(all sender)' \
                    '--format=+[format]:f:(default json sexp headers-only)' \
                    '--format-version=+[version]:n:' \
                    '--decrypt=+[mode]:m:(true false nostash auto)' \
                    '*:query:' ;;
                new) _arguments \
                    '--no-hooks[no hooks]' \
                    '--quiet[quiet]' \
                    '--verbose[verbose]' \
                    '--full-scan[full scan]' ;;
                config) _arguments \
                    '1:cmd:(get set list)' \
                    '2:key:' \
                    '*:value:' ;;
            esac
            ;;
    esac
}

_notmuch-cli "$@"
