#compdef xiu
# Documentation: https://github.com/harlanc/xiu/tree/master/application/xiu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Added: -h/--help, -V/--version (documented upstream).

# xiu: RTMP / RTSP / HLS / WebRTC / HTTP-FLV live media server

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-V,--version}'[display version]' \
  '(-c --config)'{-c+,--config=}'[config TOML path]:file:_files' \
  '(-r --rtmp)'{-r+,--rtmp=}'[RTMP listen port]:port:' \
  '(-t --rtsp)'{-t+,--rtsp=}'[RTSP listen port]:port:' \
  '(-w --webrtc)'{-w+,--webrtc=}'[WebRTC/WHIP/WHEP port]:port:' \
  '(-f --httpflv)'{-f+,--httpflv=}'[HTTP-FLV port]:port:' \
  '(-s --hls)'{-s+,--hls=}'[HLS port]:port:' \
  '(-l --log)'{-l+,--log=}'[log level]:level:(trace debug info warn error)' && return 0
