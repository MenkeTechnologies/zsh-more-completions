#compdef xiu

# https://github.com/harlanc/xiu — RTMP / RTSP / HLS / WebRTC live server

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[config TOML path]:file:_files' \
  '(-r --rtmp)'{-r,--rtmp}'=[RTMP listen port]:port:' \
  '(-t --rtsp)'{-t,--rtsp}'=[RTSP listen port]:port:' \
  '(-w --webrtc)'{-w,--webrtc}'=[WebRTC/WHIP/WHEP port]:port:' \
  '(-f --httpflv)'{-f,--httpflv}'=[HTTP-FLV port]:port:' \
  '(-s --hls)'{-s,--hls}'=[HLS port]:port:' \
  '(-l --log)'{-l,--log}'=[log level]:level:(trace debug info warn error)' && return 0
