#compdef pyright pyright-langserver
# Documentation: https://man.archlinux.org/search?q=pyright
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

case $service in
  (pyright)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '--createstub+[create type stub for module]:module:' \
      '--dependencies[show dependencies]' \
      '(-l --level)'{-l+,--level=}'[diagnostic level]:l:(error warning information)' \
      '--ignoreexternal[ignore external imports]' \
      '--lib[use library code]' \
      '--outputjson[JSON output]' \
      '(-p --project)'{-p+,--project=}'[project file or dir]:project:_files' \
      '(--pythonpath)--pythonpath=[Python path]:dir:_files -/' \
      '(--pythonplatform)--pythonplatform=[platform]:p:(Linux Darwin Windows All)' \
      '(--pythonversion)--pythonversion=[Python version]:v:(3.0 3.1 3.2 3.3 3.4 3.5 3.6 3.7 3.8 3.9 3.10 3.11 3.12 3.13)' \
      '--skipunannotated[skip unannotated]' \
      '(-s --stats)'{-s,--stats}'[print stats]' \
      '(-t --typeshedpath)'{-t+,--typeshedpath=}'[typeshed path]:dir:_files -/' \
      '(-v --venvpath)'{-v+,--venvpath=}'[venv path]:dir:_files -/' \
      '(-w --watch)'{-w,--watch}'[watch mode]' \
      '(--warnings)--warnings[fail on warnings]' \
      '(--verifytypes)--verifytypes=[verify types in package]:pkg:' \
      '*: :_files -g "*.py"' && ret=0 ;;
  (pyright-langserver)
    _arguments -C \
      '--stdio[use stdio]' \
      '--node-ipc[use node IPC]' \
      '--socket=[socket]:port:' \
      '--pipe=[pipe]:name:' \
      '*: :' && ret=0 ;;
esac

return ret
