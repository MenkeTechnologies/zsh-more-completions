#compdef kube-linter
# _kube-linter-bin — StackRox kube-linter (Red Hat, Go); static analysis of k8s manifests and Helm charts
# upstream: https://github.com/stackrox/kube-linter

_kube-linter-bin() {
    local -a sub=(
        'checks:show checks'
        'lint:lint manifests'
        'templates:show check templates'
        'completion:print shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kube-linter subcommand' sub ;;
        args)
            case $words[1] in
                lint) _arguments \
                    '--config+[config file]:file:_files' \
                    '--include+[include check]:check:' \
                    '--exclude+[exclude check]:check:' \
                    '--add-all-built-in[add all built-in checks]' \
                    '--do-not-auto-add-defaults[do not auto-add defaults]' \
                    '--format+[output format]:fmt:(plain json sarif markdown)' \
                    '-o+[output format]:fmt:' \
                    '--verbose[verbose]' \
                    '--fail-if-no-objects-found[fail if no objects found]' \
                    '--fail-on-invalid-resource[fail on invalid resource]' \
                    '--ignore-paths+[ignore paths]:paths:' \
                    '*:path:_files' ;;
                checks) _arguments \
                    '1:checks cmd:(list)' \
                    '-o+[output format]:fmt:(plain json markdown)' \
                    '--format+[output format]:fmt:' ;;
                templates) _arguments \
                    '1:templates cmd:(list)' \
                    '-o+[output format]:fmt:(plain json markdown)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kube-linter-bin "$@"
