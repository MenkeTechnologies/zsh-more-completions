#compdef castget
# Documentation: https://castget.johndal.com/castget.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# castget(1) man page; Homebrew Formula/c/castget.rb.

local ret=1
_arguments -s \
  '(-c --catchup)'{-c,--catchup}'[catch up and exit]' \
  '(-l --list)'{-l,--list}'[list pending enclosures]' \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-n --new-only)'{-n,--new-only}'[only never-fetched channels]' \
  '(-1 --first-only)'{-1,--first-only}'[only newest item per channel]' \
  '(-f --filter)'{-f+,--filter=}'[URL regex filter]:pattern:' \
  '(-r --resume)'{-r,--resume}'[resume partial downloads]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[connection debug]' \
  '(-p --progress-bar)'{-p,--progress-bar}'[progress bar]' \
  '(-C --rcfile)'{-C+,--rcfile=}'[config file]:rc:_files' \
  '*::channel id:_default' && ret=0
return ret
