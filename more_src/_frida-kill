#compdef frida-kill
# _frida-kill — Frida process killer (Ole André V. Ravnås); terminates a target on a frida-server device
# upstream: https://github.com/frida/frida

_frida-kill() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-D --device)'{-D,--device}'+[device id]:device:' \
        '(-U --usb)'{-U,--usb}'[USB device]' \
        '(-R --remote)'{-R,--remote}'[remote frida-server]' \
        '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
        '*:PID or name:'
}

_frida-kill "$@"
