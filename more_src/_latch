#compdef latch
# Documentation: https://docs.latch.bio/subcommands.html
# Latch SDK CLI for building and registering bioinformatics workflows

local ret=1

_arguments -s -S \
  '(-h --help)--help[show help]' \
  '1:command:((
    init\:"initialize a new workflow project"
    register\:"register a workflow with the Latch platform"
    dockerfile\:"generate a Dockerfile for a workflow"
    get-params\:"generate a parameters file for a workflow"
    launch\:"launch a registered workflow"
    get-wf\:"list registered workflows"
    open\:"open a remote file in the local editor"
    cp\:"copy files between local and Latch Data"
    ls\:"list files in Latch Data"
    test-data\:"manage workflow test data"
    exec\:"execute a command in a running task container"
    preview\:"preview a workflow interface locally"
    workspace\:"switch the active workspace"
    get-executions\:"view workflow executions in a terminal UI"
    develop\:"start an interactive development session"
  ))' \
  '*::arg:_files' && ret=0

return ret
