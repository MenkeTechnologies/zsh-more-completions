#compdef wezterm-cli2 wezterm2
# _wezterm-cli2 — Wez Furlong WezTerm wezterm-cli2 CLI command-line frontend wrapping the WezTerm modern GPU-accelerated cross-platform terminal emulator and multiplexer written in Rust originally Wez Furlong now WezTerm community ligature support Image-Protocol-iTerm2-Sixel Hyperlinks SSH-mux multiplexer-domains true-color font-fallback nerd-font-icons internal-multiplexer remote-domain-mosh-WSL plugin-support OSC52 clipboard kiosk-mode start ssh serial connect imgcat ls-fonts show-keys cli list set-tab-title set-window-title spawn split-pane kill-pane move-pane-to-new-tab get-text get-pane-direction (Wez Furlong WezTerm community team, Rust); clap
# upstream: https://wezfurlong.org/wezterm/

_wezterm-cli2() {
    local -a sub=(
        'start:Start the GUI'
        'ssh:Connect via SSH'
        'serial:Connect to a serial port'
        'connect:Connect to a multiplexer'
        'ls-fonts:List system fonts'
        'show-keys:Show key bindings'
        'imgcat:Display image inline'
        'set-working-directory:Show OSC 7 for current directory'
        'cli:Tools for working with the running daemon'
        'shell-completion:Generate shell completion scripts'
        'help:show help'
        'version:show version'
        'replay:Replay an asciinema file'
        'record:Record a session'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-file=+[file]:file:_files -g "*.lua"' \
        '-n[skip config file]' \
        '--skip-config[skip config]' \
        '--config=+[key=value]:str:' \
        '*--config=+[key=value]:str:' \
        '--always-new-process[always new process]' \
        '--new-tab[new tab]' \
        '--position=+[pos]:str:' \
        '--no-auto-connect[no auto connect]' \
        '--domain=+[name]:str:' \
        '--cwd=+[dir]:dir:_files -/' \
        '-e+[shell]:_command_names' \
        '--prog=+[cmd]:str:' \
        '--pane-id=+[id]:str:' \
        '--workspace=+[name]:str:' \
        '--mux-server-unix-socket-path=+[file]:_files' \
        '--port=+[port]:n:' \
        '--baud=+[N]:n:' \
        '--name=+[name]:str:' \
        '--class=+[name]:str:' \
        '--height=+[N]:n:' \
        '--width=+[N]:n:' \
        '--no-frame[no window frame]' \
        '--frame[window frame]' \
        '--print-config[print config]' \
        '--show-startup-tip[show startup tip]' \
        '--list[list domains]' \
        '--username=+[name]:_users' \
        '--password=+[password]:str:' \
        '--scroll-mode[scroll mode]' \
        '--no-cmdline[no cmdline]' \
        '--text-only[text only]' \
        '--start-cwd=+[dir]:dir:_files -/' \
        '--font-size=+[N]:n:' \
        '--check-update[check for updates]' \
        '--no-check-update[no check update]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wezterm subcommand' sub ;;
        args)
            case $words[1] in
                cli) _arguments '1:op:(list list-clients proxy tlscreds spawn split-pane send-text get-text get-pane-direction kill-pane move-pane-to-new-tab activate-tab activate-pane-direction set-tab-title set-window-title set-pane-title rename-workspace activate-tab-relative activate-window-relative)' '*:arg:' ;;
                ssh) _arguments '*:host:_hosts' ;;
                connect) _arguments '*:domain:' ;;
                imgcat|replay) _arguments '*:file:_files' ;;
                shell-completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
                start) _arguments '*:command:_command_names' ;;
            esac
            ;;
    esac
}

_wezterm-cli2 "$@"
