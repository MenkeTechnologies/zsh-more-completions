#compdef kubectl-node-restart
# kubectl-node-restart (krew plugin): restart a Kubernetes node gracefully
# https://github.com/mnlsr/kubectl-node-restart

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--force[force restart without draining]' \
  '--grace-period=[pod termination grace period]:seconds' \
  '--timeout=[drain timeout]:duration' \
  '1:node name'
