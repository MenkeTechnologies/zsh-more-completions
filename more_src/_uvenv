#compdef uvenv
# _uvenv — pipx for uv (Python venv app manager) (robinvandernoord/uvenv)
# upstream: https://github.com/robinvandernoord/uvenv
# Subcommands from src/cli.rs (clap).

_uvenv() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--generate=[print shell completion script]:shell:(bash zsh fish powershell elvish)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_uvenv_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                list)
                    _arguments \
                        '(-s --short -v --verbose --json)'{-s,--short}'[short output]' \
                        '(-v --verbose -s --short)'{-v,--verbose}'[verbose output]' \
                        '--json[JSON output]' \
                        '--venv-names[show venv names instead of packages]'
                    ;;
                setup)
                    _arguments \
                        '--skip-ensurepath[do not update $PATH in shell rc]' \
                        '--skip-completions[do not enable completions in shell rc]' \
                        '--skip-activate[do not enable `uvenv activate` in shell rc]' \
                        '(-f --force)'{-f,--force}'[setup features without checking previous install]'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_uvenv_commands] )) ||
_uvenv_commands() {
    local -a commands
    commands=(
        'setup:install / configure uvenv into the shell'
        'list:list installed uvenv environments'
        'install:install a Python package into its own venv'
        'create:create a fresh empty managed venv'
        'activate:print activation snippet for a managed venv'
        'upgrade:upgrade a managed package'
        'upgrade-all:upgrade every managed package'
        'uninstall:remove a managed package'
        'uninstall-all:remove every managed package'
        'reinstall:reinstall a managed package'
        'reinstall-all:reinstall every managed package'
        'inject:inject extra packages into a managed venv'
        'uninject:remove injected packages from a managed venv'
        'check:doctor / diagnose the uvenv setup'
        'run:run a one-off command in an ephemeral venv (uvx)'
        'runuv:run uv in a managed venv context'
        'runpip:run pip in a managed venv context'
        'runpython:run python in a managed venv context'
        'freeze:freeze the managed environment list'
        'thaw:restore managed environments from a freeze file'
        'ensurepath:ensure uvenv binaries are on $PATH'
        'completions:print shell completions'
        'self:uvenv self-management (update / link / changelog / migrate / info / version)'
    )
    _describe -t commands 'uvenv command' commands
}

_uvenv "$@"
