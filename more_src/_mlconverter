#compdef mlconverter
# Documentation: https://docs.generic-mapping-tools.org/latest/
# GMT supplements/gsfml — convert magnetic lineation picks to crustal ages

local ret=1

_arguments -s \
  '-A[append metadata as additional output columns]' \
  '-G+[generate extended OGR/GMT table with crustal age]:opt:_default' \
  '-I+[specify FZ identifier]:id:_default' \
  '-T+[magnetic time scale c|g|o|s]:scale:(c g o s)' \
  '-Z+[quality index thresholds]:opts:_default' \
  '*-V[verbose (stackable)]' \
  '-bo+[binary output format]:format:_default' \
  '-do+[replace NaN output with nodata]:nodata:_default' \
  '-i+[input column selection]:cols:_default' \
  '-o+[output column selection]:cols:_default' \
  '-q+[row/data limits]:limits:_default' \
  '*:input table:_files' \
  && ret=0

return ret
