#compdef calcif2
# Documentation: https://difx.readthedocs.io/en/latest/sources/difx_programs.html
# DiFX: compute delay model (.im) files from .calc files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage information and exit]' \
  '(-a --all)'{-a,--all}'[run on all .calc files in current directory]' \
  '*'{-v,--verbose}'[print more verbose logging/debug info]' \
  '(-q --quiet)'{-q,--quiet}'[print less verbose logging/debug info]' \
  '(-f --force)'{-f,--force}'[rerun even if output files exist and are current]' \
  '(-n --noaber)'{-n,--noaber}'[do not perform aberration u,v,w corrections]' \
  '(-F --fit)'{-F,--fit}'[calculate more samples and perform a fit]' \
  '(-z --allow-neg-delay)'{-z,--allow-neg-delay}'[do not zero negative delays]' \
  '(-A --noatmos)'{-A,--noatmos}'[do not include atmosphere in u,v,w calculation]' \
  '(-s --server)'{-s,--server}'[connect to server]:server:_hosts' \
  '(-o --order)'{-o,--order}'[make polynomials with order+1 terms]:order' \
  '(-i --interval)'{-i,--interval}'[make polynomial every int seconds]:interval' \
  '--override-version[ignore difx version clashes]' \
  '*:calc file:_files -g "*.calc"' && ret=0

return ret
