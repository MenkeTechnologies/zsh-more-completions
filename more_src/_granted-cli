#compdef granted-cli
# Documentation: https://github.com/common-fate/granted
# Documentation: https://github.com/common-fate/granted/blob/main/cmd/granted/main.go
# Documentation: https://github.com/common-fate/granted/blob/main/pkg/granted/entrypoint.go
# Reference accessed: 2026-05-27
# Verified: upstream pkg/granted/entrypoint.go GetCliApp() Commands list
# granted-cli is an alias for the granted binary; mirrors granted subcommands

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'browser:view or change the browser granted uses to open cloud consoles'
  'settings:manage granted settings'
  'completion:generate shell completion scripts'
  'token:(deprecated) use sso-tokens'
  'sso-tokens:manage AWS SSO tokens stored in the keyring'
  'uninstall:remove all granted configuration'
  'sso:manage local AWS config from AWS SSO info'
  'credentials:manage secure IAM credentials'
  'credential-process:export AWS session credentials via credential_process'
  'profile-registry:manage profile registries'
  'console:generate AWS console URL from current credentials'
  'cache:manage cached credentials in secure storage'
  'doctor:diagnose the granted installation'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[log debug messages]' \
  '--aws-config-file=[path to AWS config file]:file:_files' \
  '1: :->subcommand' \
  '*::: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'granted subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (browser)
        local -a _browser_sub
        _browser_sub=(
          'set:change the default browser'
          'set-sso:change the browser used for SSO flows'
        )
        _arguments -s -S \
          '1: :->bsub' \
          '*::: :->bargs' && ret=0
        case $state in
          (bsub) _describe -t bsub 'browser subcommand' _browser_sub && ret=0 ;;
          (bargs)
            _arguments -s -S \
              '(-b --browser)'{-b+,--browser=}'[browser name]:browser:(firefox chrome chromium brave edge arc safari stdout firefoxstdpath waterfox custom)' \
              '(-p --path)'{-p+,--path=}'[browser binary path]:path:_files' && ret=0
            ;;
        esac
        ;;
      (cache)
        local -a _cache_sub
        _cache_sub=(
          'list:list currently cached credentials'
          'clear:clear cached credentials from secure storage'
        )
        _arguments -s -S \
          '1: :->csub' \
          '*::: :->cargs' && ret=0
        case $state in
          (csub) _describe -t csub 'cache subcommand' _cache_sub && ret=0 ;;
          (cargs)
            _arguments -s -S \
              '--all[apply to all cached credentials]' \
              '--storage=[secure storage type]:storage:' && ret=0
            ;;
        esac
        ;;
      (completion)
        _arguments -s -S \
          '(-s --shell)'{-s+,--shell=}'[target shell]:shell:(fish zsh tcsh bash)' && ret=0
        ;;
      (console)
        _arguments -s -S \
          '--service=[AWS service]:service:' \
          '--region=[AWS region]:region:' \
          '--destination=[console destination URL]:url:' \
          '--url[print URL to stdout instead of launching browser]' \
          '--firefox[generate firefox container URL]' \
          '--color=[firefox container tab color]:color:' \
          '--icon=[firefox container tab icon]:icon:' \
          '--container-name=[firefox container name]:name:' \
          '*--browser-launch-template-arg=[extra browser launch template arg key=value]:arg:' && ret=0
        ;;
      (credential-process)
        _arguments -s -S \
          '--profile=[AWS profile]:profile:' \
          '--url=[SSO start URL]:url:' \
          '--window=[refresh window duration]:duration:' \
          '--auto-login[auto-open browser to log in if needed]' \
          '--no-cache[disable session credential caching]' && ret=0
        ;;
      (credentials)
        local -a _cred_sub
        _cred_sub=(
          'add:add IAM credentials to secure storage'
          'import:import plaintext IAM credentials from AWS credentials file'
          'update:update existing credentials in secure storage'
          'list:list profile names with credentials in secure storage'
          'remove:remove credentials from secure storage'
          'export-plaintext:export credentials to ~/.aws/credentials in plaintext'
          'rotate:rotate AWS access key for the profile'
          'import-from-env:import IAM credentials from environment variables'
        )
        _arguments -s -S \
          '1: :->credsub' \
          '*::: :->credargs' && ret=0
        case $state in
          (credsub) _describe -t credsub 'credentials subcommand' _cred_sub && ret=0 ;;
          (credargs)
            _arguments -s -S \
              '(-a --all)'{-a,--all}'[apply to all credentials]' \
              '--overwrite[overwrite existing profile]' \
              '*:profile:' && ret=0
            ;;
        esac
        ;;
      (sso)
        local -a _sso_sub
        _sso_sub=(
          'generate:print AWS config from SSO accounts/roles'
          'populate:populate AWS config file with SSO profiles'
          'login:interactive SSO login'
        )
        _arguments -s -S \
          '1: :->ssosub' \
          '*::: :->ssoargs' && ret=0
        case $state in
          (ssosub) _describe -t ssosub 'sso subcommand' _sso_sub && ret=0 ;;
          (ssoargs)
            _arguments -s -S \
              '--config=[SSO config section name]:name:' \
              '--prefix=[profile name prefix]:prefix:' \
              '--sso-region=[SSO region]:region:' \
              '*--source=[profile source]:source:(aws-sso)' \
              '*--sso-scope=[SSO scope]:scope:' \
              '--no-credential-process[do not generate credential_process integration]' \
              '--profile-template=[profile name template]:template:' \
              '--sso-browser-profile=[pre-existing browser profile for SSO login]:profile:' \
              '--use-device-code[force device code flow]' \
              '--prune[remove generated profiles that no longer exist]' && ret=0
            ;;
        esac
        ;;
      (sso-tokens|token)
        local -a _tok_sub
        _tok_sub=(
          'list:list saved access tokens'
          'expiry:list expiry status for saved tokens'
          'clear:remove a selected token from keyring'
        )
        _arguments -s -S \
          '1: :->toksub' \
          '*::: :->tokargs' && ret=0
        case $state in
          (toksub) _describe -t toksub 'token subcommand' _tok_sub && ret=0 ;;
          (tokargs)
            _arguments -s -S \
              '--url=[SSO URL filter]:url:' \
              '--json[print as JSON]' \
              '(-a --all)'{-a,--all}'[remove all saved tokens]' && ret=0
            ;;
        esac
        ;;
      (settings|profile-registry|uninstall|doctor)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '*: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
