#compdef cgconfig cgconfigparser
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/cgconfigparser.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --load)'{-l,--load}'+[config file]:file:_files -g "*.conf"' \
  '(-L --load-directory)'{-L,--load-directory}'+[config dir]:dir:_files -/' \
  '(-a --acl)'{-a,--acl}'+[acl owner uid:gid]:owner:' \
  '(-d --dperm)'{-d,--dperm}'+[dir perms]:mode:' \
  '(-f --fperm)'{-f,--fperm}'+[file perms]:mode:' \
  '(-s --tperm)'{-s,--tperm}'+[tasks file perms]:mode:' \
  '(-t --tacl)'{-t,--tacl}'+[tasks acl]:owner:' && ret=0

return ret
