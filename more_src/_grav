#compdef grav
# _grav — Grav CMS command-line interface (getgrav/grav)
# upstream: https://github.com/getgrav/grav
# Subcommands from system/src/Grav/Console/Application/GravApplication.php.

_grav() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[no messages]' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '(-n --no-interaction)'{-n,--no-interaction}'[do not ask questions]' \
        '--ansi[force ANSI output]' \
        '--no-ansi[disable ANSI output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'install:install dependencies (Composer)'
                'composer:run Composer commands'
                'sandbox:create base Grav system in webroot'
                'clean:run distribution cleaning chores'
                'cache:clear Grav cache'
                'cache-cleanup:clean up Grav cache'
                'backup:create a Grav backup'
                'new-project:create new Grav project'
                'scheduler:run the Grav scheduler'
                'security:run security checks'
                'logviewer:view Grav logs'
                'yamllinter:lint YAML files'
                'server:run built-in web server'
                'page-system-validator:validate the page system'
                'list:list all commands'
                'help:show command help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                server)
                    _arguments \
                        '--host=[bind host]:host:' \
                        '--port=[port]:port:'
                    ;;
                sandbox)
                    _arguments '--symlink[symlink instead of copying]' '1:destination:_files -/'
                    ;;
                cache)
                    _arguments '*:type:(all assets-only images-only cache-only tmp-only)'
                    ;;
            esac
            ;;
    esac
}

_grav "$@"
