#compdef chage-cli
# _chage-cli — shadow chage change user password expiry information CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_chage-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-d+[last day]:str:' \
        '--lastday=+[last day]:str:' \
        '-E+[expire date]:str:' \
        '--expiredate=+[expire date]:str:' \
        '-I+[inactive days]:n:' \
        '--inactive=+[inactive days]:n:' \
        '-l[list password aging info]' \
        '--list[list password aging info]' \
        '-m+[min days]:n:' \
        '--mindays=+[min days]:n:' \
        '-M+[max days]:n:' \
        '--maxdays=+[max days]:n:' \
        '-W+[warn days]:n:' \
        '--warndays=+[warn days]:n:' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '-i[show seconds]' \
        '--iso8601[show ISO 8601 dates]' \
        '*:user:_users'
}

_chage-cli "$@"
