#compdef xrdpwd
# Documentation: https://man.archlinux.org/search?q=xrdpwd
# Reference accessed: 2026-05-16

# xrdpwd: xrootd password/keystore admin
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[create keystore]' \
  '-u[update entry]' \
  '-d[delete entry]' \
  '-l[list entries]' \
  '-p[print formatted]' \
  '-f[keystore file]:file:_files' \
  '*::xrdpwd args:_files' && ret=0
return ret
