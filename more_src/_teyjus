#compdef tjcc tjlink tjdis tjsim tjparse tjdepend
# Documentation: https://teyjus.cs.umn.edu/old/language/teyjus_4.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (tjcc)
    _arguments \
      '(- *)'{-help,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-o --output)'{-o,--output}'+[output bytecode file]:file:_files' \
      '(-p --path)'{-p,--path}'+[add to search path]:dir:_files -/' \
      '--log[enable logging information]' \
      '*:module:_files -g "*.mod"' && ret=0 ;;
  (tjlink)
    _arguments \
      '(- *)'{-help,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-o --output)'{-o,--output}'+[output file]:file:_files' \
      '(-p --path)'{-p,--path}'+[add to search path]:dir:_files -/' \
      '*:module:_files -g "*.lpo"' && ret=0 ;;
  (tjsim)
    _arguments \
      '(- *)'{-help,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-p --path)'{-p,--path}'+[add to search path]:dir:_files -/' \
      '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
      '(-b --batch)'{-b,--batch}'[suppress system interaction]' \
      '(-k --heap)'{-k,--heap}'+[heap size (K)]:size:' \
      '*:module:' && ret=0 ;;
  (tjdis)
    _arguments \
      '(- *)'{-help,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-t --table)'{-t,--table}'[only print tables]' \
      '(-i --instr)'{-i,--instr}'[only print instructions]' \
      '*:object file:_files' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-help,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:file:_files' && ret=0 ;;
esac

return ret
