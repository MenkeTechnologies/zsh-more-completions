#compdef tjcc tjlink tjdis tjsim tjparse tjdepend
# Documentation: https://man.archlinux.org/search?q=tjcc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (tjcc)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-s --sim)'{-s,--sim}'[generate object code for simulator]' \
      '(-o --output)'{-o,--output}'+[output file]:file:_files' \
      '(-p --path)'{-p,--path}'+[search path]:dir:_files -/' \
      '*:module:_files -g "*.mod"' && ret=0 ;;
  (tjlink)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-o --output)'{-o,--output}'+[output file]:file:_files' \
      '(-p --path)'{-p,--path}'+[search path]:dir:_files -/' \
      '*:module:_files -g "*.lpo"' && ret=0 ;;
  (tjsim)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(-p --path)'{-p,--path}'+[search path]:dir:_files -/' \
      '(-s --source)'{-s,--source}'[load source modules]' \
      '(-q --query)'{-q,--query}'+[run query and exit]:goal:' \
      '*:module:_files -g "*.lp"' && ret=0 ;;
  (*)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '*:file:_files' && ret=0 ;;
esac

return ret
