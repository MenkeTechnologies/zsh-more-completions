#compdef exoscale

# Zsh completion for exoscale - Exoscale cloud CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-A --account)'{-A,--account}'[account name]:account' \
  '--config-file=[config file path]:config file:_files' \
  '(-O --output-format)'{-O,--output-format}'[output format]:format:(json table text)' \
  '--output-template=[output template]:template' \
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode]' \
  '(-z --zone)'{-z,--zone}'[zone]:zone' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'compute:Manage compute resources'
      'dbaas:Manage Database as a Service'
      'dns:Manage DNS'
      'iam:Manage IAM'
      'sks:Manage SKS (Scalable Kubernetes Service)'
      'sos:Manage Simple Object Storage'
      'storage:Manage storage'
      'config:Manage CLI configuration'
      'environment:Manage environments'
      'status:Show service status'
      'version:Show version'
    )
    _describe -t commands 'exoscale command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      compute)
        local -a subcmds=(
          'instance:Manage compute instances'
          'security-group:Manage security groups'
          'elastic-ip:Manage elastic IPs'
          'ssh-key:Manage SSH keys'
          'private-network:Manage private networks'
          'anti-affinity-group:Manage anti-affinity groups'
          'instance-pool:Manage instance pools'
          'instance-type:List instance types'
          'template:Manage templates'
          'snapshot:Manage snapshots'
          'reverse-dns:Manage reverse DNS'
        )
        _describe -t subcmds 'compute subcommand' subcmds && ret=0
        ;;
      dbaas)
        local -a subcmds=(
          'create:Create a database service'
          'delete:Delete a database service'
          'list:List database services'
          'show:Show database service details'
          'type:List database service types'
          'update:Update a database service'
          'migration:Manage database migrations'
        )
        _describe -t subcmds 'dbaas subcommand' subcmds && ret=0
        ;;
      dns)
        local -a subcmds=(
          'add:Add a DNS record'
          'create:Create a DNS domain'
          'delete:Delete a DNS record'
          'list:List DNS domains or records'
          'remove:Remove a DNS domain'
          'show:Show DNS domain details'
          'update:Update a DNS record'
        )
        _describe -t subcmds 'dns subcommand' subcmds && ret=0
        ;;
      iam)
        local -a subcmds=(
          'access-key:Manage access keys'
          'api-key:Manage API keys'
          'org-policy:Manage organization policy'
          'role:Manage IAM roles'
        )
        _describe -t subcmds 'iam subcommand' subcmds && ret=0
        ;;
      sks)
        local -a subcmds=(
          'create:Create an SKS cluster'
          'delete:Delete an SKS cluster'
          'kubeconfig:Get kubeconfig'
          'list:List SKS clusters'
          'nodepool:Manage node pools'
          'show:Show SKS cluster details'
          'upgrade:Upgrade an SKS cluster'
          'versions:List available versions'
          'authority-cert:Get authority certificate'
        )
        _describe -t subcmds 'sks subcommand' subcmds && ret=0
        ;;
      sos|storage)
        local -a subcmds=(
          'cors:Manage CORS configuration'
          'create:Create a bucket'
          'delete:Delete an object'
          'download:Download an object'
          'headers:Manage object headers'
          'list:List buckets or objects'
          'metadata:Manage object metadata'
          'presign:Generate presigned URL'
          'rb:Remove a bucket'
          'show:Show bucket or object details'
          'upload:Upload an object'
        )
        _describe -t subcmds 'storage subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
