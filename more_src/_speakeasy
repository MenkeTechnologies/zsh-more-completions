#compdef speakeasy

# Zsh completion for Speakeasy - API tooling

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:manage authentication'
  'generate:generate SDKs, docs, etc.'
  'lint:lint an OpenAPI document'
  'merge:merge OpenAPI documents'
  'overlay:manage OpenAPI overlays'
  'quickstart:start a new project interactively'
  'run:run Speakeasy workflows'
  'suggest:get suggestions to improve your OpenAPI spec'
  'validate:validate an OpenAPI document'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'speakeasy command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      generate)
        local -a gen_cmds=(
          'sdk:generate an SDK'
          'docs:generate documentation'
        )
        _describe -t commands 'generate command' gen_cmds && ret=0
        ;;
      validate)
        _arguments \
          '(-s --schema)'{-s+,--schema=}'[path to OpenAPI spec]:file:_files -g "*.{yaml,yml,json}"' \
          '(-h --help)'{-h,--help}'[show help]'
        ;;
      lint)
        _arguments \
          '(-s --schema)'{-s+,--schema=}'[path to OpenAPI spec]:file:_files -g "*.{yaml,yml,json}"' \
          '--ruleset=[ruleset file]:file:_files -g "*.{yaml,yml}"' \
          '(-h --help)'{-h,--help}'[show help]'
        ;;
    esac
    ;;
esac

return ret
