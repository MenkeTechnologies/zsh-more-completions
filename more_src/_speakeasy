#compdef speakeasy
# Documentation: https://www.speakeasy.com/docs/speakeasy-reference/cli/getting-started
# Reference accessed: 2026-05-21
# Verified: speakeasy.com CLI reference (getting-started, quickstart, run,
# lint). Top-level subcommands and lint/quickstart/run flag sets confirmed
# upstream. Removed earlier "generate sdk/docs" subcommand list (the
# upstream `speakeasy run` workflow handles SDK generation; no separate
# `generate sdk` subcommand documented).

# Zsh completion for Speakeasy - API tooling

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authentication management'
  'quickstart:guided new-SDK setup'
  'run:run workflows from .speakeasy/workflow.yaml'
  'lint:lint OpenAPI/Arazzo/config documents'
  'merge:merge OpenAPI documents'
  'overlay:manage OpenAPI overlays'
  'suggest:get OpenAPI improvement suggestions'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--logLevel=[log level]:level:(info warn error)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'speakeasy command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      quickstart)
        _arguments \
          '(-f --from)'{-f+,--from=}'[template selection]:template:' \
          '(-n --name)'{-n+,--name=}'[SDK name (PascalCase)]:name:' \
          '(-o --out-dir)'{-o+,--out-dir=}'[output directory]:dir:_files -/' \
          '(-p --package-name)'{-p+,--package-name=}'[package name]:name:' \
          '(-s --schema)'{-s+,--schema=}'[OpenAPI schema]:schema:_files -g "*.{yaml,yml,json}"' \
          '(-t --target)'{-t+,--target=}'[generation target]:target:' \
          '--init-git[initialize git repository]' \
          '--output=[display format]:format:(summary console mermaid)' \
          '--skip-compile[skip compilation]' \
          '--skip-interactive[skip prompts]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      run)
        _arguments \
          '(-y --auto-yes)'{-y,--auto-yes}'[auto-confirm prompts]' \
          '(-d --debug)'{-d,--debug}'[debug file writing]' \
          '(-s --source)'{-s+,--source=}'[source to run (or all)]:source:' \
          '(-t --target)'{-t+,--target=}'[target to run (or all)]:target:' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(summary mermaid console)' \
          '--parallel[run targets as separate subprocesses]' \
          '(-w --watch)'{-w,--watch}'[launch web studio]' \
          '(-r --repo)'{-r+,--repo=}'[repository URL]:url:' \
          '--set-version=[set SDK version]:version:' \
          '(-i --installationURL)'{-i+,--installationURL=}'[installation URL]:url:' \
          '--repo-subdir=[repository subdirectory]:path:' \
          '--github[initiate generation in GitHub]' \
          '--github-repos=[run across multiple repos]:repos:' \
          '--minimal[essential generation only]' \
          '--skip-compile[skip compilation]' \
          '--skip-testing[skip testing]' \
          '--skip-upload-spec[skip spec registry upload]' \
          '--skip-versioning[skip auto version bumps]' \
          '--registry-tags=[apply registry tags]:tags:' \
          '--verbose[detailed logging]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      lint)
        local -a lint_cmds=(
          'arazzo:validate an Arazzo document'
          'config:lint a Speakeasy configuration file'
          'openapi:lint an OpenAPI document'
        )
        _describe -t commands 'speakeasy lint subcommand' lint_cmds && ret=0
        ;;
      auth)
        local -a auth_cmds=(
          'login:authenticate with Speakeasy Platform'
          'logout:sign out'
        )
        _describe -t commands 'speakeasy auth subcommand' auth_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
