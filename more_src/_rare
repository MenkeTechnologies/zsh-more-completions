#compdef rare

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'filter:filter incoming data by match expression'
      'histogram:build histogram from matched data'
      'bargraph:build bar graph from matched data'
      'table:build table from matched data'
      'heatmap:build heatmap from matched data'
      'analyze:analyze matched data with statistics'
      'docs:generate documentation'
      'help:show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    local -a common_args=(
      '(-m --match)'{-m,--match}'=[match expression]:expression:'
      '(-e --extract)'{-e,--extract}'=[extract expression]:expression:'
      '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive matching]'
      '(-n --line)'{-n,--line}'=[include line number as field]'
      '--workers=[number of workers]:workers:'
      '--readers=[number of readers]:readers:'
      '--gunzip[decompress gzip files]'
      '--follow[follow file changes like tail -f]'
      '--poll[use polling for file follow]'
      '--recursive[recurse into directories]'
      '(-z --batch-size)'{-z,--batch-size}'=[batch size for processing]:size:'
      '*:file:_files'
    )
    case ${words[1]} in
      (filter)
        _arguments $common_args && ret=0
        ;;
      (histogram|bargraph)
        _arguments \
          $common_args \
          '--bars=[number of bars to display]:bars:' \
          '--reverse[reverse sort order]' \
          '--sort-by=[sort by]:field:(key value)' \
          '--min=[minimum value to display]:min:' \
          '--extra[show extra data]' && ret=0
        ;;
      (table)
        _arguments \
          $common_args \
          '--rows=[number of rows]:rows:' \
          '--cols=[number of columns]:cols:' && ret=0
        ;;
      (heatmap)
        _arguments \
          $common_args \
          '--min=[minimum value]:min:' \
          '--rows=[number of rows]:rows:' && ret=0
        ;;
      (analyze)
        _arguments $common_args && ret=0
        ;;
    esac
    ;;
esac

return ret
