#compdef gnatbind
# Documentation: https://docs.adacore.com/live/wave/gnat_ugn/html/gnat_ugn/gnat_ugn/building_executable_programs_with_gnat.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-A[output a list of ALI files]' \
  '-aO+[search path for object files]:dir:_files -/' \
  '-aI+[search path for source files]:dir:_files -/' \
  '-aP+[project search path]:dir:_files -/' \
  '-b[generate brief output]' \
  '-c[check semantics, no output]' \
  '-C[output ALI consistency info]' \
  '-d[dynamic stack checking]' \
  '-D+[stack size]:bytes:' \
  '-e[output list of elaboration order]' \
  '-Ea[automatic elaboration order]' \
  '-Es[static elaboration order]' \
  '-F[restrict to suite of pragmas]' \
  '-h[print help]' \
  '-I+[search path]:dir:_files -/' \
  '-I-[remove default search path]' \
  '-K[show binder usage]' \
  '-l[list scenarios]' \
  '-Mxyz[rename generated main procedure]:name:' \
  '-n[no main]' \
  '-nostdinc[no stdinc]' \
  '-nostdlib[no stdlib]' \
  '-o+[output file]:file:_files' \
  '-O+[output object list]:file:_files' \
  '-p[pessimistic order]' \
  '-q[quiet]' \
  '-r[generate restrictions list]' \
  '-R[restrictions audit (sources)]' \
  '-s[require all sources present]' \
  '-shared[link as shared image]' \
  '-static[link static]' \
  '-t[ignore timestamp errors]' \
  '-T+[task stack size]:n:' \
  '-u+[# of secondary stacks]:n:' \
  '-v[verbose]' \
  '-V+[Ada version]:ver:(83 95 2005 2012 2022)' \
  '-w+[warning mode]:mode:(e w s)' \
  '-W+[wide character encoding]:enc:(h b u s e 8)' \
  '-x[do not require all source files]' \
  '-X+[scenario var]:var=val:' \
  '-y[enable leap seconds]' \
  '-Y[no leap seconds]' \
  '-z[no main subprogram]' \
  '-Z[stack check]' \
  '*:ali_file:_files -g "*.ali"' && ret=0

return ret
