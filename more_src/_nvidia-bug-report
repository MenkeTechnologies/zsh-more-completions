#compdef nvidia-bug-report nvidia-bug-report.sh
# Documentation: https://manpages.debian.org/testing/nvidia-support/nvidia-bug-report.sh.1
# Reference accessed: 2026-05-16
# Verified: Debian testing nvidia-bug-report.sh(1) manpage. Real
# binary name has .sh suffix.
# Removed from prior file: fabricated -V/--version (not documented) and
# bogus man.archlinux.org search URL.

# nvidia-bug-report: NVIDIA bug report log generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--output-file=[output log file]:file:_files' \
  '--safe-mode[disable parts that may hang the system]' \
  '--extra-system-data[collect additional system data]' && ret=0
return ret
