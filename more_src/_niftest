#compdef niftest
# _niftest — test .nif files on the filesystem and in BSA archives (OpenMW/openmw)
# upstream: https://github.com/OpenMW/openmw
# Flags from apps/niftest/niftest.cpp (boost::program_options).

_niftest() {
    _arguments \
        '(- *)'{-h,--help}'[print help message]' \
        '(-v --write-debug-log)'{-v,--write-debug-log}'[write debug log for unsupported nif files]' \
        '(-q --quiet)'{-q,--quiet}'[do not log read archives/files]' \
        '*--archives=[archive files to provide files]:archive:_files' \
        '*:nif file:_files'
}

_niftest "$@"
