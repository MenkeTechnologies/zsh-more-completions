#compdef alacarte
# _alacarte — GNOME alacarte (GNOME-classic application menu editor for ~/.config/menus/applications-merged; reads system menus from /etc/xdg/menus and writes user overrides; --display picks an X display, no positional args supported)
# upstream: https://gitlab.gnome.org/GNOME/alacarte
# Argument shape from alacarte main.py on tip.

_alacarte() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--display+[X display]:display:'
}

_alacarte "$@"
