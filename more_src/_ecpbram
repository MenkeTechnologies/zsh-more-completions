#compdef ecpbram

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--input=[input config]:file:_files -g "*.config"' \
  '--output=[output config]:file:_files -g "*.config"' \
  '--from=[from hex/asc]:file:_files' \
  '--to=[to hex/asc]:file:_files' \
  '--generate=[generate random BRAM content]:size:' && ret=0

return ret
