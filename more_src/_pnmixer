#compdef pnmixer
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/pnmixer.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show summary of options and exit]' \
  '(- *)'{-v,--version}'[show version information and exit]' \
  {-d,--debug}'[enable debug messages]' && ret=0

return ret
