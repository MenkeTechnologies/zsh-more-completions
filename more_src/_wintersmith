#compdef wintersmith

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:build a site'
  'preview:run local webserver'
  'new:create a new site'
  'plugin:manage plugins'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --chdir)'{-C,--chdir=}'[change directory]:dir:_files -/' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-i --contents)'{-i,--contents=}'[contents path]:path:_files -/' \
  '(-t --templates)'{-t,--templates=}'[templates path]:path:_files -/' \
  '(-L --locals)'{-L,--locals=}'[locals file]:file:_files' \
  '(-R --require)'{-R,--require=}'[require list]:list:' \
  '(-P --plugins)'{-P,--plugins=}'[plugins list]:list:' \
  '(-I --ignore)'{-I,--ignore=}'[ignore list]:list:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'wintersmith subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-o --output)'{-o,--output=}'[output path]:dir:_files -/' \
          '(-X --clean)'{-X,--clean}'[clean output]' && ret=0
        ;;
      (preview)
        _arguments \
          '(-p --port)'{-p,--port=}'[port]:port:' \
          '(-H --hostname)'{-H,--hostname=}'[hostname]:host:_hosts' && ret=0
        ;;
      (new)
        _arguments \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-T --template)'{-T,--template=}'[template]:template:' \
          ':location:_files -/' && ret=0
        ;;
      (plugin)
        _values 'plugin action' 'list' 'install' && ret=0
        ;;
    esac
    ;;
esac

return ret
