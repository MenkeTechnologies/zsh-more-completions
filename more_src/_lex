#compdef lex

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-Ca[trade larger tables for better memory alignment]' \
  '-Ce[construct equivalence classes]' \
  '-Cf[do not compress tables, use -f representation]' \
  '-CF[do not compress tables, use -F representation]' \
  '-Cm[construct meta-equivalence classes]' \
  '-Cr[use read() instead of stdio]' \
  '-Cem[default compression]' \
  {-f,--full}'[generate fast, large scanner]' \
  {-F,--fast}'[use alternate table representation]' \
  {-d,--debug}'[enable debug mode in scanner]' \
  {-b,--backup}'[write backing-up info to lex.backup]' \
  {-p,--perf-report}'[write performance report to stderr]' \
  {-s,--nodefault}'[suppress default rule to ECHO unmatched]' \
  {-T,--trace}'[run in trace mode]' \
  {-w,--nowarn}'[do not generate warnings]' \
  {-v,--verbose}'[write scanner statistics to stdout]' \
  '--hex[use hexadecimal in debug outputs]' \
  {-o+,--outfile=}'[output filename]:file:_files' \
  {-S+,--skel=}'[skeleton file]:file:_files' \
  {-t,--stdout}'[write scanner to stdout]' \
  '--yyclass=[name of C++ class]:name:' \
  '--header-file=[also create a C header file]:file:_files' \
  '--tables-file=-[write tables to file]:file:_files' \
  {-7,--7bit}'[generate 7-bit scanner]' \
  {-8,--8bit}'[generate 8-bit scanner]' \
  {-B,--batch}'[generate batch scanner]' \
  {-i,--case-insensitive}'[ignore case in patterns]' \
  {-l,--lex-compat}'[maximal compatibility with original lex]' \
  {-X,--posix-compat}'[maximal compatibility with POSIX lex]' \
  {-I,--interactive}'[generate interactive scanner]' \
  '--yylineno[track line count in yylineno]' \
  {-+,--c++}'[generate C++ scanner class]' \
  '*-D+[#define macro]:macro[=defn]:' \
  {-L,--noline}'[suppress #line directives]' \
  {-P+,--prefix=}'[prefix instead of yy]:prefix:' \
  {-R,--reentrant}'[generate reentrant C scanner]' \
  '--bison-bridge[scanner for bison pure parser]' \
  '--bison-locations[include yylloc support]' \
  '--stdinit[initialize yyin/yyout to stdin/stdout]' \
  '--nounistd[do not include unistd.h]' \
  '*:input file:_files -g "*.(l|lex)"' && ret=0

return ret
