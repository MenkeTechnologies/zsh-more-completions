#compdef zenml-cli
# Documentation: https://github.com/zenml-io/zenml
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ZenML CLI for MLOps pipelines
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
case zenml-cli in
  metaflow-cli)
    commands=(
      'help:show help'
      'configure:configure metaflow defaults'
      'init:initialize project'
      'run:run a flow'
      'show:show flow steps'
      'resume:resume a failed run'
      'logs:show logs for a step'
      'card:work with cards'
      'tag:tag a run'
      'tutorials:install tutorials'
    )
    ;;
  zenml-cli)
    commands=(
      'init:initialize ZenML repository'
      'connect:connect to ZenML server'
      'disconnect:disconnect from server'
      'login:login to ZenML Pro'
      'logout:logout from ZenML Pro'
      'pipeline:pipeline operations'
      'stack:manage stacks'
      'integration:manage integrations'
      'orchestrator:manage orchestrators'
      'artifact-store:manage artifact stores'
      'experiment-tracker:manage experiment trackers'
      'model-registry:manage model registries'
      'service-connector:manage service connectors'
      'secret:manage secrets'
      'user:manage users'
      'project:manage projects'
      'role:manage roles'
      'analytics:opt in/out of analytics'
      'version:show version'
      'config:configuration commands'
      'go:open ZenML dashboard'
    )
    ;;
  kedro-cli)
    commands=(
      'new:create a new project'
      'starter:list/use starter templates'
      'info:show installed plugins and versions'
      'run:run the pipeline'
      'jupyter:Jupyter integration'
      'ipython:IPython integration'
      'package:package the project'
      'build-docs:build docs'
      'build-reqs:build requirements'
      'catalog:show data catalog'
      'pipeline:pipeline operations'
      'registry:show pipelines registry'
      'micropkg:micro-package operations'
      'docs:open kedro docs'
      'test:run tests'
      'lint:lint the project'
      'install:install project deps'
      'activate-nbstripout:activate nbstripout'
    )
    ;;
esac
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'zenml-cli command' commands && ret=0 ;;
esac
return ret
