#
# THE gitty CLI — stdlib flag + reflow + lipgloss + multi-forge git API
#
# gitty's CLI is in main.go.  Uses Go's stdlib `flag` package:
#
#     var (
#         maxBranches     = flag.Int("max-branches", 10, "Max amount of active branches to show")
#         maxCommits      = flag.Int("max-commits", 10, "Max amount of commits to show")
#         maxIssues       = flag.Int("max-issues", 10, "Max amount of issues to show")
#         maxPullRequests = flag.Int("max-pull-requests", 10, "Max amount of pull requests to show")
#         maxBranchAge    = flag.Int("max-branch-age", 28, "Max age of a branch in days to be considered active")
#         minNewCommits   = flag.Int("min-new-commits", 1, "Min amount of new commits for a repo to be considered new")
#         skipStaleRepos  = flag.Bool("skip-stale-repos", true, "Skip repos without new activity")
#         withCommits     = flag.Bool("with-commits", false, "Show new commits")
#         allProjects     = flag.Bool("all-projects", false, "Retrieve information for all source repositories")
#         namespace       = flag.String("namespace", "", "User/organization name when using --all-projects")
#         version         = flag.Bool("version", false, "display version")
#     )
#
# Positional arguments:
#   [repo]              repository (. for current dir, owner/repo, or URL)
#                       defaults to "." (current git repository)
#   [issue|pr#]         optional issue/PR number to open in browser
#
# muesli/reflow is used in commit.go for truncating commit messages
# to terminal width (truncate.StringWithTail) and elsewhere for
# formatting the multi-section status output.
#
# Five-axis distinctness from textwrap (R625) and other Axis 12
# libraries:
#
#   1. SIX-MODULE io.Writer ARCHITECTURE — ansi/dedent/indent/
#      padding/truncate/wordwrap/wrap as separate sub-packages.
#
#   2. io.Writer DECORATOR PIPELINE via NewWriterPipe.
#
#   3. TWO-TIER API per module — NewWriter (streaming) + String
#      (one-shot) consistently across all modules.
#
#   4. ANSI-AWARE BY DEFAULT in every sub-module.
#
#   5. CHRISTIAN-MUEHLHAEUSER / CHARM ECOSYSTEM PROVENANCE.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/muesli/gitty/blob/master/main.go
# stdlib flag.Int + flag.Bool + flag.String definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '--max-branches=[max active branches to show (default 10)]:n:_default' \
    '--max-commits=[max commits to show (default 10)]:n:_default' \
    '--max-issues=[max issues to show (default 10)]:n:_default' \
    '--max-pull-requests=[max pull requests to show (default 10)]:n:_default' \
    '--max-branch-age=[max age in days for branch to be active (default 28)]:days:_default' \
    '--min-new-commits=[min new commits for repo to be new (default 1)]:n:_default' \
    '--skip-stale-repos=[skip repos without activity (default true)]:bool:(true false)' \
    '--with-commits[show new commits]' \
    '--all-projects[retrieve info for all source repositories]' \
    '--namespace=[user/organization name (use with --all-projects)]:name:_default' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '1:repository (. or owner/repo or URL or issue#):_default' \
    '2:issue or PR number:_default' \
    && ret=0

return ret
