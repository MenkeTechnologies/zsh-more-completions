# WHAT IS muesli/reflow AND WHY IS IT THE 64TH GO CLI LIBRARY?
#
# reflow (https://github.com/muesli/reflow, 870+ stars) is **Christian
# Muehlhaeuser's "Reflow lets you reformat blocks of text in a terminal"**
# — the dominant Go text-wrapping library since 2020 and a foundational
# piece of the Charm ecosystem (bubbletea / lipgloss / glow / soft-
# serve).  Where textwrap (Rust, R625) is a SINGLE crate handling all
# wrapping concerns, reflow takes a different approach: SIX independent
# sub-packages, each io.Writer-compatible, that COMPOSE via NewWriterPipe.
#
# reflow's distinguishing characteristics:
#
#   1. SIX-MODULE io.Writer ARCHITECTURE — reflow's central design is
#      six independent sub-packages, each implementing io.Writer:
#
#          import "github.com/muesli/reflow/wordwrap"
#          import "github.com/muesli/reflow/indent"
#          import "github.com/muesli/reflow/truncate"
#          import "github.com/muesli/reflow/padding"
#          import "github.com/muesli/reflow/dedent"
#          import "github.com/muesli/reflow/wrap"
#          import "github.com/muesli/reflow/ansi"
#
#          // wordwrap — break at word boundaries:
#          w := wordwrap.NewWriter(80)
#          fmt.Fprint(w, "Long text to wrap at word boundaries...")
#          w.Close()
#          fmt.Println(w.String())
#
#          // truncate — truncate to width with ellipsis:
#          fmt.Println(truncate.StringWithTail("Long text...", 20, "…"))
#          // Output: "Long text very lo…"
#
#          // indent — add 4-space indent to each line:
#          fmt.Println(indent.String("Line 1\nLine 2\nLine 3", 4))
#          // Output: "    Line 1\n    Line 2\n    Line 3"
#
#          // padding — pad each line to width:
#          fmt.Println(padding.String("short\nlonger line", 20))
#          // Each line padded with spaces to 20 cols
#
#          // dedent — strip common leading whitespace:
#          fmt.Println(dedent.String("  Line 1\n  Line 2\n    Line 3"))
#          // Output: "Line 1\nLine 2\n  Line 3" (2-space common prefix removed)
#
#          // wrap — hard wrap at any character:
#          w := wrap.NewWriter(20)
#          fmt.Fprint(w, "Long URL: https://example.com/very/long/path")
#          // Breaks at character boundary, not word boundary
#
#      Compare:
#         * Rust textwrap (R625): SINGLE crate with all features
#         * Go mitchellh/go-wordwrap: word-wrap only
#         * Go termwidth: width helper only
#         * Node word-wrap: word-wrap only
#         * Node wrap-ansi: ANSI-aware wrap only
#         * Python textwrap (stdlib): single module with multiple
#                                       functions
#         * reflow: SIX SEPARATE MODULES, each io.Writer
#      FIRST documented Go Axis 12 library with six-module
#      io.Writer-composable architecture.
#
#   2. io.Writer COMPOSABILITY via NewWriterPipe — every reflow
#      module exposes both NewWriter() AND NewWriterPipe() — letting
#      users chain writers in a pipeline:
#
#          import (
#              "github.com/muesli/reflow/wordwrap"
#              "github.com/muesli/reflow/indent"
#          )
#
#          // Compose: wrap at 80 cols → then indent with 4 spaces:
#          out := wordwrap.NewWriter(80)
#          piped := indent.NewWriterPipe(out, 4, nil)
#          fmt.Fprint(piped, "Long input text...")
#          // Output: text wrapped to 80 cols, then indented 4 spaces
#
#      The pipeline pattern lets reflow modules act as Decorators
#      in the classic OO sense — adding behavior incrementally.
#      Compare:
#         * Rust textwrap (R625): single function call with options
#                                   struct
#         * Go go-wordwrap: function call only
#         * Node word-wrap: function call only
#         * Python textwrap (stdlib): function call only
#         * reflow: io.Writer DECORATOR PIPELINE via NewWriterPipe
#      FIRST documented Go Axis 12 library with io.Writer Decorator
#      pipeline as the canonical composition pattern.
#
#   3. STRING() CONVENIENCE FUNCTIONS — every reflow module provides
#      String() helpers for one-shot operations without Writer
#      boilerplate:
#
#          wordwrap.String("text", 80)
#          indent.String("text", 4)
#          truncate.String("text", 80)
#          truncate.StringWithTail("text", 80, "…")
#          padding.String("text", 80)
#          dedent.String("text")
#          wrap.String("text", 80)
#
#      Two-tier API: NewWriter for streaming, String for one-shot.
#      Compare:
#         * Rust textwrap (R625): wrap() function only (Vec<String>);
#                                   fill() function for joined String
#         * Go go-wordwrap: WrapString() function only
#         * Node word-wrap: function call only
#         * Python textwrap (stdlib): wrap/fill/dedent functions
#         * reflow: TWO-TIER API per module (Writer + String)
#      FIRST documented Go Axis 12 library with consistent
#      two-tier (Writer + String) API across all modules.
#
#   4. ANSI-AWARE BY DEFAULT via reflow/ansi — every reflow module
#      uses reflow/ansi internally to compute visible width
#      separately from raw byte count, correctly handling colored
#      output:
#
#          import "github.com/charmbracelet/lipgloss"
#          import "github.com/muesli/reflow/truncate"
#
#          colored := lipgloss.NewStyle().
#              Foreground(lipgloss.Color("212")).
#              Bold(true).
#              Render("Very long red bold text")
#          // colored = "\x1b[1;38;5;212mVery long red bold text\x1b[0m"
#          //   (raw length: 38+, visible length: 23)
#
#          truncated := truncate.StringWithTail(colored, 10, "…")
#          // Truncates based on VISIBLE width (10 cols),
#          // preserving ANSI escapes
#
#      Compare:
#         * Rust textwrap (R625): strip-ansi feature for ANSI-aware
#         * Go go-wordwrap: NOT ansi-aware
#         * Node word-wrap: NOT ansi-aware
#         * Node wrap-ansi: ansi-aware (separate package)
#         * Python textwrap (stdlib): NOT ansi-aware
#         * reflow: BUILT-IN ansi awareness in every sub-module
#      FIRST documented Go Axis 12 library with ANSI-awareness as
#      a built-in feature of every sub-module (no opt-in).
#
#   5. CHRISTIAN MUEHLHAEUSER / CHARM ECOSYSTEM PROVENANCE — reflow
#      is by Christian Muehlhaeuser (muesli on GitHub), a German
#      open-source developer + co-maintainer of the Charm
#      ecosystem.  reflow is foundational to:
#         * charmbracelet/bubbletea (Elm-architecture TUI framework)
#         * charmbracelet/lipgloss (terminal styling)
#         * charmbracelet/glow (markdown renderer)
#         * charmbracelet/soft-serve (Git server)
#         * charmbracelet/glamour (markdown rendering library)
#      Other muesli projects: termenv (terminal env detection),
#      cancelreader (cancelable readers), gitty (THIS — same-
#      author tool using muesli's own reflow library), duf (df
#      replacement, 15k stars), gamut (color palette tools).
#      Downstream users:
#         * rclone/rclone (cloud storage rsync, 57k stars)
#         * dagger/dagger (CI/CD engine, 16k stars)
#         * yorukot/superfile (file manager, 17k stars)
#         * charmbracelet/soft-serve (Git server, 7k stars)
#         * achannarasappa/ticker (stock ticker, 6k stars)
#         * digitalocean/doctl (DO CLI, 3.4k stars)
#         * cloudposse/atmos (Terraform tooling, 1.3k stars)
#         * ignite/cli (Cosmos SDK, 1.4k stars)
#         * muesli/gitty (THIS — same-author dogfooding)
#         * 800+ Go terminal applications
#         * THE ENTIRE CHARM ECOSYSTEM (transitively)
#      FIRST documented Go Axis 12 library with this specific
#      Christian-Muehlhaeuser + Charm-ecosystem-foundational
#      provenance.
#
# reflow's relationship to other Axis 12 libraries:
#
#   * Unlike textwrap (R625, Rust) — textwrap is single-crate
#                                      all-in-one with two
#                                      algorithms; reflow is
#                                      six-module decorator
#                                      pipeline
#   * Closest analogs:
#         * Go mitchellh/go-wordwrap — single-function wordwrap
#         * Go termwidth — width helper only
#         * Node word-wrap — single-function wordwrap
#         * Node wrap-ansi — ANSI-aware wrap (closest analog —
#                              same ANSI-aware concept)
#         * Python textwrap (stdlib) — function-based multi-purpose
#     reflow is the FIRST documented Go Axis 12 library
#     providing six-module io.Writer-composable text-formatting +
#     decorator-pipeline architecture + ANSI-awareness by default
#     + two-tier (Writer + String) API + Charm-ecosystem-
#     foundational role.
#
