#compdef shp2las
# LAStools: convert an ESRI shapefile to LAS/LAZ

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[print help output]' \
  '-version[report tool version]' \
  '-gui[start with files loaded into GUI]' \
  '-demo[run in demo mode]' \
  '-license[show license information]' \
  '-fail[fail if license expired or invalid]' \
  '(-v -verbose)'{-v,-verbose}'[verbose output]' \
  '-vv[very verbose output]' \
  '-silent[only output on errors or warnings]' \
  '-quiet[no output at all]' \
  '-force[continue despite serious warnings]' \
  '-errors_ignore[continue despite errors]' \
  '-print_log_stats[print additional log statistics]' \
  '-idbf[use DBF file of shapefile as additional input]' \
  '-set_class+[set classification to n]:code' \
  '-set_creation_date+[set creation date (day year)]:day' \
  '-set_offset+[set offset x y]:x' \
  '-set_scale+[quantize points with x y z]:x' \
  '-set_version+[set version major.minor]:major' \
  '*-i+[input shapefile or mask]:input:_files -g "*.(shp|SHP)"' \
  '-o+[output file]:output:_files' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-otxt[output as text]' \
  '-compress[convert to compressed LAZ file]' \
  '-cores+[process inputs on n parallel cores]:n' \
  '*:file:_files -g "*.(shp|SHP)"' && ret=0

return ret
