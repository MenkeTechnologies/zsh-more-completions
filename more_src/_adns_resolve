#compdef adns_resolve
# Documentation: https://man.archlinux.org/search?q=adns_resolve
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-t+[record type]:type:(a aaaa ns mx cname ptr txt soa srv hinfo)' \
  '*:hostname:_hosts' && ret=0

return ret
