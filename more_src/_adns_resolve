#compdef adns_resolve
# Documentation: https://www.chiark.greenend.org.uk/~ian/adns/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-t+[record type]:type:(a aaaa ns mx cname ptr txt soa srv hinfo)' \
  '*:hostname:_hosts' && ret=0

return ret
