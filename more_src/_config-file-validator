#compdef config-file-validator

_arguments -s -S \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--search-path=[directory to search for configuration files]:directory:_directories' \
    '--exclude-dirs=[comma-separated list of directories to exclude]:dirs:' \
    '--exclude-file-types=[comma-separated list of file types to exclude]:types:' \
    '--reporter=[output reporter]:reporter:(standard json junit sarif)' \
    '--depth=[maximum directory depth to search]:depth:' \
    '--quiet[suppress output]' \
    '--group-output[group output by file type]' \
    '*:search path:_directories'
