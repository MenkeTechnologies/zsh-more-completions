#compdef named-checkzone named-compilezone

_arguments -s \
  '(- *)-h[show help]' \
  '-d[enable debugging]' \
  '-D[dump zone in canonical format]' \
  '-j[read JSON serialized format]' \
  '-q[quiet]' \
  '-v[show version]' \
  '-c=[zone class]:class:' \
  '-f=[input zone format]:format:(text raw)' \
  '-F=[output zone format]:format:(text raw)' \
  '-J=[journal file]:file:_files' \
  '-i=[integrity check mode]:mode:(full full-sibling local local-sibling none)' \
  '-k=[NSEC3PARAM check]:mode:(fail warn ignore)' \
  '-l=[max TTL]:ttl:' \
  '-L=[serial number]:serial:' \
  '-m=[mx record check]:mode:(fail warn ignore)' \
  '-M=[MX target check]:mode:(fail warn ignore)' \
  '-n=[NS check]:mode:(fail warn ignore)' \
  '-o=[output file]:file:_files' \
  '-r=[duplicate records check]:mode:(fail warn ignore)' \
  '-s=[serial style]:style:(full relative)' \
  '-S=[SRV target check]:mode:(fail warn ignore)' \
  '-t=[chroot directory]:dir:_files -/' \
  '-T=[NSEC3 check]:mode:(warn ignore)' \
  '-w=[working directory]:dir:_files -/' \
  '-W=[wildcard check]:mode:(warn ignore)' \
  ':zonename:' \
  ':zonefile:_files'
