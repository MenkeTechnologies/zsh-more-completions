#compdef kubelogin

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get-token:run as a credential plugin'
  'setup:setup OAuth2/OIDC for kubectl'
  'version:display version'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --v)'{-v,--v}'[log verbosity level]:level' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      get-token)
        _arguments \
          '--oidc-issuer-url=[OIDC issuer URL]:URL' \
          '--oidc-client-id=[OIDC client ID]:client ID' \
          '--oidc-client-secret=[OIDC client secret]:secret' \
          '--oidc-extra-scope=[extra scopes]:scopes' \
          '--certificate-authority=[path to CA certificate]:cert file:_files' \
          '--certificate-authority-data=[base64 encoded CA certificate]:data' \
          '--insecure-skip-tls-verify[skip TLS verification]' \
          '--token-cache-dir=[directory for token cache]:directory:_files -/' \
          '--force-refresh[force token refresh]' \
          '--grant-type=[authorization grant type]:type:(auto authcode authcode-keyboard device-code)' \
          '--listen-address=[address for redirect URI server]:address' \
          '--skip-open-browser[skip opening browser]' && ret=0
        ;;
      setup)
        _arguments \
          '--oidc-issuer-url=[OIDC issuer URL]:URL' \
          '--oidc-client-id=[OIDC client ID]:client ID' \
          '--oidc-client-secret=[OIDC client secret]:secret' \
          '--oidc-extra-scope=[extra scopes]:scopes' \
          '--certificate-authority=[path to CA certificate]:cert file:_files' \
          '--grant-type=[authorization grant type]:type:(auto authcode authcode-keyboard device-code)' \
          '--listen-address=[address for redirect URI server]:address' && ret=0
        ;;
    esac
    ;;
esac

return ret
