#compdef db_hotbackup
# Documentation: db_hotbackup usage (Berkeley DB 18.1.40)
# Source: create a hot backup of a Berkeley DB environment.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-c[skip checkpoint of source environment]' \
    '-C[run catastrophic recovery in destination]' \
    '-D[run regular recovery in destination]' \
    '-u[update existing hot backup]' \
    '-v[verbose]' \
    '*-d+[data directory (repeatable)]:dir:_files -/' \
    '-i+[source blob directory]:dir:_files -/' \
    '-h+[source environment home]:dir:_files -/' \
    '-l+[log directory]:dir:_files -/' \
    '-m+[message prefix]:msg_pfx:' \
    '-P+[password]:password:' \
    '-b+[backup destination directory]:dir:_files -/' \
    && ret=0

return ret
