#compdef fastq-grep
# Documentation: https://github.com/dcjones/fastq-tools
# match fastq sequences against regular expressions

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print this message]' \
  '(-V --version)'{-V,--version}'[output version information and exit]' \
  '(-i --id)'{-i,--id}'[match the read id (by default, sequence is matched)]' \
  '(-v --invert-match)'{-v,--invert-match}'[select nonmatching entries]' \
  '(-m --mismatches)'{-m,--mismatches=}'[output mismatching entries to the given file]:file:_files' \
  '(-c --count)'{-c,--count}'[output only the number of matching sequences]' \
  '(-a --trim_after)'{-a,--trim_after}'[trim output after the match end]' \
  '(-b --trim_before)'{-b,--trim_before}'[trim output before the match start]' \
  '(-t --trim_match)'{-t,--trim_match}'[trim the match itself, regardless of trimming mode]' \
  '1:pattern:' \
  '*:fastq file:_files' && ret=0

return ret
