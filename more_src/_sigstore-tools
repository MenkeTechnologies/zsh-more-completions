#compdef sigstore-tools sigstore-python
# _sigstore-tools — Sigstore Python reference signing client CLI alias (Sigstore community, Python); click
# upstream: https://github.com/sigstore/sigstore-python

_sigstore-tools() {
    local -a sub=(
        'sign:sign artifacts'
        'verify:verify signatures'
        'attest:create in-toto attestation'
        'plumbing:plumbing commands'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--staging[use staging Sigstore]' \
        '--trust-config=+[trust config]:file:_files' \
        '--rekor-url=+[rekor URL]:url:_urls' \
        '--fulcio-url=+[fulcio URL]:url:_urls' \
        '--oidc-issuer=+[oidc issuer]:str:' \
        '--oidc-client-id=+[oidc client id]:str:' \
        '--oidc-client-secret=+[oidc client secret]:str:' \
        '--identity-token=+[id token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sigstore subcommand' sub ;;
        args)
            case $words[1] in
                sign) _arguments \
                    '--output-signature=+[signature output]:file:_files' \
                    '--output-certificate=+[certificate output]:file:_files' \
                    '--bundle=+[bundle output]:file:_files' \
                    '--no-default-files[no default outputs]' \
                    '--overwrite[overwrite]' \
                    '--oidc-disable-ambient-providers[disable ambient providers]' \
                    '--signing-config=+[signing config]:file:_files' \
                    '*:file:_files' ;;
                verify) _arguments \
                    '1:cmd:(identity github)' \
                    '--cert-identity=+[cert identity]:str:' \
                    '--cert-oidc-issuer=+[cert oidc issuer]:str:' \
                    '--cert-identity-regex=+[cert identity regex]:str:' \
                    '--bundle=+[bundle file]:file:_files' \
                    '--signature=+[signature file]:file:_files' \
                    '--certificate=+[certificate file]:file:_files' \
                    '--offline[offline verify]' \
                    '--trust-config=+[trust config]:file:_files' \
                    '*:file:_files' ;;
                attest) _arguments \
                    '--predicate=+[predicate file]:file:_files -g "*.json"' \
                    '--predicate-type=+[predicate type]:str:' \
                    '--bundle=+[bundle output]:file:_files' \
                    '*:file:_files' ;;
                plumbing) _arguments \
                    '1:cmd:(fix-bundle)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_sigstore-tools "$@"
