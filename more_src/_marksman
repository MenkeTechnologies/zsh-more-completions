#compdef marksman

# Zsh completion for Marksman - Markdown LSP server

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'server:start LSP server'
      'completion:generate shell completion'
    )
    _describe -t commands 'marksman command' commands && ret=0
    ;;
  args)
    case $line[1] in
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash fish zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
