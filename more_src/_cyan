#compdef cyan
# Documentation: https://github.com/teal-language/cyan
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cyan: build system and project manager for the Teal language.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a project based on tlconfig.lua'
  'check:type-check one or more Teal files'
  'gen:type-check and compile one or more Teal files'
  'init:initialize a new Teal project'
  'run:type-check and run a Teal script'
  'warnings:list configurable warnings'
  'help:show help'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'cyan command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      build)
        _arguments -s -S \
          '--prune[prune extra files in build directory]' \
          '--global[build for global installation]' \
          '--source-dir=[source directory]:directory:_directories' \
          '--build-dir=[build output directory]:directory:_directories' && ret=0
        ;;
      check)
        _arguments -s -S \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      init)
        _arguments -s -S \
          '1:project name:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
    esac
    ;;
esac

return ret
