#compdef cyan

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a project'
  'check:type-check Teal files'
  'init:initialize a new project'
  'run:run a Teal script'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'cyan command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      build)
        _arguments -s -S \
          '--prune[prune extra files in build directory]' \
          '--global[build for global installation]' \
          '--source-dir=[source directory]:directory:_directories' \
          '--build-dir=[build output directory]:directory:_directories' && ret=0
        ;;
      check)
        _arguments -s -S \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
      init)
        _arguments -s -S \
          '1:project name:' && ret=0
        ;;
      run)
        _arguments -s -S \
          '*:Teal file:_files -g "*.tl"' && ret=0
        ;;
    esac
    ;;
esac

return ret
