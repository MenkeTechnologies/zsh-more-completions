#compdef nats-streaming-server
# _nats-streaming-server — NATS streaming server (STAN) daemon (nats-io/nats-streaming-server)
# upstream: https://github.com/nats-io/nats-streaming-server
# Flags from nats-streaming-server.go (flag.Parse usage string).

_nats-streaming-server() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--help_tls[TLS help]' \
        '(-cid --cluster_id)'{-cid+,--cluster_id=}'[cluster ID]:id:' \
        '(-st --store)'{-st+,--store=}'[store type]:type:(MEMORY FILE SQL)' \
        '--dir=[FILE store root directory]:dir:_files -/' \
        '(-mc --max_channels)'{-mc+,--max_channels=}'[max channels (0=unlimited)]:n:' \
        '(-msu --max_subs)'{-msu+,--max_subs=}'[max subscriptions per channel]:n:' \
        '(-mm --max_msgs)'{-mm+,--max_msgs=}'[max messages per channel]:n:' \
        '(-mb --max_bytes)'{-mb+,--max_bytes=}'[max bytes per channel]:size:' \
        '(-ma --max_age)'{-ma+,--max_age=}'[max message age]:duration:' \
        '(-mi --max_inactivity)'{-mi+,--max_inactivity=}'[max inactivity for GC]:duration:' \
        '(-ns --nats_server)'{-ns+,--nats_server=}'[external NATS server URL]:url:_urls' \
        '(-sc --stan_config)'{-sc+,--stan_config=}'[streaming server config file]:file:_files' \
        '(-hbi --hb_interval)'{-hbi+,--hb_interval=}'[heartbeat interval]:duration:' \
        '(-hbt --hb_timeout)'{-hbt+,--hb_timeout=}'[heartbeat timeout]:duration:' \
        '(-hbf --hb_fail_count)'{-hbf+,--hb_fail_count=}'[failed heartbeats before disconnect]:n:' \
        '--ft_group=[FT Group name]:name:' \
        '(-sl --signal)'{-sl+,--signal=}'[send signal to server (stop/quit/reopen/reload)]:sig:(stop quit reopen reload)' \
        '--encrypt[use encryption at rest]' \
        '--encryption_cipher=[encryption cipher]:cipher:(AES CHAHA)' \
        '--encryption_key=[encryption key]:key:' \
        '--replace_durable[replace existing durable subscription]' \
        '--clustered[run in clustered configuration]' \
        '--cluster_node_id=[node ID within cluster]:id:' \
        '--cluster_bootstrap[bootstrap cluster by electing self leader]' \
        '--cluster_peers=[comma-separated cluster peer node IDs]:peers:' \
        '--cluster_log_path=[log replication directory]:dir:_files -/' \
        '--cluster_log_cache_size=[in-memory log entry cache size]:n:' \
        '--cluster_log_snapshots=[number of log snapshots to retain]:n:' \
        '--cluster_trailing_logs=[log entries to leave after snapshot]:n:' \
        '--cluster_sync[fsync after every write]' \
        '--cluster_raft_logging[enable raft library logging]' \
        '--cluster_allow_add_remove_node[allow NATS-based add/remove of nodes]' \
        '--sql_driver=[SQL driver]:driver:(mysql postgres)' \
        '--sql_source=[SQL datasource]:dsn:' \
        '--sql_no_caching[disable SQL caching]' \
        '--sql_max_open_conns=[max DB connections]:n:' \
        '--sql_bulk_insert_limit=[max messages per bulk insert]:n:' \
        '-secure[use TLS to NATS server without verification]' \
        '-tls_client_key=[TLS client key]:file:_files' \
        '-tls_client_cert=[TLS client cert]:file:_files' \
        '-tls_client_cacert=[TLS client CA cert]:file:_files' \
        '(-SD --stan_debug)'{-SD,--stan_debug}'[enable STAN debug output]' \
        '(-SV --stan_trace)'{-SV,--stan_trace}'[trace raw STAN protocol]' \
        '-SDV[debug and trace STAN]' \
        '(-a --addr)'{-a+,--addr=}'[NATS bind host]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[NATS client port]:port:' \
        '(-P --pid)'{-P+,--pid=}'[PID file]:file:_files' \
        '(-m --http_port)'{-m+,--http_port=}'[HTTP monitoring port]:port:' \
        '(-ms --https_port)'{-ms+,--https_port=}'[HTTPS monitoring port]:port:' \
        '(-c --config)'{-c+,--config=}'[NATS configuration file]:file:_files' \
        '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
        '(-T --logtime)'{-T,--logtime}'[timestamp log entries]' \
        '(-s --syslog)'{-s,--syslog}'[enable syslog]' \
        '(-r --remote_syslog)'{-r+,--remote_syslog=}'[remote syslog addr]:addr:' \
        '(-D --debug)'{-D,--debug}'[enable debug output]' \
        '(-V --trace)'{-V,--trace}'[trace raw protocol]' \
        '-DV[debug and trace]' \
        '--user=[user for client connections]:user:' \
        '--pass=[password for client connections]:password:' \
        '--auth=[authorization token]:token:' \
        '--tls[enable TLS]' \
        '--tlscert=[TLS server certificate]:file:_files' \
        '--tlskey=[TLS server private key]:file:_files' \
        '--tlsverify[enable TLS verifying clients]' \
        '--tlscacert=[client CA cert]:file:_files' \
        '--routes=[comma-separated routes to solicit]:routes:' \
        '--cluster=[NATS cluster URL for solicited routes]:url:_urls'
}

_nats-streaming-server "$@"
