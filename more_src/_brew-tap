#compdef brew-tap
# _brew-tap — Homebrew brew tap third-party repo subcommand alias (Homebrew team, Ruby); custom argparse
# upstream: https://github.com/Homebrew/brew

_brew-tap() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--force-auto-update[force auto-update]' \
        '--custom-remote[custom remote]' \
        '--shallow[shallow clone]' \
        '--no-shallow[no shallow clone]' \
        '--full[full clone]' \
        '--list-pinned[list pinned taps]' \
        '--repair[repair]' \
        '--list-official[list official taps]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--eval-all[eval all formulae/casks]' \
        '*:user-and-repo:'
}

_brew-tap "$@"
