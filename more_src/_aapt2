#compdef aapt2
# _aapt2 — Android AAPT2 Asset Packaging Tool v2 (Google AOSP, C++); custom argparse
# upstream: https://android.googlesource.com/platform/frameworks/base/+/refs/heads/main/tools/aapt2/

_aapt2() {
    local -a sub=(
        'compile:compile resources to flat files'
        'link:link resources to APK'
        'dump:dump resources/manifests'
        'diff:diff two APKs'
        'optimize:optimize APK'
        'convert:convert APK proto<->binary'
        'version:show version'
        'daemon:run in daemon mode'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'aapt2 subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '-o+[output dir or zip]:dst:_files' \
                    '--dir+[input directory]:dir:_files -/' \
                    '--zip+[input zip]:file:_files -g "*.zip"' \
                    '--output-text-symbols+[output R.txt]:file:_files' \
                    '--pseudo-localize[pseudo-localize]' \
                    '--no-crunch[disable PNG crunching]' \
                    '--no-xml-namespaces[no xml namespaces]' \
                    '--legacy[legacy mode]' \
                    '--preserve-visibility-of-styleables[preserve visibility]' \
                    '--visibility=+[visibility]:vis:(public private default)' \
                    '*:file:_files -g "*.(xml|png|jpg|9.png|ttf|otf|json|webp)"' ;;
                link) _arguments \
                    '-o+[output APK]:file:_files' \
                    '-I+[android jar]:list:_files -g "*.jar"' \
                    '--manifest=+[manifest file]:file:_files -g "AndroidManifest.xml"' \
                    '-A+[assets dir]:dir:_files -/' \
                    '-R+[resource flat files]:list:_files' \
                    '--package-id=+[package id]:str:' \
                    '--allow-reserved-package-id[allow reserved id]' \
                    '--java=+[output java R dir]:dir:_files -/' \
                    '--proguard=+[proguard rules]:file:_files' \
                    '--proguard-main-dex=+[proguard main dex]:file:_files' \
                    '--auto-add-overlay[auto add overlay]' \
                    '--rename-manifest-package=+[rename manifest package]:str:' \
                    '--rename-instrumentation-target-package=+[rename instr pkg]:str:' \
                    '--rename-resources-package=+[rename resources pkg]:str:' \
                    '--shared-lib[shared library]' \
                    '--static-lib[static library]' \
                    '--no-static-lib-packages[no static lib packages]' \
                    '--non-final-ids[non-final ids in R class]' \
                    '--stable-ids=+[stable IDs file]:file:_files' \
                    '--emit-ids=+[emit IDs file]:file:_files' \
                    '--private-symbols=+[private symbols pkg]:str:' \
                    '--min-sdk-version=+[min SDK]:n:' \
                    '--target-sdk-version=+[target SDK]:n:' \
                    '--version-code=+[version code]:n:' \
                    '--version-name=+[version name]:str:' \
                    '--no-version-vectors[no version vectors]' \
                    '--no-version-transitions[no version transitions]' \
                    '--no-resource-deduping[no resource deduping]' \
                    '--enable-sparse-encoding[enable sparse encoding]' \
                    '--enable-resource-path-shortening[enable path shortening]' \
                    '--enable-resource-obfuscation[enable resource obfuscation]' \
                    '--collapse-resource-names[collapse resource names]' \
                    '--shorten-resource-paths[shorten resource paths]' \
                    '--resource-path-shortening-map=+[shortening map output]:file:_files' \
                    '--no-auto-version[no auto-version vector drawables]' \
                    '--package=+[package name]:str:' \
                    '--exclude-configs=+[exclude configs]:list:' \
                    '--config=+[include configs]:list:' \
                    '--preferred-density=+[preferred density]:n:' \
                    '--split=+[split apk path:configs]:str:' \
                    '--output-to-dir[output to dir]' \
                    '--keep-raw-values[keep raw values]' \
                    '--debug-mode[debug mode]' \
                    '*:file:_files' ;;
                dump) _arguments \
                    '1:cmd:(apc badging chunks configurations packagename permissions resources strings styleparents xmlstrings xmltree)' \
                    '--no-values[no values]' \
                    '--file=+[xml file to dump]:file:_files' \
                    '*:file:_files' ;;
                diff) _arguments '*:file:_files -g "*.apk"' ;;
                optimize) _arguments \
                    '-o+[output apk]:file:_files' \
                    '--target-densities=+[densities]:list:' \
                    '--resources-config-path=+[resources config path]:file:_files' \
                    '--enable-sparse-encoding[enable sparse encoding]' \
                    '--enable-resource-path-shortening[enable path shortening]' \
                    '--collapse-resource-names[collapse resource names]' \
                    '*:file:_files -g "*.apk"' ;;
                convert) _arguments \
                    '-o+[output]:file:_files' \
                    '--output-format=+[output format]:fmt:(proto binary)' \
                    '*:file:_files' ;;
                daemon) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_aapt2 "$@"
