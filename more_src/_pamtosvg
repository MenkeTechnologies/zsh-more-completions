#compdef pamtosvg
# Documentation: man pamtosvg (Netpbm)
# Source: Netpbm pamtosvg — convert a Netpbm image to an SVG (vector tracer; based on Autotrace).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-background-color=[treat this color as background and ignore]:color:' \
    '-centerline[trace centerline instead of outline]' \
    '-corner-threshold=[corner angle threshold (deg, default 100)]:angle:' \
    '-corner-always-threshold=[force-corner angle threshold (deg, default 60)]:angle:' \
    '-corner-surround=[pixels on either side considered for corner (default 4)]:N:' \
    '-tangent-surround=[pixels on either side considered for tangent]:N:' \
    '-error-threshold=[curve-subdivision offset threshold (default 2.0)]:pixels:' \
    '-filter-iterations=[curve-smoothing iterations (default 4)]:N:' \
    '-line-reversion-threshold=[line-revert closeness threshold]:float:' \
    '-line-threshold=[line-detection threshold]:float:' \
    '-width-weight-factor=[width-weighting factor]:float:' \
    '-preserve-width[preserve original line width]' \
    '-remove-adjacent-corners[discard adjacent corner pixels]' \
    '-log[log diagnostic info to stderr]' \
    '-report-progress[print progress messages]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
