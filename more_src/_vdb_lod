#compdef vdb_lod
# Documentation: https://github.com/AcademySoftwareFoundation/openvdb/blob/master/openvdb_cmd/vdb_lod/main.cc
# OpenVDB: generate volume mipmaps from a VDB grid

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '(-version --version)'{-version,--version}'[print version information]' \
  '-name=[name(s) of the grid(s) to be processed]:name' \
  '-keep[pass through grids that were not processed]' \
  '-nokeep[cancel an earlier -keep option]' \
  '(-p -preserve)'{-p,-preserve}'[if only one mip level is generated, give it the original name]' \
  '-nopreserve[cancel an earlier -p or -preserve option]' \
  '-range=[mipmap level range FROM\[-TO\[:STEP\]\]]:range' \
  '*:vdb file:_files -g "*.vdb"' && ret=0

return ret
