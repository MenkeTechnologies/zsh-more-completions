#compdef ProteinQuantifier
# Documentation: https://openms.readthedocs.io/en/latest/
# OpenMS TOPP: compute protein abundances from peptide quantities

local ret=1

_arguments -s -S \
  '-in[input file]:input file:_files' \
  '-protein_groups[protein inference results for quantification]:file:_files' \
  '-design[experimental design file]:file:_files' \
  '-out[output file for protein abundances]:output file:_files' \
  '-peptide_out[output file for peptide abundances]:file:_files' \
  '-mztab[mzTab format output]:file:_files' \
  '-out_qpx[output directory for QPX Parquet files]:dir:_files -/' \
  '-method[quantification method]:method:(top iBAQ)' \
  '-top:N[number of abundant peptides for protein calculation]:n:' \
  '-top:aggregate[aggregation method]:method:(median mean weighted_mean sum)' \
  '-top:include_all[include proteins with fewer peptides]' \
  '-consensus:normalize[equalize median abundances across samples]' \
  '-consensus:fix_peptides[use consistent peptide sets across samples]' \
  '-best_charge_and_fraction[distinguish charge states and fractions separately]' \
  '-ratios[add log2 abundance ratios to output]' \
  '-ratiosSILAC[calculate SILAC triple-labeling ratios]' \
  '-ini[use the given TOPP INI file]:ini file:_files' \
  '-write_ini[write default INI file]:ini file:_files' \
  '-threads[number of threads (0 = all cores)]:threads:' \
  '-log[log file name]:log file:_files' \
  '-debug[set debug level]:level:' \
  '-no_progress[disable progress logging]' \
  '-force[override tool-specific checks]' \
  '-test[enable test mode]' \
  '--help[show standard options]' \
  '--helphelp[show all options including advanced]' && ret=0

return ret
