#compdef afl-minimize
# Documentation: https://github.com/rc0r/afl-utils
# Corpus collection and minimization wrapper for afl-fuzz sync dirs (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --collect)'{-c,--collect}'=[collect all samples from sync dir into collection dir]:dir:_files -/' \
  '--cmin[run afl-cmin on collection dir]' \
  '--cmin-mem-limit=[set memory limit for afl-cmin]:MB' \
  '--cmin-timeout=[set timeout for afl-cmin]:seconds' \
  '--cmin-qemu[enable qemu mode afl-cmin]' \
  '--reseed[reseed afl-fuzz with the collected corpus]' \
  '--tmin[run afl-tmin on minimized collection dir]' \
  '--tmin-mem-limit=[set memory limit for afl-tmin]:MB' \
  '--tmin-timeout=[set timeout for afl-tmin]:seconds' \
  '--tmin-qemu[enable qemu mode afl-tmin]' \
  '(-d --dry-run)'{-d,--dry-run}'[perform dry-run, moving intermittent crashes out of corpus]' \
  '(-j --threads)'{-j,--threads}'=[number of threads for parallel dry-run/t-min]:threads' \
  '*::sync dir and target:_files' && ret=0

return ret
