#compdef grdcut
# Documentation: https://docs.generic-mapping-tools.org/latest/grdcut.html
# Source: GenericMappingTools/gmt classic-mode grdcut — cut a sub-region from a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-R+[region (subregion to cut out)]:region:_default' \
    '-D[dry run (report dimensions only)]' \
    '-E+[vertical slice along x or y (3-D netCDF cube)]:axis:(x y)' \
    '-F+[polygon mask file]:file:_files' \
    '-J+[projection for oblique region]:proj:_default' \
    '-N+[extend beyond original boundary with fill value]:value:_default' \
    '-S+[extract circular region around point/radius]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-Z+[region from value range (handles NaN)]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
