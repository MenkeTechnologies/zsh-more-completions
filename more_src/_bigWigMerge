#compdef bigWigMerge
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# merge multiple bigWigs into a single output bedGraph

local ret=1

_arguments -s -S \
  '-threshold=[do not output values at or below this threshold (default 0.0)]:n' \
  '-adjust=[add adjustment to each value]:n' \
  '-clip=[values higher than this are clipped to this value]:n' \
  '-inList[input files are lists of file names of bigWigs]' \
  '-max[merged value is maximum from input files rather than sum]' \
  '*:file:_files -g "*.(bw|bigWig)"' && ret=0

return ret
