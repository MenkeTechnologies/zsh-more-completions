#compdef aws-runas
# _aws-runas — aws-runas role-assuming helper (Mike Morain, Go); MFA + AssumeRole + IAM credentials for AWS CLI
# upstream: https://github.com/mmmorris1975/aws-runas

_aws-runas() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-d+[duration]:duration:' \
        '--duration+[duration]:duration:' \
        '-r[refresh cached creds]' \
        '--refresh[refresh cached creds]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D+[debug]' \
        '--debug[debug]' \
        '-l[list available roles]' \
        '--list-roles[list available roles]' \
        '-m[print MFA serial]' \
        '--list-mfa[print MFA serial]' \
        '-M+[MFA code]:code:' \
        '--mfa-code+[MFA code]:code:' \
        '--mfa-serial+[MFA serial]:str:' \
        '-S+[mfa duration]:duration:' \
        '--session-duration+[session duration]:duration:' \
        '-u[update aws-runas]' \
        '--update[update aws-runas]' \
        '-e[output env vars]' \
        '--env[output env vars]' \
        '-E+[expiration time]:duration:' \
        '-O+[output format]:fmt:(env powershell)' \
        '-X+[external id]:str:' \
        '--external-id+[external id]:str:' \
        '-w+[ssh wrap command]:cmd:_command_names -e' \
        '-W+[ssh wrap target]:host:_hosts' \
        '-s[show diagnostics]' \
        '--diagnose[show diagnostics]' \
        '-J+[jump server]:host:_hosts' \
        '*:profile or args:'
}

_aws-runas "$@"
