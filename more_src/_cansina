#compdef cansina
# Documentation: https://github.com/deibit/cansina/blob/master/README.md
# Web content discovery tool

local ret=1

_arguments -s -S \
  '-u[site URL to scan]:url' \
  '-p[payload file]:file:_files' \
  '-t[number of threads (default 4)]:threads' \
  '-T[set a delay between requests (float seconds)]:delay' \
  '-a[specify an alternative User-Agent string]:user agent' \
  '-P[designate a proxy for requests]:proxy' \
  '-H[make requests using HEAD HTTP method]' \
  '--headers[configure custom HTTP headers]:headers' \
  '--persist[make all requests with persistent connections]' \
  '--no-follow[treat all 3xx codes as 404 results]' \
  '--no-progress[disable fancy terminal interface]' \
  '-V[view sqlite database results]' \
  '-h[show help summary]' && ret=0

return ret
