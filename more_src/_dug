#compdef dug

# Zsh completion for dug
# Upstream: Global DNS propagation checker that gives pretty output
# Conservative fallback — run `dug --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
