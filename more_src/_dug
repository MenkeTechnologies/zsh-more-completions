#compdef dug
# Documentation: https://man.archlinux.org/search?q=dug
# Reference accessed: 2026-05-16

# Zsh completion for dug
# Upstream: Global DNS propagation checker that gives pretty output
# Conservative fallback — run `dug --help` for full options.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[(show version if supported)]' \
  '*::file:_files' && ret=0

return ret
