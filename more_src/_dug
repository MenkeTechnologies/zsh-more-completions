#compdef dug
# Documentation: https://github.com/unfrl/dug
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# unfrl/dug — global DNS propagation checker (.NET); top-level verbs: run, update, help

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-q+[DNS record type]:record type:(A AAAA CNAME MX NS PTR SOA SRV TXT)' \
  '--output-format=[output format]:format:(JSON CSV YAML)' \
  '--server-count=[number of nameservers to query]:n:' \
  '--output-template=[custom output column template]:template:' \
  '--output-file=[output file path]:file:_files' \
  '--server-file=[custom server list]:file:_files' \
  '--server=[comma-separated nameservers]:servers:' \
  '*:hostname:' && ret=0

return ret
