#compdef earlyoom

_arguments \
  '-m[set minimum available memory percent]:percent' \
  '-s[set minimum available swap percent]:percent' \
  '-M[set minimum available memory size in KiB]:size' \
  '-S[set minimum available swap size in KiB]:size' \
  '-k[use kernel OOM killer instead of SIGTERM/SIGKILL]' \
  '-i[user-space oom killer should ignore positive oom_score_adj values]' \
  '-d[enable debugging messages]' \
  '-v[print version information]' \
  '-r[report interval in seconds]:seconds' \
  '-p[set preferred process name to kill]:name' \
  '--prefer[prefer killing processes matching regex]:regex' \
  '--avoid[avoid killing processes matching regex]:regex' \
  '-n[send notifications via notify-send]' \
  '-N[specify notifier command]:command:_command_names' \
  '-g[kill entire process group]' \
  '--dryrun[print actions without actually killing]' \
  '-h[display help]'
