#compdef earlyoom
# Documentation: https://github.com/rfjakob/earlyoom
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '-m+[available memory minimum percent (optionally with KILL_PERCENT)]:percent[,kill_percent]:' \
  '-s+[available swap minimum percent (optionally with KILL_PERCENT)]:percent[,kill_percent]:' \
  '-M+[available memory minimum in KiB (optionally with KILL_SIZE)]:size[,kill_size]:' \
  '-S+[available swap minimum in KiB (optionally with KILL_SIZE)]:size[,kill_size]:' \
  '-k[deprecated (was: use kernel OOM killer); accepted but ignored]' \
  '-i[ignore positive oom_score_adj values when choosing victim]' \
  '(-d --debug)'{-d,--debug}'[enable debugging messages]' \
  '-v[print version information]' \
  '-r+[memory report interval in seconds (0 to disable)]:seconds:' \
  '-p[set niceness/oom_score_adj for earlyoom itself]' \
  '-n[enable d-bus desktop notifications]' \
  '-N+[notifier script to run after killing]:script:_files' \
  '-P+[notifier script to run before killing]:script:_files' \
  '-g[kill the entire process group]' \
  '--prefer=[prefer killing processes matching regex]:regex:' \
  '--avoid=[avoid killing processes matching regex]:regex:' \
  '--ignore=[ignore processes matching regex entirely]:regex:' \
  '--sort-by-rss[select victim by largest RSS instead of oom_score]' \
  '--ignore-root-user[do not kill root-owned processes]' \
  '--dryrun[print actions without actually killing]' \
  '--syslog[log to syslog instead of stdout/stderr]' \
  '-h[display help]'
