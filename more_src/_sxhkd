#compdef sxhkd

# Zsh completion for sxhkd - simple X hotkey daemon

_arguments \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c)'-c'[specify config file]:config file:_files' \
  '(-r)'-r'[specify redirect file for command output]:file:_files' \
  '(-s)'-s'[specify status fifo]:fifo:_files' \
  '(-a)'-a'[specify abort keysym]:keysym' \
  '(-t)'-t'[specify timeout for chain abortion]:seconds' \
  '(-m)'-m'[handle monitor-related syntax]:count'
