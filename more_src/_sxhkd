#compdef sxhkd
# Documentation: https://man.archlinux.org/man/sxhkd.1.en
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# Zsh completion for sxhkd - simple X hotkey daemon. Note: -h and -v are
# short flags only upstream (no long-form --help/--version).

_arguments \
  '(- *)-h[print synopsis and exit]' \
  '(- *)-v[print version and exit]' \
  '-c+[main configuration file]:config file:_files' \
  '-r+[redirect command output to file]:file:_files' \
  '-s+[status FIFO]:fifo:_files' \
  '-a+[abort keysym name]:keysym:' \
  '-t+[timeout in seconds for chord chains]:seconds:' \
  '-m+[handle first COUNT mapping notify events]:count:' \
  '*:extra config file:_files'
