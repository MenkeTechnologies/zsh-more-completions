#compdef icecc-scheduler
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/icecc-scheduler.1.html
# icecc-scheduler - Icecream scheduler

local ret=1

_arguments -s -S \
  '(-n --netname)'{-n+,--netname+}'[name of the icecream network the scheduler controls]:netname' \
  '(-p --port)'{-p+,--port+}'[IP port the scheduler uses]:port' \
  '(-l --log-file)'{-l+,--log-file+}'[file where log output is written]:logfile:_files' \
  '*-v[increase verbosity; repeat for more]' \
  '(-d --daemonize)'{-d,--daemonize}'[detach daemon from shell]' \
  '(-u --user-uid)'{-u+,--user-uid+}'[system user to run the daemon as (not root)]:user uid' \
  '(-r --persistent-client-connection)'{-r,--persistent-client-connection}'[keep client connections even if a better scheduler is available]' && ret=0

return ret
