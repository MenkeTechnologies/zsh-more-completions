#compdef 1dFlagMotion
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dFlagMotion.html
# Identify time points exceeding motion thresholds in motion parameter files

local ret=1

_arguments -s -S \
  '-MaxTrans[max translation allowed in any direction (default 1.5mm)]:mm' \
  '-MaxRot[max rotation allowed in any direction (default 1.25 deg)]:deg' \
  '*:file:_files' && ret=0

return ret
