#compdef posthog-cli posthog

# Zsh completion for PostHog CLI
# https://posthog.com/docs/cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Authenticate with PostHog'
  'sourcemap:Manage sourcemaps'
  'dsym:Manage debug symbols'
  'hermes:Manage Hermes sourcemaps'
  'proguard:Manage ProGuard mapping files'
  'query:Run a HogQL query'
  'exp:Experimental features'
)

_arguments -s -S \
  '--host=[PostHog host to connect to]:host:' \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'posthog-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (sourcemap)
        _arguments -s -S \
          '1:subcommand:(inject upload)' \
          '*:: :->sourcemap_args' && ret=0
        ;;
      (query)
        _arguments -s -S '1:HogQL query:' && ret=0
        ;;
      (exp)
        _arguments -s -S '1:subcommand:(endpoints)' && ret=0
        ;;
    esac
    ;;
esac

return ret
