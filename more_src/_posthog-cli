#compdef posthog-cli
# Documentation: https://github.com/PostHog/posthog/tree/master/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:interactively authenticate with PostHog'
  'query:run a SQL query'
  'sourcemap:upload a directory of bundled chunks'
  'dsym:upload Apple dSYM debug symbol files'
  'hermes:upload hermes sourcemaps'
  'proguard:upload proguard mapping files'
  'symbol-sets:manage uploaded symbol sets'
  'exp:experimental commands'
  'help:print help message'
)

_arguments -s -S \
  '--host=[PostHog host to connect to]:host:' \
  '--no-fail[disable non-zero exit codes on errors]' \
  '--skip-ssl-verification[skip SSL verification]' \
  '--rate-limit=[requests per minute for API client]:n:' \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'posthog-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (sourcemap)
        _arguments -s -S \
          '1:subcommand:(inject upload)' \
          '*:: :->sourcemap_args' && ret=0
        ;;
      (query)
        _arguments -s -S '1:SQL query:' && ret=0
        ;;
      (exp)
        _arguments -s -S '1:subcommand:(endpoints tasks)' && ret=0
        ;;
    esac
    ;;
esac

return ret
