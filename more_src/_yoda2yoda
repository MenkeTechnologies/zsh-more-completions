#compdef yoda2yoda
# Documentation: https://yoda.hepforge.org/
# yoda2yoda - convert between YODA file formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --match)'{-m,--match}'[only write histograms whose path matches this regex]:regex:' \
  '(-M --unmatch)'{-M,--unmatch}'[exclude histograms whose path matches this regex]:regex:' \
  '--as-scatters[convert all input analysis objects to Scatter types]' \
  '*:file:_files' && ret=0

return ret
