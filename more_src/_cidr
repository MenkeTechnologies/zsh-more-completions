#compdef cidr

local -a commands=(
  'contains:check whether an IP is inside a CIDR'
  'count:count addresses in a CIDR'
  'divide:split a CIDR into N subnets'
  'explain:show network details for a CIDR'
  'overlaps:check whether two CIDRs overlap'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '(- *)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*::args:->args'

case $state in
  (cmd) _describe -t commands 'cidr command' commands ;;
  (args)
    case $line[1] in
      (contains)
        _arguments -s -S \
          '1:CIDR range:' \
          '2:IP address:' && return 0
        ;;
      (count|explain)
        _arguments -s -S '1:CIDR range:' && return 0
        ;;
      (divide)
        _arguments -s -S \
          '1:CIDR range:' \
          '2:number of subnets:' && return 0
        ;;
      (overlaps)
        _arguments -s -S \
          '1:first CIDR:' \
          '2:second CIDR:' && return 0
        ;;
    esac
    ;;
esac
