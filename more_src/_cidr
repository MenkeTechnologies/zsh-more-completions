#compdef cidr
# Documentation: https://github.com/bschaatsbergen/cidr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cidr: IPv4/IPv6 CIDR network prefix utility (bschaatsbergen/cidr)
local -a commands=(
  'contains:check whether an address belongs to a CIDR range'
  'count:count addresses in a CIDR range'
  'divide:divide a CIDR range into N distinct networks'
  'explain:show detailed network info for a CIDR'
  'overlaps:check whether two CIDRs overlap'
  'completion:generate shell completion'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '(- *)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*::args:->args'

case $state in
  (cmd) _describe -t commands 'cidr command' commands ;;
  (args)
    case $line[1] in
      (contains)
        _arguments -s -S \
          '1:CIDR range:' \
          '2:IP address:' && return 0
        ;;
      (count|explain)
        _arguments -s -S '1:CIDR range:' && return 0
        ;;
      (divide)
        _arguments -s -S \
          '1:CIDR range:' \
          '2:number of subnets:' && return 0
        ;;
      (overlaps)
        _arguments -s -S \
          '1:first CIDR:' \
          '2:second CIDR:' && return 0
        ;;
    esac
    ;;
esac
