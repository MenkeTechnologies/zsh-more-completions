#compdef drizzle-kit

# Zsh completion for Drizzle Kit CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:Generate SQL migrations'
      'push:Push schema changes directly to the database'
      'pull:Pull schema from existing database'
      'drop:Drop a migration'
      'check:Check for schema consistency'
      'up:Apply migrations to the database'
      'studio:Launch Drizzle Studio'
    )
    _describe -t commands 'drizzle-kit command' commands && ret=0
    ;;
  args)
    local -a common_flags=(
      '--config=[path to drizzle config file]:config file:_files'
      '--dialect=[database dialect]:dialect:(postgresql mysql sqlite)'
      '--driver=[database driver]:driver:(pg mysql2 better-sqlite3 libsql turso d1-http expo)'
      '--schema=[path to schema file]:schema file:_files'
      '--out=[output directory for migrations]:directory:_directories'
    )
    case ${words[1]} in
      generate)
        _arguments -s -S \
          $common_flags \
          '--name=[migration name]:name' \
          '--custom[generate empty custom migration]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      push)
        _arguments -s -S \
          $common_flags \
          '--strict[always ask for confirmation]' \
          '--verbose[show SQL statements]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      pull)
        _arguments -s -S \
          $common_flags \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      drop)
        _arguments -s -S \
          '--out=[migrations directory]:directory:_directories' \
          '--config=[path to drizzle config file]:config file:_files' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      check)
        _arguments -s -S \
          $common_flags \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      up)
        _arguments -s -S \
          $common_flags \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      studio)
        _arguments -s -S \
          '--config=[path to drizzle config file]:config file:_files' \
          '--port=[port for studio]:port' \
          '--host=[host for studio]:host' \
          '--verbose[verbose logging]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
