#compdef gmi
# Documentation: https://lieer.gaute.vetsj.com/
# gmi (lieer) - two-way tag synchronization between notmuch and GMail

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-C)-C[use repository directory]:dir:_files -/' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'gmi command' \
      'init[initialize local repository and authorize]' \
      'auth[authorize lieer with your GMail account]' \
      'sync[push local then pull remote changes]' \
      'pull[pull new e-mail and remote tag changes]' \
      'push[push local tag changes]' \
      'send[send a MIME message read from stdin]' \
      'set[set options for repository]' && ret=0
    ;;
  args)
    case $line[1] in
      pull|push|sync)
        _arguments -s \
          '(-f --force)'{-f,--force}'[overwrite conflicting changes]' \
          '--dry-run[do not apply changes]' \
          '--resume[continue an interrupted operation]' \
          '(-t)-t[list labels only]' && ret=0
        ;;
      auth)
        _arguments -s \
          '(-f --force)'{-f,--force}'[force reauthorization]' \
          '(-c)-c[client secrets file]:file:_files' && ret=0
        ;;
      set)
        _arguments -s \
          '--replace-slash-with-dot[replace slashes in labels with dots]' \
          '--ignore-empty-history[ignore empty remote history]' && ret=0
        ;;
    esac
    ;;
esac

return ret
