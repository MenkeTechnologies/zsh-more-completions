#compdef polyglot

# Zsh completion for polyglot - count lines of code

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-e,--exclude}'[exclude directory]:directory:_directories' \
  '(-p --parallel)'{-p,--parallel}'[number of parallel threads]:threads' \
  '(-t --table)'{-t,--table}'[table output]' \
  '(-s --sort)'{-s,--sort}'[sort results]:sort by:(language files code comments blanks)' \
  '(-S --no-sort)'{-S,--no-sort}'[do not sort results]' \
  '*:directory:_directories'
