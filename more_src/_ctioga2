#compdef ctioga2
# Documentation: https://manpages.ubuntu.com/manpages/trusty/en/man1/ctioga2.1.html
# ctioga2 - command-line front-end for the Tioga plotting library

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[print help about short and long options]' \
  '(-V --version)'{-V,--version}'[print the version of ctioga in use]' \
  '(-f --file)'{-f,--file}'[read the file and run commands found in it]:file:_files' \
  '(-e --eval)'{-e,--eval}'[run the given string as commands]:command' \
  '(-n --name)'{-n,--name}'[set the base name for output files]:name' \
  '(-o --output)'{-o,--output}'[write a figure with the given name and keep state]:name' \
  '--output-and-reset[write the current figure and start a fresh one]:name' \
  '(-O --output-directory)'{-O,--output-directory}'[directory for output files]:dir:_files -/' \
  '(-r --page-size)'{-r,--page-size}'[set PDF output dimensions (e.g. 12cm x 3in)]:size' \
  '--png[convert PDFs to PNG at the given resolution]:resolution' \
  '(-X --xpdf)'{-X,--xpdf}'[use xpdf viewer to display output]' \
  '--viewer[specify custom PDF viewer command]:command' \
  '(-p --plot)'{-p,--plot}'[load the given datasets and plot them]:dataset:_files' \
  '(-L --load)'{-L,--load}'[load the given dataset(s) onto the data stack]:dataset:_files' \
  '(-t --title)'{-t,--title}'[set the title of the current plot]:title' \
  '(-x --xlabel)'{-x,--xlabel}'[set the X-axis label]:label' \
  '(-y --ylabel)'{-y,--ylabel}'[set the Y-axis label]:label' \
  '--xrange[set the range of the X coordinates]:range' \
  '--yrange[set the range of the Y coordinates]:range' \
  '--xlog[use a logarithmic scale for the X axis]' \
  '--ylog[use a logarithmic scale for the Y axis]' \
  '(-c --color)'{-c,--color}'[set the line color for subsequent curves]:color' \
  '--line-width[set the line width for subsequent curves]:width' \
  '(-m --marker)'{-m,--marker}'[set the marker for subsequent curves]:marker' \
  '(-l --legend)'{-l,--legend}'[set the legend for the next dataset]:legend' \
  '--legend-inside[position legend inside plot area]:position' \
  '(-j --join-datasets)'{-j,--join-datasets}'[concatenate multiple datasets]' \
  '(-P --print-dataset)'{-P,--print-dataset}'[print the last dataset to standard output]' \
  '--sort-last[sort the last dataset by X values]' \
  '--apply-formula[apply a formula to the last dataset]:formula' \
  '--math[select the math backend]' \
  '--gnuplot[select the gnuplot backend]' \
  '--text[select the text file backend]' \
  '--csv[parse data files as CSV format]' \
  '(-v --verbose)'{-v,--verbose}'[output informative messages]' \
  '--debug[write extensive debugging information]' \
  '--echo[write the whole command-line to standard error]' \
  '*:dataset:_files' && ret=0

return ret
