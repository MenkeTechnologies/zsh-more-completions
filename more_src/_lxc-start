#compdef lxc-start

# Zsh completion for lxc-start (start an LXC container)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --name)'{-n,--name}'[container name]:name:->containers' \
  '(-d --daemon)'{-d,--daemon}'[run in background]' \
  '(-F --foreground)'{-F,--foreground}'[run in foreground]' \
  '(-p --pidfile)'{-p,--pidfile}'[PID file]:file:_files' \
  '(-f --rcfile)'{-f,--rcfile}'[config file]:file:_files' \
  '(-c --console)'{-c,--console}'[console device]:device' \
  '(-L --console-log)'{-L,--console-log}'[console log file]:file:_files' \
  '(-C --close-all-fds)'{-C,--close-all-fds}'[close all inherited file descriptors]' \
  '(-s --define)'{-s,--define}'[set config parameter]:key=value' \
  '--share-net[share network namespace]:container or PID' \
  '--share-ipc[share IPC namespace]:container or PID' \
  '--share-uts[share UTS namespace]:container or PID' \
  '--share-pid[share PID namespace]:container or PID' \
  '(-P --lxcpath)'{-P,--lxcpath}'[LXC path]:path:_files -/' \
  '(-o --logfile)'{-o,--logfile}'[log file]:file:_files' \
  '(-l --logpriority)'{-l,--logpriority}'[log priority]:priority:(FATAL CRIT ERROR WARN NOTICE INFO DEBUG)' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

case $state in
  (containers)
    local -a containers
    containers=(${(f)"$(lxc-ls 2>/dev/null)"})
    _describe -t containers 'container' containers && ret=0
    ;;
esac

return ret
