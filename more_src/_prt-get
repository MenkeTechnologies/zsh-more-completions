#compdef prt-get
# Documentation: https://crux.nu/Main/Handbook3-7
# CRUX higher-level package management tool operating on the ports tree

local ret=1

_arguments -s -S \
  '--install-scripts[enable pre/post-install script execution]' \
  '--no-deps[skip dependency processing]' \
  '--test[dry-run mode]' \
  '--pre-install[run pre-install scripts only]' \
  '--post-install[run post-install scripts only]' \
  '--root=[specify alternate root directory]:root:_files -/' \
  '(-fr --force)'{-fr,--force}'[override safety checks]' \
  '--cache[use the cache]' \
  '--regex[treat search expression as regex]' \
  '1:command:(install depinst update sysup diff listinst listorphans info search fsearch dsearch printf depends quickdep deptree dup remove ls cat readme path isinst current sync help dumpconfig)' \
  '*:port:' && ret=0

return ret
