#compdef create-expo-monorepo-template
# Documentation: https://www.npmjs.com/package/create-expo-monorepo-template
# Reference accessed: 2026-05-24
# Verified: npm view create-expo-monorepo-template bin; npm readme Flags section.

# Zsh completion for create-expo-monorepo-template - Expo monorepo template generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--repo=[template repository URL]:url:' \
  '--yes[use defaults or flag-provided values]' \
  '--dry-run[show plan without writing changes]' \
  '--project-name=[monorepo project name]:name:' \
  '--package-scope=[npm scope for packages]:scope:' \
  '--app-name=[display app name]:name:' \
  '--expo-slug=[Expo slug]:slug:' \
  '--bundle-identifier-ios=[iOS bundle identifier]:id:' \
  '--package-name-android=[Android package name]:name:' \
  '--no-git[skip git initialization]' \
  '--no-commit[skip initial commit]' && ret=0

return ret
