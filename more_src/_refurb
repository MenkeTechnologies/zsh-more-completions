#compdef refurb
# Documentation: https://man.archlinux.org/search?q=refurb
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help message]' \
  '--version[show version]' \
  '--debug[show debug information]' \
  '--quiet[suppress all output except errors]' \
  '--enable+[enable specific check]:check id:' \
  '--disable+[disable specific check]:check id:' \
  '--enable-all[enable all checks]' \
  '--disable-all[disable all checks]' \
  '--ignore+[ignore error code]:error code:' \
  '--load+[load custom check module]:module:' \
  '--config-file+[path to config file]:config:_files' \
  '--python-version+[target Python version]:version:(3.7 3.8 3.9 3.10 3.11 3.12 3.13)' \
  '--format+[output format]:format:(text github)' \
  '--sort[sort errors by category]' \
  '--explain+[explain an error code]:error code:' \
  '*:file or directory:_files' && ret=0

return ret
