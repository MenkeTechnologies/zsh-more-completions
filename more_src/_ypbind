#compdef ypbind
# _ypbind — OpenBSD ypbind (locates the YP server for a domain and stores binding info in /var/yp/binding/DOMAIN.version; pings every 20s and switches servers on failure)
# upstream: https://github.com/openbsd/src (usr.sbin/ypbind)
# Flags from usr.sbin/ypbind/ypbind.8 on tip.

_ypbind() {
    _arguments \
        '-insecure[allow ypset/ypsetme without privileged port]' \
        '-ypset[allow ypset from any host (insecure)]' \
        '-ypsetme[allow ypset only from localhost]'
}

_ypbind "$@"
