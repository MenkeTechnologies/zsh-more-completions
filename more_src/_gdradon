#compdef gdradon
# _gdradon — GDScript code metrics (cyclomatic complexity via radon) from gdtoolkit
# upstream: https://github.com/Scony/godot-gdscript-toolkit
# Flags from gdtoolkit/gdradon/__main__.py (docopt).

_gdradon() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_gdradon_commands' \
        '*:GDScript file or directory:_files -g "*.gd"' && ret=0

    return ret
}

(( $+functions[_gdradon_commands] )) ||
_gdradon_commands() {
    local -a commands
    commands=(
        'cc:cyclomatic-complexity report for the given GDScript files'
    )
    _describe -t commands 'gdradon command' commands
}

_gdradon "$@"
