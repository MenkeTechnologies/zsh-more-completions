#compdef fatrace

# Zsh completion for fatrace (file access trace - report file access events)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --current-mount)'{-c,--current-mount}'[Only report events on the current mount]' \
  '(-C --command-pattern)'{-C,--command-pattern}'=[Report events only for commands matching pattern]:pattern' \
  '(-f --filter)'{-f,--filter}'=[Report only specified event types]:filter:(O R W C)' \
  '(-o --output)'{-o,--output}'=[Write output to file]:file:_files' \
  '(-p --ignore-pid)'{-p,--ignore-pid}'=[Ignore events from this PID]:pid:_pids' \
  '(-s --timestamp)'{-s,--timestamp}'[Add timestamp to each event]' \
  '(-t --time-limit)'{-t,--time-limit}'=[Stop after specified seconds]:seconds' \
  '--sort[Sort events by timestamp]' \
  '(-h --help)'{-h,--help}'[Display help]' \
  '*:mount point:_files -/' && ret=0

return ret
