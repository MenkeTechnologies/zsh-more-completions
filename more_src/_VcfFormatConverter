#compdef VcfFormatConverter
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#VcfFormatConverter
# Picard: convert between VCF and BCF formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT=}'[BCF or VCF input file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  {-O=,--OUTPUT=}'[BCF or VCF output file]:vcf:_files -g "*.(vcf|vcf.gz|bcf)"' \
  '--REQUIRE_INDEX=[fail if an index is not available for the input]:bool:(true false)' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:vcf file:_files -g "*.(vcf|vcf.gz|bcf)"' && ret=0

return ret
