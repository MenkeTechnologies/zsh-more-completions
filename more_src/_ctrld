#compdef ctrld
# Documentation: https://github.com/Control-D-Inc/ctrld
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Control D DNS resolver / proxy.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run DNS proxy server in foreground'
  'start:install and launch service, configure DNS on interface'
  'stop:stop service and restore DNS settings'
  'restart:restart ctrld service'
  'reload:reload ctrld configuration'
  'status:show service status'
  'uninstall:terminate and remove service'
  'service:administer ctrld service'
  'clients:manage clients'
  'upgrade:upgrade ctrld to latest version'
  'log:manage runtime debug logging'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --silent)'{-s,--silent}'[suppress log output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging (-vv for debug)]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'ctrld command' commands && ret=0 ;;
esac

return ret
