#compdef ripctl
# _ripctl — OpenBSD ripctl (control + introspect the running ripd(8) RIPv2 routing daemon; show neighbors/interfaces/rib/fib, fib couple/decouple, reload, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/ripctl)
# Flags + commands from usr.sbin/ripctl/ripctl.8 on tip.

_ripctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /var/run/ripd.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ripctl command' \
                '(show:show subsystem state (interfaces|neighbor|rib|fib) fib:fib couple/decouple reload:reload ripd config log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(interfaces neighbor rib fib)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_ripctl "$@"
