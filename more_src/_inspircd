#compdef inspircd
# Documentation: https://man.archlinux.org/search?q=inspircd
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start daemon'
  'stop:stop daemon'
  'restart:restart daemon'
  'reload:reload configuration'
  'cron:run cron'
  'status:show status'
  'rehash:rehash configuration'
  'mkpasswd:make password hash'
  'modules:list modules'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=+[config file]:file:_files' \
  '--debug[debug to terminal]' \
  '--nofork[do not fork]' \
  '--nolog[disable file logging]' \
  '--runasroot[run as root]' \
  '--protocoldebug[debug protocol]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'inspircd command' commands && ret=0 ;;
esac

return ret
