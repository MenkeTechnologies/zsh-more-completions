#compdef inspircd
# Documentation: https://github.com/inspircd/inspircd
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# inspircd is a daemon binary with flags only (no subcommands).
# Flags verified against src/inspircd.cpp (lyra argv parsing).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-F --nofork)'{-F,--nofork}'[do not daemonize]' \
  '(-L --nolog)'{-L,--nolog}'[disable file logging]' \
  '(-p --protocoldebug)'{-p,--protocoldebug}'[enable protocol debug]' \
  '(-P --nopid)'{-P,--nopid}'[do not create PID file]' \
  '(-r --runasroot)'{-r,--runasroot}'[allow running as root]'
