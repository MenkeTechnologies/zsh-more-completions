#compdef tailpipe

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'collect:run a collection'
  'compact:compact parquet files'
  'connect:return a connection string'
  'format:list/show/delete formats'
  'help:show help'
  'partition:list/show/delete partitions'
  'plugin:plugin management'
  'query:execute a query'
  'source:list/show sources'
  'table:list/show tables'
)

_arguments -C \
  '--config-path=[config dir]:dir:_files -/' \
  '--workspace=[profile]:profile:' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'tailpipe subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (collect)
        _arguments -s \
          '--compact[compact after]' \
          '--from=[from date]:date:' \
          '--to=[to date]:date:' \
          '--overwrite[overwrite]' \
          '--progress[show progress]' \
          '*:partition or table:' && ret=0 ;;
      (compact)
        _arguments -s \
          '--reindex[reindex]' \
          '*:target:' && ret=0 ;;
      (connect)
        _arguments -s \
          '--from=[from]:date:' \
          '--to=[to]:date:' \
          '--index=[index]:index:' \
          '--partition=[partition]:partition:' \
          '--output=[format]:fmt:(json plain pretty)' && ret=0 ;;
      (query)
        _arguments -s \
          '--from=[from]:date:' \
          '--to=[to]:date:' \
          '--header=[header]:bool:(true false)' \
          '--index=[index]:index:' \
          '--partition=[partition]:partition:' \
          '--output=[format]:fmt:(table csv json line)' \
          '--separator=[separator]:char:' \
          '*:sql or file:_files -g "*.sql"' && ret=0 ;;
      (plugin)
        local -a psubs=('install:install plugin' 'list:list plugins' 'show:show plugin' 'uninstall:uninstall plugin' 'update:update plugin')
        _arguments '1: :->psub' '*:plugin:' && ret=0
        if [[ $state == psub ]]; then
          _describe -t subs 'plugin subcommand' psubs && ret=0
        fi ;;
      (partition)
        _arguments \
          '1:subcommand:(list show delete)' \
          '--output=[format]:fmt:(json plain pretty)' \
          '--from=[from]:date:' \
          '--force[force]' \
          '*:partition:' && ret=0 ;;
      (source|table|format)
        _arguments \
          '1:subcommand:(list show)' \
          '--output=[format]:fmt:(json plain pretty)' && ret=0 ;;
    esac
    ;;
esac

return ret
