#compdef pkgcruft
# _pkgcruft — QA scanner for Gentoo repositories (pkgcraft/pkgcraft)
# upstream: https://github.com/pkgcraft/pkgcraft
# Subcommands from crates/pkgcruft/src/bin/subcmds.rs (clap derive).

_pkgcruft() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
        '*'{-q,--quiet}'[decrease verbosity (repeatable)]' \
        '--color=[colorize output]:mode:(always auto never)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_pkgcruft_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                completion)
                    _arguments '1:shell:(bash elvish fish powershell zsh)' && ret=0 ;;
                diff)
                    _arguments '1:left report file:_files' '2:right report file:_files' && ret=0 ;;
                ignore|show)
                    _arguments '*:target:_files' && ret=0 ;;
                replay)
                    _arguments '1:report file:_files' && ret=0 ;;
                scan)
                    _arguments \
                        '-r+[repo to scan]:repo:_files -/' \
                        '-R+[reporter format]:reporter:(simple fancy json fixed)' \
                        '-c+[only run the given check (repeatable)]:check:' \
                        '-e+[only emit the given report level]:level:(info warning style error critical)' \
                        '-S+[sort reports by]:field:(category package version)' \
                        '*:target:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pkgcruft_commands] )) ||
_pkgcruft_commands() {
    local -a commands
    commands=(
        'completion:generate shell completion'
        'diff:compare two pkgcruft reports'
        'ignore:show ignore information for a target'
        'replay:replay a saved pkgcruft report'
        'scan:scan a repository for QA issues'
        'show:show various pkgcruft information (checks / reporters / scopes)'
    )
    _describe -t commands 'pkgcruft command' commands
}

_pkgcruft "$@"
