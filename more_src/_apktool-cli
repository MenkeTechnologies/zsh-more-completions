#compdef apktool

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'd:decode an APK'
  'decode:decode an APK'
  'b:build an APK'
  'build:build an APK'
  'if:install framework'
  'install-framework:install framework'
  'empty-framework-dir:remove installed frameworks'
  'p:publicize resources'
  'publicize-resources:publicize resources'
  'help:show help'
)

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-advance[advanced help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'apktool command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (d|decode)
        _arguments \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-r --no-res)'{-r,--no-res}'[no resources decode]' \
          '(-s --no-src)'{-s,--no-src}'[no source decode]' \
          '(-b --no-debug-info)'{-b,--no-debug-info}'[no debug info]' \
          '(-t --frame-tag)'{-t+,--frame-tag=}'[framework tag]:tag:' \
          '(-p --frame-path)'{-p+,--frame-path=}'[framework path]:dir:_files -/' \
          '(-o --output)'{-o+,--output=}'[output dir]:dir:_files -/' \
          '(-k --keep-broken-res)'{-k,--keep-broken-res}'[keep broken res]' \
          '(--no-assets)--no-assets[no assets]' \
          '(--only-main-classes)--only-main-classes[only main classes]' \
          '(--api)--api+[API level]:n:' \
          '*: :_files -g "*.apk"' && ret=0 ;;
      (b|build)
        _arguments \
          '(-f --force-all)'{-f,--force-all}'[force all]' \
          '(-d --debug)'{-d,--debug}'[debug]' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-o --output)'{-o+,--output=}'[output APK]:file:_files' \
          '(-a --aapt)'{-a+,--aapt=}'[aapt path]:file:_files' \
          '(--use-aapt2)--use-aapt2[use aapt2]' \
          '(-c --copy-original)'{-c,--copy-original}'[copy original]' \
          '(-p --frame-path)'{-p+,--frame-path=}'[framework path]:dir:_files -/' \
          '(--no-crunch)--no-crunch[no PNG crunching]' \
          '*: :_files -/' && ret=0 ;;
      (if|install-framework)
        _arguments \
          '(-t --tag)'{-t+,--tag=}'[tag]:tag:' \
          '(-p --frame-path)'{-p+,--frame-path=}'[framework path]:dir:_files -/' \
          '*: :_files -g "*.apk"' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
