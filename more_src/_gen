#compdef gen
# Documentation: https://github.com/genai-io/gen-code
# Reference accessed: 2026-05-22
# Verified: cmd/gen/main.go and cmd/gen/mcp.go Cobra commands.

# Zsh completion for gen - Gen Code terminal AI coding assistant

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --print)'{-p,--print}'[non-interactive print mode]:prompt:' \
  '(-c --continue)'{-c,--continue}'[resume most recent session]' \
  '(-r --resume)'{-r,--resume}'[resume session by ID]:id:' \
  '--plugin-dir[load plugins from directory]:directory:_directories' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'gen command' \
      'version[print version]' \
      'help[show help]' \
      'mcp[manage MCP servers]' \
      'agent[agent management]' && ret=0
    ;;
  args)
    case $line[1] in
      mcp)
        _values 'mcp command' add add-json edit list get remove && ret=0
        case $line[2] in
          add)
            _arguments \
              '(-t --transport)'{-t,--transport}'[transport type]:transport:(stdio http sse)' \
              '(-s --scope)'{-s,--scope}'[config scope]:scope:(user project local)' \
              '(-e --env)'{-e,--env}'[environment variable KEY=value]:env:' \
              '(-H --header)'{-H,--header}'[HTTP header Key\: Value]:header:' \
              '1:name:' '2:command or url:' && ret=0
            ;;
          add-json)
            _arguments \
              '(-s --scope)'{-s,--scope}'[config scope]:scope:(user project local)' \
              '1:name:' '2:json:' && ret=0
            ;;
          get|remove|edit)
            _arguments '1:name:' && ret=0
            ;;
        esac
        ;;
      agent)
        case $line[2] in
          run)
            _arguments \
              '--type[agent type]:type:' \
              '--prompt[task prompt]:prompt:' \
              '--model[model override]:model:' \
              '--max-turns[maximum turns]:turns:' && ret=0
            ;;
          *)
            _values 'agent command' run && ret=0
            ;;
        esac
        ;;
      *)
        _arguments '*:message:' && ret=0
        ;;
    esac
    ;;
esac

return ret
