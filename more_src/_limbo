#compdef limbo
# =============================================================================
# limbo — "Limbo compiler" — the reference compiler for Limbo,
#         Bell Labs / Vita Nuova's concurrent statically-typed
#         programming language for the Inferno distributed
#         operating system.  Compiles .b source files into
#         machine-independent .dis bytecode for the Dis virtual
#         machine.
#         Distinguishing from C, Java, Go, Erlang, and other
#         systems languages by:
#           - CSP-STYLE CHANNEL CONCURRENCY — Limbo introduced
#             the channel-based concurrency model later adopted
#             by Go (which shares authors Rob Pike + Phil
#             Winterbottom + Sean Dorward, all Bell Labs):
#               c := chan of int;
#               spawn sender(c);
#               # receive 10 values:
#               for (i := 0; i < 10; i++) {
#                   v := <-c;
#                   sys->print("received %d\n", v);
#               }
#           - `alt` STATEMENT for multi-channel select —
#             Limbo's `alt` is the direct ancestor of Go's
#             `select`:
#               alt {
#               v := <-c1 =>
#                   sys->print("from c1: %d\n", v);
#               c2 <-= 42 =>
#                   sys->print("sent to c2\n");
#               * =>
#                   sys->print("nothing ready\n");
#               }
#           - MACHINE-INDEPENDENT Dis BYTECODE — compiles to
#             .dis files interpreted by the Dis virtual machine;
#             portable across all Inferno-supported platforms
#             (AIX, FreeBSD, Linux, MacOS X, NetBSD, OpenBSD,
#             Plan 9, Solaris, Windows NT, and the native
#             Inferno OS).  Predates JVM portability claims
#             with proper bytecode portability since 1995.
#           - REFERENCE TYPES via `ref` keyword — `ref T` is a
#             reference to an ADT; assignment is by reference
#             (like Java objects), distinct from `T` value
#             types (like C structs)
#           - ALGEBRAIC DATA TYPES (`adt`) — record-with-methods
#             type:
#               Point: adt {
#                   x, y: int;
#                   add: fn(p: self ref Point, q: ref Point);
#                   neg: fn(p: self ref Point);
#               };
#               # Methods access via p.add(q) or Point.add(p, q)
#           - PICK-ADT (tagged unions / sum types) —
#             `adt { ... pick { ... } }` for sum types with
#             pattern matching via `pick`:
#               Tree: adt { pick {
#                   Leaf => v: int;
#                   Node => l, r: ref Tree;
#               } };
#               sum := 0;
#               pick t := tree {
#                   Leaf =>
#                       sum = t.v;
#                   Node =>
#                       sum = sum_tree(t.l) + sum_tree(t.r);
#               }
#           - MODULES via `module` and `implement` — Limbo
#             modules have explicit interfaces (in .m files)
#             and implementations:
#               implement Hello;
#               include "sys.m";  sys: Sys;
#               include "draw.m"; draw: Draw;
#               Hello: module {
#                   init: fn(ctxt: ref Draw->Context, args: list of string);
#               };
#               init(nil: ref Draw->Context, nil: list of string) {
#                   sys = load Sys Sys->PATH;
#                   sys->print("Hello, world!\n");
#               }
#           - LIST AS FIRST-CLASS LIST TYPE — `list of T` is a
#             cons-list (head + tail), distinct from `array of
#             T` which is dynamic-array:
#               l: list of int;
#               l = 3 :: 2 :: 1 :: nil;  # :: is cons
#               while (l != nil) {
#                   sys->print("%d ", hd l);  # hd = head
#                   l = tl l;                  # tl = tail
#               }
#           - EXCEPTIONS via `raise` / `exception` — explicit
#             exception types with declared `raises` annotation:
#               func: fn(x: int): int raises "math";
#               { ... raise "math:divbyzero" ... }
#           - SPAWN PRIMITIVE — `spawn` creates a new
#             coroutine/process with copy-on-write semantics,
#             managed by the Inferno scheduler (similar to Go's
#             `go` keyword which was directly inspired)
#           - DYNAMIC LOADING via `load` — modules can be loaded
#             at runtime from .dis files, enabling
#             plugin-architecture style applications:
#               sys = load Sys Sys->PATH;
#         Used by: distributed-OS research (Inferno spec
#         continues at Vita Nuova), embedded telecom systems
#         (Lucent IPN platform), and as the conceptual ancestor
#         of Go's concurrency model.  Limbo is what Rob Pike +
#         Phil Winterbottom + Sean Dorward developed at Bell
#         Labs immediately before Pike + Robert Griesemer + Ken
#         Thompson at Google created Go (2009); Go's `chan`,
#         `select`, `go` keywords are direct descendants of
#         Limbo's `chan`, `alt`, `spawn`.
#
# Author:  Bell Labs Computing Sciences Research (1995-1999):
#          Sean Dorward, Rob Pike, David Leo Presotto, Dennis
#          M. Ritchie, Howard Trickey, Philip Winterbottom.
#          Now maintained by Vita Nuova Holdings under the
#          Inferno OS project.  inferno-os GitHub mirror by
#          the community.  License: GPL/MIT/Lucent Public
#          License (multi-license, Inferno 4th Edition is
#          MIT+Plan 9 OSL).
# Source:  https://github.com/inferno-os/inferno-os
#          https://github.com/inferno-os/inferno-os/tree/master/limbo
#          https://github.com/inferno-os/inferno-os/blob/master/man/1/limbo
# Manpage: limbo(1) from Inferno man pages.
# Language: Limbo (https://www.vitanuova.com/inferno/limbo.html).
#           Distinct from C (Limbo's syntactic ancestor), Alef
#           (Limbo's immediate predecessor at Bell Labs), Go
#           (Limbo's successor), Java (closest contemporary by
#           design philosophy), and Erlang (closest by
#           concurrency model) by being:
#              1. CHANNEL-BASED CONCURRENCY — first-class chan
#                 type + spawn primitive + alt statement
#              2. MACHINE-INDEPENDENT Dis BYTECODE — portable
#                 across all Inferno-supported platforms (since
#                 1995, predating JVM bytecode portability
#                 claims)
#              3. EXPLICIT MODULE SYSTEM — module declarations
#                 in .m files + implement statements in .b
#                 files; modules loaded dynamically at runtime
#                 via `load`
#              4. ADT WITH PICK — algebraic data types with
#                 sum-type pattern matching
#              5. LIST OF T + ARRAY OF T as DISTINCT TYPES —
#                 cons-lists for functional patterns + dynamic
#                 arrays for sequential access
#              6. CYCLIC TYPES via `cyclic` keyword for self-
#                 referential ADT declarations
#              7. FIXED-POINT NUMBERS via `fixed` keyword —
#                 explicit fixed-point arithmetic with declared
#                 scale (no IEEE float ambiguity)
#              8. NO GLOBAL VARIABLES — modules export functions
#                 only; global state must go through ADT
#                 instances
#              9. tagof / sizeof / hd / tl BUILT-INS — explicit
#                 introspection without reflection
#             10. GO LINEAGE — direct ancestor of Go's `chan` /
#                 `select` / `go` concurrency primitives (Rob
#                 Pike acknowledged in Go talks that Limbo
#                 shaped Go's concurrency model)
# License: Lucent Public License + Plan 9 OSL.
# Status:  Inferno OS — 773+ stars on inferno-os/inferno-os;
#          historically deployed in Lucent telecom systems,
#          set-top boxes, embedded handsets.  Limbo's
#          conceptual influence persists in Go (Google) and
#          academic concurrent-language research.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 96TH LANGUAGE: LIMBO
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **96TH PROGRAMMING LANGUAGE**: Limbo.  This expands the taxonomy from
# 95 to 96 documented programming languages.  Pattern: R653 Rust=71
# (notify → Axis 17 OPENS) → R654 Go=71 (fsnotify) → R655 TS-Node=71
# (chokidar → Axis 17 1/1/1) → R656 96TH LANGUAGE (Limbo via limbo
# THIS).  This completes the 3-leader-bump + 1-new-language micro-cycle.
#
# WHY LIMBO IS A DISTINCTIVE 96TH LANGUAGE:
#
#   1. GO'S CONCEPTUAL ANCESTOR — Limbo is the language Rob Pike
#      + Phil Winterbottom + Sean Dorward designed at Bell Labs
#      in 1995-1999, immediately before Pike + Robert Griesemer
#      + Ken Thompson created Go at Google (2007 design, 2009
#      release).  Go's defining concurrency primitives are
#      direct descendants:
#         Limbo `chan T`        → Go `chan T`
#         Limbo `spawn fn(...)` → Go `go fn(...)`
#         Limbo `alt { ... }`   → Go `select { ... }`
#         Limbo `<-c` (recv)    → Go `<-c` (recv)
#         Limbo `c <-= v` (send)→ Go `c <- v` (send)
#      Rob Pike has stated in talks that Go's concurrency
#      model owes more to Limbo than to any other source
#      (including the original Hoare CSP paper that influenced
#      both).
#
#   2. MACHINE-INDEPENDENT Dis BYTECODE since 1995 — Limbo
#      compiles to a portable bytecode (Dis) interpreted by
#      a virtual machine.  This PREDATES Java's JVM (1995-1996
#      release) and dramatically predates .NET CLR (2002).
#      Inferno's Dis was designed for distributed computing
#      with cryptographic name-based resource access — a
#      vision that influenced Plan 9's 9P protocol and modern
#      capabilities-based systems.
#
#   3. ADT WITH PICK (Sum Types + Pattern Matching) — Limbo's
#      `adt { ... pick { Leaf => ...; Node => ... } }` provides
#      tagged-union sum types with structural pattern matching:
#         Tree: adt { pick {
#             Leaf => v: int;
#             Node => l, r: ref Tree;
#         } };
#         sum_tree: fn(t: ref Tree): int
#         {
#             sum := 0;
#             pick u := t {
#                 Leaf => sum = u.v;
#                 Node => sum = sum_tree(u.l) + sum_tree(u.r);
#             }
#             return sum;
#         }
#      Distinct from C/Java's lack of sum types, Rust's enums
#      (newer), and Haskell's data declarations (different
#      syntax).
#
#   4. EXPLICIT MODULES WITH DYNAMIC LOADING — Limbo separates
#      interface (.m files with `module` declarations) from
#      implementation (.b files with `implement` statements),
#      and supports DYNAMIC module loading via `load`:
#         sys = load Sys Sys->PATH;
#      enabling plugin architectures.  Distinct from C's
#      headers (preprocessor-based), Java's classpath (static),
#      and Go's import paths (compile-time).
#
#   5. FIXED-POINT NUMBERS — Limbo has built-in `fixed`
#      arithmetic with explicit scale (avoiding IEEE float
#      ambiguity).  Used in financial / telecom applications
#      where rounding semantics matter:
#         x: fixed (-1.0, 1.0, 0.00001);
#      Distinct from C/Java/Go which have only int + float.
#
#   6. CYCLIC TYPES via `cyclic` keyword — self-referential
#      ADTs explicitly marked:
#         Node: adt {
#             value: int;
#             cyclic next: ref Node;
#         };
#      Prevents infinite-recursion type errors in cyclic
#      structures (linked lists, trees).
#
#   7. EXCEPTION HANDLING via `raise` + `exception` — Limbo's
#      exceptions are first-class values with declared `raises`
#      clauses on function signatures:
#         divide: fn(a, b: int): int raises "math:divbyzero"
#         {
#             if (b == 0) raise "math:divbyzero";
#             return a / b;
#         }
#      Distinct from C's setjmp/longjmp, Java's checked
#      exceptions, and Go's panic/recover.
#
#   8. NO GLOBAL VARIABLES — Limbo modules export functions
#      only.  All global state lives inside ADT instances
#      passed explicitly to functions.  Enforces functional-
#      style code without static singletons.
#
#   9. INFERNO OS LINEAGE — Limbo is THE language for Inferno
#      OS (1995, Bell Labs).  Inferno was Plan 9's commercial
#      descendant — a distributed OS where all resources
#      (files, devices, network endpoints) are exposed through
#      a unified namespace.  Inferno was sold to Vita Nuova
#      Holdings (UK) in 2000, who continue maintaining the
#      4th Edition (MIT-licensed since 2003).
#
#  10. ROB PIKE / KEN THOMPSON / DENNIS RITCHIE LINEAGE —
#      Limbo's author team includes Rob Pike (Plan 9 + UTF-8 +
#      Go), Dennis Ritchie (C + Unix), Howard Trickey (Plan 9
#      compilers + Bell Labs), Phil Winterbottom (Alef + Plan
#      9 commands), and Sean Dorward (Inferno + Plan 9).  The
#      most prestigious systems-programming author roster of
#      any language in the taxonomy.
#
# Cross-language CLI library taxonomy after R656:
#   * 96 languages documented (Limbo is the 96th)
#   * 392 total CLI library variants
#   * Rust=71 / Go=71 / TS-Node=71 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 11 + 12 + 15 + 16 + 17: 1/1/1 three-language symmetric
#   * Nine axes at three-language symmetry
#
# Languages documented prior to R656 (selected):
#   * R605 ATS2 (patsopt) — 84th
#   * R612 Logtalk (logtalk_backend_select) — 85th
#   * R616 M/MUMPS (ydbinstall.sh) — 86th
#   * R620 REXX (regina) — 87th
#   * R624 Austral (austral) — 88th
#   * R628 Onyx (onyx) — 89th
#   * R632 TXR (txr) — 90th
#   * R636 Ioke (ioke) — 91st
#   * R640 Falcon (falcon) — 92nd
#   * R644 Slang (slangc) — 93rd
#   * R648 Clarity (clarity-cli) — 94th
#   * R652 Icon (icont) — 95th
#   * R656 Limbo (limbo THIS) — 96th
#
# -----------------------------------------------------------------------------
#
# THE limbo CLI — manpage-sourced flags
#
# limbo accepts the following flags (sourced verbatim from
# the limbo(1) manpage in inferno-os/inferno-os/man/1/limbo):
#
#   -a               Print type definitions and call frames
#                    useful for writing C language implementations
#                    of Limbo modules (suppresses normal output)
#   -C               Mark the Dis object file to PREVENT runtime
#                    compilation
#   -c               Mark the Dis object file to GUARANTEE runtime
#                    compilation
#   -D FLAGS         Turn on debugging flags.  FLAGS is a string of
#                    letters from the set: A a b C c D d e E F f m
#                    n P r S s T t v
#                    (each letter enables debugging for one aspect:
#                     A=arrays, a=alt, b=bools, C=case-body,
#                     c=case, D=descriptors, d=decls, e=exprs,
#                     E=extended-exprs, F=fn-info, f=const-fold,
#                     m=modules, n=nil-refs, P=pc-manip,
#                     r=ref-types, S=type-sigs, s=codegen-summary,
#                     T=tuples, t=type-check, v=var-init)
#   -e               Increase the number of errors before exit
#   -G               Annotate assembly output with debug info
#                    (no-op unless -S)
#   -g               Generate .sbl debug-info file
#   -i               Disable inlining of functions
#   -I DIR           Add DIR to include search path
#   -o OBJ           Place output in file OBJ (only allowed with
#                    a single input file)
#   -S               Create assembly language output instead of
#                    object code (.s instead of .dis)
#   -T MODULE        Print C stub functions to stdout (for
#                    implementing Limbo modules in C)
#   -t MODULE        Print runtime function table to stdout (for
#                    linking C implementations with Limbo
#                    interpreter)
#   -w[w...]         Print warnings about unused variables, etc.
#                    More w's increase pedantry
#
# File extensions:
#   FILE.b           Limbo source file
#   FILE.dis         Object code for Dis virtual machine
#   FILE.m           Module declarations
#   FILE.s           Assembly code
#   FILE.sbl         Symbolic debugging information
#
# Environment / paths:
#   /module          Standard include directory for module files
#   /appl/limbo      Compiler source written IN Limbo (self-hosting)
#   /limbo           Compiler source written in C (host build)
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/inferno-os/inferno-os/blob/master/man/1/limbo
# manpage option entries.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-a[print type defs + call frames for C impl of Limbo modules (suppresses output)]' \
    '-C[mark Dis object to prevent runtime compilation]' \
    '-c[mark Dis object to guarantee runtime compilation]' \
    '-D+[debugging flags (A/a/b/C/c/D/d/e/E/F/f/m/n/P/r/S/s/T/t/v)]:flags:_default' \
    '-e[increase number of errors before exit]' \
    '-G[annotate assembly output with debug info (requires -S)]' \
    '-g[generate .sbl debug-info file]' \
    '-i[disable function inlining]' \
    '*-I+[add directory to include search path]:directory:_files -/' \
    '-o+[output to FILE (single input only)]:file:_files' \
    '-S[create assembly output instead of Dis object code]' \
    '-T+[print C stub functions for MODULE]:module:_default' \
    '-t+[print C runtime function table for MODULE]:module:_default' \
    '*-w[warn about unused variables (more w = more pedantic)]' \
    '*:source file:_files -g "*.(b|m|dis|s|sbl)"' \
    && ret=0

return ret
