#compdef apfs-fuse
# Documentation: https://github.com/sgan81/apfs-fuse
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-d[debug mode]' \
  '-f[foreground mode]' \
  '-o+[mount options]:options' \
  '-s+[volume number]:volume number' \
  '-v+[volume number to mount]:volume number' \
  '-r[recovery volume]' \
  '-p+[password or recovery key]:password' \
  '1:device or image:_files' \
  '2:mountpoint:_directories' && return 0
