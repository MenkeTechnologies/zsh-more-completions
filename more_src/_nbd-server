#compdef nbd-server
# Documentation: https://man.archlinux.org/search?q=nbd-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-d[do not fork (debug)]' \
  '-r[read-only]' \
  '-m[multi-file export]' \
  '-c[copy-on-write]' \
  '-l+[hosts allow file]:file:_files' \
  '-o+[output config to stdout]:section:' \
  '-C+[config file]:file:_files -g "*.conf"' \
  '-p+[PID file]:file:_files' \
  '-n[non-fork mode (one client at a time)]' \
  '-M+[max connections]:n:' \
  '*:host_port_or_file:_files' && ret=0

return ret
