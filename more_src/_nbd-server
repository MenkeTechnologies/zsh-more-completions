#compdef nbd-server
# Documentation: https://manpages.debian.org/trixie/nbd-server/nbd-server.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-V[show version]' \
  '-d[do not fork (debug)]' \
  '-r[read-only]' \
  '-m[multi-file export]' \
  '-c[copy-on-write]' \
  '-l+[hosts allow file]:file:_files' \
  '-o+[output config section]:section:' \
  '-C+[config file]:file:_files -g "*.conf"' \
  '-M+[max connections]:n:' \
  '*:host_port_or_file:_files' && ret=0

return ret
