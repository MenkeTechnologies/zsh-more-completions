#compdef dolphin-emu
# Documentation: https://github.com/dolphin-emu/dolphin
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dolphin-emu — GameCube and Wii emulator.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-u --user)'{-u+,--user=}'[user folder path]:directory:_directories' \
  '(-e --exec)'{-e+,--exec=}'[load the specified file]:file:_files' \
  '(-n --nand_title)'{-n+,--nand_title=}'[launch a NAND title (16-char ID)]:title id:' \
  '(-m --movie)'{-m+,--movie=}'[play a movie file]:file:_files' \
  '(-s --save_state)'{-s+,--save_state=}'[load initial save state]:file:_files' \
  '(-C --config)'{-C+,--config=}'[set System.Section.Key=Value]:setting:' \
  '(-v --video_backend)'{-v+,--video_backend=}'[select video backend]:backend:(D3D D3D12 OGL Vulkan Null Software)' \
  '(-a --audio_emulation)'{-a+,--audio_emulation=}'[audio emulation]:emulation:(HLE LLE)' \
  '(-d --debugger)'{-d,--debugger}'[show debugger pane]' \
  '(-l --logger)'{-l,--logger}'[open the logger]' \
  '(-b --batch)'{-b,--batch}'[run without UI (requires --exec or --nand-title)]' \
  '(-c --confirm)'{-c,--confirm}'[set Confirm on Stop]' \
  '*:game file:_files'
