#compdef dolphin-emu

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-u+[user directory path]:directory:_directories' \
  '--user=[user directory path]:directory:_directories' \
  '-m+[system memory size in MB]:size' \
  '--movie=[play a movie file]:file:_files' \
  '-e+[load the specified file]:file:_files' \
  '--exec=[load the specified file]:file:_files' \
  '-C+[set a configuration option]:setting' \
  '--config=[set a configuration option]:setting' \
  '-b[exit Dolphin after emulation ends]' \
  '--batch[exit Dolphin after emulation ends]' \
  '-d[start in debugger mode]' \
  '--debugger[start in debugger mode]' \
  '-l[use logger]' \
  '--logger[use logger]' \
  '-v+[select video backend]:backend:(OGL Vulkan "Software Renderer" Null)' \
  '--video_backend=[select video backend]:backend:(OGL Vulkan "Software Renderer" Null)' \
  '-a+[select audio emulation]:emulation:(HLE LLE)' \
  '--audio_emulation=[select audio emulation]:emulation:(HLE LLE)' \
  '-p+[select platform]:platform' \
  '--platform=[select platform]:platform' \
  '*:game file:_files'
