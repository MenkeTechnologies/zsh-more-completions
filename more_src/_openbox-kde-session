#compdef openbox-kde-session
# Documentation: https://man.archlinux.org/search?q=openbox-kde-session
# Reference accessed: 2026-05-16

# openbox-kde-session: launch Openbox inside a KDE session
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::openbox-kde-session args:_files' && ret=0
return ret
