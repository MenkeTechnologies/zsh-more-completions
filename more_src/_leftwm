#compdef leftwm

# Zsh completion for leftwm (tiling window manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'worker:Start the window manager worker'
  'state:Print the current state as JSON'
  'command:Send a command to the running WM'
  'check:Check the configuration for errors'
  'theme:Manage themes'
  'log:Output log level'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'leftwm command' commands && ret=0
    ;;
  args)
    case $words[1] in
      command)
        local -a wm_commands=(
          'SoftReload' 'HardReload' 'ToggleScratchPad' 'ToggleFullScreen'
          'ToggleSticky' 'GotoTag' 'ReturnToLastTag' 'FloatingToTile'
          'TileToFloating' 'ToggleFloating' 'SwapTags' 'MoveWindowUp'
          'MoveWindowDown' 'MoveWindowTop' 'FocusWindowUp' 'FocusWindowDown'
          'FocusNextTag' 'FocusPreviousTag' 'FocusWorkspaceNext'
          'FocusWorkspacePrevious' 'NextLayout' 'PreviousLayout'
          'SetLayout' 'RotateTag' 'IncreaseMainWidth' 'DecreaseMainWidth'
          'SetMarginMultiplier' 'CloseWindow' 'SwapScreens'
          'MoveWindowToLastWorkspace' 'MoveWindowToNextWorkspace'
          'MoveWindowToPreviousWorkspace'
        )
        _describe -t wm_commands 'window manager command' wm_commands && ret=0
        ;;
      theme)
        local -a theme_cmds=(
          'update:Update the themes list'
          'install:Install a theme'
          'uninstall:Uninstall a theme'
          'list:List available themes'
          'status:Show current theme status'
          'apply:Apply a theme'
          'new:Create a new theme'
        )
        _describe -t theme_cmds 'theme subcommand' theme_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
