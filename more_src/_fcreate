#compdef fcreate
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/fcreate.txt
# Create a FITS table extension from ASCII files

local ret=1

_arguments -s \
  "cdfile=[column descriptor file]:file:_files" \
  "datafile=[ASCII data file]:file:_files" \
  "outfile=[output FITS file]:file:_files" \
  "headfile=[optional header keyword file]:file:_files" \
  "tbltype=[table type ascii or binary]:type:(ascii binary)" \
  "nskip=[number of leading lines to skip]:" \
  "nrows=[number of rows to read]:" \
  "history=[add HISTORY keywords]:bool:(yes no)" \
  "morehdr=[number of extra header slots]:" \
  "extname=[extension name]:" \
  "anull=[ASCII null value]:" \
  "inull=[integer null value]:" \
  "clobber=[overwrite output file]:bool:(yes no)" \
  "*:file:_files" && ret=0

return ret
