#compdef twister
# _twister — Zephyr Project twister CLI test runner orchestrating sample app and unit-test builds across boards QEMU native_posix native_sim hardware target adapters parallel multi-config matrix coverage merging filtering by tag platform arch (Zephyr team, Python); custom argparse
# upstream: https://github.com/zephyrproject-rtos/zephyr/blob/main/scripts/twister

_twister() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-T+[testsuite root]:dir:_files -/' \
        '--testsuite-root=+[dir]:dir:_files -/' \
        '-t+[tag]:str:' \
        '--tag=+[tag]:str:' \
        '-x+[extra args]:str:' \
        '--extra-args=+[name=val]:str:' \
        '-p+[platform]:str:' \
        '--platform=+[platform]:str:' \
        '-A+[board-root]:dir:_files -/' \
        '--board-root=+[dir]:dir:_files -/' \
        '-s+[test name]:str:' \
        '--scenario=+[test name]:str:' \
        '-l[show all tests]' \
        '--list-tests[list tests]' \
        '--list-tags[list tags]' \
        '-n[no clean]' \
        '--no-clean[no clean]' \
        '-c[clobber output dir]' \
        '--clobber-output[clobber output dir]' \
        '-O+[outdir]:dir:_files -/' \
        '--outdir=+[outdir]:dir:_files -/' \
        '-N+[ninja]:n:' \
        '--ninja[use ninja]' \
        '-M[make]' \
        '-j+[jobs]:n:' \
        '--jobs=+[jobs]:n:' \
        '-b[build only]' \
        '--build-only[build only]' \
        '-d[device testing]' \
        '--device-testing[device testing]' \
        '-X+[serial]:str:' \
        '--device-serial=+[device]:file:_files -g "/dev/tty* /dev/cu.*"' \
        '--device-serial-baud=+[baud]:n:' \
        '-H+[hardware-map]:file:_files -g "*.yaml *.yml"' \
        '--hardware-map=+[file]:file:_files -g "*.yaml *.yml"' \
        '-R[enable size report]' \
        '--enable-size-report[size report]' \
        '--west-flash[west flash]' \
        '--west-runner=+[runner]:str:' \
        '-G[ccache]' \
        '--ccache[ccache]' \
        '--coverage[coverage]' \
        '--coverage-formats=+[fmt]:f:(html xml csv lcov json)' \
        '--coverage-platform=+[plat]:str:' \
        '--coverage-tool=+[tool]:t:(gcovr lcov)' \
        '--enable-coverage[enable coverage]' \
        '--gcov-tool=+[gcov]:file:_files' \
        '--save-tests=+[file]:file:_files' \
        '--load-tests=+[file]:file:_files' \
        '--quarantine-list=+[file]:file:_files -g "*.yaml *.yml"' \
        '--inline-logs[inline logs]' \
        '--retry-failed=+[N]:n:' \
        '--retry-build-errors[retry build errors]' \
        '--show-footprint[show footprint]' \
        '--filter=+[f]:f:(buildable runnable any)' \
        '--integration[integration mode]' \
        '--only-failed[only failed]' \
        '--report-dir=+[dir]:dir:_files -/' \
        '--report-name=+[name]:str:' \
        '--report-summary=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '*:path:_files'
}

_twister "$@"
