#compdef pcp-summary
# Documentation: https://man.archlinux.org/search?q=pcp-summary
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[archive]:file:_files' \
  '-h+[host]:host:_hosts' \
  '-O+[origin time]:time:' \
  '-z[use archive timezone]' \
  '-Z+[timezone]:tz:' && ret=0

return ret
