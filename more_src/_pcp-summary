#compdef pcp-summary
# Documentation: https://man7.org/linux/man-pages/man1/pcp.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a+[archive]:file:_files' \
  '-h+[host]:host:_hosts' \
  '-O+[origin time]:time:' \
  '-z[use archive timezone]' \
  '-Z+[timezone]:tz:' && ret=0

return ret
