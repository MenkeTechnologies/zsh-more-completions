#compdef ddev

# Zsh completion for ddev (local PHP/Node.js development tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'auth:authentication commands'
      'clean:remove unnecessary items'
      'composer:execute composer commands'
      'config:create or modify ddev project config'
      'craft:execute Craft CMS commands'
      'debug:debugging commands'
      'delete:remove a project'
      'describe:describe a project'
      'drush:execute Drush commands'
      'exec:execute a command in a container'
      'export-db:export a database'
      'get:get add-on'
      'hostname:manage hostnames'
      'import-db:import a database'
      'import-files:import files'
      'launch:launch a browser'
      'list:list projects'
      'logs:view container logs'
      'mutagen:mutagen commands'
      'npm:execute npm commands'
      'pause:pause a project'
      'php:execute PHP commands'
      'poweroff:stop all projects and containers'
      'pull:pull files and database'
      'push:push files and database'
      'restart:restart a project'
      'self-upgrade:upgrade ddev'
      'share:share project via ngrok'
      'snapshot:manage database snapshots'
      'ssh:SSH into a container'
      'start:start a project'
      'stop:stop a project'
      'version:show version'
      'wp:execute WP-CLI commands'
      'xdebug:enable/disable Xdebug'
      'yarn:execute yarn commands'
    )
    _describe -t commands 'ddev command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (config)
        _arguments \
          '--project-type[project type]:type:(backdrop craftcms django4 drupal drupal6 drupal7 drupal8 drupal9 drupal10 drupal11 laravel magento magento2 php shopware6 silverstripe typo3 wordpress)' \
          '--docroot[document root]:path:_files -/' \
          '--project-name[project name]:name' \
          '--php-version[PHP version]:version:(5.6 7.0 7.1 7.2 7.3 7.4 8.0 8.1 8.2 8.3)' \
          '--webserver-type[web server]:type:(nginx-fpm apache-fpm nginx-gunicorn)' \
          '--database[database type and version]:db:(mariadb:10.4 mariadb:10.5 mariadb:10.6 mariadb:10.11 mysql:5.7 mysql:8.0 postgres:14 postgres:15 postgres:16)' \
          '--nodejs-version[Node.js version]:version:(16 18 20 22)' && ret=0
        ;;
      (start|stop|restart|pause|delete|describe|launch)
        local -a projects
        projects=(${(f)"$(ddev list -j 2>/dev/null | jq -r '.[].name' 2>/dev/null)"})
        _arguments '1:project:compadd -a projects' && ret=0
        ;;
      (exec|ssh)
        _arguments \
          '-s[service]:service:(web db)' \
          '--dir[working directory]:directory' \
          '*:command' && ret=0
        ;;
      (import-db)
        _arguments \
          '--file[database file]:file:_files -g "*.{sql,sql.gz,sql.bz2,sql.xz,sql.zip,tar,tar.gz,tgz}"' \
          '--no-drop[do not drop existing database]' \
          '--target-db[target database name]:name' && ret=0
        ;;
      (export-db)
        _arguments \
          '--file[output file]:file:_files' \
          '--gzip[compress with gzip]' \
          '--bzip2[compress with bzip2]' \
          '--xz[compress with xz]' \
          '--target-db[target database name]:name' && ret=0
        ;;
      (snapshot)
        _arguments '1:action:(restore list clear)' && ret=0
        ;;
      (xdebug)
        _arguments '1:action:(on off toggle status)' && ret=0
        ;;
      (logs)
        _arguments \
          '-s[service]:service:(web db)' \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '--tail[number of lines]:lines' && ret=0
        ;;
    esac
    ;;
esac

return ret
