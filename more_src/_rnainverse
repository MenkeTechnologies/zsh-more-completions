#compdef rnainverse
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAinverse.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAinverse: design RNA sequences that fold to a target structure
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-R --repeat)'{-R,--repeat=-}'[number of trial sequences per design]::n:' \
  '(-F --function)'{-F,--function=}'[fitness function]:fn:(mp m p)' \
  '(-f --final)'{-f,--final=}'[final fitness threshold]:val:' \
  '(-a --alphabet)'{-a,--alphabet=}'[allowed alphabet]:alphabet:' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '--nsp=[non-standard base pair list]:pairs:' \
  '--energyModel=[energy model]:em:' \
  '*:target structure file:_files' && ret=0
return ret
