#compdef ghalint
# Documentation: https://github.com/suzuki-shunsuke/ghalint
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a base_args

base_args=(
  '(-h --help)'{-h,--help}'[Show help]'
  '(-c --config)'{-c,--config}'+[Configuration file]:file:_files -g "*.y?(a)ml(-.)"'
  '1: :->cmds'
  '*:: :->args'
)

_arguments -C "${base_args[@]}" && ret=0

case $state in
  (cmds)
    local -a cmds=(
      run:'lint GitHub Actions workflows'
      'run-action:lint composite action metadata'
      act:'alias for run-action'
      exp:'experimental commands'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments '*:path:_files' && ret=0
        ;;
      (run-action|act)
        _arguments '*:action file:_files -g "action.y?(a)ml(-.)"' && ret=0
        ;;
      (exp)
        _arguments '2:subcommand:(validate-input token)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
