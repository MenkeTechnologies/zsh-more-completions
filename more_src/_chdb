#compdef chdb
# Documentation: https://github.com/chdb-io/chdb-go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--path=[directory for persistent storage]:dir:_files -/' \
  '(-q --query)'{-q+,--query=}'[SQL query to execute]:query:' \
  '--queries-file=[file containing queries]:file:_files -g "*.sql"' \
  '--multiquery[multiple semicolon-separated queries]' \
  '(-m --multiline)'{-m,--multiline}'[multi-line input mode]' \
  '--database=[database to use]:database:' \
  '--format=[output format]:format:(TSV CSV TabSeparated TabSeparatedWithNames JSON JSONEachRow PrettyCompact Pretty Vertical Markdown Native Parquet Arrow ORC LineAsString TabSeparatedRaw RawBLOB)' \
  '--vertical[use Vertical output format]' \
  '--time[print query execution time]' \
  '--echo[echo queries before executing]' \
  '--verbose[verbose output]' \
  '--logger.level=[log level]:level:(trace debug information warning error)' \
  '--config-file=[server config file]:file:_files' \
  '--input-format=[input format]:format:' \
  '--structure=[input table structure]:structure:' \
  '--input=[input file]:file:_files' \
  '--output=[output file]:file:_files' \
  '--no-system-tables[disable system tables]' \
  '--stacktrace[print stack trace on errors]' \
  '*::extra:' && ret=0

return ret
