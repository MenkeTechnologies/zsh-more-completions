#compdef pt-mongodb-summary pt-mongodb-query-digest
# Documentation: https://docs.percona.com/percona-toolkit/pt-mongodb-summary.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (pt-mongodb-summary)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      {-v,--version}'[show version]' \
      {-a+,--authenticationDatabase=}'[database for credentials]:db:' \
      {-c,--no-version-check}'[disable version check]' \
      {-f+,--output-format=}'[report format]:fmt:(text json)' \
      '--host=[MongoDB host]:host:_hosts' \
      {-i+,--running-ops-interval=}'[ms between op samples]:ms:' \
      {-l+,--log-level=}'[log level]:lvl:(panic fatal error warn info debug)' \
      {-p+,--password=}'[password]:pw:' \
      '--port=[MongoDB port]:port:' \
      {-s+,--running-ops-samples=}'[op samples to collect]:n:' \
      '--sslCAFile=[SSL CA file]:file:_files' \
      '--sslPEMKeyFile=[SSL PEM key file]:file:_files' \
      '--uri=[MongoDB connection URI]:uri:' \
      {-u+,--username=}'[username]:user:' \
      '*:host\:port:' && ret=0 ;;
  (pt-mongodb-query-digest)
    _arguments \
      '(- *)'{-?,--help}'[show help]' \
      {-v,--version}'[show version]' \
      {-a+,--authenticationDatabase=}'[database for credentials]:db:' \
      {-c,--no-version-check}'[do not check for updates]' \
      {-d+,--database=}'[database to profile]:db:' \
      {-f+,--output-format=}'[report format]:fmt:(text json)' \
      {-l+,--log-level=}'[log level]:lvl:(panic fatal error warn info debug)' \
      {-n+,--limit=}'[limit queries to show]:n:' \
      {-o+,--order-by=}'[order by]:field:(count ratio query-time docs-examined docs-returned)' \
      {-p+,--password=}'[password]:pw:' \
      {-s+,--skip-collections=}'[collections to skip]:list:' \
      '--sslCAFile=[SSL CA file]:file:_files' \
      '--sslPEMKeyFile=[SSL PEM key file]:file:_files' \
      {-u+,--user=}'[username]:user:' \
      '*:host\:port:' && ret=0 ;;
  (*)
    _arguments \
      '(- *)--help[show help]' \
      '--version[show version]' && ret=0 ;;
esac

return ret
