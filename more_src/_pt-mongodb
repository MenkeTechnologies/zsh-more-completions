#compdef pt-mongodb-summary pt-mongodb-query-digest
# Documentation: https://man.archlinux.org/search?q=pt-mongodb-summary
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (pt-mongodb-summary)
    _arguments \
      '(- *)--help[show help]' \
      '--version[show version]' \
      '--user=[user]:user:' \
      '--password=[password]:pw:' \
      '--auth-db=[auth db]:db:' \
      '--auth-mechanism=[auth mechanism]:mech:(SCRAM-SHA-1 SCRAM-SHA-256 MONGODB-CR PLAIN GSSAPI)' \
      '--ssl[use SSL]' \
      '--ssl-ca-file=[CA file]:file:_files' \
      '--sample-count=[sample count]:n:' \
      '--sample-rate=[sample rate]:rate:' \
      '--debug-level=[debug level]:lvl:' \
      '--json[output JSON]' \
      '*:host\:port:' && ret=0 ;;
  (pt-mongodb-query-digest)
    _arguments \
      '(- *)--help[show help]' \
      '--version[show version]' \
      '--user=[user]:user:' \
      '--password=[password]:pw:' \
      '--auth-db=[auth db]:db:' \
      '--database=[database]:db:' \
      '--explain[show query plans]' \
      '--limit=[limit queries shown]:n:' \
      '--order-by=[order by]:field:(count ratio query_time docs_returned docs_scanned response_length)' \
      '--no-version-check[skip version check]' \
      '--no-stats[skip stats]' \
      '--debug-level=[debug level]:lvl:' \
      '*:host\:port:' && ret=0 ;;
  (*)
    _arguments \
      '(- *)--help[show help]' \
      '--version[show version]' && ret=0 ;;
esac

return ret
