#compdef mpdas
# Documentation: https://man.archlinux.org/search?q=mpdas
# Reference accessed: 2026-05-16

# Zsh completion for mpdas - C++ MPD AudioScrobbler client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[display help]' \
  '-d[run as daemon]' \
  '-v[verbose output]' \
  '-c[config file path]:file:_files' && ret=0

return ret
