#compdef mpdas
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mpdas.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mpdas - C++ MPD AudioScrobbler client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[display help]' \
  '-v[display version]' \
  '-d[run as daemon (detached)]' \
  '-c+[config file path]:file:_files' && ret=0

return ret
