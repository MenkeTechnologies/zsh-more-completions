#compdef ld65
# ld65 — linker for 6502-based systems

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-C+[use linker config file]:config file:_files' \
  '*-D+[define a symbol]:name=value:' \
  '*-L+[add library search path]:directory:_directories' \
  '-Ln+[create VICE label file]:label file:_files' \
  '-S+[set start address]:address:' \
  '-m+[create map file]:map file:_files' \
  '-o+[specify output file]:output file:_files' \
  '-t+[set target system]:target:(apple2 apple2enh atari atarixl atmos c16 c64 c128 cbm510 cbm610 cx16 geos-apple geos-cbm lynx nes none osic1p pce pet plus4 sim6502 sim65c02 supervision vic20)' \
  '-u+[force import of symbol]:symbol:' \
  '-v[increase verbosity]' \
  '--cfg-path=[add config search path]:directory:_directories' \
  '--lib-path=[add library search path]:directory:_directories' \
  '--obj-path=[add object search path]:directory:_directories' \
  '--dbgfile=[create debug info file]:debug file:_files' \
  '--config=[use linker config file]:config file:_files' \
  '--define=[define a symbol]:name=value:' \
  '--force-import=[force import of symbol]:symbol:' \
  '--lib=[link with library]:library file:_files' \
  '--mapfile=[create map file]:map file:_files' \
  '--module-id=[specify module id]:id:' \
  '--start-addr=[set start address]:address:' \
  '--target=[set target system]:target:(apple2 apple2enh atari atarixl atmos c16 c64 c128 cbm510 cbm610 cx16 geos-apple geos-cbm lynx nes none osic1p pce pet plus4 sim6502 sim65c02 supervision vic20)' \
  '*:object file:_files -g "*.o(-.)"' && ret=0

return ret
