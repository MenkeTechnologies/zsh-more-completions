#compdef nwggrid nwgbar nwgdmenu
# Documentation: https://man.archlinux.org/search?q=nwggrid
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

case $service in
  (nwggrid)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-fn+[font]:font:' \
      '-l+[locale]:locale:' \
      '-b+[background color RGBA]:rgba:' \
      '-t+[opacity 0.0-1.0]:opacity:' \
      '-c+[columns count]:n:' \
      '-s+[icon size px]:px:' \
      '-d[focus first item]' \
      '-o+[opacity]:val:' \
      '-x[skip categories]' \
      '-fav[show favourites]' \
      '-pins[show pinned items]' \
      '-p[show pinned items]' \
      '-r[run in background]' \
      '-n+[max favourites]:n:' \
      '-wm+[window manager]:wm:(sway hyprland river openbox i3 awesome)' \
      '-layer-shell-layer=[layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' && ret=0 ;;
  (nwgbar)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-v[show version]' \
      '-t+[template]:tpl:' \
      '-c+[CSS file]:file:_files' \
      '-s+[icon size]:px:' \
      '-o+[opacity 0.0-1.0]:opacity:' \
      '-p+[position]:pos:(left right top bottom center)' \
      '-x[exit on focus loss]' \
      '-wm+[window manager]:wm:(sway hyprland river openbox i3 awesome)' \
      '-layer-shell-layer=[layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' && ret=0 ;;
  (nwgdmenu)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '-v[show version]' \
      '-c+[columns]:n:' \
      '-fh+[history max]:n:' \
      '-fm+[favourites max]:n:' \
      '-l+[label format]:fmt:' \
      '-r[run in background]' \
      '-wm+[window manager]:wm:(sway hyprland river openbox i3 awesome)' && ret=0 ;;
esac

return ret
