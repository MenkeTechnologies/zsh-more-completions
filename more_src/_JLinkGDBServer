#compdef JLinkGDBServer JLinkGDBServerCLExe
# Documentation: https://kb.segger.com/J-Link_GDB_Server
# SEGGER J-Link GDB Server - remote debugging via the GDB protocol

local ret=1

_arguments -s -S \
  '-device[specify target device]:device' \
  '-endian[set target endianness]:endianness:(little big)' \
  '-if[select target interface]:interface:(JTAG SWD FINE 2-wire-JTAG-PIC32)' \
  '-speed[set initial connection speed in kHz]:speed' \
  '-port[GDB listener port]:port' \
  '-swoport[SWO data port]:port' \
  '-telnetport[printf/semihosting output port]:port' \
  '-RTTTelnetPort[RTT output port]:port' \
  '-USB[select J-Link over USB]:serial/nickname' \
  '-IP[select J-Link over TCP/IP]:host' \
  '-halt[halt target on startup]' \
  '-nohalt[do not halt target]' \
  '-noreset[skip reset, only halt CPU]' \
  '-ir[initialize CPU registers]' \
  '-noir[skip register initialization]' \
  '-log[write output to log file]:file:_files' \
  '-logtofile[generate log file]' \
  '-nologtofile[disable log file]' \
  '-silent[suppress log messages]' \
  '-nosilent[show log messages]' \
  '-excdbg[enable exception debugging]:steps' \
  '(-singlerun -s)'{-singlerun,-s}'[close when all clients disconnect]' \
  '(-nosinglerun -nos)'{-nosinglerun,-nos}'[stay running]' \
  '-gui[allow DLL dialogs]' \
  '-nogui[suppress DLL dialogs]' \
  '-x[execute init file once at first connection]:file:_files' \
  '-xc[execute init file on each connection]:file:_files' \
  '-jlinkscriptfile[run J-Link script before debugging]:file:_files' \
  '-settingsfile[use J-Link settings file]:file:_files' \
  '-rtos[load RTOS plugin]:file:_files' \
  '-localhostonly[accept only localhost connections]:state' \
  '-nolocalhostonly[allow remote connections]' \
  '-timeout[target connection timeout in ms]:ms' \
  '-notimeout[infinite timeout]' \
  '-jtagconf[configure JTAG scan chain]:IRPre,DRPre' \
  '-cpu[pre-select CPU core (deprecated)]:core' \
  '-stayontop[keep window on top]' \
  '-nostayontop[normal window behavior]' \
  '-vd[verify downloaded data]' \
  '-novd[skip verification]' \
  '-powertarget[power target after delay]:value' \
  '-JLinkDevicesXMLPath[custom device definitions path]:path:_files' \
  '-strict[exit on configuration errors]' \
  '-version[print version and exit]' && ret=0

return ret
