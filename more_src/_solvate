#compdef solvate gmx-solvate
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-solvate.html
# Generate a box of solvent or solvate a solute configuration in solvent

local ret=1

_arguments -s -S \
  '-cp+[solute structure file]:structure file:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '-cs+[solvent structure file]:structure file:_files -g "*.(gro|g96|pdb|brk|ent|esp|tpr)"' \
  '-p+[topology file]:topology file:_files -g "*.top"' \
  '-o+[output coordinate file]:structure file:_files -g "*.(gro|g96|pdb)"' \
  '-box+[box dimensions in nm]:vector:' \
  '-radius+[default van der Waals distance nm]:value:' \
  '-scale+[scaling factor for van der Waals radii]:value:' \
  '-shell+[thickness of water layer around solute nm]:value:' \
  '-maxsol+[maximum solvent molecules to add]:number:' \
  '-vel[retain velocities from input structures]' \
  '-h[show help]' \
  '-version[show version]' && ret=0

return ret
