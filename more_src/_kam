#compdef kam
# Documentation: https://man.archlinux.org/search?q=kam
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      bootstrap:'bootstrap GitOps CI/CD'
      build:'build pipeline definitions'
      completion:'emit shell completion scripts'
      environment:'manage GitOps environments'
      service:'manage services in an environment'
      version:'print version details'
      webhook:'configure Git webhooks'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    case $words[1] in
      bootstrap)
        _arguments -s -S \
          '--service-repo-url=[service repository URL]:url:' \
          '--gitops-repo-url=[gitops repository URL]:url:' \
          '--git-host-access-token=[Git provider token]:' \
          '--image-repo=[image registry/repository]:' \
          '--dockercfgjson=[Docker config path]:file:_files' \
          '--output=[path to write manifests]:dir:_directories' \
          '--push-to-git[push generated manifests]' \
          '--interactive[prompt for unset options]' \
          '--overwrite[replace existing GitOps output]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
