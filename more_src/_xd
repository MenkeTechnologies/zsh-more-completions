#compdef xd
# Documentation: https://github.com/lueckenhoff/xd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall xdotter@0.5.2
# Probed via: completion zsh
# Repository: https://github.com/cncsmonster/xdotter

autoload -U is-at-least

_xd() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_xd_commands" \
"*::: :->xd" \
&& ret=0
    case $state in
    (xd)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:xd-command-$line[1]:"
        case $line[1] in
            (deploy)
_arguments "${_arguments_options[@]}" : \
'-n[Show planned operations without modifying the filesystem]' \
'--dry-run[Show planned operations without modifying the filesystem]' \
'(-i --interactive)-f[Automatically handle recoverable conflicts (cannot bypass safety checks)]' \
'(-i --interactive)--force[Automatically handle recoverable conflicts (cannot bypass safety checks)]' \
'(-f --force)-i[Ask for confirmation before each destructive operation]' \
'(-f --force)--interactive[Ask for confirmation before each destructive operation]' \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(undeploy)
_arguments "${_arguments_options[@]}" : \
'-n[Show planned operations without modifying the filesystem]' \
'--dry-run[Show planned operations without modifying the filesystem]' \
'(-i --interactive)-f[Automatically handle recoverable conflicts (cannot bypass safety checks)]' \
'(-i --interactive)--force[Automatically handle recoverable conflicts (cannot bypass safety checks)]' \
'(-f --force)-i[Ask for confirmation before each destructive operation]' \
'(-f --force)--interactive[Ask for confirmation before each destructive operation]' \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'-n[Report what would be created without writing the file]' \
'--dry-run[Report what would be created without writing the file]' \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completion for:_default' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'*-v[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'*--verbose[Increase log verbosity (-v info, -vv debug, -vvv trace). May be repeated; more than three is treated as -vvv]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_xd__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:xd-help-command-$line[1]:"
        case $line[1] in
            (deploy)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(undeploy)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_xd_commands] )) ||
_xd_commands() {
    local commands; commands=(
'deploy:Deploy dotfiles (default)' \
'undeploy:Remove deployed dotfiles' \
'status:Show deployment status' \
'new:Create a new xdotter.toml template' \
'completion:Generate shell completion scripts' \
'version:Print version' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'xd commands' commands "$@"
}
(( $+functions[_xd__subcmd__completion_commands] )) ||
_xd__subcmd__completion_commands() {
    local commands; commands=()
    _describe -t commands 'xd completion commands' commands "$@"
}
(( $+functions[_xd__subcmd__deploy_commands] )) ||
_xd__subcmd__deploy_commands() {
