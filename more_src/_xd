    _describe -t commands 'xd help undeploy commands' commands "$@"
}
(( $+functions[_xd__subcmd__help__subcmd__version_commands] )) ||
_xd__subcmd__help__subcmd__version_commands() {
    local commands; commands=()
    _describe -t commands 'xd help version commands' commands "$@"
}
(( $+functions[_xd__subcmd__new_commands] )) ||
_xd__subcmd__new_commands() {
    local commands; commands=()
    _describe -t commands 'xd new commands' commands "$@"
}
(( $+functions[_xd__subcmd__status_commands] )) ||
_xd__subcmd__status_commands() {
    local commands; commands=()
