#compdef pfstmo_durand02
# Documentation: http://pfstools.sourceforge.net/man1/pfstmo_durand02.1.html
# pfstools: Durand 2002 bilateral filtering tone mapping operator

local ret=1

_arguments -s -S \
  '(-s --sigma-s)'{-s,--sigma-s}'=[sigma for spatial kernel (default 40)]:val' \
  '(-r --sigma-r)'{-r,--sigma-r}'=[sigma for range kernel (default 0.4)]:val' \
  '(-c --base-contrast)'{-c,--base-contrast}'=[contrast of base layer (default 5.0)]:val' \
  '(-g --original)'{-g,--original}'[use original algorithm with no extensions]' \
  '--verbose[print additional information]' \
  '(-q --quiet)'{-q,--quiet}'[do not display progress report]' \
  '(-h --help)'{-h,--help}'[print list of command line options]' && ret=0

return ret
