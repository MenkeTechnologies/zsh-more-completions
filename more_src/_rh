#compdef rh
# Documentation: https://github.com/chucknorris/roundhouse/wiki/ConfigurationOptions
# RoundhousE database migration utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --database --databasename)'{-d,--database,--databasename}'=[target database name]:database' \
  '(-c --connstring --connectionstring)'{-c,--connstring,--connectionstring}'=[full connection string]:connstring' \
  '(-s --server --servername --instance)'{-s,--server,--servername,--instance}'=[database server location]:server' \
  '(-f --files --sqlfilesdirectory)'{-f,--files,--sqlfilesdirectory}'=[SQL scripts folder path]:dir:_files -/' \
  '(--silent --noninteractive -ni)'{--silent,--noninteractive,-ni}'[do not ask for any input]' \
  '--dryrun[preview changes without executing]' \
  '(--transaction --withtransaction)'{--transaction,--withtransaction}'[run inside of a transaction]' \
  '--baseline[record scripts without executing them]' \
  '--drop[remove database without running migrations]' \
  '--commandtimeout=[script execution timeout]:seconds' \
  '--commandtimeoutadmin=[admin command timeout]:seconds' \
  '--restoretimeout=[restore operation timeout]:seconds' \
  '--restore[enable database restoration]' \
  '(--restorefrompath --rfp)'{--restorefrompath,--rfp}'=[backup file location]:file:_files' \
  '--version=[specify version directly]:version' \
  '(--repo --repositorypath)'{--repo,--repositorypath}'=[repository identifier]:repo' \
  '(--environment --environmentname --env)'{--environment,--environmentname,--env}'=[environment-specific script filtering]:env' \
  '--versionfile=[version resolution file]:file:_files' \
  '(-o --output --outputpath)'{-o,--output,--outputpath}'=[migration artifacts location]:dir:_files -/' \
  '--debug[enable verbose logging]' \
  '--disableoutput[suppress backup/permissions output]' && ret=0

return ret
