#compdef nmail
# Documentation: https://man.archlinux.org/search?q=nmail
# Reference accessed: 2026-05-16

# https://github.com/d99kris/nmail — terminal email client (see `nmail --help`)
_arguments -s -S \
  '--help[help]' \
  '--version[version]' \
  '--verbose[verbose log]' \
  '--config-dir=-[override config directory]:dir:_directories' \
  '*:ignored:_default'
