#compdef nmail
# Documentation: https://github.com/d99kris/nmail
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Flags taken from d99kris/nmail README usage section.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --cache-encrypt)'{-c,--cache-encrypt}'[prompt for cache encryption during OAuth2 setup]' \
  '(-d --confdir)'{-d,--confdir}'+[override config directory]:dir:_directories' \
  '(-e --verbose)'{-e,--verbose}'[verbose logging]' \
  '(-ee --extra-verbose)'{-ee,--extra-verbose}'[extra verbose logging]' \
  '(-k --keydump)'{-k,--keydump}'[key code dump mode]' \
  '(-o --offline)'{-o,--offline}'[run in offline mode]' \
  '(-p --pass)'{-p,--pass}'[change password]' \
  '(-ro --read-only)'{-ro,--read-only}'[run shadow instance with read-only cache]' \
  '(-s --setup)'{-s,--setup}'+[setup wizard for service]:service:(gmail gmail-oauth2 icloud outlook outlook-oauth2)' \
  '(-x --export)'{-x,--export}'+[export cache to directory in Maildir format]:dir:_directories'
