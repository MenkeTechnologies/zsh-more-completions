#compdef kube2pulumi
# Documentation: https://github.com/pulumi/kube2pulumi/blob/master/cmd/kube2pulumi/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[YAML file to convert]:file:_files -g "*.(yaml|yml)(N)"' \
  '(-d --directory)'{-d+,--directory=}'[file path for directory to convert]:dir:_files -/' \
  '(-o --outputFile)'{-o+,--outputFile=}'[name of the output file to write to]:file:_files' \
  '1:language:->langs' \
  '*::arg:->args' && ret=0

case $state in
  langs)
    local -a langs=(
      'go:convert to Go'
      'typescript:convert to TypeScript'
      'python:convert to Python'
      'csharp:convert to C#'
      'java:convert to Java'
      'all:convert to all supported languages'
      'version:print version'
    )
    _describe -t langs 'kube2pulumi language' langs && ret=0
    ;;
esac

return ret
