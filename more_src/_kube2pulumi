#compdef kube2pulumi

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubernetes-version=[target Kubernetes version]:ver:' \
  '-d[directory of YAML manifests]:dir:_files -/' \
  '-f[multi-document YAML file]:file:_files -g "*.yaml" "*.yml"' \
  '*:manifest files:_files -g "*.yaml" "*.yml"'
