#compdef just-cli
# _just-cli — Casey Rodarmor just command runner CLI alias (casey, Rust); clap-rs
# upstream: https://github.com/casey/just

_just-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--changelog[print changelog]' \
        '--check[check format]' \
        '--choose[interactively choose a recipe]' \
        '--chooser=+[chooser command]:str:' \
        '--clear-shell-args[clear shell args]' \
        '--color=+[color]:c:(auto always never)' \
        '--command=+[command]:str:' \
        '-c+[command]:str:' \
        '--command-color=+[command color]:c:(black blue cyan green purple red yellow)' \
        '--completions=+[completions]:s:(bash elvish fish nushell powershell zsh)' \
        '--dotenv-filename=+[dotenv filename]:str:' \
        '--dotenv-path=+[dotenv path]:file:_files' \
        '--dry-run[dry run]' \
        '--dump[print canonical recipe]' \
        '--dump-format=+[dump format]:fmt:(just json)' \
        '--edit[edit justfile]' \
        '-e[edit justfile]' \
        '--evaluate[evaluate variables]' \
        '--explain[print explanation]' \
        '--fmt[format justfile]' \
        '--global-justfile[use global justfile]' \
        '-g[use global justfile]' \
        '--groups[list groups]' \
        '--highlight[highlight]' \
        '--init[init justfile]' \
        '--justfile=+[justfile]:file:_files -g "justfile *.just"' \
        '-f+[justfile]:file:_files -g "justfile *.just"' \
        '--list[list recipes]' \
        '-l[list recipes]' \
        '--list-heading=+[list heading]:str:' \
        '--list-prefix=+[list prefix]:str:' \
        '--list-submodules[list submodules]' \
        '--no-deps[no deps]' \
        '--no-dotenv[no dotenv]' \
        '--no-highlight[no highlight]' \
        '--one[run only first recipe]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--set=+[set variable key=value]:list:' \
        '--shell=+[shell command]:str:' \
        '--shell-arg=+[shell arg]:str:' \
        '--shell-command[shell command mode]' \
        '--show=+[show recipe]:str:' \
        '-s+[show recipe]:str:' \
        '--summary[print recipe summaries]' \
        '--timestamp[timestamps]' \
        '--unsorted[unsorted list]' \
        '-u[unsorted list]' \
        '--unstable[enable unstable features]' \
        '--variables[list variables]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--working-directory=+[working dir]:dir:_files -/' \
        '-d+[working dir]:dir:_files -/' \
        '--yes[assume yes]' \
        '*:recipe-or-args:'
}

_just-cli "$@"
