#compdef dt-cli
# Documentation: https://github.com/blurgyy/dt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# blurgyy/dt dotfile manager — `dt-cli` takes config-path + group names, no subcommands

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config-path)'{-c,--config-path=}'[config file path]:file:_files' \
  '(-d --dry-run)'{-d,--dry-run}'[dry-run, show what would change]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging verbosity (repeatable)]' \
  '(-q --quiet)'{-q,--quiet}'[decrease logging verbosity (repeatable)]' \
  '*:group name:'
