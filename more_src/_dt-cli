#compdef dt-cli
# Documentation: https://man.archlinux.org/search?q=dt-cli
# Reference accessed: 2026-05-16

# Zsh completion for dt-cli (blurgyy/dt crate dt-cli binary; structopt name "dt").

local -a subcmds
subcmds=(
  'sync:sync dotfiles from source to target (aliases: s)'
  's:alias for sync'
  'collect:collect changes from target (aliases: c)'
  'c:alias for collect'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :{_describe '\''command'\'' subcmds}' \
  '*:: :->args'

[[ $state == args ]] || return 0

case $line[1] in
  sync|s)
    _arguments -s -S \
      '(-c --config-path)'{-c,--config-path=}'[config file]:file:_files' \
      '(-d --dry-run)'{-d,--dry-run}'[show changes only]' \
      '(-v --verbose)'{-v,--verbose}'[more logging (repeatable)]' \
      '(-q --quiet)'{-q,--quiet}'[less logging (repeatable)]' \
      '*:group name:'
    ;;
  collect|c)
    _arguments -s -S \
      '(-c --config-path)'{-c,--config-path=}'[config file]:file:_files' \
      '(-d --dry-run)'{-d,--dry-run}'[show changes only]' \
      '(-s --state-path)'{-s,--state-path=}'[state file]:file:_files' \
      '--skip-dirty[skip dirty files instead of aborting]' \
      '(-v --verbose)'{-v,--verbose}'[more logging (repeatable)]' \
      '(-q --quiet)'{-q,--quiet}'[less logging (repeatable)]' \
      '*:group name:'
    ;;
esac
