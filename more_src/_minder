#compdef minder
# Documentation: https://man.archlinux.org/search?q=minder
# Reference accessed: 2026-05-16

# Zsh completion for minder (Stacklok minder CLI)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values -s 'minder' \
      auth completion config docs doctor fetch invite project provider quickstart repo \
      artifact attestation ruletype secret user version whoami && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
