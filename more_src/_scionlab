#compdef scionlab scionlab-config
# _scionlab — Network Security Group ETH Zurich scionlab CLI for joining and managing SCIONLab network experiments (netsec-ethz team, Python); argparse
# upstream: https://github.com/netsec-ethz/scionlab

_scionlab() {
    local -a sub=(
        'config:configure local SCIONLab host'
        'fetch:fetch and apply latest config'
        'register:register a host'
        'status:show host status'
        'restart:restart SCIONLab services'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--host-id=+[host id]:str:' \
        '--host-secret=+[host secret]:str:' \
        '--url=+[coordinator URL]:url:_urls' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scionlab subcommand' sub ;;
        args)
            case $words[1] in
                register) _arguments \
                    '--as-id=+[ISD-AS id]:str:' \
                    '--label=+[label]:str:' ;;
                status) _arguments \
                    '--all[show all services]' ;;
            esac
            ;;
    esac
}

_scionlab "$@"
