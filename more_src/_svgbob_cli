#compdef svgbob_cli
# Documentation: https://github.com/ivanceras/svgbob
# svgbob_cli - convert ASCII diagrams to SVG

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --inline)'{-s,--inline}'[parse an inline string]' \
  '(-o --output)'{-o,--output}'[where to write svg output]:output file:_files' \
  '--background=[backdrop background fill color]:color' \
  '--fill-color=[solid shapes fill color]:color' \
  '--font-family=[font to render text with]:font' \
  '--font-size=[font size for text]:size' \
  '--stroke-width=[stroke width for all lines]:width' \
  '--stroke-color=[stroke color for all lines]:color' \
  '--scale=[scale the entire svg by this factor]:factor' \
  '1:input file:_files' && ret=0

return ret
