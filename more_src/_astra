#compdef astra

# datastax/astra-cli; Homebrew: Formula/a/astra.rb (tests: config path -p, db list, compgen)

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'astra command' compadd -- config db compgen shell completion help
  ;;
rest)
  case $line[1] in
    config)
      _arguments '2: :((path))' \
        '(-p)'{-p}'[print path only]' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
