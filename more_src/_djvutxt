#compdef djvutxt
# _djvutxt — DjVuLibre djvutxt CLI for extracting hidden OCR text layer from DjVu documents emitting either plain text or DjVuTXT structured text-zone output (djvu team, C++); getopt
# upstream: https://djvu.sourceforge.net/

_djvutxt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-page=+[page range]:str:' \
        '--page=+[page range]:str:' \
        '-detail=+[d]:d:(page region para line word char)' \
        '--detail=+[d]:d:(page region para line word char)' \
        '-escape[escape unicode]' \
        '--escape[escape unicode]' \
        '-text[plain text only]' \
        '--text[plain text only]' \
        '-output=+[output file]:file:_files -g "*.txt *.djvutxt"' \
        '--output=+[output file]:file:_files -g "*.txt *.djvutxt"' \
        '-noxml[no XML wrapper]' \
        '--no-xml[no XML wrapper]' \
        '-keepbreaks[keep breaks]' \
        '--keep-breaks[keep breaks]' \
        '*:DjVu file:_files -g "*.djvu *.djv *.djz"'
}

_djvutxt "$@"
