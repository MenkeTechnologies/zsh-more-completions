#compdef xremap

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--watch[watch for new devices and remap them]' \
  '--mouse[also remap mouse events]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish)' \
  '--device=[target device names]:device' \
  '--ignore=[device names to ignore]:device' \
  '*:config file:_files -g "*.{yml,yaml,toml}"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
