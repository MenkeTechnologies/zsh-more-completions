#compdef xremap
# Documentation: https://github.com/k0kubun/xremap
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--watch=-[monitor for new devices or config changes]:what:(device config)' \
  '--mouse[also remap mouse events]' \
  '--completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '*--device=[restrict to device by name or path]:device:' \
  '*--ignore=[exclude devices by name or path]:device:' \
  '--output-device-name=[name of virtual output device]:name:' \
  '--vendor=[vendor ID (hex)]:id:' \
  '--product=[product ID (hex)]:id:' \
  '--list-devices[list device information]' \
  '--device-details[show detailed device specifications]' \
  '--list-windows[list open windows with app class and title]' \
  '--no-window-logging[suppress window change logging]' \
  '--allow-launch=[control program execution permissions]:val:(true false)' \
  '--bridge[open desktop environment bridge for system service]' \
  '*:config file:_files -g "*.{yml,yaml,toml}"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
