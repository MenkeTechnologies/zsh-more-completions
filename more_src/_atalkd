#compdef atalkd
# _atalkd — Netatalk atalkd (AppleTalk routing daemon and per-interface registrar; -d debug, -f config file, -P pidfile, -t test config + exit, -V version, -n print network setup, -q quiet, -F foreground, -b run as bootstrap; reads /etc/netatalk/atalkd.conf for AppleTalk interface declarations)
# upstream: https://github.com/Netatalk/netatalk
# Flags from Netatalk/netatalk etc/atalkd/main.c on tip.

_atalkd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[debug level]:level:' \
        '-f+[config file]:file:_files' \
        '-P+[pidfile]:file:_files' \
        '-t[test config + exit]' \
        '-n[print network setup + exit]' \
        '-q[quiet]' \
        '-F[foreground]' \
        '-b[bootstrap mode]'
}

_atalkd "$@"
