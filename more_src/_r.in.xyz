#compdef r.in.xyz
# Creates a raster map from an assemblage of coordinates using statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-s[scan data file for extent then exit]' \
  '-g[in scan mode, print using shell script style]' \
  '-i[ignore broken lines]' \
  '--overwrite[allow output files to overwrite existing files]' \
  '--verbose[verbose module output]' \
  '--quiet[quiet module output]' \
  'input=[ASCII file path (- for stdin)]:input:_files' \
  'output=[name for resulting raster map]:output:' \
  'method=[statistical aggregation approach]:method:(n min max range sum mean stddev variance coeff_var median percentile skewness trimmean)' \
  'type=[output data type]:type:(CELL FCELL DCELL)' \
  'separator=[field delimiter]:separator:' \
  'x=[column position of x coordinates]:x:' \
  'y=[column position of y coordinates]:y:' \
  'z=[column position of z values]:z:' \
  'zrange=[filter bounds for z data (min,max)]:zrange:' \
  'zscale=[multiplier applied to z values]:zscale:' \
  'percent=[memory allocation percent]:percent:' \
  '*:param:' && ret=0

return ret
