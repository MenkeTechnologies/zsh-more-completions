#compdef lumo
# Documentation: https://github.com/anmonteiro/lumo/wiki/Cli-options
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --legal)'{-l,--legal}'[legal info]' \
  '(-c --classpath)'{-c+,--classpath=}'[classpath]:cp:' \
  '(-D --dependencies)'{-D+,--dependencies=}'[Maven deps]:deps:' \
  '(-L --local-repo)'{-L+,--local-repo=}'[Maven local repo]:dir:_files -/' \
  '(-K --auto-cache)'{-K,--auto-cache}'[auto-cache]' \
  '(-k --cache)'{-k+,--cache=}'[cache dir]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-d --dumb-terminal)'{-d,--dumb-terminal}'[dumb terminal]' \
  '(-r --repl)'{-r,--repl}'[run repl]' \
  '(-i --init)'{-i+,--init=}'[init file]:file:_files -g "*.cljs *.cljc"' \
  '(-e --eval)'{-e+,--eval=}'[evaluate string]:expr:' \
  '(-m --main)'{-m+,--main=}'[main ns]:ns:' \
  '(-n --socket-repl)'{-n+,--socket-repl=}'[socket repl]:bind:' \
  '*: :_files -g "*.cljs *.cljc"' && ret=0

return ret
