#compdef kanji-config-updmap
# Set up embedding of Japanese/Chinese/Korean fonts via updmap.cfg

local ret=1

_arguments -s -S \
  '(-n --dry-run)'{-n,--dry-run}'[do not actually run updmap]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--mode=[set up for a CJK language]:mode:(ja ko sc tc)' \
  '--ja[shorthand for --mode=ja (Japanese)]' \
  '--ko[shorthand for --mode=ko (Korean)]' \
  '--sc[shorthand for --mode=sc (Simplified Chinese)]' \
  '--tc[shorthand for --mode=tc (Traditional Chinese)]' \
  '--jis2004[use JIS2004 variants for default (u)pTeX fonts]' \
  '--sys[run in sys mode (updmap -sys)]' \
  '--user[run in user mode (updmap -user)]' \
  '--old[call updmap without --user argument in user mode]' \
  '--force[set up embedding even if the font is not available]' \
  '--version[show version information and exit]' \
  '*:target:(auto nofont status)' && ret=0

return ret
