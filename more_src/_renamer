#compdef renamer
# Documentation: https://man.archlinux.org/search?q=renamer
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-y[skip confirmation]' \
  '--yes[skip confirmation]' \
  '-u[undo the last operation]' \
  '--undo[undo the last operation]' \
  '-p[pretty print diff]' \
  '--pretty-diff[pretty print diff]' \
  '*:files:_files' && ret=0

return ret
