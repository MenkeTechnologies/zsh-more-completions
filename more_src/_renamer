#compdef renamer
# Documentation: https://github.com/75lb/renamer/wiki/Renamer-CLI-docs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dry-run)'{-d,--dry-run}'[do everything but rename the file]' \
  '--force[overwrite target path if it exists]' \
  '--view=[output view]:view:(long diff one-line)' \
  '(-f --find)'{-f,--find}'=[find string or regex literal]:pattern:' \
  '(-r --replace)'{-r,--replace}'=[replace string]:replacement:' \
  '(-e --path-element)'{-e,--path-element}'=[part of path to rename]:element:(base name ext)' \
  '--index-format=[printf format for {{index}}]:fmt:' \
  '--index-root=[starting index value]:n:' \
  '--index-step=[index increment]:n:' \
  '--plugin=[load a renamer plugin]:plugin:' \
  '--chain=[plugin chain]:chain:' \
  '*:files:_files' && ret=0

return ret
