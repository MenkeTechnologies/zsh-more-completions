#compdef shai-scan
# Documentation: https://github.com/digi4care/shai-scan
# Reference accessed: 2026-05-22
# Verified: src/cli.ts argument parsing and --help output.

# Zsh completion for shai-scan - npm/PyPI supply chain compromise scanner

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--json[output results as JSON]' \
  '--sarif[output results as SARIF]' \
  '--sarif-file[write SARIF to file]:file:_files' \
  '--text[human-readable text output]' \
  '--severity[minimum severity]:severity:(critical high medium low)' \
  '--lockfiles-only[skip system IOC checks]' \
  '--system-only[skip lockfile scanning]' \
  '--no-color[disable ANSI colors]' \
  '1:path:_files -/' && ret=0

return ret
