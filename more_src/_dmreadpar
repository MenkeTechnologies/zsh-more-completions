#compdef dmreadpar
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmreadpar.html
# Write the contents of a parameter file into a file header

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'input=[input parameter file]:input:_files -g "*.par"' \
  'output=[file receiving new header keywords]:output:_files' \
  'template=[template file]:template:_files' \
  'case=[output keyword case]:case:(same upper lower)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing keywords]:clobber:(yes no)' \
  '*:argument:_files' && ret=0

return ret
