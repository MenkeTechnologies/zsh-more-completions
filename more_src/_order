#compdef order gmx-order
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-order.html
# gmx order: compute the order parameter per atom for carbon tails

local ret=1

_arguments -s \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-nr[index file]:file:_files' \
  '-s[portable xdr run input file]:file:_files' \
  '-o[xvgr/xmgr file]:file:_files' \
  '-od[xvgr/xmgr file]:file:_files' \
  '-ob[protein data bank file]:file:_files' \
  '-os[xvgr/xmgr file]:file:_files' \
  '-Sg[xvgr/xmgr file]:file:_files' \
  '-Sk[xvgr/xmgr file]:file:_files' \
  '-Sgsl[xvgr/xmgr file]:file:_files' \
  '-Sksl[xvgr/xmgr file]:file:_files' \
  '-b[time of first frame to read]:time:' \
  '-e[time of last frame to read]:time:' \
  '-dt[frame selection interval]:time:' \
  '-w[view output files]' \
  '-xvg[xvg plot formatting]:format:(xmgrace xmgr none)' \
  '-d[direction of membrane normal]:dir:(z x y)' \
  '-sl[number of slices for box division]:int:' \
  '-szonly[only Sz tensor element]' \
  '-permolecule[per-molecule Scd parameters]' \
  '-radial[radial membrane normal]' \
  '-calcdist[distance from reference]' && ret=0

return ret
