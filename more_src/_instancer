#compdef instancer
# Documentation: https://man.archlinux.org/search?q=instancer
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-o[Output file]:file:_files'
    '--output[Output file]:file:_files'
    '--no-overlap-flag[Do not set overlap simple flag]'
    '--remove-overlaps[Remove overlaps in glyphs]'
    '--update-name-table[Update name table entries]'
    '--no-recalc-timestamp[Do not recalc font modified timestamp]'
    '--no-recalc-bounds[Do not recalc glyph bounding boxes]'
    '*:font file or axis=value:_files -g "*.{ttf,otf,ttc}"'
)

_arguments -s -S $arguments
