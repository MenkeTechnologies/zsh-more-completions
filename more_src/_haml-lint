#compdef haml-lint
# Documentation: https://github.com/sds/haml-lint/blob/main/lib/haml_lint/options.rb
# tool for writing clean and consistent HAML

local ret=1

_arguments -s -S \
  '(-c --config)'{-c+,--config=}'[configuration file to use]:config:_files' \
  '(-e --exclude)'{-e+,--exclude=}'[exclude one or more files from linting]:pattern' \
  '(-i --include-linter)'{-i+,--include-linter=}'[run only the specified linters]:linters' \
  '(-x --exclude-linter)'{-x+,--exclude-linter=}'[do not run the specified linters]:linters' \
  '(-r --reporter)'{-r+,--reporter=}'[reporter for output]:reporter' \
  '--fail-level=[minimum severity for failure]:level:(warning error)' \
  '(-a --auto-correct)'{-a,--auto-correct}'[auto-correct safe offenses]' \
  '(-A --auto-correct-all)'{-A,--auto-correct-all}'[auto-correct all offenses]' \
  '--auto-gen-config[generate a config acting as a TODO list]' \
  '--[no-]color[whether to output in color]' \
  '--show-linters[show all registered linters]' \
  '--show-reporters[display available reporters]' \
  '--display-disabled[display disabled linters]' \
  '(-s --stdin)'{-s+,--stdin=}'[pipe source from STDIN using FILE in offense]:file:_files' \
  '(-p --parallel)'{-p,--parallel}'[run linters in parallel using available CPUs]' \
  '--fail-fast[stop after the first failure]' \
  '--stderr[send output to stderr]' \
  '--summary[show summary of offenses]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:HAML file:_files' && ret=0

return ret
