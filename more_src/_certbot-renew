#compdef certbot-renew
# Documentation: https://eff-certbot.readthedocs.io/en/latest/using.html
# Reference accessed: 2026-05-16
# Verified: certbot upstream docs. certbot-renew is typically a systemd timer
# or cron wrapper for `certbot renew`. Lists renew-relevant flags only.

# certbot-renew: certbot renewal wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '--dry-run[test renewal without saving certs]' \
  '--force-renewal[renew regardless of age]' \
  '--cert-name=[target specific cert]:name:' \
  '--pre-hook=[shell command before renewal]:cmd:' \
  '--post-hook=[shell command after renewal]:cmd:' \
  '--deploy-hook=[shell command for each issued cert]:cmd:' \
  '--disable-hook-validation[skip hook syntax check]' \
  '--no-directory-hooks[disable renewal-hooks/]' \
  '--no-random-sleep-on-renew[disable jitter delay]' \
  '--no-autorenew[disable automatic renewal]' && ret=0
return ret
