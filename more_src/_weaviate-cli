#compdef weaviate-cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create collections, tenants, backups, replications, or import data'
  'get:retrieve collection info, tenant details, replication ops, or shard status'
  'delete:delete collections, tenants, replications, or data'
  'update:update collection settings, tenant states, or data'
  'query:search data (vector / hybrid / keyword)'
  'restore:restore a backup from a backend'
  'assign:assign a role/permission to a user'
  'revoke:revoke a role/permission from a user'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--config-file=[path to config]:file:_files' \
  '--user=[named user from config]:user:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'weaviate-cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _values 'create object' \
          'collection' 'tenant' 'backup' 'replication' 'data' && ret=0
        ;;
      (get)
        _values 'get object' \
          'collection' 'tenant' 'replication' 'shard' && ret=0
        ;;
      (delete)
        _values 'delete object' \
          'collection' 'tenant' 'replication' 'data' && ret=0
        ;;
      (update)
        _values 'update object' \
          'collection' 'tenant' 'data' && ret=0
        ;;
      (query)
        _values 'query type' \
          'vector' 'hybrid' 'keyword' 'bm25' 'near_text' 'near_vector' && ret=0
        ;;
      (restore)
        _values 'restore object' \
          'backup' && ret=0
        ;;
      (assign|revoke)
        _values 'rbac object' \
          'role' 'permission' && ret=0
        ;;
    esac
    ;;
esac

return ret
