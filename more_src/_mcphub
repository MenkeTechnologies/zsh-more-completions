#compdef mcphub
# Documentation: https://man.archlinux.org/search?q=mcphub
# Reference accessed: 2026-05-16
# Source: https://github.com/MenkeTechnologies/zsh-more-completions/blob/d278e5f1659fc62ca4671ab34a319c3ceb558a41/src/_mcphub
# Repository: MenkeTechnologies/zsh-more-completions (src/_mcphub)

# Zsh completion for mcphub (MCP server registry and hub)

local -a commands
commands=(
  'list:List available MCP servers'
  'install:Install an MCP server'
  'update:Update installed servers'
  'search:Search the hub'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '1: :_describe -t commands "command" commands' \
  '*:: :->args'
