#compdef Herwig
# Documentation: https://manpages.debian.org/testing/herwig++/Herwig++.1.en.html
# Herwig - multi-purpose Monte-Carlo event generator for particle physics

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '--full-help[print help including hidden options and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-N --numevents)'{-N,--numevents}'[number of events to generate]:num:' \
  '(-s --seed)'{-s,--seed}'[the random number generator seed]:seed:' \
  '(-t --tag)'{-t,--tag}'[a tag to append to the run name]:tag:' \
  '(-d --debug)'{-d,--debug}'[set the ThePEG debug level]:level:' \
  '(-D --debug-fpe)'{-D,--debug-fpe}'[enable floating point exceptions]' \
  '(-q --quiet)'{-q,--quiet}'[disable event counter]' \
  '*'{-l,--append}'[append a search path for dynamically loaded libraries]:dir:_files -/' \
  '*'{-L,--prepend}'[prepend a search path for dynamically loaded libraries]:dir:_files -/' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'Herwig command' \
      'read[read an input file and create a run file]' \
      'run[read a run file and generate events]' && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
