#compdef goodtables
# Documentation: https://goodtables.readthedocs.io/en/latest/cli.html
# Good Tables: validate and process tabular data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--schema=[schema filepath or url]:schema:_files' \
  '--fail_fast[stop processing on first error]' \
  '--dry_run[perform a trial run without permanent changes]' \
  '--row_limit=[cap number of rows processed]:rows' \
  '--report_limit=[cap number of errors in report]:errors' \
  '1:command:(pipeline structure schema)' \
  '*:file:_files' && ret=0

return ret
