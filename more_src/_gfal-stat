#compdef gfal-stat
# Documentation: https://man.archlinux.org/search?q=gfal-stat
# Reference accessed: 2026-05-16

# gfal-stat: stat an object via GFAL
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  "-X[show extended attrs]" "--xattr[show extended attrs]" \\\n   \
  '--config-file=[config file]:file:_files' \
  '--cert=[user cert]:file:_files' \
  '--key=[user key]:file:_files' \
  '*:URL:_files' && ret=0
return ret
