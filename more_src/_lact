#compdef lact
# Documentation: https://github.com/ilya-zlobintsev/LACT
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lact (Linux AMDGPU Controller)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'gui:launch graphical interface'
      'daemon:run the LACT daemon'
      'cli:command-line interface (limited)'
    )
    _describe -t commands 'lact command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (cli)
        local -a subcmds=(
          'list-gpus:list system GPUs'
          'info:show GPU information'
          'profile:manage settings profiles'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'cli subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (profile)
                _arguments '1:profile sub:(list get set auto-switch)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
