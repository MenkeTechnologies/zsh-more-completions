#compdef lact

# Zsh completion for lact (Linux AMDGPU Controller)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'gui:launch graphical interface'
      'daemon:run the LACT daemon'
      'cli:command-line interface'
    )
    _describe -t commands 'lact command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (daemon)
        _arguments \
          '--tcp-listen-address[TCP listen address]:address' && ret=0
        ;;
      (cli)
        local -a subcmds=(
          'list-gpus:list available GPUs'
          'info:show GPU info'
          'set-fan:set fan control'
          'set-power-cap:set power cap'
          'set-performance-level:set performance level'
          'set-clocks-value:set clock value'
          'set-power-profile-mode:set power profile mode'
        )
        _arguments '1:subcommand:->subcmd' '*:: :->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t commands 'cli subcommand' subcmds && ret=0
            ;;
          (subargs)
            case ${words[1]} in
              (info|set-fan|set-power-cap|set-performance-level|set-clocks-value|set-power-profile-mode)
                _arguments '--gpu-id[GPU ID]:gpu id' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
