#compdef lerna
# _lerna-bin — Lerna JavaScript monorepo tool (Nrwl, Sebastian McKenzie originally); manages multi-package npm/yarn/pnpm workspaces
# upstream: https://github.com/lerna/lerna

_lerna-bin() {
    local -a sub=(
        'init:initialize a new lerna repo'
        'add:add a local or external package'
        'add-caching:add nx caching configuration'
        'bootstrap:install + link dependencies (legacy)'
        'changed:list changed packages since last release'
        'check:run lerna doctor'
        'clean:remove node_modules'
        'create:create a new package'
        'diff:diff packages since last release'
        'exec:run a command in each package'
        'import:import a package into the monorepo'
        'info:print env info'
        'link:symlink packages together (legacy)'
        'list:list local packages'
        'ls:alias for list'
        'publish:publish bumped packages'
        'repair:repair lerna-managed projects'
        'run:run an npm script in each package'
        'version:bump versions only'
        'watch:watch packages and run a command'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--concurrency+[parallel jobs]:n:' \
        '--scope+[package glob]:scope:' \
        '--ignore+[ignore glob]:ignore:' \
        '--loglevel+[log level]:level:(silent error warn info verbose silly)' \
        '--no-progress[no progress]' \
        '--no-sort[no sort]' \
        '--stream[streaming output]' \
        '--parallel[run in parallel]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lerna subcommand' sub ;;
        args)
            case $words[1] in
                publish) _arguments \
                    '--canary[publish per-commit canary]' \
                    '--registry+[npm registry]:url:_urls' \
                    '--dist-tag+[dist tag]:tag:' \
                    '--otp+[npm OTP]:otp:' \
                    '--no-git-reset[do not reset working tree]' \
                    '--no-git-tag-version[skip git tag]' \
                    '--no-push[skip git push]' \
                    '--no-verify-access[skip access check]' \
                    '--yes[skip confirmation]' \
                    '--include-private[include private packages]' \
                    '*:bump:(major minor patch premajor preminor prepatch prerelease)' ;;
                version) _arguments \
                    '--allow-branch+[allow branch]:branch:' \
                    '--conventional-commits[use conventional-commits]' \
                    '--changelog-preset+[changelog preset]:preset:' \
                    '--exact[exact version]' \
                    '--include-merged-tags[include merged tags]' \
                    '--message+[commit msg]:msg:' \
                    '--no-changelog[skip changelog]' \
                    '--no-commit-hooks[skip commit hooks]' \
                    '--no-git-tag-version[skip git tag]' \
                    '--no-push[skip git push]' \
                    '--yes[skip confirmation]' \
                    '*:bump:(major minor patch premajor preminor prepatch prerelease)' ;;
                run|exec) _arguments \
                    '--no-bail[do not bail on errors]' \
                    '--no-prefix[no log prefix]' \
                    '--stream[streaming output]' \
                    '*:script-or-cmd:' ;;
                add|create) _arguments '*:package:' ;;
                changed|list|ls|diff|clean|bootstrap) _arguments \
                    '--all[include private]' \
                    '--json[JSON output]' \
                    '--long[long output]' \
                    '--parseable[machine output]' ;;
            esac
            ;;
    esac
}

_lerna-bin "$@"
