#compdef impacket-dpapi

# Impacket dpapi.py: decrypt DPAPI-protected secrets from local or remote
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-debug[debug]' \
  '1: :(masterkey credential vault backupkey)' \
  '-file[input file]:file:_files' \
  '-key[DPAPI master key (hex)]:hex:' \
  '-system[SYSTEM hive]:file:_files' \
  '-security[SECURITY hive]:file:_files' \
  '-sid[user SID]:sid:' \
  '-password[user password]:pwd:' \
  '-hashes[LM:NT hashes]:hashes:' \
  '-dc-ip[DC IP]:ip:' \
  '-target-ip[target host IP]:ip:' \
  '-k[Kerberos auth]' \
  '*::dpapi args:_files' && ret=0
return ret
