#compdef kmplayer
# Documentation: https://github.com/KDE/kmplayer/blob/master/src/app/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/app/main.cpp lines 48-53. No custom options beyond KAboutData
# standard set.

# KMPlayer: KDE media player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '*:file/URL:_files' && ret=0
return ret
