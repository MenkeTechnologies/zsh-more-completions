#compdef apicurio-cli apicurio-registry-cli apicurio-registry
# _apicurio-cli — Apicurio Registry schema/artifact CLI (Apicurio team / Red Hat, TypeScript/Java); custom argparse
# upstream: https://github.com/Apicurio/apicurio-registry

_apicurio-cli() {
    local -a sub=(
        'login:login to registry'
        'logout:logout'
        'whoami:show current identity'
        'groups:manage groups'
        'artifacts:manage artifacts'
        'rules:manage rules'
        'system:manage system info/limits/properties'
        'admin:admin commands'
        'roles:manage role mappings'
        'config:CLI config'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--registry-url=+[registry URL]:url:_urls' \
        '--auth-server=+[auth server URL]:url:_urls' \
        '--client-id=+[client id]:str:' \
        '--client-secret=+[client secret]:str:' \
        '--username=+[username]:str:_users' \
        '--password=+[password]:str:' \
        '--token=+[bearer token]:str:' \
        '--insecure[skip TLS verify]' \
        '--output=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apicurio subcommand' sub ;;
        args)
            case $words[1] in
                artifacts) _arguments \
                    '1:cmd:(create get list update delete versions test latest meta state)' \
                    '--group=+[group id]:str:' \
                    '-g+[group id]:str:' \
                    '--id=+[artifact id]:str:' \
                    '-a+[artifact id]:str:' \
                    '--type=+[artifact type]:t:(AVRO PROTOBUF JSON OPENAPI ASYNCAPI GRAPHQL KCONNECT WSDL XSD XML)' \
                    '-t+[artifact type]:t:(AVRO PROTOBUF JSON OPENAPI ASYNCAPI GRAPHQL KCONNECT WSDL XSD XML)' \
                    '--file=+[file]:file:_files' \
                    '-f+[file]:file:_files' \
                    '*:arg:' ;;
                groups) _arguments \
                    '1:cmd:(create get list update delete)' \
                    '--group=+[group id]:str:' \
                    '-g+[group id]:str:' \
                    '*:arg:' ;;
                rules) _arguments \
                    '1:cmd:(create get list update delete)' \
                    '--group=+[group id]:str:' \
                    '-g+[group id]:str:' \
                    '--id=+[artifact id]:str:' \
                    '-a+[artifact id]:str:' \
                    '--rule=+[rule]:r:(VALIDITY COMPATIBILITY INTEGRITY)' \
                    '*:arg:' ;;
                system) _arguments \
                    '1:cmd:(info limits properties resourceLimits)' \
                    '*:arg:' ;;
                admin) _arguments \
                    '1:cmd:(export import role-mappings logger-config update-properties read-only)' \
                    '*:arg:' ;;
                roles) _arguments \
                    '1:cmd:(create get list update delete)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_apicurio-cli "$@"
