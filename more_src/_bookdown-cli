#compdef bookdown-cli bookdown2
# _bookdown-cli — Yihui Xie Posit bookdown-cli CLI command-line frontend to the R Markdown bookdown package for authoring long-form technical books HTML PDF EPUB MOBI integration with knitr Pandoc supporting cross-reference numbered-equation theorem proof footnote citation bibliography-aware bibtex preview-server render-book modes (Yihui Xie team, R); custom argparse
# upstream: https://bookdown.org/

_bookdown-cli() {
    local -a sub=(
        'render:render book to all formats'
        'serve:start preview server'
        'preview:preview chapter'
        'clean:clean intermediate'
        'init:initialize a new bookdown project'
        'publish:publish via rsconnect'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input dir]:dir:_files -/' \
        '--input=+[dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-f+[format]:f:(gitbook html_book pdf_book epub_book bs4_book tufte_book2 word_book2 markdown_document2)' \
        '--format=+[format]:f:(gitbook html_book pdf_book epub_book bs4_book tufte_book2 word_book2 markdown_document2)' \
        '--config-file=+[file]:file:_files -g "_bookdown.yml _output.yml"' \
        '--preview-host=+[host]:_hosts' \
        '--preview-port=+[port]:n:' \
        '--server[start preview server]' \
        '--clean[clean intermediate]' \
        '--params=+[file]:file:_files -g "*.yml *.yaml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bookdown-cli subcommand' sub ;;
        args)
            _arguments '*:input file:_files -g "*.Rmd *.md *.qmd"'
            ;;
    esac
}

_bookdown-cli "$@"
