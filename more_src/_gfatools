#compdef gfatools
# Documentation: https://github.com/lh3/gfatools
# gfatools: tools for manipulating sequence graphs in the GFA and rGFA formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->command' && ret=0

case $state in
  command)
    _values 'gfatools subcommand' \
      'view[read a GFA file]' \
      'stat[statistics about a GFA file]' \
      'gfa2fa[convert GFA to FASTA]' \
      'gfa2bed[convert rGFA to BED]' \
      'blacklist[blacklist regions]' \
      'bubble[print bubble-like regions]' \
      'asm[miniasm-like graph transformation]' \
      'sql[export rGFA to SQLite]' \
      'ed[GWFA prefix alignment]' \
      'version[print version number]' && ret=0
    ;;
esac

return ret
