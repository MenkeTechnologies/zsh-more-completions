#compdef mafSpeciesSubset
# UCSC kent: extract a maf that just has a subset of species

local ret=1

_arguments -s -S \
  '-keepFirst[keep the first a line in a maf no matter what]' \
  '1:input maf:_files -g "*.maf"' \
  '2:species list:_files' \
  '3:output maf:_files -g "*.maf"' && ret=0

return ret
