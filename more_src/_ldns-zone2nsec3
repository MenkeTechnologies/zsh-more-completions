#compdef ldns-zone2nsec3
# _ldns-zone2nsec3 — NLnet Labs ldns-zone2nsec3 (rewrite an unsigned BIND zone file to use NSEC3 records (RFC 5155); -a algorithm, -i iterations, -s salt hex (or -S random salt size), -p opt-out for unsigned delegations, -f output file; positional argument is the input zone file)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-zone2nsec3.c on tip.

_ldns-zone2nsec3() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-a+[algorithm]:algo:(1)' \
        '-i+[iterations]:n:' \
        '-s+[salt hex]:salt:' \
        '-S+[random salt size bytes]:bytes:' \
        '-p[opt-out for unsigned delegations]' \
        '-f+[output file]:file:_files' \
        '1:input zone file:_files'
}

_ldns-zone2nsec3 "$@"
