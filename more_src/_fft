#compdef fft
# Documentation: https://www.ccp4.ac.uk/html/fft.html
# fft — fast Fourier transform of reflection data into an electron density/Patterson map (CCP4)

local ret=1

_arguments -s -S \
  'HKLIN[input reflection MTZ]:file:_files -g "*.mtz"' \
  'MAPOUT[output binary map]:file:_files -g "*.(map|ccp4)"' \
  'ABCOEFFS[output Fourier coefficients listing]:file:_files' \
  'LABIN[data item column assignments]:labels:' \
  'GRID[sampling divisions along cell edges]:grid:' \
  'FFTSPACEGROUP[space group for FFT]:sg:' \
  'RESOLUTION[resolution limits]:lim:' \
  'XYZLIM[map extent or ASU]:lim:' \
  'SCALE[scaling and B-factors]:opt:' \
  'AXIS[fast/medium/slow axis order]:axes:' \
  'PATTERSON[calculate Patterson map]' \
  'RHOLIM[automatic map scaling]:lim:' \
  'EXCLUDE[cutoff filters]:opt:' \
  'SYMMETRY[spacegroup]:sg:' \
  'TITLE[output title]:title:' \
  'END[terminate input]' \
  '*:argument:_files' && ret=0

return ret
