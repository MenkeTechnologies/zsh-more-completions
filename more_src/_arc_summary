#compdef arc_summary
# _arc_summary — OpenZFS arc_summary (per-section diagnostic dump of ARC tunables, ARC stats, L2ARC behaviour, prefetch, IO scheduler, ZFETCH, DMU prefetch, DBUF, vdev metrics; -a alphabetical sections, -d show description, -s pick sections (comma-list), -p output style, -r raw, -g graph)
# upstream: https://github.com/openzfs/zfs (cmd/arc_summary)
# Flags from openzfs cmd/arc_summary on tip.

_arc_summary() {
    _arguments \
        '-h[show help]' \
        '-a[sort alphabetically]' \
        '-d[descriptions]' \
        '-g[graph]' \
        '-p+[output style]:style:(1 2 3 4)' \
        '-r[raw values]' \
        '-s+[sections, comma]:sections:(arc archits dbufs dmu dnode dnodestat io l2arc tunables vdev xuio zfetch zil)' \
        '-v[verbose]' \
        '--version[show version]'
}

_arc_summary "$@"
