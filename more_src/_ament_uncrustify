#compdef ament_uncrustify
# Documentation: https://github.com/ament/ament_lint/blob/rolling/ament_uncrustify/ament_uncrustify/main.py
# ament_uncrustify - check C/C++ code style using uncrustify

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-c[the uncrustify config file]:config:_files' \
  '--linelength=[the maximum line length]:N:' \
  '*--exclude=[exclude specific file names from the check]:filename:_files' \
  '--language=[force a specific language rather than choosing one by extension]:language:(C C++ CPP)' \
  '--reformat[reformat the files in place]' \
  '--xunit-file=[generate a xunit compliant XML file]:file:_files' \
  '*:path:_files' && ret=0

return ret
