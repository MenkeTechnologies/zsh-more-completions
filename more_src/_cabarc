#compdef cabarc
# Documentation: https://am.net/lib/tools/Microsoft/cab-sdk/DOCS/CABARC.DOC
# Reference accessed: 2026-05-16
# Verified: Microsoft CAB SDK CABARC.DOC. Originally a Windows tool;
# runs on Wine. libmspack on Linux ships `cabextract`, not `cabarc`.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# cabarc: Microsoft cabinet archiver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[preserve path information]' \
  '-P[strip path prefix when adding]:prefix:' \
  '-r[recurse into subdirectories]' \
  '-s[reserve bytes in cabinet for code signing]:bytes:' \
  '-i[cabinet ID (default 0)]:id:' \
  '-m[compression type]:type:(MSZIP NONE)' \
  '1:command:(N L X)' \
  '*:cab file or list:_files' && ret=0
return ret
