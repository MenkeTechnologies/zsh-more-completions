#compdef archgw
# Documentation: https://man.archlinux.org/search?q=archgw
# Reference accessed: 2026-05-16

# katanemo/archgw cli/main.py (click); Homebrew: Formula/a/archgw.rb

local curcontext="$curcontext" ret=1

_arguments -C \
  '--version[show CLI version and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'archgw command' compadd -- up down build logs cli-agent generate-prompt-targets
  ;;
args)
  case $line[1] in
    up)
      _arguments -s \
        '--path[config search path]:path:_files -/' \
        '--foreground[run in foreground]' \
        '::config file:_files' && ret=0
      ;;
    logs)
      _arguments -s '--debug[verbose gateway logs]' '--follow[follow log stream]' && ret=0
      ;;
    generate-prompt-targets)
      _arguments -s '(-f --file)'{-f,--file=}'[python file]:python file:_files -g "*.py"' && ret=0
      ;;
    cli-agent)
      _arguments -s \
        '1:agent type:(claude)' \
        '--path[directory with arch_config.yaml]:path:_files -/' \
        '--settings=[extra settings JSON]:json string:' \
        '::config file:_files' && ret=0
      ;;
    *)
      _default && ret=0
      ;;
  esac
  ;;
esac

return ret
