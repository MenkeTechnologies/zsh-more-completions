#compdef vulnknox
# Documentation: https://github.com/iqzer0/vulnknox
# vulnknox - Go wrapper for the KNOXSS API

local ret=1

_arguments -s -S \
  '-u[input URL to test for XSS]:url:' \
  '-i[input file containing URLs to test]:file:_files' \
  '-X[HTTP method]:method:(GET POST BOTH)' \
  '-pd[POST data]:data:' \
  '-headers[custom headers]:headers:' \
  '-afb[enable advanced filter bypass]' \
  '-checkpoc[enable CheckPoC verification]' \
  '-flash[enable flash mode for quick polyglot testing]' \
  '-o[file to save results]:file:_files' \
  '-ow[overwrite output file if it exists]' \
  '-oa[output all results, not just successful]' \
  '-s[show only successful XSS payloads]' \
  '-p[number of parallel processes (1-5)]:processes:' \
  '-t[timeout for API requests in seconds]:seconds:' \
  '-dw[Discord webhook URL for notifications]:url:' \
  '-r[number of retries for failed requests]:retries:' \
  '-ri[interval between retries in seconds]:seconds:' \
  '-sb[skip domains after this many 403 responses]:n:' \
  '-proxy[proxy URL]:proxy:' \
  '-v[verbose output mode]' \
  '-version[display version number]' \
  '-no-banner[suppress banner display]' \
  '-api-key[KNOXSS API key]:key:' && ret=0

return ret
