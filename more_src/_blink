#compdef blink
# Documentation: source-direct extraction from upstream
# jart/blink blink/blink.c (**C language**; uses POSIX
# `getopt(3)` via a custom `GetOpt` wrapper — corpus's
# first documented C getopt-based CLI):
#   blink/blink.c line 93 (`#define OPTS "hvjemZs0L:C:"`
#     — POSIX getopt option-string format)
#   blink/blink.c lines 95-131 (`static const char USAGE
#     []` = preprocessor-gated help-text string with
#     `#ifndef DISABLE_JIT`, `#ifndef DISABLE_STRACE`,
#     `#ifndef NDEBUG`, `#ifndef DISABLE_OVERLAYS`,
#     `#ifndef DISABLE_VFS`, `#ifndef TINY` conditional
#     compilation directives interleaved with help
#     lines)
#   blink/blink.c lines 266-323 (GetOpts fn: getopt-loop
#     dispatch via switch(opt) — 10 cases including 'C'
#     which is dual-purpose for overlays OR vfs prefix
#     via nested `#if !defined(...)` checks)
#   blink/blink.c lines 268-278 (FLAG_* globals
#     initialized from env vars BEFORE getopt loop:
#     `getenv("BLINK_OVERLAYS")`,
#     `getenv("BLINK_PREFIX")`,
#     `getenv("BLINK_LOG_FILENAME")`)
#   blink/blink.c lines 313-318 (special cases:
#     '-v' calls PrintVersion + exit; '-h' calls
#     PrintUsage + exit; default also calls PrintUsage
#     but with exit code 48)
# Reference accessed: 2026-05-30 via gh api.
#
# blink is the **tiniest x86-64-linux emulator** from
# jart (the cosmopolitan / ape / redbean author).
# Allows running x86-64 Linux binaries on any platform
# that supports POSIX (macOS / FreeBSD / Windows / WASM /
# etc.).  Pivots from OCaml (R271 dune) into the **C
# language tooling cluster**.  Sister to cosmocc /
# cosmopolitan / ape (all jart projects in spirit).
# **MAJOR MILESTONE**: corpus's **first documented C
# CLI using POSIX getopt(3)** — adds C to the cross-
# language CLI taxonomy (14 library variants now).
#
# Critical extraction note: blink uses **POSIX `getopt(3)`**
# via a custom `GetOpt` wrapper at blink.c:279.  Documents
# the **POSIX getopt(3) C CLI pattern** — corpus's first
# documented C CLI.  Extends the **cross-language CLI
# taxonomy** to FOURTEEN library variants (R269 added
# Crystal; R270 added Haskell; R271 added OCaml; R272
# adds C): (a) Rust clap derive (R247-R262, R268), (b)
# Rust clap builder (R259), (c) Rust clap v3 (R261),
# (d) Go cobra (multiple), (e) Go pflag (multiple), (f)
# Go flaggy (R263), (g) Go stdlib flag (R264, R265),
# (h) Python Click (R266), (i) Python argparse (R267),
# (j) Python Typer (R268), (k) Crystal OptionParser
# (R269), (l) Haskell optparse-applicative (R270), (m)
# OCaml Cmdliner (R271), (n) **C POSIX getopt(3)**
# (R272 — NEW).  POSIX getopt is the **most primitive**
# CLI library: parses a single OPTS string (e.g.
# `"hvjemZs0L:C:"`) where each letter is a flag, and
# `:` suffix means "takes a value".  No long-option
# support in plain `getopt()` (GNU `getopt_long()` adds
# long options; blink uses the short-only form).  No
# subcommand support.  No help generation.  No
# validation.  Most C CLIs use getopt; some use the
# GNU extensions; some implement their own arg parser.
#
# Critical extraction note: blink uses the **OPTS string
# `"hvjemZs0L:C:"`** at blink.c:93 — POSIX getopt
# option-string format:
#   - Each letter is a flag (`h` / `v` / `j` / `e` / `m`
#     / `Z` / `s` / `0`)
#   - `:` suffix marks "takes a value" (`L:` for `-L PATH`,
#     `C:` for `-C PATH`)
#   - GNU extension: `::` for optional value (not used
#     in blink)
#   - GNU extension: leading `+` or `-` modifies parsing
#     behavior (not used in blink)
# Documents the **getopt OPTS string format** — corpus's
# **first documented POSIX getopt OPTS string**.
# Distinct from clap's struct attributes, Click's
# decorator strings, argparse's add_argument calls.
# Getopt's OPTS string is the most COMPRESSED CLI
# specification format — entire CLI surface in one
# string.
#
# Critical extraction note: blink uses **preprocessor-
# gated help text** at blink.c:95-131 — the static C
# string USAGE has `#ifndef DISABLE_JIT`, `#ifndef
# DISABLE_STRACE`, `#ifndef NDEBUG`, `#ifndef
# DISABLE_OVERLAYS`, `#ifndef DISABLE_VFS`, `#ifndef
# TINY` directives interleaved with help lines.  When
# blink is compiled with `-DDISABLE_JIT`, the `-j`
# help line is REMOVED from the string and the `-j`
# flag itself isn't handled (the getopt switch case
# would still match but the action is conditionally
# compiled out via further `#ifdef`s).  Documents the
# **C preprocessor `#ifdef`-gated CLI surface** —
# corpus's first documented occurrence.  Distinct from
# Rust's `#[cfg(feature = "X")]` (R201/R250/R251), Go's
# `//go:build linux` build tags (R264 ctop), and
# Python's runtime `if HAS_FOO` checks.  C's #ifdef is
# the **earliest** (preprocessor stage) feature-gating
# pattern — happens before compilation.
#
# Critical extraction note: blink's `-C` flag is
# **DUAL-PURPOSE** at blink.c:302-311 — when both
# DISABLE_OVERLAYS and DISABLE_VFS are NOT defined,
# `-C PATH` sets `FLAG_overlays`.  When ONLY DISABLE_VFS
# is defined, `-C PATH` sets `FLAG_prefix`.  When BOTH
# are disabled, `-C PATH` writes an error message and
# does nothing.  Documents the **conditional-purpose
# flag pattern** — a single CLI flag's semantics depend
# on which features were compiled in.  Useful for
# compile-time-flexible CLIs (e.g. when shipping
# different variants of the same binary with different
# features enabled).  Corpus's **first documented
# conditional-purpose flag** (single flag with multiple
# distinct behaviors based on compile flags).
#
# Critical extraction note: blink uses **env-vars as
# DEFAULTS for FLAG_ globals BEFORE getopt loop** at
# blink.c:268-278 — `FLAG_overlays = getenv("BLINK_OVERLAYS")`,
# `FLAG_prefix = getenv("BLINK_PREFIX")`,
# `FLAG_logpath = getenv("BLINK_LOG_FILENAME")`.  These
# are set BEFORE the getopt loop, so the corresponding
# CLI flags (`-C PATH`, `-L PATH`) OVERRIDE the env-var
# values when given.  Plus the env-var defaults are
# themselves wrapped in `#ifndef` directives so they
# only exist when the corresponding feature is enabled.
# Documents the **env-as-default-pre-getopt pattern**
# — distinct from R263 lazygit's flaggy-default-as-env
# and R266 uvicorn's Click `auto_envvar_prefix`.  In C,
# this is implemented as imperative pre-getopt
# initialization.  Corpus's **first documented C env-
# as-default pattern**.
#
# Critical extraction note: blink uses **dual exit code
# from PrintUsage** at blink.c:315 (success: 0) and
# blink.c:317 (error: 48) — explicit `-h` returns 0;
# unknown options return 48.  The exit code 48 is
# unusual (not 1 or 2 like most CLIs).  Documents the
# **custom exit code pattern** — distinct from clap
# derive's auto exit codes (clap returns 0 for help, 2
# for parse errors).  blink uses 48 perhaps as a
# convention for "CLI usage error" (similar to sysexits.h
# EX_USAGE = 64).

local curcontext="$curcontext" state line

# 10 short flags decoded source-direct from OPTS string
# at blink.c:93 + USAGE help text at blink.c:95-131.
# Many are PREPROCESSOR-GATED (compile-time conditional).
_arguments -s \
  '-h[show help (always available)]' \
  '-v[show version (always available)]' \
  '-j[disable JIT (NOT compiled when -DDISABLE_JIT)]' \
  '-e[also log to stderr (NOT compiled when -DNDEBUG)]' \
  '-0[specify argv[0] (always available)]' \
  '-m[enable memory safety (always available)]' \
  '-s[enable syscall logging (NOT compiled when -DDISABLE_STRACE / -DTINY)]' \
  '-Z[print internal statistics on exit (NOT compiled when -DNDEBUG)]' \
  '-L+[log filename path (default blink.log; env: BLINK_LOG_FILENAME; NOT compiled when -DNDEBUG)]:file:_files' \
  '-C+[chroot dir OR overlay spec (CONDITIONAL-PURPOSE: depends on -DDISABLE_OVERLAYS vs -DDISABLE_VFS; default ":o"; env: BLINK_OVERLAYS / BLINK_PREFIX)]:path:_files -/' \
  '1:program to emulate:_files' \
  '*:program args:'
