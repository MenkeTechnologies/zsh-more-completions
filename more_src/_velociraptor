#compdef velociraptor
# ---------------------------------------------------------------------------
# velociraptor — advanced DFIR incident response and monitoring agent (Go, 3,995★)
#
# upstream: https://github.com/Velocidex/velociraptor
# project: Rapid7 / Velocidex — open-source DFIR (Digital Forensics +
#                                Incident Response) platform
# license: AGPL-3.0
#
# Source-direct completion: global flags + top-level subcommand list
# verbatim from bin/main.go kingpin definitions + bin/{artifacts,config,csv,
# deaddisk,fs,golden,grant,gui,hunts,offline,pool,query,tools,unzip,users,
# verify}.go `app.Command(...)` registrations on the velociraptor tip.
#
# Direct deps from go.mod (selected):
#   github.com/alecthomas/participle v0.7.1  ← canonical Go parser-combinator
#                                              library (this axis) — by Alec
#                                              Thomas (kong, chroma, kingpin)
#                                              powers VQL (Velociraptor Query
#                                              Language) lexer + parser
#   github.com/alecthomas/kingpin/v2         (Alec Thomas's kingpin CLI parser
#                                             — sibling of participle)
#
# === AXIS 163 CONTINUES — parser-combinator library ecosystem ===
# Axis position: Go=218 continues Axis 163 (slot 2/0/0).  Canonical Go
# parser-combinator library is `participle` by Alec Thomas (the same Alec
# Thomas behind kong/kingpin/chroma) — generates parsers from Go struct
# tags using reflection.  Used by yq (Mike Farah's YAML processor),
# zitadel, cerbos, flamego, kubeshop/tracetest, and velociraptor's VQL.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=218   _prj                 ← previous round (axis 163 OPENS at 1/0/0)
#   Go=218     ← THIS FILE          (axis 163 continues, slot 2/0/0)
#   TS-Node=218 ← next round        (axis 163 CLOSES at triple-218, slot 1/1/1)
# ---------------------------------------------------------------------------

_velociraptor() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'artifacts:VQL artifact operations (list/show/verify/collect)'
        'config:configuration generation (show/client/server/repack/api/...)'
        'csv:convert a CSV file to another format'
        'deaddisk:analyze a dead disk image (E01/raw/VMDK)'
        'fs:run filesystem commands (ls/cp/cat/rm)'
        'golden:run golden tests against artifacts'
        'acl:manage ACL grants (show/grant)'
        'gui:start the GUI server'
        'hunts:hunt operations (reconstruct/dump)'
        'collector:build an offline collector binary'
        'pool_client:run as a pool of fake clients (load testing)'
        'query:run a VQL query against the local system or remote frontend'
        'tools:view and manipulate stored third-party binaries (show/rm)'
        'unzip:unzip a Velociraptor container file'
        'user:manage GUI users (add/show/delete/lock)'
        'version:print version and exit'
        'client:run as a client (connect to frontend)'
        'frontend:run as a frontend server'
        'analysis_target:set analysis target for offline workflows'
        'browser:browse the filesystem via VQL'
        'debian:generate Debian package'
        'rpm:generate RPM package'
        'minions:start minion processes for distributed querying'
        'proxy:run as an HTTP proxy'
        'reformat:reformat VQL queries'
        'debug:debug subcommands (pprof/trace/log)'
        'metrics:print metrics and exit'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-c --config)'{-c,--config=}'[configuration file]:config:_files -g "*.(yaml|yml|json)"' \
        '--embedded_config=[extract the embedded configuration from this file]:file:_files' \
        '(-a --api_config)'{-a,--api_config=}'[API configuration file]:api config:_files -g "*.(yaml|yml)"' \
        '--runas=[run as this username (apply ACLs)]:username:' \
        '(-D --definitions)'{-D,--definitions=}'[directory containing artifact definitions]:dir:_files -/' \
        '--nocolor[disable color output]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
        '--profile=[write profiling info to this file]:file:_files' \
        '--profile_duration=[generate a profile file for each period in seconds]:seconds:' \
        '--trace=[write trace info to this file]:file:_files' \
        '--trace_vql[enable VQL tracing]' \
        '--logfile=[write logs to this file as well]:file:_files' \
        '--tempdir=[directory for all temp files]:dir:_files -/' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version and exit]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'velociraptor command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                artifacts)
                    local -a acmds
                    acmds=(
                        'list:list all available artifacts'
                        'show:show one or more artifacts'
                        'verify:verify a set of artifacts'
                        'collect:collect an artifact (with --args key=value)'
                    )
                    _describe -t commands 'artifacts command' acmds && ret=0
                    ;;
                config)
                    local -a ccmds
                    ccmds=(
                        'show:show the loaded configuration'
                        'client:generate a client config from server config'
                        'server:generate a server config'
                        'api:generate an API config'
                        'repack:repack a binary with embedded config'
                        'reissue:reissue certificates'
                        'rotate_key:rotate the frontend key'
                        'frontend:print frontend config'
                        'generate:generate a fresh server config'
                    )
                    _describe -t commands 'config command' ccmds && ret=0
                    ;;
                fs)
                    local -a fcmds
                    fcmds=(
                        'ls:list files in an accessor namespace (e.g. ntfs, file, registry)'
                        'cp:copy files between accessors / to local disk'
                        'cat:cat file contents'
                        'rm:remove files'
                    )
                    _describe -t commands 'fs command' fcmds && ret=0
                    ;;
                acl)
                    local -a alcmds
                    alcmds=(
                        'show:show ACLs for a user'
                        'grant:grant permissions to a user'
                    )
                    _describe -t commands 'acl command' alcmds && ret=0
                    ;;
                hunts)
                    local -a hcmds=( 'reconstruct:rebuild a hunt from collected flows' )
                    _describe -t commands 'hunts command' hcmds && ret=0
                    ;;
                collector)
                    _arguments \
                        '--target=[collector target binary OS/arch]:target:(Windows Windows_x86 Linux Mac)' \
                        '--output=[output path]:path:_files' \
                        '--password=[ZIP archive password]:password:' \
                        '--encryption-scheme=[encryption scheme]:scheme:' \
                        '*:artifact name:' && ret=0
                    ;;
                tools)
                    local -a tcmds=(
                        'show:show tools in the inventory'
                        'rm:remove a third-party tool from inventory'
                    )
                    _describe -t commands 'tools command' tcmds && ret=0
                    ;;
                user)
                    local -a ucmds=(
                        'add:add a user (or change password)'
                        'show:show user info'
                        'delete:delete a user'
                        'lock:lock a user'
                    )
                    _describe -t commands 'user command' ucmds && ret=0
                    ;;
                query)
                    _arguments \
                        '--format=[output format]:format:(json jsonl csv text table)' \
                        '--output=[output file]:file:_files' \
                        '--env=[VQL environment variable]:key=value:' \
                        '--max_row=[max rows per result set]:n:' \
                        '*:VQL query (raw VQL or @file.vql):' && ret=0
                    ;;
                csv)
                    _arguments \
                        '--format=[output format]:format:(jsonl json csv text)' \
                        '1:csv file:_files -g "*.csv"' && ret=0
                    ;;
                unzip)
                    _arguments \
                        '--password=[archive password]:password:' \
                        '1:container file:_files -g "*.(zip|enc|enc.zip)"' \
                        '2:output dir:_files -/' && ret=0
                    ;;
                help)
                    _describe -t commands 'velociraptor command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_velociraptor "$@"
