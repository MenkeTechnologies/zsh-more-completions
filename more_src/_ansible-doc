#compdef ansible-doc
# _ansible-doc — Ansible doc (browse plugin docs from installed collections; -t selects type (module/cache/callback/lookup/...), -l/-F list installed plugins, -s emit a snippet template, --metadata-dump dumps everything as JSON)
# upstream: https://github.com/ansible/ansible (lib/ansible/cli/doc.py)
# Flags from ansible cli/doc.py on tip.

_ansible-doc() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '*-v[verbose]' \
        '-l[list available plugins]' \
        '-F[brief list]' \
        '-s[emit snippet]' \
        '-j[output as JSON]' \
        '--metadata-dump[dump everything as JSON]' \
        '-t+[plugin type]:type:(become cache callback cliconf connection httpapi inventory keyword lookup module netconf shell strategy terminal test vars filter)' \
        '--playbook-dir+[playbook dir]:dir:_files -/' \
        '--no-fail-on-errors[continue listing on errors]' \
        '*:plugin name:'
}

_ansible-doc "$@"
