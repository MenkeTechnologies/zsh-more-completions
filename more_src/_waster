#compdef waster
# Documentation: https://github.com/chaoszhang/ASTER/blob/master/tutorial/waster.md
# WASTER de novo species tree estimation from raw reads (ASTER package)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[input list of species names and FASTA/FASTQ files]:input:_files' \
  '-o+[output file for results]:output:_files' \
  '-c+[fully resolved species tree for placement or scoring]:tree:_files' \
  '-g+[candidate species trees as hints]:tree:_files' \
  '-t+[number of threads]:threads' \
  '-r+[number of initial search rounds]:rounds' \
  '-s+[number of subsampling rounds]:rounds' \
  '-R[run more rounds for ensured optimality]' \
  '-C[scoring mode with single taxon placement]' \
  '--root=[root tree at outgroup taxon]:taxon' \
  '*:input list:_files' && ret=0

return ret
