#compdef ploticus pl
# Documentation: https://man.archlinux.org/search?q=ploticus
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-ping[print version and exit]' \
  '-prefab+[use a prefab plot template]:name:(areadef bars chron dists distrib exec footer gantt getdata header heatmap intercept legend labels lines pie polar proc rangebar scat stack textbox vector usemap)' \
  '-png[output PNG]' \
  '-gif[output GIF]' \
  '-jpeg[output JPEG]' \
  '-svg[output SVG]' \
  '-svgz[output compressed SVG]' \
  '-swf[output Flash SWF]' \
  '-wbmp[output WBMP]' \
  '-eps[output encapsulated PostScript]' \
  '-ps[output PostScript]' \
  '-x[display via X11]' \
  '-o+[output file]:file:_files' \
  '-color+[default text/line color]:color:' \
  '-backcolor+[background color]:color:' \
  '-cm[absolute units in centimeters]' \
  '-mks[meter-kilogram-second units]' \
  '-pagesize+[page size WxH]:size:' \
  '-density+[output density in dpi]:dpi:' \
  '-textsize+[text size]:size:' \
  '-font+[default font]:font:' \
  '-tightcrop[crop output tight]' \
  '-outlabel+[output label/title]:label:' \
  '-fontdir+[font directory]:dir:_files -/' \
  '-debug[diagnostic output]' \
  '-noshell[do not invoke a shell]' \
  '-csvonly[CSV input only]' \
  '-maxrows+[max data rows]:n:' \
  '-maxfields+[max data fields]:n:' \
  '-maxvector+[max vector size]:n:' \
  '-stdin[read script from stdin]' \
  '-scaleup+[scale factor]:n:' \
  '*:script_or_data:_files' && ret=0

return ret
