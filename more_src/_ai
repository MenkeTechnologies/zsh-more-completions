#compdef ai
# Documentation: https://github.com/callstack/ai-cli
# Source: callstack/ai-cli — terminal AI assistant (OpenAI / Perplexity).
# Reference accessed: 2026-06-01
# Config: ~/.airc.json. Interactive `/help`, `/exit`, `/info`, `/forget`, `/verbose` commands.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ai_cmds
_ai_cmds=(
    'init:create a config file at ~/.airc.json'
)

_arguments -C \
    '(-p --provider)'{-p+,--provider=}'[inference provider]:provider:(openAi perplexity)' \
    '(-m --model)'{-m+,--model=}'[model name]:model:_default' \
    '--creative[generate creative responses]' \
    '--precise[prioritize accuracy]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command_or_query' \
    '(-)*:: :->rest' \
    && ret=0

case $state in
    command_or_query)
        _describe -t commands 'ai command' _ai_cmds && _message 'or free-form query' && ret=0
        ;;
esac

return ret
