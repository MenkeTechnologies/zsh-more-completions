#compdef clearml-debug
# Documentation: https://github.com/clearml/clearml
# Reference accessed: 2026-05-23
# Verified: clearml-debug --help (ClearML SDK debug CLI).

# Zsh completion for clearml-debug - ClearML SDK debugging utilities

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'clearml-debug command' \
      'token[print token details]' \
      'config[configuration commands]' && ret=0
    ;;
esac

return ret
