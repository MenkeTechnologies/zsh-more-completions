#compdef cromwell-tools
# Documentation: https://cromwell-tools.readthedocs.io/en/stable/Tutorials/Quickstart/cli_quickstart.html
# cromwell-tools - Python client CLI for interacting with a Cromwell server

local ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:(submit wait status abort release_hold query health)' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      submit)
        _arguments -s -S \
          '--url=[Cromwell server URL]:url' \
          '(-w --wdl-file)'{-w,--wdl-file}'[path to the WDL workflow source file]:file:_files' \
          '(-i --inputs-files)'{-i,--inputs-files}'[path(s) to JSON input file(s)]:file:_files' \
          '(-d --deps-file)'{-d,--deps-file}'[path to zip of dependencies]:file:_files' \
          '(-o --options-file)'{-o,--options-file}'[path to workflow options JSON]:file:_files' \
          '(-l --label-file)'{-l,--label-file}'[path to labels JSON]:file:_files' \
          '(-c --collection-name)'{-c,--collection-name}'[SAM collection name]:name' \
          '--username=[username for HTTP basic auth]:user' \
          '--password=[password for HTTP basic auth]:pass' \
          '--secrets-file=[path to secrets JSON]:file:_files' \
          '--service-account-key=[path to service account key]:file:_files' \
          '--on-hold[submit the workflow in on-hold state]' \
          '--validate-labels[validate labels before submitting]' && ret=0
        ;;
      wait)
        _arguments -s -S \
          '--url=[Cromwell server URL]:url' \
          '--timeout-minutes=[timeout in minutes]:minutes' \
          '--poll-interval-seconds=[seconds between status polls]:seconds' \
          '--silent[suppress polling output]' \
          '--username=[username for HTTP basic auth]:user' \
          '--password=[password for HTTP basic auth]:pass' && ret=0
        ;;
      *)
        _arguments -s -S \
          '--url=[Cromwell server URL]:url' \
          '--username=[username for HTTP basic auth]:user' \
          '--password=[password for HTTP basic auth]:pass' \
          '*:workflow id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
