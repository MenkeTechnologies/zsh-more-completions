#compdef samtools-ampliconclip
# Documentation: http://www.htslib.org/doc/samtools-ampliconclip.html
# samtools ampliconclip: Clip reads in a SAM/BAM/CRAM file based on a BED file of primers

local ret=1

_arguments -s -S \
  '(-b)'-b'[BED file of regions (e.g. amplicon primers) to be removed.]:FILE:_files' \
  '(-o)'-o'[Output file name (defaults to stdout).]:FILE:_files' \
  '(-f)'-f'[File to write stats to (defaults to stderr).]:FILE:_files' \
  '(-u)'-u'[Output uncompressed SAM, BAM or CRAM.]' \
  '(--soft-clip)'--soft-clip'[Soft clip reads (default).]' \
  '(--hard-clip)'--hard-clip'[Hard clip reads.]' \
  '(--both-ends)'--both-ends'[Clip at both the 5'\'' and the 3'\'' ends where regions match. When using th]' \
  '(--strand)'--strand'[Use strand entry from the BED file to clip on the matching forward or]' \
  '(--clipped)'--clipped'[Only output clipped reads. Filter all others.]' \
  '(--fail)'--fail'[Mark unclipped reads as QC fail.]' \
  '(--filter-len)'--filter-len'[Filter out reads of INT size or shorter. In this case soft clips are n]:INT: ' \
  '(--fail-len)'--fail-len'[As --filter-len but mark as QC fail rather then filter out.]:INT: ' \
  '(--unmap-len)'--unmap-len'[As --filter-len but mark as unmapped. Default is 0 (no matching reads)]:INT: ' \
  '(--no-excluded)'--no-excluded'[Filter out any reads that are marked as QCFAIL or are unmapped. This w]' \
  '(--rejects-file)'--rejects-file'[Write any filtered reads out to a file.]:FILE:_files' \
  '(--primer-counts)'--primer-counts'[File to write with read counts per bed entry (bedgraph format).]:FILE:_files' \
  '(--original)'--original'[Add an OA tag with the original data for clipped files.]' \
  '(--keep-tag)'--keep-tag'[In clipped reads, keep the possibly invalid NM and MD tags. By default]' \
  '(--tolerance)'--tolerance'[The amount of latitude given in matching regions to alignments. Defaul]:INT: ' \
  '(--no-PG)'--no-PG'[Do not at a PG line to the header.]' \
  '*:file:_files' && ret=0

return ret
