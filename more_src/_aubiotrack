#compdef aubiotrack
# Documentation: https://aubio.org/manual/latest/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# aubiotrack: beat tracking
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-i[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '--input=[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '-r[sample rate]:rate:' \
  '--samplerate=[sample rate]:rate:' \
  '-B[buffer size]:n:' \
  '--bufsize=[buffer size]:n:' \
  '-H[hop size]:n:' \
  '--hopsize=[hop size]:n:' \
  -O[onset method]:method:(default energy hfc complex phase wphase specdiff kl mkl specflux) -t[onset threshold]:thr: -m[minimum onset interval]:sec: -s[silence threshold dB]:db: \
  '*::aubiotrack args:_files' && ret=0
return ret
