#compdef rbd-mirror

# rbd-mirror: Ceph RBD image mirror daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[id]:id:' \
  '--id=[id]:id:' \
  '-n[name]:name:' \
  '--name=[name]:name:' \
  '-d[foreground (debug)]' \
  '-f[foreground]' \
  '--foreground[foreground]' \
  '--log-file=[log file]:file:_files' \
  '*::rbd-mirror args:_files' && ret=0
return ret
