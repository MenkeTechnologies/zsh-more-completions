#compdef rbd-mirror
# Documentation: https://docs.ceph.com/en/latest/man/8/rbd-mirror/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rbd-mirror: Ceph RBD image mirror daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '--version[show version]' \
  '-c[ceph config file]:file:_files -g "*.conf"' \
  '--conf=[ceph config file]:file:_files -g "*.conf"' \
  '--cluster=[cluster name]:name:' \
  '-i[id]:id:' \
  '--id=[id]:id:' \
  '-n[name]:name:' \
  '--name=[name]:name:' \
  '-m[monitor address]:addr:' \
  '-d[foreground (debug)]' \
  '-f[foreground]' \
  '*::rbd-mirror args:_files' && ret=0
return ret
