#compdef sediff
# _sediff — SELinux setools sediff (semantic diff between two SELinux policies; --types/--attributes/--roles/--users/--bools/--commons/--classes/--levels/--cats/--mlsrange/--polcaps/--initialsids/--fs_uses/--genfscons/--netifcons/--nodecons/--portcons/--ibendportcons/--ibpkeycons/--rangetrans/--rbac/--terules/--avrules/--avxrules/--filename_trans; --summary just stats, --stats counters only, --header header only, --json output JSON)
# upstream: https://github.com/SELinuxProject/setools
# Flags from SELinuxProject/setools setools/sediff.py on tip.

_sediff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--summary[summary only]' \
        '--stats[stats only]' \
        '--header[header only]' \
        '--json[JSON output]' \
        '--types[types]' \
        '--attributes[attributes]' \
        '--roles[roles]' \
        '--users[users]' \
        '--bools[bools]' \
        '--commons[commons]' \
        '--classes[classes]' \
        '--levels[levels]' \
        '--cats[cats]' \
        '--mlsrange[mlsrange]' \
        '--polcaps[polcaps]' \
        '--initialsids[initial SIDs]' \
        '--fs_uses[fs_uses]' \
        '--genfscons[genfscons]' \
        '--netifcons[netifcons]' \
        '--nodecons[nodecons]' \
        '--portcons[portcons]' \
        '--rangetrans[range transitions]' \
        '--rbac[rbac rules]' \
        '--terules[type-enforcement rules]' \
        '--avrules[av rules]' \
        '--avxrules[avx rules]' \
        '--filename_trans[filename transitions]' \
        '1:policy1:_files' \
        '2:policy2:_files'
}

_sediff "$@"
