#compdef recfix
# Documentation: https://www.gnu.org/software/recutils/
# Reference accessed: 2026-06-10

# Zsh completion for recfix (GNU Recutils)

_arguments -s -S \
  '-f[force fix mode]' \
  '--check[check only, do not modify]' \
  '--sort[sort fields in records]' \
  '--no-auto[do not generate auto fields]' \
  '-P+[password for encrypted fields]:password:' \
  '*:file:_files'
