#compdef splitter
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS splitter: chop a sequence into smaller overlapping chunks of a
# given size. Useful for breaking up large sequences for tools that
# require shorter input.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-size=[chunk size in bases]:size:' \
  '-overlap=[overlap between adjacent chunks in bases]:overlap:' \
  '-addoverlap[also append the overlap to the next chunk]' \
  '-feature[carry feature tables into each output chunk]' \
  '-outseq=[output sequence file (will be N split files)]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
