#compdef cutechess-cli
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man6/cutechess-cli.6.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu trusty cutechess-cli(6) manpage + upstream
# cutechess/cutechess docs.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -pgn-out-min-moves and -srandom flags.

# cutechess-cli: CLI tournament runner for chess engines
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-engines[list configured engines]' \
  '-protocols[list supported protocols]' \
  '-variants[list supported chess variants]' \
  '*-engine[engine definition]:opts:' \
  '-each[options to apply to each engine]:opts:' \
  '-variant[chess variant]:variant:(standard fischerandom atomic crazyhouse 3check antichess horde kingofthehill racingkings)' \
  '-concurrency[max concurrent games]:n:' \
  '-tournament[tournament type]:type:(round-robin gauntlet knockout pyramid)' \
  '-event[event name]:name:' \
  '-site[site/location]:site:' \
  '-games[games per encounter]:n:' \
  '-rounds[multiply rounds by N]:n:' \
  '-openings[opening book config]:opts:' \
  '-bookmode[Polyglot book access]:mode:(ram disk)' \
  '-sprt[Sequential Probability Ratio Test]:opts:' \
  '-pgnout[save PGN]:file_min:_files -g "*.pgn(-.)"' \
  '-epdout[save FEN]:file:_files -g "*.epd(-.)"' \
  '-ratinginterval[rating output interval]:n:' \
  '-outcomeinterval[outcome interval]:n:' \
  '-resultformat[result format]:format:(help)' \
  '-draw[draw adjudication]:opts:' \
  '-resign[resign adjudication]:opts:' \
  '-maxmoves[max moves per game]:n:' \
  '-tb[tablebase directory]:path:_files -/' \
  '-tbpieces[max tablebase pieces]:n:' \
  '-tbignore50[ignore 50-move rule in tablebases]' \
  '-repeat[repeat openings (optional N)]:n:' \
  '-noswap[do not swap colors]' \
  '-reverse[reverse colors]' \
  '-seeds[seeded round-robin seeds]:n:' \
  '-srand[random seed]:n:' \
  '-wait[wait milliseconds between games]:ms:' \
  '-recover[recover from engine crashes]' \
  '-debug[debug engine protocol]' \
  '-tournamentfile[save tournament state]:file:_files' && ret=0
return ret
