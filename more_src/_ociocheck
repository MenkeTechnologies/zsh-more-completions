#compdef ociocheck
# Documentation: https://opencolorio.readthedocs.io/
# validate an OpenColorIO configuration

local ret=1

_arguments -s -S \
  '--help[print help message]' \
  '--iconfig=[input .ocio configuration file (default: $OCIO)]:config:_files -g "*.ocio"' \
  '--oconfig=[output .ocio file]:config:_files -g "*.ocio"' && ret=0

return ret
