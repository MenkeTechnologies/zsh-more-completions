#compdef camply
# camply — campsite availability finder CLI (Python)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcommands=(
  'campsites:search for available campsites'
  'recreation-areas:list recreation areas'
  'campgrounds:list campgrounds within a recreation area'
  'equipment-types:list supported equipment types'
  'configure:set up camply configuration'
  'providers:list supported providers'
  'list-campsites:list campsite details'
)

_arguments -s -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug logging]' \
  '1:command:->command' \
  '*:: :->args' \
  && ret=0

case $state in
  (command)
    _describe -t commands 'camply command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (campsites)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--provider=[campsite provider]:provider:(RecreationDotGov Yellowstone GoingToCamp)' \
          '--rec-area=[recreation area ID]:rec area ID:' \
          '--campground=[campground ID]:campground ID:' \
          '--start-date=[start date (YYYY-MM-DD)]:date:' \
          '--end-date=[end date (YYYY-MM-DD)]:date:' \
          '--nights=[minimum number of consecutive nights]:nights:' \
          '--continuous[require continuous availability]' \
          '--search=[search by name]:search string:' \
          '--state=[filter by state]:state:' \
          '--equipment=[equipment type]:type:' \
          '--polling-interval=[minutes between checks]:minutes:' \
          '--notifications=[notification provider]:provider:(email pushover pushbullet ntfy slack telegram apprise silent)' \
          '--yaml-config=[YAML config file]:config file:_files -g "*.yml *.yaml"' \
          '--day[search for day-use sites only]' \
          && ret=0
        ;;
      (recreation-areas)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--search=[search by name]:search string:' \
          '--state=[filter by state]:state:' \
          && ret=0
        ;;
      (campgrounds)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--rec-area=[recreation area ID]:rec area ID:' \
          '--search=[search by name]:search string:' \
          && ret=0
        ;;
      (configure)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
