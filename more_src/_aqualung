#compdef aqualung
# Documentation: https://www.mankier.com/1/aqualung
# Reference accessed: 2026-05-16
# Verified: mankier aqualung(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# aqualung: advanced music player (no inter-track gaps)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-D --disk-realtime)'{-D,--disk-realtime}'[disk thread realtime priority]' \
  '(-Y --disk-priority)'{-Y+,--disk-priority=}'[disk thread priority]:n:' \
  '(-d --device)'{-d+,--device=}'[output device]:device:' \
  '(-r --rate)'{-r+,--rate=}'[sample rate]:rate:' \
  '(-b --buffer-size)'{-b+,--buffer-size=}'[buffer size]:bytes:' \
  '(-R --realtime)'{-R,--realtime}'[realtime output]' \
  '(-P --priority)'{-P+,--priority=}'[output priority]:n:' \
  '(-a --auto)'{-a-,--auto=-}'[auto-connect ports]:ports:' \
  '(-c --client)'{-c+,--client=}'[JACK client name]:name:' \
  '(-s --srctype)'{-s-,--srctype=-}'[sample rate converter type]:type:' \
  '(-N --session)'{-N+,--session=}'[session id]:n:' \
  '(-B --back)'{-B,--back}'[play previous track]' \
  '(-F --fwd)'{-F,--fwd}'[play next track]' \
  '(-L --play)'{-L,--play}'[start playback]' \
  '(-U --pause)'{-U,--pause}'[pause playback]' \
  '(-T --stop)'{-T,--stop}'[stop playback]' \
  '(-V --volume)'{-V+,--volume=}'[set volume]:value:' \
  '(-Q --quit)'{-Q,--quit}'[quit aqualung]' \
  '(-E --enqueue)'{-E,--enqueue}'[enqueue tracks]' \
  '(-t --tab)'{-t-,--tab=-}'[switch to tab]:name:' \
  '(-l --show-pl)'{-l-,--show-pl=-}'[show playlist]:yesno:(yes no)' \
  '(-m --show-ms)'{-m-,--show-ms=-}'[show music store]:yesno:(yes no)' \
  '*:audio file:_files' && ret=0
return ret
