_streamdeck-cli() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'brightness:set key brightness (0-100)'
        'clear:clear all images (reset keys to black)'
        'devices:list all available Stream Deck devices'
        'image:set an image on a specific key'
        'reset:reset the device, clear all images, show default Elgato logo'
        'help:help about any command'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[help for streamdeck-cli]' \
        '--version[version for streamdeck-cli]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'streamdeck-cli subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                brightness)
                    _arguments '1:percentage (0-100):(0 10 25 50 75 100)' && ret=0
                    ;;
                image)
                    _arguments \
                        '1:key index (0-indexed top-left to bottom-right):' \
                        '2:image file:_files -g "*.(jpg|jpeg|png|gif|bmp|tiff|webp|JPG|JPEG|PNG|GIF|BMP|TIFF|WebP)"' && ret=0
                    ;;
                help)
                    _describe -t commands 'subcommand' subcmds && ret=0
                    ;;
                clear|devices|reset)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_streamdeck-cli "$@"
