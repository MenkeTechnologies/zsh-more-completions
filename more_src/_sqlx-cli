#compdef sqlx

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'database:manage databases'
  'migrate:manage migrations'
  'prepare:prepare query metadata for offline mode'
  'completions:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-D+[database URL]:URL' \
  '--database-url=[database URL]:URL' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'sqlx command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      database)
        local -a db_cmds=(
          'create:create the database'
          'drop:drop the database'
          'reset:drop and re-create the database and run migrations'
          'setup:create database and run migrations'
        )
        _arguments -s -S \
          '1:database command:->db_cmd' && ret=0
        case "$state" in
          db_cmd)
            _describe -t commands 'database subcommand' db_cmds && ret=0
            ;;
        esac
        ;;
      migrate)
        local -a mig_cmds=(
          'add:create a new migration'
          'run:run pending migrations'
          'revert:revert the last migration'
          'info:list all migrations'
          'build-script:generate build script for migrations'
        )
        _arguments -s -S \
          '--source=[migration source directory]:directory:_directories' \
          '1:migrate command:->mig_cmd' \
          '*::args:->mig_args' && ret=0
        case "$state" in
          mig_cmd)
            _describe -t commands 'migrate subcommand' mig_cmds && ret=0
            ;;
          mig_args)
            case "${words[1]}" in
              add)
                _arguments -s -S \
                  '-r[create reversible migration with up/down files]' \
                  '--reversible[create reversible migration with up/down files]' \
                  '--sequential[use sequential versioning]' \
                  '--timestamp[use timestamp versioning]' \
                  '1:migration name:' && ret=0
                ;;
              run)
                _arguments -s -S \
                  '--dry-run[dry run]' \
                  '--ignore-missing[ignore missing migrations]' && ret=0
                ;;
              revert)
                _arguments -s -S \
                  '--dry-run[dry run]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      prepare)
        _arguments -s -S \
          '--workspace[prepare for all crates in the workspace]' \
          '--check[check that the query cache is up to date]' && ret=0
        ;;
    esac
    ;;
esac

return ret
