#compdef muesli-cli
# Documentation: https://github.com/pHequals7/muesli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# muesli-cli: agent-friendly local CLI bundled with the Muesli macOS app
# (local meeting transcription + dictation). Output is JSON.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'spec:return the command contract specification'
  'info:show general application information'
  'meetings:manage meeting transcripts'
  'dictations:manage dictations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--db-path=[override database path]:file:_files' \
  '--support-dir=[override support directory]:directory:_directories' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'muesli-cli command' commands && ret=0 ;;
  args)
    case ${line[1]} in
      (meetings)
        local -a mcmds=(
          'list:list recent meetings'
          'get:fetch a specific meeting record'
          'update-notes:update meeting notes'
        )
        _arguments \
          '1: :_describe -t mcmds "meetings command" mcmds' \
          '--limit=[limit results]:n:' \
          '--folder-id=[filter by folder]:id:' \
          '--file=[read notes from file]:file:_files' \
          '--stdin[read notes from stdin]' && ret=0
        ;;
      (dictations)
        local -a dcmds=(
          'list:list recent dictations'
          'get:fetch a specific dictation record'
        )
        _arguments \
          '1: :_describe -t dcmds "dictations command" dcmds' \
          '--limit=[limit results]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
