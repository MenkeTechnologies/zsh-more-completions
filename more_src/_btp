#compdef btp
# _btp — SAP Business Technology Platform CLI (SAP/btp-cli)
# upstream: https://help.sap.com/docs/btp/btp-cli-command-reference

_btp() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--format=[output format]:format:(text json)' \
        '--verbose[verbose output]' \
        '--help[show help]' \
        '--version[show version]' \
        '1: :_btp_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login)
                    _arguments \
                        '--url=[server URL]:url:' \
                        '--subdomain=[global account subdomain]:subdomain:' \
                        '--user=[username]:user:' \
                        '--password=[password]:password:' \
                        '--idp=[identity provider]:idp:' \
                        '--sso[use SSO]' \
                        '--help[show help]' && ret=0 ;;
                target)
                    _arguments \
                        '--global-account=[global account]:ga:' \
                        '--directory=[directory]:dir:' \
                        '--subaccount=[subaccount]:sa:' \
                        '--help[show help]' && ret=0 ;;
                *)
                    _arguments '--help[show help]' '*:args:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_btp_commands] )) ||
_btp_commands() {
    local -a commands
    commands=(
        'login:log in to a global account'
        'logout:log out'
        'target:set the target for commands'
        'list:list resources'
        'get:get resource details'
        'create:create a resource'
        'update:update a resource'
        'delete:delete a resource'
        'subscribe:subscribe to a service'
        'unsubscribe:unsubscribe from a service'
        'assign:assign resources'
        'unassign:unassign resources'
        'add:add resources'
        'remove:remove resources'
        'enable:enable a feature'
        'disable:disable a feature'
        'move:move resources'
        'register:register a resource'
        'unregister:unregister a resource'
        'help:show help'
    )
    _describe -t commands 'btp command' commands
}

_btp "$@"
