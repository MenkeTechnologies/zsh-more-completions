#compdef arachni_reporter
# Documentation: https://github.com/Arachni/arachni/wiki/Executables
# Arachni report converter from AFR report files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[output this message]' \
  '--version[show version information]' \
  '--reporter=[reporter to use, format name:option=value]:reporter' \
  '--reporters-list[list available reporters]' \
  '*:AFR report file:_files -g "*.afr"' && ret=0

return ret
