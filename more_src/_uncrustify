#compdef uncrustify

# Zsh completion for Uncrustify source code beautifier

_uncrustify() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-c+[configuration file]:config file:_files' \
    '-f+[input file]:input file:_files' \
    '-o+[output file]:output file:_files' \
    '-F+[file containing list of files to process]:file list:_files' \
    '--files=[file containing list of files to process]:file list:_files' \
    '-t[load a file as a fragment (part of a function)]' \
    '--frag[load a file as a fragment]' \
    '--assume=[override file type with specified language extension]:extension:' \
    '-l+[language override]:language:(C CPP D CS JAVA PAWN OC OC+ VALA)' \
    '-L+[log severity]:severity:(0 1 2 3 4 5 6)' \
    '--log=[log file]:log file:_files' \
    '-q[quiet mode]' \
    '--quiet[quiet mode]' \
    '-s[log to stderr]' \
    '--show[show the config file with all options and values]' \
    '-p+[dump debug parsed file]:dump file:_files' \
    '--parsed=[dump debug parsed file]:dump file:_files' \
    '--prefix=[set prefix for dump files]:prefix:' \
    '--suffix=[set suffix for dump files]:suffix:' \
    '--replace[replace source files (creates backup)]' \
    '--no-backup[replace files without backup (use with --replace)]' \
    '--mtime[preserve file modification time]' \
    '--universalindent[output the config as a Universal Indent GUI config file]' \
    '--detect[detect language from file extension]' \
    '-e+[set error file]:error file:_files' \
    '--set=[set a config option]:option=value:' \
    '--check[check if file needs formatting (exit 0 = no changes needed)]' \
    '--if-changed[write output only if changes are needed]' \
    '--decode=[decode and display flag]:flag:' \
    '--update-config[update config with uncrustify-formatted output]' \
    '--update-config-with-doc[update config with documentation]' \
    '--config-default=[create a default config file]:output file:_files' \
    '--configfile-default=[create a default config file]:output file:_files' \
    '--version[display version]' \
    '(-h --help)'{-h,--help}'[display help]' \
    '--usage[display usage]' \
    '*:source files:_files -g "*.{c,cpp,cc,cxx,h,hpp,hxx,cs,java,m,mm,d,pawn,vala}"' \
    && ret=0

  return ret
}

_uncrustify "$@"
