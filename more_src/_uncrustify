#compdef uncrustify
# Documentation: https://man.archlinux.org/man/uncrustify.1.en
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

# Zsh completion for Uncrustify source code beautifier

_uncrustify() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '-c+[configuration file]:config file:_files' \
    '-f+[process single file]:input file:_files' \
    '-o+[redirect output to file]:output file:_files' \
    '-F+[read filenames from file (or stdin)]:file list:_files' \
    '--prefix=[prepend text to output filename paths]:prefix:' \
    '--suffix=[append suffix to output filenames]:suffix:' \
    '--frag[treat input as a code fragment]' \
    '-t+[load a types file]:types file:_files' \
    '-l+[language override]:language:(C CPP D CS JAVA PAWN OC OC+ VALA)' \
    '-L+[log severity]:severity:' \
    '-q[quiet mode (suppress stderr output)]' \
    '-s[show log severity in output]' \
    '-p+[dump debug information to file]:dump file:_files' \
    '-ds+[dump parsing information at formatting steps]:dump file:_files' \
    '--dump-steps=[dump parsing information at formatting steps]:dump file:_files' \
    '--replace[replace source files (creates backup)]' \
    '--no-backup[replace files without backup]' \
    '--mtime[preserve modification time on replaced files]' \
    '--check[verify processing causes no changes]' \
    '--if-changed[write output only if changes detected]' \
    '--decode[print flag as text]:flag:' \
    '--universalindent[output Universal Indent GUI config]' \
    '--detect[detect configuration from source]' \
    '--tracking[prepare debugging information]' \
    '--show-config[display option documentation]' \
    '--update-config[generate a new config file]' \
    '--update-config-with-doc[generate config with comments]' \
    '--count-options[print available option count]' \
    '--version[show version]' \
    '(-h --help -? --usage)'{-h,--help,-\?,--usage}'[display help]' \
    '*:source files:_files' \
    && ret=0

  return ret
}

_uncrustify "$@"
