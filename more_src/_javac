#compdef javac
# _javac — OpenJDK Java compiler (Oracle/OpenJDK, Java); custom argparse
# upstream: https://github.com/openjdk/jdk

_javac() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '--help-extra[show extra help]' \
        '-X[show extra help]' \
        '-Akey=+[annotation processor option]:str:' \
        '--add-modules=+[add modules]:list:' \
        '--add-reads=+[add reads]:str:' \
        '--add-exports=+[add exports]:str:' \
        '--boot-class-path=+[boot class path]:list:_files' \
        '-bootclasspath+[boot class path]:list:_files' \
        '-classpath+[class path]:list:_files' \
        '-cp+[class path]:list:_files' \
        '--class-path=+[class path]:list:_files' \
        '-d+[output dir for classes]:dir:_files -/' \
        '-deprecation[show deprecation]' \
        '--enable-preview[enable preview]' \
        '-encoding+[source encoding]:enc:' \
        '-endorseddirs+[endorsed dirs]:dirs:_files -/' \
        '-extdirs+[ext dirs]:dirs:_files -/' \
        '-g[generate all debug info]' \
        '-g:lines[generate lines info]' \
        '-g:source[generate source info]' \
        '-g:vars[generate vars info]' \
        '-g:none[no debug info]' \
        '-h+[output dir for native headers]:dir:_files -/' \
        '-implicit:+[implicit policy]:p:(none class)' \
        '-J+[JVM arg]:arg:' \
        '--limit-modules=+[limit modules]:list:' \
        '--module=+[compile only specified module]:str:' \
        '-m+[compile only specified module]:str:' \
        '--module-path=+[module path]:list:_files' \
        '-p+[module path]:list:_files' \
        '--module-source-path=+[module source path]:list:_files' \
        '--module-version=+[module version]:ver:' \
        '-nowarn[no warnings]' \
        '-parameters[generate metadata for params]' \
        '-proc:none[do not process]' \
        '-proc:only[only process]' \
        '-proc:full[full process]' \
        '-processor+[annotation processors]:list:' \
        '-processorpath+[processor path]:list:_files' \
        '--processor-path=+[processor path]:list:_files' \
        '-processormodulepath+[processor module path]:list:_files' \
        '--processor-module-path=+[processor module path]:list:_files' \
        '--release=+[release version]:n:' \
        '--source=+[source version]:n:' \
        '-source+[source version]:n:' \
        '--source-path=+[source path]:list:_files' \
        '-sourcepath+[source path]:list:_files' \
        '--system=+[system jdk]:dir:_files -/' \
        '--target=+[target version]:n:' \
        '-target+[target version]:n:' \
        '--upgrade-module-path=+[upgrade module path]:list:_files' \
        '-verbose[verbose]' \
        '-Werror[treat warnings as errors]' \
        '-Xlint=+[warnings]:list:(all none auxiliaryclass cast classfile deprecation dep-ann divzero empty fallthrough finally lossy-conversions module options overloads overrides path preview rawtypes removal requires-automatic requires-transitive-automatic serial static synchronization text-blocks try unchecked varargs)' \
        '-Xdoclint:+[doc lint]:list:' \
        '-Xstdout+[redirect output]:file:_files' \
        '-Xmaxerrs+[max errors]:n:' \
        '-Xmaxwarns+[max warnings]:n:' \
        '-Xprefer:+[prefer source/newer]:p:(source newer)' \
        '*:source-file:_files -g "*.java"'
}

_javac "$@"
