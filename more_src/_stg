#compdef stg

_stg_cmds() {
    local -a commands=(
        'init:initialize StGit for the current branch'
        'new:create a new empty patch'
        'delete:delete patches'
        'push:push patches onto the stack'
        'pop:pop patches from the stack'
        'goto:push or pop to the named patch'
        'rebase:move the stack base to another point'
        'refresh:incorporate worktree changes into current patch'
        'edit:edit a patch'
        'rename:rename a patch'
        'series:display the patch series'
        'log:display the patch changelog'
        'diff:show the tree diff'
        'show:show patch commit'
        'files:show files changed by a patch'
        'export:export patches to a directory'
        'import:import patches from various sources'
        'mail:send patches via email'
        'fold:fold diff into current patch'
        'squash:squash two or more patches into one'
        'sink:move patches deeper in the stack'
        'float:push patches to the top of the stack'
        'commit:permanently store bottom patches into the stack base'
        'uncommit:convert regular commits to StGit patches'
        'repair:fix StGit metadata'
        'reset:reset the patch stack to an earlier state'
        'clean:delete empty patches'
        'clone:clone a repository with StGit support'
        'branch:manage branches'
        'undo:undo the last stack operation'
        'redo:undo the last undo operation'
        'top:print the name of the top patch'
        'next:print the name of the next patch'
        'prev:print the name of the previous patch'
        'id:print the git hash of a patch'
        'patches:show patches that modify a file'
        'completion:generate shell completions'
        'version:print version information'
        'help:print help information'
    )
    _describe -t commands 'stg command' commands
}

_stg() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '--version[print version]' \
        '(-h --help)'{-h,--help}'[print help]' \
        '--color=[when to colorize output]:when:(auto always never ansi)' \
        '1:command:_stg_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                new)
                    _arguments \
                        '(-m --message)'{-m,--message}'=[patch description]:message' \
                        '--author=[set author]:author' \
                        '--authname=[set author name]:name' \
                        '--authemail=[set author email]:email' \
                        '--authdate=[set author date]:date' \
                        '(-s --sign)'{-s,--sign}'[add Signed-off-by]' \
                        '(-e --edit)'{-e,--edit}'[invoke editor]' \
                        '--save-template=[save message template]:file:_files' \
                        '1:patch-name'
                    ;;
                push)
                    _arguments \
                        '(-a --all)'{-a,--all}'[push all unapplied patches]' \
                        '(-n --number)'{-n,--number}'=[push specified number]:number' \
                        '--set-tree[set tree to match patch]' \
                        '(-k --keep)'{-k,--keep}'[keep local changes]' \
                        '(-m --merged)'{-m,--merged}'[check for already merged patches]' \
                        '--committer-date-is-author-date[use author date as committer date]' \
                        '*:patch'
                    ;;
                pop)
                    _arguments \
                        '(-a --all)'{-a,--all}'[pop all applied patches]' \
                        '(-n --number)'{-n,--number}'=[pop specified number]:number' \
                        '(-k --keep)'{-k,--keep}'[keep local changes]' \
                        '*:patch'
                    ;;
                refresh)
                    _arguments \
                        '(-p --patch)'{-p,--patch}'=[refresh named patch]:patch' \
                        '(-e --edit)'{-e,--edit}'[invoke editor]' \
                        '(-a --annotate)'{-a,--annotate}'=[annotate commit log]:note' \
                        '(-m --message)'{-m,--message}'=[replace patch description]:message' \
                        '(-s --sign)'{-s,--sign}'[add Signed-off-by]' \
                        '--author=[set author]:author' \
                        '(-i --index)'{-i,--index}'[refresh from index]' \
                        '(-F --force)'{-F,--force}'[force refresh even if index is dirty]' \
                        '--submodules[include submodules]' \
                        '--no-submodules[exclude submodules]' \
                        '*:file:_files'
                    ;;
                edit)
                    _arguments \
                        '(-m --message)'{-m,--message}'=[patch description]:message' \
                        '(-e --edit)'{-e,--edit}'[invoke editor]' \
                        '(-s --sign)'{-s,--sign}'[add Signed-off-by]' \
                        '--author=[set author]:author' \
                        '(-d --diff)'{-d,--diff}'[edit diff]' \
                        '(-t --set-tree)'{-t,--set-tree}'=[set tree]:treeish' \
                        '1:patch'
                    ;;
                delete)
                    _arguments \
                        '--top[delete top patch]' \
                        '--spill[spill patch contents to worktree]' \
                        '*:patch'
                    ;;
                series)
                    _arguments \
                        '(-a --all)'{-a,--all}'[show all patches]' \
                        '(-A --applied)'{-A,--applied}'[show applied patches]' \
                        '(-U --unapplied)'{-U,--unapplied}'[show unapplied patches]' \
                        '(-H --hidden)'{-H,--hidden}'[show hidden patches]' \
                        '(-c --count)'{-c,--count}'[print count of patches]' \
                        '(-d --description)'{-d,--description}'[show patch descriptions]' \
                        '--no-description[do not show descriptions]' \
                        '(-e --empty)'{-e,--empty}'[show empty status]' \
                        '--short[list just names]'
                    ;;
                import)
                    _arguments \
                        '(-m --mail)'{-m,--mail}'[import from mbox file]' \
                        '(-u --url)'{-u,--url}'[import from URL]' \
                        '(-n --name)'{-n,--name}'=[use name for patch]:name' \
                        '(-s --strip)'{-s,--strip}'=[strip leading path components]:number' \
                        '(-t --stripname)'{-t,--stripname}'[strip numbering from patch name]' \
                        '--series[import from series file]' \
                        '(-e --edit)'{-e,--edit}'[invoke editor]' \
                        '(-s --sign)'{-s,--sign}'[add Signed-off-by]' \
                        '1:file:_files'
                    ;;
                squash)
                    _arguments \
                        '(-m --message)'{-m,--message}'=[patch description]:message' \
                        '(-n --name)'{-n,--name}'=[name for squashed patch]:name' \
                        '*:patch'
                    ;;
                rebase)
                    _arguments \
                        '(-n --nopush)'{-n,--nopush}'[do not push patches after rebase]' \
                        '(-m --merged)'{-m,--merged}'[check for merged patches]' \
                        '1:new-base'
                    ;;
                branch)
                    _arguments \
                        '--list[list branches]' \
                        '--create[create and switch to branch]' \
                        '--clone[clone current branch]' \
                        '--rename[rename current branch]' \
                        '--protect[protect branch]' \
                        '--unprotect[unprotect branch]' \
                        '--delete[delete branch]' \
                        '--cleanup[cleanup stale branches]' \
                        '--description=[set branch description]:desc' \
                        '*:branch'
                    ;;
            esac
            ;;
    esac
}

_stg "$@"
