#compdef svdrpsend
# Documentation: https://manpages.debian.org/bookworm/vdr/svdrpsend.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm svdrpsend(1) manpage. Minimal surface.

# svdrpsend: send commands to VDR via SVDRP protocol
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[VDR hostname (default localhost)]:host:_hosts' \
  '-p[SVDRP port (default 6419)]:port:' \
  '*:SVDRP command:' && ret=0
return ret
