#compdef aseprite

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  '(-b --batch)'{-b,--batch}'[Run in batch mode without UI]' \
  '--sheet[Export sprite sheet to file]:file:_files' \
  '--sheet-type[Sprite sheet type]:type:(horizontal vertical rows columns packed)' \
  '--sheet-columns[Number of columns in sprite sheet]:columns' \
  '--sheet-rows[Number of rows in sprite sheet]:rows' \
  '--sheet-width[Sprite sheet width]:width' \
  '--sheet-height[Sprite sheet height]:height' \
  '--sheet-pack[Pack frames in sprite sheet]' \
  '--data[Export sprite data to JSON file]:file:_files' \
  '--format[Data format]:format:(json-hash json-array)' \
  '--list-layers[List layer names in JSON data]' \
  '--list-tags[List tag names in JSON data]' \
  '--list-slices[List slice names in JSON data]' \
  '--layer[Include only the given layer]:layer' \
  '--all-layers[Include all layers]' \
  '--frame-tag[Include only frames of the given tag]:tag' \
  '--frame-range[Select a frame range]:range' \
  '--ignore-empty[Ignore empty frames]' \
  '--trim[Trim whitespace on each frame]' \
  '--trim-sprite[Trim the entire sprite]' \
  '--crop[Crop the sprite]:rect' \
  '--slice[Select a specific slice]:slice' \
  '--filename-format[Filename format string]:format' \
  '--save-as[Save the sprite as a specific file]:file:_files' \
  '--scale[Scale factor]:scale' \
  '--dithering-algorithm[Dithering algorithm]:algorithm:(none ordered old bayer)' \
  '--dithering-matrix[Dithering matrix ID]:matrix' \
  '--color-mode[Convert to color mode]:mode:(rgb grayscale indexed)' \
  '--palette-size[Set palette size for quantization]:size' \
  '--shrink-to[Shrink to fit dimensions]:dimensions' \
  '--split-layers[Save each layer as separate file]' \
  '--split-tags[Save each tag as separate file]' \
  '--verbose[Enable verbose output]' \
  '--script[Execute a Lua script]:script:_files' \
  '--script-param[Pass a parameter to the script]:param' \
  '*:file:_files' && ret=0

return ret
