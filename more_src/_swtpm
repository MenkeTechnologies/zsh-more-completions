#compdef swtpm
# _swtpm — IBM Stefan Berger Software TPM emulator CLI (stefanberger, C); custom argparse
# upstream: https://github.com/stefanberger/swtpm

_swtpm() {
    local -a sub=(
        'socket:run as TCP/Unix socket'
        'chardev:run as character device'
        'cuse:run as cuse character device'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-?[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swtpm subcommand' sub ;;
        args)
            case $words[1] in
                socket) _arguments \
                    '--tpm2[TPM2]' \
                    '--tpmstate=+[state path]:str:' \
                    '-t+[state path]:str:' \
                    '--server=+[server type]:str:' \
                    '--ctrl=+[ctrl type]:str:' \
                    '--migration-key=+[migration key]:str:' \
                    '--log=+[log file/socket]:str:' \
                    '-l+[log file/socket]:str:' \
                    '--terminate[terminate when client closes]' \
                    '-T[terminate when client closes]' \
                    '--pid=+[pid file]:file:_files' \
                    '-p+[pid file]:file:_files' \
                    '--vtpm-proxy[run in vtpm-proxy mode]' \
                    '--daemon[daemonize]' \
                    '-d[daemonize]' \
                    '--createek[create endorsement key]' \
                    '--locality+[allow locality]:n:' \
                    '--flags=+[flags]:list:' ;;
                chardev) _arguments \
                    '--tpm2[TPM2]' \
                    '--vtpm-proxy[vtpm-proxy mode]' \
                    '--ctrl=+[ctrl type]:str:' \
                    '--log=+[log file]:file:_files' \
                    '-l+[log file]:file:_files' \
                    '--migration-key=+[migration key]:str:' \
                    '--tpmstate=+[state path]:str:' \
                    '-t+[state path]:str:' \
                    '--pid=+[pid file]:file:_files' \
                    '-p+[pid file]:file:_files' \
                    '--daemon[daemonize]' \
                    '-d[daemonize]' \
                    '--terminate[terminate when client closes]' \
                    '-T[terminate when client closes]' \
                    '--createek[create endorsement key]' \
                    '--locality+[allow locality]:n:' ;;
                cuse) _arguments \
                    '--tpm2[TPM2]' \
                    '--name=+[cuse name]:str:' \
                    '-n+[cuse name]:str:' \
                    '--maj=+[major number]:n:' \
                    '-M+[major number]:n:' \
                    '--min=+[minor number]:n:' \
                    '-m+[minor number]:n:' \
                    '--log=+[log file]:file:_files' \
                    '-l+[log file]:file:_files' \
                    '--tpmstate=+[state path]:str:' \
                    '-t+[state path]:str:' \
                    '--migration-key=+[migration key]:str:' \
                    '--ctrl=+[ctrl type]:str:' \
                    '--pid=+[pid file]:file:_files' \
                    '-p+[pid file]:file:_files' \
                    '--createek[create endorsement key]' \
                    '--locality+[allow locality]:n:' ;;
            esac
            ;;
    esac
}

_swtpm "$@"
