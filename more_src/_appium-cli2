#compdef appium-cli2 appium2
# _appium-cli2 — Dan Cuellar Jonathan Lipps OpenJS appium-cli2 CLI command-line frontend wrapping the Appium open source automation framework for mobile native hybrid and mobile web apps as well as desktop apps using the WebDriver protocol open-source written in JavaScript Node TypeScript Selenium WebDriver compatible mobile test automation framework Sauce-Labs originated server driver plugin extension setup install run version help completion XCUITest UiAutomator2 Espresso Mac2 Windows MJPeg gecko safari chrome flutter (Dan Cuellar Jonathan Lipps OpenJS Foundation team, JavaScript/TypeScript); commander
# upstream: https://appium.io/

_appium-cli2() {
    local -a sub=(
        'driver:driver operations'
        'plugin:plugin operations'
        'extension:extension operations'
        'server:start Appium server'
        'setup:run setup'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-a+[address]:_hosts' \
        '--address=+[host]:_hosts' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '--base-path=+[path]:str:' \
        '--callback-address=+[host]:_hosts' \
        '--callback-port=+[port]:n:' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json *.toml"' \
        '-c+[config]:file:_files -g "*.yml *.yaml *.json *.toml"' \
        '--debug-log-spacing[debug log spacing]' \
        '--default-capabilities=+[json]:str:' \
        '-dc+[default caps]:str:' \
        '--keep-alive-timeout=+[sec]:n:' \
        '--local-timezone[local timezone]' \
        '--log=+[file]:file:_files' \
        '-g+[log file]:file:_files' \
        '--log-filters=+[file]:file:_files' \
        '--log-level=+[l]:l:(info info:debug info:info info:warn info:error info:fatal info:warning debug warn error fatal warning)' \
        '--log-no-colors[no log colors]' \
        '--log-timestamp[log timestamp]' \
        '--long-stacktrace[long stack trace]' \
        '--no-perms-check[no perms check]' \
        '--nodeconfig=+[file]:file:_files -g "*.json"' \
        '--relaxed-security[relaxed security]' \
        '--session-override[session override]' \
        '--strict-caps[strict caps]' \
        '--tmp=+[dir]:dir:_files -/' \
        '--trace-dir=+[dir]:dir:_files -/' \
        '--webhook=+[host:port]:_hosts' \
        '--ssl-cert-path=+[file]:file:_files -g "*.pem *.crt"' \
        '--ssl-key-path=+[file]:file:_files -g "*.pem *.key"' \
        '--allow-cors[allow CORS]' \
        '--allow-insecure=+[features]:str:' \
        '--deny-insecure=+[features]:str:' \
        '--use-drivers=+[list]:str:' \
        '--use-plugins=+[list]:str:' \
        '--plugins-import-chunk-size=+[N]:n:' \
        '--drivers-import-chunk-size=+[N]:n:' \
        '--show-build-info[show build info]' \
        '--show-config[show config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'appium subcommand' sub ;;
        args)
            case $words[1] in
                driver|plugin|extension) _arguments '1:op:(install uninstall list update run doctor)' '*:name:(xcuitest uiautomator2 espresso mac2 windows safari chromium gecko flutter)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_appium-cli2 "$@"
