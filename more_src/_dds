#compdef dds
# ============================================================================
# dds - Display.Monks Development Server: HTML5
#        ad preview + webpack-based compilation
#        with JSON Schema validation of
#        .richmediarc configs (Node.js, MIT)
#
# Author : MediaMonks / Display.Monks team
# Upstream: https://github.com/mediamonks/display-dev-server
# npm    : @mediamonks/display-dev-server
#           (binary: dds)
#
# `dds` (Display.Monks Development Server) is
# the canonical local-development tool for the
# MediaMonks HTML5 banner ad workflow. HTML5
# banners are interactive ads built with HTML +
# CSS + JS that ship to ad-tech platforms
# (Google Display & Video 360 + The Trade Desk +
# Adform + ...) as a single .zip bundle per
# format/size.
#
# dds manages:
#   - `.richmediarc` configuration files (the
#     Display.Monks JSON schema defining ad
#     dimensions + click-through URLs + asset
#     paths + platform-specific overrides for
#     DCM/DV360/TTD/Adform)
#   - Webpack-based compilation of HTML5 ads
#     with optimal asset bundling (image
#     compression + CSS minification + JS
#     transpilation)
#   - Real-time preview server with hot-reload
#     for development
#   - Multi-platform output (each .richmediarc
#     can target multiple ad platforms with
#     different output zip names)
#   - Parallel webpack workers for compiling
#     large ad packs (e.g., 50+ ad sizes ×
#     5 languages × 10 variants)
#
# Use cases:
#   - HTML5 banner ad agency workflow (the
#     MediaMonks / Display.Monks production
#     model)
#   - In-browser preview during ad design +
#     QA review
#   - CI-driven ad-pack production builds
#     (jenkins / github-actions)
#   - Ad-platform-specific output generation
#     (single .richmediarc → DV360 zip + DCM zip
#     + TTD zip + Adform zip)
#
# Usage:
#   dds [options]
#
# Flags (commander v4+):
#   -g, --glob <pattern>           - glob
#                                     pattern
#                                     for
#                                     finding
#                                     .richmediarc
#                                     config
#                                     files
#                                     (default
#                                     `./**/.
#                                     richmediarc*`)
#   -ss, --stats                   - show
#                                     webpack
#                                     stats
#                                     when
#                                     building
#   -c, --choices <data>           - base64-
#                                     encoded
#                                     JSON of
#                                     predetermined
#                                     interactive
#                                     CLI
#                                     prompt
#                                     selections
#                                     (for CI
#                                     automation)
#   -m, --mode <mode>              - webpack
#                                     mode
#                                     (development
#                                     or
#                                     production;
#                                     default
#                                     development)
#   -o, --outputDir <dir>          - output
#                                     directory
#                                     for
#                                     compiled
#                                     ads
#                                     (default
#                                     ./build)
#       --skipBuild                - skip the
#                                     compilation
#                                     phase
#                                     (preview-
#                                     only mode)
#       --skipPreview              - skip the
#                                     preview
#                                     phase
#                                     (build-
#                                     only mode)
#   -p, --parallel [count]         - run webpack
#                                     in parallel
#                                     workers
#                                     (count
#                                     optional;
#                                     defaults
#                                     to all
#                                     CPU cores)
#   -h, --help                     - print help
#   -V, --version                  - print
#                                     version
#
# Example invocations:
#   dds
#     # interactive preview server with auto-
#     # discovery of .richmediarc files
#
#   dds -m production -o ./dist \
#       --skipPreview
#     # CI build mode: production webpack +
#     # output to ./dist + no preview server
#
#   dds -g "./campaigns/2024-q4/**/.richmediarc" \
#       -p 8
#     # specific campaign + 8 parallel workers
#
#   dds -c "$(echo '{"build":true}' | base64)"
#     # pre-selected CLI choices for
#     # non-interactive CI mode
#
# Example .richmediarc:
#   {
#     "settings": {
#       "name": "summer-sale-2024",
#       "size": {"width": 728, "height": 90},
#       "fileName": "[name]_[width]x[height]",
#       "clickTag": "https://example.com",
#       "platform": "doubleclick"
#     },
#     "build": {
#       "scripts": ["src/main.ts"],
#       "assets": "src/assets",
#       "styles": "src/styles.css"
#     }
#   }
#
# The ajv lane is built on `ajv` (declared
# transitively + directly through the
# Display.Monks toolchain, imported in src/
# util/validateSchema.js for `.richmediarc`
# JSON Schema validation against the
# Display.Monks schema spec), the canonical
# Node JSON Schema validator by Evgeny
# Poberezkin - github.com/ajv-validator/ajv.
#
# Evgeny Poberezkin's ajv-validator/ajv is the
# de-facto canonical Node JSON Schema
# validator + the most-used JSON Schema
# validator in any language:
#   - 60,000,000+ weekly npm downloads (THE
#     highest-downloaded JSON Schema validator
#     in any ecosystem)
#   - JSON Schema Draft 4 + 6 + 7 + 2019-09 +
#     2020-12 support
#   - Compiles schemas to optimized JavaScript
#     code at validation time (the fastest
#     validator by orders of magnitude vs
#     interpreter-based validators)
#   - Strict mode + lenient mode
#   - Custom keyword + format extension
#     support
#   - Async validation (for $ref to remote
#     schemas)
#   - 30,000+ npm packages depend on ajv
#   - Used by ESLint (rule schema validation) +
#     webpack (loader/plugin schema validation) +
#     stripe-node + many AWS SDKs + every
#     OpenAPI validator + every Node JSON
#     Schema-based form generator
#
# ajv's distinguishing position vs Node JSON
# Schema alternatives:
#   - ajv-validator/ajv (Poberezkin): canonical;
#     fastest; most-used; THIS AXIS
#   - z-schema: older alternative; slower
#   - jsonschema-validator: simpler but slower
#   - tv4: deprecated; was popular pre-ajv
#
# ajv is *the* canonical Node JSON Schema
# validator by an overwhelming margin. It's
# also the fastest by significant margin -
# ajv's schema-to-code compilation strategy
# produces validators that run 10-100x faster
# than interpreter-based alternatives.
#
# Evgeny Poberezkin's broader Node ecosystem
# footprint (the ajv-validator/ org):
#   - ajv-validator/ajv (canonical Node JSON
#     Schema; THIS AXIS)
#   - ajv-validator/ajv-cli (canonical Node JSON
#     Schema validation CLI; the `ajv` binary
#     covered by another completion in this
#     corpus)
#   - ajv-validator/ajv-formats (canonical
#     format validators for ajv: date-time +
#     email + ipv4/ipv6 + uri + uuid + ...)
#   - ajv-validator/ajv-i18n (canonical
#     internationalization for ajv error
#     messages)
#   - ajv-validator/ajv-keywords (canonical
#     additional keywords for ajv)
#   - ajv-validator/ajv-async (async
#     compilation support)
#
# Poberezkin's role in the Node ecosystem is
# *the canonical JSON Schema validator
# author*. His ajv library is so dominant that
# alternative JSON Schema validators have
# essentially been displaced from the Node
# ecosystem.
#
# Poberezkin joins the parallel-individual-
# specialist canonicals cluster for JSON
# Schema validation:
#   - Rust: Dmitry Dygalo (Stranger6667/
#     jsonschema; Axis 277 Rust slot)
#   - Go: Santhosh Tekuri (santhosh-tekuri/
#     jsonschema; Axis 277 Go slot)
#   - Node: Evgeny Poberezkin (ajv-validator/
#     ajv; THIS AXIS)
#
# All three authors have a similar position in
# their respective ecosystems: single
# canonical author maintaining the JSON
# Schema validator with the broadest reverse-
# dep reach. The three lanes' canonicals are
# also functionally equivalent (all support
# Draft 4-2020-12 with similar APIs).
#
# Notable that ajv's 60M weekly downloads
# dwarf both jsonschema-rs (700+ reverse-deps)
# and santhosh-tekuri/jsonschema (1,500+
# reverse-deps) by orders of magnitude. This
# reflects Node's larger overall ecosystem
# size + ajv's specific dominance within Node
# (~every Node project that uses JSON Schema
# uses ajv directly or transitively).
#
# Multi-axis canonical-Node author/org cohort
# extension (now spanning 19 distinct
# individuals/orgs):
#   - + Evgeny Poberezkin / ajv-validator org
#     (ajv + ajv-cli + ajv-formats + ajv-i18n +
#     ajv-keywords + ajv-async; THIS AXIS)
#
# Poberezkin's position is unique because ajv
# is *the most-downloaded validation library in
# any language ecosystem*. Few canonical
# libraries achieve this level of dominance
# (chalk + lodash are higher-volume but for
# more general-purpose use; ajv is the highest
# for any specialized format/protocol library).
#
# display-dev-server uses ajv in src/util/
# validateSchema.js:
#   ```js
#   const Ajv = require('ajv');
#   const ajv = new Ajv({allErrors: true});
#
#   const schema = require('./richmediarc.
#       schema.json');
#   const validate = ajv.compile(schema);
#
#   function validateRichmediarc(config) {
#     const valid = validate(config);
#     if (!valid) {
#       throw new Error(
#         `Invalid .richmediarc: ${
#           ajv.errorsText(validate.errors)}`);
#     }
#     return true;
#   }
#   ```
# The compiled validator runs at build time +
# preview time, rejecting invalid configs
# before webpack starts compilation.
#
# ----------------------------------------------------------------------------
# AXIS 277 :: JSON Schema validation libraries
#              (JSON Schema Draft 4-2020-12
#              spec compliance + $ref resolution
#              + format validators + custom
#              keyword extensions)
# Round 1531 :: TS-Node slot 3 of 4 :: CLOSES Axis 277
#                                       (270th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : Stranger6667/jsonschema     [R1529 _spector]
#             (Dmitry Dygalo; cross-
#              language API testing +
#              validation)
#   Go      : santhosh-tekuri/jsonschema   [R1530 _csvlinter]
#             (Santhosh Tekuri; canonical
#              Go JSON Schema; multi-draft)
#   TS/Node : ajv-validator/ajv            [R1531 THIS FILE]
#             (Evgeny Poberezkin; canonical
#              Node JSON Schema; fastest +
#              most-used in any language;
#              60M+ weekly npm downloads)
#
# Notable: ajv closes Axis 277 with the
# *highest-volume validation library
# canonical* in any ecosystem. 60M weekly
# downloads is more than the *combined*
# reverse-dep count of Rust + Go JSON Schema
# validators by orders of magnitude.
#
# This reflects the *parallel-individual-
# specialist canonicals* pattern where each
# language has a single canonical author for
# JSON Schema validation, but the Node lane
# has dramatically broader reach due to:
#   1. Node's larger ecosystem size
#   2. ajv's specific dominance within Node
#      (~every Node project using JSON Schema
#      uses ajv directly or transitively)
#   3. webpack + ESLint + Stripe + AWS SDKs +
#      every OpenAPI validator + every Node
#      form generator all depending on ajv
#
# Use-case spectrum across the three lanes:
#   - spector (Rust, Stranger6667/jsonschema):
#     supply-chain attestation validation
#   - csvlinter (Go, santhosh-tekuri/
#     jsonschema): per-row CSV validation
#   - dds (Node, ajv): HTML5 ad config
#     (.richmediarc) validation in the
#     Display.Monks build pipeline
#
# Three lanes, three use-case shapes (supply-
# chain attestations / CSV data validation /
# HTML5 ad config validation), all converging
# on the *compile-once-validate-many* pattern
# with the same JSON Schema draft semantics.
#
# Axis 277 closes the round 1531 cycle - 270th
# axis closed total.
#
# Multi-axis canonical-Node author/org cohort
# extension (now spanning 19 distinct
# individuals/orgs):
#   - + Evgeny Poberezkin / ajv-validator org
#     (ajv + ajv-cli + ajv-formats + ajv-i18n +
#     ajv-keywords; THIS AXIS)
#
# 270 axes closed represents extensive
# coverage of cross-language canonical-library
# territory. The corpus has documented
# canonical authors + libraries across format
# parsing + compression + crypto + networking
# + protocols + visualization + storage + and
# now validation. The three-way Rust/Go/Node
# canonical pattern has held for all 270 axes,
# with each axis identifying a different
# canonical author per language ecosystem.
# ============================================================================

_dds() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-g --glob)'{-g,--glob}'[glob pattern for .richmediarc config files]:pattern:' \
        '(-ss --stats)'{-ss,--stats}'[show webpack stats when building]' \
        '(-c --choices)'{-c,--choices}'[base64-encoded JSON of CLI choices]:choices:' \
        '(-m --mode)'{-m,--mode}'[webpack mode]:mode:(development production)' \
        '(-o --outputDir)'{-o,--outputDir}'[output directory]:dir:_files -/' \
        '--skipBuild[skip compilation phase]' \
        '--skipPreview[skip preview phase]' \
        '(-p --parallel)'{-p,--parallel}'[run webpack in parallel workers]:count:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_dds "$@"
