#compdef govee
# Documentation: https://github.com/wez/govee2mqtt
# govee2mqtt: bridge Govee devices to Home Assistant over MQTT

local ret=1
local -a subcmds
subcmds=(
  'serve:run the bridge service'
  'list:list devices via the platform API'
  'list-http:list devices via the HTTP API'
  'http-control:control a device via the cloud HTTP API'
  'lan-control:control a device on the local network'
  'lan-disco:discover devices on the local network'
  'undoc:use the undocumented account API'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--api-key=[Govee platform API key]:key' \
  '--govee-email=[Govee account email]:email' \
  '--govee-password=[Govee account password]:password' \
  '--govee-iot-key=[path to store AWS IoT key]:file:_files' \
  '--govee-iot-cert=[path to store AWS IoT cert]:file:_files' \
  '--amazon-root-ca=[path to AWS root CA cert]:file:_files' \
  '--no-multicast[do not use the default multicast broadcast address]' \
  '--broadcast-all[broadcast to every interface broadcast address]' \
  '--global-broadcast[broadcast to 255.255.255.255]' \
  '*--scan=[address to scan for discovery]:address' \
  '--disco-timeout=[discovery wait time in seconds]:seconds' \
  '--mqtt-host=[MQTT broker host]:host:_hosts' \
  '--mqtt-port=[MQTT broker port]:port' \
  '--mqtt-username=[MQTT username]:username' \
  '--mqtt-password=[MQTT password]:password' \
  '--mqtt-bind-address=[local address to bind for MQTT]:address' \
  '--hass-discovery-prefix=[Home Assistant discovery topic prefix]:prefix' \
  '--temperature-scale=[temperature scale]:scale:(C F)' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'govee command' subcmds && ret=0 ;;
esac

return ret
