#compdef nvcc

# Zsh completion for nvcc - NVIDIA CUDA compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-V,--version}'[print version information]' \
  '(-o --output-file)'{-o,--output-file}'[specify output file name]:output file:_files' \
  '(-c --compile)'{-c,--compile}'[compile each input file into an object file]' \
  '(-E --preprocess)'{-E,--preprocess}'[preprocess input files]' \
  '(-M --generate-dependencies)'{-M,--generate-dependencies}'[generate dependency file]' \
  '(-ptx --ptx)'{-ptx,--ptx}'[compile to PTX]' \
  '(-cubin --cubin)'{-cubin,--cubin}'[compile to cubin]' \
  '(-fatbin --fatbin)'{-fatbin,--fatbin}'[compile to fatbin]' \
  '(-link --link)'{-link,--link}'[link object files]' \
  '(-lib --lib)'{-lib,--lib}'[generate a library]' \
  '(-run --run)'{-run,--run}'[compile and run]' \
  '(-shared --shared)'{-shared,--shared}'[generate a shared library]' \
  '--device-c[compile device code into device object file]' \
  '--device-w[compile device code into whole program]' \
  '--device-link[link device object files]' \
  '(-g --debug)'{-g,--debug}'[generate debug information for host code]' \
  '(-G --device-debug)'{-G,--device-debug}'[generate debug information for device code]' \
  '--generate-line-info[generate line-number information for device code]' \
  '(-O --optimize)'{-O,--optimize}'[specify optimization level]:level:(0 1 2 3)' \
  '--use_fast_math[make use of fast math library]' \
  '--ftz=[flush denormalized floats to zero]:enable:(true false)' \
  '--prec-div=[enable precise division]:enable:(true false)' \
  '--prec-sqrt=[enable precise square root]:enable:(true false)' \
  '--fmad=[enable fused multiply-add]:enable:(true false)' \
  '(-arch --gpu-architecture)'{-arch,--gpu-architecture}'[specify virtual GPU architecture]:arch:(compute_50 compute_52 compute_53 compute_60 compute_61 compute_62 compute_70 compute_72 compute_75 compute_80 compute_86 compute_87 compute_89 compute_90 sm_50 sm_52 sm_53 sm_60 sm_61 sm_62 sm_70 sm_72 sm_75 sm_80 sm_86 sm_87 sm_89 sm_90)' \
  '(-code --gpu-code)'{-code,--gpu-code}'[specify real GPU architecture]:code:(sm_50 sm_52 sm_53 sm_60 sm_61 sm_62 sm_70 sm_72 sm_75 sm_80 sm_86 sm_87 sm_89 sm_90)' \
  '(-gencode --generate-code)'{-gencode,--generate-code}'[generate code for specified architectures]:spec' \
  '(-t --threads)'{-t,--threads}'[specify number of threads]:threads' \
  '(-I --include-path)'{-I,--include-path}'[specify include search path]:path:_files -/' \
  '(-L --library-path)'{-L,--library-path}'[specify library search path]:path:_files -/' \
  '(-l --library)'{-l,--library}'[specify library to link]:library' \
  '(-D --define-macro)'{-D,--define-macro}'[define a macro]:macro' \
  '(-U --undefine-macro)'{-U,--undefine-macro}'[undefine a macro]:macro' \
  '--compiler-options=[extra options for host compiler]:options' \
  '--linker-options=[extra options for host linker]:options' \
  '--archive-options=[extra options for library manager]:options' \
  '--ptxas-options=[extra options for ptxas]:options' \
  '--maxrregcount=[maximum number of registers per thread]:count' \
  '(-std --std)'{-std,--std}'[select C/C++ dialect]:standard:(c++03 c++11 c++14 c++17 c++20)' \
  '--default-stream=[specify default CUDA stream]:stream:(legacy null per-thread)' \
  '--expt-relaxed-constexpr[allow constexpr in host code to call device code]' \
  '--expt-extended-lambda[allow host code to invoke device lambdas]' \
  '--extended-lambda[allow extended lambdas]' \
  '--allow-unsupported-compiler[allow unsupported host compiler]' \
  '--Werror=[treat warnings as errors]:kind:(all cross-execution-space-call deprecated-declarations reorder)' \
  '--diag-suppress=[suppress specified diagnostic]:diagnostic id' \
  '--diag-warn=[treat specified diagnostic as warning]:diagnostic id' \
  '--diag-error=[treat specified diagnostic as error]:diagnostic id' \
  '(-w --disable-warnings)'{-w,--disable-warnings}'[suppress all warnings]' \
  '--resource-usage[show resource usage during compilation]' \
  '(-v --verbose)'{-v,--verbose}'[print compilation commands]' \
  '(-dryrun --dryrun)'{-dryrun,--dryrun}'[dry run without executing]' \
  '(-keep --keep)'{-keep,--keep}'[keep all intermediate files]' \
  '(-keep-dir --keep-dir)'{-keep-dir,--keep-dir}'[keep intermediate files in specified directory]:directory:_files -/' \
  '(-clean-targets --clean-targets)'{-clean-targets,--clean-targets}'[clean target files]' \
  '--ccbin=[specify host compiler]:compiler:_files' \
  '--cudart=[specify CUDA runtime library]:runtime:(none shared static)' \
  '--relocatable-device-code=[enable relocatable device code]:enable:(true false)' \
  '-Xcompiler=[pass options to host compiler]:options' \
  '-Xlinker=[pass options to host linker]:options' \
  '-Xptxas=[pass options to ptxas]:options' \
  '-Xnvlink=[pass options to nvlink]:options' \
  '*:input file:_files -g "*.cu *.c *.cc *.cpp *.cxx *.o *.obj *.a *.lib *.ptx *.cubin *.fatbin"'
