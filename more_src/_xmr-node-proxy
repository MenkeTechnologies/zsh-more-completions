#compdef xmr-node-proxy
# _xmr-node-proxy — xmrpool Snipa xmr-node-proxy CLI for the Node.js Stratum-to-Stratum proxy for Monero family CryptoNight RandomX mining pools providing single-share upstream consolidation reducing pool load (xmrpool team, JavaScript); commander.js
# upstream: https://github.com/Snipa22/xmr-node-proxy

_xmr-node-proxy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.json config*.json"' \
        '--config=+[config file]:file:_files -g "*.json config*.json"' \
        '-l+[log dir]:dir:_files -/' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '-L+[log level]:l:(debug info warn error fatal trace)' \
        '--log-level=+[log level]:l:(debug info warn error fatal trace)' \
        '--upstream-pool=+[host:port]:str:' \
        '--upstream-user=+[user]:str:' \
        '--upstream-pass=+[password]:str:' \
        '--upstream-ssl[upstream SSL]' \
        '--listen-port=+[port]:n:' \
        '--listen-address=+[addr]:str:' \
        '--difficulty=+[N]:n:' \
        '--algo=+[a]:a:(cn cn/2 cn/1 cn-lite cn-heavy cn/r cn-pico cn/half cn/double cn/rwz cn/xao cn/wow cn/gpu cn-zls rx/0 rx/wow rx/loki rx/arq rx/xeq rx/sfx rx/keva)' \
        '--name=+[name]:str:' \
        '--workers=+[N]:n:' \
        '--nicehash[NiceHash mode]' \
        '--cluster[cluster mode]' \
        '--api-port=+[port]:n:' \
        '--enable-api[enable API]' \
        '--prometheus-port=+[port]:n:'
}

_xmr-node-proxy "$@"
