#compdef cluster_control
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/tools/cluster-control.html
# Wazuh cluster_control - inspect cluster nodes, agents and health

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-fn --filter-node)'{-fn,--filter-node}'[filter by node name]:node:' \
  '(-fs --filter-agent-status)'{-fs,--filter-agent-status}'[filter by agent status]:status:' \
  '(-a --list-agents)'{-a,--list-agents}'[list agents]' \
  '(-l --list-nodes)'{-l,--list-nodes}'[list nodes]' \
  '(-i --health)'{-i,--health}'[show cluster health]' \
  '(-u --usage)'{-u,--usage}'[show usage]' && ret=0

return ret
