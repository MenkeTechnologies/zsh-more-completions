#compdef kubectl-tunnel
# kubectl-tunnel (krew plugin): create network tunnels to Kubernetes clusters
# https://github.com/hcl-tech-software/kubectl-tunnel

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--local-port=[local port to bind]:port' \
  '--remote-port=[remote port to forward to]:port' \
  '--service=[target service name]:service' \
  '--pod=[target pod name]:pod' \
  '1:resource'
