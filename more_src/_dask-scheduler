#compdef dask-scheduler
# Documentation: https://docs.dask.org/en/stable/deploying-cli.html
# dask-scheduler - launch a Dask distributed scheduler process

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--host=[URI, IP or hostname of this server]:host' \
  '--port=[serving port]:port' \
  '--interface=[preferred network interface like eth0 or ib0]:interface' \
  '--protocol=[protocol like tcp, tls, or ucx]:protocol:(tcp tls ucx)' \
  '--tls-ca-file=[CA cert(s) file for TLS in PEM format]:file:_files' \
  '--tls-cert=[certificate file for TLS in PEM format]:file:_files' \
  '--tls-key=[private key file for TLS in PEM format]:file:_files' \
  '--dashboard-address=[address on which to listen for diagnostics dashboard]:address' \
  '--dashboard[launch the dashboard]' \
  '--no-dashboard[do not launch the dashboard]' \
  '--jupyter[start a Jupyter server in the same process]' \
  '--no-jupyter[do not start a Jupyter server]' \
  '--dashboard-prefix=[prefix for the dashboard app]:prefix' \
  '--pid-file=[file to write the process PID]:file:_files' \
  '--scheduler-file=[file to write connection information]:file:_files' \
  '--preload=[module that should be loaded by the scheduler process]:module' \
  '--idle-timeout=[time of inactivity after which to kill the scheduler]:timeout' \
  '*:arg:' && ret=0

return ret
