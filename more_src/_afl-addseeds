#compdef afl-addseeds
# Documentation: https://github.com/AFLplusplus/AFLplusplus/blob/stable/afl-addseeds
# AFL++ add new seeds to an existing AFL++ fuzzing campaign

local ret=1

_arguments -s -S \
  '-o[output directory of the running fuzzing campaign]:afl-out-dir:_files -/' \
  '-i[seed file or directory of files to add]:seed:_files' \
  '*:seed file or dir:_files' && ret=0

return ret
