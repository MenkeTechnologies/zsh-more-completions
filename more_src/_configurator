_configurator() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a base_flags
    base_flags=(
        '--url=[Saleor instance URL]:url:'
        '--token=[Saleor API token]:token:'
        '--config=[configuration file path (default config.yml)]:config:_files -g "*.yml *.yaml"'
        '--quiet[suppress output]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_configurator_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                start)
                    _arguments '*: :' && ret=0 ;;
                introspect|diff|validate|schema)
                    _arguments $base_flags && ret=0 ;;
                deploy)
                    _arguments \
                        $base_flags \
                        '--report-path=[write a structured deployment report]:path:_files' \
                        '--verbose[show detailed error information]' \
                        '--json[output deployment results in JSON format]' \
                        '--plan[show deployment plan without executing]' \
                        '--fail-on-delete[exit with error if deletions detected]' \
                        '--skip-media[skip media fields during deployment]' \
                        '--text[force human-readable output even in non-TTY mode]' && ret=0 ;;
                recipe)
                    _arguments \
                        '1:recipe subcommand:(list show apply export)' \
                        '*::arg:->recipe_args'
                    case $state in
                        recipe_args)
                            case $words[1] in
                                list)
                                    _arguments '*: :' && ret=0 ;;
                                show)
                                    _arguments '1:recipe name:' && ret=0 ;;
                                apply)
                                    _arguments \
                                        $base_flags \
                                        '1:recipe name:' && ret=0 ;;
                                export)
                                    _arguments \
                                        '1:recipe name:' \
                                        '2:output file path:_files' && ret=0 ;;
                            esac ;;
                    esac ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_configurator_commands] )) ||
_configurator_commands() {
    local -a commands
    commands=(
        'start:interactive first-time-setup wizard'
        'introspect:download the current configuration from the remote Saleor instance'
        'diff:show differences between local config.yml and remote'
        'deploy:deploy local config.yml to the remote Saleor instance'
        'validate:validate the local config file against the JSON schema'
        'schema:output the JSON Schema for config.yml'
        'recipe:manage recipes (pre-built configuration templates)'
    )
    _describe -t commands 'configurator command' commands
}

_configurator "$@"
