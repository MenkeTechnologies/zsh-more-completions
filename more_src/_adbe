#compdef adbe
# Documentation: https://man.archlinux.org/search?q=adbe
# Reference accessed: 2026-05-16

# adb-enhanced — docopt CLI with many subcommands; globals from usage header.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '*:adbe command and args:_default' && ret=0

return ret
