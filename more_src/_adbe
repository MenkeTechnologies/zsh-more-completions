#compdef adbe
# Documentation: https://github.com/ashishb/adb-enhanced
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# adb-enhanced — docopt CLI with many subcommands; globals from usage header.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '--version[show version]' \
  '-v[verbose]' \
  '*:adbe command and args:_default' && ret=0

return ret
