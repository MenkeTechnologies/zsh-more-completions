#compdef kedro

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '(-e --env)'{-e,--env}'[Kedro configuration environment]:environment' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'catalog:manage the data catalog'
      'ipython:open IPython session'
      'jupyter:manage Jupyter notebooks'
      'micropkg:manage micro-packages'
      'new:create a new Kedro project'
      'package:package the project'
      'pipeline:manage pipelines'
      'registry:manage the project registry'
      'run:run the project'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--from-nodes=[start from nodes]:nodes' \
          '--to-nodes=[stop at nodes]:nodes' \
          '--from-inputs=[start from inputs]:inputs' \
          '--to-outputs=[stop at outputs]:outputs' \
          '--node=[run specific nodes]:node' \
          '--runner=[runner to use]:runner' \
          '--async[run asynchronously]' \
          '--tag=[filter by tag]:tag' \
          '--load-version=[load specific version]:version' \
          '--pipeline=[run specific pipeline]:pipeline' \
          '--namespace=[run specific namespace]:namespace' \
          '--config=[path to config directory]:directory:_directories' \
          '--params=[set parameters]:params' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--name=[project name]:name' \
          '--tools=[tools to include]:tools' \
          '--example=[use example pipeline]:example:(y n)' \
          '--starter=[project starter]:starter' \
          '--checkout=[checkout tag/branch of starter]:ref' \
          '--directory=[directory within starter]:directory' \
          '--config=[config file]:config file:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      catalog)
        _arguments -s -S \
          '1:action:(create list rank resolve)' && ret=0
        ;;
      pipeline)
        _arguments -s -S \
          '1:action:(create delete describe list package pull)' && ret=0
        ;;
      jupyter)
        _arguments -s -S \
          '1:action:(lab notebook convert)' && ret=0
        ;;
    esac
    ;;
esac

return ret
