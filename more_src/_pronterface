#compdef pronterface
# Documentation: https://github.com/kliment/Printrun
# Printrun pronterface: GUI 3D printer host (inherits pronsole CLI flags)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-a --autoconnect)'{-a,--autoconnect}'[automatically connect to printer on startup]' \
  '*'{-c,--conf,--config}'=[load config file on startup instead of .pronsolerc]:config:_files' \
  '*'{-e,--execute}'=[execute command after config is loaded]:command:' \
  '*:gcode/stl file:_files -g "*.(gcode|gco|g|stl|STL)"' && ret=0

return ret
