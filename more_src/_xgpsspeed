#compdef xgpsspeed

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(--speedunits)--speedunits=+[speed units]:units:(mph kph knots)' \
  '(--maxspeed)--maxspeed=+[max speed]:n:' \
  '(--landspeed)--landspeed[land speedometer]' \
  '(--nautical)--nautical[nautical speedometer]' \
  '(--rotate)--rotate=+[rotation]:deg:' \
  '*:server:_hosts' && ret=0

return ret
