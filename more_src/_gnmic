#compdef gnmic

# Zsh completion for gnmic - gNMI CLI client

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'capabilities:query target gNMI capabilities'
  'get:run a gNMI Get request'
  'set:run a gNMI Set request'
  'subscribe:run a gNMI Subscribe request'
  'listen:start a gNMI server'
  'path:generate gnmi or xpath paths'
  'prompt:start gnmic interactive prompt'
  'generate:generate paths, set-request, or proto files'
  'diff:diff two gNMI targets'
  'version:show version'
  'help:show help for any command'
)

_arguments -s -S \
  '(-a --address)'{-a+,--address=}'[target gNMI address]:address:' \
  '(-u --username)'{-u+,--username=}'[username]:username:' \
  '(-p --password)'{-p+,--password=}'[password]:password:' \
  '--port=[default gRPC port]:port:' \
  '--encoding=[subscription encoding]:encoding:(json json_ietf bytes proto ascii)' \
  '--insecure[skip TLS verification]' \
  '--tls-ca=[TLS CA file]:ca file:_files' \
  '--tls-cert=[TLS certificate]:cert file:_files' \
  '--tls-key=[TLS key]:key file:_files' \
  '--skip-verify[skip TLS certificate verification]' \
  '--timeout=[gRPC timeout]:duration:' \
  '--debug[enable debug logging]' \
  '--log[enable logging]' \
  '--log-file=[log file path]:log file:_files' \
  '--config=[config file]:config file:_files -g "*.{yaml,yml,json,toml}"' \
  '--format=[output format]:format:(flat json event proto prototext)' \
  '--target=[target name]:target:' \
  '--gzip[enable gzip compression]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'gnmic command' commands && ret=0
    ;;
esac

return ret
