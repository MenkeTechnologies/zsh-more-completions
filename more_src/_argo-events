#compdef argo-events
# _argo-events — Argo Events CLI (argoproj/argo-events)
# upstream: https://github.com/argoproj/argo-events
# Subcommands from cmd/commands/root.go (cobra).

_argo-events() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'controller:run the Argo Events controller'
                'eventsource:run an EventSource pod'
                'sensor:run a Sensor pod'
                'webhook:run a webhook server'
                'lint:lint Argo Events manifests'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_argo-events "$@"
