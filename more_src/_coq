#compdef coqc

# Zsh completion for coqc - Coq proof assistant compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[print version]' \
  '(- *)--print-version[print version in machine-readable format]' \
  '(- *)-where[print standard library location]' \
  '(- *)-config[print configuration]' \
  '(- *)-list-tags[list available compilation tags]' \
  '-q[skip loading rcfile]' \
  '*-R[recursive loadpath mapping]: :_directories:logical directory name: ' \
  '*-Q[loadpath mapping]: :_directories:logical directory name: ' \
  '*-I[include path]: :_directories' \
  '-top[set logical name of the compilation unit]:logical name: ' \
  '-topfile[set the toplevel name based on filename]:file:_files -g "*.v"' \
  '-noinit[do not load the coqrc resource file]' \
  '-nois[do not load the initial state]' \
  '-w[configure warnings (+flag,-flag,all,none)]:warnings spec: ' \
  '*-set[set a Coq option]:option=value: ' \
  '*-unset[unset a Coq option]:option name: ' \
  '-boot[boot mode for building standard library]' \
  '-time[display compilation time per sentence]' \
  '-time-file[write timing info to file]:timing file:_files' \
  '-vos[fast compilation, skip opaque proofs]' \
  '-vok[verify .vos files are correct]' \
  '-o[set output file]:output file:_files' \
  '-verbose[verbose output]' \
  '-debug[enable debug mode]' \
  '-stm-debug[enable STM debug mode]' \
  '-batch[batch mode]' \
  '-native-compiler[control native compilation]:mode:(yes no ondemand)' \
  '-output-context[output the context at the end]' \
  '-schedule-vio-checking[schedule vio checking with N processes]:number of processes: ' \
  '-check-vio-tasks[check vio tasks in range]:range (from to): ' \
  '-vio2vo[convert .vio files to .vo]' \
  '-byte[use bytecode compiler]' \
  '-opt[use native compiler]' \
  '*:Coq source file:_files -g "*.v"'
