#compdef duff

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --all)'{-a,--all}'[include hidden files]' \
  '(-e --empty)'{-e,--empty}'[include zero-length files]' \
  '(-f --format)'{-f,--format}'=[output format string]:format' \
  '(-l --limit)'{-l,--limit}'=[minimum size limit]:size' \
  '(-L --limit-max)'{-L,--limit-max}'=[maximum size limit]:size' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-p --physical)'{-p,--physical}'[stay on same physical filesystem]' \
  '(-r --recurse)'{-r,--recurse}'[recurse into subdirectories]' \
  '(-0 --null)'{-0,--null}'[use null character as separator]' \
  '(-t --thorough)'{-t,--thorough}'[thorough byte-by-byte comparison]' \
  '(-z --zero-size)'{-z,--zero-size}'[include zero-length files]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:directory or file:_files' && ret=0

return ret
