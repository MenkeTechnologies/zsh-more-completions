#compdef suricatactl

# suricatactl: control utility for Suricata IDS
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'filestore:manage suricata filestore'
  'reload-rules:reload Suricata rules'
  'shutdown:shutdown Suricata'
  'unregister-tenant:unregister a tenant'
  'register-tenant:register a tenant'
  'iface-list:list interfaces'
  'iface-stat:interface stats'
  'capture-mode:show capture mode'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'suricatactl command' commands && ret=0 ;;
esac
return ret
