#compdef slpkg

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'update:update package list'
  'upgrade:upgrade installed packages'
  'repo-info:show repository info'
  'configs:edit slpkg configuration'
  'clean-tmp:clean temporary downloads'
  'clean-data:clean database'
  'build:build a SlackBuild'
  'install:install package(s)'
  'remove:remove package(s)'
  'download:download a package without installing'
  'find:find an installed package'
  'view:view package information'
  'search:search packages in repos'
  'dependees:show dependee packages'
  'tracking:track dependencies'
  'new-config:resolve .new config files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[answer yes to prompts]' \
  '(-J --jobs)'{-J,--jobs}'+[parallel jobs]:n:' \
  '(-c --check)'{-c,--check}'[check only - do not install]' \
  '(-O --no-color)'{-O,--no-color}'[disable colour]' \
  '(-R --repository)'{-R,--repository}'+[repository]:repo:' \
  '(-d --skip-installed)'{-d,--skip-installed}'[skip already installed]' \
  '(-r --resolve-off)'{-r,--resolve-off}'[do not resolve dependencies]' \
  '(-p --reinstall)'{-p,--reinstall}'[reinstall]' \
  '(-k --no-silent)'{-k,--no-silent}'[verbose mode]' \
  '(-w --pkg-version)'{-w,--pkg-version}'[show package version]' \
  '(-S --search)'{-S,--search}'[search packages]' \
  '(-D --directory)'{-D,--directory}'+[work directory]:dir:_files -/' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'slpkg command' commands && ret=0 ;;
esac

return ret
