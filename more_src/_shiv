#compdef shiv

# Zsh completion for shiv - create self-contained Python zipapps

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:output file:_files' \
  '--output-file=[output file]:output file:_files' \
  '-e+[entry point]:entry point' \
  '--entry-point=[entry point]:entry point' \
  '-c+[console script entry point]:console script' \
  '--console-script=[console script entry point]:console script' \
  '-p+[python interpreter]:python:_files' \
  '--python=[python interpreter]:python:_files' \
  '-r+[requirements file]:requirements:_files -g "*.txt"' \
  '--requirement=[requirements file]:requirements:_files -g "*.txt"' \
  '--site-packages[include system site-packages]' \
  '--compressed[compress the zipapp]' \
  '--compile-pyc[compile .py files to .pyc]' \
  '--no-compile-pyc[do not compile .py files]' \
  '--extend-pythonpath[extend PYTHONPATH]' \
  '--reproducible[make reproducible zipapps]' \
  '--no-modify[do not modify the shebang]' \
  '--preamble=[path to preamble script]:script:_files -g "*.py"' \
  '--build-id=[custom build ID]:id' \
  '--root=[pip install root]:directory:_directories' \
  '*:packages' && ret=0

return ret
