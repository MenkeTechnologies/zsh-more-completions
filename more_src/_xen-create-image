#compdef xen-create-image xen-delete-image xen-list-images xen-update-image

local curcontext="$curcontext" state line ret=1

case $service in
  (xen-create-image)
    _arguments -C \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '--manual[manual]' \
      '--hostname=[hostname]:h:_hosts' \
      '--ip=[IP]:ip:' \
      '--netmask=[netmask]:n:' \
      '--gateway=[gateway]:g:' \
      '--mac=[MAC]:mac:' \
      '--dhcp[use DHCP]' \
      '--vcpus=[vcpus]:n:' \
      '--memory=[memory]:m:' \
      '--maxmem=[max memory]:m:' \
      '--swap=[swap size]:s:' \
      '--size=[disk size]:s:' \
      '--fs=[filesystem]:fs:(ext4 ext3 ext2 xfs btrfs reiserfs)' \
      '--dist=[distribution]:d:(stretch buster bullseye bookworm trixie focal jammy noble)' \
      '--arch=[architecture]:a:(amd64 i386 arm64 armhf)' \
      '--lvm=[LVM VG]:vg:' \
      '--dir=[image dir]:dir:_files -/' \
      '--evms=[EVMS container]:c:' \
      '--config=[config file]:file:_files' \
      '--cache=[cache mode]:m:(yes no auto)' \
      '--cachedir=[cache dir]:dir:_files -/' \
      '--mirror=[debian mirror]:url:' \
      '--apt-proxy=[apt proxy]:url:' \
      '--password=[root password]:p:' \
      '--passwd=[prompt password]' \
      '--noswap[no swap]' \
      '--genpass=[gen password]:b:(0 1)' \
      '--initrd=[initrd]:file:_files' \
      '--kernel=[kernel]:file:_files' \
      '--modules=[modules dir]:dir:_files -/' \
      '--pygrub[use pygrub]' \
      '--pyrgrub[use pygrub]' \
      '--pkg=[extra package]:p:' \
      '--role=[role]:r:' \
      '--scsi[use SCSI]' \
      '--keyring=[keyring]:file:_files' \
      '--no-debootstrap[no debootstrap]' \
      '*: :' && ret=0 ;;
  (xen-delete-image)
    _arguments -C \
      '(- *)--help[show help]' \
      '--lvm=[LVM VG]:vg:' \
      '--dir=[image dir]:dir:_files -/' \
      '--evms=[EVMS]:c:' \
      '--hostname=[hostname]:h:' \
      '--test[test mode]' \
      '*: :' && ret=0 ;;
  (xen-list-images)
    _arguments -C \
      '(- *)--help[show help]' \
      '--lvm=[LVM VG]:vg:' \
      '--dir=[image dir]:dir:_files -/' \
      '--test[test mode]' \
      '*: :' && ret=0 ;;
  (xen-update-image)
    _arguments -C \
      '(- *)--help[show help]' \
      '--lvm=[LVM VG]:vg:' \
      '--dir=[image dir]:dir:_files -/' \
      '*: :' && ret=0 ;;
esac

return ret
