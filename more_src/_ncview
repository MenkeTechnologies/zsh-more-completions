#compdef ncview
# Documentation: https://github.com/iem-projects/ncview/blob/master/data/ncview.1
# Source: ncview man page — graphically display netCDF files under X windows.
# Reference accessed: 2026-06-20

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-beep[ring terminal bell at movie-loop restart]' \
    '-copying[print copying/distribution terms]' \
    '-frames[dump displayed frames as PPM files]' \
    '-warranty[print warranty disclaimer]' \
    '-private[force use of a private colormap]' \
    '-ncolors+[number of colors to display]:n:_default' \
    '-extrainfo[show extra info in the color-contour window]' \
    '-mtitle+[title for the color-contour window]:title:_default' \
    '-minmax+[min/max calculation method]:method:(fast med slow all)' \
    '-maxsize+[max window size as PCT or WIDTH,HEIGHT]:size:_default' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
