#compdef postfwd postfwd2 postfwd3
# Documentation: https://github.com/postfwd/postfwd
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# postfwd: Postfix firewall/policy daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --manual)'{-m,--manual}'[show manual]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f,--file=}'[ruleset configuration file]:file:_files' \
  '(-r --rule)'{-r,--rule=}'[inline rule]:rule:' \
  '(-s --scores)'{-s,--scores=}'[scoring rules]:rules:' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-k --kill)'{-k,--kill}'[terminate running daemon]' \
  '--reload[reload configuration]' \
  '--dumpstats[print runtime statistics]' \
  '--dumpcache[print contents of policy cache]' \
  '--delcache[delete contents of policy cache]' \
  '--delrate[delete contents of rate cache]' \
  '(-i --interface)'{-i,--interface=}'[listen interface]:host:' \
  '(-p --port)'{-p,--port=}'[listen port]:port:' \
  '--proto=[network protocol]:proto:(tcp inet inet6 unix)' \
  '(-u --user)'{-u,--user=}'[run as user]:user:_users' \
  '(-g --group)'{-g,--group=}'[run as group]:group:_groups' \
  '--umask=[file mode creation mask]:mask:' \
  '(-R --chroot)'{-R,--chroot=}'[chroot to directory]:dir:_files -/' \
  '--pidfile=[PID file]:file:_files' \
  '--facility=[syslog facility]:facility:(daemon mail local0 local1 local2 local3 local4 local5 local6 local7)' \
  '--socktype=[socket type]:type:(inet unix)' \
  '(-l --logname)'{-l,--logname=}'[syslog identity]:name:' \
  '--loglen=[max log message length]:n:' \
  '(-c --cache)'{-c,--cache=}'[cache lifetime seconds]:seconds:' \
  '--cache-no-size[do not include msg size in cache id]' \
  '--cache-no-sender[do not include sender in cache id]' \
  '--cache-rdomain-only[match only on recipient domain]' \
  '--cache-rbl-timeout=[RBL cache lifetime]:seconds:' \
  '--cache-rbl-default=[default RBL cache value]:val:' \
  '--cacheid=[cache id template]:template:' \
  '--cleanup-requests=[request cache cleanup interval]:n:' \
  '--cleanup-rbls=[RBL cache cleanup interval]:n:' \
  '--cleanup-rates=[rate cache cleanup interval]:n:' \
  '(-t --test)'{-t,--test}'[run a single test]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-S --summary)'{-S,--summary=}'[print summary every N seconds]:seconds:' \
  '--norulelog[disable per-rule logging]' \
  '--norulestats[disable per-rule statistics]' \
  '--noidlestats[disable idle statistics]' \
  '(-n --nodns)'{-n,--nodns}'[disable DNS lookups]' \
  '--nodnslog[disable DNS lookup logging]' \
  '--dns_async_txt[use async TXT lookups]' \
  '--dns_timeout=[DNS query timeout seconds]:seconds:' \
  '--dns_timeout_max=[max DNS timeout]:seconds:' \
  '--dns_timeout_interval=[retry interval]:seconds:' \
  '--dns_max_ns_lookups=[max NS lookups per query]:n:' \
  '--dns_max_mx_lookups=[max MX lookups per query]:n:' \
  '(-I --instantcfg)'{-I,--instantcfg}'[apply config changes immediately]' \
  '--config_timeout=[config file recheck interval]:seconds:' \
  '--keep_rates[preserve rate counters across reloads]' \
  '--save_rates=[save rates to file on exit]:file:_files' \
  '--fast_limit_evaluation[fast rate limit evaluation]' \
  '--plugins=[plugin directory]:dir:_files -/' \
  '(-C --showconfig)'{-C,--showconfig}'[print parsed configuration]' \
  '(-L --stdoutlog)'{-L,--stdoutlog}'[log to stdout instead of syslog]' \
  '(-P --perfmon)'{-P,--perfmon}'[performance monitoring]' && ret=0
return ret
