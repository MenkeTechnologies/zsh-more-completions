#compdef tif2mrc
# Documentation: https://bio3d.colorado.edu/imod/doc/man/tif2mrc.html
# Convert TIFF files into an MRC file

local ret=1

_arguments -s \
  '-g[This option will convert 24-bit color images to 8-bit g]' \
  '-G[This option will convert 24-bit color images to 8-bit g]' \
  '-u[With this option, the program will convert 16-bit numbe]' \
  '-d[With this option, the program will treat 16-bit numbers]' \
  '-s[With this option, the program will treat 16-bit numbers]' \
  '-k[With this option, the program will treat 16-bit numbers]' \
  '-B[overrides both the default behavior of writing signed b]' \
  '-i[Invert the order of sections in the output stack. Eithe]' \
  '-f[If only one input file is given and it is a multi-page ]' \
  '-o[This option has no effect for multi-page input files]' \
  '-F[data because an image is smaller than the output size. ]' \
  '-P[Set the pixel spacing in the header of the output file ]' \
  '-p[given value. This spacing is defined as having units of]' \
  '-b[This option loads a background file in TIFF format. If ]:file:_files' \
  '-T[When the input files are produced by TVIPS data acquisi]:file:_files' \
  '-m[Turn off file-to-memory mapping in the TIFF library. Th]' \
  '-t[Set the criterion for processing each file in chunks to]:value:' \
  '*:file:_files' && ret=0

return ret
