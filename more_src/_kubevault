#compdef kubevault
# Documentation: https://man.archlinux.org/search?q=kubevault
# Reference accessed: 2026-05-16
# Source: cargo binstall kubevault@1.1.0
# Probed via: completion zsh
# Repository: https://github.com/chezmoi-sh/kubevault

autoload -U is-at-least

_kubevault() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kubevault_commands" \
"*::: :->kubevault" \
&& ret=0
    case $state in
    (kubevault)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kubevault-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
'-n+[Namespace where the kvstore will be created]:NAMESPACE: ' \
'--namespace=[Namespace where the kvstore will be created]:NAMESPACE: ' \
'--output-dir=[Output directory where all manifests will be generated]:PATH:_files -/' \
'--vault-dir=[Path to the directory where the kubevault configuration is stored]:PATH:_files -/' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'::vault_dir -- Path to the directory where the kubevault configuration will be stored:_files -/' \
&& ret=0
;;
(can-read)
_arguments "${_arguments_options[@]}" : \
'--vault-dir=[Path to the directory where the kubevault configuration is stored]:PATH:_files -/' \
'--show-only-allowed[Only show secrets that the user is allowed to read]' \
'-h[Print help]' \
'--help[Print help]' \
':user -- The user to list the secrets for:' \
&& ret=0
;;
(external-secret-store)
_arguments "${_arguments_options[@]}" : \
'--vault-dir=[Path to the directory where the kubevault configuration is stored]:PATH:_files -/' \
'--vault-url=[URL of the kubevault'\''s Kubernetes API]:URL:_urls' \
'--context=[The name of Kubernetes context to use]:CONTEXT: ' \
'-n+[Namespace where the kvstore is installed]:NAMESPACE: ' \
'--namespace=[Namespace where the kvstore is installed]:NAMESPACE: ' \
'--clustered[Create a ClusterSecretStore instead of a SecretStore]' \
'-h[Print help]' \
'--help[Print help]' \
':user -- The name of the user to generate the manifests for:' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- The shell to generate the completion script for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_kubevault__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kubevault-help-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(new)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(can-read)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(external-secret-store)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_kubevault_commands] )) ||
_kubevault_commands() {
    local commands; commands=(
'generate:Generate all Kubernetes manifests' \
'new:Initialize the kubevault configuration' \
'can-read:List all accessible secrets for a given user' \
'external-secret-store:Generate Kubernetes manifests required to use an external-secret' \
'completion:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kubevault commands' commands "$@"
}
(( $+functions[_kubevault__can-read_commands] )) ||
_kubevault__can-read_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault can-read commands' commands "$@"
}
(( $+functions[_kubevault__completion_commands] )) ||
_kubevault__completion_commands() {
