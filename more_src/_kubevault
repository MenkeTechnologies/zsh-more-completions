    )
    _describe -t commands 'kubevault help commands' commands "$@"
}
(( $+functions[_kubevault__help__can-read_commands] )) ||
_kubevault__help__can-read_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help can-read commands' commands "$@"
}
(( $+functions[_kubevault__help__completion_commands] )) ||
_kubevault__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help completion commands' commands "$@"
}
(( $+functions[_kubevault__help__external-secret-store_commands] )) ||
_kubevault__help__external-secret-store_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help external-secret-store commands' commands "$@"
}
(( $+functions[_kubevault__help__generate_commands] )) ||
_kubevault__help__generate_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help generate commands' commands "$@"
}
(( $+functions[_kubevault__help__help_commands] )) ||
_kubevault__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help help commands' commands "$@"
}
(( $+functions[_kubevault__help__new_commands] )) ||
_kubevault__help__new_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault help new commands' commands "$@"
}
(( $+functions[_kubevault__new_commands] )) ||
_kubevault__new_commands() {
    local commands; commands=()
    _describe -t commands 'kubevault new commands' commands "$@"
}

if [ "$funcstack[1]" = "_kubevault" ]; then
    _kubevault "$@"
else
    compdef _kubevault kubevault
fi
