#compdef N3BiasFieldCorrection
# Documentation: https://github.com/ANTsX/ANTs/blob/master/Examples/N3BiasFieldCorrection.cxx
# ANTs N3 (nonparametric nonuniform intensity normalization) bias field correction

local ret=1

_arguments -s -S \
  '(-h)--help[print full help menu]' \
  '(--help)-h[print brief help menu]' \
  '--version[display version information]' \
  '(-d --image-dimensionality)'{-d,--image-dimensionality}'[image dimensionality (2/3/4)]:dim:(2 3 4)' \
  '(-i --input-image)'{-i,--input-image}'[input scalar image]:image:_files' \
  '(-x --mask-image)'{-x,--mask-image}'[mask constraining correction region]:mask:_files' \
  '(-r --rescale-intensities)'{-r,--rescale-intensities}'[rescale output intensity range]:flag:(0 1)' \
  '(-w --weight-image)'{-w,--weight-image}'[weight map for B-spline fitting]:image:_files' \
  '(-s --shrink-factor)'{-s,--shrink-factor}'[resampling shrink factor]:factor:(1 2 3 4)' \
  '(-c --convergence)'{-c,--convergence}'[convergence [iterations,threshold]]:conv:' \
  '(-b --bspline-fitting)'{-b,--bspline-fitting}'[B-spline mesh settings]:bspline:' \
  '(-t --histogram-sharpening)'{-t,--histogram-sharpening}'[deconvolution parameters]:params:' \
  '(-o --output)'{-o,--output}'[output corrected image]:output:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]:flag:(0 1)' \
  '*:arg:_files' && ret=0

return ret
