#compdef coverage2cytosine
# Documentation: https://github.com/FelixKrueger/Bismark/blob/master/coverage2cytosine
# coverage2cytosine: generate genome-wide cytosine methylation report from Bismark coverage

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--man[show full manual]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[name of the output file]:filename:' \
  '--dir[output directory for results]:dir:_files -/' \
  '(-g --genome_folder)'{-g+,--genome_folder=}'[path to genome folder with FastA files]:dir:_files -/' \
  '(--CX --CX_context)'{--CX,--CX_context}'[report every cytosine regardless of context]' \
  '--merge_CpG[pool top and bottom strand into single CpG entities]' \
  '--discordance=[max percent difference between strands when merging CpGs]:n:' \
  '(--gc --gc_context)'{--gc,--gc_context}'[generate additional GpC context report]' \
  '--nome-seq[process as NOMe-Seq data, filter to ACG/TCG contexts]' \
  '(--coverage_threshold --threshold)'{--coverage_threshold,--threshold}'=[min coverage to report a position]:n:' \
  '(--drach --m6A)'{--drach,--m6A}'[filter for DRACH motif to assess m6A methylation]' \
  '--ffs[extract four-, five-, and six-nucleotide contexts]' \
  '--zero_based[use 0-based coordinates instead of 1-based]' \
  '--split_by_chromosome[write a separate output file per chromosome]' \
  '--gzip[compress output with gzip]' \
  '*:coverage file:_files' && ret=0

return ret
