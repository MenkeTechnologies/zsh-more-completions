#compdef toywasm
# Documentation: https://github.com/yamt/toywasm
# toywasm: a WebAssembly interpreter written in C

local ret=1

_arguments -s -S \
  '--version[show version information]' \
  '--load=[load a module]:module:_files' \
  '--invoke=[invoke specific function with arguments]:function:' \
  '--wasi[enable WASI support]' \
  '*--wasi-dir=[map host directory to guest]:host_dir:_files -/' \
  '*--wasi-env=[set environment variable]:name=var:' \
  '--repl[interactive REPL mode]' \
  '--repl-prompt=[custom REPL prompt]:string:' \
  '--print-stats[display execution statistics]' \
  '--print-build-options[display build configuration]' \
  '--timeout=[execution timeout in milliseconds]:timeout_ms:' \
  '--max-memory=[memory usage limit in bytes]:bytes:' \
  '--max-stack-cells=[maximum stack cells]:cells:' \
  '--max-frames=[maximum stack frames]:frames:' \
  '--allow-unresolved-functions[allow unresolved functions]' \
  '--disable-jump-table[disable jump table optimization]' \
  '--disable-localtype-cellidx[disable local type cell indexing]' \
  '--disable-resulttype-cellidx[disable result type cell indexing]' \
  '--dyld[enable dynamic linking]' \
  '--dyld-bindnow[dynamic linking bind now]' \
  '--dyld-dlfcn[dynamic linking dlfcn support]' \
  '--dyld-path=[set library search directory]:library_dir:_files -/' \
  '--dyld-stack-size=[stack size for PIE modules]:bytes:' \
  '*:wasm module:_files' && ret=0

return ret
