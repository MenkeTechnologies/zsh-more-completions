#compdef is-fast
# ---------------------------------------------------------------------------
# is-fast — fast terminal-based content extractor for internet searches (Rust, 168★)
#
# upstream: https://github.com/Magic-JD/is-fast
# author : Joseph Daunt  (Magic-JD)
# license: MIT
#
# Source-direct completion: every flag and every ValueEnum below is verbatim
# from src/cli/command.rs on the is-fast tip — Cli, OpenArgs, SelectionArgs,
# CacheArgs, HistoryArgs, OutputArgs, TaskArgs, LogArgs structs + ColorMode,
# CacheMode, LogLevel value-enums.
#
# Direct deps from Cargo.toml (selected):
#   zstd          = "0.13.3"        ← canonical Rust zstd binding (this axis)
#   brotli        = "8.0.1"         (sibling compression)
#   clap          = "4.5.40"        (derive)
#   crossterm     = "0.29.0"
#   csv           = "1.3.1"
#   chrono        = "0.4.41"
#   globset       = "0.4.16"        (BurntSushi)
#   dashmap       = "7.0.0-rc2"
#   encoding_rs   = "0.8.35"        (Mozilla / hsivonen)
#   env_logger    = "0.11.8"
#
# === AXIS 156 OPENER — zstd / Zstandard compression ecosystem ===
# Axis position: Rust=211 OPENS Axis 156 at slot 1/0/0.  Canonical Rust
# zstd binding is `gyscos/zstd-rs` by Alexandre Bury (gyscos — also Cursive
# TUI) — a high-level wrapper around the official libzstd from Yann Collet
# (Facebook, 2016).  is-fast uses zstd for its compressed page cache that
# stores previously-rendered terminal-extracted webpages on disk for
# near-instant re-display via cache-mode read|write|read-write|flash.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=211   ← THIS FILE              (axis 156 OPENS, slot 1/0/0)
#   Go=211     ← next round              (axis 156 continues, slot 2/0/0)
#   TS-Node=211 ← round after            (axis 156 CLOSES at triple-211, slot 1/1/1)
# ---------------------------------------------------------------------------

_is-fast() {
    _arguments -s -S \
        '(-f --file)'{-f,--file=}'[path to the HTML file to render]:html file:_files -g "*.(html|htm|xhtml)"' \
        '(-u --url)'{-u,--url=}'[optional URL to associate with --file]:url:' \
        '*'{-d,--direct=}'[open the given URL(s) directly]:url:' \
        '--last[show last viewed page]' \
        '--site=[show results only from a specific site]:site:' \
        \
        '(-s --selector)'{-s,--selector=}'[use the given CSS selector for this query]:css selector:' \
        '*--ignore=[ignore the given HTML element(s)]:element:' \
        '--no-block[do not put block elements on separate lines]' \
        '*--nth-element=[show only the Nth element matching the selector]:n:' \
        \
        '--cache[apply caching (shorthand for --cache-mode=read-write)]' \
        '--no-cache[disable caching (shorthand for --cache-mode=never)]' \
        '--cache-mode=[set cache mode]:mode:(never read write read-write flash)' \
        '--flash-cache[enable caching with extremely short TTL (shorthand for --cache-mode=flash)]' \
        \
        '--history[show previously viewed pages]' \
        '--no-history[disable history for this search]' \
        \
        '--piped[output the result to stdout]' \
        '--color=[set color mode]:mode:(tui always never)' \
        '*--pretty-print=[additional display config (wrap|margin|title)]:option:(wrap margin title)' \
        '*--style-element=[apply the given style to an element]:style spec:' \
        \
        '--generate-config[generate a default configuration file]' \
        '--clear-all[wipe all data (cache + history)]' \
        '--clear-history[wipe history]' \
        '--clear-cache[wipe the cache]' \
        \
        '--log[activate logging]' \
        '--log-level=[set log level]:level:(error warn info debug trace)' \
        \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '*::query (search terms extracted from web search):'
}

_is-fast "$@"
