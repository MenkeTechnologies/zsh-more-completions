#compdef bitcoin-qt
# _bitcoin-qt — Bitcoin Core bitcoin-qt GUI desktop client CLI launching the wallet network full node with optional Qt arguments for hot reset reindex chain rollback testnet signet regtest splashscreen prune (bitcoin team, C++/Qt); custom argparse
# upstream: https://github.com/bitcoin/bitcoin

_bitcoin-qt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-help-debug[show debug help]' \
        '--help-debug[show debug help]' \
        '-version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf bitcoin.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-printtoconsole[print to console]' \
        '-noprinttoconsole[no print to console]' \
        '-debug=+[category]:c:(net tor mempool http bench zmq walletdb rpc estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb i2p ipc all)' \
        '-debugexclude=+[csv]:str:' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-logips[log IPs]' \
        '-logtimestamps[log timestamps]' \
        '-logsourcelocations[log source locations]' \
        '-shrinkdebugfile[shrink debug file]' \
        '-testnet[use testnet]' \
        '-testnet4[use testnet4]' \
        '-signet[use signet]' \
        '-signetchallenge=+[hex]:str:' \
        '-signetseednode=+[host:port]:str:' \
        '-regtest[use regtest]' \
        '-chain=+[c]:c:(main test test4 signet regtest)' \
        '-rest[enable REST]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserialversion=+[N]:n:(0 1)' \
        '-rpcservertimeout=+[seconds]:n:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpcthreads=+[N]:n:' \
        '-rpcworkqueue=+[N]:n:' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-i2psam=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-maxuploadtarget=+[MiB]:n:' \
        '-mempoolfullrbf[full RBF]' \
        '-paytxfee=+[BTC/kB]:f:' \
        '-prune=+[MiB or 0]:n:' \
        '-reindex[reindex]' \
        '-reindex-chainstate[reindex chainstate]' \
        '-rescan[rescan]' \
        '-wallet=+[name]:str:' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubsequence=+[address]:str:' \
        '-lang=+[locale]:str:' \
        '-min[start minimized]' \
        '-resetguisettings[reset GUI settings]' \
        '-rootcertificates=+[file]:file:_files -g "*.pem *.crt"' \
        '-splash[show splash]' \
        '-style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '-uiplatform=+[platform]:p:(xcb wayland cocoa windows direct2d)'
}

_bitcoin-qt "$@"
