#compdef rosetta_scripts rosetta_scripts.default.linuxgccrelease rosetta_scripts.default.macosclangrelease
# Documentation: https://man.archlinux.org/search?q=rosetta_scripts
# Reference accessed: 2026-05-16

# Rosetta scripts: XML-driven Rosetta protocol engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-database[Rosetta database location]:dir:_files -/' \
  '-parser:protocol[XML protocol file]:file:_files -g "*.xml"' \
  '-parser:script_vars[script variables (key=val)]:vars:' \
  '-parser:view[interactive viewer]' \
  '-in:file:s[input PDB(s)]:file:_files -g "*.pdb"' \
  '-in:file:l[list of input PDBs]:file:_files' \
  '-in:file:silent[input silent file]:file:_files' \
  '-in:file:silent_struct_type[silent struct type]:type:' \
  '-in:file:tags[only process these tags]:tags:' \
  '-out:prefix[output file prefix]:prefix:' \
  '-out:suffix[output file suffix]:suffix:' \
  '-out:path:pdb[output PDB directory]:dir:_files -/' \
  '-out:file:silent[output silent file]:file:_files' \
  '-out:file:scorefile[score file]:file:_files' \
  '-out:nstruct[number of structures]:n:' \
  '-overwrite[allow overwrite of output files]' \
  '-nstruct[number of structures]:n:' \
  '-mute[mute log channels]:channels:' \
  '-unmute[unmute log channels]:channels:' \
  '-out:level[log verbosity]:level:(0 100 200 300 400 500)' \
  '-out:user_tag[user-defined tag]:tag:' \
  '-restore_pre_talaris_2013_behavior[use pre-2013 score function]' \
  '*::Rosetta options:_files' && ret=0
return ret
