#compdef neroAacEnc
# Documentation: https://wiki.hydrogenaudio.org/index.php?title=Nero_AAC
# Reference accessed: 2026-05-16
# Verified: Hydrogenaudio wiki Nero AAC reference. Proprietary binary,
# last release 2010, archived.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# neroAacEnc: Nero AAC encoder (proprietary, archived 2010)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-if[WAV input file (- for stdin)]:file:_files' \
  '-of[MP4 output file]:file:_files' \
  '(-cbr -2pass -q)-br[ABR target bitrate bps]:bps:' \
  '(-br -2pass -q)-cbr[CBR bitrate bps]:bps:' \
  '(-br -cbr -q)-2pass[two-pass encoding]' \
  '-2passperiod[bitrate averaging period in ms]:ms' \
  '(-br -cbr -2pass)-q[VBR quality 0.0-1.0]:quality:' \
  '-lc[force LC profile]' \
  '-he[force HE-AAC profile]' \
  '-hev2[force HE-AACv2 profile]' \
  '-ignorelength[ignore WAV length header]' && ret=0
return ret
