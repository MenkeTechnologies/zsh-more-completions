#compdef oso
# Documentation: https://man.archlinux.org/search?q=oso
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'authorize:check whether a principal can perform an action'
  'list:list actions a principal can perform'
  'list-resources:list resources a principal can act on'
  'tell:write a fact'
  'bulk-tell:write many facts'
  'delete:delete a fact'
  'bulk-delete:delete many facts'
  'get:get facts matching a predicate/arguments'
  'policy:upload (or preview) a Polar policy'
  'test:run policy tests'
  'reconcile:reconcile facts using Oso Sync'
  'validate:validate Polar syntax'
  'validate-local-authorization-config:validate Local Authorization YAML'
  'data-bindings:configure local data bindings'
  'login:authenticate to Oso Cloud'
  'logout:clear stored credentials'
  'whoami:show current identity'
  'profile:manage local profiles'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[Oso Cloud API key]:key:' \
  '--url=[Oso Cloud API URL]:url:' \
  '--profile=[CLI profile]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'oso command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (authorize|list|list-resources|get)
        _arguments \
          '(-c --context-facts)*'{-c+,--context-facts=}'[context fact]:fact:' \
          '*::actor_action_resource:' && ret=0 ;;
      (policy)
        _arguments \
          '--preview[preview without submitting]' \
          '*::polar_file:_files -g "*.polar"' && ret=0 ;;
      (test)
        _arguments \
          '*::test_file:_files -g "*.polar"' && ret=0 ;;
      (reconcile)
        _arguments \
          '--perform-updates[apply diff to Oso Cloud]' \
          '--timeout=[per-iteration timeout (s)]:n:' \
          '--summarized-output[summary counts only]' \
          '*::config:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (validate)
        _arguments '*::polar_file:_files -g "*.polar"' && ret=0 ;;
      (validate-local-authorization-config)
        _arguments '*::yaml_file:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (tell|bulk-tell|delete|bulk-delete)
        _arguments '*::fact:' && ret=0 ;;
      (profile)
        _arguments '*::sub:(create list use show delete)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
