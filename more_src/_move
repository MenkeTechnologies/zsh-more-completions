#compdef move move-cli aptos-move
# _move — Aptos Foundation Move CLI for the Move resource-oriented smart contract language Diem/Aptos/Sui fork (move-language team, Rust); clap-derive
# upstream: https://github.com/move-language/move

_move() {
    local -a sub=(
        'new:create a new Move package'
        'build:build a package'
        'check:type-check a package'
        'test:run unit tests'
        'coverage:show test coverage'
        'docgen:generate docs'
        'disassemble:disassemble bytecode'
        'errmap:generate error map'
        'experimental:experimental subcommands'
        'info:show package info'
        'manifest:print manifest'
        'prove:run move-prover'
        'sandbox:sandbox subcommands'
        'package:package subcommands'
        'lint:run move-lint'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--path=+[package dir]:dir:_files -/' \
        '-p+[package dir]:dir:_files -/' \
        '--abi[generate abi]' \
        '--bytecode-version=+[version]:n:' \
        '--compiler-version=+[version]:str:' \
        '--language-version=+[version]:str:' \
        '--dev[dev mode]' \
        '-d[dev mode]' \
        '--doc[generate docs]' \
        '--force[force]' \
        '--test[include test code]' \
        '--check-test-code[check test code]' \
        '--install-dir=+[dir]:dir:_files -/' \
        '--override-std=+[std]:s:(mainnet testnet devnet)' \
        '--named-addresses=+[addresses]:str:' \
        '--skip-fetch-latest-git-deps[skip git fetch]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'move subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '--filter=+[filter]:str:' \
                    '-f+[filter]:str:' \
                    '--list[list tests only]' \
                    '-l[list tests only]' \
                    '--gas-limit=+[gas]:n:' \
                    '--stackless-bytecode-interpreter[use bytecode interpreter]' \
                    '--coverage[run with coverage]' \
                    '--check-stackless-vm[check stackless vm]' \
                    '-t+[threads]:n:' \
                    '--threads=+[threads]:n:' \
                    '*:test pattern:' ;;
                coverage) _arguments '1:coverage cmd:(summary source bytecode)' ;;
                experimental) _arguments '1:experimental cmd:(read-write-set inspect dump-graph print-package-version)' ;;
                sandbox) _arguments '1:sandbox cmd:(publish run view doctor link generate cleanup)' ;;
                package) _arguments '1:package cmd:(info manifest summary)' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_move "$@"
