#compdef eck-diagnostics
# Documentation: https://github.com/elastic/eck-diagnostics/blob/main/README.md
# Diagnostic tooling for Elastic Cloud on Kubernetes (ECK) installations

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for eck-diagnostics]' \
  '(-v --version)'{-v,--version}'[version for eck-diagnostics]' \
  '(-r --resources-namespaces)'{-r,--resources-namespaces}'=[comma-separated namespaces in which resources are managed]:namespaces:' \
  '(-o --operator-namespaces)'{-o,--operator-namespaces}'=[comma-separated namespaces in which operators are running]:namespaces:' \
  '(-f --filters)'{-f,--filters}'=[comma-separated list of filters in format type=name]:filters:' \
  '(-l --log-selectors)'{-l,--log-selectors}'=[label selectors to restrict logs collected]:selectors:' \
  '(-n --output-name)'{-n,--output-name}'=[name of the output diagnostics file]:name:' \
  '--output-directory=[path where to output diagnostic results]:dir:_files -/' \
  '--kubeconfig=[optional path to kube config]:path:_files' \
  '--eck-version=[ECK version in use, autodetected if not specified]:version:' \
  '--diagnostic-image=[diagnostic image for stack diagnostics]:image:' \
  '--run-stack-diagnostics[run diagnostics on deployed Elasticsearch and Kibana]' \
  '--stack-diagnostics-timeout=[maximum time to wait for diagnostics completion]:timeout:' \
  '--run-agent-diagnostics[run diagnostics on deployed Elastic Agents]' \
  '--image-pull-secrets=[comma-separated Kubernetes secret names for diagnostic Pods]:secrets:' \
  '--verbose[verbose mode]' && ret=0

return ret
