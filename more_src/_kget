#compdef kget
# Documentation: https://github.com/KDE/kget/blob/master/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# (KDE kget main.cpp: showDropTarget/hideMainWindow/startWithoutAnimation
# options plus URL positional args, confirmed against source.)

# kget: KDE download manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--showDropTarget[start with drop target]' \
  '--hideMainWindow[start with hidden main window]' \
  '--startWithoutAnimation[start without drop-target animation]' \
  '*:URL:_urls' && ret=0
return ret
