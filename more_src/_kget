#compdef kget
# Documentation: https://github.com/KDE/kget/blob/master/main.cpp
# Reference accessed: 2026-05-16
# Verified: upstream KDE kget main.cpp.
# Removed from prior file: bogus man.archlinux.org search URL.

# kget: KDE download manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--showDropTarget[start with drop target]' \
  '--hideMainWindow[start with hidden main window]' \
  '--startWithoutAnimation[start without drop-target animation]' \
  '*:URL:_urls' && ret=0
return ret
