#compdef suop2
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/operations/suop2.c
# do a binary operation on two data sets

local ret=1

_arguments -s -S \
  'op=[binary operation]:op:(diff sum prod quo ptdiff ptsum ptprod ptquo zipper zippol)' \
  'trid=[output trace id code (op=zipper)]:trid' \
  'w1=[weight for the first dataset]:w1' \
  'w2=[weight for the second dataset]:w2' \
  '*:file:_files' && ret=0


return ret
