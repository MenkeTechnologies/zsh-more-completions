#compdef alacritty-theme
# Documentation: https://man.archlinux.org/search?q=alacritty-theme
# Reference accessed: 2026-05-16

# Zsh completion for alacritty-theme (davidarmstronglewis/alacritty-theme, structopt).

local -a sub
sub=(
  'list:print all available themes'
  'current:print the active theme name'
  'change:switch to a theme'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :{_describe '\''command'\'' sub}' \
  '*:: :->rest'

[[ $state == rest ]] || return 0

case $line[1] in
  list|current)
    _arguments '(-c --config-file)'{-c,--config-file=}'[alacritty.yml path]:file:_files'
    ;;
  change)
    _arguments \
      '(-c --config-file)'{-c,--config-file=}'[alacritty.yml path]:file:_files' \
      '2:theme name:'
    ;;
esac
