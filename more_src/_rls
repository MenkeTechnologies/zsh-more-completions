#compdef rls
# Documentation: https://man.archlinux.org/search?q=rls
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_rustup] )) || autoload -Uz _rustup 2>/dev/null
if (( $+functions[_rustup] )); then
  _rustup "$@"
  return
fi

_arguments \
  '*::arg:_files' && ret=0

return ret
