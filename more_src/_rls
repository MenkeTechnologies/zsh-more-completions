#compdef rls
# Documentation: https://github.com/rust-lang/rls
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: rls is the Rust Language Server (deprecated upstream in favor of
# rust-analyzer). Invoked via `rustup component`; no documented CLI args
# beyond rustup-managed flags. Minimal stub falls through to _rustup.

local curcontext="$curcontext" state line ret=1

(( $+functions[_rustup] )) || autoload -Uz _rustup 2>/dev/null
if (( $+functions[_rustup] )); then
  _rustup "$@"
  return
fi

_arguments \
  '*::arg:_files' && ret=0

return ret
