#compdef CollectF1R2Counts
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/readorientation/CollectF1R2Counts.java
# Collect F1R2 read counts for the Mutect2 orientation bias mixture model filter

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--output -O)'{--output,-O}'[Output .tar.gz file]:value:_files' \
  '*:argument:_files' && ret=0

return ret
