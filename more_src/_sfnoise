#compdef sfnoise
# Documentation: https://github.com/ahay/src/blob/master/system/generic/Mnoise.c
# Madagascar: add random noise to data

local ret=1

_arguments -s -S \
  'seed=[random seed]:seed' \
  'type=[y for normal distribution, n for uniform]:type:(y n)' \
  'var=[noise variance]:var' \
  'range=[noise range]:range' \
  'mean=[noise mean]:mean' \
  'rep=[y - replace data with noise instead of adding]:rep:(y n)' \
  '*:RSF file:_files' && ret=0

return ret
