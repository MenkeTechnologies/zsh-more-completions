#compdef pueue
# Documentation: https://github.com/Nukesor/pueue
# Reference accessed: 2026-05-20
# Verified: upstream pueue/src/client/cli.rs clap definitions.

# pueue: task queue manager (client)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:enqueue a task for execution'
  'remove:remove tasks from the list'
  'rm:alias for remove'
  'switch:switch the position of two tasks'
  'stash:stash a task (prevent it from being started)'
  'enqueue:enqueue a stashed task'
  'start:resume operation on paused tasks'
  'restart:restart failed or successful tasks'
  're:alias for restart'
  'pause:pause running tasks or groups'
  'kill:kill running tasks or whole groups'
  'send:send something to a task stdin'
  'edit:edit the command or path of a stashed or queued task'
  'env:manage environment variables for a task'
  'group:manage groups'
  'status:display the current status of all tasks'
  'log:display the log output of finished tasks'
  'follow:follow the output of a running task'
  'fo:alias for follow'
  'wait:wait until tasks are finished'
  'clean:remove finished tasks from the list'
  'cleanup:alias for clean'
  'clear:alias for clean'
  'reset:reset everything back to a clean state'
  'shutdown:shut down the daemon'
  'parallel:set the amount of allowed parallel tasks'
  'completions:generate shell completion files'
)

_arguments -s -S \
  '(-v --verbose)*'{-v,--verbose}'[verbose mode (repeatable)]' \
  '--color=[colorize output]:when:(auto never always)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-p --profile)'{-p+,--profile=}'[profile to load]:profile:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pueue command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (add)
        _arguments \
          '(-w --working-directory)'{-w+,--working-directory=}'[working directory]:dir:_directories' \
          '(-e --escape)'{-e,--escape}'[escape special shell characters]' \
          '(--immediate)--immediate[start the task immediately]' \
          '--follow[follow output after immediate start]' \
          '(-s --stashed)'{-s,--stashed}'[create in stashed state]' \
          '(-d --delay)'{-d+,--delay=}'[delay until]:delay:' \
          '(-g --group)'{-g+,--group=}'[assign to group]:group:' \
          '(-a --after)'{-a+,--after=}'[start after task IDs]:task IDs:' \
          '(-o --priority)'{-o+,--priority=}'[task priority]:priority:' \
          '(-l --label)'{-l+,--label=}'[label for the task]:label:' \
          '(-p --print-task-id)'{-p,--print-task-id}'[only print the task ID]' \
          '*:command:' && ret=0
        ;;
      (remove|rm)
        _arguments '*:task ID:' && ret=0
        ;;
      (switch)
        _arguments '1:task ID 1:' '2:task ID 2:' && ret=0
        ;;
      (stash|enqueue)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '(-a --all)'{-a,--all}'[target all tasks]' \
          '(-d --delay)'{-d+,--delay=}'[delay until]:delay:' \
          '*:task ID:' && ret=0
        ;;
      (start)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '(-a --all)'{-a,--all}'[target all tasks]' \
          '*:task ID:' && ret=0
        ;;
      (restart|re)
        _arguments \
          '--all-failed[restart all failed tasks]' \
          '(-g --failed-in-group)'{-g+,--failed-in-group=}'[restart failed tasks in group]:group:' \
          '(-k --immediate)'{-k,--immediate}'[start the task immediately]' \
          '(-s --stashed)'{-s,--stashed}'[restart in stashed state]' \
          '(-i --in-place)'{-i,--in-place}'[edit in-place]' \
          '--not-in-place[do not edit in-place]' \
          '(-e --edit)'{-e,--edit}'[edit before restart]' \
          '*:task ID:' && ret=0
        ;;
      (pause)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '(-a --all)'{-a,--all}'[pause all]' \
          '(-w --wait)'{-w,--wait}'[wait for running tasks before pausing]' \
          '*:task ID:' && ret=0
        ;;
      (kill)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '(-a --all)'{-a,--all}'[kill all]' \
          '(-s --signal)'{-s+,--signal=}'[signal to send]:signal:' \
          '*:task ID:' && ret=0
        ;;
      (send)
        _arguments '1:task ID:' '2:input:' && ret=0
        ;;
      (edit)
        _arguments '*:task ID:' && ret=0
        ;;
      (env)
        _arguments '1:env command:(set unset)' '*::env arg:' && ret=0
        ;;
      (log)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '(-a --all)'{-a,--all}'[show all]' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-l --lines)'{-l+,--lines=}'[number of lines]:lines:' \
          '(-f --full)'{-f,--full}'[full log output]' \
          '*:task ID:' && ret=0
        ;;
      (follow|fo)
        _arguments \
          '(-l --lines)'{-l+,--lines=}'[number of lines to show]:lines:' \
          '1:task ID:' && ret=0
        ;;
      (clean|cleanup|clear)
        _arguments \
          '(-s --successful-only)'{-s,--successful-only}'[only clean successful tasks]' \
          '(-g --group)'{-g+,--group=}'[clean specific group]:group:' && ret=0
        ;;
      (group)
        _arguments \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '1:group command:(add remove)' \
          '*::group arg:' && ret=0
        ;;
      (parallel)
        _arguments \
          '(-g --group)'{-g+,--group=}'[target group]:group:' \
          '1:parallel tasks:' && ret=0
        ;;
      (wait)
        _arguments \
          '(-g --group)'{-g+,--group=}'[wait for group]:group:' \
          '(-a --all)'{-a,--all}'[wait for all tasks]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '--status=[wait for status]:status:' \
          '*:task ID:' && ret=0
        ;;
      (status)
        _arguments \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '(-g --group)'{-g+,--group=}'[show specific group]:group:' \
          '*:query:' && ret=0
        ;;
      (reset)
        _arguments \
          '(-g --groups)'{-g+,--groups=}'[reset specific groups]:group:' \
          '(-f --force)'{-f,--force}'[force reset without prompt]' && ret=0
        ;;
      (completions)
        _arguments '1:shell:(bash zsh fish elvish powershell nushell)' '2:output directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
