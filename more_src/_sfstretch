#compdef sfstretch
# Documentation: https://www.reproducibility.org/wiki/Guide_to_madagascar_programs
# Madagascar: stretch of the time axis

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'rule=[stretch rule (n2t/lmo/nmo/chebyshev/log/...)]:rule:' \
  'inv=[apply inverse stretch (y/n)]:inv:(y n)' \
  'v0=[velocity]:v0:' \
  'half=[half-offset coordinate (y/n)]:half:(y n)' \
  'CDPtype=[CDP type]:CDPtype:' \
  'mute=[mute zone]:mute:' \
  'maxstr=[maximum stretch]:maxstr:' \
  'nout=[output length]:nout:' \
  'dens=[axis stretching density]:dens:' \
  'extend=[extension]:extend:' \
  'scale=[scaling]:scale:' \
  'delay=[time delay]:delay:' \
  'tdelay=[time delay]:tdelay:' \
  'hdelay=[half delay]:hdelay:' \
  'verb=[verbosity (y/n)]:verb:(y n)' \
  '*: :_files' && ret=0

return ret
