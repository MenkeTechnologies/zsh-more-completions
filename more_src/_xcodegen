#compdef xcodegen

# Zsh completion for xcodegen - generate Xcode projects from YAML specs

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate Xcode project from spec'
  'cache:generate cache for spec'
  'dump:dump resolved spec to stdout or file'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-v --version)'{-v,--version}'[show xcodegen version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress logs]' \
  '--no-env[do not expand environment variables in spec]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xcodegen command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '(-s --spec)'{-s,--spec}'[spec file path]:file:_files -g "*.(yml|yaml|json)"' \
          '(-p --project)'{-p,--project}'[output directory for project]:directory:_files -/' \
          '(-r --project-root)'{-r,--project-root}'[project root path]:directory:_files -/' \
          '(-c --use-cache)'{-c,--use-cache}'[use cached spec, skip generation if unchanged]' \
          '--cache-path[path to load/save cache]:file:_files' \
          '--only-plists[only generate plist files]' \
          '(-q --quiet)'{-q,--quiet}'[suppress log output]' \
          '--no-env[do not expand environment variables]' && ret=0
        ;;
      (cache)
        _arguments \
          '(-s --spec)'{-s,--spec}'[spec file path]:file:_files -g "*.(yml|yaml|json)"' \
          '--cache-path[path to save cache]:file:_files' && ret=0
        ;;
      (dump)
        _arguments \
          '(-s --spec)'{-s,--spec}'[spec file path]:file:_files -g "*.(yml|yaml|json)"' \
          '--type[dump format]:format:(yaml json)' \
          '--file[file to write to]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
