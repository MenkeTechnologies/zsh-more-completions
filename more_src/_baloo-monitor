#compdef baloo-monitor baloo_monitor
# _baloo-monitor — KDE baloo-monitor CLI live-monitoring of the Baloo file index daemon DBus signals printing per-file indexing progress current file mime database size files-pending current-state remaining duration estimate for the KDE Plasma file search backend (KDE team, C++); custom argparse
# upstream: https://invent.kde.org/system/baloo-widgets

_baloo-monitor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w[watch mode]' \
        '--watch[watch mode]' \
        '-o+[output format]:f:(text json)' \
        '--format=+[format]:f:(text json)' \
        '-q[quiet]' \
        '*:path:_files'
}

_baloo-monitor "$@"
