#compdef libfido2 fido2-tools

# libfido2 umbrella: fido2-cred, fido2-token, fido2-assert
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'fido2-cred:make/verify FIDO2 credentials'
  'fido2-token:manage FIDO2 token (PIN, reset, etc.)'
  'fido2-assert:make/verify FIDO2 assertions'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'libfido2 command' commands && ret=0 ;;
esac
return ret
