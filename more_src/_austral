#compdef austral
# =============================================================================
# austral — Fernando Borretti's Austral compiler — a systems
#           programming language with LINEAR TYPES + CAPABILITY-
#           BASED SECURITY as primary type-system features.  The
#           austral binary is the OCaml-based reference compiler
#           that parses .aui (interface) + .aum (module body)
#           files and emits either standalone C source or
#           directly-buildable native executables.
#           Distinguishing from every other documented language
#           by:
#             - LINEAR TYPES as the PRIMARY mechanism for memory
#               + resource safety — every Linear value must be
#               consumed exactly once (cf. Rust's affine ownership
#               which allows DROPS).  No garbage collector, no
#               reference counting, no unsafe blocks
#             - CAPABILITY-BASED SECURITY — system effects
#               (filesystem, network, environment vars) are
#               accessed only by holding a CAPABILITY value;
#               capabilities are themselves Linear types and
#               must be threaded explicitly through function
#               signatures.  No ambient authority
#             - .aui INTERFACE / .aum MODULE BODY SPLIT — every
#               module has TWO files: an interface (.aui) declaring
#               public types + function signatures, and a body
#               (.aum) containing implementations.  Like OCaml's
#               .mli/.ml split, but mandatory + with stronger
#               separation guarantees
#             - C-STANDALONE BACKEND via `--target-type=c`:
#               Austral emits PORTABLE C99 source that can be
#               compiled by any C compiler; no LLVM dependency
#             - DIRECT EXECUTABLE BACKEND via `--target-type=exe`:
#               Austral compiles + links + emits a native binary
#               in one step (uses cc under the hood)
#             - TYPE-CHECK-ONLY MODE via `--target-type=tc`:
#               run the type checker without producing any output
#               (for editor integration / CI gates)
#             - JSON ERROR FORMAT via `--error-format=json`:
#               structured error output for editor / language-
#               server integration; alternative `plain` is human-
#               readable text
#             - ENTRYPOINT FORMAT `Module:name` — pass the
#               application entry point as Module:identifier
#               (e.g. `MyApp:main`)
#             - INSPIRED BY BOTH RUST AND SML — linear types from
#               Wadler's 1990 paper "Linear Types Can Change The
#               World", module structure from SML/OCaml, syntax
#               loosely Rust-like
#           Used by: PL researchers + linear-types enthusiasts +
#           systems-programming theorists + developers who want
#           Rust-like safety with stronger capability discipline
#           than Rust's `unsafe` escape hatch.
#
# Author:  Fernando Borretti (eudoxia0 on GitHub) — Argentine
#           computer scientist + Common Lisp / OCaml veteran.
#           Austral released 2018; continuous development through
#           2026 with quarterly releases and an external
#           Rust-based implementation (LambdaClass/austral.rs)
#           starting 2024.
# Source:  https://github.com/austral/austral
#          https://github.com/austral/austral/blob/master/bin/austral.ml
#          https://github.com/austral/austral/blob/master/lib/CliParser.ml
#          https://austral-lang.org/spec/spec.html (language spec)
# CLI:     bin/austral.ml → lib/Cli.ml → lib/CliParser.ml — OCaml-
#          based hand-rolled subcommand parser.  Uses custom
#          arglist + pop_value_flag/pop_bool_flag helpers in
#          CliUtil.ml (NO external CLI framework — pure OCaml).
# Language: AUSTRAL
#           ("Austral" — Fernando Borretti — released 2018 as a
#            "Systems language with linear types and capability-
#            based security".  Distinct from every other
#            documented language by:
#              1. LINEAR (not affine) types — every Linear value
#                 must be USED EXACTLY ONCE.  Cannot be dropped
#                 silently like Rust's affine values; cannot be
#                 used more than once like normal values.  Linear
#                 ensures resources are always released exactly
#                 once + always passed to a recipient
#              2. CAPABILITY-BASED EFFECTS — Austral has NO
#                 ambient authority.  To open a file, the
#                 function must receive a FileSystem capability;
#                 to make a network call, a Network capability;
#                 to read env-vars, an Environment capability.
#                 The Root capability is the source of all
#                 capabilities; main() receives Root
#              3. .aui / .aum FILE SPLIT mandatory for all
#                 modules — interface in .aui, body in .aum,
#                 separately type-checked
#              4. NO PRIMITIVES BUT BOOLS — All other primitive
#                 types are defined in the standard library; the
#                 compiler only knows about Bool natively.
#                 Integers, floats, characters, arrays, etc. are
#                 all library types
#              5. NO INHERITANCE — uses typeclasses (called
#                 "instances") for ad-hoc polymorphism, similar
#                 to Haskell + Rust traits but without dyn-
#                 dispatch
#              6. NO EXCEPTIONS — error handling via Result-like
#                 algebraic data types; Linear ensures errors
#                 cannot be silently dropped
#              7. C-STANDALONE COMPILATION TARGET — Austral
#                 emits portable C99 source as one output mode,
#                 enabling deployment to any platform with a C
#                 compiler (embedded systems, microcontrollers,
#                 unusual OSes))
# License: Apache-2.0 WITH LLVM-exception
# Status:  Austral — 1,518+ stars on austral/austral; alternative
#          Rust-based implementation in development at lambdaclass/
#          austral.rs.  Specification at austral-lang.org/spec/.
#          Active PL research community.  Real-world adoption is
#          limited but the design is influential in linear-types
#          + capability-security PL theory discussions.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 88TH LANGUAGE DOCUMENTED
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# its **88TH PROGRAMMING LANGUAGE**: Austral.  This expands the taxonomy
# from 87 to 88 languages, joining the prior 87 in the cross-language
# inventory.  Taxonomy now spans 363 cross-language CLI library variants
# across **88 documented languages**.
#
# Pattern: R621 Rust=63 (humantime — Axis 11 OPENS) → R622 Go=63
# (go-humanize) → R623 TS-Node=63 (vercel/ms — Axis 11 symmetric at
# 1/1/1) → R624 88TH LANGUAGE (Austral THIS).  This completes the
# 3-leader-bump + new-language segment.  Expected R625 begins next
# segment (likely Rust=64 → Go=64 → TS-Node=64 → 89th language).
#
# Leaderboard unchanged at R624: Rust=63, Go=63, TypeScript-Node=63
# (three-way tie at 63).
#
# WHY AUSTRAL IS A DISTINCTIVE 88TH LANGUAGE:
#
# Austral occupies a unique cell in the language design space that NO
# previously-documented language fills:
#
#   Feature              | Austral    | Other documented langs
#   ---------------------|------------|------------------------
#   Linear (not affine)  | ✓ exactly  | Rust: affine (allows drop)
#   types                  once use   | ATS (R605): linear in views
#                                       only, not all data
#                                       Linear Haskell: extension
#                                       (not core)
#   Capability-based     | ✓ no       | None (all others have
#   security               ambient     ambient authority for
#                          authority   filesystem/network/env)
#   .aui/.aum mandatory  | ✓          | OCaml's .mli/.ml is
#   interface/body                       optional; SML's signatures
#   split                                are optional
#   No primitives but    | ✓ Bool     | All others have many
#   Bool                   only        built-in primitive types
#   No exceptions        | ✓ Result   | Most have exceptions
#                          ADTs only    (Java, Python, C++) or
#                                       panics (Rust, Go)
#
# Linear types vs Rust's affine ownership:
#   - Rust: values can be DROPPED implicitly (going out of scope
#            calls Drop::drop automatically)
#   - Austral: values MUST be CONSUMED — passed to a function that
#              consumes them, returned, or destructured.  Forgetting
#              to use a Linear value is a COMPILE ERROR
#
# This stricter discipline catches a class of bugs Rust's affine
# system allows:
#   - Forgetting to close a file handle: Rust calls Drop, Austral
#     refuses to compile
#   - Forgetting to drain a channel: Rust calls Drop, Austral
#     refuses to compile
#   - Resource leaks where Drop is the wrong action: Austral
#     forces explicit handling
#
# Capability-based security:
#   - Austral programs have NO ambient authority.  To open a file,
#     a function must receive a FileSystem capability as a parameter.
#     Capabilities are themselves Linear, so they cannot be copied
#     or stored beyond their intended scope
#   - The Root capability is the source of all derived capabilities;
#     main() receives Root and derives more specific capabilities
#     before passing them to subsystems
#   - No other documented language has this discipline at the
#     language-design level (some research languages — like Pony's
#     reference capabilities — come close but with different
#     semantics)
#
# Cross-language analogs (closest matches by feature):
#   - Linear types → Linear Haskell (extension), ATS (R605, in views)
#   - Capability security → Pony's reference capabilities (similar
#                             but reference-discipline rather than
#                             effect-discipline)
#   - Mandatory interface/body split → OCaml .mli/.ml (optional)
#   - C-standalone backend → Vala, Genie, Eiffel SmartEiffel, ATS,
#                              Nim
#
# Austral is the FIRST documented language with LINEAR (not affine)
# types + CAPABILITY-BASED SECURITY + MANDATORY .aui/.aum INTERFACE
# SPLIT as language-level features.
#
# -----------------------------------------------------------------------------
#
# THE austral CLI — OCaml + hand-rolled argparser + 3 subcommands
#
# austral's CLI is in bin/austral.ml → lib/Cli.ml → lib/CliParser.ml.
# Pure OCaml implementation with custom arglist parser (no external
# CLI framework):
#
#     (* From bin/austral.ml *)
#     open Austral_core.Cli
#     let _ = main (Array.to_list Sys.argv)
#
#     (* From lib/CliParser.ml *)
#     type cmd =
#         | HelpCommand
#         | VersionCommand
#         | CompileHelp
#         | WholeProgramCompile of {
#             modules: mod_source list;
#             target: target;
#             error_reporting_mode: error_reporting_mode;
#         }
#
#     type target =
#         | TypeCheck
#         | Executable of { bin_path: string; entrypoint: entrypoint; }
#         | CStandalone of { output_path: string;
#                             entrypoint: entrypoint option; }
#
#     type mod_source =
#         | ModuleSource of { inter_path: string; body_path: string }
#         | ModuleBodySource of { body_path: string }
#
#     type entrypoint =
#         | Entrypoint of module_name * identifier
#
# Subcommands:
#   help                   Show top-level help
#   version                Show version
#   compile <modules>      Compile Austral modules
#
# Compile subcommand flags:
#   --entrypoint MOD:NAME       Entry point function (e.g. MyApp:main)
#   --output PATH                Output path (executable or .c file)
#   --target-type TYPE           exe (executable) | c (C source) | tc (typecheck)
#   --no-entrypoint              No entrypoint (requires --target-type=c)
#   --error-format FORMAT        plain (default) | json
#
# Module source positional arguments:
#   path.aum                     Body file only
#   interface.aui,body.aum       Interface + body comma-separated pair
#
# Five-axis distinctness of Austral from every other documented
# language:
#
#   1. LINEAR (not affine) TYPES — exactly-once consumption discipline;
#      stricter than Rust's affine "drop is allowed" semantics.
#
#   2. CAPABILITY-BASED SECURITY — no ambient authority; all system
#      effects gated by Linear capability values threaded through
#      function signatures.
#
#   3. MANDATORY .aui/.aum SPLIT — every module has separate
#      interface + body files (OCaml's split is optional; Austral
#      enforces it).
#
#   4. NO PRIMITIVES BUT BOOL — only Bool is a compiler-builtin
#      primitive; all other types (Int32, Float64, Array, etc.)
#      are in the standard library.
#
#   5. NO EXCEPTIONS — error handling via Result-like ADTs only;
#      Linear ensures errors cannot be silently dropped.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/austral/austral/blob/master/lib/CliParser.ml
# OCaml type definitions + flag parsing logic.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _austral_cmds _austral_targets _austral_error_formats
_austral_cmds=(
    'compile:compile Austral modules to executable / C source / type-check only'
    'help:show top-level help'
    'version:show compiler version'
)
_austral_targets=(
    'exe:build a native executable (default if --entrypoint given)'
    'c:emit standalone portable C99 source'
    'tc:type-check only (no output)'
)
_austral_error_formats=(
    'plain:human-readable text error output (default)'
    'json:structured JSON error output for editor integration'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'austral subcommand' _austral_cmds && ret=0
        ;;
    args)
        case $words[1] in
            compile)
                _arguments \
                    '--entrypoint=[entry-point function (format Module:name)]:entrypoint:_default' \
                    '--output=[output path (executable or .c file)]:output:_files' \
                    '--target-type=[output target type]:type:(exe c tc)' \
                    '--no-entrypoint[no entrypoint (requires --target-type=c)]' \
                    '--error-format=[error reporting mode]:format:(plain json)' \
                    '*:module source (path.aum OR interface.aui,body.aum):_files -g "*.{aum,aui}"' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _austral_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
