#compdef velox

_velox() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[Show help]' \
        '(-v --version)'{-v,--version}'[Show version]' \
        '--config[Configuration file]:file:_files' \
        '--log-level[Set log level]:level:(debug info warn error fatal)' \
        '1:command:_velox_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                build)
                    _arguments \
                        '--source[Source directory]:dir:_directories' \
                        '--output[Output directory]:dir:_directories' \
                        '--type[Build type]:type:(debug release relwithdebinfo)' \
                        '--num-threads[Number of build threads]:threads:' \
                        '--benchmarks[Build benchmarks]' \
                        '--tests[Build tests]'
                    ;;
                test)
                    _arguments \
                        '--filter[Test filter pattern]:pattern:' \
                        '--repeat[Number of test repetitions]:count:' \
                        '--num-threads[Number of threads]:threads:' \
                        '--verbose[Verbose test output]'
                    ;;
                benchmark)
                    _arguments \
                        '--filter[Benchmark filter pattern]:pattern:' \
                        '--iterations[Number of iterations]:count:' \
                        '--output[Output file]:file:_files'
                    ;;
                run)
                    _arguments \
                        '--query[Query to execute]:query:' \
                        '--data[Input data path]:path:_files' \
                        '--format[Input format]:format:(parquet orc dwrf json csv)' \
                        '--output[Output file]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_velox_commands() {
    local -a commands
    commands=(
        'build:Build Velox from source'
        'test:Run Velox tests'
        'benchmark:Run benchmarks'
        'run:Execute a query'
        'setup:Set up development environment'
        'clean:Clean build artifacts'
    )
    _describe -t commands 'velox command' commands
}

_velox "$@"
