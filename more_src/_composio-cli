#compdef composio-cli
# Documentation: https://docs.composio.dev/docs/cli
# Reference accessed: 2026-05-23
# Verified: composio CLI (see also _composio).

# Zsh completion for composio-cli - Composio agent toolkit CLI package name

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--install-skill[install composio skill]:agent:(claude codex openclaw):' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'composio command' \
      'search[search tools]' \
      'execute[execute tool by slug]' \
      'link[link toolkit account]' \
      'run[run TS/JS workflow]' \
      'listen[listen to trigger]' \
      'proxy[proxy HTTP with toolkit auth]' \
      'login[log in]' \
      'logout[log out]' \
      'whoami[show account]' \
      'generate[generate integration code]' \
      'upgrade[upgrade CLI]' \
      'config[manage config]' \
      'orgs[manage organizations]' \
      'projects[manage projects]' \
      'files[manage session files]' \
      'tools[toolkit commands]' \
      'triggers[trigger commands]' \
      'connections[manage connections]' \
      'artifacts[session artifacts]' && ret=0
    ;;
esac

return ret
