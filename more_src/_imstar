#compdef imstar
# imstar: find and list stars in a FITS or IRAF image (WCSTools)

local ret=1

_arguments -s -S \
  '-a[set rotation angle to this constant in nominal WCS]:angle' \
  '-b[output B1950 (FK4) coordinates, overriding image equinox]' \
  '-c[use this RA and Dec as the image center]:RA:_message RA' \
  '-d[use this DAOFIND output catalog as input instead of searching]:catalog:_files' \
  '-e[number of pixels to ignore around image edge]:pixels' \
  '-f[write simple ASCII catalog file]' \
  '-h[print heading to output table]' \
  '-i[minimum peak brightness in counts for a star to be recorded]:peak value' \
  '-j[output J2000 (FK5) coordinates, overriding image equinox]' \
  '-k[print each star as it is found]' \
  '-m[add this number to magnitudes from counts]:magnitude offset' \
  '-n[number of brightest stars to print]:number' \
  '-p[plate scale in arcseconds per pixel, overriding header]:arcsec' \
  '-q[write SAOimage region file with this shape (osdv+x)]:shape' \
  '-r[reject all stars with radius greater than this many pixels]:number' \
  '-s[sort output list by right ascension instead of flux]' \
  '-t[print tab table (Starbase) output to standard output]' \
  '-u[assume image is unsigned if 16-bit integers]' \
  '-v[print more information about process]' \
  '-w[write output file in DAOFIND format]' \
  '-z[use AIPS classic projection code instead of WCSLIB]' \
  '*:FITS file:_files -g "*.(fits|fit|fts|FITS|FIT|FTS|imh)"' && ret=0

return ret
