#compdef turbo_tests
# Documentation: https://github.com/serpapi/turbo_tests/blob/master/lib/turbo_tests/cli.rb
# run RSpec tests on multiple cores with incremental summarized output

local ret=1

_arguments -s -S \
  '-n+[number of processes to use]:processes' \
  '*'{-r+,--require=}'[require a file]:file:_files' \
  '(-f --format)'{-f+,--format=}'[choose a formatter]:formatter:(progress p documentation d)' \
  '*'{-t+,--tag=}'[run examples with the specified tag]:tag' \
  '(-o --out)'{-o+,--out=}'[write output to a file instead of stdout]:file:_files' \
  '--runtime-log=[location of previously recorded test runtimes]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[more output]' \
  '--fail-fast=-[enable fail-fast mode with optional threshold]::n' \
  '--seed=[seed for rspec]:seed' \
  '*:spec file:_files' && ret=0

return ret
