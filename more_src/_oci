#compdef oci

# Zsh completion for Oracle Cloud Infrastructure CLI

local curcontext="$curcontext" state line ret=1

local -a oci_commands
oci_commands=(
  'audit:manage Audit service'
  'bv:manage Block Volume service'
  'ce:manage Container Engine for Kubernetes'
  'compute:manage Compute service'
  'db:manage Database service'
  'dns:manage DNS service'
  'email:manage Email Delivery service'
  'events:manage Events service'
  'fn:manage Functions service'
  'fs:manage File Storage service'
  'iam:manage Identity and Access Management'
  'kms:manage Key Management service'
  'lb:manage Load Balancing service'
  'logging:manage Logging service'
  'marketplace:manage Marketplace'
  'monitoring:manage Monitoring service'
  'network:manage Networking service'
  'nosql:manage NoSQL Database service'
  'objects:manage Object Storage'
  'ocvs:manage Oracle Cloud VMware Solution'
  'ons:manage Notifications service'
  'os:manage Object Storage service'
  'raw-request:make a raw HTTP request'
  'resource-manager:manage Resource Manager'
  'search:manage Search service'
  'session:manage CLI sessions'
  'setup:set up the CLI'
  'streaming:manage Streaming service'
  'support:manage Support requests'
  'waas:manage Web Application Acceleration and Security'
  'waf:manage Web Application Firewall'
  'work-requests:manage Work Requests'
)

local -a oci_global_flags
oci_global_flags=(
  '(-h --help)'{-h,--help}'[show help message]'
  '--config-file=[path to config file]:config file:_files'
  '--profile=[config file profile]:profile:'
  '--region=[the region to make calls against]:region:'
  '--endpoint=[the value to use as the service endpoint]:endpoint:'
  '--cert-bundle=[CA cert bundle path]:cert bundle:_files'
  '--auth=[auth type]:auth:(api_key instance_principal instance_obo_user resource_principal security_token)'
  '--auth-purpose=[request purpose for signing]:purpose:'
  '--cli-rc-file=[path to the OCI CLI rc file]:rc file:_files'
  '--connection-timeout=[connection timeout in seconds]:seconds:'
  '--debug[send all log messages to stderr]'
  '--defaults-file=[path to defaults file]:defaults file:_files'
  '--generate-full-command-json-input[generate JSON for all command parameters]'
  '--generate-param-json-input=[generate JSON for a parameter]:parameter:'
  '--max-retries=[maximum number of retry attempts]:retries:'
  '--no-retry[disable automatic retry]'
  '--ns=[object storage namespace]:namespace:'
  '-o=[output type]:output:(json table)'
  '--output=[output type]:output:(json table)'
  '--query=[JMESPath query]:query:'
  '--raw-output[remove quotes from string output]'
  '--request-id=[request ID for tracing]:request id:'
)

_arguments -s -S \
  $oci_global_flags \
  '-v[show version]' \
  '--version[show version]' \
  '-i[interactive mode]' \
  '--interactive[interactive mode]' \
  '1:command:_describe -t commands command oci_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      setup)
        local -a setup_commands
        setup_commands=(
          'autocomplete:set up tab completion'
          'bootstrap:interactive setup for config and keys'
          'config:set up the config file'
          'keys:generate an API signing key pair'
          'oci-cli-rc:generate OCI CLI rc file'
          'repair-file-permissions:fix config and key file permissions'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:setup command:_describe -t commands command setup_commands' \
          '*::setup args:' && ret=0
        ;;
      compute)
        local -a compute_commands
        compute_commands=(
          'boot-volume:manage boot volumes'
          'boot-volume-attachment:manage boot volume attachments'
          'console-history:manage console histories'
          'dedicated-vm-host:manage dedicated VM hosts'
          'device:manage compute devices'
          'global-image-capability-schema:manage image capability schemas'
          'image:manage compute images'
          'instance:manage compute instances'
          'instance-agent:manage instance agents'
          'instance-configuration:manage instance configurations'
          'instance-console-connection:manage console connections'
          'instance-pool:manage instance pools'
          'measured-boot-report:manage measured boot reports'
          'pic:manage partner image catalog'
          'shape:manage compute shapes'
          'vnic-attachment:manage VNIC attachments'
          'volume-attachment:manage volume attachments'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:compute command:_describe -t commands command compute_commands' \
          '*::compute args:' && ret=0
        ;;
      iam)
        local -a iam_commands
        iam_commands=(
          'api-key:manage API signing keys'
          'auth-token:manage auth tokens'
          'availability-domain:manage availability domains'
          'compartment:manage compartments'
          'customer-secret-key:manage customer secret keys'
          'domain:manage identity domains'
          'dynamic-group:manage dynamic groups'
          'fault-domain:manage fault domains'
          'group:manage user groups'
          'policy:manage policies'
          'region:manage regions'
          'region-subscription:manage region subscriptions'
          'smtp-credential:manage SMTP credentials'
          'tag:manage tags'
          'tag-default:manage tag defaults'
          'tag-namespace:manage tag namespaces'
          'tenancy:manage tenancies'
          'user:manage users'
          'work-request:manage work requests'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:iam command:_describe -t commands command iam_commands' \
          '*::iam args:' && ret=0
        ;;
      os)
        local -a os_commands
        os_commands=(
          'bucket:manage buckets'
          'multipart:manage multipart uploads'
          'ns:manage namespaces'
          'object:manage objects'
          'preauthenticated-request:manage preauthenticated requests'
          'preauth-request:manage preauthenticated requests'
          'replication:manage replication'
          'retention-rule:manage retention rules'
          'work-request:manage work requests'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:os command:_describe -t commands command os_commands' \
          '*::os args:' && ret=0
        ;;
      network)
        local -a network_commands
        network_commands=(
          'drg:manage dynamic routing gateways'
          'internet-gateway:manage internet gateways'
          'ip-sec-connection:manage IPSec connections'
          'local-peering-gateway:manage local peering gateways'
          'nat-gateway:manage NAT gateways'
          'nsg:manage network security groups'
          'public-ip:manage public IPs'
          'remote-peering-connection:manage remote peering connections'
          'route-table:manage route tables'
          'security-list:manage security lists'
          'service-gateway:manage service gateways'
          'subnet:manage subnets'
          'vcn:manage virtual cloud networks'
          'vnic:manage VNICs'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:network command:_describe -t commands command network_commands' \
          '*::network args:' && ret=0
        ;;
      session)
        local -a session_commands
        session_commands=(
          'authenticate:authenticate and create a session'
          'export:export a session'
          'refresh:refresh a session'
          'terminate:terminate a session'
          'validate:validate a session'
        )
        _arguments -s -S \
          $oci_global_flags \
          '1:session command:_describe -t commands command session_commands' \
          '*::session args:' && ret=0
        ;;
      raw-request)
        _arguments -s -S \
          $oci_global_flags \
          '--http-method=[HTTP method]:method:(DELETE GET HEAD PATCH POST PUT)' \
          '--target-uri=[target URI]:uri:' \
          '--request-body=[request body]:body:' \
          '--request-body-file=[file containing request body]:file:_files' && ret=0
        ;;
      *)
        _arguments -s -S $oci_global_flags '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
