# Source: https://github.com/GhostKellz/zion/blob/68b8896db0e9ee35f12fd64c009989821e7c03fa/release/completions/zion.zsh
# Repository: GhostKellz/zion (release/completions/zion.zsh)
#compdef zion

_zion() {
    local -a commands
    commands=(
        'init:Initialize a new Zig project'
        'add:Add a dependency'
        'remove:Remove a dependency'
        'rm:Remove a dependency'
        'update:Update dependencies'
        'list:List dependencies'
        'ls:List dependencies'
        'info:Show package information'
        'fetch:Fetch dependencies'
        'pin:Pin a dependency'
        'unpin:Unpin a dependency'
        'repair:Repair dependency issues'
        'check:Check project health'
        'build:Build the project'
        'clean:Clean artifacts'
        'lock:Manage lock file'
        'hash:Manage hashes'
        'run:Run the project'
        'test:Run tests or Zion-native test workflow'
        'tree:Show dependency tree'
        'why:Explain dependency presence'
        'policy:Manage package trust policy'
        'target:Manage compilation targets'
        'doc:Generate/open docs'
        'outdated:Check outdated dependencies'
        'nvim:Neovim integration helpers'
        'config:Configuration management'
        'security:Security and trust helpers'
        'performance:Performance helpers'
        'debug:Debug helpers'
        'zig:Manage Zig versions'
        'search:Search packages'
        'registry:Manage registries'
        'template:Placeholder command'
        'fmt:Placeholder command'
        'analyze:Placeholder command'
        'version:Show version information'
        'publish:Publish packages'
        'search-interactive:Interactive package search'
        'verify:Signature verification helpers'
        'cache:Cache helpers'
        'tui:Terminal UI'
        'status:Show status'
        'setup:Onboarding flow'
        'zls:Manage ZLS'
        'workspace:Manage workspaces'
        'keyring:Manage keyrings'
        'help:Show help'
    )

    _arguments -C '1: :->command' '*: :->args'

    case $state in
        command)
            _describe 'commands' commands
            ;;
        args)
            case $words[2] in
                test)
                    _arguments '1:workflow subcommand:(bootstrap scaffold run bench ci report info docs)'
                    ;;
                registry)
                    _arguments '1:registry subcommand:(list add remove test health auth)'
                    ;;
                zig)
                    _arguments '1:zig subcommand:(install list use current)'
                    ;;
                zls)
                    _arguments '1:zls subcommand:(install doctor config)'
                    ;;
                workspace)
                    _arguments '1:workspace subcommand:(init add build)'
                    ;;
                policy)
                    _arguments '1:policy subcommand:(init audit show add-allow add-deny)'
                    ;;
                target)
                    _arguments '1:target subcommand:(list add remove available)'
                    ;;
            esac
            ;;
    esac
}

_zion "$@"
