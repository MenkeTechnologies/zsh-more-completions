#compdef gpplt
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/gpplt.html
# MIRIAD gpplt - plot or list calibration gains and polarization terms

local ret=1

_arguments -s -S \
  'vis=[input visibility dataset name]:vis:_files' \
  'device=[PGPLOT plotting device]:device' \
  'log=[output log file]:log:_files' \
  'yaxis=[amp/phase/real/imag]:yaxis' \
  'options=[gains,xygains,xbyygain,polarization,2polarization,delays,speccor,bandpass,dots,dtime,wrap]:options' \
  'nxy=[subplot grid dimensions]:nxy' \
  'select=[uv-selection subset]:select' \
  'yrange=[y-axis min and max limits]:yrange' \
  '*:dataset:_files' && ret=0

return ret
