#compdef velveth
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/velveth.1.html
# Velvet hashing of reads into k-mers for de novo assembly

local ret=1

_arguments -s -S \
  '-strand_specific[enable strand-specific transcriptome sequencing mode]' \
  '-reuse_Sequences[reuse existing Sequences file in directory]' \
  '-reuse_binary[reuse existing binary sequences file in directory]' \
  '-noHash[prepare Sequences file only, do not hash reads]' \
  '-create_binary[generate binary CnyUnifiedSeq file format]' \
  '-fasta[FASTA input format]' \
  '-fastq[FASTQ input format]' \
  '-raw[raw sequence format]' \
  '-fasta.gz[gzip-compressed FASTA]' \
  '-fastq.gz[gzip-compressed FASTQ]' \
  '-raw.gz[gzip-compressed raw format]' \
  '-sam[SAM alignment format]' \
  '-bam[BAM alignment format]' \
  '-fmtAuto[auto-detect format and decompression]' \
  '-interleaved[paired reads in single interleaved file]' \
  '-separate[read paired sequences from two separate files]' \
  '-short[single-end short reads]' \
  '-shortPaired[paired-end short reads]' \
  '-short2[secondary short read channel]' \
  '-shortPaired2[secondary paired-end short read channel]' \
  '-long[long reads]' \
  '-longPaired[paired-end long reads]' \
  '-reference[reference sequences]' \
  '*:file:_files' && ret=0

return ret
