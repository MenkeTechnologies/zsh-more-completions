#compdef bro-pkg
# _bro-pkg — Zeek bro-pkg legacy package manager CLI for installing pinning upgrading removing third-party Bro scripts plugins protocol analyzers and policy modules from Bro package sources (zeek team, Python); argparse
# upstream: https://github.com/zeek/package-manager

_bro-pkg() {
    local -a sub=(
        'install:install package'
        'upgrade:upgrade installed packages'
        'remove:remove package'
        'list:list installed/available packages'
        'search:search package database'
        'info:show package info'
        'config:show config'
        'env:print env vars'
        'autoconfig:create autoconfig'
        'refresh:refresh package sources'
        'pin:pin package version'
        'unpin:unpin package'
        'load:load package'
        'unload:unload package'
        'check:check package'
        'create:create new package'
        'test:run package tests'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--configfile=+[file]:file:_files -g "*.cfg"' \
        '-C+[file]:file:_files -g "*.cfg"' \
        '--user-var=+[KEY=VALUE]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bro-pkg subcommand' sub ;;
        args)
            case $words[1] in
                install|upgrade|remove|info|pin|unpin|load|unload) _arguments \
                    '--version=+[version]:str:' \
                    '--force[force]' \
                    '*:package:' ;;
                search) _arguments '*:keyword:' ;;
                create) _arguments \
                    '--features=+[csv]:str:' \
                    '--no-features[no features]' \
                    '*:dir name:_files -/' ;;
            esac
            ;;
    esac
}

_bro-pkg "$@"
