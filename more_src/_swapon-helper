#compdef swapon-helper
# _swapon-helper — util-linux swapon helper shim (small wrapper around swapon(8) that scans /etc/fstab + /etc/crypttab and enables every still-inactive swap entry; -a all from fstab, -L label, -U uuid, -p priority, -d discard, -v verbose, --version; intended for use in initrd / systemd-tmpfiles units rather than direct invocation)
# upstream: https://github.com/util-linux/util-linux
# Flags from util-linux sys-utils/swapon.c on tip.

_swapon-helper() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a[enable all from fstab]' \
        '-L+[label]:label:' \
        '-U+[uuid]:uuid:' \
        '-p+[priority]:priority:' \
        '-d[discard]' \
        '-v[verbose]' \
        '*:device:_files -g "/dev/*"'
}

_swapon-helper "$@"
