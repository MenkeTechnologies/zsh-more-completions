# _homer — Christopher Benner HOMER Hypergeometric Optimization of Motif EnRichment suite for motif discovery ChIP-seq RNA-seq analysis (homer team, Perl/C); custom argparse
# upstream: http://homer.ucsd.edu/homer/

_homer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-g+[genome]:g:(hg19 hg38 mm9 mm10 mm39 rn5 rn6 dm3 dm6 sacCer3 sacCer2 ce10 ce11 GRCh37 GRCh38)' \
        '--genome=+[genome]:g:(hg19 hg38 mm9 mm10 mm39 rn5 rn6 dm3 dm6 sacCer3 sacCer2 ce10 ce11)' \
        '-S+[similar motif]:n:' \
        '-len+[motif lengths csv]:str:' \
        '-size+[region size]:str:' \
        '-mask[masked genome]' \
        '-noweight[no weighting]' \
        '-mset+[motif database]:m:(vertebrates fly plants worms yeast insects)' \
        '-cpg[use CpG islands as background]' \
        '-bg+[background BED]:file:_files -g "*.bed"' \
        '-p+[number of threads]:n:' \
        '-N+[number of background sequences]:n:' \
        '-rna[RNA mode]' \
        '-h[hypergeometric scoring]' \
        '-fdr+[F]:f:' \
        '-cache+[MB]:n:' \
        '-quickMask[quick mask]' \
        '-mcheck+[motif check]:file:_files' \
        '-base+[basename for output]:str:' \
        '-S+[similar motif]:n:' \
        '-redundancy+[F]:f:' \
        '-mis+[max mismatches]:n:' \
        '-noKnown[no known motifs]' \
        '-noDeNovo[no de novo motifs]' \
        '-d+[tag directory]:dir:_files -/' \
        '-style+[style]:s:(factor histone groseq tss dnase super mC chipseq atac)' \
        '-tagdir+[tag directory]:dir:_files -/' \
        '-tagcheck[tag check]' \
        '-checkGC[check GC content]' \
        '-len+[N]:n:' \
        '-fragLength+[N]:n:' \
        '-cellsize+[N]:n:' \
        '-format+[format]:f:(bed sam bam tagAlign eland gff)' \
        '-keepOne[keep one duplicate]' \
        '-keepAll[keep all duplicates]' \
        '-precision+[N]:n:' \
        '-totalReads+[N]:n:' \
        '-normLength+[N]:n:' \
        '-c+[sample]:str:' \
        '-i+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '-b+[background file]:file:_files' \
        '-r+[ref tag directory]:dir:_files -/' \
        '*:input file:_files'
}

_homer "$@"
