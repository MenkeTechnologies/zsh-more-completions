#compdef vault-k8s
# Documentation: https://man.archlinux.org/search?q=vault-k8s
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
  '--listen=[address to listen on]:address:'
  '--tls-auto=[auto-TLS domain]:domain:'
  '--tls-auto-hosts=[TLS auto hosts]:hosts:'
  '--tls-cert-file=[TLS certificate file]:file:_files'
  '--tls-key-file=[TLS key file]:file:_files'
  '--log-level=[log level]:level:(trace debug info warn error)'
  '--log-format=[log format]:format:(standard json)'
  '--telemetry-path=[metrics path]:path:'
  '(-h --help)'{-h,--help}'[show help]'
  '--version[show version]'
)

_arguments -s -S $arguments
