#compdef plmc
# Documentation: https://github.com/debbiemarkslab/plmc
# plmc infer undirected graphical models from multiple sequence alignments

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage information]' \
  '(-c --couplings)'{-c,--couplings}'+[save coupling scores to text file]:couplingsfile:_files' \
  '(-o --output)'{-o,--output}'+[save estimated parameters to binary file]:paramfile:_files' \
  '--save-weights=[save sequence weights to text file]:weightsfile:_files' \
  '(-w --weights)'{-w,--weights}'+[load sequence weights from file]:weightsfile:_files' \
  '(-s --scale)'{-s,--scale}'+[neighborhood weight for sequence weighting]:value:' \
  '(-t --theta)'{-t,--theta}'+[neighborhood divergence for weights]:value:' \
  '(-lh --lambdah)'{-lh,--lambdah}'+[L2 lambda for fields (h_i)]:value:' \
  '(-le --lambdae)'{-le,--lambdae}'+[L2 lambda for couplings (e_ij)]:value:' \
  '(-lg --lambdag)'{-lg,--lambdag}'+[group L1 lambda for couplings (e_ij)]:value:' \
  '(-a --alphabet)'{-a,--alphabet}'+[alternative alphabet]:alphabet:' \
  '(-f --focus)'{-f,--focus}'+[select uppercase non-gapped sites from focus sequence]:identifier:' \
  '(-g --gapignore)'{-g,--gapignore}'[exclude gaps from potential calculations]' \
  '(-m --maxiter)'{-m,--maxiter}'+[maximum number of iterations]:maxiter:' \
  '(-n --ncores)'{-n,--ncores}'+[maximum threads for OpenMP]:ncores:' \
  '--fast[fast weights and stochastic gradient descent]' \
  '*:alignment file:_files' && ret=0

return ret
