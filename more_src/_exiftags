#compdef exiftags
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/exiftags.1.html
# Output the properties contained in a JPEG Exif section

local ret=1

_arguments -s -S \
  '-a[output camera-specific, image-specific, and verbose properties]' \
  '-c[output camera-specific properties]' \
  '-d[output Exif parse debug information]' \
  '-i[output image-specific properties]' \
  '-l[make lens characteristics image-specific]' \
  '-q[suppress property section header]' \
  '-s+[field/value separator string]:delim' \
  '-u[output unknown or unsupported properties]' \
  '-v[output verbose properties]' \
  '*:JPEG file:_files -g "*.(jpg|jpeg|JPG|JPEG)"' && ret=0

return ret
