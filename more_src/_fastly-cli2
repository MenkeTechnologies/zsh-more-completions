#compdef fastly-cli2
# _fastly-cli2 — Fastly Inc fastly-cli2 CLI command-line frontend wrapping the Fastly CLI command-line tool that interacts with the Fastly Compute@Edge platform and edge cloud platform open-source written in Go fully manage your Fastly services from the command line domain backend cache-setting condition dictionary header health-check pop products purge service version compute compute-init compute-build compute-deploy compute-serve compute-publish compute-validate config dashboard log alerts authtoken billing user resource-link ratelimits sso secret-store object-store kv-store products acl tls customer (Fastly team, Go); kingpin
# upstream: https://www.fastly.com/

_fastly-cli2() {
    local -a sub=(
        'acl:ACL operations'
        'acl-entry:ACL entry operations'
        'alerts:alert operations'
        'auth-token:auth token operations'
        'backend:backend operations'
        'cache-setting:cache setting operations'
        'compute:compute operations'
        'condition:condition operations'
        'config:CLI configuration'
        'config-store:config store operations'
        'customer:customer operations'
        'dashboard:open Fastly dashboard'
        'dictionary:dictionary operations'
        'dictionary-item:dictionary item ops'
        'domain:domain operations'
        'header:header operations'
        'healthcheck:healthcheck operations'
        'install:install Fastly CLI'
        'kv-store:KV store operations'
        'kv-store-entry:KV store entry operations'
        'log:log operations'
        'logging:logging endpoint operations'
        'object-store:object store ops'
        'pop:pop operations'
        'products:products operations'
        'profile:profile operations'
        'purge:purge operations'
        'rate-limit:rate limit ops'
        'resource-link:resource link ops'
        'secret-store:secret store ops'
        'secret-store-entry:secret store entry ops'
        'service:service operations'
        'service-auth:service auth ops'
        'service-version:service version ops'
        'shielding:shielding ops'
        'sso:SSO operations'
        'stats:stats'
        'tls-config:TLS config ops'
        'tls-custom:custom TLS ops'
        'tls-platform:platform TLS ops'
        'tls-subscription:TLS subscription ops'
        'update:update CLI'
        'user:user operations'
        'vcl:VCL ops'
        'version:show version'
        'whoami:show identity'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--accept-defaults[accept defaults]' \
        '--api=+[url]:str:' \
        '--auto-yes[auto yes]' \
        '--debug-mode[debug]' \
        '--enable-ssh[enable SSH]' \
        '--endpoint=+[url]:str:' \
        '--non-interactive[non interactive]' \
        '--profile=+[name]:str:' \
        '-p+[profile]:str:' \
        '--service-id=+[id]:str:' \
        '-s+[service id]:str:' \
        '--service-name=+[name]:str:' \
        '--token=+[token]:str:' \
        '-t+[token]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[no color]' \
        '--json[JSON output]' \
        '-j[JSON output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fastly subcommand' sub ;;
        args)
            case $words[1] in
                service|backend|domain|header|dictionary|cache-setting|condition|healthcheck|vcl|user|customer|acl|alerts|rate-limit|kv-store|secret-store|config-store|object-store|tls-config|tls-custom|tls-platform|tls-subscription) _arguments '1:op:(list describe create update delete activate clone deactivate validate)' '*:name:' ;;
                compute) _arguments '1:op:(init build deploy hash-files hashsum metadata pack publish serve update validate)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                purge) _arguments '*:key:' ;;
            esac
            ;;
    esac
}

_fastly-cli2 "$@"
