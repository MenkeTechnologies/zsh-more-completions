#compdef ldap-add
# _ldap-add — distro-shipped LDAP add wrapper (alias of ldapadd(1) preconfigured for the local SLAPD: -H URI, -D bind DN, -w password, -y password file, -f LDIF file, -c continue on error, -x simple bind, -Z TLS, -n dry run, -v verbose, -h help, -V version; loads new DNs from the LDIF file)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapadd)
# Flags from OpenLDAP clients/tools/ldapmodify.c (add mode) on tip.

_ldap-add() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-f+[LDIF file]:file:_files -g "*.ldif"' \
        '-c[continue on error]' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-n[dry run]' \
        '-v[verbose]' \
        '*-o+[option=value]:opt:'
}

_ldap-add "$@"
