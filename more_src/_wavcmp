#compdef wavcmp
# Documentation: https://github.com/zholos/wavcmp
# Reference accessed: 2026-05-21
# Verified: upstream source wavcmp/cmdline.py at github.com/zholos/wavcmp

local -a arguments

arguments=(
    '(-h --help)'{-h,--help}'[Show help message]'
    '--version[Show version]'
    '-o+[maximum offset in seconds (default 0.5)]:offset'
    '-t+[match threshold percent (default 1)]:threshold'
    '-k+[max skipped album tracks (default 0)]:skip'
    '-T+[number of worker threads]:threads'
    '(-v -q -M)-v[verbose match display]'
    '(-v -q -M)-q[do not show match statistics]'
    '(-v -q -M)-M[machine-readable output]'
    '-s[silently fail on invalid files]'
    '1:first audio file:_files -g "*.(wav|flac|WAV|FLAC)"'
    '2:second audio file:_files -g "*.(wav|flac|WAV|FLAC)"'
)

_arguments -s -S $arguments
