#compdef wavcmp
# Documentation: https://man.archlinux.org/search?q=wavcmp
# Reference accessed: 2026-05-16

local -a arguments

arguments=(
    '-h[Show help message]'
    '--help[Show help message]'
    '-v[Verbose output]'
    '--verbose[Verbose output]'
    '-s[Show sample differences]'
    '--samples[Show sample differences]'
    '-t[Tolerance for comparison]:tolerance'
    '--tolerance=[Tolerance for comparison]:tolerance'
    '1:first WAV file:_files -g "*.wav"'
    '2:second WAV file:_files -g "*.wav"'
)

_arguments -s -S $arguments
