#compdef pmprintf
# _pmprintf — Performance Co-Pilot pmprintf (printf(3)-style formatting of one or more PCP metrics so they can be consumed by ad-hoc scripts; -h host, -a archive, -t interval, -s samples, -f format string, -i instance list, -F first/last, -d delimiter, -z archive tz, -n namespace; positional metric list)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmprintf/pmprintf.c on tip.

_pmprintf() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-L[local context]' \
        '-t+[interval]:interval:' \
        '-s+[samples]:n:' \
        '-f+[format string]:format:' \
        '-i+[instance list]:instances:' \
        '-d+[delimiter]:delim:' \
        '-F[first/last timestamps]' \
        '-O+[sample offset]:offset:' \
        '-A+[align time]:time:' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-n+[namespace]:file:_files' \
        '*:metric:'
}

_pmprintf "$@"
