#compdef flux-resource
# Documentation: https://flux-framework.readthedocs.io/projects/flux-core/en/latest/man1/flux-resource.html
# list and manipulate Flux resource status

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --states)'{-s,--states=}'[restrict displayed resource states]:states' \
  '(-q --queue)'{-q,--queue=}'[filter results to queue(s)]:queue' \
  '(-i --include)'{-i,--include=}'[filter results matching targets]:targets' \
  '--skip-empty[skip lines with empty resource sets]' \
  '(-o --format)'{-o,--format=}'[customize output format]:format' \
  '(-n --no-header)'{-n,--no-header}'[suppress header]' \
  '(-f --force)'{-f,--force}'[force operation]' \
  '(-u --update)'{-u,--update}'[skip overwriting existing reason/timestamp]' \
  '(-x --xml)'{-x,--xml}'[interpret path as directory of hwloc XML files]' \
  '(-F --follow)'{-F,--follow}'[wait for and print new events]' \
  '(-w --wait)'{-w,--wait=}'[wait for specified event then quit]:event' \
  '(-H --human)'{-H,--human}'[display human-readable output]' \
  '(-L --color)'{-L,--color=}'[colorize output]:when:(always never auto)' \
  '(-T --time-format)'{-T,--time-format=}'[specify timestamp format]:format:(raw iso offset human)' \
  '*'{-m,--match-context=}'[filter events by key=val]:key=val' \
  '(-t --timeout)'{-t,--timeout=}'[exit if event not received in duration]:fsd' \
  '1:subcommand:(list info R status drain undrain reload acquire-mute eventlog)' \
  '*::args:_default' && ret=0

return ret
