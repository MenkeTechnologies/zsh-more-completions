#compdef immich-go

# https://github.com/simulot/immich-go — v0.31.x cobra (rootCmd.go + app.RegisterFlags)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'version:show version information'
  'upload:upload assets to an Immich server'
  'archive:archive assets'
  'stack:manage stacks'
)

_arguments -s -S \
  '--config=[config file]:file:_files' \
  '--dry-run[dry run]' \
  '--save-config[write immich-go.yaml with current flags]' \
  '--on-errors=[error policy]:policy:(stop continue)' \
  '--concurrent-tasks=[parallel tasks 1-20]:count:' \
  '--log-level=[DEBUG INFO WARN ERROR]:level:(DEBUG INFO WARN ERROR)' \
  '(-l --log-file)'{-l+,--log-file=}'[log file path]:file:_files' \
  '--log-type=[log format]:type:(text json)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'immich-go command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
