#compdef modrinth
# Documentation: https://docs.modrinth.com/
# Reference accessed: 2026-05-19
# Verified: STUB - Modrinth has no single official CLI; multiple unofficial
# clients exist (gliscowo/modrinth-cli, Tom-The-Geek/modrinth-cli,
# NexusKrop/ModrinthCLI) with divergent flag sets. Minimal completion only.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :_files' && ret=0

return ret
