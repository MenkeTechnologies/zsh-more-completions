#compdef modrinth

# Zsh completion for Modrinth CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate with Modrinth'
  'create:create a new project'
  'init:initialize an existing project'
  'list:list projects'
  'project:manage a project'
  'version:manage project versions'
  'search:search for projects on Modrinth'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'modrinth command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (auth)
        local -a auth_cmds=(
          'login:log in to Modrinth'
          'logout:log out from Modrinth'
          'status:show authentication status'
        )
        _describe -t commands 'auth command' auth_cmds && ret=0
        ;;
      (create)
        _arguments \
          '--name[project name]:name' \
          '--slug[project slug]:slug' \
          '--description[project description]:description' \
          '--type[project type]:type:(mod modpack resourcepack shader plugin datapack)' \
          '--license[project license]:license:(MIT Apache-2.0 GPL-3.0 LGPL-3.0 LicenseRef-All-Rights-Reserved)' && ret=0
        ;;
      (search)
        _arguments \
          '--facets[search facets]:facets' \
          '--limit[result limit]:limit' \
          '--offset[result offset]:offset' \
          '--index[sort index]:index:(relevance downloads follows newest updated)' \
          '1:query' && ret=0
        ;;
      (project)
        local -a project_cmds=(
          'get:get project details'
          'modify:modify project settings'
          'delete:delete a project'
          'gallery:manage project gallery'
        )
        _describe -t commands 'project command' project_cmds && ret=0
        ;;
      (version)
        local -a version_cmds=(
          'create:create a new version'
          'list:list versions'
          'get:get version details'
          'delete:delete a version'
        )
        _arguments '1:subcommand:->ver_sub' '*:: :->ver_args' && ret=0
        case $state in
          (ver_sub)
            _describe -t commands 'version command' version_cmds && ret=0
            ;;
          (ver_args)
            case $words[1] in
              (create)
                _arguments \
                  '--name[version name]:name' \
                  '--number[version number]:number' \
                  '--channel[release channel]:channel:(release beta alpha)' \
                  '--loaders[mod loaders]:loaders' \
                  '--game-versions[game versions]:versions' \
                  '--featured[mark as featured]' \
                  '*:file:_files' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
