#compdef agrind
# Documentation: https://github.com/rcoh/angle-grinder
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '--self-update[Update agrind to the latest version]' \
  '(-o --output)'{-o,--output}'[Output format]:format:(format json logfmt)' \
  '(-f --file)'{-f,--file}'[Read from file instead of stdin]:file:_files' \
  '*:query:' && return 0
