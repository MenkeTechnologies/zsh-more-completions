#compdef keyd
# Documentation: https://man.archlinux.org/man/extra/keyd/keyd.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'monitor:print keyboard events to stdout'
      'listen:print layer state changes of the running daemon'
      'bind:apply the supplied bindings (or reset)'
      'reload:reload config files'
      'list-keys:list valid key names'
      'input:emit the supplied text'
      'do:execute the supplied macro expression'
      'check:validate config files'
    )
    _describe -t commands 'keyd command' commands && ret=0
    ;;
esac

return ret
