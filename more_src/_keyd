#compdef keyd

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-e --expression)'{-e,--expression}'[evaluate an expression]:expression' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'monitor:monitor keyboard events'
      'list-keys:list key names'
      'bind:create a temporary binding'
      'unbind:remove a temporary binding'
      'reload:reload configuration'
      'listen:listen for key events'
      'do:execute a key sequence'
      'input:send input'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
