#compdef mris_decimate
# Documentation: https://github.com/freesurfer/freesurfer/blob/dev/attic/mris_decimate/mris_decimate.help.xml
# Reduce the number of triangles in a surface mesh

local ret=1

_arguments -s -S \
  '-d[decimation level]:level:' \
  '-n[desired number of faces]:num:' \
  '-a[desired average face area]:area:' \
  '-q[quiet]' \
  '-m[minimum angle]:angle:' \
  '--help[display help]' \
  '--version[show version]' \
  '*:surface:_files' && ret=0

return ret
