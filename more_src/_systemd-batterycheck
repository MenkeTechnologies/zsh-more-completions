#compdef systemd-battery-check systemd-batterycheck
# _systemd-batterycheck (systemd helper that aborts boot to a fallback shutdown unit when laptop battery is below the safe-boot threshold to avoid corrupting filesystems mid-upgrade; takes no positional arguments — invoked by systemd-battery-check.service in initrd)
# upstream: https://github.com/systemd/systemd (src/battery-check)
# Argument shape from systemd src/battery-check/battery-check.c on tip.

_systemd-batterycheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-batterycheck "$@"
