#compdef unsquashfs4 unsquashfs

# unsquashfs: extract a SquashFS filesystem
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-version[show version]' \
  '-d[destination dir]:dir:_files -/' \
  '-dest=[destination dir]:dir:_files -/' \
  '-f[force overwrite of dest]' \
  '-i[show full inode info]' \
  '-l[list files only]' \
  '-ll[list with long format]' \
  '-lc[list contents only]' \
  '-lln[list with long numeric ids]' \
  '-llc[list contents with details]' \
  '-r[regex match for partial extract]:pattern:' \
  '-exclude[exclude files matching]:pattern:' \
  '-cat[concatenate files]' \
  '-p[number of processors]:n:' \
  '-processors=[number of processors]:n:' \
  '-mem=[max memory MB]:mb:' \
  '-no-progress[do not show progress bar]' \
  '-st[do not write extracted files]' \
  '-no-xattrs[do not extract extended attributes]' \
  '-xattrs[do extract extended attributes]' \
  '-quiet[quiet output]' \
  '-stat[print file/inode stats]' \
  '-fstime[output filesystem mtime]' \
  '-UTC[print times in UTC]' \
  '-no-wildcards[no wildcards in include/exclude]' \
  '-data-queue[size of data queue]:n:' \
  '-frag-queue[size of frag queue]:n:' \
  '-fragment[print fragment info]' \
  '-export-info[show export info]' \
  '*:SquashFS file:_files -g "*.(squashfs|sfs|sqsh)"' && ret=0
return ret
