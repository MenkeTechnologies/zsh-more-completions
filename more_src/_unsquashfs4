#compdef unsquashfs4

# unsquashfs4: alternative name for unsquashfs (SquashFS extraction)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version and exit]' \
  '-d[output to directory]:dir:_files -/' \
  '-dest[output dest dir]:dir:_files -/' \
  '-n[no warnings]' \
  '-no-progress[do not display progress]' \
  '-no-xattrs[do not extract xattrs]' \
  '-xattrs[extract xattrs]' \
  '-no-exit-code[do not set exit code on error]' \
  '-p[number of parallel processors]:n:' \
  '-f[force overwrite of destination]' \
  '-i[print files as they are extracted]' \
  '-il[print final filenames as they are extracted]' \
  '-li[print final paths + permissions]' \
  '-ll[list of all files (long format)]' \
  '-l[list files (short format)]' \
  '-lc[list of all conflicting files]' \
  '-llc[long listing of conflicts]' \
  '-r[regenerate destination]' \
  '-o[byte offset to start of squashfs]:n:' \
  '-stat[show squashfs file info]' \
  '-s[show squashfs file info]' \
  '-no[no progress bar]' \
  '-cat[output files to stdout]' \
  '-q[suppress information messages]' \
  '*:SquashFS file:_files -g "*.squashfs"' && ret=0
return ret
