#compdef dvi2tty-ng
# Documentation: https://man.archlinux.org/search?q=dvi2tty-ng
# Reference accessed: 2026-05-16

# dvi2tty-ng: next-generation DVI to terminal text converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[align output left margin]' \
  '-b[output to ASCII brief]' \
  '-e[expand all ligatures]:level:' \
  '-f[output file]:file:_files' \
  '-l[output with line feed]' \
  '-N[don'\''t use ANSI escape sequences]' \
  '-o[output file]:file:_files' \
  '-p[page range]:range:' \
  '-q[quiet mode]' \
  '-s[scan width]:n:' \
  '-t[output format]:fmt:' \
  '-u[underline]' \
  '-w[output width]:cols:' \
  '*:DVI file:_files -g "*.dvi"' && ret=0
return ret
