#compdef pdfjam
# Documentation: pdfjam --help
# Source: TeX pdfjam — shell front-end to LaTeX pdfpages package.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--configpath[print configpath and exit]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-q --quiet)'{-q,--quiet}'[suppress verbose commentary]' \
    '--batch[run pdfjam per input file separately]' \
    '(-o --outfile)'{-o,--outfile=}'[output file or dir]:path:_files' \
    '--suffix=[suffix for derived output filenames]:string:' \
    '--checkfiles[check files before processing]' \
    '--no-tidy[do not remove intermediate files]' \
    '--rotateoversize=[handle oversize pages]:bool:(true false)' \
    '--keepinfo[copy /Info dict from input PDF]' \
    '*--nup=[arrange pages in grid (e.g. 2x2)]:nup:' \
    '*--paper=[page paper]:paper:(letterpaper a4paper a3paper a5paper legalpaper executive)' \
    '*--papersize=[explicit paper size]:size:' \
    '*--orient=[orientation]:orient:(landscape portrait)' \
    '*--landscape[landscape orientation]' \
    '*--no-landscape[portrait orientation]' \
    '*--scale=[uniform scale]:n:' \
    '*--offset=[page offset]:xpt ypt:' \
    '*--delta=[delta between pages]:xpt ypt:' \
    '*--trim=[crop trim "L B R T"]:trim:' \
    '*--frame=[draw frame]:bool:(true false)' \
    '*--noautoscale[do not auto-scale]' \
    '*--column=[fill columns first]:bool:(true false)' \
    '*--columnstrict[strict column fill]' \
    '*--openright[start with blank right page]' \
    '*:input PDF/JPG/PNG [page selection]:_files -g "*.{pdf,jpg,jpeg,png}"' \
    && ret=0

return ret
