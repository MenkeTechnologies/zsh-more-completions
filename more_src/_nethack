#compdef nethack

# Zsh completion for nethack (roguelike dungeon exploration game)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u+[Specify player name]:name' \
  '-p+[Specify profession/role]:role:(Archeologist Barbarian Caveman Healer Knight Monk Priest Ranger Rogue Samurai Tourist Valkyrie Wizard)' \
  '-r+[Specify race]:race:(human elf dwarf gnome orc)' \
  '-s[Print scores]' \
  '-d+[Specify playground directory]:directory:_files -/' \
  '-n[Suppress news]' \
  '-D[Start in debug (wizard) mode]' \
  '-X[Start in explore (discovery) mode]' \
  '-dec[Use DEC graphics]' \
  '-ibm[Use IBM graphics]' \
  '-windowtype+[Use specified window type]:type' && ret=0

return ret
