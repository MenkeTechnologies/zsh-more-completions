#compdef edgeadm
# Documentation: https://github.com/superedge/edgeadm/blob/main/docs/installation/install_edge_kubernetes.md
# SuperEdge edgeadm - kubeadm-based tool to create edge Kubernetes clusters

local ret=1

_arguments -s -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '1:command:(( \
    init\:"initialize an edge Kubernetes master node" \
    join\:"join an edge node to an existing cluster" \
    reset\:"reset a node to its pre-edgeadm state" \
    addon\:"deploy SuperEdge addon components" \
    manifests\:"export default SuperEdge YAML manifests" \
    change\:"convert a native cluster into an edge cluster" \
    revert\:"revert an edge cluster back to a native cluster" \
    config\:"manage edgeadm configuration" \
    version\:"print edgeadm version" \
    completion\:"generate shell completion script" \
  ))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      init)
        _arguments -s \
          '--apiserver-cert-extra-sans=[extra SANs to sign into the apiserver certificate]:sans' \
          '--apiserver-advertise-address=[master internal IP for cluster communication]:address' \
          '--image-repository=[container image registry to pull from]:repo' \
          '--pod-network-cidr=[IP range for the pod network]:cidr' \
          '--service-cidr=[IP range for service cluster IPs]:cidr' \
          '--install-pkg-path=[local path or URL of the Kubernetes static install package]:path:_files' \
          '--enable-edge=[deploy edge capability components (true/false)]:bool:(true false)' \
          '--runtime=[container runtime to use]:runtime:(containerd docker)' \
          '--kubernetes-version=[Kubernetes version to deploy]:version' \
          '(-c --config)'{-c,--config}'=[path to a kubeadm config file]:file:_files' && ret=0
        ;;
      join)
        _arguments -s \
          '--token=[bootstrap token used to join the cluster]:token' \
          '--discovery-token-ca-cert-hash=[SHA256 hash to verify the cluster CA certificate]:hash' \
          '--install-pkg-path=[local path or URL of the Kubernetes static install package]:path:_files' \
          '--enable-edge=[deploy edge capability components (true/false)]:bool:(true false)' && ret=0
        ;;
      change|revert)
        _arguments -s \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--ca.cert=[cluster CA certificate file]:file:_files' \
          '--ca.key=[cluster CA key file]:file:_files' && ret=0
        ;;
      manifests)
        _arguments -s \
          '-m=[output directory for the exported manifests]:dir:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
