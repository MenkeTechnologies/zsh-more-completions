#compdef psi4

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-i --input)'{-i,--input}'=[input file]:file:_files -g "*.(dat|in|psi4)"' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-n --nthread)'{-n,--nthread}'=[number of threads]:threads:' \
  '(-s --scratch)'{-s,--scratch}'=[scratch directory]:dir:_files -/' \
  '(-m --messy)'{-m,--messy}'[leave temporary files]' \
  '(-p --prefix)'{-p,--prefix}'=[output file prefix]:prefix:' \
  '(-a --append)'{-a,--append}'[append to output file]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '-l+[library path]:path:_files -/' \
  '--psi4-python[show psi4 Python interpreter]' \
  '--inplace[run with inplace build]' \
  '--json[input is JSON formatted]' \
  '*:input file:_files' && ret=0

return ret
