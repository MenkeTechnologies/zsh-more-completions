#compdef tigris
# Documentation: https://www.tigrisdata.com/docs/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Tigris object storage CLI (S3-compatible). Subcommand set is intentionally
# small and high-traffic; sub-options not enumerated to avoid drift.

local -a commands
commands=(
  'login:Authenticate via OAuth or credentials'
  'logout:End the current session'
  'configure:Save persistent access keys'
  'whoami:Show current user and organization'
  'organizations:List and switch organizations'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[Print help message]' \
  '--access-key=[access key]:key:' \
  '--access-secret=[access secret]:secret:' \
  '--bucket=[bucket]:bucket:' \
  '1: :_describe -t commands "command" commands' \
  '*::arg:_files'
