#compdef cupstestppd
# Documentation: cupstestppd --help (CUPS 26 - deprecated)
# Source: test PPD files for compliance with the spec.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-I+[ignore specific warnings]:warning:(filename filters none profiles)' \
    '-R+[alternate root directory]:dir:_files -/' \
    '*-W+[issue warnings instead of errors]:warning:(all none constraints defaults duplex filters profiles sizes translations)' \
    '(-v -vv)-q[run silently]' \
    '-r[use relaxed open mode]' \
    '(-q -vv)-v[verbose]' \
    '(-q -v)-vv[very verbose]' \
    '*:ppd file:_files -g "*.ppd(|.gz)"' \
    && ret=0

return ret
