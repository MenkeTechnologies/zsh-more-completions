#compdef auditctl
# _auditctl — Linux audit auditctl (control the running audit subsystem; -e 0|1|2 enable/disable/lock, -f failure mode (0|1|2), -s/--show status, -l list rules, -D delete all rules, -a add rule action,filter, -A prepend, -d delete rule, -w watch file, -W remove watch, -k key, -p permissions (rwxa), -F field=value, -S syscall name, -m message, -R rules file, -b backlog, -r rate, -t buffer, --version)
# upstream: https://github.com/linux-audit/audit-userspace
# Flags from linux-audit/audit-userspace src/auditctl.c on tip.

_auditctl() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-e+[enable]:state:(0 1 2)' \
        '-f+[failure mode]:mode:(0 1 2)' \
        '-s[status]' \
        '-l[list rules]' \
        '-D[delete all rules]' \
        '*-a+[action,filter]:spec:' \
        '*-A+[action,filter]:spec:' \
        '*-d+[action,filter]:spec:' \
        '-w+[watch file]:file:_files' \
        '-W+[remove watch]:file:_files' \
        '-k+[key]:key:' \
        '-p+[perms]:perms:(r w x a rw rwx)' \
        '*-F+[field=value]:field:' \
        '-S+[syscall]:syscall:' \
        '-m+[message]:message:' \
        '-R+[rules file]:file:_files -g "*.rules"' \
        '-b+[backlog]:n:' \
        '-r+[rate per second]:n:' \
        '-t[trim rules]' \
        '-i[ignore errors]' \
        '-q+[mount.point,subtree]:mount:'
}

_auditctl "$@"
