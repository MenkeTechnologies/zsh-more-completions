#compdef doxygen
# Documentation: https://www.doxygen.nl/manual/starting.html
# Source: doxygen/doxygen — C++/Java/etc documentation generator from source comments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-g[generate template Doxyfile (optional name)]:config file:_files' \
    '-s[silence header comment in generated Doxyfile]' \
    '-u[update existing Doxyfile to current format]:config file:_files' \
    '-w[generate HTML/LaTeX/RTF documentation style template]:type:(html latex rtf)' \
    '-e[generate the example output for an HTML/LaTeX template]:type:' \
    '-x[compare config file to default config]:config file:_files' \
    '-d[debug specific output category]:category:(commentcnv commentscan filterevent pp tokenizer code preprocessor printtree time extcmd markdown filteroutput lex)' \
    '-l[generate layout XML template]:layout.xml:_files' \
    '-q[do not print version/intro messages]' \
    '-b[stdin input mode]' \
    '-T[show timing info]' \
    '-S[show "Source" footer in generated HTML]' \
    '-v[show version]' \
    '-h[show help]' \
    '*:Doxyfile or input dir:_files' \
    && ret=0

return ret
