#compdef necpp nec2cpp nec2++
# Documentation: https://man.archlinux.org/search?q=necpp
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-i+[input file]:file:_files -g "*.nec"' \
  '-o+[output file]:file:_files' \
  '*:file:_files' && ret=0

return ret
