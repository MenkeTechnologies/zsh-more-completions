#compdef sfsegyread
# Documentation: http://www.ahay.org/RSF/sfsegyread.html
# Madagascar: convert a SEG-Y or SU dataset to RSF

local ret=1

_arguments -s \
  'tape=[input data file]:file:_files' \
  'su=[y if SU input, n if SEGY]:flag:(y n)' \
  'suxdr=[y if SU has XDR support]:flag:(y n)' \
  'endian=[auto-estimate endianness]:flag:(y n)' \
  'format=[data format (1 IBM,2 int4,3 int2,5 IEEE,6 native)]:fmt:(1 2 3 5 6)' \
  'n2=[number of traces to read (0 = all)]:n2' \
  'ns=[number of samples per trace]:ns' \
  'hfile=[output text data header file]:file:_files' \
  'bfile=[output binary data header file]:file:_files' \
  'tfile=[output trace header file]:file:_files' \
  'mask=[optional header mask for selected traces]:file:_files' \
  'read=[what to read: h header, d data, b both]:mode:(h d b)' \
  'verb=[verbosity flag]:flag:(y n)' \
  '*:rsf file:_files' && ret=0

return ret
