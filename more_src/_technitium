#compdef technitium DnsServerApp
# _technitium — Shreyas Zare Technitium DNS Server cross-platform recursive DNS resolver with web UI (technitiumsoftware team, C#); custom argparse
# upstream: https://github.com/TechnitiumSoftware/DnsServer

_technitium() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-dir=+[config directory]:dir:_files -/' \
        '--web-port=+[admin web port]:port:_ports' \
        '--web-bind-address=+[bind address]:host:_hosts' \
        '--web-https[enable web https]' \
        '--web-https-port=+[admin https port]:port:_ports' \
        '--web-https-certificate=+[cert path]:file:_files' \
        '--no-web[disable web ui]' \
        '--bind-address=+[dns bind address]:host:_hosts' \
        '--dns-port=+[dns port]:port:_ports' \
        '--dnssec-validation=+[mode]:m:(true false strict)' \
        '--enable-dns-over-http=+[bool]:b:(true false)' \
        '--enable-dns-over-tls=+[bool]:b:(true false)' \
        '--enable-dns-over-https=+[bool]:b:(true false)' \
        '--enable-dns-over-quic=+[bool]:b:(true false)' \
        '--log-level=+[level]:l:(0 1 2 3 4)' \
        '--no-log[disable logging]' \
        '--forwarder=+[forwarder server]:server:'
}

_technitium "$@"
