#compdef pssh-2.7
# Documentation: https://github.com/lilydjwg/pssh/blob/master/psshlib/cli.py
# Reference accessed: 2026-05-20
# Verified: upstream OptionParser definitions and local `pssh --help` output
# (Homebrew pssh 2.3.6). Versioned binary pssh-2.7 ships the same option set
# as the unversioned pssh / parallel-ssh.

local -a arguments

arguments=(
  '(- *)--version[show program version]'
  '(- *)--help[show help]'
  '(-h --hosts)'{-h+,--hosts=}'[hosts file (each line "\[user@\]host\[:port\]")]:host file:_files'
  '(-H --host)'{-H+,--host=}'[additional host entries ("\[user@\]host\[:port\]")]:host'
  '(-l --user)'{-l+,--user=}'[username]:user:_users'
  '(-p --par)'{-p+,--par=}'[max parallel threads]:threads'
  '(-o --outdir)'{-o+,--outdir=}'[stdout output directory]:dir:_directories'
  '(-e --errdir)'{-e+,--errdir=}'[stderr output directory]:dir:_directories'
  '--fileappend[append to existing output/error files]'
  '(-t --timeout)'{-t+,--timeout=}'[per-host timeout seconds (0 = none)]:seconds'
  '(-O --option)'{-O+,--option=}'[SSH option]:option'
  '(-v --verbose)'{-v,--verbose}'[warning and diagnostic messages]'
  '(-A --askpass)'{-A,--askpass}'[ask for a password]'
  '(-x --extra-args)'{-x+,--extra-args=}'[extra command-line args with quote processing]:args'
  '(-X --extra-arg)'{-X+,--extra-arg=}'[single extra command-line arg]:arg'
  '(-g --host-glob)'{-g+,--host-glob=}'[shell-style glob to filter hosts]:glob'
  '(-i --inline)'{-i,--inline}'[inline aggregated stdout/stderr per server]'
  '--inline-stdout[inline standard output for each server]'
  '(-I --send-input)'{-I,--send-input}'[read from stdin and send as input to ssh]'
  '(-P --print)'{-P,--print}'[print output as it arrives]'
  '--no-headers[do not print headers with --inline/--inline-stdout]'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
