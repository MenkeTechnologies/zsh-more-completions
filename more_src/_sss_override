#compdef sss_override
# Documentation: https://man.archlinux.org/search?q=sss_override
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'user-add:add a user override'
  'user-del:delete a user override'
  'user-find:find user overrides'
  'user-show:show user override'
  'user-import:import user overrides from file'
  'user-export:export user overrides to file'
  'group-add:add a group override'
  'group-del:delete a group override'
  'group-find:find group overrides'
  'group-show:show group override'
  'group-import:import group overrides from file'
  'group-export:export group overrides to file'
)

_arguments -C \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--usage[show usage]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sss_override command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (user-add|user-del|user-show)
        _arguments \
          '(-n --name)'{-n,--name}'+[override name]:name:' \
          '(-u --uid)'{-u,--uid}'+[UID]:uid:' \
          '(-g --gid)'{-g,--gid}'+[GID]:gid:' \
          '(-h --home)'{-h,--home}'+[home dir]:dir:_files -/' \
          '(-s --shell)'{-s,--shell}'+[shell]:shell:_files' \
          '(-c --gecos)'{-c,--gecos}'+[GECOS]:gecos:' \
          '(-x --certificate)'{-x,--certificate}'+[certificate]:cert:' \
          '1:user:_users' && ret=0 ;;
      (group-add|group-del|group-show)
        _arguments \
          '(-n --name)'{-n,--name}'+[override name]:name:' \
          '(-g --gid)'{-g,--gid}'+[GID]:gid:' \
          '1:group:_groups' && ret=0 ;;
    esac ;;
esac

return ret
