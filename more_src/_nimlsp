#compdef nimlsp
# Nim Language Server Protocol

local ret=1

_arguments -s -S \
  '--stdio[use stdio for communication]' \
  '--socket=[listen on socket]:port:' \
  '--debug[enable debug mode]' \
  '--log=[log file path]:file:_files' \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' && ret=0

return ret
