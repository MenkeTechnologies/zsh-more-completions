#compdef snarkos
# Documentation: https://github.com/AleoNet/snarkOS/blob/mainnet/cli/src/commands/start.rs
# Reference accessed: 2026-05-21
# Verified: upstream cli/src/commands/start.rs Start struct and
# cli/src/commands/account.rs Account enum.
# Removed from prior file: fabricated --rest-rps=, --metrics-write-interval-ms=,
# --max-cdn-block=, --no-cdn, --cdn= (cdn is a URI value; nocdn is bool flag),
# --metrics= (metrics is bool, --metrics-ip takes the addr), --logfile= (PathBuf
# not Option), account `export` subcommand (not in upstream).
# Added: --bootstrap-client, --rotate-external-peers, --jwt-secret,
# --jwt-timestamp, --nojwt, --nobanner, --log-filter, --metrics-ip,
# --ledger-storage, --node-data-storage, --auto-db-checkpoints, --nocdn,
# --dev-num-clients, --dev-bonded-balances, --auto-migrate-node-data.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'account:manage Aleo accounts (new/import/sign/verify)'
  'clean:clean snarkOS node storage'
  'start:start the snarkOS node'
  'update:self-update snarkOS'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity 0-6]:n:(0 1 2 3 4 5 6)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'snarkos command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--network=[network id]:id:(0 1 2)' \
          '--validator[run as validator]' \
          '--prover[run as prover]' \
          '--client[run as client]' \
          '--bootstrap-client[run as bootstrap client]' \
          '--private-key=[node private key]:key:' \
          '--private-key-file=[file containing node private key]:file:_files' \
          '--node=[bind address for node]:addr:' \
          '--bft=[bind address for BFT]:addr:' \
          '*--peers=[comma-separated peer list]:peers:' \
          '*--validators=[comma-separated validator list]:validators:' \
          '--allow-external-peers[allow connections from external peers]' \
          '--rotate-external-peers[rotate external peer connections]' \
          '--rest=[bind address for REST API]:addr:' \
          '--rest-rps=[REST requests per second per IP]:n:' \
          '--jwt-secret=[base64 JWT secret]:secret:' \
          '--jwt-timestamp=[JWT timestamp]:n:' \
          '--norest[disable REST API]' \
          '--nojwt[disable JWT auth]' \
          '--trusted-peers-only[only connect to trusted peers]' \
          '--nodisplay[disable interactive display]' \
          '--nobanner[disable banner]' \
          '--log-filter=[tracing log filter]:filter:' \
          '--logfile=[log file]:file:_files' \
          '--metrics[enable metrics exporter]' \
          '--metrics-ip=[metrics exporter address]:addr:' \
          '--ledger-storage=[ledger storage directory]:dir:_files -/' \
          '--node-data-storage=[node data storage directory]:dir:_files -/' \
          '--auto-db-checkpoints=[auto db checkpoint directory]:dir:_files -/' \
          '--cdn=[CDN URL]:url:' \
          '--nocdn[disable CDN sync]' \
          '--dev=[run a local dev node id]:n:' \
          '--dev-num-validators=[dev: validator count]:n:' \
          '--dev-num-clients=[dev: client count]:n:' \
          '--no-dev-txs[do not generate dev transactions]' \
          '--dev-bonded-balances=[dev bonded balances]:balances:' \
          '--auto-migrate-node-data[auto-migrate node data]' && ret=0 ;;
      (account)
        _arguments \
          '*::sub:(new import sign verify)' && ret=0 ;;
      (clean)
        _arguments \
          '--dev=[clean dev storage]:n:' \
          '--network=[network id]:n:(0 1 2)' \
          '--path=[storage path]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
