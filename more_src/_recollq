#compdef recollq
# Recoll command-line query tool

local ret=1

_arguments -s -S \
  '-c[specify configuration directory]:directory:_files -/' \
  '-d[specify extra database]:database dir:_files -/' \
  '-a[ALL words must match]' \
  '-o[OR: any word can match]' \
  '-f[specify result field list]:fields:' \
  '-l[specify language]:language:' \
  '-n[number of results]:count:' \
  '-b[batch mode]' \
  '-Q[query language mode]' \
  '-m[dump raw document]' \
  '-t[sort by date]' \
  '-D[sort descending]' \
  '-s[specify minimum size]:size:' \
  '-S[specify maximum size]:size:' \
  '-A[specify after date]:date:' \
  '-B[specify before date]:date:' \
  '-i[specify index step]:step:' \
  '-h[show help]' \
  '*:query terms:' && ret=0

return ret
