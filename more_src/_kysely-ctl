#compdef kysely kysely-ctl

_kysely-ctl() {
    local line state
    local -a commands
    commands=(
        'init:Scaffold a kysely.config.ts file'
        'migrate:make:Create a new migration file'
        'migrate:latest:Run all pending migrations'
        'migrate:up:Run the next pending migration'
        'migrate:down:Rollback the last executed migration'
        'migrate:rollback:Rollback the last batch'
        'migrate:list:List all migrations'
        'seed:make:Create a new seed file'
        'seed:run:Run all seed files'
        'seed:list:List all available seed files'
        'sql:Execute SQL query'
    )

    _arguments -C \
        '--config[Path to configuration file]:file:_files' \
        '(-e --environment)'{-e,--environment}'[Specify environment]:env:' \
        '--help[Display help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kysely command' commands
            ;;
        args)
            case $line[1] in
                migrate:make|seed:make)
                    _arguments '1:name:'
                    ;;
                sql)
                    _arguments '1:query:'
                    ;;
            esac
            ;;
    esac
}

_kysely-ctl "$@"
