#compdef 3dBlurToFWHM
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dBlurToFWHM.html
# Blur a dataset to a specified FWHM smoothness

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-input[dataset to be smoothed and output]:dataset:_files' \
  '-blurmaster[dataset whose smoothness controls blurring]:dataset:_files' \
  '-prefix[output dataset prefix]:prefix:' \
  '-mask[blur only within masked voxels]:dataset:_files' \
  '-automask[generate automask from input]' \
  '-FWHM[blur to target 3D FWHM]:fwhm:' \
  '-FWHMxy[blur to target 2D FWHM in x,y-plane]:fwhm:' \
  '-quiet[suppress verbose progress reports]' \
  '-maxite[maximum number of iterations]:n:' \
  '-rate[blurring rate (0.05-3.5)]:rate:' \
  '-nbhd[neighborhood for local smoothness]:nbhd:' \
  '-ACF[use ACF method for global smoothness]' \
  '-acf[use ACF method for global smoothness]' \
  '-bsave[save local smoothness estimates each iteration]:prefix:' \
  '-bmall[use all blurmaster sub-bricks]' \
  '-unif[uniformize voxel-wise MAD before blurring]' \
  '-detrend[detrend the blurmaster dataset]' \
  '-nodetrend[disable detrending]' \
  '-detin[detrend input before and after blurring]' \
  '-temper[enhance spatial uniformity of smoothness]' \
  '*:dataset:_files' && ret=0

return ret
