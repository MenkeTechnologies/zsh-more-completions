#compdef xresprobe
# Documentation: (no Debian/Ubuntu manpage retrievable across releases)
# Reference accessed: 2026-05-16
# Verified: no upstream docs accessible. Canonical invocation is
# `xresprobe <driver-name>` taking one positional driver name (e.g. vesa,
# nvidia, ati). Tool kept per "do not delete files" directive.

# xresprobe: probe X11 resolution support (Ubuntu hardware-detection legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:driver name:(vesa nvidia ati intel radeon nv fbdev vmware virtualbox)' && ret=0
return ret
