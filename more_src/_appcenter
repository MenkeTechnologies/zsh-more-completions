#compdef appcenter
# Documentation: https://man.archlinux.org/search?q=appcenter
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate to App Center'
  'logout:log out of App Center'
  'profile:show or update user profile'
  'tokens:manage API tokens'
  'apps:manage apps (create/list/show/delete/update)'
  'analytics:analytics commands'
  'crashes:upload crash symbols / mappings'
  'codepush:CodePush commands (deployment/release/release-react/etc.)'
  'distribute:distribute releases (groups/stores/release/download)'
  'orgs:manage organizations'
  'teams:manage teams'
  'test:cloud testing commands'
  'build:build commands (queue/branches/configure)'
  'devices:manage devices and device sets'
  'help:show help'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug logging]' \
  '--token=[API token]:token:' \
  '--env=[App Center environment]:env:' \
  '--quiet[suppress output]' \
  '--output=[output format]:format:(json csv table)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'appcenter command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (codepush)
        local -a cp_subs=(
          'release:release a CodePush update from a directory'
          'release-react:release a CodePush update for React Native'
          'release-cordova:release a CodePush update for Cordova'
          'rollback:rollback a release'
          'patch:patch an existing release'
          'promote:promote a release between deployments'
          'deployment:manage deployments'
        )
        _describe -t cpcmds 'codepush subcommand' cp_subs && ret=0
        case $words[2] in
          (deployment)
            _arguments '*::sub:(add list remove rename clear history show)' && ret=0 ;;
          (release-react)
            _arguments \
              '(-a --app)'{-a+,--app=}'[app id (owner/name)]:app:' \
              '(-d --deployment-name)'{-d+,--deployment-name=}'[deployment]:dep:' \
              '(-t --target-binary-version)'{-t+,--target-binary-version=}'[target binary version]:version:' \
              '(-x --disable-duplicate-release-error)'{-x,--disable-duplicate-release-error}'[disable dup release error]' \
              '(-m --mandatory)'{-m,--mandatory}'[mark as mandatory]' \
              '(-r --rollout)'{-r+,--rollout=}'[rollout %]:percent:' \
              '(-c --description)'{-c+,--description=}'[release description]:desc:' \
              '(-b --bundle-name)'{-b+,--bundle-name=}'[bundle name]:name:' \
              '--use-hermes[use Hermes engine]' \
              '--extra-bundler-option=[extra metro bundler option]:opt:' \
              '--xcode-project-file=[Xcode project file]:file:_files' \
              '--gradle-file=[gradle file]:file:_files' && ret=0 ;;
        esac ;;
      (distribute)
        _arguments \
          '*::sub:(release groups stores download collect-iap-receipts release-files)' \
          '(-a --app)'{-a+,--app=}'[app id]:app:' \
          '(-f --file)'{-f+,--file=}'[binary file to upload]:file:_files' \
          '(-r --release-notes)'{-r+,--release-notes=}'[release notes]:notes:' \
          '(-R --release-notes-file)'{-R+,--release-notes-file=}'[release notes file]:file:_files' \
          '(-g --group)*'{-g+,--group=}'[distribution group]:group:' \
          '(-s --store)*'{-s+,--store=}'[store name]:store:' \
          '--mandatory[mandatory release]' \
          '--silent[silent release]' \
          '--build-version=[build version]:version:' \
          '--build-number=[build number]:n:' && ret=0 ;;
      (crashes)
        _arguments \
          '*::sub:(upload-symbols upload-mappings upload-missing-symbols)' \
          '(-a --app)'{-a+,--app=}'[app id]:app:' \
          '(-s --symbol)*'{-s+,--symbol=}'[symbol file]:file:_files' \
          '(-x --xcarchive)'{-x+,--xcarchive=}'[xcarchive directory]:file:_files -/' \
          '(-d --dsym)'{-d+,--dsym=}'[dSYM directory]:file:_files -/' \
          '(-m --mapping)'{-m+,--mapping=}'[mapping file]:file:_files' && ret=0 ;;
      (apps|orgs|teams|devices|tokens|profile|build|test|analytics)
        _arguments '*::sub:(list show create update delete)' && ret=0 ;;
      (login)
        _arguments \
          '(-u --user)'{-u+,--user=}'[username]:user:' \
          '(-p --password)'{-p+,--password=}'[password]:pass:' \
          '--token=[API token]:token:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
