#compdef photofilmstrip photofilmstrip-cli
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/photofilmstrip-cli.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy photofilmstrip-cli(1) manpage. Note: the GUI
# `photofilmstrip` binary has no flags; flags below are for the `-cli`
# variant. Both are accepted via #compdef alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# photofilmstrip(-cli): create slideshow movies from images
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --project)'{-p+,--project=}'[project file]:file:_files' \
  '(-o --outputpath)'{-o+,--outputpath=}'[output path (- for stdout)]:path:_files -/' \
  '(-t --profile)'{-t+,--profile=}'[profile]:profile:((0\:Medium 1\:HD 2\:FULL-HD))' \
  '(-n --videonorm)'{-n+,--videonorm=}'[video norm]:norm:((n\:NTSC p\:PAL))' \
  '(-f --format)'{-f+,--format=}'[output format]:format:((0\:Single\ pictures 1\:VCD\ MPG 2\:SVCD 3\:DVD 4\:Theora/Vorbis\ OGV 5\:x264/MP3\ MKV 6\:Preview))' \
  '(-a --draft)'{-a,--draft}'[enable draft mode]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '*:arg:_files' && ret=0
return ret
