#compdef tackler
# Documentation: https://tackler.fi/docs/tackler/latest/reference/command-line/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# https://github.com/tackler-ng/tackler — plain-text accounting / git journals

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'new:create new journal with configuration'
  'init:prepare journal in current directory'
  'report:run reports/exports per configuration'
  'help:show help'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[configuration file]:config:_files' \
  '--strict.mode=[strict validation of transactions]:bool:(true false)' \
  '--audit.mode=[produce checksums for transaction data]:bool:(true false)' \
  '--output.dir=[output directory]:dir:_files -/' \
  '--output.prefix=[filename prefix for reports]:prefix:' \
  '--input.file=[single journal file]:file:_files' \
  '--input.storage=[storage backend]:backend:(fs git)' \
  '--input.fs.path=[root journal directory]:dir:_files -/' \
  '--input.fs.dir=[transaction directory]:dir:' \
  '--input.fs.ext=[transaction file extension]:ext:' \
  '--input.git.repo=[git repository path]:dir:_files -/' \
  '--input.git.ref=[git reference (tag/branch)]:ref:' \
  '--input.git.commit=[git commit id]:commit:' \
  '--input.git.dir=[transaction directory in repo]:dir:' \
  '--input.git.ext=[transaction file extension]:ext:' \
  '*--accounts=[account name regex patterns]:regex:' \
  '*--reports=[report types]:type:(register balance balance-group)' \
  '--group-by=[grouping for balance-group]:group:(year month date iso-week iso-week-date)' \
  '*--formats=[output formats]:fmt:(txt json)' \
  '*--exports=[export types]:type:(identity equity accounts)' \
  '--invert[reverse amounts in exports/reports]' \
  '--pricedb=[price database file]:file:_files' \
  '--report.commodity=[reporting commodity]:commodity:' \
  '--price.lookup-type=[pricing method]:type:(none last-price given-time txn-time)' \
  '--price.before=[timestamp for price lookup]:timestamp:' \
  '--api-filter-def=[transaction filter JSON]:filter:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'tackler command' commands && ret=0 ;;
esac

return ret
