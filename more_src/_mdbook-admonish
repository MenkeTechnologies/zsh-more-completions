#compdef mdbook-admonish
# Documentation: https://github.com/tommilligan/mdbook-admonish
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'supports:check whether a renderer is supported'
      'install:install assets and update book.toml'
      'generate-custom:generate the CSS file for custom directives'
    )
    _describe -t commands 'mdbook-admonish command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      supports)
        _arguments -s -S '1:renderer:' && ret=0
        ;;
      install)
        _arguments -s -S \
          '--css-dir=[CSS asset directory relative to book root]:directory:_directories' \
          '1:book directory:_directories' && ret=0
        ;;
      generate-custom)
        _arguments -s -S \
          '--dir=[book root directory]:directory:_directories' \
          '1:output CSS file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
