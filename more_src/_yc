#compdef yc

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'application-load-balancer:Application Load Balancer'
  'audit-trails:Audit Trails'
  'backup:Cloud Backup'
  'baremetal:Bare Metal'
  'cdn:Cloud CDN'
  'certificate-manager:Certificate Manager'
  'cic:Cloud Interconnect'
  'cloud-registry:Cloud Registry'
  'cloudrouter:Cloud Router'
  'components:CLI components'
  'compute:Compute Cloud'
  'config:CLI configuration'
  'container:Serverless Containers'
  'dataproc:Data Proc'
  'datatransfer:Data Transfer'
  'desktops:Cloud Desktops'
  'dns:Cloud DNS'
  'help:show help'
  'iam:Identity and Access Management'
  'init:initialize CLI'
  'iot:IoT Core'
  'kms:Key Management Service'
  'load-balancer:Network Load Balancer'
  'loadtesting:Load Testing'
  'lockbox:Lockbox secrets'
  'logging:Cloud Logging'
  'managed-airflow:Managed Airflow'
  'managed-clickhouse:Managed ClickHouse'
  'managed-gitlab:Managed GitLab'
  'managed-greenplum:Managed Greenplum'
  'managed-kafka:Managed Kafka'
  'managed-kubernetes:Managed Kubernetes'
  'managed-metastore:Managed Metastore'
  'managed-mongodb:Managed MongoDB'
  'managed-mysql:Managed MySQL'
  'managed-opensearch:Managed OpenSearch'
  'managed-postgresql:Managed PostgreSQL'
  'managed-redis:Managed Redis'
  'managed-sharded-postgresql:Managed Sharded PostgreSQL'
  'managed-spark:Managed Spark'
  'managed-trino:Managed Trino'
  'managed-ytsaurus:Managed YTsaurus'
  'marketplace:Marketplace'
  'metadata-hub:Metadata Hub'
  'operation:long-running operations'
  'organization-manager:Organization Manager'
  'quota-manager:Quota Manager'
  'resource-manager:Resource Manager'
  'serverless:Cloud Functions and serverless'
  'smartcaptcha:SmartCaptcha'
  'smartwebsecurity:Smart Web Security'
  'storage:Object Storage'
  'version:show version'
  'vpc:Virtual Private Cloud'
  'ydb:Yandex Database'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--profile=[profile]:profile:' \
  '--token=[OAuth token]:token:' \
  '--cloud-id=[cloud ID]:id:' \
  '--folder-id=[folder ID]:id:' \
  '--folder-name=[folder name]:name:' \
  '--endpoint=[API endpoint]:url:' \
  '--format=[output format]:format:(json text yaml table)' \
  '--debug[enable debug]' \
  '--no-user-output[suppress user output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'yc subcommand' subcommands && ret=0
    ;;
esac

return ret
