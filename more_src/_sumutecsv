#compdef sumutecsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/windowing_sorting_muting/sumutecsv.c
# SUMUTECSV - mute above or below bilinearly interpolated polygonal curves

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'rfile=[read a K-file with grid definition]:f:_files' \
  'cdp=[CDPs for which mute times are specified]:c:' \
  'tims=[mute time values]:t:' \
  'offs=[offset values for mute]:o:' \
  'vel=[velocity values for mute]:v:' \
  'mode=[mute mode option]:m:' \
  'abs=[absolute value option]:a:' \
  'tzero=[time zero value]:t:' \
  'ntaper=[number of taper samples]:n:' \
  'offkey=[offset key name]:k:' \
  'extrapi=[extrapolation in igi direction]:e:' \
  'extrapc=[extrapolation in igc direction]:e:' \
  'extrapt=[extrapolation in time direction]:e:' \
  'check=[1 print checking details]:c:(0 1)' \
  'print=[print option]:p:' \
  '*:SU file:_files' && ret=0

return ret
