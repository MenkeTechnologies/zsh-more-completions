#compdef spark-r

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--master=[master URL]:url:' \
  '--deploy-mode=[deploy mode]:mode:(client cluster)' \
  '--name=[application name]:name:' \
  '--jars=[comma-separated jars]:jars:' \
  '--packages=[Maven coordinates]:packages:' \
  '--exclude-packages=[Maven excludes]:packages:' \
  '--repositories=[remote repositories]:repos:' \
  '--py-files=[zip/egg/py files]:files:_files' \
  '--files=[files for executor working dir]:files:_files' \
  '--archives=[archives for executor]:archives:_files' \
  {-c+,--conf=}'[Spark conf]:KEY=VALUE:' \
  '--properties-file=[properties file]:file:_files' \
  '--load-spark-defaults[load spark-defaults.conf]' \
  '--driver-memory=[driver memory]:size:' \
  '--driver-java-options=[driver Java options]:opts:' \
  '--driver-library-path=[driver library path]:path:' \
  '--driver-class-path=[driver classpath]:path:' \
  '--executor-memory=[executor memory]:size:' \
  '--proxy-user=[user to impersonate]:user:_users' \
  {-v,--verbose}'[verbose output]' \
  '--remote=[Spark Connect URL]:url:' \
  '--driver-cores=[cluster mode driver cores]:n:' \
  '--supervise[restart driver on failure]' \
  '--kill=[kill submission]:submission-id:' \
  '--status=[query submission status]:submission-id:' \
  '--total-executor-cores=[total executor cores]:n:' \
  '--executor-cores=[cores per executor]:n:' \
  '--num-executors=[number of executors]:n:' \
  '--principal=[Kerberos principal]:principal:' \
  '--keytab=[Kerberos keytab]:file:_files' \
  '*:R script:_files -g "*.R"' && ret=0

return ret
