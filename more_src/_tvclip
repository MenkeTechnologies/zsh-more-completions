#compdef tvclip
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/tvclip.html
# MIRIAD: interactive baseline editing of a UV dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'vis=[input UV dataset]:vis:_files' \
  'server=[TV server]:server:' \
  'tvchan=[TV channel number]:tvchan:' \
  'range=[min and max scaling values]:range:' \
  'tvcorn=[lower-left corner device coords]:tvcorn:' \
  'line=[channel or wide line type]:line:' \
  'mode=[display type]:mode:(amplitude phase real imaginary)' \
  'taver=[time averaging window in minutes]:taver:' \
  'clip=[clipping threshold in abs deviations]:clip:' \
  'options=[nochannel,notime,nopixel,notv,nosrc]:options:(nochannel notime nopixel notv nosrc)' \
  'commands=[non-interactive command sequence]:commands:' \
  'select=[visibility selection]:select:' \
  '*:image:_files' && ret=0

return ret
