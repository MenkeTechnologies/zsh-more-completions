#compdef k3sup

_k3sup_commands() {
  local -a commands=(
    'install:install k3s on a server'
    'join:join a node to a k3s cluster'
    'update:update a k3s installation'
    'plan:plan a k3s cluster'
    'ready:check if a cluster is ready'
    'node-token:get the node join token'
    'completion:generate shell completion'
    'version:print version'
  )
  _describe 'command' commands
}

_k3sup() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '-h[display help]' \
    '--help[display help]' \
    '1:command:_k3sup_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        install)
          _arguments \
            '--ip[server IP address]:ip' \
            '--user[SSH user]:user' \
            '--ssh-key[path to SSH key]:file:_files' \
            '--ssh-port[SSH port]:port' \
            '--sudo[use sudo for installation]' \
            '--cluster[initialize a new cluster]' \
            '--context[kubeconfig context name]:name' \
            '--k3s-version[k3s version to install]:version' \
            '--k3s-extra-args[extra args for k3s]:args' \
            '--local-path[local kubeconfig path]:file:_files' \
            '--merge[merge into existing kubeconfig]' \
            '--tls-san[additional TLS SAN]:hostname' \
            '--no-extras[skip installing extras]' \
            '--print-command[print the command instead of running]'
          ;;
        join)
          _arguments \
            '--ip[agent IP address]:ip' \
            '--server-ip[server IP address]:ip' \
            '--user[SSH user]:user' \
            '--ssh-key[path to SSH key]:file:_files' \
            '--ssh-port[SSH port]:port' \
            '--sudo[use sudo for installation]' \
            '--server[join as server node]' \
            '--k3s-version[k3s version to install]:version' \
            '--k3s-extra-args[extra args for k3s]:args' \
            '--print-command[print the command instead of running]'
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_k3sup "$@"
