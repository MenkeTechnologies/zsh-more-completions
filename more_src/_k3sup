#compdef k3sup
# Documentation: https://github.com/alexellis/k3sup/blob/master/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: removed fabricated 'completion' subcommand
# (k3sup has none); added real get-config subcommand; added real
# install flags --host/--k3s-channel/--datastore/--token/--local/
# --skip-install/--ipsec and join flags --server-host/--server-user/
# --server-ssh-port/--k3s-channel.

_k3sup_commands() {
  local -a commands=(
    'install:install k3s on a server via SSH'
    'join:install the k3s agent on a remote host and join it to an existing server'
    'update:print update instructions'
    'plan:plan an installation given a JSON file from "k3sup get"'
    'ready:check if the cluster is ready'
    'node-token:get the node join token from a server'
    'get-config:fetch the kubeconfig from a server'
    'version:print the version'
  )
  _describe 'command' commands
}

_k3sup() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '(-h --help)'{-h,--help}'[display help]' \
    '1:command:_k3sup_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        install)
          _arguments \
            '--ip=[public IP of the server]:ip' \
            '--host=[public hostname of the server]:host' \
            '--user=[username for SSH login]:user' \
            '--ssh-key=[path to the SSH private key]:file:_files' \
            '--ssh-port=[SSH port for the server]:port' \
            '--sudo[use sudo for installation (default true)]' \
            '--cluster[start this server in clustering mode (embedded etcd)]' \
            '--context=[kubeconfig context name]:name' \
            '--k3s-version=[set a version to install]:version' \
            '--k3s-channel=[release channel: stable, latest, or pinned]:channel:' \
            '--k3s-extra-args=[additional args to pass to k3s installer]:args' \
            '--local-path=[local path to save the kubeconfig]:file:_files' \
            '--merge[merge the config with an existing kubeconfig]' \
            '--tls-san=[use an additional IP or hostname for the API server TLS cert]:san' \
            '--no-extras[disable installation of traefik and servicelb]' \
            '--print-command[print the command sent over SSH]' \
            '--datastore=[connection string for an external datastore]:dsn' \
            '--token=[token to use for the server and agents]:token' \
            '--local[perform a local install without SSH]' \
            '--skip-install[skip the k3s installer, useful for kubeconfig only]' \
            '--ipsec[enforce IPSec networking for Flannel]'
          ;;
        join)
          _arguments \
            '--ip=[public IP of the new agent]:ip' \
            '--host=[public hostname of the new agent]:host' \
            '--server-ip=[public IP of an existing k3s server]:ip' \
            '--server-host=[public hostname of an existing k3s server]:host' \
            '--user=[username for SSH login to the agent]:user' \
            '--server-user=[username for SSH login to the server]:user' \
            '--ssh-key=[path to the SSH private key]:file:_files' \
            '--ssh-port=[SSH port for the agent]:port' \
            '--server-ssh-port=[SSH port for the server]:port' \
            '--sudo[use sudo for installation (default true)]' \
            '--server[join the new node as a server instead of an agent]' \
            '--k3s-version=[set a version to install]:version' \
            '--k3s-channel=[release channel: stable, latest, or pinned]:channel:' \
            '--k3s-extra-args=[additional args to pass to k3s installer]:args' \
            '--print-command[print the command sent over SSH]'
          ;;
        ready)
          _arguments \
            '--context=[kubeconfig context name]:name' \
            '--kubeconfig=[path to the kubeconfig file]:file:_files'
          ;;
      esac
      ;;
  esac
}

_k3sup "$@"
