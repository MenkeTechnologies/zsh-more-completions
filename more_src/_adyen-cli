#compdef adyen-cli adyen
# _adyen-cli — Adyen adyen-cli CLI command-line frontend wrapping the Adyen global payments platform REST API managing payments authorizations captures refunds reversals stores merchants accounts terminals report generation account-holders transfers payouts kyc legal-entity-management transactions disputes notifications (Adyen team, Go); cobra
# upstream: https://www.adyen.com/

_adyen-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'payment:payment operations'
        'authorization:authorization operations'
        'capture:capture operations'
        'refund:refund operations'
        'reversal:reversal operations'
        'store:store operations'
        'merchant:merchant operations'
        'account:account operations'
        'terminal:terminal operations'
        'report:report operations'
        'account-holder:account holder operations'
        'transfer:transfer operations'
        'payout:payout operations'
        'kyc:KYC operations'
        'legal-entity:legal entity management'
        'transaction:transaction operations'
        'dispute:dispute operations'
        'notification:notification webhooks'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--merchant-account=+[name]:str:' \
        '--environment=+[e]:e:(live test)' \
        '--api-version=+[v]:v:(v68 v69 v70 v71)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'adyen-cli subcommand' sub ;;
        args)
            case $words[1] in
                payment|authorization|capture|refund|reversal|store|merchant|account|terminal|report|account-holder|transfer|payout|kyc|legal-entity|transaction|dispute|notification) _arguments '1:op:(list get create update delete cancel close approve)' '*:id:' ;;
            esac
            ;;
    esac
}

_adyen-cli "$@"
