#compdef CollectIndependentReplicateMetrics
# Documentation: https://github.com/broadinstitute/picard/blob/master/src/main/java/picard/analysis/replicates/CollectIndependentReplicateMetrics.java
# Estimates the rate of independent replication of reads within a bam

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--INPUT -I)'{--INPUT,-I}'=[input indexed BAM/CRAM file]:value:_files' \
  '(--OUTPUT -O)'{--OUTPUT,-O}'=[write metrics to this file]:value:_files' \
  '(--MATRIX_OUTPUT -MO)'{--MATRIX_OUTPUT,-MO}'=[write the confusion matrix to this file]:value:_files' \
  '(--VCF -V)'{--VCF,-V}'=[input VCF file]:value:_files' \
  '(--SAMPLE -SA)'{--SAMPLE,-SA}'=[name of sample to look at in VCF]:value:' \
  '-GQ=[minimal GQ field value]:value:' \
  '-MQ=[minimal read mapping quality]:value:' \
  '-BQ=[minimal base quality]:value:' \
  '-MBQ=[minimal molecular barcode base quality]:value:' \
  '-FUR=[filter unpaired reads]:value:(true false)' \
  '--STOP_AFTER=[number of sets to examine before stopping]:value:' \
  '--BARCODE_TAG=[barcode SAM tag]:value:' \
  '--BARCODE_BQ=[barcode quality SAM tag]:value:' \
  '--PROGRESS_STEP_INTERVAL=[interval between progress displays]:value:' \
  '*:argument:_files' && ret=0

return ret
