#compdef rsgisbatchconvert2cog
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisbatchconvert2cog RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[A search string where for the input files (e.g., '\''./images/*.kea'\''). The search string much contain at least one * wildcard.]:value:_files' \
  '(-o --output)'{-o,--output}'[Output directory where output COG (i.e., GTIFF) files will be written.]:value:_files' \
  '--chkimgs[Only convert images which are not already]' \
  '(-b --byte)'{-b,--byte}'[Convert the output image data type to Byte.]' \
  '(-d --deflate)'{-d,--deflate}'[Use deflate compression.]' \
  '*:file:_files' && ret=0

return ret
