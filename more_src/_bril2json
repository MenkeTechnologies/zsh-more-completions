#compdef bril2json
# ============================================================================
# _bril2json — zsh completion for Bril's text → JSON parser
#              (Cornell's educational compiler IR;  152nd language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/sampsyo/bril
#   Author     : Adrian Sampson (sampsyo) and the CS 6120 community,
#                Cornell University
#   License    : MIT
#   Stars      : 764
#   Language   : Rust  (this binary;  Bril proper is implementation-
#                       agnostic — there are TypeScript, OCaml, Rust,
#                       Swift, and LLVM front-/back-ends in the same
#                       repo under bril-ts/, bril-ocaml/, bril-rs/,
#                       bril-swift/, and bril-llvm/)
#   Crate      : bril2json v0.1.0  (workspace member under bril-rs/)
#   Binary     : bril2json
#   Last push  : 2026-05-18
#
# WHAT IT IS
#   Bril is "an educational compiler intermediate representation" —
#   a deliberately tiny, JSON-first IR designed by Adrian Sampson for
#   Cornell's CS 6120 graduate compilers course.  Bril programs are
#   stored as JSON documents (one function-per-element with named
#   labels, typed instructions, and explicit operand lists), so
#   students can build new passes without writing a parser.  A human-
#   readable text representation (`.bril` files) exists as a courtesy;
#   `bril2json` is the LALR-parsed text-to-JSON pipeline that
#   normalizes those `.bril` files into the canonical JSON form that
#   every downstream Bril tool consumes.  The complementary
#   `bril2txt` (in the Python `bril-txt/` directory) goes the other
#   direction.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bril-rs/bril2json/src/cli.rs
#                       clap-derive Cli struct + bril-rs/bril2json/
#                       src/main.rs Cli::parse driver)
#   bril2json [-f <FILE>] [-p]...
#
#   Options:
#     -f, --file <FILE>     The Bril text file to statically parse.
#                           If omitted, stdin is read.
#     -p                    Include position information in the
#                           emitted JSON  (repeatable count, via
#                           `clap::ArgAction::Count`):
#                             no flag → no position info
#                             -p       → line/column position info
#                             -pp+     → full source-range position
#                                        info (start + end)
#
#   Standard clap auto-flags (from `#[command(about, version,
#                                            author)]`):
#     -h, --help            Show help
#     -V, --version         Show version
#
# LANGUAGE-CORPUS POSITION
#   Bril is the 152nd programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R877
#   (_openwecd / rdkafka 0.37.0 Rust=127 OPENS Axis 72 Apache Kafka
#   Client Library) and continued through R878 (_kafy /
#   confluentinc/confluent-kafka-go/v2 v2.11.1 Go=127) and R879
#   (_openhim-core / kafkajs ^2.2.4 TS-Node=127 CLOSES Axis 72 at
#   1/1/1 three-language symmetry — triple-127 landmark and 65th
#   axis closed).  Round-number R880 landmark on commit.  Bril joins
#   Vyxal (R876 151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th), Mochi
#   (R860 147th), Oden (R856 146th), Hop (R852 145th), Lustre via
#   Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ (R840 142nd),
#   Granule (R836 141st), Sixten (R832 140th), Imba (R828 139th),
#   Tao (R824 138th), Dada (R820 137th), Acton (R816 136th), and
#   Stanza (R812 135th).
#
#   No completion for `bril2json` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_bril2json() {
    _arguments -s \
        '(-f --file)'{-f+,--file=}'[Bril text file to parse (stdin if omitted)]:bril file:_files -g "*.bril"' \
        '*-p[include position info (-p line/col, -pp full source range)]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_bril2json "$@"
