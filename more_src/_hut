#compdef hut

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'builds:manage builds.sr.ht'
  'git:manage git.sr.ht'
  'hg:manage hg.sr.ht'
  'lists:manage lists.sr.ht'
  'meta:manage meta.sr.ht'
  'pages:manage pages.sr.ht'
  'paste:manage paste.sr.ht'
  'todo:manage todo.sr.ht'
  'graphql:execute a GraphQL query'
  'init:initialize a project configuration'
  'help:show help for a command'
)

_arguments -s -S \
  '--instance=[SourceHut instance]:URL' \
  '--oauth2-token=[OAuth2 access token]:token' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      builds)
        local -a builds_cmds=(
          'submit:submit a build manifest'
          'list:list builds'
          'show:show build details'
          'cancel:cancel a running build'
          'resubmit:resubmit a build'
          'log:show build logs'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' builds_cmds && ret=0
        ;;
      git)
        local -a git_cmds=(
          'create:create a new repository'
          'delete:delete a repository'
          'list:list repositories'
          'show:show repository details'
          'update:update repository settings'
          'set-head:set the HEAD reference'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' git_cmds && ret=0
        ;;
      lists)
        local -a lists_cmds=(
          'create:create a new mailing list'
          'delete:delete a mailing list'
          'list:list mailing lists'
          'show:show mailing list details'
          'update:update mailing list settings'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' lists_cmds && ret=0
        ;;
      todo)
        local -a todo_cmds=(
          'create:create a new tracker'
          'delete:delete a tracker'
          'list:list trackers'
          'show:show tracker details'
          'ticket:manage tickets'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' todo_cmds && ret=0
        ;;
      paste)
        local -a paste_cmds=(
          'create:create a new paste'
          'delete:delete a paste'
          'list:list pastes'
          'show:show paste details'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'subcommand' paste_cmds && ret=0
        ;;
      graphql)
        _arguments \
          '1:service:(builds git hg lists meta pages paste todo)' \
          '2:query' && ret=0
        ;;
    esac
    ;;
esac

return ret
