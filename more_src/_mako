#compdef mako

# Zsh completion for mako - Wayland notification daemon

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--font[set font]:font' \
  '--background-color[set background color]:color' \
  '--text-color[set text color]:color' \
  '--width[set notification width]:pixels' \
  '--height[set max notification height]:pixels' \
  '--margin[set margin]:margin' \
  '--padding[set padding]:padding' \
  '--border-size[set border size]:pixels' \
  '--border-color[set border color]:color' \
  '--border-radius[set border radius]:pixels' \
  '--icons[enable/disable icons]:bool:(0 1)' \
  '--max-icon-size[set max icon size]:pixels' \
  '--icon-path[icon search path]:path:_files -/' \
  '--markup[enable/disable markup]:bool:(0 1)' \
  '--actions[enable/disable actions]:bool:(0 1)' \
  '--format[notification format string]:format' \
  '--default-timeout[default timeout in ms]:ms' \
  '--ignore-timeout[ignore notification timeout]:bool:(0 1)' \
  '--max-visible[max visible notifications]:count' \
  '--sort[sort criteria]:criteria:(-time +time -priority +priority)' \
  '--output[show on output]:output' \
  '--layer[layer to render on]:layer:(background bottom top overlay)' \
  '--anchor[position]:anchor:(top-left top-center top-right center-left center center-right bottom-left bottom-center bottom-right)' \
  '--group-by[group criteria]:criteria'
