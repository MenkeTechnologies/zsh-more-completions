#compdef jekyll

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'build:build your site'
      'clean:clean the site output'
      'doctor:search site for common problems'
      'help:show help'
      'new:create a new Jekyll site'
      'new-theme:create a new Jekyll theme'
      'serve:serve your site locally'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      build|serve)
        _arguments -s -S \
          '(-s --source)'{-s,--source}'[source directory]:directory:_directories' \
          '(-d --destination)'{-d,--destination}'[destination directory]:directory:_directories' \
          '--config=[config file]:file:_files -g "*.{yml,yaml}"' \
          '-w[watch for changes]' \
          '--watch[watch for changes]' \
          '--no-watch[do not watch]' \
          '--force-polling[force polling]' \
          '--future[publish posts with a future date]' \
          '--drafts[render posts in _drafts]' \
          '--unpublished[render unpublished posts]' \
          '-q[quiet output]' \
          '--quiet[quiet output]' \
          '-V[verbose output]' \
          '--verbose[verbose output]' \
          '--safe[safe mode]' \
          '--trace[show stack trace]' \
          '--lsi[use latent semantic indexing]' \
          '--incremental[enable incremental build]' \
          '-I[enable incremental build]' \
          '--strict-front-matter[fail on YAML errors]' \
          '--baseurl=[set base URL]:URL' \
          '--layouts=[layouts directory]:directory:_directories' \
          '--profile[profile site generation]' \
          '--limit-posts=[max posts to generate]:count' \
          '(- *)'{-h,--help}'[show help]' && ret=0

        if [[ ${words[1]} == serve ]]; then
          _arguments -s -S \
            '(-H --host)'{-H,--host}'[host to listen on]:host' \
            '(-P --port)'{-P,--port}'[port to listen on]:port' \
            '-o[open in browser]' \
            '--open-url[open in browser]' \
            '-l[enable live-reload]' \
            '--livereload[enable live-reload]' \
            '--livereload-port=[live-reload port]:port' \
            '--detach[detach from terminal]' \
            '--skip-initial-build[skip initial build]' \
            '--ssl-key=[SSL key]:file:_files' \
            '--ssl-cert=[SSL cert]:file:_files' && ret=0
        fi
        ;;
      new)
        _arguments -s -S \
          '--force[force creation]' \
          '--blank[create a blank site]' \
          '--skip-bundle[skip bundle install]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
