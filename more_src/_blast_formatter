#compdef blast_formatter
# BLAST+ tool to reformat results from a BLAST archive (-outfmt 11) or remote RID
# Flags from NCBI BLAST+ Command Line Applications User Manual (NBK569843)

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '(-archive)-rid=[BLAST request ID (RID) to format]:rid:' \
  '(-rid)-archive=[BLAST archive file (output of -outfmt 11)]:file:_files' \
  '-out=[output file name]:file:_files' \
  '-outfmt=[alignment view / output format]:format:' \
  '-html[produce HTML output]' \
  '-show_gis[show NCBI GIs in report]' \
  '-num_descriptions=[number of one-line descriptions to show]:int:' \
  '-num_alignments=[number of database sequences to show alignments for]:int:' \
  '-line_length=[line length for formatted alignments]:int:' \
  '-max_target_seqs=[number of aligned sequences to keep]:int:' \
  '-parse_deflines[parse query and subject bar-delimited sequence identifiers]' && ret=0

return ret
