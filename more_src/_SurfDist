#compdef SurfDist
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/SurfDist.html
# Compute distances between nodes on a surface (SUMA)

local ret=1

_arguments -s -S \
  '(-h -help -HELP)'{-h,-help,-HELP}'[show help]' \
  '-node_path_do[output shortest paths as SUMA objects]:file:_files' \
  '-Euclidean[straight-line distance instead of mesh]' \
  '-Euclidian[straight-line distance instead of mesh]' \
  '-graph[distance along mesh (default)]' \
  '-from_node[single starting node]:node:' \
  '-i[input surface]:surface:_files' \
  '-onestate[render all input surfaces simultaneously]' \
  '-anatomical[label surfaces as anatomically correct]' \
  '-sv[surface volume for coordinate alignment]:dataset:_files' \
  '-spec[load surface specification file]:spec:_files' \
  '-input[read input dataset]:dataset:_files' \
  '-n_mask[apply to specified node indices]:mask:_files' \
  '-b_mask[filter nodes using binary mask]:mask:_files' \
  '-c_mask[apply expression-based masking]:expr:' \
  '-novolreg[ignore volumetric transformations]' \
  '-noxform[ignore volumetric transformations]' \
  '-setenv[set environment variable]:env:' \
  '-trace[enable debug and memory tracing]' \
  '-TRACE[enable extreme tracing]' \
  '-nomall[disable memory tracing]' \
  '-yesmall[enable memory tracing (default)]' \
  '-h_view[open help in text editor]' \
  '-h_web[open help in web browser]' \
  '-h_find[search help for word]:word:' \
  '-all_opts[identify all program options]' \
  '*:surface:_files' && ret=0

return ret
