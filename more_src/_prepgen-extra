#compdef prepgen-extra
# Documentation: https://ambermd.org/doc12/Amber24.pdf
# AmberTools prepgen: generate a prep input file from an ac file

local ret=1

_arguments -s -S \
  '-i[input file name (ac)]:file:_files' \
  '-o[output file name]:file:_files' \
  '-f[output file format]:format:(car int)' \
  '-m[mainchain file name]:file:_files' \
  '-rn[residue name]:name:' \
  '-rf[residue file name]:file:_files' \
  '*:file:_files' && ret=0

return ret
