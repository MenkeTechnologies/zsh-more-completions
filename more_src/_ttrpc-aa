#compdef ttrpc-aa attestation-agent
# _ttrpc-aa — Confidential Containers guest attestation-agent ttRPC service
# upstream: https://github.com/confidential-containers/guest-components
# Flags from attestation-agent/attestation-agent/src/bin/ttrpc-aa.rs Cli on tip (clap).

_ttrpc-aa() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-a --attestation_sock)'{-a,--attestation_sock}'=[attestation ttRPC Unix socket addr (unix:///path)]:uri:' \
        '(-c --config_file)'{-c,--config_file}'=[attestation-agent config file]:file:_files' \
        '(-i --initdata_digest)'{-i,--initdata_digest}'=[base64 initdata digest to verify at startup]:b64:' \
        '(-t --initdata_toml)'{-t,--initdata_toml}'=[initdata TOML file to verify at startup]:file:_files'
}

_ttrpc-aa "$@"
