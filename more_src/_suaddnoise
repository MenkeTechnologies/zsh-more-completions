#compdef suaddnoise
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/noise/suaddnoise.c
# Add noise to traces

local ret=1

_arguments -s -S \
  'sn=[signal to noise ratio]:sn' \
  'noise=[noise probability distribution; gauss or flat]:noise:(gauss flat)' \
  'seed=[random number seed (integer)]:seed' \
  'f=[array of filter frequencies (as in sufilter)]:f' \
  'amps=[array of filter amplitudes]:amps' \
  'dt=[time sampling interval (sec)]:dt' \
  'verbose=[=1 for echoing useful information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for storing temporary files]:tmpdir:_files -/' \
  '*:file:_files' && ret=0

return ret
