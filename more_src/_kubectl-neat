#compdef kubectl-neat
# Documentation: https://github.com/itaysk/kubectl-neat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for kubectl-neat - kubectl output cleaner

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f,--file}'[file to neat]:file:_files' \
  '(-o --output)'{-o,--output}'[output format]:format:(yaml json)' \
  '*:file:_files'
