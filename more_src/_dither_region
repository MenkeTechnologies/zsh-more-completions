#compdef dither_region
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dither_region.html
# Compute fraction of region area that covers chips

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[aspect solution file(s) or aspect histogram file]:file:_files' \
  'region=[sky region to dither across the chip]:region:' \
  'outfile=[output file name]:file:_files' \
  'wcsfile=[file containing WCS information]:file:_files' \
  'maskfile=[mask file (msk1.fits) for the observation]:file:_files' \
  'psffile=[an image of the PSF]:file:_files' \
  'gtifile=[good time interval table]:file:_files' \
  'dtffile=[dead time factor file]:file:_files' \
  'imapfile=[stack of Instrument files]:file:_files' \
  'tolerance=[aspect solution tolerance (in arcsec)]:tolerance:' \
  'resolution=[resolution of sky region to evaluate fractions]:resolution:' \
  'maxpix=[maximum number of pixels to evaluate]:maxpix:' \
  'convex=[only convex hull points are analyzed]:convex:(yes no)' \
  'geompar=[Pixlib parameter file]:file:_files' \
  'ardlibpar=[Ardlib parameter file]:file:_files' \
  'detsubsysmod=[Ardlib detector sub-system modifier]:detsubsysmod:' \
  'verbose=[tool verbosity or chatter level]:verbose:(0 1 2 3 4 5)' \
  'clobber=[overwrite existing files]:clobber:(yes no)' && ret=0

return ret
