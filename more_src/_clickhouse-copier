#compdef clickhouse-copier

_arguments -s \
  '(- *)--help[show help]' \
  '--config-file=[config file]:file:_files -g "*.xml"' \
  '--task-path=[task path in ZK]:path:' \
  '--task-file=[task file]:file:_files' \
  '--task-upload-force[force task upload]' \
  '--base-dir=[base directory]:dir:_files -/' \
  '--daemon[run as daemon]' \
  '--safe-mode[safe mode]' \
  '--copy-fault-probability=[copy fault probability]:probability:' \
  '--move-fault-probability=[move fault probability]:probability:' \
  '--log-level=[log level]:level:(trace debug information warning error fatal)' \
  '--status[show status]' \
  '--experimental-use-sample-offset[use sample offset]' \
  '--max-table-tries=[max table tries]:n:' \
  '--max-shard-partition-tries=[max shard partition tries]:n:' \
  '--max-shard-partition-piece-tries-for-alter=[max shard partition piece tries for alter]:n:' \
  '--retry-delay-ms=[retry delay ms]:ms:'
