_vortix_commands() {
    local commands; commands=(
'up:Connect to a VPN profile' \
'connect:Connect to a VPN profile' \
'down:Disconnect from VPN' \
'disconnect:Disconnect from VPN' \
'reconnect:Reconnect to the last used VPN profile' \
'status:Show connection state and network telemetry' \
'list:List imported VPN profiles' \
'ls:List imported VPN profiles' \
'import:Import VPN profile(s) from a file, directory, or URL' \
'show:Display the configuration of a VPN profile' \
'delete:Delete a VPN profile' \
'rm:Delete a VPN profile' \
'rename:Rename a VPN profile' \
'mv:Rename a VPN profile' \
'killswitch:Get or set the kill switch mode' \
'release-kill-switch:Emergency release of kill switch firewall rules' \
'info:Show config directory, profile count, and runtime info' \
'update:Update vortix to the latest version from crates.io' \
'report:Generate a pre-filled bug report with system diagnostics' \
'completions:Generate shell completions for vortix' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'vortix commands' commands "$@"
}
