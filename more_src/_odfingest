#compdef odfingest
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/odfingest/node14.html
# Extend the ODF summary file with data from instrument housekeeping datasets

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--odfdir=[directory to look for the ODF files]:dir:_files -/' \
  '--withodfdir=[look for ODF files in odfdir, else use SAS_ODF]:bool:(yes no)' \
  '--outdir=[directory to write the summary file]:dir:_files -/' \
  '--summaryfile=[name of the summary file]:file:_files' \
  '--usecanonicalname=[auto-generate summary name from ODF identifier]:bool:(yes no)' \
  '--writepath=[write path to ODF in the summary file]:bool:(yes no)' \
  '--findinstrumentmodes=[determine the instrument modes]:bool:(yes no)' \
  '--usehousekeeping=[extract instrument params from housekeeping data]:bool:(yes no)' \
  '--oalcheck=[check via ODF Access Layer that the ODF is complete]:bool:(yes no)' \
  '*:param=value:_default' && ret=0

return ret
