#compdef jextract
# Documentation: https://github.com/openjdk/jextract/blob/master/doc/GUIDE.md
# jextract - generate Java FFM bindings from C header files

local ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '*'{-D,--define-macro}'=[define macro to value or 1]:macro:' \
  '--header-class-name=[name of the generated header class]:name:' \
  {-t,--target-package}'=[target package for generated classes]:package:' \
  '*'{-I,--include-dir}'=[append directory to the include search paths]:dir:_files -/' \
  '*'{-l,--library}'=[shared library to load]:library:' \
  '--use-system-load-library[load libraries via System.loadLibrary]' \
  '--output=[directory to place generated files]:dir:_files -/' \
  '--dump-includes=[dump included symbols into the named file]:file:_files' \
  '*--include-function=[include the named function]:function:' \
  '*--include-constant=[include the named constant]:constant:' \
  '*--include-struct=[include the named struct]:struct:' \
  '*--include-union=[include the named union]:union:' \
  '*--include-typedef=[include the named typedef]:typedef:' \
  '*--include-var=[include the named variable]:var:' \
  '--symbols-class-name=[override the name of the root header class]:name:' \
  '*-F-[framework search directory (macOS)]:dir:_files -/' \
  '*--framework=[library framework name (macOS)]:framework:' \
  '--version[print version information and exit]' \
  '*:header:_files -g "*.h"' && ret=0

return ret
