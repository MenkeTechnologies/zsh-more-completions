#compdef certoraRun
# _certora — Certora Prover for smart contract verification (Certora)
# upstream: https://docs.certora.com/

_certora() {
    _arguments -s -S \
        '--verify=[contract and spec to verify]:contract\:spec:' \
        '*--rule=[rules to verify]:rule:' \
        '--msg=[verification message]:message:' \
        '*--settings=[prover settings]:setting:' \
        '*--packages=[package path mappings]:mapping:' \
        '--solc=[Solidity compiler path]:compiler:_files' \
        '*--link=[contract linking]:link:' \
        '--optimistic_loop[assume loops terminate]' \
        '--loop_iter=[max loop iterations]:n:' \
        '--rule_sanity[enable rule sanity checks]:mode:(none basic advanced)' \
        '--multi_assert_check[check each assertion independently]' \
        '--short_output[shorter output format]' \
        '--help[show help]' \
        '*:solidity files:_files -g "*.sol"'
}

_certora "$@"
