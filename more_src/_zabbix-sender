#compdef zabbix-sender zabbix_sender
# Documentation: https://manpages.debian.org/trixie/zabbix-sender/zabbix_sender.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian trixie zabbix_sender(1) manpage.

# zabbix-sender: send data to Zabbix server/proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[read server details from agentd config]:file:_files' \
  '(-z --zabbix-server)'{-z,--zabbix-server=}'[server/proxy hostname or IP]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[server port (default 10051)]:port:' \
  '(-I --source-address)'{-I,--source-address=}'[source IP]:ip:' \
  '(-t --timeout)'{-t,--timeout=}'[timeout 1-300 seconds (default 60)]:seconds:' \
  '(-s --host)'{-s,--host=}'[host name as registered in frontend]:name:' \
  '(-k --key)'{-k,--key=}'[item key]:key:' \
  '(-o --value)'{-o,--value=}'[item value]:value:' \
  '(-i --input-file)'{-i,--input-file=}'[input file (- for stdin)]:file:_files' \
  '(-T --with-timestamps)'{-T,--with-timestamps}'[use timestamps in input file]' \
  '(-N --with-ns)'{-N,--with-ns}'[use nanoseconds (with --with-timestamps)]' \
  '(-r --real-time)'{-r,--real-time}'[send values immediately as received]' \
  '*'{-v,--verbose}'[verbose (-vv for more)]' \
  '--tls-connect=[TLS connection method]:method:(unencrypted psk cert)' \
  '--tls-ca-file=[CA certificate file]:file:_files' \
  '--tls-crl-file=[CRL file]:file:_files' \
  '--tls-server-cert-issuer=[expected server cert issuer]:issuer:' \
  '--tls-server-cert-subject=[expected server cert subject]:subject:' \
  '--tls-cert-file=[client cert file]:file:_files' \
  '--tls-key-file=[client key file]:file:_files' \
  '--tls-psk-identity=[PSK identity]:identity:' \
  '--tls-psk-file=[PSK file]:file:_files' \
  '--tls-cipher13=[TLS 1.3 cipher suites]:ciphers:' \
  '--tls-cipher=[TLS 1.2 cipher suites]:ciphers:' && ret=0
return ret
