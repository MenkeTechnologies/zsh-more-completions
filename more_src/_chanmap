#compdef chanmap
# Documentation: https://starlink.eao.hawaii.edu/devdocs/sun95.htx/sun95ss19.html
# KAPPA: produce a channel map from a cube NDF by collapsing along a nominated axis

local ret=1

_arguments -s \
  'IN=[input 3-d NDF]:ndf:_files -g "*.sdf"' \
  'OUT=[output NDF]:ndf:_files -g "*.sdf"' \
  'AXIS=[axis to collapse along]:axis' \
  'NCHAN=[number of channels in the map]:n' \
  'SHAPE=[number of channels along x axis of output]:n' \
  'LOW=[axis value at start of channel range]:value' \
  'HIGH=[axis value at end of channel range]:value' \
  'ESTIMATOR=[method for estimating collapsed values]:est:(Mean WMean Median Mode Max Min Comax Comin Absdev RMS Sigma Sum Iwc Iwd FBad FGood NBad NGood)' \
  'WLIM=[min fraction of good input pixels]:frac' \
  'CLIP=[std deviations for clipping outliers]:n' \
  'TITLE=[title for the output NDF]:title' \
  'USEAXIS=[which axes to retain]:axes' \
  '*:ndf:_files -g "*.sdf"' && ret=0

return ret
