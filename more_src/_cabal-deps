#compdef cabal-deps
# _cabal-deps — check project/package dependencies vs Hackage (phadej/cabal-extras)
# upstream: https://github.com/phadej/cabal-extras
# Flags from cabal-deps/src/CabalDeps/Main.hs (optparse-applicative).

_cabal-deps() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*'{-e+,--exclude=}'[package(s) to skip in report]:pkg:' \
        '--builddir=[build dir containing plan.json]:dir:_files -/' \
        '*:cabal file:_files -g "*.cabal"'
}

_cabal-deps "$@"
