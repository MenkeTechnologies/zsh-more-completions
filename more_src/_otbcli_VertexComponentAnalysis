#compdef otbcli_VertexComponentAnalysis
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VertexComponentAnalysis.html
# Orfeo ToolBox: extract endmembers from a hyperspectral image via VCA

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-in[input hyperspectral data cube]:image:_files' \
  '-outendm[output endmembers as a one-line image]:output:_files' \
  '-ne[number of endmembers to extract]:value:' \
  '-rand[specific random seed value]:value:' \
  '*::arg:_files' && ret=0

return ret
