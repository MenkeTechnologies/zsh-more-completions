#compdef cqrlog
# Documentation: https://man.archlinux.org/search?q=cqrlog
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d+[debug level]:lvl:' \
  '-c+[config file]:file:_files' && ret=0

return ret
