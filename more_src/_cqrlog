#compdef cqrlog
# Documentation: https://github.com/ok2cqr/cqrlog/blob/master/src/cqrlog.lpr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# cqrlog: amateur radio logging program

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --remote)'{-r+,--remote=}'[remote mode key]:key:(J M K)' \
  '--debug=[debug verbosity level]:level:' && ret=0

return ret
