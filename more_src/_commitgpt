#compdef commitgpt
# Documentation: https://github.com/RomanHotsiy/commitgpt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# commitgpt does not document explicit CLI flags beyond `npx commitgpt`;
# behavior is configured via .commitgpt.json and .commitgpt-template files.

_commitgpt() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:file:_files'
}

_commitgpt "$@"
