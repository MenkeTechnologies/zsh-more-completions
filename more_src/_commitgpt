#compdef commitgpt
# Documentation: https://man.archlinux.org/search?q=commitgpt
# Reference accessed: 2026-05-16

_commitgpt() {
    _arguments \
        '(-s --suggestions)'{-s,--suggestions}'[Number of suggestions to generate]:number:' \
        '(-t --tokens)'{-t,--tokens}'[Maximum tokens for the message]:number:' \
        '(-h --help)'{-h,--help}'[Show help]'
}

_commitgpt "$@"
