#compdef bowtie2
# Documentation: https://bowtie-bio.sourceforge.net/bowtie2/manual.shtml
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# bowtie2 - ultrafast short read aligner

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-x[index basename]:basename:' \
  '-1[mate 1 reads]:file:_files' \
  '-2[mate 2 reads]:file:_files' \
  '-U[unpaired reads]:file:_files' \
  '-S[output SAM file]:file:_files' \
  '--end-to-end[entire read must align (default)]' \
  '--local[local alignment, allow soft clipping]' \
  '(-p --threads)'{-p,--threads}'=[parallel search threads]:n:' \
  '--reorder[reorder output to match input]' \
  '--mm[memory-mapped index I/O]' \
  '-k[report up to N alignments per read]:n:' \
  '-a[report all alignments]' \
  '(-t --time)'{-t,--time}'[print wall-clock time]' \
  '--quiet[suppress non-error output]' \
  '*:args:_files'
