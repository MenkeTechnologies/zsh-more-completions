#compdef ddcctl
# Documentation: https://man.archlinux.org/search?q=ddcctl
# Reference accessed: 2026-05-16

# https://github.com/kfix/ddcctl — OS X DDC/CI monitor control (usage from README)
_arguments -s -S \
  '-h[help]' \
  '-d=-[display ID]:id:' \
  '-m=-[mute 1|0]:bool:' \
  '-v=-[volume 0–100 or step]:val:' \
  '-i=-[brightness]:n:' \
  '-c=-[contrast]:n:' \
  '-p[dump EDID]' \
  '-V[show supported commands]' \
  '*:unused:_default'
