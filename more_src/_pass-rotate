#compdef pass-rotate
# Documentation: https://git.sr.ht/~sircmpwn/pass-rotate (archived snapshot)
# Reference accessed: 2026-05-16
# Verified: web.archive.org snapshot of git.sr.ht/~sircmpwn/pass-rotate (2021).

# pass-rotate: bulk rotate passwords for online services
local curcontext="$curcontext" ret=1
_arguments -C \
  '--list-accounts[print all configured accounts]' \
  '--list-providers[print all supported providers]' \
  '--list-options=[print options for provider]:provider:' \
  '--config=[alternate config file]:file:_files' \
  '*:accounts:' && ret=0
return ret
