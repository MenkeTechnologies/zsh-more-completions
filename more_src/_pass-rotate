#compdef pass-rotate
# Documentation: https://sr.ht/~sircmpwn/pass-rotate/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pass-rotate: bulk rotate passwords for online services
local curcontext="$curcontext" ret=1
_arguments -C \
  '--list-accounts[print all configured accounts]' \
  '--list-providers[print all supported providers]' \
  '--list-options=[print options for provider]:provider:' \
  '--config=[alternate config file]:file:_files' \
  '*:accounts:' && ret=0
return ret
