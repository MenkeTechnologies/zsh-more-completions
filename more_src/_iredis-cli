#compdef iredis
# Documentation: https://man.archlinux.org/search?q=iredis
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '-H+[host]:host:_hosts' \
  '--host=[host]:host:_hosts' \
  '-p+[port]:port:' \
  '--port=[port]:port:' \
  '-s+[unix socket]:file:_files' \
  '--socket=[unix socket]:file:_files' \
  '-a+[password]:p:' \
  '--password=[password]:p:' \
  '--username=[username]:u:_users' \
  '-u+[URL]:url:' \
  '--url=[URL]:url:' \
  '-n+[db number]:n:' \
  '--db=[db number]:n:' \
  '--auth-provider=[auth provider]:p:' \
  '-c[cluster mode]' \
  '--encode=[encoding]:e:' \
  '--encoding=[encoding]:e:' \
  '--decode=[decoding]:d:' \
  '--no-info[no info]' \
  '--newbie[newbie mode]' \
  '--iredisrc=[config file]:file:_files' \
  '--no-config[no config]' \
  '--prompt=[prompt]:s:' \
  '--logfile=[log file]:file:_files' \
  '--history-location=[history file]:file:_files' \
  '--no-shell[no shell completer]' \
  '--shell[shell completer]' \
  '--no-pager[no pager]' \
  '--pager=[pager]:c:' \
  '--no-version-reminder[no version reminder]' \
  '--bottom-toolbar[show bottom toolbar]' \
  '--no-bottom-toolbar[no bottom toolbar]' \
  '--enable-shell[enable shell exec]' \
  '--disable-shell[disable shell]' \
  '--socket-keepalive[keepalive]' \
  '--socket-timeout=[s]:s:' \
  '--retry-on-timeout[retry on timeout]' \
  '--connection-pool[use connection pool]' \
  '--ssl[use SSL]' \
  '--ssl-keyfile=[key file]:file:_files' \
  '--ssl-certfile=[cert file]:file:_files' \
  '--ssl-cert-reqs=[reqs]:r:(none optional required)' \
  '--ssl-ca-certs=[CA certs]:file:_files' \
  '--ssl-check-hostname[check hostname]' \
  '*: :' && ret=0

return ret
