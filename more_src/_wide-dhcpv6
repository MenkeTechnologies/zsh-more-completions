#compdef dhcp6s dhcp6c dhcp6relay dhcp6ctl
# _wide-dhcpv6 — WIDE-DHCPv6 project Kazu Yamamoto wide-dhcpv6 reference DHCPv6 server client and relay agents (wide-dhcpv6 team, C); getopt
# upstream: https://sourceforge.net/projects/wide-dhcpv6/

_wide-dhcpv6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "dhcp6s.conf dhcp6c.conf *.conf"' \
        '-d[debug mode]' \
        '-D[more debug]' \
        '-f[run in foreground]' \
        '-k+[control key file]:file:_files' \
        '-l+[lease file]:file:_files' \
        '-p+[pid file]:file:_files' \
        '-P+[control port]:port:_ports' \
        '-r+[control receive port]:port:_ports' \
        '-Q+[reqlist file]:file:_files' \
        '-i+[duid identifier]:str:' \
        '-x[no exit on config errors]' \
        '*:interface:'
}

_wide-dhcpv6 "$@"
