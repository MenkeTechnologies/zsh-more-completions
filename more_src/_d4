#compdef d4
# Documentation: https://github.com/crillab/d4
# d4 model counter and decision-DNNF compiler

local ret=1

_arguments -s -S \
  '--help[display usage information]' \
  '-mc[run the model counter]' \
  '-dDNNF[compile to decision-DNNF representation]' \
  '-out=[output file for decision-DNNF results]:output file:_files' \
  '-drat=[generate certified decision-DNNF with DRAT proof]:drat file:_files' \
  '*:dimacs file:_files' && ret=0

return ret
