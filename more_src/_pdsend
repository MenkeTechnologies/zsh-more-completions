#compdef pdsend
# Documentation: https://github.com/pure-data/pure-data/blob/master/src/u_pdsend.c
# Reference accessed: 2026-05-27
# Verified: upstream pure-data/pure-data master branch src/u_pdsend.c argv parsing

# Usage: pdsend <portnumber> [host] [udp|tcp] [timeout(s)]
# pdsend is a purely positional CLI with no flags.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:portnumber:' \
  '2:hostname:_hosts' \
  '3:protocol:(tcp udp)' \
  '4:timeout-seconds:' && ret=0

return ret
