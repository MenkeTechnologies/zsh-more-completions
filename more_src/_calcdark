#compdef calcdark
# Documentation: https://starlink.eao.hawaii.edu/docs/sun258.htx/sun258ss2.html
# SMURF: calculate the 2d dark frame from dark observation.

local ret=1

_arguments -s -S \
  'IN=[input files to process]:ndf:_files' \
  'OUT=[output dark files]:ndf:_files' \
  'BBM=[bad bolometer mask files]:ndf:_files' \
  'MSG_FILTER=[message verbosity]:level:(NONE QUIET NORMAL VERBOSE DEBUG ALL)' \
  '*:ndf:_files' && ret=0

return ret
