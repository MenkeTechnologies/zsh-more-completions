#compdef corscanner cors
# Documentation: https://github.com/chenjj/CORScanner
# CORScanner - fast CORS misconfiguration scanner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --url)'{-u,--url}'[URL/domain to check its CORS policy]:url:' \
  '(-d --headers)'{-d,--headers}'[add headers to the request]:headers:' \
  '(-i --input)'{-i,--input}'[URL/domain list file to check]:file:_files' \
  '(-t --threads)'{-t,--threads}'[number of threads to use]:threads:' \
  '(-o --output)'{-o,--output}'[save the results to json file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode, display results in realtime]' \
  '(-T --timeout)'{-T,--timeout}'[set requests timeout (default 10 sec)]:seconds:' \
  '(-p --proxy)'{-p,--proxy}'[enable proxy (http or socks5)]:proxy:' \
  '*:url:' && ret=0

return ret
