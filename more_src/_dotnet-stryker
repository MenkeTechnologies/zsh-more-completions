#compdef dotnet-stryker
# Documentation: https://stryker-mutator.io/docs/stryker-net/configuration/
# dotnet-stryker - mutation testing for .NET

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display version information]' \
  '(-s --solution)'{-s,--solution}'=[solution file path for dependency resolution]:file:_files -g "*.sln"' \
  '(-p --project)'{-p,--project}'=[project file name to mutate]:file:_files' \
  '(-tp --test-project)'{-tp,--test-project}'=[test project path]:file:_files' \
  '(-f --config-file)'{-f,--config-file}'=[custom config file location]:file:_files' \
  '--target-framework=[specific framework when multi-targeting]:tfm:' \
  '--configuration=[build configuration]:config:(Debug Release)' \
  '*'{-m,--mutate}'=[file patterns to mutate]:glob:' \
  '(-l --mutation-level)'{-l,--mutation-level}'=[mutation level]:level:(Basic Standard Advanced Complete)' \
  '--language-version=[C# language version]:version:' \
  '(-c --concurrency)'{-c,--concurrency}'=[number of parallel workers]:n:' \
  '(-t --test-runner)'{-t,--test-runner}'=[test runner]:runner:(vstest mtp)' \
  '--disable-bail[run all tests per mutant instead of stopping early]' \
  '--since=[test only code changed since target]:committish:' \
  '(-r --reporter)'{-r,--reporter}'=[reporter type]:reporter:(html json progress dashboard cleartext)' \
  '(-o --open-report)'{-o,--open-report}'=[auto-open the report]:type:(html dashboard)' \
  '(-O --output)'{-O,--output}'=[output directory for reports]:dir:_files -/' \
  '--threshold-high=[high mutation score threshold]:n:' \
  '--threshold-low=[low mutation score threshold]:n:' \
  '(-b --break-at)'{-b,--break-at}'=[exit code 1 if score below threshold]:n:' \
  '(-V --verbosity)'{-V,--verbosity}'=[log verbosity]:level:(error warning info debug trace)' \
  '(-L --log-to-file)'{-L,--log-to-file}'[write detailed logs to file]' \
  '--dev-mode[enable development mode with extra logging]' \
  '--skip-version-check[skip the version update check]' \
  '--dashboard-api-key=[API key for the Stryker Dashboard]:key:' \
  '--with-baseline=[enable baseline comparison]:committish:' \
  '1:command:(init)' && ret=0

return ret
