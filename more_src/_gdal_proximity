#compdef gdal_proximity

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-b+[source band]:band:' \
  '-srcband+[source band]:band:' \
  '-dstband+[destination band]:band:' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-ot+[output type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 Float32 Float64)' \
  '*-values+[target pixel values]:values:' \
  '-distunits+[distance units]:units:(GEO PIXEL)' \
  '-maxdist+[maximum distance]:value:' \
  '-nodata+[nodata value]:value:' \
  '-use_input_nodata+[use input nodata]:flag:(YES NO)' \
  '-fixed-buf-val+[fixed buffer value]:value:' \
  '1:source raster:_files' \
  '2:destination raster:_files' && ret=0

return ret
