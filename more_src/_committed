#compdef committed

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--config=[path to config file]:config file:_files' \
  '--no-merge-commit[disallow merge commits]' \
  '--merge-commit[allow merge commits]' \
  '--no-fixup-commit[disallow fixup commits]' \
  '--fixup-commit[allow fixup commits]' \
  '--no-wip-commit[disallow WIP commits]' \
  '--wip-commit[allow WIP commits]' \
  '--imperative-subject[require imperative mood in subject]' \
  '--no-imperative-subject[do not require imperative mood]' \
  '--subject-length=[maximum subject line length]:length' \
  '--line-length=[maximum body line length]:length' \
  '--hard-line-length=[hard maximum body line length]:length' \
  '--no-subject-punctuation[disallow subject trailing punctuation]' \
  '--subject-punctuation[allow subject trailing punctuation]' \
  '--conventional[enforce conventional commit format]' \
  '--no-conventional[do not enforce conventional format]' \
  '--allowed-types=[comma-separated allowed conventional types]:types' \
  '--dump-config=[dump effective config]:format:(toml)' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '*:commit range or path:_files' && ret=0

return ret
