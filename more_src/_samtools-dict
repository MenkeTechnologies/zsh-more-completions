#compdef samtools-dict
# Documentation: http://www.htslib.org/doc/samtools-dict.html
# samtools dict: Create a sequence dictionary file from a fasta file

local ret=1

_arguments -s -S \
  '(-a --assembly)'{-a,--assembly}'[Specify the assembly for the AS tag.]:STR: ' \
  '(-A --alias --alternative-name)'{-A,--alias,--alternative-name}'[Add an AN tag with the same value as the SN tag, except that a “chr” p]' \
  '(-H --no-header)'{-H,--no-header}'[Do not print the @HD header line.]' \
  '(-l --alt)'{-l,--alt}'[Add an AH tag to each sequence listed in the specified bwa (1)-style .]:FILE:_files' \
  '(-o --output)'{-o,--output}'[Output to FILE \[stdout\].]:FILE:_files' \
  '(-s --species)'{-s,--species}'[Specify the species for the SP tag.]:STR: ' \
  '(-u --uri)'{-u,--uri}'[Specify the URI for the UR tag. Defaults to the absolute path of ref.f]:STR: ' \
  '*:file:_files' && ret=0

return ret
