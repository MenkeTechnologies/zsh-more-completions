# WHAT IT IS
#   `gosky` is the **canonical client + operator CLI for the AT
#   Protocol** — the Go-side counterpart to the TypeScript
#   reference client in `bluesky-social/atproto/packages/api`
#   and the Rust SDK at `sugyan/atrium`.  It speaks every AT
#   Protocol XRPC method directly to a configurable PDS host
#   (`--pds-host`) or BGS relay, signs requests with an account
#   session loaded from a JSON auth file (`--auth`), resolves
#   handles + DIDs against a configurable PLC directory
#   (`--plc`), and exposes 16 top-level subcommand families
#   covering the full AT Protocol surface:
#
#     • Account lifecycle  (`account create-session`,
#       `account new`, `account refresh-session`,
#       `account reset-password`, `account request-deletion`,
#       `account delete`)
#
#     • Bluesky-specific operations  (`bsky follow`,
#       `bsky list-follows`, `bsky post`, `bsky get-feed`,
#       `bsky actor-get-suggestions`, `bsky like`,
#       `bsky delete-post`, `bsky notifs`)
#
#     • PDS / BGS admin  (`admin check-user`,
#       `admin build-invite-tree`, `admin reports list`,
#       `admin disable-invites`, `admin enable-invites`,
#       `admin list-invite-tree`, `admin account-takedown`;
#       `bgs list`, `bgs kick`, `bgs list-domain-bans`,
#       `bgs ban-domain`, `bgs take-down-repo`,
#       `bgs set-accept-subs`, `bgs compact-repo`,
#       `bgs compact-all`, `bgs reset-repo`,
#       `bgs set-trusted-domain`)
#
#     • CAR archive handling  (`car unpack`)
#
#     • Firehose + repo debugging  (`debug inspect-event`,
#       `debug debug-stream`, `debug compare-streams`,
#       `debug debug-feed`, `debug view-feed`,
#       `debug get-repo`, `debug compare-repos`;
#       `read-stream <repo> [cursor]`)
#
#     • DID + handle resolution  (`did get`, `did did-key`;
#       `handle resolve`, `handle update`)
#
#     • Repo sync  (`sync get-repo`, `sync get-root`,
#       `sync list-repos`)
#
#     • Feed generator + label tooling  (`create-feed-gen`,
#       `get-record`, `list`, `list-labels`, `parse-rkey`,
#       `verify-user`)
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/gosky/{main.go,
#                       account.go, admin.go, bsky.go, bgs.go,
#                       car.go, debug.go, did.go, handle.go,
#                       sync.go} urfave/cli/v2 `cli.Command`
#                       registrations; extracted via raw.
#                       githubusercontent.com fetch of every
#                       command file)
#
#   gosky [GLOBAL OPTIONS] <command> [subcommand] [options...]
#
#   Global options:
#     -h, --help                     Show help
#     -v, --version                  Print version
#     --pds-host <URL>               PDS endpoint
#                                    [default: https://bsky.social]
#                                    [env: ATP_PDS_HOST]
#     --auth <PATH>                  Path to JSON file with ATP
#                                    auth info
#                                    [default: bsky.auth]
#                                    [env: ATP_AUTH_FILE]
#     --plc <URL>                    PLC registry endpoint
#                                    [default: https://plc.directory]
#                                    [env: ATP_PLC_HOST]
#     --log-level <LEVEL>            Log verbosity
#                                    [default: info]
#                                    [values: debug, info, warn,
#                                     error]
#                                    [env: GOSKY_LOG_LEVEL,
#                                          LOG_LEVEL,
#                                          BSKYLOG_LOG_LEVEL,
#                                          GOLOG_LOG_LEVEL]
#
#   Commands:
#     account create-session         Create a session against the
#                                    configured PDS
#     account new                    Create a new account
#     account refresh-session        Refresh session credentials
#     account reset-password         Reset account password
#     account request-deletion       Request account deletion
#     account delete                 Confirm account deletion
#     admin check-user [--raw] [--list-invited-dids]
#     admin build-invite-tree [--invite-list <PATH>]
#                             [--top <N>]
#     admin reports list [--raw] [--resolved] [--template-output]
#     admin disable-invites
#     admin enable-invites
#     admin list-invite-tree [--disable-invites]
#                            [--revoke-existing-invites]
#                            [--print-handles] [--print-emails]
#     admin account-takedown --reason <STRING>
#     bsky follow                    Follow an account
#     bsky list-follows              List a user's follows
#     bsky post                      Post a text note
#     bsky get-feed [--count <N>] [--author <DID>] [--raw]
#                   [--uris]
#     bsky actor-get-suggestions     List suggested accounts
#     bsky like                      Like a post
#     bsky delete-post               Delete a post by URI
#     bsky notifs                    List notifications
#     bgs list                       List repos on a BGS relay
#     bgs kick [--ban]               Kick a repo off a relay
#     bgs list-domain-bans           List banned domains
#     bgs ban-domain                 Ban a domain on a relay
#     bgs take-down-repo             Take a repo down
#     bgs set-accept-subs            Toggle the relay accepting
#                                    new subscribers
#     bgs compact-repo [--fast]
#     bgs compact-all [--dry] [--limit <N>] [--threshold <N>]
#                     [--fast]
#     bgs reset-repo
#     bgs set-trusted-domain
#     car unpack [--cbor] [--out-dir <DIR>]
#                                    Unpack a CAR archive
#     debug inspect-event --host <URL> [--dump-raw-blocks]
#     debug debug-stream --host <URL> [--dump-raw-blocks]
#     debug compare-streams --host1 <URL> --host2 <URL>
#     debug debug-feed               Debug a feed-generator feed
#     debug view-feed                Print a feed in pretty form
#     debug get-repo                 Get a repo's CAR archive
#     debug compare-repos --host-1 <URL> --host-2 <URL>
#     did get --handle <HANDLE>      Resolve a handle to its DID
#                                    document
#     did did-key [--keypath <PATH>] Generate a did:key from a
#                                    private-key file
#     handle resolve                 Resolve a handle
#     handle update                  Update a user's handle on
#                                    their PDS
#     sync get-repo --host <URL>     Download a repo's CAR
#     sync get-root                  Get a repo's current root
#                                    commit CID
#     sync list-repos                List all repos available on
#                                    a relay
#     read-stream <relay> [cursor]
#                                    Subscribe to a repo event
#                                    stream
#         --json                     Output events as JSON
#         --unpack                   Unpack CAR archives
#         --resolve-handles          Resolve DIDs to handles
#         --max-throughput <RATE>    Cap req/sec
#     create-feed-gen --name <STR> --did <DID>
#                     [--description <STR>]
#                     [--display-name <STR>]
#     get-record --repo <DID|HANDLE> [--raw]
#     list [--all] [--values] [--cids]
#                                    List records on a repo
#     parse-rkey [--format <FORMAT>] Decode a record key
#     list-labels [--since <CURSOR>] List labels emitted by a
#                                    labeler
#     verify-user                    Verify a user's DID against
#                                    their handle
#
# AXIS / CORPUS POSITION
#   `cmd/gosky/main.go` declares **direct** imports from the
#   workspace-internal `github.com/bluesky-social/indigo/api/
#   atproto`, `github.com/bluesky-social/indigo/api/bsky`,
#   `github.com/bluesky-social/indigo/atproto/identity`,
#   `github.com/bluesky-social/indigo/atproto/syntax`,
#   `github.com/bluesky-social/indigo/events`, `github.com/
#   bluesky-social/indigo/events/schedulers/sequential`,
#   `github.com/bluesky-social/indigo/lex/util` (the lexicon
#   codegen output), `github.com/bluesky-social/indigo/repo`,
#   `github.com/bluesky-social/indigo/util`, `github.com/
#   bluesky-social/indigo/util/cliutil`, and `github.com/
#   bluesky-social/indigo/xrpc` packages (verified via
#   raw.githubusercontent.com fetch of `cmd/gosky/main.go`).
#
#   `bluesky-social/indigo` is **THE canonical Go AT Protocol /
#   Bluesky SDK** — the Bluesky PBC engineering team's official
#   monorepo, maintained alongside the protocol specification at
#   `bluesky-social/atproto`.  It is **THE reference Go
#   implementation of the AT Protocol** in the same way that
#   the TypeScript SDK at `bluesky-social/atproto/packages/api`
#   is the reference TS implementation:
#
#     • Lexicon codegen — `lex/lexgen/` reads the canonical
#       lexicon JSON specs at `bluesky-social/atproto/lexicons/`
#       and generates typed Go bindings under `api/atproto/`,
#       `api/bsky/`, `api/chat/` (the DMs surface), `api/
#       ozone/` (the moderation surface), `api/identity/`, and
#       `api/label/` for every record kind, query, and
#       procedure
#
#     • Typed `xrpc.Client` with full request/response framing,
#       authentication header injection, refresh-token rotation,
#       and retry logic for the AT Protocol XRPC wire protocol
#
#     • Typed `repo.Repo` MST + DAG-CBOR encoder/decoder
#       implementing the canonical AT Protocol repo format
#       (the Merkle Search Tree of typed `*Record`s addressed
#       by typed `cid.Cid` content-addresses, signed with the
#       account's rotation key)
#
#     • Typed `events.RepoStreamCallbacks` firehose subscriber
#       with the sequential / parallel / pool schedulers under
#       `events/schedulers/{sequential,parallel,pool}/` —
#       the event-loop machinery every Bluesky labeler / feed
#       generator / archiver builds on
#
#     • Typed `identity.BaseDirectory` DID + handle resolver
#       with built-in PLC + did:web support, in-process LRU
#       caching, and pluggable resolver plumbing
#
#     • Typed `bgs.BGS` (the Big Graph Service relay
#       implementation that powers `bsky.network`),
#       `pds.PDS` (the canonical reference PDS impl that
#       powers `bsky.social` user accounts), `palomar.Search`
#       (the Elasticsearch-backed search appview),
#       `rainbow.FeedGen` (the canonical feed-generator
#       service framework), `hepa.Labeler` (the automated
#       moderation labeler driving Bluesky's `!warn` /
#       `!hide` / `!takedown` labels), `ozone.Server` (the
#       moderation back-office API server), `astrolabe.Tool`
#       (the operator-facing account-takedown utility),
#       `sonar.Listener` (the firehose-observer service),
#       `goat.Tool` (the relay-query operator CLI),
#       `tap.Tool` (the firehose tap utility)
#
#   `indigo` is **the canonical Bluesky / AT Protocol Go SDK**
#   used by every serious Go AT Protocol project in production
#   alongside `bsky.app`'s own infrastructure: GoToSocial's
#   AT Protocol bridge (bridging the ActivityPub fediverse to
#   Bluesky), the Bluesky Web (bsky-web-fb-importer), the
#   feed-generator framework starter kits (bluesky-social/
#   feed-generator's Go reference impl), `karmanyaahm/up_rest_in_peace`
#   (the bridge between Pushbullet and Bluesky), `mariusor/
#   go-bsky` (the ActivityPub-to-Bluesky bridge), `blacksky-
#   algorithms/rsky`'s Go-side feed-generator integrations,
#   and dozens of community feed generators, archivers,
#   moderation labelers, and analytics pipelines.
#
#   Verified via:
#     gh api repos/bluesky-social/indigo/contents/cmd
#       → cmd/gosky (and 16 other binary workspace members:
#         astrolabe, athome, beemo, bluepages, collectiondir,
#         fakermaker, goat, hepa, lexgen, netsync, palomar,
#         rainbow, relay, sonar, stress, tap)
#     raw.githubusercontent.com bluesky-social/indigo main
#         cmd/gosky/main.go
#       → import (
#           "github.com/bluesky-social/indigo/api/atproto"
#           "github.com/bluesky-social/indigo/api/bsky"
#           "github.com/bluesky-social/indigo/atproto/identity"
#           "github.com/bluesky-social/indigo/atproto/syntax"
#           "github.com/bluesky-social/indigo/events"
#           "github.com/bluesky-social/indigo/events/schedulers/sequential"
#           "github.com/bluesky-social/indigo/lex/util"
#           "github.com/bluesky-social/indigo/repo"
#           "github.com/bluesky-social/indigo/util"
#           "github.com/bluesky-social/indigo/util/cliutil"
#           "github.com/bluesky-social/indigo/xrpc"
#           "github.com/urfave/cli/v2"
#         )
#       → app := cli.App{Name: "gosky", Usage:
#         "client CLI for atproto and bluesky", Version:
#         versioninfo.Short()}
#       → 4 global StringFlags + 16 top-level Commands as
#         documented above
#
#   This entry is the Go=168 leader bump that continues Axis 113
#   (AT Protocol / ATProto / Bluesky) at 2/0/0 following R1037
#   _skystreamer (Rust=168 OPENED Axis 113 via FyraLabs/skystreamer
#   on sugyan/atrium).  TS-Node=168 closing pair on deck for
#   R1039 via the canonical `@atproto/api` SDK (the Bluesky-
#   authored reference TS/JS implementation used by every
#   browser-based AT Protocol client including `bsky.app`
#   itself).
#
#   No completion for `gosky` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_gosky() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a _gosky_global=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[print version]'
        '--pds-host=[PDS endpoint (default https://bsky.social)]:url:'
        '--auth=[path to JSON file with ATP auth info (default bsky.auth)]:path:_files -g "*.auth *.json"'
        '--plc=[PLC registry endpoint (default https://plc.directory)]:url:'
        '--log-level=[log verbosity (default info)]:level:(debug info warn error)'
    )

    _arguments -C \
        $_gosky_global \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _gosky_cmds=(
                'account:account lifecycle operations'
                'admin:PDS / appview admin operations'
                'bsky:Bluesky-specific operations'
                'bgs:Big Graph Service relay admin'
                'car:CAR archive handling'
                'debug:firehose + repo debugging'
                'did:DID resolution'
                'handle:handle resolution and updates'
                'sync:repo sync operations'
                'read-stream:subscribe to a repo event stream'
                'create-feed-gen:create a feed generator record'
                'get-record:fetch a single record by URI'
                'list:list records on a repo'
                'parse-rkey:decode a record key'
                'list-labels:list labels emitted by a labeler'
                'verify-user:verify a user DID against their handle'
            )
            _describe -t commands 'gosky command' _gosky_cmds && ret=0
            ;;
        args)
            case $words[1] in
                account)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'create-session:create a session against the configured PDS'
                            'new:create a new account'
                            'refresh-session:refresh session credentials'
                            'reset-password:reset account password'
                            'request-deletion:request account deletion'
                            'delete:confirm account deletion'
                        )
                        _describe -t sub 'account sub' _a && ret=0
                    fi
                    ;;
                admin)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'check-user:check a single user'
                            'build-invite-tree:build invite tree from an invite-codes list'
                            'reports:list / inspect moderation reports'
                            'disable-invites:disable invites globally'
                            'enable-invites:enable invites globally'
                            'list-invite-tree:list the invite tree'
                            'account-takedown:take down an account'
                        )
                        _describe -t sub 'admin sub' _a && ret=0
                    fi
                    _arguments \
                        '--admin-password=[admin password]:password:' \
                        '--admin-endpoint=[admin endpoint]:url:' && ret=0
                    ;;
                bsky)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'follow:follow an account'
                            'list-follows:list a user follows'
                            'post:post a text note'
                            'get-feed:fetch a feed'
                            'actor-get-suggestions:list suggested accounts'
                            'like:like a post'
                            'delete-post:delete a post by URI'
                            'notifs:list notifications'
                        )
                        _describe -t sub 'bsky sub' _a && ret=0
                    elif [[ $words[2] == get-feed ]]; then
                        _arguments \
                            '--count=[number of items]:n:' \
                            '--author=[author DID]:did:' \
                            '--raw[output raw JSON]' \
                            '--uris[output URIs only]' && ret=0
                    fi
                    ;;
                bgs)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'list:list repos on a relay'
                            'kick:kick a repo off a relay'
                            'list-domain-bans:list banned domains'
                            'ban-domain:ban a domain on a relay'
                            'take-down-repo:take a repo down'
                            'set-accept-subs:toggle the relay accepting new subscribers'
                            'compact-repo:compact a single repo'
                            'compact-all:compact all repos'
                            'reset-repo:reset a repo'
                            'set-trusted-domain:mark a domain as trusted'
                        )
                        _describe -t sub 'bgs sub' _a && ret=0
                    fi
                    _arguments \
                        '--key=[admin key]:key:' \
                        '--bgs=[BGS endpoint]:url:' && ret=0
                    case $words[2] in
                        kick)        _arguments '--ban[also ban this repo]' && ret=0 ;;
                        compact-repo) _arguments '--fast[fast-mode compaction]' && ret=0 ;;
                        compact-all) _arguments \
                            '--dry[dry-run]' \
                            '--limit=[max repos to compact]:n:' \
                            '--threshold=[size threshold]:n:' \
                            '--fast[fast-mode compaction]' && ret=0 ;;
                    esac
                    ;;
                car)
                    if (( CURRENT == 2 )); then
                        local -a _a=('unpack:unpack a CAR archive')
                        _describe -t sub 'car sub' _a && ret=0
                    elif [[ $words[2] == unpack ]]; then
                        _arguments \
                            '--cbor[output cbor instead of json]' \
                            '--out-dir=[output directory]:dir:_files -/' && ret=0
                    fi
                    ;;
                debug)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'inspect-event:inspect a single event from a host'
                            'debug-stream:dump and decode a stream from a host'
                            'compare-streams:compare two relay streams'
                            'debug-feed:debug a feed-generator feed'
                            'view-feed:print a feed in pretty form'
                            'get-repo:get a repo CAR archive'
                            'compare-repos:compare two repo CAR archives'
                        )
                        _describe -t sub 'debug sub' _a && ret=0
                    fi
                    case $words[2] in
                        inspect-event|debug-stream)
                            _arguments \
                                '--host=[relay host URL]:url:' \
                                '--dump-raw-blocks[dump raw CBOR blocks]' && ret=0 ;;
                        compare-streams)
                            _arguments \
                                '--host1=[first relay URL]:url:' \
                                '--host2=[second relay URL]:url:' && ret=0 ;;
                        compare-repos)
                            _arguments \
                                '--host-1=[first PDS URL]:url:' \
                                '--host-2=[second PDS URL]:url:' && ret=0 ;;
                    esac
                    ;;
                did)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'get:resolve a handle to its DID document'
                            'did-key:generate a did:key from a private-key file'
                        )
                        _describe -t sub 'did sub' _a && ret=0
                    fi
                    case $words[2] in
                        get)     _arguments '--handle=[handle to resolve]:handle:' && ret=0 ;;
                        did-key) _arguments '--keypath=[private key file path]:path:_files' && ret=0 ;;
                    esac
                    ;;
                handle)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'resolve:resolve a handle'
                            'update:update a user handle on their PDS'
                        )
                        _describe -t sub 'handle sub' _a && ret=0
                    fi
                    ;;
                sync)
                    if (( CURRENT == 2 )); then
                        local -a _a=(
                            'get-repo:download a repo CAR'
                            'get-root:get a repo current root commit CID'
                            'list-repos:list all repos available on a relay'
                        )
                        _describe -t sub 'sync sub' _a && ret=0
                    elif [[ $words[2] == get-repo ]]; then
                        _arguments '--host=[relay URL]:url:' && ret=0
                    fi
                    ;;
                read-stream)
                    _arguments \
                        '1:relay URL or hostname:' \
                        '2:cursor:' \
                        '--json[output events as JSON]' \
                        '--unpack[unpack CAR archives]' \
                        '--resolve-handles[resolve DIDs to handles]' \
                        '--max-throughput=[cap requests per second]:rate:' && ret=0
                    ;;
                create-feed-gen)
                    _arguments \
                        '--name=[feed-generator name]:name:' \
                        '--did=[feed-generator service DID]:did:' \
                        '--description=[description]:desc:' \
                        '--display-name=[display name]:name:' && ret=0
                    ;;
                get-record)
                    _arguments \
                        '--repo=[repo DID or handle]:repo:' \
                        '--raw[output raw JSON]' && ret=0
                    ;;
                list)
                    _arguments \
                        '--all[list all collections]' \
                        '--values[print record values]' \
                        '--cids[print record CIDs]' && ret=0
                    ;;
                parse-rkey)
                    _arguments '--format=[output format]:fmt:' && ret=0
                    ;;
                list-labels)
                    _arguments '--since=[cursor]:cursor:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_gosky "$@"
