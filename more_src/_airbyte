#compdef airbyte airbyte-cli abctl
# _airbyte — Airbyte data integration CLI/abctl bootstrapper (Airbyte, Go); spf13/cobra
# upstream: https://github.com/airbytehq/abctl

_airbyte() {
    local -a sub=(
        'local:manage local airbyte (install/uninstall/credentials/status)'
        'images:airbyte container images'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'airbyte subcommand' sub ;;
        args)
            case $words[1] in
                local) _arguments \
                    '1:cmd:(install uninstall status credentials deployments)' \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--username=+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '--values=+[helm values file]:file:_files' \
                    '--chart-version=+[chart version]:ver:' \
                    '--secret=+[secret manifest]:file:_files' \
                    '--low-resource-mode[low resource mode]' \
                    '--no-browser[no browser]' \
                    '--insecure-cookies[insecure cookies]' \
                    '*:arg:' ;;
                images) _arguments \
                    '1:cmd:(manifest list pull)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_airbyte "$@"
