#compdef mpy-cross
# Documentation: https://github.com/micropython/micropython/blob/master/mpy-cross/main.c
# Reference accessed: 2026-05-27
# Verified: upstream mpy-cross/main.c usage() text in micropython repo

local curcontext="$curcontext" state line ret=1

local -a _archs
_archs=(
  'x86:Intel x86 32-bit'
  'x64:Intel x86 64-bit'
  'armv6:ARMv6 (no Thumb-2)'
  'armv6m:ARMv6-M'
  'armv7m:ARMv7-M'
  'armv7em:ARMv7E-M'
  'armv7emsp:ARMv7E-M single-precision FP'
  'armv7emdp:ARMv7E-M double-precision FP'
  'xtensa:Xtensa'
  'xtensawin:Xtensa for ESP32 Windows'
  'rv32imc:RISC-V 32-bit IMC'
  'rv64imc:RISC-V 64-bit IMC'
  'host:host architecture'
  'debug:debug pseudo-arch'
)

local -a _emits
_emits=(
  'bytecode:default bytecode emitter'
  'native:native machine-code emitter'
  'viper:Viper typed emitter'
)

_arguments -s -S -C \
  '--version[show version information]' \
  '-h[show help and exit]' \
  '*-v[verbose (trace various operations); repeatable]' \
  '-O0[disable bytecode optimizations]' \
  '-O1[apply bytecode optimization level 1]' \
  '-O2[apply bytecode optimization level 2]' \
  '-O3[apply bytecode optimization level 3]' \
  '-o+[output file for compiled bytecode]:output file:_files' \
  '-s+[source filename to embed in compiled bytecode]:source filename:' \
  '-msmall-int-bits=-[set max bits used to encode a small-int]:bits:' \
  '-march=-[set architecture for native emitter]:arch:->arch' \
  '-march-flags=-[set architecture-specific flags (rv32imc: zba,zcmp)]:flags:' \
  '*-X+[implementation-specific option]:impl option:->ximpl' \
  '*:input file:_files -g "*.py"' && ret=0

case $state in
  (arch)
    _describe -t archs 'native arch' _archs && ret=0
    ;;
  (ximpl)
    if [[ $PREFIX == emit=* ]]; then
      compset -P 'emit='
      _describe -t emits 'emit backend' _emits && ret=0
    elif [[ $PREFIX == heapsize=* ]]; then
      compset -P 'heapsize='
      _message 'heap size in bytes (suffix: K, M; w=adjust for word size)' && ret=0
    else
      local -a _ximpl
      _ximpl=(
        'emit=:set the default code emitter'
        'heapsize=:set the GC heap size'
      )
      _describe -t ximpl '-X implementation option' _ximpl -S '' && ret=0
    fi
    ;;
esac

return ret
