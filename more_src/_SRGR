#compdef SRGR
# Documentation: https://step.esa.int/main/wp-content/help/versions/9.0.0/snap-toolboxes/org.esa.s1tbx.s1tbx.op.sar.processing.ui/operators/SRGROp.html
# ESA SNAP gpt SRGR operator - slant range to ground range conversion

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-PsourceBands=[the list of source bands]:bands' \
  '-PwarpPolynomialOrder=[order of WARP polynomial function]:order:(1 2 3 4)' \
  '-PinterpolationMethod=[interpolation method]:method' \
  '*:graph xml:_files' && ret=0

return ret
