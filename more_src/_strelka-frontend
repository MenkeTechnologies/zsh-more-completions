#compdef strelka-frontend
# _strelka-frontend — Target Brands Strelka frontend gRPC daemon CLI receiving file-submission requests authenticating clients enqueueing tasks to coordinator-backend Redis queue for processing (target team, Go); flag
# upstream: https://github.com/target/strelka

_strelka-frontend() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--logfile=+[file]:file:_files' \
        '--logsystem=+[system]:s:(stdout syslog journald file)' \
        '--listen=+[host:port]:str:' \
        '--ca-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--server-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--server-key=+[file]:file:_files -g "*.pem *.key"' \
        '--insecure[allow self-signed]' \
        '--metrics=+[host:port]:str:' \
        '--prometheus-port=+[port]:n:' \
        '--coordinator=+[host:port]:str:' \
        '--gateway-timeout=+[d]:str:' \
        '--maxConcurrentStreams=+[N]:n:' \
        '--connectionTimeout=+[d]:str:' \
        '--idleTimeout=+[d]:str:' \
        '--maxRecvMsgSize=+[bytes]:n:' \
        '--maxSendMsgSize=+[bytes]:n:' \
        '--allowed-cn=+[csv]:str:' \
        '--allowed-orgs=+[csv]:str:' \
        '--allowed-ou=+[csv]:str:' \
        '--no-banner[no banner]'
}

_strelka-frontend "$@"
