#compdef findfs
# _findfs-bin — util-linux find a filesystem by label or UUID; print the matching device path
# upstream: https://github.com/util-linux/util-linux

_findfs-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:LABEL=/UUID=/PARTUUID=/PARTLABEL=:'
}

_findfs-bin "$@"
