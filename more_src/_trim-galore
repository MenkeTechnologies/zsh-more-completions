#compdef trim-galore
# Documentation: https://github.com/FelixKrueger/TrimGalore/blob/master/Docs/Trim_Galore_User_Guide.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Trim Galore: wrapper around cutadapt for quality+adapter trimming
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-q --quality)'{-q,--quality=}'[quality threshold]:q:' \
  '--phred33[Phred 33 quality scores]' \
  '--phred64[Phred 64 quality scores]' \
  '--fastqc[run FastQC after trimming]' \
  '--fastqc_args[args passed to FastQC]:args:' \
  '-a[adapter sequence to trim (R1)]:seq:' \
  '-a2[adapter sequence to trim (R2)]:seq:' \
  '--illumina[Illumina TruSeq adapter]' \
  '--stranded_illumina[Illumina stranded adapter]' \
  '--nextera[Nextera adapter]' \
  '--small_rna[Illumina small RNA adapter]' \
  '--consider_already_trimmed[skip primary trimming]' \
  '--max_length=[max read length]:n:' \
  '--stringency=[minimum adapter overlap]:n:' \
  '-e[error rate]:val:' \
  '--length=[minimum read length]:n:' \
  '--max_n=[max N count]:n:' \
  '--trim-n[trim N bases from ends]' \
  '-o[output directory]:dir:_files -/' \
  '--no_report_file[no .txt report]' \
  '--suppress_warn[suppress warnings]' \
  '--dont_gzip[do not gzip output]' \
  '--gzip[gzip output]' \
  '--length_1=[R1 min length]:n:' \
  '--length_2=[R2 min length]:n:' \
  '--paired[paired-end mode]' \
  '--retain_unpaired[keep singleton reads]' \
  '-r1[R1 unpaired output]:file:_files' \
  '-r2[R2 unpaired output]:file:_files' \
  '--rrbs[reduced-representation bisulfite mode]' \
  '--non_directional[non-directional bisulfite]' \
  '--keep[keep original]' \
  '--clip_R1=[bp to clip from 5-prime of R1]:n:' \
  '--clip_R2=[bp to clip from 5-prime of R2]:n:' \
  '--three_prime_clip_R1=[bp to clip from 3-prime of R1]:n:' \
  '--three_prime_clip_R2=[bp to clip from 3-prime of R2]:n:' \
  '--nextseq[NextSeq/NovaSeq dark cycle trimming threshold]:q:' \
  '--basename=[output basename]:name:' \
  '-j[number of cores for parallel cutadapt]:n:' \
  '--cores=[number of cores]:n:' \
  '--hardtrim5=[hard trim to N bp from 5-prime]:n:' \
  '--hardtrim3=[hard trim to N bp from 3-prime]:n:' \
  '--clock[Clock UMI trimming mode]' \
  '*:FASTQ file:_files -g "*.(fastq|fq|fastq.gz|fq.gz)"' && ret=0
return ret
