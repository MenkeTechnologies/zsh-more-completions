#compdef bao

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agent:run agent for auth and secret injection'
  'audit:manage audit devices'
  'auth:manage auth methods'
  'debug:capture debug bundle'
  'delete:delete data at path'
  'kv:KV secret engine'
  'lease:manage leases'
  'list:list paths'
  'login:authenticate and obtain token'
  'monitor:stream server logs'
  'namespace:manage namespaces'
  'operator:operational tasks'
  'patch:patch fields at path'
  'path-help:API doc for paths'
  'pki:PKI engine'
  'plugin:manage plugins'
  'policy:manage policies'
  'print:print formatted token info'
  'proxy:run proxy'
  'read:read data from path'
  'secrets:manage secret engines'
  'server:start a server'
  'ssh:SSH credential generation'
  'status:server status'
  'token:manage tokens'
  'transit:transit engine'
  'unwrap:unwrap wrapped secret'
  'version:show CLI version'
  'version-history:show version history'
  'write:write data to path'
)

_arguments -C \
  '-address=[server address]:url:' \
  '-namespace=[namespace]:ns:' \
  '-format=[output format]:fmt:(table json yaml)' \
  '-no-color[strip ANSI]' \
  '-output-curl-string[print equivalent curl]' \
  '-output-policy[print policy needed]' \
  '-ca-cert=[PEM CA cert]:file:_files' \
  '-tls-skip-verify[skip TLS verification]' \
  '(- *)'{-h,-help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'bao subcommand' subcommands && ret=0
    ;;
esac

return ret
