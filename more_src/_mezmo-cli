#compdef mezmo-cli mezmo
# _mezmo-cli — Mezmo mezmo-cli CLI command-line frontend wrapping the Mezmo formerly LogDNA observability data observability log management Telemetry Pipeline platform CLI providing login logout whoami pipeline source destination processor transform pipeline-stage run deploy validate build secret variable env account organization workspace usage retention tail search view alert dashboard share (Mezmo team Chris Cooney, Go); cobra
# upstream: https://mezmo.com/

_mezmo-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'pipeline:pipeline operations'
        'source:source operations'
        'destination:destination operations'
        'processor:processor operations'
        'transform:transform operations'
        'deploy:deploy pipeline'
        'validate:validate pipeline'
        'build:build pipeline'
        'secret:secret operations'
        'variable:variable operations'
        'account:account operations'
        'organization:organization operations'
        'workspace:workspace operations'
        'usage:usage operations'
        'retention:retention operations'
        'tail:tail logs'
        'search:search logs'
        'view:view operations'
        'alert:alert operations'
        'dashboard:dashboard operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--service-key=+[key]:str:' \
        '--api-key=+[key]:str:' \
        '--ingestion-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu uk)' \
        '--workspace-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mezmo subcommand' sub ;;
        args)
            case $words[1] in
                pipeline|source|destination|processor|transform|secret|variable|account|organization|workspace|view|alert|dashboard) _arguments '1:op:(list get create update delete deploy)' '*:id:' ;;
                tail|search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_mezmo-cli "$@"
