#compdef pdftk
# Documentation: https://manpages.debian.org/pdftk.1
# Source: PDF Toolkit — pdftk-java implementation of the original pdftk by Sid Steward.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'cat:assemble pages from input PDFs into a new PDF'
            'shuffle:collate pages from input PDFs'
            'burst:split input PDF into individual pages'
            'rotate:rotate specified pages of an input PDF'
            'generate_fdf:emit FDF suitable for fill_form'
            'fill_form:fill form fields from an FDF/XFDF/JSON file'
            'background:apply a PDF watermark behind input pages'
            'multibackground:per-page background overlay'
            'stamp:overlay stamp PDF on top of input pages'
            'multistamp:per-page stamp overlay'
            'dump_data:report metadata / bookmarks / page metrics'
            'dump_data_utf8:dump_data with UTF-8 output'
            'dump_data_fields:report form-field statistics'
            'dump_data_fields_utf8:dump_data_fields with UTF-8'
            'dump_data_annots:report annotation info (link only)'
            'update_info:change bookmarks / page labels / metadata'
            'update_info_utf8:update_info with UTF-8 input'
            'attach_files:pack arbitrary files into a PDF'
            'unpack_files:copy all attachments out of a PDF'
        )
        _describe -t subcmds 'pdftk operation' subcmds && ret=0
        ;;
    args)
        _arguments \
            '(encrypt_40bit encrypt_128bit encrypt_aes128)encrypt_40bit[40-bit encryption]' \
            '(encrypt_40bit encrypt_128bit encrypt_aes128)encrypt_128bit[128-bit RC4 encryption]' \
            '(encrypt_40bit encrypt_128bit encrypt_aes128)encrypt_aes128[128-bit AES encryption]' \
            'allow[allowed permissions]:perm:(Printing DegradedPrinting ModifyContents Assembly CopyContents ScreenReaders ModifyAnnotations FillIn AllFeatures)' \
            'flatten[merge form fields with pages]' \
            '(compress uncompress)compress[compress page streams]' \
            '(compress uncompress)uncompress[uncompress page streams]' \
            '(keep_first_id keep_final_id)keep_first_id[preserve first-input document ID]' \
            '(keep_first_id keep_final_id)keep_final_id[preserve final-input document ID]' \
            'drop_xfa[remove XFA data]' \
            'drop_xmp[remove XMP metadata]' \
            'need_appearances[cue Reader/Acrobat to generate field appearances]' \
            'replacement_font[font for form-field text]:font:' \
            'verbose[detailed output]' \
            '(dont_ask do_ask)dont_ask[non-interactive]' \
            '(dont_ask do_ask)do_ask[prompt for input]' \
            'output[output file]:file:_files' \
            'owner_pw[owner password]:password:' \
            'user_pw[user password]:password:' \
            'input_pw[input password]:password:' \
            '*:PDF file:_files -g "*.pdf"' \
            && ret=0
        ;;
esac

return ret
