#compdef pdftk
# Documentation: https://www.pdflabs.com/docs/pdftk-man-page/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pdftk - PDF toolkit

local curcontext="$curcontext" state line ret=1

local -a operations=(
  'cat:assemble pages from input PDFs to create a new PDF'
  'shuffle:collate pages from multiple input PDFs'
  'burst:split a single PDF into individual pages'
  'rotate:rotate specified pages'
  'generate_fdf:generate FDF file suitable for fill_form'
  'fill_form:fill PDF form fields using FDF/XFDF data'
  'background:apply a PDF watermark to the background'
  'multibackground:apply different backgrounds to each input page'
  'stamp:apply a PDF watermark to the foreground'
  'multistamp:apply different stamps to each input page'
  'dump_data:report metadata, bookmarks, page info'
  'dump_data_utf8:dump_data with UTF-8 encoding'
  'dump_data_fields:report form field statistics'
  'dump_data_fields_utf8:dump_data_fields in UTF-8'
  'dump_data_annots:report annotation information'
  'update_info:update bookmarks and metadata'
  'update_info_utf8:update_info in UTF-8'
  'attach_files:embed files into a PDF'
  'unpack_files:extract attachments from a PDF'
)

_arguments -s -S \
  'input_pw[input PDF owner password]:password:' \
  'output[output file or directory]:file:_files' \
  'owner_pw[set output owner password]:password:' \
  'user_pw[set output user password]:password:' \
  'allow[set user permissions]:permissions:(Printing DegradedPrinting ModifyContents Assembly CopyContents ScreenReaders ModifyAnnotations FillIn AllFeatures)' \
  'encrypt_40bit[use 40-bit encryption]' \
  'encrypt_128bit[use 128-bit encryption]' \
  'encrypt_aes128[use AES 128-bit encryption]' \
  'flatten[merge form fields with pages]' \
  'need_appearances[generate new form field appearances]' \
  'compress[compress page streams]' \
  'uncompress[uncompress page streams]' \
  'keep_first_id[preserve first document ID]' \
  'keep_final_id[preserve final document ID]' \
  'drop_xfa[remove XFA form data]' \
  'drop_xmp[remove XMP metadata stream]' \
  'verbose[enable verbose output]' \
  'dont_ask[do not prompt for confirmation]' \
  'do_ask[always prompt for confirmation]' \
  '*: :->input_or_op' && ret=0

case $state in
  input_or_op)
    _alternative \
      'files:PDF file:_files -g "*.pdf"' \
      'operations:operation:((${(j: :)operations}))' \
      && ret=0
    ;;
esac

return ret
