(( $+functions[_envoke_commands] )) ||
_envoke_commands() {
    local commands; commands=(
'render:Resolve variables and print or write them' \
'r:Resolve variables and print or write them' \
'exec:Resolve variables and exec a command with them overlaid on the current process environment' \
'x:Resolve variables and exec a command with them overlaid on the current process environment' \
'meta:Enumerate names of a config dimension (environments, tags, overrides)' \
'schema:Print the JSON Schema for envoke.yaml and exit' \
'completions:Generate shell completions for the given shell and exit' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'envoke commands' commands "$@"
}
(( $+functions[_envoke__subcmd__completions_commands] )) ||
_envoke__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'envoke completions commands' commands "$@"
}
(( $+functions[_envoke__subcmd__exec_commands] )) ||
