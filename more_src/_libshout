#compdef libshout shout shout3
# _libshout — Xiph.Org libshout source client library for streaming to Icecast/SHOUTcast servers (xiph team, C); getopt for shout helper
# upstream: https://github.com/xiph/Icecast-libshout

_libshout() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-H+[host]:h:_hosts' \
        '--host=+[host]:h:_hosts' \
        '-P+[port]:n:(8000 8443 443)' \
        '--port=+[port]:n:(8000 8443 443)' \
        '-u+[user]:u:_users' \
        '--user=+[user]:u:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-m+[mount point]:str:' \
        '--mount=+[mount point]:str:' \
        '-f+[format]:f:(ogg mp3 webm)' \
        '--format=+[format]:f:(ogg mp3 webm)' \
        '-c+[content-type]:c:(audio/mpeg application/ogg audio/aacp audio/webm video/webm)' \
        '--content-type=+[content-type]:c:(audio/mpeg application/ogg audio/aacp audio/webm video/webm)' \
        '-r+[stream protocol]:p:(http icy roaraudio)' \
        '--protocol=+[stream protocol]:p:(http icy roaraudio)' \
        '-n+[stream name]:str:' \
        '--name=+[stream name]:str:' \
        '-U+[URL]:str:' \
        '--url=+[URL]:str:' \
        '-g+[genre]:str:' \
        '--genre=+[genre]:str:' \
        '-d+[description]:str:' \
        '--description=+[description]:str:' \
        '-a[advertise on YP]' \
        '--public[advertise on YP]' \
        '-b+[bitrate kbps]:n:' \
        '--bitrate=+[bitrate kbps]:n:' \
        '-S+[samplerate Hz]:n:' \
        '--samplerate=+[samplerate Hz]:n:' \
        '-C+[N channels]:n:(1 2)' \
        '--channels=+[N channels]:n:(1 2)' \
        '-Q+[quality]:f:' \
        '--quality=+[quality]:f:' \
        '-T+[TLS]:t:(disabled auto auto_no_plain rfc2818 rfc2817)' \
        '--tls=+[TLS]:t:(disabled auto auto_no_plain rfc2818 rfc2817)' \
        '-A+[ca file]:file:_files -g "*.pem *.crt"' \
        '--ca-file=+[ca file]:file:_files -g "*.pem *.crt"' \
        '-D+[ca dir]:dir:_files -/' \
        '--ca-dir=+[ca dir]:dir:_files -/' \
        '*:audio file:_files -g "*.ogg *.oga *.opus *.mp3 *.webm *.aac"'
}

_libshout "$@"
