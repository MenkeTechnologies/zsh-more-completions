#compdef pcm-pcie
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-pcie.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-pcie: Intel PCM PCIe events monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-B[estimate PCIe bandwidth in bytes/sec]' \
  '-e[print additional PCIe LLC miss/hit stats]' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-pcie args:_files' && ret=0
return ret
