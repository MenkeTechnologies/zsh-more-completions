#compdef uu-sum
# Documentation: https://man.archlinux.org/search?q=uu-sum
# Reference accessed: 2026-05-16
# Source: Homebrew bottle
# Formula: uutils-coreutils
# Type: maintainer-shipped (Homebrew)
# Harvested: 2026-05-15

autoload -U is-at-least

_uu-sum() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-r[use the BSD sum algorithm, use 1K blocks (default)]' \
'-s[use System V sum algorithm, use 512 bytes blocks]' \
'--sysv[use System V sum algorithm, use 512 bytes blocks]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::file:_files' \
&& ret=0
}

(( $+functions[_uu-sum_commands] )) ||
_uu-sum_commands() {
    local commands; commands=()
    _describe -t commands 'uu-sum commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-sum" ]; then
    _uu-sum "$@"
else
    compdef _uu-sum uu-sum
fi
