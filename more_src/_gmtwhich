#compdef gmtwhich
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtwhich.html
# Source: GenericMappingTools/gmt classic-mode gmtwhich — locate GMT data/cache/user files on disk.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[only readable files]' \
    '-C[Y/N confirmation instead of path]' \
    '-D[print containing directory instead of path]' \
    '-G+[download missing files (destination)]:dest:(a c l u)' \
    '*-V[verbose (stackable)]' \
    '(- *)-\?[show help]' \
    '*:file:_files' \
    && ret=0

return ret
