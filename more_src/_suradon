#compdef suradon
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/suradon.c
# compute forward or reverse Radon transform or remove multiples

local ret=1

_arguments -s -S \
  'choose=[choose]:choose:' \
  'igopt=[igopt]:igopt:' \
  'offref=[offref]:offref:' \
  'interoff=[interoff]:interoff:' \
  'pmin=[pmin]:pmin:' \
  'pmax=[pmax]:pmax:' \
  'anderson=[anderson]:anderson:' \
  'dp=[dp]:dp:' \
  'pmula=[pmula]:pmula:' \
  'pmulb=[pmulb]:pmulb:' \
  'depthref=[depthref]:depthref:' \
  'nwin=[nwin]:nwin:' \
  'f1=[f1]:f1:' \
  'f2=[f2]:f2:' \
  'prewhite=[prewhite]:prewhite:' \
  'cdpkey=[cdpkey]:cdpkey:' \
  'offkey=[offkey]:offkey:' \
  'nxmax=[nxmax]:nxmax:' \
  'ltaper=[ltaper]:ltaper:' \
  'ninterp=[ninterp]:ninterp:' \
  'freq1=[freq1]:freq1:' \
  'freq2=[freq2]:freq2:' \
  'lagc=[lagc]:lagc:' \
  'lent=[lent]:lent:' \
  'lenx=[lenx]:lenx:' \
  'xopt=[xopt]:xopt:' \
  '*:file:_files' && ret=0

return ret
