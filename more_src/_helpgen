#compdef helpgen
# _helpgen — generate help boilerplate for controller-tools markers (kubernetes-sigs/controller-tools)
# upstream: https://github.com/kubernetes-sigs/controller-tools
# Flags from cmd/helpgen/main.go (pflag).

_helpgen() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '*::generator spec:'
}

_helpgen "$@"
