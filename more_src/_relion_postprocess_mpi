#compdef relion_postprocess_mpi
# Documentation: https://relion.readthedocs.io/en/release-5.0/Reference/
# RELION: MPI sharpening, masking, FSC and local-resolution of reconstructed maps

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--i=[input name of half1, e.g. run_half1_class001_unfil.mrc]:file:_files' \
  '--i2=[input name of half2]:file:_files' \
  '--ios=[input tomo optimiser set file]:file:_files' \
  '--o=[output rootname]:file:_files' \
  '--angpix=[pixel size (A)]:value' \
  '--half_maps[write post-processed half maps for validation]' \
  '--mtf_angpix=[pixel size in the original micrographs/movies (A)]:value' \
  '--molweight=[molecular weight (kDa) of ordered protein mass]:value' \
  '--auto_mask[perform automated masking based on a density threshold]' \
  '--inimask_threshold=[density at which to threshold for initial seed mask]:value' \
  '--extend_inimask=[number of pixels to extend the initial seed mask]:value' \
  '--width_mask_edge=[width for the raised cosine soft mask edge (pixels)]:value' \
  '--mask=[filename of a user-provided mask]:file:_files' \
  '--force_mask[use the mask even when masked resolution is worse]' \
  '--mtf=[STAR-file with the MTF-curve of the detector]:file:_files' \
  '--auto_bfac[perform automated B-factor determination]' \
  '--autob_lowres=[lowest resolution (A) to include in B-factor fitting]:value' \
  '--autob_highres=[highest resolution (A) to include in B-factor fitting]:value' \
  '--adhoc_bfac=[user-provided B-factor (A^2) for map sharpening]:value' \
  '--skip_fsc_weighting[do not use FSC-weighting in sharpening]' \
  '--low_pass=[resolution (A) to low-pass filter the final map]:value' \
  '--locres[perform local resolution estimation]' \
  '--locres_sampling=[sampling rate (A) for local-resolution map]:value' \
  '--locres_maskrad=[radius (A) of spherical mask for local-resolution]:value' \
  '--locres_edgwidth=[width of soft edge (A) on masks for local-resolution]:value' \
  '--locres_randomize_at=[randomize phases from this resolution (A)]:value' \
  '--locres_minres=[lowest local resolution allowed (A)]:value' \
  '--ampl_corr[perform amplitude correlation and DPR]' \
  '--randomize_at_fsc=[randomize phases where FSC drops below this value]:value' \
  '--randomize_at_A=[randomize phases from this resolution (A) onwards]:value' \
  '--filter_edge_width=[width of raised cosine on low-pass filter edge]:value' \
  '--interpolate[interpolate the FSC for a more precise estimate]' \
  '--verb=[verbosity]:value' \
  '--random_seed=[seed for random number generator]:value' \
  '*:file:_files' && ret=0

return ret
