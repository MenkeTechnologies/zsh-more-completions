#compdef mergedx
# Documentation: https://apbs.readthedocs.io/en/latest/using/tools.html
# Combine OpenDX files into a single resampled map

local ret=1

_arguments -s \
  '-v[verbose output]' \
  '-quiet[silent operation]' \
  '-pad[number of pad grid points]:integer' \
  '-o[output file]:file:_files -g "*.dx"' \
  '*:OpenDX file:_files -g "*.dx"' && ret=0

return ret
