#compdef solana-verify
# Documentation: https://github.com/Ellipsis-Labs/solana-verifiable-build
# solana-verify - deterministically build and verify Solana programs

local curcontext="$curcontext" state line ret=1
local -a sub

sub=(
  'build:build the program with verified reproducibility'
  'verify-from-image:verify against a built container image'
  'verify-from-repo:verify a deployment against repository source'
  'get-executable-hash:print the executable hash of a program'
  'get-program-hash:print the hash of an on-chain program'
  'get-buffer-hash:print the hash of a buffer account'
  'list-program-pdas:list program-associated accounts'
  'remote:submit jobs to remote verification workers'
  'export-pda-tx:generate transaction data for on-chain PDAs'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-u --url)'{-u,--url}'=[network RPC endpoint]:url:' \
  '(-k --keypair)'{-k,--keypair}'=[signing keypair path]:file:_files' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd) _describe -t commands 'solana-verify command' sub && ret=0 ;;
  args)
    case $words[1] in
      verify-from-repo) _arguments '--program-id=[on-chain program id]:id:' '--remote[upload verification on-chain]' && ret=0 ;;
    esac
    ;;
esac

return ret
