#compdef fleetdm fleetctl fleetdm-cli
# _fleetdm — Fleet Device Management fleetdm CLI command-line frontend to the Fleet Open Source osquery-based device management deployment endpoint visibility security posture compliance vulnerability software scheduled-queries hosts teams users policies live-queries-fleet-api-management for osquery-powered fleet (Fleet team, Go); cobra
# upstream: https://fleetdm.com/

_fleetdm() {
    local -a sub=(
        'apply:apply configuration'
        'config:configuration'
        'convert:convert configuration'
        'debug:debug operations'
        'delete:delete resources'
        'eitherctl:either operations'
        'gitops:gitops apply'
        'get:fetch resources'
        'goquery:open goquery'
        'hosts:hosts operations'
        'login:authenticate'
        'logout:revoke session'
        'package:build agent installer package'
        'preview:preview Fleet locally'
        'preview-mock:mock preview'
        'query:run live query'
        'queries:saved queries'
        'setup:initial setup'
        'trigger:trigger schedules'
        'updates:fetch product updates'
        'user:user operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--context=+[ctx]:str:' \
        '-c+[config]:file:_files -g "*.yml *.yaml *.json"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json"' \
        '--insecure[skip TLS verify]' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fleetdm subcommand' sub ;;
        args)
            case $words[1] in
                apply|delete|get) _arguments '*:file:_files -g "*.yml *.yaml *.json"' ;;
                query) _arguments \
                    '--hosts=+[list]:str:' \
                    '--labels=+[list]:str:' \
                    '--query=+[SQL]:str:' \
                    '--query-name=+[name]:str:' ;;
            esac
            ;;
    esac
}

_fleetdm "$@"
