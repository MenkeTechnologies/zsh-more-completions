#compdef bwm-ng

# Zsh completion for bwm-ng (bandwidth monitor NG)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-t --timeout)'{-t,--timeout}'=[Set update interval in ms]:milliseconds' \
  '(-d --dynamic)'{-d,--dynamic}'=[Show dynamic (transfer rate) or total]:mode:(0 1)' \
  '(-I --interfaces)'{-I,--interfaces}'=[Comma-separated list of interfaces]:interfaces' \
  '(-o --output)'{-o,--output}'=[Output method]:method:(plain curses csv html)' \
  '(-u --unit)'{-u,--unit}'=[Unit to display]:unit:(bytes bits packets errors)' \
  '(-T --type)'{-T,--type}'=[Type of data]:type:(rate max sum avg)' \
  '(-c --count)'{-c,--count}'=[Number of samples to take]:count' \
  '(-C --csvchar)'{-C,--csvchar}'=[CSV separator char]:char' \
  '(-F --outfile)'{-F,--outfile}'=[Output file]:file:_files' \
  '(-f --configfile)'{-f,--configfile}'=[Config file]:file:_files' \
  '(-a --allif)'{-a,--allif}'=[Show all interfaces]:mode:(0 1)' \
  '(-N --ansiout)'{-N,--ansiout}'[Use ANSI escape codes for output]' \
  '(-D --daemon)'{-D,--daemon}'=[Fork to background]:pid file:_files' \
  '(-h --help)'{-h,--help}'[Print help]' \
  '(-V --version)'{-V,--version}'[Print version]' && ret=0

return ret
