#compdef cert-manager-webhook

# cert-manager-webhook: cert-manager admission webhook
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--v=[log verbosity]:n:' \
  '--secure-port=[webhook port]:port:' \
  '--healthz-port=[healthz port]:port:' \
  '--bind-address=[bind address]:addr:' \
  '--healthz-bind-address=[healthz bind address]:addr:' \
  '--tls-cert-file=[TLS cert file]:file:_files' \
  '--tls-private-key-file=[TLS key file]:file:_files' \
  '--tls-min-version=[min TLS version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
  '--tls-cipher-suites=[TLS cipher suites]:list:' \
  '--dynamic-serving-ca-secret-namespace=[dynamic serving CA namespace]:ns:' \
  '--dynamic-serving-ca-secret-name=[dynamic serving CA name]:name:' \
  '--dynamic-serving-dns-names=[dynamic serving DNS names]:list:' \
  '--profiler-address=[profiler addr]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '*::cert-manager-webhook args:_files' && ret=0
return ret
