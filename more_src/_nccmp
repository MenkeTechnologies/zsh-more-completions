#compdef nccmp
# Documentation: https://gitlab.com/remikz/nccmp
# Source: nccmp README.md — compare two netCDF files bitwise, semantically, or within a tolerance.
# Reference accessed: 2026-06-20

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-A --Attribute)'{-A,--Attribute=}'[ignore attribute(s) for all variables]:atts:_default' \
    '(-b --verbose)'{-b,--verbose}'[print progress messages]' \
    '(-B --buffer-entire-var)'{-B,--buffer-entire-var}'[load entire variable into memory]' \
    '(-c --var-diff-count)'{-c,--var-diff-count=}'[stop a variable after COUNT data diffs]:count:_default' \
    '(-C --diff-count)'{-C,--diff-count=}'[stop after COUNT total data diffs]:count:_default' \
    '(-d --data)'{-d,--data}'[compare data (variable values)]' \
    '(-D --debug)'{-D,--debug}'[print verbose debug messages]' \
    '(-e --encoding)'{-e,--encoding}'[compare variable encoding settings]' \
    '(-f --force)'{-f,--force}'[do not stop after first difference]' \
    '(-F --fortran)'{-F,--fortran}'[Fortran-style (1-based reverse) position indices]' \
    '(-g --global)'{-g,--global}'[compare global attributes]' \
    '(-G --globalex)'{-G,--globalex}'+[exclude global attributes]:atts:_default' \
    '(-h --history)'{-h,--history}'[compare global history attribute]' \
    '(-H --help)'{-H,--help}'[show usage message]' \
    '(-i --info)'{-i,--info}'[print file structure info]' \
    '(-j --join-tolerance)'{-j,--join-tolerance}'[join absolute and percent tolerance checks]' \
    '(-l --color)'{-l,--color}'[print colored messages]' \
    '(-m --metadata)'{-m,--metadata}'[compare metadata]' \
    '(-M --missing)'{-M,--missing}'[ignore missing_value/_FillValue differences]' \
    '(-n --threads)'{-n,--threads=}'[use N POSIX threads]:n:_default' \
    '(-N --nans-are-equal)'{-N,--nans-are-equal}'[treat NaNs as equal]' \
    '(-p --precision)'{-p,--precision=}'[difference-printing precision format]:fmt:_default' \
    '(-P --header-pad)'{-P,--header-pad}'[compare header padding]' \
    '(-q --quiet)'{-q,--quiet}'[do not print differences]' \
    '(-r --group)'{-r,--group=}'[compare group(s)]:groups:_default' \
    '(-R --no-subgroups)'{-R,--no-subgroups}'[do not compare nested groups]' \
    '(-s --report-identical-files)'{-s,--report-identical-files}'[report when files are the same]' \
    '(-S --statistics)'{-S,--statistics}'[report data difference statistics]' \
    '(-t --tolerance)'{-t,--tolerance=}'[absolute difference tolerance]:tol:_default' \
    '(-T --Tolerance)'{-T,--Tolerance=}'[relative percent difference tolerance]:pct:_default' \
    '(-v --variable)'{-v,--variable=}'[compare only listed variable(s)]:vars:_default' \
    '(-V --version)'{-V,--version}'[print program version]' \
    '(-w --warn)'{-w,--warn=}'[promote certain differences to exceptions]:tags:(all format eos)' \
    '(-x --exclude)'{-x,--exclude=}'[exclude variable(s)]:vars:_default' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
