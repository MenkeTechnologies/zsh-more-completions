#compdef mkdtboimg

# mkdtboimg: build Android dtbo.img (device tree overlay)
# Documentation: https://source.android.com/docs/core/architecture/dto/partitions
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create dtbo.img'
  'cfg_create:create dtbo.img from config file'
  'dump:dump dtbo.img info'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--page_size=[page size]:n:' \
  '--id=[dt id]:hex:' \
  '--rev=[dt revision]:hex:' \
  '--custom0=[custom0]:hex:' \
  '--custom1=[custom1]:hex:' \
  '--custom2=[custom2]:hex:' \
  '--custom3=[custom3]:hex:' \
  '--version=[dtbo version]:n:(0 1)' \
  '--dtb[show DTB info as JSON]:file:_files' \
  '-o[output file]:file:_files' \
  '--output=[output file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mkdtboimg command' commands && ret=0 ;;
esac
return ret
