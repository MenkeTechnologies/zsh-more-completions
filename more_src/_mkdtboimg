#compdef mkdtboimg
# Documentation: https://android.googlesource.com/platform/system/libufdt/+/refs/heads/main/utils/src/mkdtboimg.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mkdtboimg: build Android dtbo.img (device tree overlay)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create dtbo.img from one or more DTB files'
  'cfg_create:create dtbo.img from a config file'
  'dump:dump dtbo.img info and optionally extract DTBs'
  'help:show usage information'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd)
    _describe -t commands 'mkdtboimg command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      create)
        _arguments \
          '--dt_type=[device tree type]:type:(dtb dtbo)' \
          '--page_size=[page size]:n' \
          '--version=[dtbo version]:n:(0 1)' \
          '--id=[dt id]:hex' \
          '--rev=[dt revision]:hex' \
          '--flags=[dt flags]:hex' \
          '--custom0=[custom0]:hex' \
          '--custom1=[custom1]:hex' \
          '--custom2=[custom2]:hex' \
          '--custom3=[custom3]:hex' \
          '1:output image:_files' \
          '*:dtb file:_files -g "*.dtb"' && ret=0
        ;;
      cfg_create)
        _arguments \
          '(-d --dtb-dir)'{-d+,--dtb-dir=}'[directory for DTB files]:dir:_files -/' \
          '1:output image:_files' \
          '2:config file:_files' && ret=0
        ;;
      dump)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
          '(-b --dtb)'{-b+,--dtb=}'[extract DTB files with prefix]:prefix' \
          '--decompress[decompress embedded files]' \
          '1:dtbo image:_files' && ret=0
        ;;
      help)
        _arguments \
          '1::command:(create cfg_create dump)' && ret=0
        ;;
    esac
    ;;
esac
return ret
