#compdef foamEtcFile
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamEtcFile — locate OpenFOAM configuration / etc files (~/.OpenFOAM, $WM_PROJECT_DIR/etc/...).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-all[return all files (default: stop after first match)]' \
    '-list[list the directories to be searched]' \
    '-mode[combination of u/g/o (user/group/other)]:mode:' \
    '-prefix[alternative installation prefix]:dir:_directories' \
    '-quiet[suppress all normal output]' \
    '-silent[suppress all stderr output]' \
    '-version[OpenFOAM version Maj.Min.Rev]:ver:' \
    '-help[print usage]' \
    '*:etc file:_files' \
    && ret=0

return ret
