#compdef sphere_selector
# Documentation: https://wiki.docking.org/index.php/Sphere_Selector
# sphere_selector - DOCK6 select spheres within radius of an atom set.

local ret=1

_arguments -s \
  '1:sphere cluster file (.sph):_files' \
  '2:atom set (.mol2):_files' \
  '3:radius (angstroms):' && ret=0

return ret
