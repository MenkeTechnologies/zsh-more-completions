#compdef suxmovie
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/graphics/xplot/suxmovie.c
# X-windows movie plot of a 3D SU data cube via xmovie

local ret=1

_arguments -s -S \
  'n1=[number of samples per trace]:n1' \
  'ntr=[number of traces in the data set]:ntraces' \
  'n2=[number of traces in inline direction]:n2' \
  'n3=[number of traces in crossline direction]:n3' \
  'd1=[sampling interval in the fast dimension]:d1' \
  'd2=[sampling interval in the slow dimension]:d2' \
  'd3=[sampling interval in the slowest dimension]:d3' \
  'f1=[first sample in the z dimension]:f1' \
  'f2=[first sample in the x dimension]:f2' \
  'f3=[first sample in the y dimension]:f3' \
  'mode=[slice mode 0=inline 1=crossline 2=time slice]:mode:(0 1 2)' \
  'verbose=[print useful information]:verbose:(0 1)' \
  'tmpdir=[directory path prefix for temporary files]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
