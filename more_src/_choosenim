#compdef choosenim
# Documentation: https://github.com/dom96/choosenim
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '--firstInstall[used by install script]' \
  '--choosenimDir=[set toolchain install directory]:dir:_files -/' \
  '--nimbleDir=[set Nimble binary directory]:dir:_files -/' \
  '--verbose[enable verbose output]' \
  '--debug[enable debug output]' \
  '--noColor[disable colored output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command or version:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'stable:install/select latest stable version'
      'devel:install/select latest development version'
      '#version:install/select a specific version'
      'show:show current Nim version and channel'
      'update:update choosenim or installed versions'
      'versions:list available and installed versions'
      'remove:remove a Nim version'
    )
    _describe -t commands 'command or version' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (remove)
        _arguments '1:version:' && ret=0
        ;;
      (update)
        _arguments '1:target:(self stable devel)' && ret=0
        ;;
      (versions)
        _arguments '--installed[show only installed versions]' && ret=0
        ;;
      (show)
        _arguments '1:subcommand:(path)' && ret=0
        ;;
    esac
    ;;
esac

return ret
