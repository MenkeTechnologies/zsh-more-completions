#compdef choosenim

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '--firstInstall[used by install script]' \
  '--nimDir=[set Nim directory]:dir:_files -/' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command or version:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'stable:install/select latest stable version'
      'devel:install/select latest development version'
      '#version:install/select a specific version'
      'show:show current Nim version'
      'update:update choosenim and installed versions'
      'versions:list available and installed versions'
      'remove:remove a Nim version'
    )
    _describe -t commands 'command or version' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (remove)
        _arguments '1:version:' && ret=0
        ;;
      (update)
        _arguments '1:target:(self stable devel)' && ret=0
        ;;
    esac
    ;;
esac

return ret
