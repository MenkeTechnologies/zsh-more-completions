#compdef mlxuptime
# Documentation: https://man.archlinux.org/search?q=mlxuptime
# Reference accessed: 2026-05-16

# mlxuptime: show Mellanox device uptime since last reset
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[device]:dev:' \
  '--device=[device]:dev:' \
  '*::mlxuptime args:_files' && ret=0
return ret
