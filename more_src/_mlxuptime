#compdef mlxuptime
# Documentation: https://docs.nvidia.com/networking/display/mftv4340/mlxuptime-utility
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d+,--device=}'[mst device]:dev:' \
  '(-s --sample)'{-s+,--sample=}'[sampling interval (sec)]:s:' \
  '(-f --force_sample)'{-f,--force_sample}'[force sampling instead of reading uptime]' && ret=0
return ret
