#compdef vexctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create VEX document'
  'add:add statement to VEX'
  'filter:filter VEX by products'
  'merge:merge VEX documents'
  'validate:validate VEX JSON'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(* -)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'vexctl command' commands && ret=0
    ;;
  (args)
    _arguments '*:vexctl args: _default' && ret=0
    ;;
esac

return ret
