#compdef vexctl
# Documentation: https://github.com/openvex/vexctl
# Reference accessed: 2026-05-21
# Verified: upstream source tree under internal/cmd/.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:add a statement to a VEX document'
  'attest:attest and attach VEX statements to a container image'
  'create:create a new VEX document'
  'filter:filter scanner results (SARIF) by VEX documents'
  'generate:generate a VEX document'
  'list:list operations'
  'merge:merge multiple VEX documents'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'vexctl command' commands && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
