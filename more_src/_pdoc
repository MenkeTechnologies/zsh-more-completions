#compdef pdoc
# _pdoc — Python API documentation generator (mitmproxy/pdoc)
# upstream: https://github.com/mitmproxy/pdoc

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--host=[development server host]:host:' \
  '(-p --port)'{-p,--port}'=[development server port]:port:' \
  '--no-browser[do not open browser]' \
  '--docformat=[docstring format]:format:(google numpy restructuredtext)' \
  '(-o --output-directory)'{-o,--output-directory}'=[output directory]:dir:_files -/' \
  '(-t --template-directory)'{-t,--template-directory}'=[template directory]:dir:_files -/' \
  '--math[enable math rendering]' \
  '--mermaid[enable mermaid diagrams]' \
  '--search[enable search]' \
  '--logo=[logo URL]:url:' \
  '--logo-link=[logo link URL]:url:' \
  '--favicon=[favicon URL]:url:' \
  '--footer-text=[footer text]:text:' \
  '--edit-url=[edit URL template]:url:' \
  '--no-show-source[hide source code]' \
  '--no-include-undocumented[hide undocumented members]' \
  '*:module:_python_modules'
