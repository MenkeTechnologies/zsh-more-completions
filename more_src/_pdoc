#compdef pdoc

local -a arguments

arguments=(
  '(-o --output-directory)'{-o,--output-directory}'=[output directory]:directory:_files -/'
  '--html[generate HTML output]'
  '--pdf[generate PDF output]'
  '--math[enable math rendering]'
  '--mermaid[enable mermaid diagram rendering]'
  '--logo=[custom logo URL]:url:'
  '--logo-link=[custom logo link URL]:url:'
  '--favicon=[custom favicon URL]:url:'
  '--footer-text=[custom footer text]:text:'
  '--edit-url=[link to source repository]:module=url:'
  '--no-show-source[do not show source code]'
  '--no-include-undocumented[exclude undocumented members]'
  '--no-search[disable search]'
  '-t[custom template directory]:directory:_files -/'
  '--template-directory=[custom template directory]:directory:_files -/'
  '(-d --docformat)'{-d,--docformat}'=[docstring format]:format:(google numpy restructuredtext markdown)'
  '-n[host for HTTP server]:host:'
  '-p[port for HTTP server]:port:'
  '--host=[host for HTTP server]:host:'
  '--port=[port for HTTP server]:port:'
  '--no-browser[do not open browser]'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version]'
  '*:module:'
)

_arguments -s -S $arguments
