#compdef sukdsyn2d
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/synthetics_waveforms_testpatterns/sukdsyn2d.c
# 2D prestack Kirchhoff synthetic data generation

local ret=1

_arguments -s -S \
  'infile=[input reflectivity file]:file:_files' \
  'outfile=[output synthetic data file]:file:_files' \
  'ttfile=[input traveltime tables file]:file:_files' \
  'fzt=[first depth sample in traveltime table]:fzt' \
  'nzt=[number of depth samples in traveltime table]:nzt' \
  'dzt=[depth interval in traveltime table]:dzt' \
  'fxt=[first lateral sample in traveltime table]:fxt' \
  'nxt=[number of lateral samples in traveltime table]:nxt' \
  'dxt=[lateral interval in traveltime table]:dxt' \
  'fs=[first source coordinate]:fs' \
  'ns=[number of sources]:ns' \
  'ds=[source coordinate interval]:ds' \
  'fz=[first depth sample of reflectivity]:fz' \
  'dz=[depth interval of reflectivity]:dz' \
  'nz=[number of depth samples of reflectivity]:nz' \
  'fx=[first lateral sample of reflectivity]:fx' \
  'dx=[lateral interval of reflectivity]:dx' \
  'nx=[number of lateral samples of reflectivity]:nx' \
  'nt=[number of time samples]:nt' \
  'dt=[time sampling interval]:dt' \
  'ft=[first time sample]:ft' \
  'nxo=[number of output midpoints]:nxo' \
  'dxo=[output midpoint interval]:dxo' \
  'fxo=[first output midpoint]:fxo' \
  'nxs=[number of shots]:nxs' \
  'dxs=[shot interval]:dxs' \
  'fxs=[first shot coordinate]:fxs' \
  'fmax=[maximum frequency]:fmax' \
  'aperx=[lateral aperture]:aperx' \
  'angmax=[maximum angle]:angmax' \
  'v0=[reference velocity at surface]:v0' \
  'dvz=[velocity vertical gradient]:dvz' \
  'ls=[1 for line source]:ls:(0 1)' \
  'jpfile=[job print file]:file:_files' \
  'mtr=[print verbose info every mtr traces]:mtr' \
  '*:file:_files' && ret=0

return ret
