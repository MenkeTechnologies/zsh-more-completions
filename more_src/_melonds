#compdef melonds melonDS
# Documentation: https://github.com/melonDS-emu/melonDS/blob/master/src/frontend/qt_sdl/CLI.cpp
# Reference accessed: 2026-05-16
# Verified: src/frontend/qt_sdl/CLI.cpp lines 36-122 (QCommandLineParser).
# -V/--version is Qt's built-in.

# melonDS: Nintendo DS emulator (Qt frontend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-b --boot)'{-b,--boot=}'[firmware boot mode]:mode:(auto always never)' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen]' \
  '(-a --archive-file)'{-a,--archive-file=}'[load file inside NDS archive]:rom:' \
  '(-A --archive-file-gba)'{-A,--archive-file-gba=}'[load file inside GBA archive]:rom:' \
  '*:NDS or GBA ROM:_files -g "*.(nds|gba|zip|7z|rar)"' && ret=0
return ret
