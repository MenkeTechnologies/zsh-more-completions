#compdef prte-term
# Documentation: https://man.archlinux.org/search?q=prte-term
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--pid+[PID of DVM to terminate]:pid:_pids' && ret=0

return ret
