#compdef spop

# spop: Spotify command-line daemon / mpd-like CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'play:start playback'
  'toggle:play/pause toggle'
  'stop:stop playback'
  'next:next track'
  'prev:previous track'
  'qls:list current queue'
  'add:add a URI to the queue'
  'rm:remove from queue'
  'clear:clear queue'
  'status:show status'
  'volume:set volume'
  'repeat:toggle repeat'
  'shuffle:toggle shuffle'
  'image:cover image of current track'
  'help:show help'
  'quit:quit the spop daemon'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d[daemonize]' \
  '-v[verbose]' \
  '-c[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'spop command' commands && ret=0 ;;
esac
return ret
