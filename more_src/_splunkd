#compdef splunkd

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the daemon'
  'stop:stop the daemon'
  'restart:restart the daemon'
  'status:show daemon status'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--accept-license[accept license]' \
  '--answer-yes[answer yes to all prompts]' \
  '--no-prompt[no prompts]' \
  '--under-systemd[run under systemd]' \
  '--systemd-delegate=[systemd delegate]:flag:(yes no)' \
  '-p=[port]:port:' \
  '1: :->action' \
  '*::arg:->args' && ret=0

case $state in
  (action)
    _describe -t actions 'splunkd action' actions && ret=0
    ;;
esac

return ret
