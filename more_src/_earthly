#compdef earthly

# Zsh completion for earthly - CI/CD build tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'prune:prune Earthly cache'
  'docker:manage docker-related operations'
  'account:manage Earthly account'
  'org:manage Earthly organizations'
  'secret:manage Earthly secrets'
  'ls:list targets from an Earthfile'
  'doc:show documentation for targets'
)

_arguments -s -S \
  '1:target or command:->target_or_command' \
  '--ci[enable CI mode]' \
  '--push[enable pushing images and artifacts]' \
  '--no-output[do not output build artifacts]' \
  '--no-cache[do not use cache]' \
  '--artifact[output only specified artifact]:artifact' \
  '--image[output only specified image]:image' \
  '*--platform[set target platform]:platform' \
  '*--build-arg[set a build arg]:key=value' \
  '*--secret[pass a secret to the build]:id=value' \
  '--ssh-auth-sock[SSH auth socket path]:path:_files' \
  '--allow-privileged[allow privileged mode]' \
  '--config[path to earthly config file]:file:_files' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
  '--debug[enable debug mode]' \
  '--no-fake-dep[do not use fake dependencies]' \
  '--strict[enable strict mode]' \
  '--conversion-parallelism[set conversion parallelism]:number' \
  '--org[organization name]:org' \
  '--satellite[satellite name]:satellite' \
  '--use-inline-cache[attempt to use inline cache]' \
  '--save-inline-cache[save inline cache]' \
  '--remote-cache[set remote cache image]:image' \
  '--max-remote-cache[use all layers for remote cache]' \
  '--interactive[start an interactive debugger on failure]' \
  '--output[enable output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (target_or_command)
    local -a targets
    if [[ -f Earthfile ]]; then
      targets=("${(@f)$(grep -E '^\S+:$' Earthfile 2>/dev/null | sed 's/:$//' | sed 's/^/+/')}")
    fi
    _describe -t commands 'earthly command' commands
    if (( ${#targets} )); then
      _describe -t targets 'earthly target' targets
    fi
    ret=0
    ;;
  (args)
    case $words[1] in
      (prune)
        _arguments -s -S \
          '--all[prune all cache]' \
          '--reset[reset the cache entirely]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (secret)
        local -a secret_cmds=(
          'set:set a secret'
          'get:get a secret'
          'rm:remove a secret'
          'ls:list secrets'
          'migrate:migrate secrets'
        )
        _arguments -s -S \
          '1:subcommand:->secret_cmd' \
          '*:: :->secret_args' && ret=0
        case $state in
          (secret_cmd) _describe -t commands 'secret command' secret_cmds && ret=0 ;;
        esac
        ;;
      (account)
        local -a account_cmds=(
          'register:register an Earthly account'
          'login:login to an Earthly account'
          'logout:logout from an Earthly account'
          'list-keys:list registered public keys'
          'add-key:add a public key'
          'remove-key:remove a public key'
          'list-tokens:list access tokens'
          'create-token:create an access token'
          'remove-token:remove an access token'
        )
        _arguments -s -S \
          '1:subcommand:->account_cmd' \
          '*:: :->account_args' && ret=0
        case $state in
          (account_cmd) _describe -t commands 'account command' account_cmds && ret=0 ;;
        esac
        ;;
      (org)
        local -a org_cmds=(
          'create:create a new organization'
          'list:list organizations'
          'list-permissions:list organization permissions'
          'invite:invite a user to an organization'
          'revoke:revoke a user from an organization'
        )
        _arguments -s -S \
          '1:subcommand:->org_cmd' \
          '*:: :->org_args' && ret=0
        case $state in
          (org_cmd) _describe -t commands 'org command' org_cmds && ret=0 ;;
        esac
        ;;
      (ls|doc)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:target or path:_files' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
