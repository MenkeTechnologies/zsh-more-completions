#compdef boggle
# Documentation: man boggle(6)
# Source: openbsd/src games/boggle/boggle/bog.c — word search game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-B[5x5 grid (Big Boggle)]' \
    '-b[batch mode]' \
    '-c[challenge mode]' \
    '-d[debug]' \
    '-t+[time limit in seconds]:secs:_default' \
    '-w+[minimum word length]:N:_default' \
    '1::cube board:_default' \
    '2::starting word:_default' \
    && ret=0

return ret
