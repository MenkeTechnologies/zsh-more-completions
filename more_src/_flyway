#compdef flyway

# Zsh completion for Flyway database migration

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'migrate:migrate the database'
  'clean:drop all objects in the configured schemas'
  'info:print details and status about all migrations'
  'validate:validate applied migrations against available ones'
  'undo:undo the most recently applied versioned migration'
  'baseline:baseline an existing database'
  'repair:repair the schema history table'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-url=[JDBC url for the database]:url:' \
  '-driver=[JDBC driver class name]:driver:' \
  '-user=[database user]:user:' \
  '-password=[database password]:password:' \
  '-connectRetries=[max retries when connecting]:retries:' \
  '-schemas=[comma-separated list of schemas]:schemas:' \
  '-table=[name of the schema history table]:table:' \
  '-locations=[comma-separated list of locations to scan]:locations:' \
  '-sqlMigrationPrefix=[file name prefix for SQL migrations]:prefix:' \
  '-repeatableSqlMigrationPrefix=[file name prefix for repeatable migrations]:prefix:' \
  '-baselineVersion=[version to tag an existing schema with]:version:' \
  '-baselineDescription=[description for the baseline]:description:' \
  '-configFiles=[comma-separated list of config files]:config files:_files' \
  '-outputType=[output type]:type:(json)' \
  '*:: :->subcmd' && ret=0

case $state in
  subcmd)
    if (( CURRENT == 1 )); then
      _describe -t commands 'flyway command' subcommands && ret=0
    fi
    ;;
esac

return ret
