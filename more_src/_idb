#compdef idb

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list-targets:list available targets'
  'connect:connect to a target'
  'disconnect:disconnect from a target'
  'install:install an app'
  'uninstall:uninstall an app'
  'launch:launch an app'
  'terminate:terminate an app'
  'list-apps:list installed apps'
  'log:tail device logs'
  'record:record screen video'
  'screenshot:take a screenshot'
  'describe:describe a target'
  'focus:focus a simulator window'
  'open:open a URL'
  'contacts:manage contacts'
  'set-location:set simulated location'
  'approve:approve permissions'
  'accessibility:accessibility commands'
  'push:send a push notification'
  'pull:pull files from target'
  'mkdir:create a directory on target'
  'mv:move files on target'
  'rm:remove files on target'
  'ls:list files on target'
  'xctest:run xctests'
  'dsym:manage debug symbols'
  'debugserver:manage debug server'
  'crash:manage crash logs'
  'instruments:run instruments'
  'hid:simulate HID events'
  'boot:boot a simulator'
  'shutdown:shutdown a simulator'
  'erase:erase a simulator'
  'clone:clone a simulator'
  'create:create a simulator'
  'delete:delete a simulator'
  'clean:clean idb state'
  'kill:kill idb companion'
  'companion:manage companion processes'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--udid=[target UDID]:udid' \
  '--log=[log level]:level:(DEBUG INFO WARNING ERROR)' \
  '--json[JSON output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'idb command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments '1:app bundle:_files -g "*.{app,ipa}"' && ret=0
        ;;
      (uninstall|launch|terminate)
        _arguments '1:bundle identifier' && ret=0
        ;;
      (screenshot)
        _arguments '1:output file:_files -g "*.png"' && ret=0
        ;;
      (record)
        _arguments '1:output file:_files -g "*.mp4"' && ret=0
        ;;
      (open)
        _arguments '1:URL' && ret=0
        ;;
      (push)
        _arguments \
          '1:bundle identifier' \
          '2:payload file:_files -g "*.json"' && ret=0
        ;;
      (set-location)
        _arguments '1:latitude' '2:longitude' && ret=0
        ;;
      (approve)
        _arguments \
          '1:bundle identifier' \
          '*:permissions:(photos camera contacts url microphone location notification)' && ret=0
        ;;
      (pull)
        _arguments \
          '--bundle-id=[app bundle ID]:bundle ID' \
          '1:source path' \
          '2:destination:_files' && ret=0
        ;;
      (xctest)
        local -a xctest_cmds=('install:install test bundle' 'list:list test bundles' 'list-bundle:list tests in bundle' 'run:run tests')
        _arguments '1:xctest command:_describe -t xctest-cmds "xctest command" xctest_cmds' && ret=0
        ;;
      (log)
        _arguments '--system[show system logs]' && ret=0
        ;;
      (crash)
        local -a crash_cmds=('list:list crashes' 'show:show crash log' 'delete:delete crashes')
        _arguments '1:crash command:_describe -t crash-cmds "crash command" crash_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
