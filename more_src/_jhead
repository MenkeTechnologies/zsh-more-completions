#compdef jhead

# Zsh completion for jhead (JPEG Exif header manipulation tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-dt[remove Exif thumbnails]' \
  '-dc[remove comment fields]' \
  '-de[remove Exif data entirely]' \
  '-di[remove IPTC data]' \
  '-dx[remove XMP data]' \
  '-du[remove non-essential data]' \
  '-purejpg[strip all metadata]' \
  '-mkexif[create minimal Exif header]' \
  '-ce[edit comment field]' \
  '-cs[save comment to file]:file:_files' \
  '-ci[insert comment from file]:file:_files' \
  '-cl[set comment to string]:comment' \
  '-ft[set file modification time from Exif]' \
  '-dsft[set Exif time from file modification time]' \
  '-n[rename files using Exif date]:format string' \
  '-nf[rename with name format]:format string' \
  '-a[auto-rotate based on Exif orientation]' \
  '-norot[do not rotate]' \
  '-rgt[regenerate Exif thumbnail]' \
  '-q[quiet mode]' \
  '-V[print version]' \
  '-v[verbose output]' \
  '-se[suppress error messages]' \
  '-c[concise output]' \
  '-model[show camera model]' \
  '-exifmap[show Exif structure]' \
  '-da[specify date adjustment]:date adjustment' \
  '-ta[adjust Exif time]:time adjustment' \
  '-ts[set Exif time]:time (yyyy\:mm\:dd-hh\:mm\:ss)' \
  '-cmd[apply command to each file]:command' \
  '-orp[only process portrait orientation]' \
  '-orl[only process landscape orientation]' \
  '*:JPEG file:_files -g "*.{jpg,jpeg,JPG,JPEG}"' && ret=0

return ret
