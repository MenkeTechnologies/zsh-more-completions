#compdef jhead
# Documentation: https://www.sentex.ca/~mwandel/jhead/usage.html
# Reference accessed: 2026-05-19
# Verified: upstream usage docs at the URL above.

# Zsh completion for jhead (JPEG Exif header manipulation tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-te[transplant Exif header from image]:image:_files' \
  '-dt[remove Exif thumbnails]' \
  '-dc[remove comment fields]' \
  '-de[remove Exif data entirely]' \
  '-di[remove IPTC section]' \
  '-dx[remove XMP section]' \
  '-du[remove unknown sections]' \
  '-purejpg[strip all metadata]' \
  '-mkexif[create minimal Exif header]' \
  '-ce[edit comment field via editor]' \
  '-cs[save comment section to a file]:file:_files' \
  '-ci[replace comment with text from file]:file:_files' \
  '-cl[replace comment with command-line string]:comment' \
  '-ft[set file modification time from Exif]' \
  '-dsft[set Exif time from file modification time]' \
  '-n[rename/move files using Exif date]:fmt-string:' \
  '-a[auto-rotate based on Exif orientation]' \
  '-autorot[auto-rotate based on Exif orientation]' \
  '-norot[clear rotation tag without rotating]' \
  '-rgt[regenerate Exif thumbnail]' \
  '-rt[replace thumbnails from the Exif header]:image:_files' \
  '-st[save built-in thumbnail to a file]:file:_files' \
  '-q[quiet mode]' \
  '-V[print version]' \
  '-v[verbose output]' \
  '-se[suppress error messages]' \
  '-c[concise output]' \
  '-r[process files recursively]' \
  '-model[restrict processing to specific camera model]:model:' \
  '-quality[restrict by estimated quality factor]:nn:' \
  '-exonly[only work on files with Exif sections]' \
  '-exifmap[show Exif structure]' \
  '-da[specify large date adjustment]:date-date:' \
  '-ta[adjust Exif time by h:mm]:timediff:' \
  '-ts[set Exif date and time]:date-time:' \
  '-ds[set Exif date]:date-time:' \
  '-tf[set Exif time from a file modification time]:file:_files' \
  '-cmd[execute command on each JPEG file]:command:' \
  '-orp[only process portrait orientation]' \
  '-orl[only process landscape orientation]' \
  '*:JPEG file:_files -g "*.{jpg,jpeg,JPG,JPEG}"' && ret=0

return ret
