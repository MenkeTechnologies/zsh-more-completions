#compdef moeda

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '--supported[list supported currencies]' \
  '--latest[show latest exchange rates]' \
  '--base[base currency]:currency code' \
  '--amount[amount to convert]:amount' \
  '--symbols[target currencies, comma-separated]:currencies'
