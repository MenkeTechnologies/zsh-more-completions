#compdef 7kaa
# Documentation: https://github.com/the3dfxdude/7kaa/blob/master/src/CmdLine.cpp
# Reference accessed: 2026-05-16
# Verified: src/CmdLine.cpp option-name constants (lobbyJoin/Host/Name/demoOption/
# noAudioOption/noIfOption/rndOption/speedOption/windowOption)
# Removed from prior file: -h/--help/-v/--version (no source handler), -c/--config,
# -d/--data, --enable-audio, --disable-audio, --fullscreen, --no-fullscreen,
# --w, --h - all invented.

# Seven Kingdoms: Ancient Adversaries (open-source RTS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-join[join multiplayer host (named or IP)]:host:_hosts' \
  '-host[begin by hosting a multiplayer match]' \
  '-name[player name]:name:' \
  '-demo[start a new game in observer mode]' \
  '-noaudio[disable audio]' \
  '-noif[no interface]' \
  '-rnd[set RNG seed]:seed:' \
  '-speed[game speed]:value:' \
  '-win[run in window mode]' \
  '*::extra args:_files' && ret=0
return ret
