#compdef kafka-topics
# Documentation: https://kafka.apache.org/documentation/ (kafka-topics.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--alter[Alter the number of partitions and replica assignment]'
    '--at-min-isr-partitions[Only show partitions whose isr count equals the configured minimum]'
    '--bootstrap-server[REQUIRED: The Kafka server to connect to]:host\:port:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--config[A topic configuration override for the topic being created (name=value)]:config:'
    '--create[Create a new topic]'
    '--delete[Delete a topic]'
    '--delete-config[(DEPRECATED since 4.0, no longer supported)]:name:'
    '--describe[List details for the given topics]'
    '--exclude-internal[Exclude internal topics when listing or describing topics]'
    '--help[Print usage information]'
    '--if-exists[Only execute if the topic exists (alter/delete/describe)]'
    '--if-not-exists[Do not fail if the topic already exists (create)]'
    '--list[List all available topics]'
    '--partition-size-limit-per-response[Max partitions per DescribeTopicPartitions response]:count:'
    '--partitions[The number of partitions for the topic being created or altered]:count:'
    '--replica-assignment[A list of manual partition-to-broker assignments]:assignment:'
    '--replication-factor[The replication factor for each partition]:factor:'
    '--topic[The topic to create, alter, describe or delete (accepts a regex)]:topic:'
    '--topic-id[The topic-id to describe]:id:'
    '--topics-with-overrides[Only show topics that have overridden configs]'
    '--unavailable-partitions[Only show partitions whose leader is not available]'
    '--under-min-isr-partitions[Only show partitions whose isr count is less than minimum]'
    '--under-replicated-partitions[Only show under-replicated partitions]'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
