#compdef arm-linux-gcc arm-linux-gnueabi-gcc arm-linux-gnueabihf-gcc arm-none-linux-gnueabi-gcc arm-none-linux-gnueabihf-gcc
# _arm-linux-gcc — GNU GCC arm-linux-gcc CLI cross-compiler build targeting ARMv7 ARMv6 ARMv5 little-endian Linux Cortex-A Cortex-R generating ELF DWARF binaries with GNU EABI hard-float soft-float ABI Thumb-2 NEON VFPv3 mfloat-abi vector instructions PIE PIC LTO march mtune (GNU team, C); custom argparse
# upstream: https://gcc.gnu.org/

_arm-linux-gcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-E[stop after preprocessor]' \
        '-S[stop after compilation]' \
        '-c[compile or assemble only]' \
        '-o+[output file]:file:_files' \
        '-O+[optimization level]:l:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-g0[no debug info]' \
        '-Wall[enable common warnings]' \
        '-Wextra[enable extra warnings]' \
        '-Werror[treat warnings as errors]' \
        '-pedantic[strict ISO C]' \
        '-fPIC[position independent code]' \
        '-fpic[position independent code]' \
        '-fPIE[position independent executable]' \
        '-pie[link as PIE]' \
        '-static[link statically]' \
        '-shared[link as shared object]' \
        '-mthumb[generate Thumb-2 code]' \
        '-marm[generate ARM code]' \
        '-mfpu=+[fpu]:f:(none vfp vfpv3 vfpv3-d16 vfpv4 neon neon-vfpv4 neon-fp16 fpv5-sp-d16 fpv5-d16 neon-fp-armv8)' \
        '-mfloat-abi=+[abi]:a:(soft softfp hard)' \
        '-mcpu=+[cpu]:c:(cortex-a5 cortex-a7 cortex-a8 cortex-a9 cortex-a15 cortex-a17 cortex-a35 cortex-a53 cortex-a55 cortex-a57 cortex-a72 cortex-a73 cortex-a75 cortex-a76 cortex-r4 cortex-r5 cortex-r7 cortex-r8 cortex-m0 cortex-m3 cortex-m4 cortex-m7 cortex-m33 cortex-m55 generic-armv7-a)' \
        '-mtune=+[tune]:str:' \
        '-march=+[arch]:a:(armv6 armv6-m armv7 armv7-a armv7-r armv7-m armv7e-m armv7ve armv8-a armv8-a+crc armv8.1-a armv8.2-a armv8.3-a armv8.4-a armv8.5-a armv8.6-a)' \
        '-D+[macro]:str:' \
        '-U+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '-isystem+[system include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-Wl,+[linker option]:str:' \
        '-flto[link time optimization]' \
        '-ffunction-sections[per-function sections]' \
        '-fdata-sections[per-data sections]' \
        '-std=+[std]:s:(c89 c99 c11 c17 c23 gnu89 gnu99 gnu11 gnu17 gnu23 c++98 c++11 c++14 c++17 c++20 c++23 gnu++98 gnu++11 gnu++14 gnu++17 gnu++20 gnu++23)' \
        '-MD[generate dependency .d file]' \
        '-MMD[generate dependency .d file no system]' \
        '-MP[add phony rules]' \
        '-MF+[file]:file:_files' \
        '-x+[lang]:l:(c c-header c++ c++-header assembler assembler-with-cpp none)' \
        '--sysroot=+[dir]:dir:_files -/' \
        '*:source file:_files -g "*.c *.cc *.cpp *.cxx *.h *.hpp *.hxx *.s *.S *.o *.a *.so"'
}

_arm-linux-gcc "$@"
