#compdef antora

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'generate:generate documentation site'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-r,--require=}'[require module]:module:' \
  '--stacktrace[print stacktrace on error]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'antora subcommand' subcommands
    _files -g '*.(yml|yaml)' && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '--asciidoc-sourcemap[include AsciiDoc sourcemap]' \
          '*--attribute=[set attribute]:key=val:' \
          '--cache-dir=[cache directory]:dir:_files -/' \
          '--clean[clean output]' \
          '*--extension=[load extension]:ext:' \
          '--fetch[fetch updates from remotes]' \
          '--generator=[site generator]:gen:' \
          '--git-credentials-path=[git credentials file]:file:_files' \
          '--html-url-extension-style=[URL extension style]:style:(default drop indexify)' \
          '--http-proxy=[HTTP proxy]:url:' \
          '--https-proxy=[HTTPS proxy]:url:' \
          '*--key=[key value]:key=val:' \
          '--log-failure-level=[log failure level]:level:(fatal error warn none)' \
          '--log-file=[log file]:file:_files' \
          '--log-format=[log format]:fmt:(json pretty)' \
          '--log-level=[log level]:level:(fatal error warn info debug all silent)' \
          '--log-level-format=[log level format]:fmt:(label number)' \
          '--noproxy=[noproxy hosts]:hosts:' \
          '--quiet[quiet output]' \
          '--redirect-facility=[redirect facility]:facility:(disabled gitlab httpd netlify nginx static)' \
          '--silent[silent]' \
          '--start-page=[start page]:page:' \
          '--title=[site title]:title:' \
          '--to-dir=[output directory]:dir:_files -/' \
          '--ui-bundle-url=[UI bundle URL]:url:' \
          '--url=[site URL]:url:' \
          ':playbook:_files -g "*.(yml|yaml)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
