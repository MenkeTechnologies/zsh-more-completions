#compdef pos2kml
# Documentation: https://manpages.debian.org/bullseye/rtklib/pos2kml.1.en.html
# RTKLIB converter from solution position file to Google Earth KML

local ret=1

_arguments -s \
  '-h[print help]' \
  '-o[output file]:output file:_files' \
  '-c[track color]:color:(0 1 2 3 4 5)' \
  '-p[point color]:color:(0 1 2 3 4 5)' \
  '-a[output altitude information]' \
  '-ag[output geodetic altitude]' \
  '-tg[output time stamp of gpst]' \
  '-tu[output time stamp of utc]' \
  '-i[output time interval (sec)]:interval' \
  '-q[q-flag filter]:qflg' \
  '-f[north/east/height offset (m)]:n: :e: :h:' \
  '*:solution file:_files' && ret=0

return ret
