#compdef cppman
# Documentation: https://github.com/aitjcize/cppman
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# aitjcize/cppman C++ manual pages

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-s)'{-s+,--source=}'[manual source]:source:(cppreference.com cplusplus.com)' \
  {-c,--cache-all}'[download manuals for offline use]' \
  {-C,--clear-cache}'[delete cached pages]' \
  '(-f)'{-f+,--find-page=}'[search keyword with menu]:keyword:' \
  {-o,--force-update}'[refresh cache during cache-all or cache hits]' \
  '(-m)'{-m+,--use-mandb=}'[register cppman pages with mandb]:bool:(true false)' \
  '(-p)'{-p+,--pager=}'[pager backend]:pager:(vim nvim less system)' \
  {-r,--rebuild-index}'[rebuild sqlite index for current source]' \
  {-v,--version}'[show cppman version]' \
  '--force-columns=[force terminal width]:cols:' \
  '(-n)'{-n+,--max-results=}'[cap interactive search results]:count:' \
  '(- *)'{-h,--help}'[usage]' \
  '*:C++ manual keyword:_default' && ret=0

return ret
