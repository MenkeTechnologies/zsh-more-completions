#compdef qselect
# Documentation: https://linux.die.net/man/1/qselect-torque
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# qselect: list job IDs matching criteria
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-a[after time]:datetime:' \
  '-A[account]:account:' \
  '-c[checkpoint]:val:' \
  '-h[hold type]:val:(u o s n)' \
  '-l[resource]:resource:' \
  '-N[job name]:name:' \
  '-p[priority]:n:' \
  '-q[queue]:queue:' \
  '-r[rerunable]:val:(y n)' \
  '-s[state]:state:(Q R H W T S E C)' \
  '-u[user]:user:_users' \
  '-U[user list]:list:' \
  '*::qselect args:_files' && ret=0
return ret
