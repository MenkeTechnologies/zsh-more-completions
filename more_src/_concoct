#compdef concoct
# Documentation: https://github.com/BinPro/CONCOCT/blob/develop/concoct/parser.py
# CONCOCT - unsupervised binning of metagenomic contigs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--coverage_file=[coverage table file]:file:_files' \
  '--composition_file=[composition fasta file]:file:_files' \
  '(-c --clusters)'{-c,--clusters}'=[max number of clusters for VGMM (default 400)]:clusters' \
  '(-k --kmer_length)'{-k,--kmer_length}'=[kmer length (default 4)]:length' \
  '(-t --threads)'{-t,--threads}'=[number of threads]:threads' \
  '(-l --length_threshold)'{-l,--length_threshold}'=[contig length threshold (default 1000)]:length' \
  '(-r --read_length)'{-r,--read_length}'=[read length for coverage (default 100)]:length' \
  '--total_percentage_pca=[variance percent for PCA (default 90)]:percent' \
  '(-b --basename)'{-b,--basename}'=[output basename or directory]:path:_files -/' \
  '(-s --seed)'{-s,--seed}'=[random seed for clustering]:seed' \
  '(-i --iterations)'{-i,--iterations}'=[max iterations for VBGMM (default 500)]:iterations' \
  '--no_cov_normalization[do not normalize coverage]' \
  '--no_total_coverage[do not add total coverage column]' \
  '--no_original_data[do not save original data to disk]' \
  '(-o --converge_out)'{-o,--converge_out}'[write convergence info to files]' \
  '(-d --debug)'{-d,--debug}'[debug parameters]' && ret=0

return ret
