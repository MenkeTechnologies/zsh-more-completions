#compdef lldb-dap
# Documentation: https://man.archlinux.org/search?q=lldb-dap
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-p+,--port=}'[port for DAP server to listen on]:port:' \
  '--connection=[connection URI (e.g. listen://[host]:port)]:uri:' \
  {-g,--pre-init-command}'[command to run before initialization]:command:' \
  '*--pre-init-command=[command to run before initialization]:command:' \
  '--repl-mode=[REPL evaluation mode]:mode:(variable command auto)' \
  {-l+,--launch-target=}'[program to launch (server-then-launch mode)]:program:_files' \
  '--debugger-options=[options to pass to LLDB debugger]:opts:' && ret=0

return ret
