#compdef logseq-cli
# _logseq-cli — Logseq local-first knowledge graph (privacy-first markdown) CLI alias (logseq team, ClojureScript); commander
# upstream: https://github.com/logseq/logseq

_logseq-cli() {
    local -a sub=(
        'graph:list:list graphs'
        'graph:create:create graph'
        'graph:delete:delete graph'
        'graph:open:open graph'
        'graph:export:export graph'
        'graph:import:import graph'
        'graph:rebuild-index:rebuild search index'
        'graph:refresh:refresh files'
        'page:list:list pages'
        'page:create:create page'
        'page:get:get page'
        'page:delete:delete page'
        'page:rename:rename page'
        'page:export:export page'
        'block:get:get block'
        'block:append:append block'
        'block:insert:insert block'
        'block:update:update block'
        'block:delete:delete block'
        'block:move:move block'
        'query:run query'
        'query:datalog:run datalog query'
        'query:simple:run simple query'
        'config:get:get config'
        'config:set:set config'
        'config:list:list config'
        'sync:start:start sync'
        'sync:stop:stop sync'
        'sync:status:show sync status'
        'plugin:list:list plugins'
        'plugin:install:install plugin'
        'plugin:remove:remove plugin'
        'theme:list:list themes'
        'theme:set:set theme'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--graph=+[graph name or path]:str:' \
        '-g+[graph name or path]:str:' \
        '--config=+[config file]:file:_files' \
        '--api-token=+[api token]:str:' \
        '--api-url=+[api url]:url:_urls' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'logseq subcommand' sub ;;
        args)
            case $words[1] in
                page:create|page:get|page:delete|page:rename|page:export) _arguments \
                    '1:page name:' \
                    '--journal[journal page]' \
                    '--format=+[format]:f:(markdown org html json)' ;;
                block:append|block:insert|block:update) _arguments \
                    '--content=+[block content]:str:' \
                    '-c+[block content]:str:' \
                    '--file=+[content file]:file:_files' \
                    '--parent=+[parent uuid]:str:' \
                    '--sibling-of=+[sibling uuid]:str:' \
                    '--properties=+[properties json]:str:' ;;
                query:datalog|query:simple|query) _arguments \
                    '1:query:' \
                    '--limit=+[limit]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_logseq-cli "$@"
