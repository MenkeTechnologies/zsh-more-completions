#compdef pslRecalcMatch
# UCSC kent: recalculate match,mismatch,repMatch columns in psl file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-ignoreQUniq[ignore text after last dash in qName]' \
  '-ignoreQMissing[pass through if querySeq lacks qName]' \
  ':in psl:_files' \
  ':target seq:_files' \
  ':query seq:_files' \
  ':out psl:_files' && ret=0

return ret
