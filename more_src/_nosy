#compdef nosy
# Source: cargo binstall nosy-cli@0.1.0
# Probed via: completion zsh
# Repository: https://github.com/ynqa/nosy

autoload -U is-at-least

_nosy() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-o+[Output file path]:OUTPUT:_files' \
'--out=[Output file path]:OUTPUT:_files' \
'-w+[Working directory for temporary files]:WORKDIR:_files' \
'--workdir=[Working directory for temporary files]:WORKDIR:_files' \
'--log-level=[Set log level]:LOG_LEVEL:((off\:"No logging"
error\:""
warn\:""
info\:""
debug\:""
trace\:""))' \
'--http-fetch-mode=[HTTP fetch mode (only if input scheme is HTTP or HTTPS)]:MODE:(headless get)' \
'--ext-kind=[Force extractor kind for extraction]:EXTRACTOR_KIND:((plain\:"Pass-through for plain text inputs"
html\:"Use built-in (readability-like) HTML extractor"
pdf\:"Use built-in PDF text extractor"
pandoc\:"Use pandoc command line tool for supported document formats"
whisper\:"Use whisper for audio/video transcription WHISPER_MODEL_PATH environment variable must be set to a valid whisper model file path"))' \
'--provider=[LLM service provider]:PROVIDER:((github-copilot\:""
open-ai\:"For OpenAI Chat Completions and also can be used for OpenAI compatible APIs NOTE\: This adapter share some behavior that other adapters can use while still providing some variant"
open-ai-resp\:"For OpenAI Responses API"
gemini\:"Gemini adapter supports gemini native protocol. e.g., support thinking budget"
anthropic\:"Anthopric native protocol as well"
fireworks\:"For fireworks.ai, mostly OpenAI"
together\:"Together AI (Mostly uses OpenAI-compatible protocol)"
groq\:"Reuse some of the OpenAI adapter behavior, customize some (e.g., normalize thinking budget)"
mimo\:"For Mimo (Mostly use OpenAI)"
nebius\:"For Nebius (Mostly use OpenAI)"
xai\:"For xAI (Mostly use OpenAI)"
deep-seek\:"For DeepSeek (Mostly use OpenAI)"
zai\:"For ZAI (Mostly use OpenAI)"
big-model\:"For big model (only accessible via namespace bigmodel\:\:)"
cohere\:"Cohere today use it'\''s own native protocol but might move to OpenAI Adapter"
ollama\:"OpenAI shared behavior + some custom. (currently, localhost only, can be customize with ServerTargetResolver)"))' \
'--model=[LLM model identifier (e.g., claude-sonnet-4-5-20250929)]:MODEL:_default' \
'--system-template=[Path to the system message template file (defaults to built-in template)]:PATH:_files' \
'--user-template=[Path to the user message template file (defaults to built-in template)]:PATH:_files' \
'--lang=[Language for the summary]:LANGUAGE:_default' \
'--no-progress[Disable progress bar]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::input -- Input path or URL:_default' \
":: :_nosy_commands" \
"*::: :->nosy" \
&& ret=0
    case $state in
    (nosy)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nosy-command-$line[2]:"
        case $line[2] in
            (extract)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path]:OUTPUT:_files' \
'--out=[Output file path]:OUTPUT:_files' \
'-w+[Working directory for temporary files]:WORKDIR:_files' \
'--workdir=[Working directory for temporary files]:WORKDIR:_files' \
'--log-level=[Set log level]:LOG_LEVEL:((off\:"No logging"
error\:""
warn\:""
info\:""
debug\:""
trace\:""))' \
'--http-fetch-mode=[HTTP fetch mode (only if input scheme is HTTP or HTTPS)]:MODE:(headless get)' \
'--ext-kind=[Force extractor kind for extraction]:EXTRACTOR_KIND:((plain\:"Pass-through for plain text inputs"
html\:"Use built-in (readability-like) HTML extractor"
pdf\:"Use built-in PDF text extractor"
pandoc\:"Use pandoc command line tool for supported document formats"
whisper\:"Use whisper for audio/video transcription WHISPER_MODEL_PATH environment variable must be set to a valid whisper model file path"))' \
'--no-progress[Disable progress bar]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::input -- Input path or URL:_default' \
&& ret=0
;;
(summarize)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path]:OUTPUT:_files' \
'--out=[Output file path]:OUTPUT:_files' \
'-w+[Working directory for temporary files]:WORKDIR:_files' \
'--workdir=[Working directory for temporary files]:WORKDIR:_files' \
'--log-level=[Set log level]:LOG_LEVEL:((off\:"No logging"
error\:""
warn\:""
info\:""
debug\:""
trace\:""))' \
'--http-fetch-mode=[HTTP fetch mode (only if input scheme is HTTP or HTTPS)]:MODE:(headless get)' \
'--ext-kind=[Force extractor kind for extraction]:EXTRACTOR_KIND:((plain\:"Pass-through for plain text inputs"
html\:"Use built-in (readability-like) HTML extractor"
pdf\:"Use built-in PDF text extractor"
pandoc\:"Use pandoc command line tool for supported document formats"
whisper\:"Use whisper for audio/video transcription WHISPER_MODEL_PATH environment variable must be set to a valid whisper model file path"))' \
'--provider=[LLM service provider]:PROVIDER:((github-copilot\:""
open-ai\:"For OpenAI Chat Completions and also can be used for OpenAI compatible APIs NOTE\: This adapter share some behavior that other adapters can use while still providing some variant"
open-ai-resp\:"For OpenAI Responses API"
gemini\:"Gemini adapter supports gemini native protocol. e.g., support thinking budget"
anthropic\:"Anthopric native protocol as well"
fireworks\:"For fireworks.ai, mostly OpenAI"
together\:"Together AI (Mostly uses OpenAI-compatible protocol)"
groq\:"Reuse some of the OpenAI adapter behavior, customize some (e.g., normalize thinking budget)"
mimo\:"For Mimo (Mostly use OpenAI)"
nebius\:"For Nebius (Mostly use OpenAI)"
xai\:"For xAI (Mostly use OpenAI)"
deep-seek\:"For DeepSeek (Mostly use OpenAI)"
zai\:"For ZAI (Mostly use OpenAI)"
big-model\:"For big model (only accessible via namespace bigmodel\:\:)"
cohere\:"Cohere today use it'\''s own native protocol but might move to OpenAI Adapter"
ollama\:"OpenAI shared behavior + some custom. (currently, localhost only, can be customize with ServerTargetResolver)"))' \
'--model=[LLM model identifier (e.g., claude-sonnet-4-5-20250929)]:MODEL:_default' \
'--system-template=[Path to the system message template file (defaults to built-in template)]:PATH:_files' \
'--user-template=[Path to the user message template file (defaults to built-in template)]:PATH:_files' \
'--lang=[Language for the summary]:LANGUAGE:_default' \
'--no-progress[Disable progress bar]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::input -- Input path or URL:_default' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(download-whisper)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path]:OUTPUT:_files' \
'--out=[Output file path]:OUTPUT:_files' \
'--overwrite[Overwrite existing file]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':model -- Whisper model to download (tiny, base, small, medium, large-v1/v2/v3):((tiny-en\:"Tiny Whisper model - finetuned for English"
tiny\:"Tiny Whisper model"
base-en\:"Base Whisper model - finetuned for English"
base\:"Base Whisper model"
small-en\:"Small Whisper model - finetuned for English"
small\:"Small Whisper model"
medium-en\:"Medium Whisper model - finetuned for English"
medium\:"Medium Whisper model"
large-v1\:"Large Whisper model - old version"
large-v2\:"Large Whisper model - V2"
large-v3\:"Large Whisper model - V3"))' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_nosy__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nosy-help-command-$line[1]:"
        case $line[1] in
            (extract)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(summarize)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(download-whisper)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_nosy_commands] )) ||
_nosy_commands() {
    local commands; commands=(
'extract:Extract fetched content to text for LLM consumption (alias\: ext)' \
'summarize:Summarize content using LLM (alias\: recap)' \
'completion:Generate shell completion script for specified shell (alias\: comp)' \
'download-whisper:Download Whisper model to a specified path' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'nosy commands' commands "$@"
}
(( $+functions[_nosy__completion_commands] )) ||
_nosy__completion_commands() {
    local commands; commands=()
    _describe -t commands 'nosy completion commands' commands "$@"
}
(( $+functions[_nosy__download-whisper_commands] )) ||
_nosy__download-whisper_commands() {
    local commands; commands=()
    _describe -t commands 'nosy download-whisper commands' commands "$@"
}
(( $+functions[_nosy__extract_commands] )) ||
_nosy__extract_commands() {
    local commands; commands=()
    _describe -t commands 'nosy extract commands' commands "$@"
}
(( $+functions[_nosy__help_commands] )) ||
_nosy__help_commands() {
    local commands; commands=(
'extract:Extract fetched content to text for LLM consumption (alias\: ext)' \
'summarize:Summarize content using LLM (alias\: recap)' \
'completion:Generate shell completion script for specified shell (alias\: comp)' \
'download-whisper:Download Whisper model to a specified path' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'nosy help commands' commands "$@"
}
(( $+functions[_nosy__help__completion_commands] )) ||
_nosy__help__completion_commands() {
    local commands; commands=()
    _describe -t commands 'nosy help completion commands' commands "$@"
}
(( $+functions[_nosy__help__download-whisper_commands] )) ||
_nosy__help__download-whisper_commands() {
    local commands; commands=()
    _describe -t commands 'nosy help download-whisper commands' commands "$@"
}
(( $+functions[_nosy__help__extract_commands] )) ||
_nosy__help__extract_commands() {
    local commands; commands=()
    _describe -t commands 'nosy help extract commands' commands "$@"
}
(( $+functions[_nosy__help__help_commands] )) ||
_nosy__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'nosy help help commands' commands "$@"
}
(( $+functions[_nosy__help__summarize_commands] )) ||
_nosy__help__summarize_commands() {
    local commands; commands=()
    _describe -t commands 'nosy help summarize commands' commands "$@"
}
(( $+functions[_nosy__summarize_commands] )) ||
_nosy__summarize_commands() {
    local commands; commands=()
    _describe -t commands 'nosy summarize commands' commands "$@"
}

if [ "$funcstack[1]" = "_nosy" ]; then
    _nosy "$@"
else
    compdef _nosy nosy
fi
