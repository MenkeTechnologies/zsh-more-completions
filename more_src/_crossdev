#compdef crossdev
# Gentoo cross-compilation toolchain builder

local ret=1

_arguments -s -S \
  '-t[specify target tuple]:target tuple:' \
  '-S[use stable versions]' \
  '-s0[skip binutils]' \
  '-s1[skip gcc stage1]' \
  '-s2[skip kernel headers]' \
  '-s3[skip libc]' \
  '-s4[skip gcc stage2]' \
  '--b[specify binutils version]:version:' \
  '--g[specify gcc version]:version:' \
  '--k[specify kernel version]:version:' \
  '--l[specify libc version]:version:' \
  '--env[set environment variable]:key=value:' \
  '-C[clean target]' \
  '--clean[clean target]:target:' \
  '-P[pretend mode]' \
  '-v[verbose output]' \
  '--show-fail-log[show failure log]' \
  '--init-target[initialize target sysroot]' \
  '--ov-output=[specify overlay output directory]:directory:_files -/' \
  '--overlays=[specify overlays]:overlay path:_files -/' \
  '-h[show help]' \
  '--help[show help]' && ret=0

return ret
