#compdef bw-pix
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=bw-pix&sektion=1
# BRL-CAD black-and-white to color pix converter

local ret=1

_arguments -s \
  '-s[square size for image dimensions]:size' \
  '-w[image width in pixels]:width' \
  '-n[image height in pixels]:height' \
  '-o[output pix file]:output:_files' \
  '*:input.bw:_files' && ret=0

return ret
