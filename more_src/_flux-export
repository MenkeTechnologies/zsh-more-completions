#compdef flux-export
# Documentation: https://fluxcd.io/flux/cmd/flux_export/
# FluxCD export: output Flux resources in YAML

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--all[select all resources]' \
  '--context=[kubeconfig context to use]:context:' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--timeout=[timeout for this operation]:duration:' \
  '--verbose[print generated objects]' \
  '*::subcommand:(alert alert-provider artifact helmrelease image kustomization receiver source)' && ret=0

return ret
