#compdef machinectl-cli
# _machinectl-cli — systemd machinectl control the systemd machine manager CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_machinectl-cli() {
    local -a sub=(
        'list:list running VMs/containers'
        'status:show status'
        'show:show properties'
        'start:start container'
        'login:open login session in container'
        'shell:open shell in container'
        'enable:enable container'
        'disable:disable container'
        'poweroff:power off container'
        'reboot:reboot container'
        'terminate:terminate container'
        'kill:kill container'
        'bind:bind mount'
        'copy-to:copy file into container'
        'copy-from:copy file from container'
        'list-images:list local images'
        'image-status:show image status'
        'show-image:show image properties'
        'clone:clone image'
        'rename:rename image'
        'read-only:mark image read-only'
        'remove:remove image'
        'set-limit:set quota'
        'clean:clean images'
        'pull-tar:download tar image'
        'pull-raw:download raw image'
        'import-tar:import tar'
        'import-raw:import raw'
        'import-fs:import filesystem'
        'export-tar:export as tar'
        'export-raw:export as raw'
        'list-transfers:list transfers'
        'cancel-transfer:cancel transfer'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-ask-password[no ask password]' \
        '-p+[property]:str:' \
        '--property=+[property]:str:' \
        '-a[all]' \
        '--all[all]' \
        '--value[value only]' \
        '-l[full output]' \
        '--full[full output]' \
        '--kill-whom=+[whom]:w:(leader all)' \
        '-s+[signal]:str:' \
        '--signal=+[signal]:str:' \
        '-n+[lines]:n:' \
        '--lines=+[lines]:n:' \
        '-o+[output format]:f:(short verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '--output=+[output format]:f:(short verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--read-only[mark read-only]' \
        '--mkdir[mkdir]' \
        '--max-addresses=+[n]:n:' \
        '--verify=+[mode]:m:(no checksum signature)' \
        '--force[force]' \
        '--format=+[fmt]:f:(uncompressed xz gzip bzip2 zstd)' \
        '--uid=+[uid]:n:' \
        '-E+[var=value]:str:' \
        '--setenv=+[var=value]:str:' \
        '--now[do action now]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'machinectl subcommand' sub ;;
    esac
}

_machinectl-cli "$@"
