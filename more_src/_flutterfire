#compdef flutterfire

# Zsh completion for FlutterFire CLI

local curcontext="$curcontext" state line ret=1

local -a flutterfire_commands
flutterfire_commands=(
  'configure:configure Firebase for a Flutter project'
  'reconfigure:reconfigure Firebase for a Flutter project'
  'upload-crashlytics-symbols:upload Crashlytics debug symbols'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[enable verbose logging]' \
  '1:command:_describe -t commands command flutterfire_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      configure)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-p --project)'{-p,--project}'=[specify Firebase project ID]:project:' \
          '(-a --account)'{-a,--account}'=[specify the account to use]:account:' \
          '(-o --out)'{-o,--out}'=[specify output file path]:file:_files -g "*.dart"' \
          '--platforms=[specify platforms to configure]:platforms:_values -s , platform android ios macos web linux windows' \
          '--ios-bundle-id=[specify iOS bundle ID]:bundle ID:' \
          '--android-package-name=[specify Android package name]:package name:' \
          '--macos-bundle-id=[specify macOS bundle ID]:bundle ID:' \
          '--web-app-id=[specify web app ID]:app ID:' \
          '--windows-app-id=[specify Windows app ID]:app ID:' \
          '--yes[answer yes to all prompts]' \
          '--overwrite-firebase-options[overwrite existing firebase_options.dart]' \
          && ret=0
        ;;
      reconfigure)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      upload-crashlytics-symbols)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--upload-symbols-script-path=[path to upload symbols script]:file:_files' \
          '--debug-info-path=[path to debug info directory]:directory:_directories' \
          '--app-id=[Firebase app ID]:app ID:' \
          '--google-service-plist=[path to GoogleService-Info.plist]:file:_files -g "*.plist"' \
          '--google-service-json=[path to google-services.json]:file:_files -g "*.json"' \
          && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
