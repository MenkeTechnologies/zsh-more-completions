#compdef rsgisvectools
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgisvectools RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--vecfile[Input vector file.]:value:_files' \
  '--veclyr[Layer within the specified input vector file.]:value:_files' \
  '--veccol[Column within the specified vector file layer.]:value:_files' \
  '--lyrs[List the layers in vector file.]' \
  '--cols[List the columns in vector layer.]' \
  '--nfeats[Count for the number of feats in layer.]' \
  '--proj[Print the projection of the vector layer.]' \
  '--bbox[Print the bounding box of the vector layer.]' \
  '--unqvals[Print the unique values within a column of the attribute table.]' \
  '--geom[Print the geometry type of the vector layer.]' \
  '*:file:_files' && ret=0

return ret
