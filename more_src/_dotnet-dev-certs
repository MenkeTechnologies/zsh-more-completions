#compdef dotnet-dev-certs
# Documentation: https://learn.microsoft.com/en-us/dotnet/core/tools/dotnet-dev-certs
# dotnet-dev-certs - generate self-signed certificate for HTTPS in development

local ret=1

_arguments -s -S \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--version[display version information]' \
  '(-c --check)'{-c,--check}'[check for the existence of a development certificate]' \
  '--check-trust-machine-readable[check trust in machine-readable form]' \
  '--clean[clean all HTTPS development certificates]' \
  '(-ep --export-path)'{-ep,--export-path}'=[export the certificate to a file]:path:_files' \
  '--format[exported certificate format]:format:(PFX PEM)' \
  '(-i --import)'{-i,--import}'=[import the provided HTTPS development certificate]:path:_files' \
  '(-np --no-password)'{-np,--no-password}'[export PEM key without a password]' \
  '(-p --password)'{-p,--password}'=[password for the exported certificate]:password:' \
  '(-q --quiet)'{-q,--quiet}'[display warnings and errors only]' \
  '(-t --trust)'{-t,--trust}'[trust the certificate on the local machine]' \
  '(-v --verbose)'{-v,--verbose}'[display debug information]' \
  '*:command:(https)' && ret=0

return ret
