#compdef dropbear
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/dropbear.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dropbear (lightweight SSH server)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b+[display contents of banner file before login]:banner file:_files' \
  '*-r+[host key file (may be specified multiple times)]:host key:_files' \
  '-R[create host keys as required]' \
  '-F[do not fork into background]' \
  '-E[log to stderr rather than syslog]' \
  '-e[pass server environment to child processes]' \
  '-m[do not display the message of the day]' \
  '-w[disallow root logins]' \
  '-s[disable password logins]' \
  '-g[disable password logins for root]' \
  '-t[require two-factor authentication]' \
  '-j[disable local port forwarding]' \
  '-k[disable remote port forwarding]' \
  '-a[allow connections to forwarded ports from any host]' \
  '*-p+[listen on specified address and/or port]:address\:port' \
  '-P+[PID file path]:pid file:_files' \
  '-D+[authorized_keys directory]:dir:_files -/' \
  '-i[start for inetd]' \
  '-K+[keepalive interval seconds]:seconds:' \
  '-I+[disconnect sessions after idle timeout]:seconds:' \
  '-T+[maximum authentication tries]:tries:' \
  '-W+[per-channel receive window size]:bytes:' \
  '-c+[force command for all sessions]:command:' \
  '-z[disable QoS AF21 setting]' \
  '-V[print version]' && ret=0

return ret
