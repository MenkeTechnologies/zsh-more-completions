#compdef zef-j zef-js
# Documentation: https://man.archlinux.org/search?q=zef-j
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

(( $+functions[_zef] )) || autoload -Uz _zef 2>/dev/null
if (( $+functions[_zef] )); then
  _zef "$@"
  return
fi

_arguments \
  '*::zef arg:' && ret=0

return ret
