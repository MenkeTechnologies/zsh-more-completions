#compdef md-toc md_toc
# Documentation: https://man.archlinux.org/search?q=md-toc
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cmark:CommonMark spec parser'
  'github:GitHub flavor parser'
  'gitlab:GitLab flavor parser'
  'redcarpet:Redcarpet parser'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --in-place)'{-i,--in-place}'[edit in place]' \
  '(-p --no-list-coherence)'{-p,--no-list-coherence}'[skip list coherence check]' \
  '(-l --header-levels)'{-l,--header-levels}'+[header levels]:n:(1 2 3 4 5 6)' \
  '(-c --skip-lines)'{-c,--skip-lines}'+[skip lines]:n:' \
  '(-s --toc-marker)'{-s,--toc-marker}'+[TOC marker]:marker:' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-u --ul)'{-u,--ul}'+[unordered marker]:char:' \
  '(-S --indentation-log-name)'{-S,--indentation-log-name}'+[log file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'md-toc parser' commands && ret=0 ;;
  (args)
    _arguments \
      '*:markdown:_files -g "*.{md,markdown}"' && ret=0
    ;;
esac

return ret
