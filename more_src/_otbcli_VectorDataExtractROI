#compdef otbcli_VectorDataExtractROI
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_VectorDataExtractROI.html
# Orfeo ToolBox: extract a region of interest from vector data

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-io.vd[input vector data file]:vector:_files' \
  '-io.in[support image specifying the region]:image:_files' \
  '-io.out[output extracted vector data file]:output:_files' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default height above ellipsoid]:value:' \
  '*::arg:_files' && ret=0

return ret
