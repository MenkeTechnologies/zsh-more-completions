#compdef lua5.5
# Documentation: https://man.archlinux.org/search?q=lua5.5
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-e+[execute string]:stat:' \
  '-i[enter interactive mode after script]' \
  '*-l+[require library]:lib:' \
  '-v[show version information]' \
  '-E[ignore environment variables]' \
  '-W[turn warnings on]' \
  '*:script:_files -g "*.lua"' && ret=0

return ret
