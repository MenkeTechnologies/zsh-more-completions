#compdef lua5.5
# Documentation: https://www.lua.org/manual/5.5/manual.html#7
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-e+[execute string]:stat:' \
  '-i[enter interactive mode after script]' \
  '*-l+[require library]:lib:' \
  '-v[show version information]' \
  '-E[ignore environment variables]' \
  '-W[turn warnings on]' \
  '*:script:_files -g "*.lua"' && ret=0

return ret
