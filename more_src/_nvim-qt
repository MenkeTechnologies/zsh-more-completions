#compdef nvim-qt

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-ext-tabline[disable the external tabline]' \
  '--no-ext-popupmenu[disable the external popup menu]' \
  '--no-ext-linegrid[disable line-based grid]' \
  '--nvim[path to nvim executable]:nvim path:_files' \
  '--timeout[timeout for nvim startup in seconds]:seconds:' \
  '--geometry[set initial window geometry]:WxH:' \
  '--maximized[start maximized]' \
  '--fullscreen[start in fullscreen mode]' \
  '--embed[embed nvim process]' \
  '--server[connect to existing nvim]:address:' \
  '--spawn[spawn nvim process]:nvim args:' \
  '--nofork[do not fork into background]' \
  '--stylesheet[Qt stylesheet]:stylesheet file:_files' \
  '*:file:_files' && ret=0

return ret
