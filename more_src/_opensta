#compdef sta opensta
# _opensta — Parallax Software OpenSTA gate-level static timing analyzer for SPEF SDF Liberty Verilog DEF (parallaxsw team, C++/Tcl); custom argparse
# upstream: https://github.com/parallaxsw/OpenSTA

_opensta() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-version[show version]' \
        '--version[show version]' \
        '-no_init[no init script]' \
        '-no_splash[no splash banner]' \
        '-exit[exit after script]' \
        '-batch[batch mode]' \
        '-log+[log file]:file:_files -g "*.log"' \
        '--log=+[log file]:file:_files -g "*.log"' \
        '-tcl_dir+[tcl dir]:dir:_files -/' \
        '-threads+[N]:n:' \
        '--threads=+[N]:n:' \
        '*:tcl script:_files -g "*.tcl"'
}

_opensta "$@"
