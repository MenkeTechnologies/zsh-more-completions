#compdef cargo-grammarly
# Documentation: https://man.archlinux.org/search?q=cargo-grammarly
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*: :_files -g "*.rs"' && ret=0

return ret
