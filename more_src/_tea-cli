#compdef tea
# Documentation: https://gitea.com/gitea/tea (README)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: duplicates _tea (same #compdef); kept for legacy filename association.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'h:show help'
  'login:log in to a Gitea server'
  'logins:log in to a Gitea server'
  'logout:remove a logged-in user'
  'whoami:show current user'
  'notifications:list notifications'
  'notification:list notifications'
  'n:list notifications'
  'pulls:work with pull requests'
  'pull:work with pull requests'
  'pr:work with pull requests'
  'issues:work with issues'
  'issue:work with issues'
  'i:work with issues'
  'milestones:work with milestones'
  'milestone:work with milestones'
  'ms:work with milestones'
  'labels:work with labels'
  'label:work with labels'
  'releases:work with releases'
  'release:work with releases'
  'r:work with releases'
  'organizations:list organizations'
  'organization:list organizations'
  'org:list organizations'
  'repos:work with repositories'
  'repo:work with repositories'
  'branches:consult branches'
  'branch:consult branches'
  'b:consult branches'
  'open:open repository in browser'
  'o:open repository in browser'
  'clone:clone a repository locally'
  'C:clone a repository locally'
  'admin:Gitea admin commands'
  'a:Gitea admin commands'
  'comment:work with issue/pr comments'
  'c:work with issue/pr comments'
  'times:work with tracked times'
  'time:work with tracked times'
  't:work with tracked times'
  'actions:manage repository actions'
  'webhooks:manage repository webhooks'
  'webhook:manage repository webhooks'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[enable debug mode]' \
  '--vvv[enable debug mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tea command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login|logins)
        _arguments \
          '1:subcommand:(add list default delete edit setdefault)' \
          '*: :' && ret=0 ;;
      (pulls|pull|pr)
        _arguments \
          '1:subcommand:(list checkout clean close create merge reopen review)' \
          '*: :' && ret=0 ;;
      (issues|issue|i)
        _arguments \
          '1:subcommand:(list close create reopen)' \
          '*: :' && ret=0 ;;
      (milestones|milestone|ms)
        _arguments \
          '1:subcommand:(list close create delete issues reopen)' \
          '*: :' && ret=0 ;;
      (labels|label)
        _arguments \
          '1:subcommand:(list create delete update)' \
          '*: :' && ret=0 ;;
      (releases|release|r)
        _arguments \
          '1:subcommand:(list assets create delete edit)' \
          '*: :' && ret=0 ;;
      (repos|repo)
        _arguments \
          '1:subcommand:(list create fork search)' \
          '*: :' && ret=0 ;;
      (notifications|notification|n)
        _arguments \
          '1:subcommand:(list mark-read mark-unread)' \
          '*: :' && ret=0 ;;
      (admin|a)
        _arguments \
          '1:subcommand:(users)' \
          '*: :' && ret=0 ;;
      (actions)
        _arguments \
          '1:subcommand:(secrets variables)' \
          '*: :' && ret=0 ;;
      (webhooks|webhook)
        _arguments \
          '1:subcommand:(list create delete)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
