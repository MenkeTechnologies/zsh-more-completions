#compdef tea

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'login:authenticate to a Gitea instance'
  'logout:remove a logged-in user'
  'logins:list logins'
  'whoami:show current user'
  'autocomplete:install shell completion'
  'notifications:list notifications'
  'pulls:work with pull requests'
  'issues:work with issues'
  'milestones:work with milestones'
  'labels:work with labels'
  'releases:work with releases'
  'organizations:list organizations'
  'repos:work with repositories'
  'open:open repository in browser'
  'admin:Gitea admin commands'
  'comments:work with issue/pr comments'
  'times:work with tracked times'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*--login=[login name]:l:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tea command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '1:subcommand:(add list default delete edit setdefault)' \
          '*: :' && ret=0 ;;
      (pulls)
        _arguments \
          '1:subcommand:(checkout clean close create list merge reopen review)' \
          '*: :' && ret=0 ;;
      (issues)
        _arguments \
          '1:subcommand:(close create list reopen)' \
          '*: :' && ret=0 ;;
      (milestones)
        _arguments \
          '1:subcommand:(close create delete issues list reopen)' \
          '*: :' && ret=0 ;;
      (labels)
        _arguments \
          '1:subcommand:(create delete update list)' \
          '*: :' && ret=0 ;;
      (releases)
        _arguments \
          '1:subcommand:(assets create delete edit list)' \
          '*: :' && ret=0 ;;
      (repos)
        _arguments \
          '1:subcommand:(create fork list search)' \
          '*: :' && ret=0 ;;
      (notifications)
        _arguments \
          '1:subcommand:(list mark-read mark-unread)' \
          '*: :' && ret=0 ;;
      (admin)
        _arguments \
          '1:subcommand:(users)' \
          '*: :' && ret=0 ;;
      (autocomplete)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
