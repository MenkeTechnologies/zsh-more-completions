#compdef nbqa
# Documentation: https://man.archlinux.org/search?q=nbqa
# Reference accessed: 2026-05-16

local linters=(
  'ruff' 'isort' 'pyupgrade' 'mypy' 'pylint' 'flake8'
  'black' 'blacken-docs' 'autopep8' 'pydocstyle' 'yapf' 'doctest'
)

_arguments -s \
  '--nbqa-md[process markdown cells]' \
  '--nbqa-diff[show changes without applying]' \
  '--nbqa-mutate[allow mutation]' \
  '*--nbqa-files=[files pattern]:pattern:' \
  '*--nbqa-exclude=[exclude pattern]:pattern:' \
  '*--nbqa-addopts=[additional options]:opts:' \
  '--nbqa-shell[run as shell command]' \
  '--nbqa-skip-bad-cells[skip cells with errors]' \
  '(- *)'{-h,--help}'[show help]' \
  "1:linter:(${linters[*]})" \
  '*:notebook or arg:_files -g "*.(ipynb|py)"'
