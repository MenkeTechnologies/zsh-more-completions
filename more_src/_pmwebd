#compdef pmwebd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-A+[archive dir]:dir:_files -/' \
  '-c+[config file]:file:_files' \
  '-d+[document root]:dir:_files -/' \
  '-D+[debug flags]:flags:' \
  '-f[foreground]' \
  '-G+[graphite addr]:addr:' \
  '-h+[bind host]:host:_hosts' \
  '-K+[ssl key]:file:_files' \
  '-l+[log file]:file:_files' \
  '-N[no GUI]' \
  '-p+[port]:port:' \
  '-P+[pid file]:file:_files' \
  '-R+[resource dir]:dir:_files -/' \
  '-r+[refresh interval ms]:ms:' \
  '-S[disable hostname checks]' \
  '-s[secure mode]' \
  '-t+[connection timeout sec]:sec:' \
  '-U+[user]:user:_users' \
  '-v[verbose]' \
  '-x+[exit on fatal]' && ret=0

return ret
