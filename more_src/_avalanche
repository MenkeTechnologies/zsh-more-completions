#compdef avalanche
# Documentation: https://man.archlinux.org/search?q=avalanche
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'blockchain:develop and deploy blockchains'
  'config:customize CLI configuration'
  'contract:deploy and interact with contracts'
  'help:show help'
  'icm:interact with ICM messenger'
  'ictt:manage Interchain Token Transferrers'
  'interchain:set/manage blockchain interoperability'
  'key:create/manage signing keys'
  'network:manage local blockchain deployments'
  'node:create/maintain validators'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '--log-level=[log level]:level:(TRACE DEBUG INFO WARN ERROR)' \
  '--skip-update-check[skip version check]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'avalanche subcommand' subcommands && ret=0
    ;;
esac

return ret
