#compdef clipper
# Documentation: https://github.com/wincent/clipper
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h -help)'{-h,-help}'[usage]' \
  '(-v -version)'{-v,-version}'[print version]' \
  '(-p -port)'{-p+,--port=}'[listen port]:port:' \
  '(-a -address)'{-a+,--address=}'[listen address/host]:host:_hosts' \
  '(-c -config)'{-c+,--config=}'[JSON config file]:file:_files' \
  '(-e -executable)'{-e+,--executable=}'[handler executable path]:path:_files' \
  '(-f -flags)'{-f+,--flags=}'[extra flags passed to handlers]:flags:' \
  '(-l -logfile)'{-l+,--logfile=}'[log file path]:file:_files'
