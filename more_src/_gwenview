#compdef gwenview

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[all help options]' \
  '--help-qt[Qt help]' \
  '--help-kde[KDE help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen]' \
  '(-s --slideshow)'{-s,--slideshow}'[start slideshow]' \
  '--display=[X display]:display:' \
  '--style=[Qt style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '*:image or folder:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.cr2 *.nef *.arw *.dng *.kra *.psd *.xcf"' && ret=0

return ret
