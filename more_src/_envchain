#compdef envchain

# Zsh completion for envchain - set environment variables from keychain

local curcontext="$curcontext" state line ret=1

local -a namespaces
namespaces=( ${(f)"$(command envchain --list 2>/dev/null)"} )

_arguments -s -S \
  '--set[set environment variables in namespace]:namespace: :*:variable name:' \
  '--list[list stored namespaces]' \
  '--noecho[disable echo when reading values (default)]' \
  '--require-passphrase[require passphrase for keychain access]' \
  '--no-require-passphrase[do not require passphrase for keychain access]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:namespace:(${namespaces})' \
  '*:command:_command_names -e' && ret=0

return ret
