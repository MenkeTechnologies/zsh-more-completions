#compdef gv2gxl
# Documentation: man gv2gxl(1) (graphviz)
# Source: GraphViz gv2gxl — convert a DOT graph to GXL.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-g -d)-g[input is GV, output GXL (force direction)]' \
    '(-g -d)-d[input is GXL, output GV (force direction)]' \
    '-o+[output file]:file:_files' \
    '(- *)-?[show usage]' \
    '*:input file:_files -g "*.{gv,dot,gxl,xml}"' \
    && ret=0

return ret
