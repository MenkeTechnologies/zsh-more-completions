#compdef mitmweb

# Zsh completion for mitmweb - mitmproxy web interface

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--web-host=[web UI host]:host' \
  '--web-port=[web UI port]:port' \
  '--web-open-browser[open browser on startup]' \
  '--no-web-open-browser[do not open browser on startup]' \
  '--web-columns=[columns to display]:columns' \
  '(-p --listen-port)'{-p,--listen-port}'[proxy listen port]:port' \
  '--listen-host=[proxy listen host]:host' \
  '(-s --scripts)'{-s,--scripts}'[run a script]:script file:_files -g "*.py"' \
  '(-n --no-server)'{-n,--no-server}'[do not start a proxy server]' \
  '--mode=[proxy mode]:mode:(regular transparent socks5)' \
  '(-k --ssl-insecure)'{-k,--ssl-insecure}'[do not verify upstream server SSL certificates]' \
  '--cert=[SSL certificate]:cert file:_files' \
  '--client-certs=[client certificate directory or file]:path:_files' \
  '*--set=[set an option value]:option' \
  '--http2[enable HTTP/2]' \
  '--no-http2[disable HTTP/2]' \
  '*--ignore-hosts=[ignore host pattern]:pattern' \
  '*--allow-hosts=[allow host pattern]:pattern' \
  '--upstream-auth=[upstream proxy auth]:user\:password' \
  '--anticache[strip cache headers to prevent caching]' \
  '--anticomp[try to convince servers to send uncompressed data]' \
  '--showhost[use Host header for URL display]'
