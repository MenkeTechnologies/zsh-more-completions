#compdef dotdrop

# Zsh completion for dotdrop - Dotfile manager

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-c --cfg)'{-c,--cfg}'[config file path]:config file:_files' \
  '(-p --profile)'{-p,--profile}'[profile to use]:profile' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose output]' \
  '(-d --dry)'{-d,--dry}'[dry run, do not modify anything]' \
  '(-f --force)'{-f,--force}'[force overwrite]' \
  '(-b --no-banner)'{-b,--no-banner}'[suppress banner]' \
  '(-w --workers)'{-w,--workers}'[number of parallel workers]:workers' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:Install dotfiles'
      'compare:Compare dotfiles'
      'import:Import dotfiles'
      'update:Update dotfiles'
      'remove:Remove dotfiles'
      'files:List managed files'
      'detail:Show dotfile details'
      'profiles:List available profiles'
    )
    _describe -t commands 'dotdrop command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      install)
        _arguments -s -S \
          '--link=[link type]:type:(nolink link link_children)' \
          '(-f --force)'{-f,--force}'[force overwrite]' \
          '(-t --temp)'{-t,--temp}'[install to temp directory]:temp dir:_directories' \
          '(-k --keys)'{-k,--keys}'[install specific keys]:keys' && ret=0
        ;;
      import)
        _arguments -s -S \
          '--link=[link type]:type:(nolink link link_children)' \
          '--as=[rename imported file]:name' \
          '*:files to import:_files' && ret=0
        ;;
      compare)
        _arguments -s -S \
          '(-C --focus)'{-C,--focus}'[compare specific key]:key' && ret=0
        ;;
      update)
        _arguments -s -S \
          '(-k --key)'{-k,--key}'[update specific key]:key' \
          '(-P --show-patch)'{-P,--show-patch}'[show patch on update]' \
          '(-i --ignore)'{-i,--ignore}'[patterns to ignore]:pattern' && ret=0
        ;;
    esac
    ;;
esac

return ret
