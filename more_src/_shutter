#compdef shutter
# Documentation: https://man.archlinux.org/search?q=shutter
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-a --active)'{-a,--active}'[capture active window]' \
  '(-f --full)'{-f,--full}'[capture entire screen]' \
  '(-s --select)'{-s,--select}'[capture a selected area]' \
  '(-w --window)'{-w+,--window=}'[select window matching pattern]:pattern:' \
  '--web=[capture website]:url:' \
  '--section[capture a section]' \
  '--menu[capture menu]' \
  '--tooltip[capture tooltip]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-e --exit_after_capture)'{-e,--exit_after_capture}'[exit after first capture]' \
  '(-d --delay)'{-d+,--delay=}'[delay seconds]:secs:' \
  '(-c --include_cursor)'{-c,--include_cursor}'[include cursor]' \
  '(-C --remove_cursor)'{-C,--remove_cursor}'[exclude cursor]' \
  '--full_screen=[full screen at startup]:bool:(0 1)' \
  '--min_at_startup[minimised at startup]' \
  '--disable_systray[disable system tray]' \
  '--no_session_at_startup[no session at startup]' \
  '--profile=[profile name]:profile:' \
  '(-p --picker)'{-p,--picker}'[show capture picker]' \
  '(-n --no_session)'{-n,--no_session}'[do not load session]' \
  '(-b --debug)'{-b,--debug}'[debug mode]' \
  '--clear_cache[clear cache]' \
  '--show_in_taskbar[show in taskbar]' \
  '*: :_files -g "*.png *.jpg *.jpeg *.bmp *.tiff *.svg"' && ret=0

return ret
