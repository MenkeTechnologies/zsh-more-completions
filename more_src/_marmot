# -----------------------------------------------------------------------------
#
# THE marmot CLI
#
# marmot is invoked as:
#   marmot [OPTIONS]
#
# Common invocations:
#   # Start marmot with a config file
#   marmot -config config.toml
#
#   # Override config values via flags
#   marmot -config config.toml -node-id 42 -grpc-port 9101 -mysql-port 3306
#
#   # Join a replica set by pointing at peer addresses
#   marmot -config config.toml -follow-addresses node1:9101,node2:9101
#
#   # Run as a daemon
#   marmot -config config.toml -daemon -pid-file /var/run/marmot.pid
#
#   # Override the data directory
#   marmot -config config.toml -data-dir /var/lib/marmot/data
#
# OPTIONS (sourced directly from
# https://github.com/maxpert/marmot/blob/main/cfg/config.go):
#
#   -config FILE                Path to configuration file
#                               (default: config.toml)
#   -data-dir DIR               Data directory (overrides config)
#   -node-id N                  Node ID (overrides config, 0=auto)
#   -grpc-port N                gRPC port (overrides config)
#   -mysql-port N               MySQL wire-protocol port
#                               (overrides config)
#   -follow-addresses ADDRS     Comma-separated peer addresses
#                               for replica/follower mode
#   -daemon                     Run as daemon (background process)
#   -pid-file FILE              PID file path (used with -daemon)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-config[path to configuration file]:file:_files -g "*.(toml|TOML)"' \
    '-data-dir[data directory (overrides config)]:dir:_files -/' \
    '-node-id[node ID (0=auto)]:id:_default' \
    '-grpc-port[gRPC port]:port:_default' \
    '-mysql-port[MySQL wire-protocol port]:port:_default' \
    '-follow-addresses[comma-separated peer addresses for replica/follower mode]:addresses:_default' \
    '-daemon[run as daemon (background process)]' \
    '-pid-file[PID file path (used with -daemon)]:file:_files' \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
