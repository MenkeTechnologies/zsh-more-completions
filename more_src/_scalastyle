#compdef scalastyle
# _scalastyle — Matthew Farwell scalastyle Scala code style checker CLI alias (scalastyle team, Scala); custom argparse
# upstream: https://github.com/scalastyle/scalastyle

_scalastyle() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config xml file]:file:_files -g "scalastyle_config.xml"' \
        '-c+[config xml file]:file:_files -g "scalastyle_config.xml"' \
        '--xmlOutput=+[xml output]:file:_files -g "*.xml"' \
        '-x+[xml output]:file:_files -g "*.xml"' \
        '--xmlEncoding=+[xml encoding]:e:(utf-8 iso-8859-1)' \
        '-e+[xml encoding]:e:(utf-8 iso-8859-1)' \
        '--quiet=+[quiet]:b:(true false)' \
        '-q+[quiet]:b:(true false)' \
        '--verbose=+[verbose]:b:(true false)' \
        '-v+[verbose]:b:(true false)' \
        '--warnings=+[warnings]:b:(true false)' \
        '-w+[warnings]:b:(true false)' \
        '--inputEncoding=+[input encoding]:e:(utf-8 iso-8859-1)' \
        '--useEclipseMessages=+[eclipse messages]:b:(true false)' \
        '-u+[eclipse messages]:b:(true false)' \
        '--failOnWarning=+[fail on warning]:b:(true false)' \
        '*:scala files:_files -g "*.{scala,sc}"'
}

_scalastyle "$@"
