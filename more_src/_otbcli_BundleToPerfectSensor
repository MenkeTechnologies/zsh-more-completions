#compdef otbcli_BundleToPerfectSensor
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_BundleToPerfectSensor.html
# Orfeo ToolBox: perform P+XS pansharpening from a bundle

local ret=1

_arguments -s -S \
  '(-help)-help[show help]' \
  '-inp[panchromatic input image]:image:_files' \
  '-inxs[XS input image]:image:_files' \
  '-out[output image]:output:_files' \
  '-elev.dem[directory containing DEM files]:dir:_files -/' \
  '-elev.geoid[geoid grid file]:file:_files' \
  '-elev.default[default elevation value]:value:' \
  '-mode[superimposition mode]:mode:(default phr)' \
  '-method[pan-sharpening algorithm]:method:(rcs lmvm bayes)' \
  '-method.rcs.radiusx[RCS horizontal radius]:value:' \
  '-method.rcs.radiusy[RCS vertical radius]:value:' \
  '-method.lmvm.radiusx[LMVM horizontal radius]:value:' \
  '-method.lmvm.radiusy[LMVM vertical radius]:value:' \
  '-method.bayes.lambda[Bayesian weighting value]:value:' \
  '-method.bayes.s[Bayesian S coefficient]:value:' \
  '-lms[spacing of deformation field]:value:' \
  '-interpolator[interpolation method]:interp:(bco nn linear)' \
  '-interpolator.bco.radius[bicubic filter size]:radius:' \
  '-fv[fill value for areas outside reprojected image]:value:' \
  '-ram[available memory for processing in MB]:mb:' \
  '*::arg:_files' && ret=0

return ret
