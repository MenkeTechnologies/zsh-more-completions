#compdef deproject
# Documentation: https://www.atnf.csiro.au/computing/software/miriad/doc/deproject.html
# MIRIAD: create a deprojected image of a galaxy

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'in=[input data cube]:in:_files' \
  'out=[output data cube]:out:_files' \
  'center=[polar coordinate center in pixels]:center:' \
  'pa=[major axis position angle in degrees]:pa:' \
  'inc=[inclination angle in degrees]:inc:' \
  'osize=[output image dimensions]:osize:' \
  'ocenter=[output galaxy center position]:ocenter:' \
  'iflux=[flux conversion flag]:iflux:(0 1)' \
  'invert=[reverse operation flag]:invert:(0 -1)' \
  '*:image:_files' && ret=0

return ret
