#compdef ratchet

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'check:check if all versions are pinned'
      'pin:pin action versions to SHAs'
      'unpin:unpin actions back to tags'
      'update:update pinned actions to latest'
    )
    _describe -t commands 'ratchet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      check|pin|unpin|update)
        _arguments \
          '(-o --out)'{-o,--out}'[output file]:file:_files' \
          '--parser=[parser type]:parser:(actions circleci cloudbuild drone gitlab tekton)' \
          '--concurrency=[number of concurrent requests]:count' \
          '*:file:_files -g "*.{yaml,yml}"' && ret=0
        ;;
    esac
    ;;
esac

return ret
