#compdef gocover
# _gocover — Go cmd/cover viewer (Go team); render coverage profile as HTML / text / func summary
# upstream: https://pkg.go.dev/cmd/cover

_gocover() {
    _arguments \
        '-html+[coverage profile to render]:file:_files' \
        '-func+[coverage profile for func summary]:file:_files' \
        '-mode+[set mode]:mode:(set count atomic)' \
        '-o+[output file]:file:_files' \
        '-pkgcfg+[package config]:file:_files' \
        '-var+[cover var]:str:' \
        '*:input file:_files'
}

_gocover "$@"
