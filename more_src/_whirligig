#compdef whirligig
# Documentation: https://www.desy.de/~twhite/crystfel/manual-whirligig.html
# Find connected series of frames (rotation series) in a stream (CrystFEL).

local ret=1

_arguments -s -S \
  '--help[show help]' \
  '--output-dir=[put output log files in folder]:dir:_files -/' \
  '--window-size=[size of history buffer]:n:' \
  '*:stream:_files' && ret=0

return ret
