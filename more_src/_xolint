#compdef xolint

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c[show invalid uses of complex modifiers]' \
  '-C[ignore content escapes]' \
  '-d[show debug output]' \
  '-D[show only doc warnings]' \
  '-f[show field offset]' \
  '-F+[output format]:fmt:(plain json xml html)' \
  '-I[show informational warnings]' \
  '-o+[output file]:file:_files' \
  '-O[only suggest fixes]' \
  '-p+[print warning if pattern matches]:pattern:' \
  '-r+[recurse into directory]:dir:_files -/' \
  '-s[show stats]' \
  '-V+[verbosity level]:level:' \
  '-X[only XML escapes]' \
  '-Y[suppress warnings about default style]' \
  '-Z[suppress final newline]' \
  '*:file:_files -g "*.c"' && ret=0

return ret
