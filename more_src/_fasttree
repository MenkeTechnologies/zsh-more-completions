#compdef fasttree FastTree
# Documentation: https://morgannprice.github.io/fasttree/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# FastTree: approximate maximum-likelihood phylogenetic tree
local curcontext="$curcontext" ret=1
_arguments -C \
  '-nt[input is nucleotide alignment]' \
  '-gtr[use GTR substitution model (DNA)]' \
  '-lg[use LG amino-acid model]' \
  '-wag[use WAG amino-acid model]' \
  '-gamma[fit gamma rate heterogeneity]' \
  '-cat[number of rate categories]:n:' \
  '-nocat[disable rate categories]' \
  '-spr[number of SPR rearrangement rounds]:n:' \
  '-mlacc[ML branch length accuracy levels]:n:' \
  '-slownni[slower but more thorough NNI search]' \
  '-noml[skip ML refinement]' \
  '-nome[skip minimum-evolution refinement]' \
  '-fastest[fastest tree, less accurate]' \
  '-pseudo[pseudocount weight]:val:' \
  '-bionj[BIONJ neighbour joining]' \
  '-quote[allow quoted IDs with whitespace]' \
  '-boot[bootstrap replicates]:n:' \
  '-seed[random seed]:n:' \
  '-quiet[suppress non-essential output]' \
  '-nopr[no progress output]' \
  '-log[log file]:file:_files' \
  '-intree[user starting tree]:file:_files' \
  '-intree1[start from this tree, evaluate only]:file:_files' \
  '-n[number of alignments]:n:' \
  '-makematrix[output distance matrix only]' \
  '-rawdist[output raw pairwise distances]' \
  '-constraints[constraint topology file]:file:_files' \
  '-out[output tree file]:file:_files' \
  '*:alignment file:_files -g "*.(fa|fasta|aln|phy|nex)"' && ret=0
return ret
