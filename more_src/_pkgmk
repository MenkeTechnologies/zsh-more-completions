#compdef pkgmk
# Documentation: https://crux.nu/Main/Handbook3-7
# CRUX utility to make software packages from a Pkgfile

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-d[download missing source files]' \
  '-do[download missing source files only, no build]' \
  '-i[download, build, and install package]' \
  '-u[download, build, and upgrade package]' \
  '-uf[update footprint after build]' \
  '-utf[update footprint, force]' \
  '-if[ignore footprint mismatches]' \
  '-um[update md5sum checksums]' \
  '-us[update signature]' \
  '-cf[check footprint only]' \
  '-kw[keep work directory]' \
  '-r[remove work directory after build]' \
  '-f[force build, ignore existing package]' \
  '-cm[check md5sum only]' \
  '-ns[no stripping of binaries]' \
  '-ignore-new[ignore new files in footprint check]' \
  '-cf=[use alternate configuration file]:config file:_files' \
  '*:Pkgfile:_files' && ret=0

return ret
