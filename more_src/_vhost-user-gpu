#compdef vhost-user-gpu
# Documentation: https://github.com/qemu/qemu/blob/master/contrib/vhost-user-gpu/vhost-user-gpu.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (QEMU contrib vhost-user-gpu daemon).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --print-capabilities)'{-c,--print-capabilities}'[print capabilities in JSON]' \
  '(-f --fd)'{-f+,--fd=}'[use inherited fd socket]:fd:' \
  '(-s --socket-path)'{-s+,--socket-path=}'[UNIX socket path]:file:_files' \
  '(-r --render-node)'{-r+,--render-node=}'[DRM render node]:path:_files' \
  '(-v --virgl)'{-v,--virgl}'[turn virgl rendering on]' && ret=0
return ret
