#compdef zapbirds
# Documentation: https://github.com/scottransom/presto/blob/master/docs/zapbirds.1
# PRESTO: zap birdies (interference) from an FFT file.

local ret=1

_arguments -s -S \
  '-zap[zap the birds in the FFT from zapfile]' \
  '-zapfile=[file of freqs and widths to zap]:file:_files' \
  '-in=[file of freqs (Hz) and number of harmonics]:file:_files' \
  '-out=[file to write zapped freqs and widths]:file:_files' \
  '-baryv=[radial velocity component (v/c) to target]:baryv:' \
  '*:input FFT file (no suffix):_files' && ret=0

return ret
