#compdef carbon-c-relay

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-d[debug]' \
  '-f+[config file]:file:_files' \
  '-i+[bind interface]:iface:_net_interfaces' \
  '-l+[log file]:file:_files' \
  '-p+[listen port]:port:' \
  '-w+[worker threads]:n:' \
  '-b+[batchsize]:n:' \
  '-q+[queue size]:n:' \
  '-c+[CPU mask]:mask:' \
  '-H+[hostname]:host:' \
  '-D[daemonize]' \
  '-P+[PID file]:file:_files' \
  '-O+[output flush ms]:ms:' \
  '-B+[backlog]:n:' \
  '-L+[connection limit]:n:' \
  '-T+[idle timeout sec]:sec:' \
  '-U+[max stalls]:n:' \
  '-E+[disable extras]:extras:' \
  '-S[print statistics]' \
  '-m+[statistics interval sec]:sec:' \
  '-M+[statistics suffix]:suffix:' \
  '-t[test mode (dry-run)]' \
  '-s+[submission limit]:n:' \
  '-V[print version and exit]' && ret=0

return ret
