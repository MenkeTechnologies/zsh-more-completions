#compdef rddescr
# Obtain channel and gain information from an XTE .pha file

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'phafil=[name of the input .pha file]:pha file:_files' \
  'chanfil=[name of the output ascii file]:output file:_files' \
  'chatter=[verbosity level]:level:' \
  'clobber=[delete output file if it exists]:flag:(yes no)' \
  '*:file:_files' && ret=0

return ret
