#compdef fontinst
# Documentation: https://man.archlinux.org/search?q=fontinst
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '*:fontinst source:_files -g "*.{tex,sty,mtx,etx}"' && ret=0

return ret
