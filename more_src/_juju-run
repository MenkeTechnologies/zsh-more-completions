#compdef juju-run
# Documentation: https://man.archlinux.org/search?q=juju-run
# Reference accessed: 2026-05-16

# juju-run: run commands inside a Juju unit/agent context
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[unit data dir]:dir:_files -/' \
  '--data-dir=[unit data dir]:dir:_files -/' \
  '--debug[enable debug]' \
  '-l[log file]:file:_files' \
  '--logging-config=[logging config string]:cfg:' \
  '-u[unit name]:unit:' \
  '--unit=[unit name]:unit:' \
  '--no-context[do not load Juju execution context]' \
  '*:command:' && ret=0
return ret
