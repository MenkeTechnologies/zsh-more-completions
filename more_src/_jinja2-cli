#compdef jinja2

_arguments -s \
  '--version[show version]' \
  '(-f --format)'{-f,--format}'=[input format]:fmt:(json ini yaml yml querystring toml xml env hjson json5 auto)' \
  '*'{-e,--extension}'=[Jinja2 extension]:ext:' \
  '*'{-F,--filter}'=[Jinja2 filter]:filter:' \
  '*-D[define KEY=VALUE]:kv:' \
  '*'{-I,--include}'=[search dir]:dir:_files -/' \
  '(-s --section)'{-s,--section}'=[config section]:section:' \
  '--strict[strict undefined]' \
  '(-o --outfile)'{-o,--outfile}'=[output file]:file:_files' \
  '--trim-blocks[trim block newline]' \
  '--lstrip-blocks[strip leading whitespace]' \
  '--autoescape[autoescape]' \
  '--variable-start=[variable start]:str:' \
  '--variable-end=[variable end]:str:' \
  '--block-start=[block start]:str:' \
  '--block-end=[block end]:str:' \
  '--comment-start=[comment start]:str:' \
  '--comment-end=[comment end]:str:' \
  '--line-statement-prefix=[line stmt prefix]:str:' \
  '--line-comment-prefix=[line comment prefix]:str:' \
  '--newline-sequence=[newline]:str:' \
  '(-S --stream)'{-S,--stream}'[read template from stdin]' \
  '1:template:_files' \
  '2:data file:_files'
