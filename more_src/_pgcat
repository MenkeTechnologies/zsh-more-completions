#compdef pgcat
# Documentation: https://github.com/postgresml/pgcat/blob/main/CONFIG.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-l --log-level)'{-l,--log-level}'=[log level]:level:(Trace Debug Info Warn Error)' \
  '(-F --log-format)'{-F,--log-format}'=[log format]:format:(Text Structured Debug)' \
  '(-n --no-color)'{-n,--no-color}'[disable color]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:config_file:_files -g "*.toml"'
