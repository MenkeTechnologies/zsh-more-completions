#compdef lazygit
# Documentation: https://github.com/jesseduffield/lazygit/blob/master/pkg/app/entry_point.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Flag set taken from kingpin definitions in pkg/app/entry_point.go.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print the current version]' \
  '(-d --debug)'{-d,--debug}'[run in debug mode with logging]' \
  '(-l --logs)'{-l,--logs}'[tail lazygit logs]' \
  '(-f --filter)'{-f,--filter}'=[path to filter on in git log]:file:_files' \
  '(-p --path)'{-p,--path}'=[path of git repo]:dir:_files -/' \
  '(-c --config)'{-c,--config}'[print the default config]' \
  '-cd[print the config directory]' \
  '--print-config-dir[print the config directory]' \
  '-ucd[override default config directory]:dir:_files -/' \
  '--use-config-dir=[override default config directory]:dir:_files -/' \
  '-ucf[comma-separated list of custom config files]:list:_files' \
  '--use-config-file=[comma-separated list of custom config files]:list:_files' \
  '(-w --work-tree)'{-w,--work-tree}'=[equivalent of git --work-tree]:dir:_files -/' \
  '(-g --git-dir)'{-g,--git-dir}'=[equivalent of git --git-dir]:dir:_files -/' \
  '-sm[initial screen mode]:mode:(normal half full)' \
  '--screen-mode=[initial screen mode]:mode:(normal half full)' \
  '--profile[start the profiler on http port 6060]' \
  ':git-arg (panel to focus on open):(status branch log stash files commits stashing commitFiles)' \
  '*: :_files' && ret=0

return ret
