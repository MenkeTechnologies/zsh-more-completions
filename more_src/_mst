#compdef mst
# Documentation: https://docs.nvidia.com/networking/display/mftv4260/mst+service
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mst: Mellanox Software Tools (MFT) service control script. STUB-level coverage
# of the published actions; argument details are device-specific.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status server ib ib_add_dev cable add del status_v2)' \
  '*::mst args:_files' && ret=0
return ret
