#compdef mst
# Documentation: https://man.archlinux.org/search?q=mst
# Reference accessed: 2026-05-16

# mst: Mellanox Software Tools master CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart status server ib ib_add_dev cable add del status_v2)' \
  '*::mst args:_files' && ret=0
return ret
