#compdef scarb-cairo-language-server
# Documentation: https://man.archlinux.org/search?q=scarb-cairo-language-server
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--port=[port for TCP transport]:port:' \
  '--stdio[use stdio transport (default)]' \
  '--logfile=[log file]:file:_files' && ret=0

return ret
