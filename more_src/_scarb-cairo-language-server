#compdef scarb-cairo-language-server

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--port=[port for TCP transport]:port:' \
  '--stdio[use stdio transport (default)]' \
  '--logfile=[log file]:file:_files' && ret=0

return ret
