#compdef create-template-next
# Documentation: https://www.npmjs.com/package/create-template-next
# Reference accessed: 2026-05-24
# Verified: npm view create-template-next bin; npm readme CommandLine Options section.

# Zsh completion for create-template-next - extended create-next-app template scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--recommend[show recommended template options]' \
  '--moonshot[enable moonshot template preset]' \
  '--ts[initialize TypeScript project]' \
  '--typescript[alias for --ts]' \
  '--js[initialize JavaScript project]' \
  '--javascript[alias for --js]' \
  '--tailwind[initialize with Tailwind CSS config]' \
  '--eslint[initialize with ESLint config]' \
  '--app[use App Router project structure]' \
  '--src-dir[use src/ directory layout]' \
  '--import-alias=[configure import alias]:alias:' \
  '--storybook[add Storybook configuration]' \
  '--jest[add Jest testing setup]' \
  '--vitest[add Vitest testing setup]' \
  '--hygen[add Hygen code generators]' \
  '--scaffdog[add Scaffdog templates]' \
  '--small[select small template preset]' \
  '--medium[select medium template preset]' \
  '--large[select large template preset]' \
  '--npm[use npm as package manager]' \
  '--yarn[use yarn as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--bun[use bun as package manager]' \
  '--github-actions[add GitHub Actions workflow]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version]' \
  ':project directory:_directories' && ret=0

return ret
