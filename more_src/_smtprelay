#compdef smtprelay
# Documentation: https://github.com/decke/smtprelay
# Source: https://github.com/decke/smtprelay/blob/master/config.go
# Reference accessed: 2026-06-01
# Go SMTP relay/proxy.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-config=[path to ini config file]:file:_files' \
    '-logfile=[log file path]:file:_files' \
    '-log_format=[log output format]:format:(default json)' \
    '-log_level=[minimum log level]:level:(trace debug info warn error fatal panic)' \
    '-hostname=[server hostname]:host:_default' \
    '-welcome_msg=[welcome message for SMTP session]:msg:_default' \
    '-listen=[SMTP listen address:port (space-separated for multiple)]:addr:_default' \
    '-local_cert=[SSL cert for STARTTLS/TLS]:file:_files -g "*.(pem|crt)"' \
    '-local_key=[SSL key for STARTTLS/TLS]:file:_files -g "*.(pem|key)"' \
    '-tls_profile=[TLS profile]:profile:(modern intermediate default legacy)' \
    '-local_forcetls=[force STARTTLS]' \
    '-read_timeout=[socket read timeout]:dur:_default' \
    '-write_timeout=[socket write timeout]:dur:_default' \
    '-data_timeout=[socket DATA timeout]:dur:_default' \
    '-max_connections=[max concurrent connections (-1 disables)]:n:_default' \
    '-max_message_size=[max message size in bytes]:n:_default' \
    '-max_recipients=[max RCPT TO calls per envelope]:n:_default' \
    '-allowed_nets=[networks allowed to send (space-separated CIDR)]:nets:_default' \
    '-allowed_sender=[regex for valid FROM addresses]:regex:_default' \
    '-allowed_recipients=[regex for valid TO addresses]:regex:_default' \
    '-allowed_users=[path to file with valid users/passwords]:file:_files' \
    '-aliases_file=[path to aliases file]:file:_files' \
    '-command=[path to pipe command]:cmd:_command_names -e' \
    '-remotes=[outgoing SMTP servers]:remotes:_default' \
    '-strict_sender=[require remote Sender match]' \
    '-remote_certificate=[client SSL cert for remote TLS]:file:_files' \
    '-remote_key=[client SSL key for remote TLS]:file:_files' \
    '-version=[show version information]' \
    && ret=0

return ret
