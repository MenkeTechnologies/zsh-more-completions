#compdef precice-cli
# Documentation: https://precice.org/tooling-builtin.html
# preCICE unified command-line tools

local ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:((version\:"show version of preCICE" init\:"generate a preCICE case" profiling\:"process preCICE profiling files" config\:"process preCICE configuration files"))' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $line[1] in
      profiling)
        _values 'profiling command' \
          'analyze[analyze profiling data]' \
          'trace[export a trace of events]' \
          'export[export profiling data]' \
          'histogram[show a histogram of event durations]' \
          'merge[merge profiling files]' && ret=0
        ;;
      config)
        _values 'config command' \
          'format[format an XML configuration file]' \
          'visualize[visualize a configuration as a graph]' \
          'check[check a configuration for logical errors]' \
          'doc[generate XML configuration reference]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
