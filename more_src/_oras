#compdef oras

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'attach:attach files to an existing artifact'
      'blob:blob operations'
      'copy:copy artifacts between registries'
      'discover:discover referrers'
      'login:log in to a registry'
      'logout:log out from a registry'
      'manifest:manifest operations'
      'pull:pull files from a registry'
      'push:push files to a registry'
      'repo:repository operations'
      'resolve:resolve a digest from a tag'
      'tag:tag a manifest'
      'version:print version'
      'completion:generate shell completion'
    )
    _describe -t commands 'oras command' commands && ret=0
    ;;
  args)
    case $words[1] in
      push)
        _arguments -s -S \
          '--config=[manifest config file]:config:_files' \
          {-a,--annotation}'=[annotation]:key=value' \
          '--annotation-file=[annotation file]:file:_files' \
          '--manifest-config=[manifest config]:config' \
          '--artifact-type=[artifact type]:type' \
          '--export-manifest=[export manifest]:path:_files' \
          '--image-spec=[image spec version]:spec:(v1.0 v1.1)' \
          '--concurrency=[concurrency]:concurrency' \
          '--plain-http[use plain HTTP]' \
          '--insecure[allow insecure connections]' \
          {-u,--username}'=[username]:username' \
          {-p,--password}'=[password]:password' \
          '1:name_tag' \
          '*:file:_files' \
          && ret=0
        ;;
      pull)
        _arguments -s -S \
          {-o,--output}'=[output directory]:directory:_directories' \
          '--keep-old-files[do not overwrite existing files]' \
          '--plain-http[use plain HTTP]' \
          '--insecure[allow insecure connections]' \
          {-u,--username}'=[username]:username' \
          {-p,--password}'=[password]:password' \
          '--concurrency=[concurrency]:concurrency' \
          '1:reference' \
          && ret=0
        ;;
      copy)
        _arguments -s -S \
          '--from-plain-http[use plain HTTP for source]' \
          '--to-plain-http[use plain HTTP for destination]' \
          '--concurrency=[concurrency]:concurrency' \
          '--recursive[copy recursively]' \
          '1:from_reference' \
          '2:to_reference' \
          && ret=0
        ;;
      login)
        _arguments -s -S \
          {-u,--username}'=[username]:username' \
          {-p,--password}'=[password]:password' \
          '--password-stdin[read password from stdin]' \
          '--insecure[allow insecure connections]' \
          '1:registry' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '1:registry' \
          && ret=0
        ;;
      tag)
        _arguments -s -S \
          '1:reference' \
          '*:tag' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
