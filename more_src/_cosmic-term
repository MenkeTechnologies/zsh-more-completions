#compdef cosmic-term
# _cosmic-term — COSMIC desktop terminal emulator (pop-os/cosmic-term)
# upstream: https://github.com/pop-os/cosmic-term
# Flags from src/main.rs (clap_lex raw args parser).

_cosmic-term() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-w --working-directory)'{-w+,--working-directory=}'[set initial working directory]:dir:_files -/' \
        '--no-daemon[do not daemonize; remain in foreground]' \
        '(-e --command --)'{-e,--command,--}'[run command then read remaining args verbatim]:command:_command_names -e' \
        '*::args:_normal'
}

_cosmic-term "$@"
