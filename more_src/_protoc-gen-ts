# protoc-gen-ts is a protoc plugin: it reads a CodeGeneratorRequest from stdin
# and writes a CodeGeneratorResponse to stdout. It has no standalone CLI flags.
# Options are passed via protoc's --ts_opt=KEY=VALUE (or --ts_out=OPTIONS:DIR).
# Recognised option keys (from src/options.rs):
#   grpc_server_package=<pkg>
#   grpc_web_package=<pkg>
#   runtime_package=<pkg>
#   base64_package=<pkg>
#   unary_rpc_promise=true|false
#   import_suffix=<suffix>
#   no_namespace        (deprecated)
#   namespaces=true|false (currently broken upstream)

_message 'protoc-gen-ts is a protoc plugin (stdin -> stdout); options via protoc --ts_opt=KEY=VALUE'
return 1
