#compdef matrix-commander
# Documentation: https://github.com/8go/matrix-commander
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '--usage[show usage]' \
  '(- *)'{-h,--help}'[show help]' \
  '--manual[show manual]' \
  '--readme[show readme]' \
  '*'{-d,--debug}'[debug output]' \
  '--log-level=[log level]:level:(NOTSET DEBUG INFO WARNING ERROR CRITICAL)' \
  '--verbose[verbose]' \
  '--login=[login mode]:mode:(PASSWORD SSO)' \
  '--verify=[verify with emoji]:emoji:' \
  '--logout=[logout]:scope:(ME ALL)' \
  '(-c --credentials)'{-c,--credentials=}'[credentials file]:file:_files' \
  '(-s --store)'{-s,--store=}'[store dir]:dir:_files -/' \
  '--access-token=[access token]:token:' \
  '--password=[password]:pw:' \
  '--homeserver=[homeserver]:url:' \
  '--device=[device name]:name:' \
  '--user-login=[user login]:user:' \
  '--no-ssl[disable SSL]' \
  '--ssl-certificate=[SSL certificate]:file:_files' \
  '--proxy=[proxy URL]:url:' \
  '--config=[config file]:file:_files' \
  '*'{-r,--room=}'[room]:room:' \
  '--room-default=[default room]:room:' \
  '*--room-create=[create room]:room:' \
  '*--room-dm-create=[create DM room]:user:' \
  '--room-dm-create-allow-duplicates[allow duplicate DMs]' \
  '*--room-join=[join room]:room:' \
  '*--room-leave=[leave room]:room:' \
  '*--room-forget=[forget room]:room:' \
  '*--room-invite=[invite to room]:user:' \
  '*--room-ban=[ban from room]:user:' \
  '*--room-unban=[unban from room]:user:' \
  '*--room-kick=[kick from room]:user:' \
  '*--room-set-alias=[set room alias]:alias:' \
  '*--room-resolve-alias=[resolve alias]:alias:' \
  '*--room-delete-alias=[delete alias]:alias:' \
  '*--room-redact=[redact event]:event:' \
  '*--room-get-visibility=[get visibility]:room:' \
  '*--room-get-state=[get room state]:room:' \
  '--room-invites=[manage invites]:mode:(LIST JOIN LIST+JOIN)' \
  '*--name=[room name]:name:' \
  '*--topic=[room topic]:topic:' \
  '*--alias=[room alias]:alias:' \
  '*'{-m,--message=}'[message]:msg:' \
  '*'{-i,--image=}'[image]:file:_files' \
  '*'{-a,--audio=}'[audio]:file:_files' \
  '*'{-f,--file=}'[file]:file:_files' \
  '*'{-e,--event=}'[event]:event:' \
  '(-w --html)'{-w,--html}'[HTML message]' \
  '(-z --markdown)'{-z,--markdown}'[markdown message]' \
  '(-k --code)'{-k,--code}'[code message]' \
  '(-j --emojize)'{-j,--emojize}'[emojize message]' \
  '(-p --split)'{-p,--split=}'[split delimiter]:delim:' \
  '(-n --notice)'{-n,--notice}'[send as notice]' \
  '--encrypted[encrypted message]' \
  '--plain[plain text]' \
  '--file-name=[file name]:name:' \
  '--key-dict=[key dict]:dict:' \
  '(-l --listen)'{-l,--listen=}'[listen mode]:mode:(NEVER ONCE FOREVER TAIL ALL)' \
  '(-t --tail)'{-t,--tail=}'[tail count]:n:' \
  '(-y --listen-self)'{-y,--listen-self}'[listen to self]' \
  '--print-event-id[print event IDs]' \
  '--download-media=[download dir]:dir:_files -/' \
  '--download-media-name=[media name]:mode:' \
  '--os-notify[OS notifications]' \
  '*'{-u,--user=}'[user]:user:' \
  '--set-device-name=[set device name]:name:' \
  '--set-display-name=[set display name]:name:' \
  '--get-display-name[get display name]' \
  '--set-presence=[set presence]:state:(online unavailable offline)' \
  '--get-presence[get presence]' \
  '--set-avatar=[set avatar]:file:_files' \
  '--get-avatar[get avatar]' \
  '--get-profile[get profile]' \
  '--whoami[show user info]' \
  '--devices[list devices]' \
  '*--delete-device=[delete device]:id:' \
  '*--upload=[upload file]:file:_files' \
  '*--download=[download URI]:uri:' \
  '*--mxc-to-http=[convert mxc to http]:mxc:' \
  '*--delete-mxc=[delete mxc]:mxc:' \
  '--delete-mxc-before=[delete mxc before]:date:' \
  '--joined-rooms[list joined rooms]' \
  '--joined-members[list joined members]' \
  '--joined-dm-rooms[list joined DM rooms]' \
  '--discovery-info[get discovery info]' \
  '--login-info[get login info]' \
  '--content-repository-config[get repo config]' \
  '*--get-room-info=[get room info]:room:' \
  '--get-client-info[get client info]' \
  '--has-permission=[check permission]:perm:' \
  '*--rest=[REST request]:method url body:' \
  '--get-openid-token[get OpenID token]' \
  '--import-keys=[import keys]:file:_files' \
  '--export-keys=[export keys]:file:_files' \
  '(-o --output)'{-o,--output=}'[output format]:fmt:(TEXT JSON JSON-MAX JSON-SPEC)' \
  '--separator=[output separator]:sep:' \
  '--sync=[sync mode]:mode:(FULL OFF)'
