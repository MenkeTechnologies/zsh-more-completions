#compdef ud_grade
# Documentation: https://healpix.sourceforge.io/html/fac_ud_grade.htm
# HEALPix: upgrade or degrade the resolution of a map

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
