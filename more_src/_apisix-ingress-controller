#compdef apisix-ingress-controller
# _apisix-ingress-controller — APISIX Kubernetes ingress controller (apache/apisix-ingress-controller)
# upstream: https://github.com/apache/apisix-ingress-controller
# Subcommands from cmd/root/root.go (cobra).

_apisix-ingress-controller() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config-path)'{-c+,--config-path=}'[config file]:file:_files -g "*.(yml|yaml)"' \
        '--metrics-bind-address=[metrics endpoint bind address]:addr:' \
        '--health-probe-bind-address=[health probe bind address]:addr:' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--controller-name=[controller class name]:name:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                version) _arguments '--long[show long-form version info]' ;;
            esac
            ;;
    esac
}

_apisix-ingress-controller "$@"
