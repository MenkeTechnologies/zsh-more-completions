#compdef gobrew

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'use:install (if needed) and select a Go version'
  'install:install a Go version'
  'uninstall:remove a Go version'
  'list:list installed Go versions'
  'ls:list installed Go versions'
  'ls-remote:list remote Go versions'
  'self-update:update gobrew itself'
  'prune:remove all versions except the active one'
  'version:show gobrew version'
  'interactive:interactive version selector'
  'noninteractive:print latest version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gobrew command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (use|install|uninstall)
        _arguments \
          '*::version:(latest mod dev tip)' && ret=0 ;;
      (ls-remote)
        _arguments \
          '--include-rc[include rc/beta versions]' && ret=0 ;;
    esac ;;
esac

return ret
