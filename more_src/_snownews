#compdef snownews
# Documentation: https://www.mankier.com/1/snownews
# snownews - text mode RSS/RDF newsreader

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage summary and exit]' \
  '(-V --version)'{-V,--version}'[print program version and exit]' \
  '(-u --update)'{-u,--update}'[automatically update all subscribed feeds at startup]' \
  '(-c --cursor-on)'{-c,--cursor-on}'[always display the cursor on the screen]' \
  '(-l --charset)'{-l,--charset}'[force using this charset]:charset' && ret=0

return ret
