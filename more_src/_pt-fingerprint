#compdef pt-fingerprint
# Documentation: https://docs.percona.com/percona-toolkit/pt-fingerprint.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--config=[comma-separated config files]:files:_files' \
  '--match-embedded-numbers[match numbers in identifiers]' \
  '--match-md5-checksums[match MD5 checksums]' \
  '--query=[fingerprint a single query]:query:' \
  '*:query files:_files' && ret=0

return ret
