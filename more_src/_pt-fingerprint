#compdef pt-fingerprint
# Documentation: https://man.archlinux.org/search?q=pt-fingerprint
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:config file:_files' \
  '--match-embedded-numbers[match numbers in identifiers]' \
  '--match-md5-checksums[match MD5 checksums]' \
  '--query=[fingerprint a single query]:query:' \
  '*:query files:_files' && ret=0

return ret
