# -----------------------------------------------------------------------------
#
# THE buffdb CLI — clap derive + tonic + rusqlite + async-stream
#
# buffdb's CLI is in src/cli.rs.  Uses clap v4 derive with
# nested subcommand groups (Backend value-enum + Command +
# KvCommand + BlobCommand + BlobGetMode + BlobUpdateMode).
#
# Source structure:
#     #[derive(Debug, Parser)]
#     struct Args {
#         #[arg(value_enum, short, long, default_value_t = Backend::default())]
#         backend: Backend,
#         #[command(subcommand)]
#         command: Command,
#     }
#
#     #[derive(Debug, Subcommand)]
#     enum Command {
#         #[clap(alias = "serve")] Run(RunArgs),
#         #[clap(aliases = ["key-value", "k-v"])] Kv(KvArgs),
#         Blob(BlobArgs),
#     }
#
# Global flags:
#   -b, --backend BACKEND        storage backend
#                                (sqlite | duckdb [disabled])
#
# Subcommands:
#   run [--kv-store PATH] [--blob-store PATH] [ADDR]
#       Run as gRPC server (alias: serve)
#       Default --kv-store: kv_store.db
#       Default --blob-store: blob_store.db
#       Default ADDR: [::1]:9313
#   kv [-s STORE] <kv-command>
#       Direct KV operations (aliases: key-value, k-v)
#       Default -s/--store: kv_store.db
#       Subcommands: get (fetch), set (put/save/store),
#                    delete (remove/rm), eq (equal/equals),
#                    not-eq (unique/ne/neq)
#   blob [-s STORE] <blob-command>
#       Direct BLOB operations
#       Default -s/--store: blob_store.db
#       Subcommands: get (fetch) ID [MODE], store (put/save/set),
#                    update ID MODE, delete (remove/rm) ID,
#                    eq-data IDS..., not-eq-data IDS...
#       BLOB get MODE: data | metadata | both
#
# tonic is used in src/lib.rs + src/backend/* for:
#   1. Server implementation: KvStoreServer / BlobStoreServer
#      generated from proto definitions
#   2. Client SDK generation: KvStoreClient / BlobStoreClient
#      compiled in build.rs via tonic-build
#   3. Streaming responses for bulk operations
#
# Five-axis distinctness from all previously-documented Rust
# libraries:
#
#   1. gRPC I/O ABSTRACTION — tonic implements gRPC; distinct
#      from every other Axis.
#
#   2. PROTO CODE GENERATION via tonic-build — Rust types
#      generated from .proto files at compile time.
#
#   3. ASYNC/AWAIT FROM DAY ONE — first Rust gRPC framework
#      designed for async/await syntax.
#
#   4. HYPER HTTP/2 BACKEND — shared transport layer with
#      reqwest (R649).
#
#   5. tower MIDDLEWARE INTEGRATION — composes with the same
#      middleware abstraction used by axum + warp.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/buffdb/buffdb/blob/main/src/cli.rs
# clap v4 derive #[command(subcommand)] + #[arg] definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _buffdb_cmds _buffdb_kv_cmds _buffdb_blob_cmds _buffdb_blob_modes
_buffdb_cmds=(
    'run:run BuffDB as a gRPC server'
    'serve:run BuffDB as a gRPC server (alias)'
    'kv:perform operations on the key-value store'
    'key-value:perform operations on the key-value store (alias)'
    'k-v:perform operations on the key-value store (alias)'
    'blob:perform operations on the BLOB store'
    'help:show help for a subcommand'
)
_buffdb_kv_cmds=(
    'get:get values for keys'
    'fetch:get values for keys (alias)'
    'set:set a value for a key'
    'put:set a value for a key (alias)'
    'save:set a value for a key (alias)'
    'store:set a value for a key (alias)'
    'delete:delete a value for a key'
    'remove:delete a value for a key (alias)'
    'rm:delete a value for a key (alias)'
    'eq:check if keys have equal values'
    'equal:check if keys have equal values (alias)'
    'equals:check if keys have equal values (alias)'
    'not-eq:check if keys have unique values'
    'unique:check if keys have unique values (alias)'
    'ne:check if keys have unique values (alias)'
    'neq:check if keys have unique values (alias)'
)
_buffdb_blob_cmds=(
    'get:get a BLOB by ID'
    'fetch:get a BLOB by ID (alias)'
    'store:store a BLOB'
    'put:store a BLOB (alias)'
    'save:store a BLOB (alias)'
    'set:store a BLOB (alias)'
    'update:update a BLOB'
    'delete:delete a BLOB'
    'remove:delete a BLOB (alias)'
    'rm:delete a BLOB (alias)'
    'eq-data:check if BLOBs have equal data'
    'not-eq-data:check if BLOBs have unique data'
)
_buffdb_blob_modes=(
    'data:get the BLOB data only'
    'bytes:get the BLOB data (alias)'
    'metadata:get the BLOB metadata only'
    'meta:get the BLOB metadata (alias)'
    'both:get both data and metadata'
)

_arguments -C \
    '(-b --backend)'{-b+,--backend=}'[storage backend]:backend:(sqlite duckdb)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'buffdb subcommand' _buffdb_cmds && ret=0
        ;;
    args)
        case $words[1] in
            run|serve)
                _arguments \
                    '--kv-store=[location of the KV store]:file:_files' \
                    '--blob-store=[location of the BLOB store]:file:_files' \
                    '1:listen address:_default' \
                    && ret=0
                ;;
            kv|key-value|k-v)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'kv subcommand' _buffdb_kv_cmds && ret=0
                else
                    case $words[2] in
                        get|fetch|delete|remove|rm|eq|equal|equals|not-eq|unique|ne|neq)
                            _message 'key' && ret=0 ;;
                        set|put|save|store)
                            _message 'key value' && ret=0 ;;
                    esac
                fi
                ;;
            blob)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'blob subcommand' _buffdb_blob_cmds && ret=0
                else
                    case $words[2] in
                        get|fetch) _message 'BLOB ID + optional mode' && ret=0 ;;
                        store|put|save|set)
                            _arguments \
                                '1:file (or - for stdin):_files' \
                                '2:metadata:_default' \
                                && ret=0
                            ;;
                    esac
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _buffdb_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
