#compdef stoken
# _stoken — cernekee stoken (open-source RSA SecurID software token; subcommands: import, tokencode (default), unlock, setpin, setpassword, show, issue; --use-time epoch override, --token-file path override, --batch script mode, --random tokencode prefix random, --version, --help)
# upstream: https://github.com/cernekee/stoken
# Subcommands from cernekee/stoken src/stoken.c on tip.

_stoken() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--use-time+[epoch override]:epoch:' \
        '--token-file+[token file]:file:_files' \
        '--batch[batch script mode]' \
        '--random[random prefix]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'stoken command' '(import tokencode unlock setpin setpassword show issue export)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_stoken "$@"
