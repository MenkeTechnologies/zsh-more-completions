#compdef kubeconform

# Zsh completion for kubeconform - Kubernetes manifest validator

_arguments -s -S \
  '-cache[cache directory for downloaded schemas]:directory:_directories' \
  '-debug[enable debug logging]' \
  '-exit-on-error[exit on first error]' \
  '*-ignore-filename-pattern[pattern of filenames to ignore]:pattern' \
  '-ignore-missing-schemas[skip resources with missing schemas]' \
  '-insecure-skip-tls-verify[skip TLS certificate verification]' \
  '-kubernetes-version[version of Kubernetes to validate against]:version' \
  '-n[number of goroutines to use]:number' \
  '-output[output format]:format:(json junit tap text)' \
  '*-reject[reject resources of specified kind]:kind' \
  '*-schema-location[override schema location]:location' \
  '*-skip[skip resources of specified kind]:kind' \
  '-strict[disallow additional properties not in schema]' \
  '-summary[show summary at the end]' \
  '-verbose[enable verbose output]' \
  '(- *)-version[show version]' \
  '(- *)-h[show help]' \
  '*:file:_files'
