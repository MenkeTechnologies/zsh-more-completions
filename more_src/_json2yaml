#compdef json2yaml
# Documentation: https://github.com/jeremyfa/yaml.js
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (yamljs json2yaml CLI).

# Zsh completion for json2yaml (yamljs) - JSON to YAML converter

_arguments -s -S \
  '(- *)'{-h,--help}'[show the help message and exit]' \
  '(- *)'{-v,--version}'[show the version number and exit]' \
  '(-d --depth)'{-d+,--depth=}'[minimum depth before generating inline YAML (default 2)]:depth:' \
  '(-i --indentation)'{-i+,--indentation=}'[number of space characters used to indent (default 2)]:spaces:' \
  '(-s --save)'{-s,--save}'[save output inside YML file(s) with the same name]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into sub-directories for JSON files]' \
  '(-w --watch)'{-w,--watch}'[watch for changes]' \
  '*:input:_files -g "*.json"'
