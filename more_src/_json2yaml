#compdef json2yaml

# Zsh completion for json2yaml - JSON to YAML converter

_arguments -s -S \
  '(-i --indent)'{-i,--indent}'[indent output with given number of spaces]:spaces:' \
  '(-s --sort-keys)'{-s,--sort-keys}'[sort object keys]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.json"'
