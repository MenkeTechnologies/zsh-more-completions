#compdef nchat
# Documentation: https://github.com/d99kris/nchat
# nchat - terminal-based chat client for Telegram and WhatsApp

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display this help and exit]' \
  '(-v --version)'{-v,--version}'[output version information and exit]' \
  '(-d --confdir)'{-d,--confdir}'[use a different directory than ~/.config/nchat]:dir:_files -/' \
  '(-e --verbose)'{-e,--verbose}'[enable verbose logging]' \
  '--extra-verbose[enable extra verbose logging]' \
  '(-k --keydump)'{-k,--keydump}'[key code dump mode]' \
  '(-m --devmode)'{-m,--devmode}'[developer mode]' \
  '(-r --remove)'{-r,--remove}'[remove chat protocol account]' \
  '(-s --setup)'{-s,--setup}'[set up chat protocol account]' \
  '(-x --export)'{-x,--export}'[export message cache to specified dir]:dir:_files -/' && ret=0

return ret
