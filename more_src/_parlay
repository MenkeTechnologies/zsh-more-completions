#compdef parlay
# Documentation: https://github.com/snyk/parlay
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f,--file}'=[SBOM file]:file:_files' \
  '(-i --image)'{-i,--image}'=[container image reference]:image' \
  '--format=[SBOM format]:format:(spdx cyclonedx)' \
  '1:command:(enrich report scan)' \
  '*: : _default'
