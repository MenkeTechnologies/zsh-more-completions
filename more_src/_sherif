#compdef sherif

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-r+[root directory]:directory:_directories' \
  '--root=[root directory]:directory:_directories' \
  '--fix[auto-fix issues]' \
  '--ignore-rule=[ignore a rule]:rule' \
  '--ignore-package=[ignore a package]:package' \
  '--ignore-dependency=[ignore a dependency]:dependency' && ret=0

return ret
