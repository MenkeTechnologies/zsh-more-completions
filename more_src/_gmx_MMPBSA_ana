#compdef gmx_MMPBSA_ana
# Documentation: https://valdes-tresanco-ms.github.io/gmx_MMPBSA/dev/gmx_MMPBSA_ana_command-line/
# GUI analyzer for gmx_MMPBSA result info files

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --files)'{-f,--files}'[info files or container folder(s)]:*:file:_files' \
  '(-r --recursive)'{-r,--recursive}'[search recursively at depth 1]' && ret=0

return ret
