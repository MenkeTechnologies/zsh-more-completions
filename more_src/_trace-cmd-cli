#compdef trace-cmd-cli
# _trace-cmd-cli — Steven Rostedt trace-cmd userspace frontend for ftrace CLI alias (rostedt team, C); custom argparse
# upstream: https://git.kernel.org/pub/scm/utils/trace-cmd/trace-cmd.git

_trace-cmd-cli() {
    local -a sub=(
        'record:record a trace'
        'start:start tracing'
        'stop:stop tracing'
        'restart:restart tracing'
        'extract:extract trace from buffer'
        'reset:reset ftrace settings'
        'snapshot:take or display snapshot'
        'report:show recorded trace'
        'split:split a trace.dat file'
        'stream:stream live trace'
        'profile:profile workload'
        'show:show current ftrace output'
        'hist:show histogram'
        'mem:show ftrace memory usage'
        'list:list available events/options'
        'restore:restore options/events from trace.dat'
        'stack:show kernel stack tracing'
        'check-events:test events parsing'
        'options:list available options'
        'agent:run as agent'
        'setup-guest:setup guest agent'
        'attach:attach to guest agent'
        'convert:convert trace to text or other format'
        'dump:dump trace meta data'
        'rmdir:remove instance dir'
        'mkdir:create instance dir'
        'clear:clear trace'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trace-cmd subcommand' sub ;;
        args)
            case $words[1] in
                record) _arguments \
                    '-p+[plugin]:str:' \
                    '-e+[event]:str:' \
                    '-f+[filter]:str:' \
                    '-F[push]' \
                    '-c[child]' \
                    '-o+[output file]:file:_files -g "*.dat"' \
                    '-b+[buf size kb]:n:' \
                    '-B+[buffer instance]:str:' \
                    '-d[disable cmdline records]' \
                    '-D[disable filter records]' \
                    '-G[no graphics]' \
                    '-i[ignore syscalls]' \
                    '-l+[function filter]:str:' \
                    '-n+[notrace function]:str:' \
                    '-O+[option]:str:' \
                    '-P+[pid]:pid:_pids' \
                    '-s+[sleep ms]:n:' \
                    '-S[no buffering]' \
                    '-T[stack tracing]' \
                    '-v[verbose]' \
                    '-N+[host]:host:_hosts' \
                    '-q[quiet]' \
                    '-r+[realtime priority]:n:' \
                    '-w[wait until killed]' \
                    '*:command:' ;;
                report) _arguments \
                    '-i+[input file]:file:_files -g "*.dat"' \
                    '-f+[filter]:str:' \
                    '-G[no graph]' \
                    '-l[show latency]' \
                    '-w[show wakeups]' \
                    '-V+[options]:str:' \
                    '-O+[option]:str:' \
                    '--cpu=+[cpu]:n:' \
                    '--cpus[show cpus]' \
                    '--events[show events]' \
                    '-q[quiet]' \
                    '-t[show ts in us]' \
                    '-T[show ts in ms]' \
                    '-v+[verbose level]:n:' ;;
                start|stop|restart|reset|clear|show) _arguments \
                    '-e+[event]:str:' \
                    '-p+[plugin]:str:' \
                    '-f+[filter]:str:' \
                    '-B+[buffer]:str:' \
                    '-l[long]' \
                    '-q[quiet]' \
                    '-v[verbose]' ;;
                list) _arguments \
                    '-e+[events]:str:' \
                    '-p+[plugins]:str:' \
                    '-o[options]' \
                    '-f[filter]' \
                    '-F[file list]' ;;
            esac
            ;;
    esac
}

_trace-cmd-cli "$@"
