#compdef freckles
# Documentation: https://man.archlinux.org/search?q=freckles
# Reference accessed: 2026-05-16

# freckles toolkit — CLI entry `freckles` manages frecklets (see freckles.io docs). Delegate specifics to `_normal` after global flags.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v+[verbosity]:level' \
  '*::args: _normal' && ret=0

return ret
