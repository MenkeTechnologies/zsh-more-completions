#compdef staq_resource_estimator
# Documentation: https://github.com/softwareQinc/staq/wiki/The-staq-tool-suite
# staq tool: estimate resources of an OpenQASM circuit

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--box-gates[count gates as atomic]' \
  '--unbox-qelib[decompose standard library gates]' \
  '--no-merge-dagger[count gates and inverses separately]' && ret=0

return ret
