#compdef chruby
# Documentation: https://man.archlinux.org/search?q=chruby
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

local -a rubies
if [[ -d ~/.rubies ]]; then
  rubies=( ~/.rubies/*(N:t) )
fi
if [[ -d /opt/rubies ]]; then
  rubies+=( /opt/rubies/*(N:t) )
fi

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:ruby version:(system ${rubies})' && ret=0

return ret
