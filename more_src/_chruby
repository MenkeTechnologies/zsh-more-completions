#compdef chruby
# Documentation: https://github.com/postmodern/chruby
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# chruby is a shell function. Usage:
#   chruby                  list available Rubies
#   chruby <version>        select a Ruby (fuzzy match)
#   chruby system           switch back to the system Ruby

local curcontext="$curcontext" state line ret=1

local -a rubies
if [[ -d ~/.rubies ]]; then
  rubies=( ~/.rubies/*(N:t) )
fi
if [[ -d /opt/rubies ]]; then
  rubies+=( /opt/rubies/*(N:t) )
fi

_arguments -s -S \
  '1:ruby version:(system ${rubies})' \
  '2::ruby option (assigned to $RUBYOPT):' && ret=0

return ret
