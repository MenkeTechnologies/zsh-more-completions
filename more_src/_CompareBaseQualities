#compdef CompareBaseQualities
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/validation/CompareBaseQualities.java
# Compares the base qualities of two SAM/BAM/CRAM files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*'{-I,--input}'=[BAM/SAM/CRAM read file (specify two)]:bam:_files' \
  '(-R --reference)'{-R,--reference}'=[reference sequence fasta]:fasta:_files' \
  '(-O --output)'{-O,--output}'=[summary output file]:output:_files' \
  '--throw-on-diff[throw exception on difference]' \
  '*--static-quantized-quals=[use static quantized quality scores to N levels]:n:' \
  '--round-down-quantized[round down quality scores to nearest quantized value]' \
  '--tmp-dir=[temp directory]:dir:_files -/' \
  '--verbosity=[logging verbosity]:level:(ERROR WARNING INFO DEBUG)' \
  '*:bam:_files' && ret=0

return ret
