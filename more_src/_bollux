#compdef bollux
# _bollux — Bollux Gemini protocol client (Bash); pure-bash gemini:// browser
# upstream: https://tildegit.org/acdw/bollux

_bollux() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-i --identity)'{-i,--identity}'+[identity cert]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
        '*:gemini URL:_urls'
}

_bollux "$@"
