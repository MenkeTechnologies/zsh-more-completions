#compdef whodepends
# Documentation: https://manpages.debian.org/whodepends
# Source: debian/devscripts scripts/whodepends.sh — list maintainers of packages that depend on a given package (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-s --source)'{-s,--source}'[show source packages instead of binary]' \
    '*:package:_default' \
    && ret=0

return ret
