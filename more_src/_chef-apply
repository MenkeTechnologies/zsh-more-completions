#compdef chef-apply
# Documentation: https://docs.chef.io/ctl_chef_apply/
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  {-v,--version}'[show version]' \
  {-e,--execute}'[execute a command string]:command string' \
  {-l,--log_level}'[set the log level]:log level:(auto trace debug info warn error fatal)' \
  {-s,--server}'[chef server URL]:server URL:_urls' \
  {-j,--json-attributes}'[JSON attributes file]:JSON file:_files -g "*.json"' \
  {-f,--recipe-url}'[URL to a recipe file]:recipe URL:_urls' \
  {-W,--why-run}'[enable why-run mode]' \
  '1::recipe file:_files -g "*.rb"' \
  && return 0
