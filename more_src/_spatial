#compdef spatial gmx-spatial
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-spatial.html
# gmx spatial: calculate the spatial distribution function

local ret=1

_arguments -s \
  '-s[structure+mass(db) file]:file:_files' \
  '-f[trajectory file]:file:_files' \
  '-n[index file]:file:_files' \
  '-b[starting frame time]:time:' \
  '-e[ending frame time]:time:' \
  '-dt[frame sampling interval]:time:' \
  '-w[view output files]' \
  '-pbc[use periodic boundary conditions for distances]' \
  '-div[apply divisor for bin occupancies based on atom counts]' \
  '-ign[number of outer cubes to exclude from display]:int:' \
  '-bin[bin width in nanometers]:real:' \
  '-nab[number of additional bins for memory allocation]:int:' && ret=0

return ret
