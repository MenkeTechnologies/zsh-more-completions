#compdef ftgrouppha
# Documentation: https://heasarc.gsfc.nasa.gov/lheasoft/help/ftgrouppha.html
# Set the GROUPING column of a PHA spectrum using various binning algorithms

local ret=1

_arguments -s -S \
  'infile=[PHA file whose GROUPING column is set]:infile:_files' \
  'backfile=[background PHA for S/N or bkg-min grouping]:backfile:_files' \
  'outfile=[output PHA with modified GROUPING column]:outfile:_files' \
  'grouptype=[grouping mode]:grouptype:(bmin constant min snmin opt optmin optsnmin file)' \
  'groupscale=[scaling factor or threshold for grouptype]:groupscale:' \
  'minchannel=[start channel for grouping]:minchannel:' \
  'maxchannel=[end channel for grouping]:maxchannel:' \
  'respfile=[RMF response file for optimal binning]:respfile:_files' \
  'templatefile=[template spectrum for grouptype=file]:templatefile:_files' \
  'rows=[range of rows to group, - for all]:rows:' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  '*:file:_files' && ret=0

return ret
