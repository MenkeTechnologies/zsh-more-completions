#compdef esl-mixdchlet

# Easel esl-mixdchlet: fit mixture-Dirichlet priors to count data
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-N[number of Dirichlet components in mixture]:n:' \
  '-T[stop training when log-likelihood improves less than T]:T:' \
  '-r[number of random initializations]:n:' \
  '-s[random seed]:n:' \
  '*:count data file:_files' && ret=0
return ret
