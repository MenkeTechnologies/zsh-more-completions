#compdef qlot
# Documentation: https://github.com/fukamachi/qlot
# qlot - project-local Common Lisp library installer/manager

local ret=1
local context state line
typeset -A opt_args

_arguments -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    local -a cmds
    cmds=(
      'install:install Quicklisp and libraries declared in qlfile'
      'update:update the project-local .qlot/ directory using qlfile'
      'add:add a line to qlfile and run qlot install'
      'remove:remove libraries from qlfile and run qlot install'
      'exec:run a command with ASDF and PATH configured for the project'
      'bundle:collect and copy all dependencies into a directory'
      'init:create qlfile, qlfile.lock and .qlot/ for a new project'
    )
    _describe -t commands 'qlot command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      install|update)
        _arguments -s \
          '--no-cache[disable shared cache for this invocation]' \
          '*:project name:' && ret=0
        ;;
      add)
        _arguments -s \
          '--latest[use the latest version]' \
          '--upstream[download from the upstream git repository]' \
          '--branch[specify branch name for git/github sources]:branch:' \
          '*:library:' && ret=0
        ;;
      remove)
        _arguments -s '*:library:' && ret=0
        ;;
      bundle)
        _arguments -s \
          '--exclude[exclude specific projects from bundling]:project:' \
          '--output[destination directory]:directory:_files -/' && ret=0
        ;;
      exec)
        _arguments -s '*:::command:_normal' && ret=0
        ;;
    esac
    ;;
esac

return ret
