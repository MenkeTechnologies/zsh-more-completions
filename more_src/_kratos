#compdef kratos
# Documentation: https://www.ory.com/docs/kratos/cli/kratos
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (kratos / kratos serve
# CLI pages). Added real top-level commands cleanup/delete/format/
# get; removed the invented `kratos serve all|admin|public`
# positional (serve has no such subcommands).

# Zsh completion for Ory Kratos - identity server

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'cleanup:various cleanup helpers'
      'courier:manage message courier'
      'delete:delete resources'
      'format:format resources'
      'get:get resources'
      'hashers:manage password hashers'
      'identities:tools to interact with remote identities'
      'import:import resources'
      'jsonnet:helpers for working with JSONNet files'
      'lint:lint JSONNet files'
      'list:list resources'
      'migrate:various migration helpers'
      'remote:helpers and management for remote Ory Kratos instances'
      'serve:run the Ory Kratos server'
      'validate:validate resources'
      'version:show the build version, build time, and git hash'
    )
    _describe -t commands 'kratos command' commands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--config=[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--dev[disables critical security features for development]' \
          '--watch-courier[run the message courier as a background task]' \
          '--sqa-opt-out[disable anonymized telemetry reports]' && ret=0
        ;;
      identities)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '--endpoint=[Kratos admin endpoint]:url' \
          '--format=[output format]:format:(table json yaml json-pretty jsonpath jsonpointer)' \
          '1:subcommand:(delete get import list patch validate)' && ret=0
        ;;
      migrate)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '-c+[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '--config=[config file]:config:_files -g "*.{yaml,yml,json}"' \
          '1:subcommand:(sql normalize-phone-numbers)' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:config file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*:config file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      hashers)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(argon2 calibrate)' && ret=0
        ;;
      jsonnet)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(format lint)' && ret=0
        ;;
    esac
    ;;
esac

return ret
