#compdef mothur
# Documentation: https://mothur.org/wiki/command_line_mode/
# mothur - microbial ecology toolkit (single binary, many commands)

local ret=1
local -a cmds

cmds=(
  'make.contigs:assemble paired reads into contigs'
  'screen.seqs:cull sequences not meeting criteria'
  'unique.seqs:collapse duplicate sequences'
  'count.seqs:count sequence representation per group'
  'align.seqs:align sequences to a reference'
  'filter.seqs:filter alignment columns'
  'pre.cluster:pre-cluster near-identical sequences'
  'chimera.vsearch:detect chimeras with vsearch'
  'remove.seqs:remove listed sequences'
  'classify.seqs:assign taxonomy to sequences'
  'cluster:assign sequences to OTUs'
  'make.shared:build a shared OTU file'
  'classify.otu:assign consensus taxonomy to OTUs'
  'rarefaction.single:rarefaction curves per sample'
  'summary.single:alpha-diversity summary'
  'dist.seqs:pairwise sequence distances'
  'dist.shared:pairwise community distances'
  'tree.shared:build dendrogram from shared file'
  'phylotype:cluster by taxonomy'
  'sub.sample:subsample to even depth'
  'normalize.shared:normalize a shared file'
  'get.oturep:representative sequence per OTU'
  'bin.seqs:list sequences by OTU'
  'heatmap.bin:OTU heatmap'
  'venn:Venn diagram of shared OTUs'
  'parsimony:parsimony test on a tree'
  'unifrac.weighted:weighted UniFrac test'
  'corr.axes:correlate axes with OTUs/metadata'
  'nmds:non-metric multidimensional scaling'
  'pcoa:principal coordinates analysis'
  'amova:analysis of molecular variance'
  'homova:homogeneity of molecular variance'
)

_arguments -s \
  '(-h --help)'{-h,--help}'[show all commands and FAQs]' \
  '(-v --version)'{-v,--version}'[show version, OS and release date]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, only output errors]' \
  '*:batch file or "#command(...)":{_alternative "files:batch file:_files" "commands:mothur command:(( ${cmds} ))"}' && ret=0

return ret
