#compdef wf-cmd
# Documentation: https://man.archlinux.org/search?q=wf-cmd
# Reference accessed: 2026-05-16

# wf-cmd: send a command to a running Wayfire instance via wayfire-shell-unstable-v2
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '*:wf-cmd args:_files' && ret=0
return ret
