#compdef lazyssh
# Documentation: https://github.com/Adembc/lazyssh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cobra root command, only built-in help/version).

# Zsh completion for lazyssh — SSH manager TUI (Adembc/lazyssh)
# STUB: tool exposes only cobra-built-in help; no documented CLI flags.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for lazyssh]' \
  '(-v --version)'{-v,--version}'[version for lazyssh]' && ret=0

return ret
