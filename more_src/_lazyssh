#compdef lazyssh
# Documentation: https://man.archlinux.org/search?q=lazyssh
# Reference accessed: 2026-05-16

# Zsh completion for lazyssh — SSH manager TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--config[ssh config]:file:_files' && ret=0

return ret
