#compdef myth

# Zsh completion for Mythril (Ethereum smart contract security analysis tool)

local curcontext="$curcontext" state line ret=1

local -a myth_commands
myth_commands=(
  'analyze:analyze a smart contract'
  'a:analyze a smart contract'
  'disassemble:disassemble a contract'
  'd:disassemble a contract'
  'list-detectors:list available vulnerability detectors'
  'read-storage:read storage from a contract'
  'function-to-hash:convert a function signature to its hash'
  'hash-to-address:convert a hash to an address'
  'version:show version information'
  'help:show help message'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '1:command:_describe -t commands command myth_commands' \
  '*::args:->args' && ret=0

case "$state" in
  args)
    case "${line[1]}" in
      analyze|a)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
          '(-o --output)'{-o,--output}'=[output format]:format:(text markdown json jsonv2)' \
          '--solc-json=[path to solc JSON input]:file:_files -g "*.json"' \
          '--solv=[specify Solidity compiler version]:version:' \
          '--max-depth=[maximum recursion depth]:depth:' \
          '--call-depth-limit=[call depth limit]:limit:' \
          '--strategy=[symbolic execution strategy]:strategy:(dfs bfs naive-random weighted-random)' \
          '--execution-timeout=[execution timeout in seconds]:seconds:' \
          '--solver-timeout=[solver timeout in milliseconds]:milliseconds:' \
          '--transaction-count=[number of transactions to explore]:count:' \
          '--modules=[comma-separated list of detection modules]:modules:' \
          '--create-timeout=[timeout for contract creation in seconds]:seconds:' \
          '--enable-physics[enable physics-based detection]' \
          '--unchecked-addresses=[comma-separated list of unchecked addresses]:addresses:' \
          '--bin-runtime[analyze runtime bytecode]' \
          '(-a --address)'{-a,--address}'=[contract address on the blockchain]:address:' \
          '(-c --code)'{-c,--code}'=[hex-encoded bytecode string]:bytecode:' \
          '(-f --codefile)'{-f,--codefile}'=[file containing hex-encoded bytecode]:file:_files' \
          '--solc-args=[additional arguments for the Solidity compiler]:args:' \
          '*:solidity file:_files -g "*.sol"' \
          && ret=0
        ;;
      disassemble|d)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --code)'{-c,--code}'=[hex-encoded bytecode string]:bytecode:' \
          '(-f --codefile)'{-f,--codefile}'=[file containing hex-encoded bytecode]:file:_files' \
          '(-a --address)'{-a,--address}'=[contract address on the blockchain]:address:' \
          '--bin-runtime[disassemble runtime bytecode]' \
          '--solc-json=[path to solc JSON input]:file:_files -g "*.json"' \
          '--solv=[specify Solidity compiler version]:version:' \
          '*:solidity file:_files -g "*.sol"' \
          && ret=0
        ;;
      read-storage)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:contract address:' \
          '2:storage slot:' \
          && ret=0
        ;;
      function-to-hash)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:function signature:' \
          && ret=0
        ;;
      hash-to-address)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:hash:' \
          && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
