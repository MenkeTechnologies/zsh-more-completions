#compdef opencv_annotation
# Documentation: https://docs.opencv.org/4.x/dc/d88/tutorial_traincascade.html
# opencv_annotation — annotate positive object samples for cascade training

local ret=1

_arguments -s -S \
  '(-h --help -usage -?)'{-h,--help}'[show usage information]' \
  '(-i --images)'{-i,--images}'=[path to image folder]:dir:_files -/' \
  '(-a --annotations)'{-a,--annotations}'=[path to annotations output file]:file:_files' \
  '(-m --maxWindowHeight)'{-m,--maxWindowHeight}'=[scale down images exceeding this height]:height' \
  '(-r --resizeFactor)'{-r,--resizeFactor}'=[scaling factor when resizing images]:factor' && ret=0

return ret
