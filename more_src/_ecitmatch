#compdef ecitmatch
# _ecitmatch — NCBI Entrez Direct ecitmatch CLI batch-matching citation strings against PubMed PMIDs using journal-name year volume first-page first-author author-list batch matching for citation deduplication PubMed-bibliography reconciliation pipeline component (NCBI Entrez Direct team, Perl); getopt
# upstream: https://www.ncbi.nlm.nih.gov/books/NBK179288/

_ecitmatch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-db+[database]:d:(pubmed)' \
        '-retmode+[m]:m:(xml json text)' \
        '-rettype+[t]:t:(xml json)' \
        '-bdata+[file]:file:_files' \
        '-input+[file]:file:_files' \
        '*::'
}

_ecitmatch "$@"
