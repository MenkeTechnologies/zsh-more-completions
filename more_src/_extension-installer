#compdef extension-installer
# _extension-installer — Percona PostgreSQL operator extension installer (downloads pg extension archives from S3-compatible storage into a shared volume)
# upstream: https://github.com/percona/percona-postgresql-operator
# Flags from cmd/extension-installer/main.go on tip.

_extension-installer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-type=[storage type]:type:(s3 gcs azure)' \
        '-endpoint=[storage endpoint]:url:_urls' \
        '-region=[storage region]:region:' \
        '-bucket=[storage bucket]:bucket:' \
        '-extension-path=[extension installation path]:path:_files -/' \
        '-key=[extension archive key]:key:' \
        '-install[install extension]' \
        '-uninstall[uninstall extension]' \
        '-force-path-style[force path-style addressing]' \
        '-disable-ssl[disable SSL/TLS]'
}

_extension-installer "$@"
