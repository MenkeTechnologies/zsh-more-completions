#compdef fpocket
# Documentation: https://github.com/Discngine/fpocket/blob/master/doc/MANUAL.md
# fpocket - protein pocket detection via Voronoi tessellation / alpha spheres.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[input PDB/mmCIF file]:file:_files' \
  '(-w --write_mode)'{-w+,--write_mode=}'[output format d/b/p/m]:mode:(d b p m)' \
  '(-d --pocket_descr_stdout)'{-d,--pocket_descr_stdout}'[write descriptors to stdout]' \
  '(-x --calculate_interaction_grids)'{-x,--calculate_interaction_grids}'[compute VdW/Coulomb grids]' \
  '(-l --model_number)'{-l+,--model_number=}'[NMR model number]:n:' \
  '(-u --topology_file)'{-u+,--topology_file=}'[Amber prmtop topology]:file:_files' \
  '(-r --custom_ligand)'{-r+,--custom_ligand=}'[ligand resnum:resname:chain]:lig:' \
  '(-P --custom_pocket)'{-P+,--custom_pocket=}'[custom pocket residues]:res:' \
  '(-a --chain_as_ligand)'{-a+,--chain_as_ligand=}'[treat chain(s) as ligand]:chain:' \
  '(-c --drop_chains)'{-c+,--drop_chains=}'[remove chains]:chains:' \
  '(-k --keep_chains)'{-k+,--keep_chains=}'[keep only chains]:chains:' \
  '(-m --min_alpha_size)'{-m+,--min_alpha_size=}'[min alpha-sphere radius]:float:' \
  '(-M --max_alpha_size)'{-M+,--max_alpha_size=}'[max alpha-sphere radius]:float:' \
  '(-i --min_spheres_per_pocket)'{-i+,--min_spheres_per_pocket=}'[min spheres per pocket]:int:' \
  '(-p --min_ratio_apolar_spheres_per_pocket)'{-p+,--min_ratio_apolar_spheres_per_pocket=}'[min apolar ratio]:float:' \
  '(-D --clustering_distance)'{-D+,--clustering_distance=}'[clustering distance]:float:' \
  '(-C --clustering_method)'{-C+,--clustering_method=}'[clustering method s/m/a/c]:m:(s m a c)' \
  '(-e --clustering_distance_measure)'{-e+,--clustering_distance_measure=}'[distance measure e/b]:m:(e b)' \
  '(-y --number_apol_asph_pocket)'{-y+,--number_apol_asph_pocket=}'[min apolar neighbors]:float:' \
  '(-v --iterations_volume_mc)'{-v+,--iterations_volume_mc=}'[Monte-Carlo volume iterations]:int:' \
  '*:file:_files' && ret=0

return ret
