#compdef munpack
# Extract MIME-encoded attachments from email messages

_arguments -s -S \
  '-f[force overwrite of existing files]' \
  '-q[quiet mode]' \
  '-t[list content types without extracting]' \
  '-C[change to directory before extracting]:dir:_files -/' \
  '*:message file:_files' \
  && return 0
