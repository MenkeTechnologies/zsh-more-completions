#compdef c-chess-cli
# _c-chess-cli — command-line interface for UCI chess engines (lucasart/c-chess-cli)
# upstream: https://github.com/lucasart/c-chess-cli
# Flags from src/options.c.

_c-chess-cli() {
    _arguments \
        '-version[show version]' \
        '*-engine[engine definition (options follow)]:opts:' \
        '-each[options applied to each engine]:opts:' \
        '-concurrency[max concurrent games (default 1)]:n:' \
        '-draw[adjudicate draw (number=N count=C score=S)]:spec:' \
        '-resign[adjudicate resign (number=N count=C score=S)]:spec:' \
        '-games[games per encounter (default 1)]:n:' \
        '-rounds[multiplier for rounds (default 1)]:n:' \
        '-gauntlet[play gauntlet tournament (first vs others)]' \
        '-sprt[SPRT test (elo0=E0 elo1=E1 alpha=A beta=B)]:spec:' \
        '-log[log engine I/O to files]' \
        '-openings[openings file=FILE order=ORDER srand=N]:spec:' \
        '-pgn[save games to FILE [verbosity 0-3]]:spec:' \
        '-repeat[repeat each opening twice]' \
        '-sample[sample positions freq=F decay=D resolve=y|n file=FILE format=csv|bin]:spec:'
}

_c-chess-cli "$@"
