#compdef readfile
# Documentation: https://github.com/scottransom/presto/blob/master/docs/readfile.1
# PRESTO: display values and information from a variety of data file formats.

local ret=1

_arguments -s -S \
  '-page[paginate the output like more]' \
  '(-byte -b)'{-byte,-b}'[raw data in byte format]' \
  '(-float -f)'{-float,-f}'[raw data in floating point format]' \
  '(-double -d)'{-double,-d}'[raw data in double precision format]' \
  '(-fcomplex -fc)'{-fcomplex,-fc}'[raw data in float-complex format]' \
  '(-dcomplex -dc)'{-dcomplex,-dc}'[raw data in double-complex format]' \
  '(-short -s)'{-short,-s}'[raw data in short format]' \
  '(-int -i)'{-int,-i}'[raw data in integer format]' \
  '(-long -l)'{-long,-l}'[raw data in long format]' \
  '(-rzwcand -rzw)'{-rzwcand,-rzw}'[raw data in rzw search candidate format]' \
  '(-bincand -bin)'{-bincand,-bin}'[raw data in bin search candidate format]' \
  '(-position -pos)'{-position,-pos}'[raw data in position struct format]' \
  '-pkmb[raw data in Parkes Multibeam format]' \
  '-bcpm[raw data in BCPM format]' \
  '-wapp[raw data in WAPP format]' \
  '-spigot[raw data in Spigot Card format]' \
  '-filterbank[raw data in SIGPROC filterbank format]' \
  '-psrfits[raw data in PSRFITS format]' \
  '-fortran[raw data written by a fortran program]' \
  '-index=[display range for objects]:index:' \
  '-nph=[0th FFT bin amplitude for RZW data]:nph:' \
  '*:input data file:_files' && ret=0

return ret
