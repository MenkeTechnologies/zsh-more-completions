#compdef kubectl-allctx
# Documentation: https://github.com/onatm/kubectl-allctx/blob/main/kubectl-allctx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-allctx runs a kubectl command across all contexts in the kubeconfig.
# Only --like and -h/--help are parsed; the rest is passed to kubectl.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--like[only show output lines matching this name]:name:' \
  '*:kubectl command and args:_default'
