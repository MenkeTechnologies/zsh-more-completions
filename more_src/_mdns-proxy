#compdef mdns-proxy mdns-proxyd
# _mdns-proxy — Multicast DNS Service Discovery RFC 6762 proxy daemon CLI bridging unicast DNS queries on TCP/UDP port 53 to mDNS responders on 224.0.0.251:5353 with .local zone forwarding allowing legacy resolvers and routed-network hosts to reach Bonjour Avahi mDNS services (mdns-proxy team, C); getopt
# upstream: https://github.com/cathugger/mdns-proxy

_mdns-proxy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f[foreground]' \
        '--foreground[foreground]' \
        '-l+[listen addr]:str:' \
        '--listen=+[addr:port]:str:' \
        '-p+[port]:n:' \
        '--port=+[port]:n:' \
        '-i+[interface]:_net_interfaces' \
        '--interface=+[iface]:_net_interfaces' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-g+[group]:_groups' \
        '--group=+[group]:_groups' \
        '-D+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '*::'
}

_mdns-proxy "$@"
