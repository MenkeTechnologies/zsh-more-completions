#compdef progressline
# Documentation: https://man.archlinux.org/search?q=progressline
# Reference accessed: 2026-05-16

# Zsh completion for progressline pipe progress bar

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-w+[bar width in columns]:width' \
  '-i+[label for progress]:label' \
  '-f[treat input as floats]' \
  '-p+[prefix string]:text' \
  '-s+[suffix string]:text' \
  '-m+[minimum value]:n' \
  '-M+[maximum value]:n' \
  '-c[force color]' \
  '-q[disable TTY detection]' && ret=0

return ret
