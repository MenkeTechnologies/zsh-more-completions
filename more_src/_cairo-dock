#compdef cairo-dock cairo-dock-cli
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/cairo-dock.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Cairo-Dock: customizable dock for Linux desktops (glx-dock.org).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --cairo)'{-c,--cairo}'[force Cairo backend]' \
  '(-o --opengl)'{-o,--opengl}'[force OpenGL backend]' \
  '(-O --indirect-opengl)'{-O,--indirect-opengl}'[OpenGL with indirect rendering]' \
  '(-A --ask-backend)'{-A,--ask-backend}'[ask which backend to use on startup]' \
  '(-l --log)'{-l+,--log=}'[log verbosity]:level:(debug message warning critical error)' \
  '(-F --colors)'{-F,--colors}'[force colored output messages]' \
  '(-w --wait)'{-w+,--wait=}'[delay startup N seconds]:secs:' \
  '(-a --keep-above)'{-a,--keep-above}'[keep dock above other windows]' \
  '(-s --no-sticky)'{-s,--no-sticky}'[do not show dock on all desktops]' \
  '(-e --env)'{-e+,--env=}'[desktop environment]:env:(gnome xfce kde none)' \
  '(-d --dir)'{-d+,--dir=}'[config directory]:dir:_files -/' \
  '(-m --maintenance)'{-m,--maintenance}'[show config panel before startup]' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude a plug-in]:module:' \
  '(-f --safe-mode)'{-f,--safe-mode}'[do not load plug-ins; show theme manager]' \
  '(-W --metacity-workaround)'{-W,--metacity-workaround}'[work around Metacity WM bugs]' \
  '(-M --modules-dir)'{-M+,--modules-dir=}'[additional modules directory]:dir:_files -/' \
  '(-T --testing)'{-T,--testing}'[disable crash manager for debugging]' \
  '(-E --easter-eggs)'{-E,--easter-eggs}'[enable hidden unstable options]' \
  '(-S --server)'{-S+,--server=}'[theme server URL]:url:' \
  '(-k --locked)'{-k,--locked}'[lock dock from modification]' \
  '(-C --capuccino)'{-C,--capuccino}'[easter egg]' && ret=0

return ret
