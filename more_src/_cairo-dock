#compdef cairo-dock cairo-dock-cli

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all help options]' \
  '--help-gtk[GTK options]' \
  '(-c --cairo)'{-c,--cairo}'[force Cairo backend]' \
  '(-o --opengl)'{-o,--opengl}'[force OpenGL backend]' \
  '(-O --indirect-opengl)'{-O,--indirect-opengl}'[indirect OpenGL]' \
  '(-A --no-opengl)'{-A,--no-opengl}'[no OpenGL]' \
  '(-S --server)'{-S+,--server=}'[server URL for themes]:url:' \
  '(-k --locked)'{-k,--locked}'[lock dock from modification]' \
  '(-K --keep-above)'{-K,--keep-above}'[keep dock above]' \
  '(-N --no-sticky)'{-N,--no-sticky}'[do not stick dock]' \
  '(-w --wait)'{-w+,--wait=}'[wait N seconds before start]:secs:' \
  '(-l --log)'{-l+,--log=}'[log verbosity]:lvl:(debug message warning critical error)' \
  '(-F --colors)'{-F+,--colors=}'[colors mode]:mode:(yes no)' \
  '(-d --conf-dir)'{-d+,--conf-dir=}'[config directory]:dir:_files -/' \
  '(-T --theme)'{-T+,--theme=}'[theme name]:theme:' \
  '(-M --modules-dir)'{-M+,--modules-dir=}'[modules dir]:dir:_files -/' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude module]:module:' \
  '(-f --safe-mode)'{-f,--safe-mode}'[safe mode]' \
  '(-e --easter-eggs)'{-e,--easter-eggs}'[enable easter eggs]' \
  '(-m --metacity-workaround)'{-m,--metacity-workaround}'[metacity workaround]' \
  '(-p --place)'{-p+,--place=}'[place at]:p:' \
  '--show-config[show config panel]' \
  '--show-theme-manager[show theme manager]' \
  '(-E --display)'{-E+,--display=}'[X display]:display:' \
  '(-r --register)'{-r,--register}'[register dock as application]' && ret=0

return ret
