#compdef gord
# Documentation: https://www.systutorials.com/docs/linux/man/1-scotch_gord/
# Scotch: compute a sparse-matrix block ordering of a source graph

local ret=1

_arguments -s \
  '-c-[choose default ordering strategy (b,q,s,t options)]:options' \
  '-h[display help]' \
  '-m-[save column block mapping data to file]:mfile:_files' \
  '-o-[use sequential graph ordering strategy]:strat' \
  '-t-[save partitioning tree data to file]:tfile:_files' \
  '-V[display version and copyright]' \
  '-v-[set verbose mode (s,t)]:verb' \
  '*:file:_files' && ret=0

return ret
