#compdef bareos-bcopy
# Documentation: https://docs.bareos.org/Appendix/BareosPrograms.html
# Reference accessed: 2026-05-16
# Verified: Bareos docs Appendix - bcopy program reference.
# Removed from prior file: bogus man.archlinux.org search URL.

# bareos-bcopy: copy one Bareos volume to another
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '(-b --parse-bootstrap)'{-b+,--parse-bootstrap=}'[bootstrap file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[configuration file]:file:_files' \
  '(-D --director)'{-D+,--director=}'[specify director]:director:' \
  '(-d --debug-level)'{-d+,--debug-level=}'[debug level]:level:' \
  '(--dt --debug-timestamps)'{--dt,--debug-timestamps}'[print timestamps in debug output]' \
  '(-i --input-volumes)'{-i+,--input-volumes=}'[input volumes (vol1|vol2|...)]:volumes:' \
  '(-o --output-volumes)'{-o+,--output-volumes=}'[output volumes (vol1|vol2|...)]:volumes:' \
  '(-p --ignore-errors)'{-p,--ignore-errors}'[proceed despite IO errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --working-directory)'{-w+,--working-directory=}'[working directory (default /tmp)]:dir:_files -/' && ret=0
return ret
