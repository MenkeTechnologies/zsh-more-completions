#compdef mustang
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/mustang.1.html
# MUSTANG - multiple structural alignment algorithm

local ret=1

_arguments -s -S \
  '-p[path to directory holding the PDB structures]:dir:_files -/' \
  '*-i[input structures to be aligned]:file:_files' \
  '-f[supply path and filename details via a description file]:file:_files' \
  '-o[common identifier for program outputs]:id' \
  '-F[alignment output format]:format:(html fasta pir msf)' \
  '-D[HTML output highlighting residues exceeding CA-CA diameter threshold]' \
  '-s[generate a PDB file of optimal superposition]:bool:(ON OFF)' \
  '-r[print rmsd table with rotation matrix and translation vector]:bool:(ON OFF)' \
  '--help[display help message and exit]' \
  '--version[output version information and exit]' \
  '*:file:_files' && ret=0

return ret
