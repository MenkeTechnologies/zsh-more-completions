#compdef waylandpp wayland-scanner++

# wayland-scanner++: code generator for waylandpp (Wayland C++ bindings)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:wayland protocol XML / cpp header:_files -g "*.(xml|hpp|h)"' && ret=0
return ret
