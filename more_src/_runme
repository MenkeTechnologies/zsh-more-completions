#compdef runme
# Documentation: https://docs.runme.dev/configuration/cli-reference
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--chdir=[change working directory before execution]:directory:_files -/' \
  '--project=[root project directory]:directory:_files -/' \
  '--filter=[regex to filter results]:regex:' \
  '--insecure[run in insecure mode]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'run:run a command block'
      'list:list available commands'
      'print:print a command block'
      'fmt:format a Markdown file'
      'tui:open the TUI'
      'login:log in to Runme'
      'logout:log out of Runme'
      'env:manage environment variables'
      'extension:check VS Code extension status'
      'open:launch the headless web client'
      'suggest:suggest a command'
      'branch:suggest a branch name (branchGPT)'
      'completion:generate shell completion'
    )
    _describe -t commands 'runme command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S \
          '(-f --filename)'{-f,--filename}'[Markdown file]:file:_files -g "*.md"' \
          '--all[run all commands]' \
          '(-c --category)'{-c,--category}'[filter by category]:category' \
          '(-y --skip-prompts)'{-y,--skip-prompts}'[skip prompts]' \
          '(-i --index)'{-i,--index}'[command index]:index' \
          '--background[run in background]' \
          '*:command name' && ret=0
        ;;
      list|print)
        _arguments -s -S \
          '(-f --filename)'{-f,--filename}'[Markdown file]:file:_files -g "*.md"' && ret=0
        ;;
      tui)
        _arguments -s -S \
          '--exit[close TUI after command execution]' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac
return ret
