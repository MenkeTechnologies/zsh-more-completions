#compdef exrmetrics
# _exrmetrics — measure OpenEXR read/write timing and file sizes (AcademySoftwareFoundation/openexr)
# upstream: https://github.com/AcademySoftwareFoundation/openexr
# Flags from src/bin/exrmetrics/main.cpp (custom usage).

_exrmetrics() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '-o+[output file (default: memory buffer)]:file:_files -g "*.exr"' \
        '-p+[part number to copy (or all)]:part:' \
        '-m[multi-threaded (auto thread count)]' \
        '-t+[worker thread count]:n:' \
        '-l+[DWA/ZIP compression level]:n:' \
        '(-z --compression)'{-z+,--compression=}'[compression methods to test]:list:' \
        '--convert[shorthand: write new file without metrics]' \
        '--bench[shorthand: robust performance benchmark]' \
        '--csv[output in CSV format]' \
        '--no-size[skip file-size reporting]' \
        '--passes=[number of passes per test]:n:' \
        '--time=[which times to record]:list:(read write reread all none)' \
        '--type=[pixel type list]:types:(uint half float orig orig+half)' \
        '*:EXR file:_files -g "*.exr"'
}

_exrmetrics "$@"
