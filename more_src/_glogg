#compdef glogg klogg
# _glogg — Anonymous glogg klogg CLI Qt5 Qt6 GUI log file viewer for huge log files providing fast scrolling regex search-multi-pattern bookmark color-coded highlighter timestamp parsing for syslog journald nginx access-log apache-access-log multi-tabs split-view interactive (Anonymous team, C++); custom argparse
# upstream: https://glogg.bonnefon.org/

_glogg() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l+[log file]:file:_files -g "*.log *.txt"' \
        '--load=+[file]:file:_files -g "*.log *.txt"' \
        '-c+[config file]:file:_files -g "*.conf *.cfg *.ini"' \
        '--config=+[file]:file:_files -g "*.conf *.cfg *.ini"' \
        '-d[debug]' \
        '--debug[debug]' \
        '-m[multi-window mode]' \
        '--multi-window[multi-window mode]' \
        '-s[server mode]' \
        '--server[server mode]' \
        '-n[no logfile follow]' \
        '--no-follow[no logfile follow]' \
        '-f[follow logfile]' \
        '--follow[follow logfile]' \
        '-t+[temp file]:file:_files' \
        '--tempfile=+[file]:file:_files' \
        '*:log file:_files -g "*.log *.txt *.csv *.tsv"'
}

_glogg "$@"
