#compdef ledis-load
# Documentation: https://github.com/ledisdb/ledisdb/blob/master/cmd/load.go
# Load tool for LedisDB — restores data from a dump file

local ret=1

_arguments -s -S \
  '-config=[ledisdb config file]:file:_files -g "*.(toml|conf)"' \
  '-dump_file=[ledisdb dump file to load]:file:_files' && ret=0

return ret
