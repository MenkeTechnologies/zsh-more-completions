#compdef nomic
# Documentation: https://github.com/nomic-ai/nomic
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--network=[Chain network id]:network:' \
  '--home=[Nomic home path]:directory:_directories' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Run a Nomic full node'
      'signer:Run the staking signer'
      'delegate:Delegate stake from the CLI wallet'
      'claim:Claim unbonded coins'
      'send:Transfer coins'
      'balance:Print balances'
      'declare:Declare a validator'
      'edit:Update validator metadata'
      'unbond:Begin unbonding'
      'claim-definitions:Claim recent definitions'
      'relayer:IBC relayer helper'
      'ibc:IBC transfer utilities'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
