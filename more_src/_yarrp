#compdef yarrp
# Documentation: https://github.com/cmand/yarrp/blob/master/yarrp.1
# Yarrp - high-speed Internet topology prober

local ret=1

_arguments -s \
  '-h[print command line options and a synopsis]' \
  '*-v[increase verbosity]' \
  '-Q[Internet-wide scanning mode for /24 (IPv4) or /48 (IPv6) blocks]' \
  '-T[test mode]' \
  '-i+[input list of explicit targets (one address per line)]:target file:_files' \
  '-o+[output file for probing results]:outfile:_files' \
  '-r+[set packet per second probing rate]:rate' \
  '-t+[set probe type]:type:(TCP_ACK TCP_SYN UDP ICMP ICMP_REPLY)' \
  '-c+[set number of traces to issue]:count' \
  '-S+[set permutation random seed]:seed' \
  '-E+[set instance]:instance' \
  '-p+[use specified transport destination port]:port' \
  '-b+[read BGP RIB (Potaroo text format)]:bgp rib:_files' \
  '-B+[read list of prefixes to skip]:blocklist:_files' \
  '-l+[set minimum TTL]:min ttl' \
  '-m+[set maximum TTL (power of 2)]:max ttl' \
  '-F+[set fill mode maximum TTL]:fill ttl' \
  '-s[send probes sequentially instead of randomly]' \
  '-n+[enable neighborhood enhancement]:nbr ttl' \
  '-Z+[choose TTLs from Poisson distribution with lambda]:lambda' \
  '-a+[set source IP address]:src addr' \
  '-I+[network interface to use]:interface:_net_interfaces' \
  '-M+[MAC address of source]:src mac' \
  '-G+[MAC address of gateway router]:dst mac' \
  '-g+[granularity at which to probe input IPv6 prefixes]:v6 granularity' \
  '-X+[set extension header type to add]:v6 eh' \
  '*:target:_hosts' && ret=0

return ret
