#compdef bcftools-csq
# Documentation: http://www.htslib.org/doc/bcftools.html#csq
# bcftools csq: Haplotype-aware consequence caller

local ret=1

_arguments -s -S \
  '(-B --trim-protein-seq)'{-B,--trim-protein-seq}'[abbreviate protein-changing predictions to maximum of INT aminoacids.]:INT: ' \
  '(-C --genetic-code)'{-C,--genetic-code}'[specify the genetic code table to use, l to print a list of supported]:INT: ' \
  '(-c --custom-tag)'{-c,--custom-tag}'[use this custom tag to store consequences rather than the default BCSQ]:STRING: ' \
  '(--dump-gff)'--dump-gff'[dump the parsed GFF into a gzipped FILE. Intended for debugging purpos]:FILE:_files' \
  '(-e --exclude)'{-e,--exclude}'[exclude sites for which EXPRESSION is true. For valid expressions see]:EXPRESSION: ' \
  '(-f --fasta-ref)'{-f,--fasta-ref}'[reference sequence in fasta format (required)]:FILE:_files' \
  '(--force)'--force'[run even if some sanity checks fail. Currently the option enables skip]' \
  '(-g --gff-annot)'{-g,--gff-annot}'[GFF3 annotation file (required), such as http\://ftp.ensembl.org/pub/cu]:FILE:_files' \
  '(-i --include)'{-i,--include}'[include only sites for which EXPRESSION is true. For valid expressions]:EXPRESSION: ' \
  '(-l --local-csq)'{-l,--local-csq}'[switch off haplotype-aware calling, run localized predictions consider]' \
  '(-n --ncsq)'{-n,--ncsq}'[maximum number of per-haplotype consequences to consider for each site]:INT: ' \
  '(--no-version)'--no-version'[see Common Options]' \
  '(-o --output)'{-o,--output}'[see Common Options]:FILE:_files' \
  '(-O --output-type)'{-O,--output-type}'[see Common Options . In addition, a custom tab-delimited plain text ou]:t: ' \
  '(-p --phase)'{-p,--phase}'[how to handle unphased heterozygous genotypes\: a take GTs as is, creat]:a: ' \
  '(-q --quiet)'{-q,--quiet}'[suppress warning messages]' \
  '(-r --regions)'{-r,--regions}'[see Common Options]:chr: ' \
  '(-R --regions-file)'{-R,--regions-file}'[see Common Options]:FILE:_files' \
  '(--regions-overlap)'--regions-overlap'[see Common Options]:0: ' \
  '(-s --samples)'{-s,--samples}'[samples to include or "-" to apply all variants and ignore samples]:LIST: ' \
  '(-S --samples-file)'{-S,--samples-file}'[see Common Options]:FILE:_files' \
  '(-t --targets)'{-t,--targets}'[see Common Options]:LIST: ' \
  '(-T --targets-file)'{-T,--targets-file}'[see Common Options]:FILE:_files' \
  '(--targets-overlap)'--targets-overlap'[see Common Options]:0: ' \
  '(--unify-chr-names)'--unify-chr-names'[unify chromosome naming by stripping a prefix in VCF, GFF, fasta, resp]:0: ' \
  '(-v --verbosity)'{-v,--verbosity}'[see Common Options]:INT: ' \
  '(-W --write-index)'{-W,--write-index}'[Automatically index the output file. FMT is optional and can be one of]:arg: ' \
  '*:file:_files' && ret=0

return ret
