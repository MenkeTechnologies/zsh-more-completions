#compdef webgen
# Documentation: https://webgen.gettalong.org/documentation/manual.html
# webgen Ruby static website generator

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --directory)'{-d,--directory}'=[website directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:(generate create show render version install help)' \
  '*::arg:_files' && ret=0

return ret
