#compdef dynatrace dt-cli dtcli dynatrace-monitoring-as-code monaco
# _dynatrace — Dynatrace dt-cli and Monaco Monitoring as Code CLI for managing Dynatrace tenant Smartscape entities synthetic monitors dashboards problem alerts management zones via Configuration as Code (dynatrace-oss team, Go); cobra
# upstream: https://github.com/dynatrace-oss/dynatrace-monitoring-as-code

_dynatrace() {
    local -a sub=(
        'convert:convert legacy config'
        'deploy:deploy configs to tenant'
        'delete:delete configs from tenant'
        'download:download tenant configs'
        'purge:purge tenant configs'
        'monitor:Synthetic monitor operations'
        'dashboard:dashboard operations'
        'metric:metric operations'
        'event:event operations'
        'token:token operations'
        'extension:extension operations'
        'log:log operations'
        'entity:entity operations'
        'account:account operations'
        'oauth:OAuth operations'
        'workflow:workflow operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[project]:str:' \
        '--project=+[project]:str:' \
        '--environments=+[file]:file:_files -g "*.yaml *.yml"' \
        '-e+[file]:file:_files -g "*.yaml *.yml"' \
        '--environment=+[env name]:str:' \
        '--group=+[group]:str:' \
        '-d[dry run]' \
        '--dry-run[dry run]' \
        '--continue-on-error[continue on error]' \
        '--no-color[no color]' \
        '--log-format=+[fmt]:f:(text json)' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--manifest=+[file]:file:_files -g "manifest.yaml manifest.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dynatrace subcommand' sub ;;
        args)
            case $words[1] in
                deploy|delete|purge) _arguments \
                    '*:dir or file:_files' ;;
                download) _arguments \
                    '1:action:(configs settings entities)' \
                    '--output-folder=+[dir]:dir:_files -/' \
                    '--specific-environment=+[env]:str:' \
                    '--specific-api=+[apis csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_dynatrace "$@"
