#compdef esl-seqrange
# Documentation: https://man.archlinux.org/search?q=esl-seqrange
# Reference accessed: 2026-05-16

# Easel esl-seqrange: split sequence file by ranges for parallel processing
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--informat[input format]:fmt:(fasta embl genbank uniprot)' \
  '*:sequence file and worker count:_files' && ret=0
return ret
