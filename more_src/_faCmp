#compdef faCmp
# compare two .fa files

local ret=1

_arguments -s -S \
  '-softMask[incorporate soft masking information during comparison]' \
  '-sortName[sort input files by sequence name before comparing]' \
  '-peptide[process files as peptide sequences]' \
  '1:a fa:_files -g "*.(fa|fasta)"' \
  '2:b fa:_files -g "*.(fa|fasta)"' && ret=0

return ret
