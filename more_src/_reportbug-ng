#compdef reportbug-ng
# Documentation: https://man.archlinux.org/search?q=reportbug-ng
# Reference accessed: 2026-05-16

# reportbug-ng: Qt GUI for Debian bug reports
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '*::reportbug-ng args:_files' && ret=0
return ret
