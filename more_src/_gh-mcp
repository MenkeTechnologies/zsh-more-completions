#compdef gh-mcp
# Documentation: https://github.com/github/github-mcp-server
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--toolsets=[comma-separated list of toolsets to enable]:toolsets:' \
  '--dynamic-toolsets[enable dynamic toolset discovery]' \
  '--read-only[run server in read-only mode]' \
  '--gh-host=[GitHub host (Enterprise Server / data residency)]:host:_hosts' \
  '--content-window-size=[max characters returned by file/log tools]:size:' \
  '--lockdown-mode[enable lockdown mode]' \
  '--repo-access-cache-ttl=[repo access cache TTL]:duration:' \
  '--log-file=[path to log file]:file:_files' \
  '*: :_default' && ret=0

return ret
