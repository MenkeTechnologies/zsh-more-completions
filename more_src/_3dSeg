#compdef 3dSeg
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dSeg.html
# Segment an anatomical volume into tissue classes

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-anat[volume to segment]:dataset:_files' \
  '-mask[analysis region (dataset or AUTO)]:mask:' \
  '-blur_meth[blurring method for bias field]:bmeth:(BFT BIM BNN LSB)' \
  '-bias_fwhm[blurring amount for bias field estimation]:fwhm:' \
  '-classes[tissue class labels (semicolon-delimited)]:classes:' \
  '-Bmrf[weight for spatial homogeneity of classes]:bmrf:' \
  '-bias_classes[classes contributing to bias estimation]:classes:' \
  '-prefix[output volume prefix]:prefix:' \
  '-overwrite[overwrite existing files]' \
  '-debug[debug verbosity level]:level:(0 1 2)' \
  '-mixfrac[tissue fraction configuration]:mixfrac:' \
  '-mixfloor[minimum mixing fraction per class]:floor:' \
  '-gold[gold-standard segmentation for comparison]:dataset:_files' \
  '-gold_bias[gold-standard bias volume for comparison]:dataset:_files' \
  '-main_N[number of iterations]:n:' \
  '-cset[initial classification dataset]:dataset:_files' \
  '-labeltable[label table with integer keys]:file:_files' \
  '-vox_debug[debug specific voxel by index or I J K]:vox:' \
  '-vox_debug_file[output file for debug information]:file:_files' \
  '*:dataset:_files' && ret=0

return ret
