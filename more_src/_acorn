#compdef acorn

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'app:manage applications'
  'build:build an Acorn image'
  'check:check installation status'
  'container:manage containers'
  'credential:manage registry credentials'
  'dashboard:open the Acorn dashboard'
  'dev:run app in development mode'
  'exec:exec into a container'
  'fmt:format an Acornfile'
  'image:manage images'
  'info:show Acorn cluster info'
  'install:install Acorn'
  'job:manage jobs'
  'login:log in to a registry'
  'logout:log out from a registry'
  'logs:show app logs'
  'offering:manage offerings'
  'port-forward:forward ports to an app'
  'project:manage projects'
  'pull:pull an image'
  'push:push an image'
  'render:render an Acornfile'
  'rm:remove an app'
  'run:run an application'
  'secret:manage secrets'
  'start:start a stopped app'
  'stop:stop an app'
  'tag:tag an image'
  'uninstall:uninstall Acorn'
  'update:update an app'
  'volume:manage volumes'
  'wait:wait for an app to be ready'
  'version:show version'
  'completion:generate shell completion'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--kubeconfig[kubeconfig path]:config:_files' \
  '--project[target project]:project:' \
  '--debug[enable debug logging]' \
  '--debug-level[debug level]:level:' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'acorn command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (run)
        _arguments \
          {-n,--name}'[app name]:name:' \
          {-f,--file}'[Acornfile path]:file:_files' \
          '--publish/-p[publish ports]:port:' \
          '--volume/-v[bind volumes]:volume:' \
          '--secret/-s[bind secrets]:secret:' \
          '--link/-l[link services]:link:' \
          '--env/-e[set env vars]:key=value:' \
          '--region[deploy region]:region:' \
          '--compute-class[compute class]:class:' \
          '--memory[memory limit]:memory:' \
          '--auto-upgrade[enable auto-upgrade]' \
          '*:image:' && ret=0
        ;;
      (build)
        _arguments \
          {-f,--file}'[Acornfile path]:file:_files' \
          {-t,--tag}'[image tag]:tag:' \
          '--push[push after build]' \
          '--platform[target platform]:platform:' \
          '*:context:_directories' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
