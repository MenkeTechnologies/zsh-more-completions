#compdef 3dLocalstat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLocalstat.html
# AFNI: compute statistics in a neighborhood around each voxel

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-nbhd[neighborhood definition string]:nbhd:' \
  '*-stat[statistic to compute]:stat:(mean stdev var cvar median MAD min max absmax num sum FWHM ALL)' \
  '-mask[mask dataset]:mask:_files' \
  '-automask[create mask from input]' \
  '-use_nonmask[also process voxels outside mask]' \
  '-prefix[output dataset prefix]:prefix:_files' \
  '-datum[output data type]:datum:(byte short float)' \
  '-label_ext[label extension string]:ext:' \
  '-reduce_grid[reduce output grid (Rx [Ry Rz])]:factors:' \
  '-reduce_restore_grid[reduce then restore grid]:factors:' \
  '-reduce_max_vox[reduce if voxels exceed max]:max:' \
  '-grid_rmode[resampling mode for restore]:mode:(NN Li Cu Bk)' \
  '-quiet[suppress progress messages]' \
  '-verb[verbose output]' \
  '-proceed_small_N[proceed with small neighborhoods]' \
  '-fillvalue[fill value for empty neighborhoods]:val:' \
  '-unfillvalue[value treated as unfilled]:val:' \
  '-maskvalue[value treated as masked]:val:' \
  '-maskvalue2[second value treated as masked]:val:' \
  '*:dataset:_files' && ret=0

return ret
