#compdef vagrant-cli
# _vagrant-cli — HashiCorp Vagrant dev environment CLI alias (HashiCorp, Ruby); custom argparse
# upstream: https://github.com/hashicorp/vagrant

_vagrant-cli() {
    local -a sub=(
        'autocomplete:autocomplete commands'
        'box:manage boxes'
        'cap:list/run vagrant capabilities'
        'cloud:Vagrant Cloud commands'
        'destroy:stop and delete VMs'
        'global-status:status of vagrant environments for this user'
        'halt:gracefully shutdown machine'
        'help:show help'
        'init:create Vagrantfile'
        'login:authenticate to Vagrant Cloud'
        'package:package running VM into reusable box'
        'plugin:manage plugins'
        'port:show port mappings'
        'powershell:connect via PowerShell'
        'provision:run provisioners'
        'push:push to configured destination'
        'rdp:connect via RDP'
        'reload:restart machine'
        'resume:resume suspended VM'
        'serve:start vagrant-go server'
        'snapshot:manage snapshots'
        'ssh:ssh into VM'
        'ssh-config:show ssh config'
        'status:show machine status'
        'suspend:suspend VM'
        'up:start machine'
        'upload:upload to VM'
        'validate:validate Vagrantfile'
        'version:show version'
        'winrm:winrm into VM'
        'winrm-config:show winrm config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug logging]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '--machine-readable[machine-readable output]' \
        '--timestamp[timestamp]' \
        '--debug-timestamp[debug timestamp]' \
        '--no-tty[no tty]' \
        '--no-parallel[no parallel]' \
        '--parallel[parallel]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vagrant subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '--provider=+[provider]:p:(virtualbox libvirt vmware_desktop hyperv docker parallels lxc)' \
                    '--no-provision[no provision]' \
                    '--provision[provision]' \
                    '--provision-with=+[provisioners]:list:' \
                    '--destroy-on-error[destroy on error]' \
                    '--parallel[parallel]' \
                    '--install-provider[install provider]' \
                    '--no-install-provider[no install provider]' \
                    '*:vm:' ;;
                box) _arguments \
                    '1:cmd:(add list outdated prune remove repackage update)' \
                    '*:arg:' ;;
                ssh) _arguments \
                    '-c+[command]:str:' \
                    '--command=+[command]:str:' \
                    '-p[plain mode]' \
                    '--plain[plain mode]' \
                    '*:vm:' ;;
                plugin) _arguments \
                    '1:cmd:(expunge install license list repair uninstall update)' \
                    '*:arg:' ;;
                snapshot) _arguments \
                    '1:cmd:(delete list pop push restore save)' \
                    '*:arg:' ;;
                cloud) _arguments \
                    '1:cmd:(auth box organization provider publish search)' \
                    '*:arg:' ;;
                destroy|halt|reload|suspend|resume|provision|status|validate|init) _arguments '*:vm:' ;;
            esac
            ;;
    esac
}

_vagrant-cli "$@"
