#compdef virt-controller
# _virt-controller — KubeVirt controller manager (kubevirt/kubevirt)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from pkg/virt-controller/watch/application.go + pkg/service/service.go on tip.

_virt-controller() {
    _arguments \
        '--listen=[bind address]:ip:' \
        '--port=[bind port]:port:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--launcher-image=[virt-launcher container image]:image:' \
        '--exporter-image=[virt-exportserver container image]:image:' \
        '--launcher-qemu-timeout=[qemu start timeout (seconds)]:n:' \
        '--image-pull-secret=[image pull secret name]:name:' \
        '--kubevirt-share-dir=[host shared dir]:dir:_files -/' \
        '--ephemeral-disk-dir=[ephemeral disk dir]:dir:_files -/' \
        '--container-disk-dir=[container disk dir]:dir:_files -/' \
        '--hotplug-disk-dir=[hotplug disk dir]:dir:_files -/' \
        '--node-controller-threads=[node controller workers]:n:' \
        '--vmi-controller-threads=[VMI controller workers]:n:' \
        '--rs-controller-threads=[VMI replicaset workers]:n:' \
        '--pool-controller-threads=[VMI pool workers]:n:' \
        '--vm-controller-threads=[VM controller workers]:n:' \
        '--migration-controller-threads=[migration workers]:n:' \
        '--evacuation-controller-threads=[evacuation workers]:n:' \
        '--disruption-budget-controller-threads=[PDB workers]:n:' \
        '--launcher-subgid=[virt-launcher sub-GID base]:n:' \
        '--snapshot-controller-threads=[snapshot workers]:n:' \
        '--restore-controller-threads=[restore workers]:n:' \
        '--export-controller-threads=[export workers]:n:' \
        '--snapshot-controller-resync-period=[snapshot resync interval]:dur:' \
        '--node-topology-update-period=[node topology refresh]:dur:' \
        '--prom-cert-file=[Prometheus TLS cert]:file:_files' \
        '--prom-key-file=[Prometheus TLS key]:file:_files' \
        '--clone-controller-threads=[clone workers]:n:' \
        '*--additional-launcher-annotations-sync=[extra annotation keys synced to launcher]:keys:' \
        '*--additional-launcher-labels-sync=[extra label keys synced to launcher]:keys:' \
        '--backup-controller-threads=[backup workers]:n:'
}

_virt-controller "$@"
