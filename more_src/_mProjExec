#compdef mProjExec
# Documentation: https://irsa.ipac.caltech.edu/Montage/docs/mProjExec.html
# Reproject a set of images listed in a metadata table

local ret=1

_arguments -s -S \
  '-p+[directory containing images to reproject]:rawdir:_files -/' \
  '-d[enable debugging]' \
  '-e[output matches header template exactly without cropping]' \
  '-X[reproject entire images even if exceeding template area]' \
  '-b+[ignore pixel-width border around image edges]:border' \
  '-r+[restart processing at record number]:restartrec' \
  '-s+[write output/errors to status file]:statusfile:_files' \
  '-x+[flux rescaling metadata column]:scaleColumn' \
  '1:images table:_files -g "*.tbl"' \
  '2:header template:_files' \
  '3:projection directory:_files -/' \
  '4:stats table:_files -g "*.tbl"' && ret=0

return ret
