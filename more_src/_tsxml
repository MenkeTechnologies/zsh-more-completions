#compdef tsxml
# Documentation: https://github.com/tsduck/tsduck/blob/master/src/tstools/tsxml.cpp
# tsxml - manipulate, validate and transform XML files (TSDuck format)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--attributes-merge=[with --merge, how attributes are processed]:mode:(add none replace)' \
  '(-c --channel)'{-c,--channel}'[shortcut to verify channel configuration files]' \
  '(-e --expand-environment)'{-e,--expand-environment}'[expand environment variables in input XML]' \
  '--expand-patch-xml[expand environment variables in patch files]' \
  '(-f --from-json)'{-f,--from-json}'[convert from JSON to XML first]' \
  '--hf-band[shortcut to verify HF bands files]' \
  '(-i --indent)'{-i,--indent}'=[output indentation size (default 2)]:n:' \
  '(-l --lnb)'{-l,--lnb}'[shortcut to verify satellite LNB files]' \
  '--merge[merge all input files as one]' \
  '(-m --model)'{-m,--model}'=[XML model file for validation]:file:_files' \
  '--monitor[shortcut to verify monitoring configs]' \
  '(-o --output)'{-o,--output}'=[output file or directory]:file:_files' \
  '*'{-p,--patch}'=[XML patch file to apply]:file:_files' \
  '(-r --reformat)'{-r,--reformat}'[reformat XML per TSDuck conventions]' \
  '*'{-s,--sort}'=[sort sub-elements of tag name]:tag:' \
  '(-t --tables)'{-t,--tables}'[use PSI/SI table model with extensions]' \
  '--uncomment[remove comments from XML documents]' \
  '--xml-line=[log tables as single XML lines with prefix]:prefix:' \
  '(-y --yaml)'{-y,--yaml}'[convert XML to YAML format]' \
  '--no-yaml-header[omit standard YAML header and trailer]' \
  '*:xml file:_files -g "*.xml *.json"' && ret=0

return ret
