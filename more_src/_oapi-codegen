#compdef oapi-codegen

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-config[configuration file]:file:_files' \
  '-generate[what to generate]:items' \
  '-import-mapping[import mapping]:mapping' \
  '-include-tags[include only these tags]:tags' \
  '-exclude-tags[exclude these tags]:tags' \
  '-include-schemas[include only these schemas]:schemas' \
  '-exclude-schemas[exclude these schemas]:schemas' \
  '-templates[custom templates directory]:directory:_directories' \
  '-o[output file]:file:_files' \
  '-package[output package name]:name' \
  '-response-type-suffix[suffix for response types]:suffix' \
  '-compatibility[compatibility options]:options' \
  '-output-config[output configuration]' \
  '-version[show version]' \
  '-help[show help]' \
  '*:spec file:_files' && ret=0
return ret
