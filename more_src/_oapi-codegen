#compdef oapi-codegen
# Documentation: https://github.com/oapi-codegen/oapi-codegen
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-o[output file location]:file:_files' \
  '-old-config-style[use the older style config file format]' \
  '-output-config[output a configuration file using current settings]' \
  '-config[YAML config file]:file:_files -g "*.{yaml,yml}"' \
  '-version[print version and exit]' \
  '-package[package name for generated code]:name:' \
  '-help[show help]' \
  '-h[show help]' \
  '-generate[comma-separated list of code to generate]:items:' \
  '-include-tags[only include operations with given tags]:tags:' \
  '-exclude-tags[exclude operations tagged with given tags]:tags:' \
  '-include-operation-ids[only include operations with given operation-ids]:ids:' \
  '-exclude-operation-ids[exclude operations with given operation-ids]:ids:' \
  '-templates[directory containing user templates]:directory:_directories' \
  '-import-mapping[external reference to Go package path mapping]:mapping:' \
  '-exclude-schemas[schemas to exclude from generation]:schemas:' \
  '-response-type-suffix[suffix for response types]:suffix:' \
  '-alias-types[alias type declarations if possible]' \
  '*:spec file:_files -g "*.{yaml,yml,json}"' && ret=0
return ret
