#compdef casr-java
# Documentation: https://github.com/ispras/casr/blob/master/docs/usage.md
# Create CASR reports from Java crashes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-o --output)'{-o,--output}'=[path to save report]:report:_files' \
  '--stdout[print CASR report to stdout]' \
  '--stdin=[stdin file for program]:file:_files' \
  '*--source-dirs=[paths to directories with Java source files]:dir:_files -/' \
  '(-t --timeout)'{-t,--timeout}'=[timeout for target execution in seconds]:seconds' \
  '--ignore=[file with regex for ignored functions/paths]:file:_files' \
  '--strip-path=[path prefix to strip from stacktrace]:prefix' \
  '*--ld-preload=[set LD_PRELOAD for target program]:libs:_files' \
  '*::args:_normal' && ret=0

return ret
