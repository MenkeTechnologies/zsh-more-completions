#compdef anthropic
# Documentation: https://man.archlinux.org/search?q=anthropic
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:login/logout/configure Anthropic credentials'
  'messages:send/list message API requests'
  'completion:legacy completion endpoint'
  'models:list available models'
  'beta:beta endpoints'
  'tools:tool registry'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--api-key=[Anthropic API key]:key:' \
  '--base-url=[API base URL]:url:' \
  '--anthropic-version=[API version header]:date:' \
  '--anthropic-beta=[beta header value]:beta:' \
  '--profile=[CLI profile name]:profile:' \
  '--debug[debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'anthropic command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (messages)
        _arguments \
          '--model=[model id]:model:(claude-opus-4-7 claude-sonnet-4-6 claude-haiku-4-5-20251001 claude-3-5-sonnet-latest claude-3-5-haiku-latest claude-3-opus-latest)' \
          '--system=[system prompt]:prompt:' \
          '--max-tokens=[max output tokens]:n:' \
          '--temperature=[sampling temperature]:f:' \
          '--top-p=[top-p sampling]:f:' \
          '--top-k=[top-k sampling]:n:' \
          '*--message=[user message]:msg:' \
          '*--tool=[tool JSON spec]:json:' \
          '--stream[stream response]' \
          '--stop-sequences=[stop sequences (comma-separated)]:seqs:' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout status configure)' && ret=0 ;;
      (models)
        _arguments '*::sub:(list get)' && ret=0 ;;
      (beta)
        _arguments '*::sub:(messages tools)' && ret=0 ;;
      (tools)
        _arguments '*::sub:(list add remove)' && ret=0 ;;
    esac ;;
esac

return ret
