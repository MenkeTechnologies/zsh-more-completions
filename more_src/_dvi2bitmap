#compdef dvi2bitmap
# Documentation: https://man.archlinux.org/search?q=dvi2bitmap
# Reference accessed: 2026-05-16

# dvi2bitmap: render TeX DVI directly to bitmap image
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-o[output filename]:file:_files' \
  '-fp[font path]:dir:_files -/' \
  '-fs[font search]:dirs:' \
  '-mfmode[Metafont mode]:mode:' \
  '-r[resolution in dpi]:dpi:' \
  '-bg[background colour]:colour:' \
  '-fg[foreground colour]:colour:' \
  '-process[output single page]' \
  '-png[force PNG output]' \
  '-pbm[force PBM output]' \
  '-Vmag[magnification]:val:' \
  '-Q[quiet mode]' \
  '-bitmap[bitmap format]:fmt:' \
  '*:DVI file:_files -g "*.dvi"' && ret=0
return ret
