#compdef dnscan
# Documentation: https://man.archlinux.org/search?q=dnscan
# Reference accessed: 2026-05-16

_arguments -s \
  '(-d --domain)'{-d,--domain}'=[target domain]:domain:' \
  '(-l --list)'{-l,--list}'=[domain list]:file:_files' \
  '(-w --wordlist)'{-w,--wordlist}'=[wordlist]:file:_files' \
  '(-t --threads)'{-t,--threads}'=[threads]:n:' \
  '(-6 --ipv6)'{-6,--ipv6}'[scan AAAA]' \
  '(-z --zonetransfer)'{-z,--zonetransfer}'[zone transfer]' \
  '(-r --recursive)'{-r,--recursive}'[recursive]' \
  '--recurse-wildcards[recurse wildcards]' \
  '(-m --maxdepth)'{-m,--maxdepth}'=[max depth]:n:' \
  '(-a --alterations)'{-a,--alterations}'[scan alterations]' \
  '(-R --resolver)'{-R,--resolver}'=[resolver IP]:ip:' \
  '(-L --resolver-list)'{-L,--resolver-list}'=[resolver list]:file:_files' \
  '(-T --tld)'{-T,--tld}'[scan all TLDs]' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-i --output-ips)'{-i,--output-ips}'=[IPs output]:file:_files' \
  '(-n --nocheck)'{-n,--nocheck}'[no nameserver check]' \
  '(-q --quick)'{-q,--quick}'[quick]' \
  '(-N --no-ip)'{-N,--no-ip}'[no IPs in output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]'
