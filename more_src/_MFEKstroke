#compdef MFEKstroke
# Documentation: https://github.com/MFEK/stroke
# MFEK path stroking utility for UFO .glif glyphs

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '1:algorithm:(PAP VWS CWS DASH NIB help)' \
  '*::args:_files' && ret=0

return ret
