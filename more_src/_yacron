#compdef yacron
# Documentation: https://man.archlinux.org/search?q=yacron
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c+,--config=}'[config file or directory]:path:_files' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '--validate[validate config and exit]' \
  '--dry-run[parse config but do not run jobs]' \
  '--web-config=[web admin config file]:file:_files -g "*.{yaml,yml}"' \
  '*::passthrough:' && ret=0

return ret
