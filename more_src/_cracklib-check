#compdef cracklib-check
# Documentation: man cracklib-check(8)
# Source: cracklib/cracklib src/util/check.c (main) — password quality check from stdin (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '(-h --help)'{-h,--help}'[show help]' \
    '--no-echo[do not echo plaintext to terminal]' \
    '1::dictionary path:_files' \
    && ret=0

return ret
