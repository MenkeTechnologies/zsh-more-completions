#compdef iox
# Documentation: https://github.com/EddieIvan01/iox/blob/master/README.md
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'fwd:port forwarding'
  'proxy:socks5 proxy'
)

_arguments -C \
  '(- *)'{-h}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'iox subcommand' subcommands && ret=0 ;;
  (args)
    _arguments -s \
      '*-l[local listen address]:host\:port:' \
      '*-r[remote address]:host\:port:' \
      '-k[pre-shared key hex]:hex:' \
      '-u[UDP forward]' \
      '-t[timeout ms]:ms:' \
      '-v[verbose]' \
      '-h[help]' && ret=0 ;;
esac

return ret
