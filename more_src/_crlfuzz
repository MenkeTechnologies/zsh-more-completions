#compdef crlfuzz

_arguments -s \
  '(-u --url)'{-u,--url}'=[single URL]:url:' \
  '(-l --list)'{-l,--list}'=[URL list file]:file:_files' \
  '(-X --method)'{-X,--method}'=[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-d --data)'{-d,--data}'=[request body]:data:' \
  '*'{-H,--header}'=[custom header]:header:' \
  '(-x --proxy)'{-x,--proxy}'=[proxy URL]:url:' \
  '(-c --concurrent)'{-c,--concurrent}'=[concurrency]:n:' \
  '(-s --silent)'{-s,--silent}'[silent]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]'
