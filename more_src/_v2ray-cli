#compdef v2ray-cli v2ray
# _v2ray-cli — V2Ray V2Fly versatile network utility for proxying CLI alias (v2fly team, Go); custom argparse
# upstream: https://github.com/v2fly/v2ray-core

_v2ray-cli() {
    local -a sub=(
        'run:run V2Ray with config'
        'version:show version'
        'help:show help'
        'api:open API operations'
        'api stats:show stats'
        'api statsquery:query stats'
        'api restartlogger:restart logger'
        'api inbounds add:add inbound'
        'api inbounds remove:remove inbound'
        'api outbounds add:add outbound'
        'api outbounds remove:remove outbound'
        'api routing add:add routing rule'
        'api stats getstats:get stats'
        'convert:convert configs'
        'fmt:format config files'
        'load:load test config'
        'test:test config'
        'uuid:generate UUID'
        'completion:generate completion'
        'tls:tls commands'
        'tls ping:ping tls server'
        'tls cert:create self-signed cert'
        'verify:verify config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-config=+[config file]:file:_files -g "*.{json,toml,yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{json,toml,yaml,yml}"' \
        '-confdir=+[config dir]:dir:_files -/' \
        '-format=+[format]:f:(json jsonv5 toml yaml yml)' \
        '-test[test config]' \
        '-plugin[plugin mode]' \
        '-dump[dump config]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'v2ray subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                run|test) _arguments \
                    '-c+[config file]:file:_files' \
                    '-config=+[config file]:file:_files' \
                    '-d+[config dir]:dir:_files -/' \
                    '-confdir=+[config dir]:dir:_files -/' \
                    '-format=+[format]:f:(json jsonv5 toml yaml yml)' \
                    '-r[recursive load]' ;;
            esac
            ;;
    esac
}

_v2ray-cli "$@"
