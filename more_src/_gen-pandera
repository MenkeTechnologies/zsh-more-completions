#compdef gen-pandera
# _gen-pandera — generate Pandera DataFrameModels from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/panderagen/panderagen.py (click).

_gen-pandera() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.py"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(python pandera)'
        '--package=[Python package name for generated module files]:package:'
        '--template-path=[Jinja2 template directory within module (incompatible with --package)]:dir:_files -/'
        '--template-file=[Jinja2 template file (incompatible with --package)]:file:_files'
        '--generator-class=[fully-qualified Python class to use as the generator]:class:'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-pandera "$@"
