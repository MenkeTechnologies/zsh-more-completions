autoload -U is-at-least

_edtr() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-E+[Bypass rules, force editor]:NAME:_default' \
'--editor=[Bypass rules, force editor]:NAME:_default' \
'-G+[Bypass rules, force group]:NAME:_default' \
'--group=[Bypass rules, force group]:NAME:_default' \
'--dry-run[Resolve rules and log decisions without dispatching]' \
'*-v[Increase log verbosity (-v, -vv)]' \
'*--verbose[Increase log verbosity (-v, -vv)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::files -- Files to dispatch (no subcommand = default dispatch):_files' \
":: :_edtr_commands" \
"*::: :->edtr" \
&& ret=0
    case $state in
    (edtr)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:edtr-command-$line[2]:"
        case $line[2] in
            (list)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'--alive-only[Only show instances that respond to ping]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'()--all[Kill every known instance]' \
'-h[Print help]' \
'--help[Print help]' \
'::group:_default' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
":: :_edtr__subcmd__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:edtr-config-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'--resolved[Show templates fully resolved using an empty file context]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_edtr__subcmd__config__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:edtr-config-help-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
'-c+[Override config path]:PATH:_files' \
'--config=[Override config path]:PATH:_files' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_edtr__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:edtr-help-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(doctor)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(config)
_arguments "${_arguments_options[@]}" : \
":: :_edtr__subcmd__help__subcmd__config_commands" \
"*::: :->config" \
&& ret=0

    case $state in
    (config)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:edtr-help-config-command-$line[1]:"
        case $line[1] in
            (path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(edit)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_edtr_commands] )) ||
_edtr_commands() {
    local commands; commands=(
'list:List alive editor instances' \
'kill:Terminate editor instance(s) by group' \
'check:Dry-run\: show which rule matches each file without dispatching' \
'doctor:Inspect the config for common footguns (unreachable rules, uncovered paths, …)' \
'config:Inspect or edit the config file' \
'completion:Generate shell completion script' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'edtr commands' commands "$@"
}
(( $+functions[_edtr__subcmd__check_commands] )) ||
_edtr__subcmd__check_commands() {
    local commands; commands=()
    _describe -t commands 'edtr check commands' commands "$@"
}
