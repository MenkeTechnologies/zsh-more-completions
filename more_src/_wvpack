#compdef wvpack wavpack
# Documentation: https://manpages.debian.org/bookworm/wavpack/wavpack.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above + man/wavpack.1 in dbry/WavPack.
# Short flags from manpage:
#   -a, -b<n>, -c, -cc, -d, -f, -g, -h, -hh, -i, -j<n>, -m, -n,
#   -o <outfile>, -q, -r, -s<n>, -t, -v, -w (encoder/settings/tag),
#   -x[n], -y, -z[n].
# Long flags: --help, --version, --allow-huge-tags, --blocksize=n,
#   --channel-order=list, --cross-decorr, --force-even-byte-depth,
#   --import-id3, --merge-blocks, --no-overwrite, --no-threads,
#   --no-utf8-convert, --optimize-int32, --pair-unassigned-chans,
#   --pre-quantize=bits, --raw-pcm, --raw-pcm=..., --raw-pcm-skip,
#   --threads=n, --use-dns, --write-binary-tag.
# Removed from prior file: -h conflict (-h is high quality, --help is help),
#   -k (no such flag), -l (no such flag - low priority bogus),
#   -p (lossy proxy mode - not in manpage), -s mode list (real -s is
#   noise shaping n, not s/j/m), wma/m4a in input glob.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[display extended help]' \
  '--version[show version]' \
  '-a[Adobe Audition mode for 32-bit floats]' \
  '-b+[hybrid compression bitrate n]:rate:' \
  '-c[create correction file (.wvc) for hybrid mode]' \
  '-cc[maximum hybrid compression]' \
  '-d[delete source file if successful]' \
  '-f[fast mode]' \
  '-g[general/normal mode]' \
  '-h[high quality compression]' \
  '-hh[very high quality compression]' \
  '-i[ignore length in wav header (>4GB)]' \
  '-j+[joint-stereo override n]:n:' \
  '-m[compute and store MD5 of raw audio]' \
  '-n[calculate average/peak quantization noise]' \
  '-o+[output filename or directory]:path:_files' \
  '-q[quiet]' \
  '-r[parse headers without storing them]' \
  '-s+[override hybrid noise shaping]:n:' \
  '-t[copy input timestamp to output]' \
  '-v[verify output file integrity]' \
  '*-w+[write APEv2 metadata (Encoder|Settings|Field=Value|Field=@file)]:tag:' \
  '-x+[extra encode processing 0..6]:n:' \
  '-y[yes to all warnings]' \
  '-z+[set/dont set console title]:n:' \
  '--allow-huge-tags[allow tag data up to 16 MB]' \
  '--blocksize=[block size in samples]:n:' \
  '--channel-order=[comma separated channel order]:list:' \
  '--cross-decorr[use cross-channel correlation in hybrid mode]' \
  '--force-even-byte-depth[round bit depth up to next whole byte]' \
  '--import-id3[import items from ID3v2 tag]' \
  '--merge-blocks[merge consecutive blocks with equal redundancy]' \
  '--no-overwrite[never overwrite an existing file]' \
  '--no-threads[force single-threaded]' \
  '--no-utf8-convert[do not recode tags from local encoding to UTF-8]' \
  '--optimize-int32[optimize 32-bit integer audio]' \
  '--pair-unassigned-chans[encode unassigned channels into stereo pairs]' \
  '--pre-quantize=[pre-quantize to N bits]:bits:' \
  '--raw-pcm[input is raw PCM 44100/16/2]' \
  '--raw-pcm-skip=[skip bytes before/after raw PCM (begin[,end])]:bytes:' \
  '--threads=[multithreaded operation 1..12]:n:' \
  '--use-dns[force use of dynamic noise shaping]' \
  '--write-binary-tag=[write binary metadata Field=@file]:tag:' \
  '*:file:_files -g "*.{wav,bwf,w64,aif,aiff,caf,dff,dsf,flac,wv}"' && ret=0

return ret
