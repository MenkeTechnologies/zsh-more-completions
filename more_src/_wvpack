#compdef wvpack wavpack

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--version[show version]' \
  '-a[Adobe Audition extensible WAV]' \
  '-b+[bitrate]:rate:' \
  '-c[create correction file]' \
  '-d[delete source after success]' \
  '-f[fast (worse) compression]' \
  '-h[high quality (slow)]' \
  '-hh[very high quality (slower)]' \
  '-i[ignore header errors]' \
  '-j+[joint stereo override]:mode:(0 1)' \
  '-k+[size limit MB]:mb:' \
  '-l[low priority]' \
  '-m[md5 hash]' \
  '-n[no audio decoded - just stats]' \
  '-o+[output dir or file]:path:_files' \
  '-p[lossy proxy mode]' \
  '-q[quiet]' \
  '-r[remove redundancy in correction]' \
  '-s+[stereo override]:mode:(s j m)' \
  '-t[copy file modification time]' \
  '-v[verify after encoding]' \
  '-w+[metadata write tag=value]:tag:' \
  '-x+[hybrid noise mode]:mode:' \
  '-y[yes - overwrite]' \
  '-z+[zero margin pad]:n:' \
  '*:file:_files -g "*.{wav,bwf,w64,aif,aiff,caf,dff,dsf,flac,m4a,wma,wv,wma}"' && ret=0

return ret
