#compdef succfilt
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/succfilt.c
# FX domain Correlation Coefficient FILTER

local ret=1

_arguments -s -S \
  'cch=[cch]:cch:' \
  'ccl=[ccl]:ccl:' \
  'key=[key]:key:' \
  'padd=[padd]:padd:' \
  'dir=[dir]:dir:' \
  'verbose=[verbose]:verbose:' \
  '*:file:_files' && ret=0

return ret
