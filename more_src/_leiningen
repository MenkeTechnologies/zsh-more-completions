#compdef lein

# Zsh completion for Leiningen (Clojure build tool)

_leiningen() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'change:rewrite project.clj with f applied to the value at key-or-path'
    'check:check syntax and warn on reflection'
    'classpath:print the classpath of the project'
    'clean:remove all files from project target paths'
    'compile:compile Clojure source into .class files'
    'deploy:build and deploy jar to remote repository'
    'deps:download all dependencies'
    'do:higher-order task to perform other tasks in succession'
    'help:display a list of tasks or help for a given task'
    'install:install jar and pom to the local repository'
    'jar:package up all the project files into a jar file'
    'javac:compile Java source files'
    'new:generate project scaffolding based on a template'
    'plugin:DEPRECATED - use the :user profile instead'
    'pom:write a pom.xml file to disk for Maven interoperability'
    'release:perform a release'
    'repl:start a REPL session'
    'run:run a -main function with optional command-line arguments'
    'search:search Central and Clojars for published artifacts'
    'show-profiles:list all available profiles'
    'test:run the project tests'
    'trampoline:run a task without nesting the project JVM'
    'uberjar:package up the project files and dependencies into a jar file'
    'update-in:perform arbitrary transformations on your project map'
    'upgrade:upgrade Leiningen to specified version or latest stable'
    'vcs:interact with the version control system'
    'version:print Leiningen version'
    'with-profile:apply the given task with the profile(s) specified'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'lein command' commands && ret=0
      ;;
    (args)
      case ${words[1]} in
        new)
          _arguments -s -S \
            '--to-dir=[target directory]:directory:_files -/' \
            '--force[force project creation]' \
            '--snapshot[use snapshot template]' \
            '1:template:(app default compojure luminus reagent re-frame figwheel-main shadow-cljs fulcro template)' \
            '2:project name:' \
            && ret=0
          ;;
        run)
          _arguments -s -S \
            '-m+[main namespace]:namespace:' \
            '*:arguments:' \
            && ret=0
          ;;
        repl)
          _arguments -s -S \
            ':connect[connect to running nREPL server]' \
            '--port=[port for nREPL server]:port:' \
            '--host=[host for nREPL server]:host:_hosts' \
            && ret=0
          ;;
        test)
          _arguments -s -S \
            '--focus=[focus on specific test]:test:' \
            '*:test namespaces:' \
            && ret=0
          ;;
        deploy)
          _arguments -s -S \
            '1:repository:(clojars releases snapshots)' \
            && ret=0
          ;;
        deps)
          _arguments -s -S \
            ':tree[show dependency tree]' \
            '--suggest[suggest newer versions]' \
            && ret=0
          ;;
        with-profile)
          _arguments -s -S \
            '1:profiles:' \
            '2:task:' \
            '*:args:' \
            && ret=0
          ;;
        release)
          _arguments -s -S \
            '1:level:(major minor patch)' \
            && ret=0
          ;;
        vcs)
          _arguments -s -S \
            '1:subcommand:(assert-committed tag push)' \
            && ret=0
          ;;
        upgrade)
          _arguments -s -S \
            '1:version:' \
            && ret=0
          ;;
        *)
          _arguments -s -S \
            '--help[display help]' \
            && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_leiningen "$@"
