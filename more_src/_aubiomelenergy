#compdef aubiomelenergy
# Documentation: https://aubio.org/manual/latest/cli.html
# Reference accessed: 2026-06-21
# Verified: shared aubio CLI options at the URL above.

# aubiomelenergy: compute mel-band energy of an audio file
local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose]' \
  '-q[quiet]' \
  '-i[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '--input=[input file]:file:_files -g "*.(wav|aif|aiff|flac|ogg|mp3|m4a)"' \
  '-r[sample rate]:rate:' \
  '--samplerate=[sample rate]:rate:' \
  '-B[buffer size]:n:' \
  '--bufsize=[buffer size]:n:' \
  '-H[hop size]:n:' \
  '--hopsize=[hop size]:n:' \
  '*::aubiomelenergy args:_files' && ret=0

return ret
