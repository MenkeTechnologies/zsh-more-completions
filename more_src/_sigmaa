#compdef sigmaa
# Documentation: https://www.ccp4.ac.uk/html/sigmaa.html
# CCP4: compute SigmaA values and weighted map coefficients

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'HKLIN[input MTZ reflection file]:mtz:_files -g "*.mtz"' \
  'HKLOUT[output MTZ reflection file]:mtz:_files' \
  '*:keyword:(COMBINE PARTIAL LABIN LABOUT RESOLUTION RANGES ERROR SIGMAA SYMMETRY TITLE END)' && ret=0

return ret
