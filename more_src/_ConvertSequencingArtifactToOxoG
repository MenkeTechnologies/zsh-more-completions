#compdef ConvertSequencingArtifactToOxoG
# Documentation: https://broadinstitute.github.io/picard/command-line-overview.html#ConvertSequencingArtifactToOxoG
# Picard: extract OxoG metrics from generalized sequencing artifact metrics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[display program version]' \
  {-I=,--INPUT_BASE=}'[basename of the input artifact metrics file]:basename:' \
  {-O=,--OUTPUT_BASE=}'[basename for the output OxoG metrics file]:basename:' \
  {-R=,--REFERENCE_SEQUENCE=}'[reference sequence fasta file]:fasta:_files -g "*.(fa|fasta)"' \
  '--PRE_ADAPTER_IN=[pre-adapter details input file]:file:_files' \
  '--BAIT_BIAS_IN=[bait bias input file]:file:_files' \
  '--OXOG_OUT=[output OxoG metrics file]:file:_files' \
  '--TMP_DIR=[temporary directory]:dir:_files -/' \
  '--VALIDATION_STRINGENCY=[validation stringency]:level:(STRICT LENIENT SILENT)' \
  '--VERBOSITY=[log level]:level:(ERROR WARNING INFO DEBUG)' \
  '*:argument:_files' && ret=0

return ret
