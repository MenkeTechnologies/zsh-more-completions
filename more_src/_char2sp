#compdef char2sp
# Documentation: http://tdc-www.harvard.edu/software/wcstools/
# char2sp: replace a character with spaces in strings (WCSTools)

local ret=1

_arguments -s -S \
  '-s[replace this character with spaces in output]:char' \
  '-v[verbose]' \
  '*:string:_message string' && ret=0

return ret
