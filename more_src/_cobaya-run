#compdef cobaya-run
# Documentation: https://cobaya.readthedocs.io/en/latest/run.html
# cobaya: run a sampler on an input file

local ret=1

_arguments -s -S \
  '(-p --packages-path)'{-p,--packages-path}'=[path where external packages were installed]:path:_files -/' \
  '(-o --output)'{-o,--output}'=[path and prefix for the text output]:path:_files' \
  '(-d --debug)'{-d,--debug}'[produce verbose debug output]' \
  '(-r --resume -f --force)'{-r,--resume}'[resume an existing chain if it has similar info]' \
  '(-f --force -r --resume)'{-f,--force}'[overwrite previous output if it exists]' \
  '--test[initialize model and sampler, and exit]' \
  '(-M --minimize)'{-M,--minimize}'[replace the sampler and run a minimization process]' \
  '--allow-changes[allow changing input parameters when resuming or minimizing]' \
  '--no-mpi[disable MPI when mpi4py installed but MPI does not work]' \
  '--version[show version information]' \
  '1:input file:_files -g "*.yaml"' && ret=0

return ret
