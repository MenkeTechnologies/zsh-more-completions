#compdef agentworkforce
# Documentation: https://github.com/AgentWorkforce/workforce/blob/main/packages/cli/README.md
# Reference accessed: 2026-05-22
# Verified: upstream packages/cli/README.md command reference.

# Zsh completion for agentworkforce - persona harness launcher CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--install-in-repo[install skills in current repo]' \
  '--no-launch-metadata[omit launch metadata]' \
  '--clean[clean launch environment]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'agentworkforce command' \
      'create[open persona-maker to author a persona]' \
      'agent[run persona harness session]' \
      'list[list persona catalog]' \
      'show[show resolved persona spec]' \
      'install[install persona pack into project]' \
      'sources[manage persona source directories]' \
      'harness[probe installed harness binaries]' \
      'destroy[tear down deployed cloud agent]' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments \
          '--save-in-directory[target persona directory]:directory:_directories' \
          '--save-default[persist default create target]' && ret=0
        ;;
      agent)
        _arguments '1:persona[@tier]:' '*:task:' && ret=0
        ;;
      list)
        _arguments \
          '--all[show every tier of every persona]' \
          '--recommended[show recommended tier per intent]' \
          '--filter-rating[tier filter]:rating:(best best-value minimum)' \
          '--filter-harness[harness filter]:harness:(claude codex opencode)' \
          '--no-display-description[hide description column]' \
          '--json[JSON output]' && ret=0
        ;;
      show)
        _arguments '1:persona[@tier]:' && ret=0
        ;;
      install)
        _arguments \
          '*--persona[persona IDs to install]:id:' \
          '--overwrite[replace existing persona files]' \
          '1:package or path:_files' && ret=0
        ;;
      sources)
        if (( CURRENT == 3 )); then
          _values 'sources command' list add remove && ret=0
        elif [[ $line[2] == add ]]; then
          _arguments '--position[insert position among sources]:index:' '1:directory:_directories' && ret=0
        elif [[ $line[2] == remove ]]; then
          _arguments '1:directory or position:' && ret=0
        elif [[ $line[2] == list ]]; then
          _arguments '--json[JSON output]' && ret=0
        fi
        ;;
      destroy)
        _arguments \
          '--workspace[workspace ID]:id:' \
          '--cloud-url[cloud URL]:url:' \
          '--no-prompt[skip confirmation]' \
          '1:persona or agent ID:' && ret=0
        ;;
    esac
    ;;
esac

return ret
