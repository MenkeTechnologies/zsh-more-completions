#compdef kube-apiserver

# kube-apiserver: Kubernetes API server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--advertise-address=[advertise address]:addr:' \
  '--allow-privileged=[allow privileged]:bool:(true false)' \
  '--anonymous-auth=[anonymous auth]:bool:(true false)' \
  '--api-audiences=[API audiences]:list:' \
  '--audit-log-format=[audit log format]:fmt:(legacy json)' \
  '--audit-log-maxage=[audit log max age]:days:' \
  '--audit-log-maxbackup=[audit log max backup]:n:' \
  '--audit-log-maxsize=[audit log max size MB]:mb:' \
  '--audit-log-path=[audit log path]:file:_files' \
  '--audit-policy-file=[audit policy file]:file:_files' \
  '--authentication-token-webhook-config-file=[webhook config]:file:_files' \
  '--authorization-mode=[authorization mode]:mode:(AlwaysAllow AlwaysDeny ABAC Node RBAC Webhook)' \
  '--authorization-policy-file=[ABAC policy file]:file:_files' \
  '--authorization-webhook-config-file=[authz webhook config]:file:_files' \
  '--bind-address=[bind address]:addr:' \
  '--cert-dir=[cert dir]:dir:_files -/' \
  '--client-ca-file=[client CA file]:file:_files' \
  '--cloud-config=[cloud config file]:file:_files' \
  '--cloud-provider=[cloud provider]:provider:(aws gce azure openstack vsphere external)' \
  '--cors-allowed-origins=[CORS origins]:list:' \
  '--default-watch-cache-size=[default watch cache size]:n:' \
  '--enable-admission-plugins=[enabled admission plugins]:list:' \
  '--disable-admission-plugins=[disabled admission plugins]:list:' \
  '--enable-aggregator-routing[enable aggregator routing]' \
  '--enable-bootstrap-token-auth[enable bootstrap token auth]' \
  '--encryption-provider-config=[encryption provider config]:file:_files' \
  '--etcd-cafile=[etcd CA file]:file:_files' \
  '--etcd-certfile=[etcd cert file]:file:_files' \
  '--etcd-keyfile=[etcd key file]:file:_files' \
  '--etcd-prefix=[etcd prefix]:prefix:' \
  '--etcd-servers=[etcd servers]:list:' \
  '--external-hostname=[external hostname]:host:_hosts' \
  '--feature-gates=[feature gates]:gates:' \
  '--insecure-bind-address=[insecure bind address]:addr:' \
  '--insecure-port=[insecure port]:port:' \
  '--kubelet-certificate-authority=[kubelet CA]:file:_files' \
  '--kubelet-client-certificate=[kubelet client cert]:file:_files' \
  '--kubelet-client-key=[kubelet client key]:file:_files' \
  '--kubelet-preferred-address-types=[preferred addr types]:list:' \
  '--max-mutating-requests-inflight=[max mutating requests inflight]:n:' \
  '--max-requests-inflight=[max requests inflight]:n:' \
  '--min-request-timeout=[min request timeout]:seconds:' \
  '--oidc-ca-file=[OIDC CA file]:file:_files' \
  '--oidc-client-id=[OIDC client id]:id:' \
  '--oidc-groups-claim=[OIDC groups claim]:claim:' \
  '--oidc-groups-prefix=[OIDC groups prefix]:prefix:' \
  '--oidc-issuer-url=[OIDC issuer URL]:url:' \
  '--oidc-username-claim=[OIDC username claim]:claim:' \
  '--oidc-username-prefix=[OIDC username prefix]:prefix:' \
  '--profiling=[enable profiling]:bool:(true false)' \
  '--proxy-client-cert-file=[proxy client cert]:file:_files' \
  '--proxy-client-key-file=[proxy client key]:file:_files' \
  '--requestheader-allowed-names=[allowed names]:list:' \
  '--requestheader-client-ca-file=[request header CA]:file:_files' \
  '--requestheader-extra-headers-prefix=[extra headers prefix]:prefix:' \
  '--requestheader-group-headers=[group headers]:list:' \
  '--requestheader-username-headers=[username headers]:list:' \
  '--runtime-config=[runtime config]:kv:' \
  '--secure-port=[secure port]:port:' \
  '--service-account-key-file=[service account key]:file:_files' \
  '--service-account-issuer=[service account issuer]:url:' \
  '--service-account-signing-key-file=[service account signing key]:file:_files' \
  '--service-cluster-ip-range=[service cluster IP range]:cidr:' \
  '--service-node-port-range=[node port range]:range:' \
  '--storage-backend=[storage backend]:backend:(etcd3)' \
  '--tls-cert-file=[TLS cert file]:file:_files' \
  '--tls-private-key-file=[TLS key file]:file:_files' \
  '--tls-cipher-suites=[TLS cipher suites]:list:' \
  '--tls-min-version=[TLS min version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
  '--token-auth-file=[token auth file]:file:_files' \
  '--v=[log level]:n:' \
  '--vmodule=[log vmodule]:patterns:' \
  '*::kube-apiserver args:_files' && ret=0
return ret
