#compdef kubectl-flame
# Documentation: https://github.com/yahoo/kubectl-flame/blob/master/cli/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream source (cli/cmd/root.go) flag definitions at the URL
# above. No --kubeconfig flag exists in the plugin.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[print version info]' \
  '(-t --time)'{-t+,--time=}'[max scan duration]:duration:' \
  '(-f --file)'{-f+,--file=}'[output file location (default flamegraph.svg)]:file:_files' \
  '--alpine[target image is based on Alpine]' \
  '--dry-run[simulate profiling]' \
  '--image=[manually choose agent docker image]:image:' \
  '--docker-path=[Docker install path (default /var/lib/docker/)]:path:_files -/' \
  '--target-namespace=[namespace of target pod if different from job namespace]:namespace:' \
  '(-p --pgrep)'{-p+,--pgrep=}'[name of the target process]:name:' \
  '(-l --lang)'{-l+,--lang=}'[programming language]:lang:(java go python ruby nodejs)' \
  '(-e --event)'{-e+,--event=}'[profiling event]:event:' \
  '--cpu.requests=[CPU requests of profiling container]:cpu:' \
  '--mem.requests=[memory requests of profiling container]:mem:' \
  '--cpu.limits=[CPU limits of profiling container]:cpu:' \
  '--mem.limits=[memory limits of profiling container]:mem:' \
  '--imagePullSecret=[imagePullSecret for agent docker image]:secret:' \
  '--serviceAccountName=[serviceAccountName for profiling container]:sa:' \
  '*:pod and container:_default'
