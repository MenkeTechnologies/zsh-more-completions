#compdef braintree-cli braintree
# _braintree-cli — PayPal Braintree braintree-cli CLI command-line frontend wrapping the Braintree payments platform REST GraphQL API managing customers payment-methods transactions disputes subscriptions plans webhooks merchant-accounts settlements add-ons-discounts vault PayPal Venmo Apple Pay Google Pay credit-card recurring (PayPal Braintree team, Go); cobra
# upstream: https://www.braintreepayments.com/

_braintree-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'customer:customer operations'
        'payment-method:payment method operations'
        'transaction:transaction operations'
        'dispute:dispute operations'
        'subscription:subscription operations'
        'plan:plan operations'
        'addon:add-on operations'
        'discount:discount operations'
        'webhook:webhook operations'
        'merchant-account:merchant account operations'
        'settlement:settlement operations'
        'vault:vault operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--merchant-id=+[id]:str:' \
        '--public-key=+[key]:str:' \
        '--private-key=+[key]:str:' \
        '--access-token=+[token]:str:' \
        '--environment=+[e]:e:(sandbox production qa development)' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'braintree-cli subcommand' sub ;;
        args)
            case $words[1] in
                customer|payment-method|transaction|dispute|subscription|plan|addon|discount|webhook|merchant-account|settlement|vault) _arguments '1:op:(list get create update delete capture refund void cancel submit-for-settlement accept finalize)' '*:id:' ;;
            esac
            ;;
    esac
}

_braintree-cli "$@"
