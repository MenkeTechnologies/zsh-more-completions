#compdef xvc
# ---------------------------------------------------------------------------
# xvc — fast MLOps tool to manage data files and ML pipelines on top of Git (Rust, 74★)
#
# upstream: https://github.com/iesahin/xvc
# author : Emre Şahin  <contact@emresahin.net>  (iesahin)
# license: GPL-3.0
#
# Source-direct completion: every subcommand and every global flag below is
# verbatim from lib/src/cli/mod.rs (XvcCLI + XvcSubCommand enum),
# file/src/lib.rs (XvcFileSubCommand), pipeline/src/lib.rs (PipelineSubCommand),
# storage/src/lib.rs (StorageSubCommand + StorageNewSubCommand) on the xvc tip.
#
# Note: xvc itself supports clap-runtime dynamic shell completion via
# `COMPLETE=zsh xvc | source /dev/stdin`.  This static fallback covers the
# tree without requiring runtime invocation.
#
# Direct deps from lib/Cargo.toml:
#   gix          = "^0.77"          ← canonical pure-Rust Git library (this axis)
#                                     by Sebastian Thiel (Byron) — the gitoxide
#                                     project
#   clap         = "^4.5"           (derive, cargo, unstable-ext)
#   clap_complete = "^4.5"          (engine, unstable-dynamic)
#   crossbeam, crossbeam-channel
#
# === AXIS 158 OPENER — pure-language Git library ecosystem ===
# Axis position: Rust=213 OPENS Axis 158 at slot 1/0/0.  Canonical Rust pure
# Git library is `gix` (gitoxide) by Sebastian Thiel (Byron) — a memory-safe
# fast pure-Rust implementation of the Git plumbing without any libgit2 cgo
# dependency.  gitoxide is the most thoroughly engineered Rust Git library
# in existence and powers cargo's git fetch path, sourcegraph/sg.nvim,
# nickel-lang/nickel, databendlabs/databend, pre-commit/pre-commit-rs,
# Astral's uv (sometimes), and dozens of MLOps + monorepo tools.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=213   ← THIS FILE              (axis 158 OPENS, slot 1/0/0)
#   Go=213     ← next round              (axis 158 continues, slot 2/0/0)
#   TS-Node=213 ← round after            (axis 158 CLOSES at triple-213, slot 1/1/1)
# ---------------------------------------------------------------------------

_xvc() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'file:file and directory management commands'
        'f:alias for file'
        'pipeline:pipeline management commands'
        'p:alias for pipeline'
        'storage:storage (cloud) management commands'
        's:alias for storage'
        'root:find the root directory of an Xvc project'
        'r:alias for root'
        'init:initialize an Xvc project'
        'check-ignore:check whether files are ignored with .xvcignore'
        'help:print help about a subcommand'
    )

    _arguments -C \
        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
        '--quiet[suppress all output]' \
        '--debug[turn on all logging to $TMPDIR/xvc.log]' \
        '-C+[set working directory for the command]:workdir:_files -/' \
        '*'{-c,--config=}'[CLI config override: section.key=value]:key=value:' \
        '--no-system-config[ignore system configuration file]' \
        '--no-user-config[ignore user configuration file]' \
        '--no-project-config[ignore project (.xvc/config) configuration]' \
        '--no-local-config[ignore local (.xvc/config.local) configuration]' \
        '--no-env-config[ignore environment-variable configuration]' \
        '--skip-git[do not run automated Git operations for this command]' \
        '--from-ref=[checkout the given Git reference before performing the Xvc op]:git ref:' \
        '--to-branch=[create or checkout the given branch before committing results]:branch:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'xvc command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                file|f)         _xvc_file     && ret=0 ;;
                pipeline|p)     _xvc_pipeline && ret=0 ;;
                storage|s)      _xvc_storage  && ret=0 ;;
                root|r|init|check-ignore)
                    ret=0
                    ;;
                help)
                    _describe -t commands 'xvc command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# `xvc file <sub>` — file/src/lib.rs XvcFileSubCommand enum
_xvc_file() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a fcmds
    fcmds=(
        'track:add files and directories to Xvc'
        't:alias for track'
        'hash:get digest hash of files with the supported algorithms'
        'h:alias for hash'
        'recheck:get files from cache by copy or *link'
        'checkout:alias for recheck'
        'r:alias for recheck'
        'carry-in:carry in changed files to cache'
        'commit:alias for carry-in'
        'c:alias for carry-in'
        'copy:copy from source to another location in the workspace'
        'C:alias for copy'
        'move:move files to another location in the workspace'
        'M:alias for move'
        'list:list tracked and untracked elements in the workspace'
        'l:alias for list'
        'send:send files to external storages'
        'upload:alias for send'
        'push:alias for send'
        'bring:bring files from external storages'
        'download:alias for bring'
        'pull:alias for bring'
        'remove:remove files from Xvc cache and storages'
        'R:alias for remove'
        'untrack:untrack (delete) files from Xvc and storages'
        'U:alias for untrack'
        'share:share a file from S3-compatible storage for a limited time'
        'S:alias for share'
    )

    _arguments -C \
        '*'{-v,--verbose}'[increase verbosity]' \
        '--quiet[suppress error messages]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :->fcmds' \
        '*::arg:->fargs' && ret=0

    case $state in
        fcmds)
            _describe -t commands 'xvc file command' fcmds && ret=0
            ;;
        fargs)
            _files && ret=0
            ;;
    esac

    return ret
}

# `xvc pipeline <sub>` — pipeline/src/lib.rs PipelineSubCommand enum
_xvc_pipeline() {
    local -a pcmds
    pcmds=(
        'new:create a new pipeline'
        'n:alias for new'
        'update:update an existing pipeline'
        'u:alias for update'
        'delete:delete a pipeline'
        'D:alias for delete'
        'run:run a pipeline'
        'r:alias for run'
        'list:list all pipelines'
        'l:alias for list'
        'dag:render the DAG of a pipeline'
        'd:alias for dag'
        'export:export a pipeline definition to a file'
        'e:alias for export'
        'import:import a pipeline definition from a file'
        'i:alias for import'
        'step:manage individual pipeline steps'
        's:alias for step'
    )
    _describe -t commands 'xvc pipeline command' pcmds
}

# `xvc storage <sub>` — storage/src/lib.rs StorageSubCommand + StorageNewSubCommand
_xvc_storage() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a scmds
    scmds=(
        'list:list all configured storages'
        'l:alias for list'
        'remove:remove a storage configuration (does not delete files)'
        'R:alias for remove'
        'new:configure a new storage'
        'n:alias for new'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '1: :->scmds' \
        '*::arg:->sargs' && ret=0

    case $state in
        scmds)
            _describe -t commands 'xvc storage command' scmds && ret=0
            ;;
        sargs)
            case $line[1] in
                new|n)
                    local -a ncmds
                    ncmds=(
                        'local:add a new local-directory storage'
                        'generic:add a generic storage'
                        'rsync:add an rsync (ssh-key) storage'
                        'rclone:add an rclone-configured storage'
                        's3:add an Amazon S3 storage'
                        'minio:add a MinIO storage'
                        'digital-ocean:add a DigitalOcean Spaces storage'
                        'r2:add a Cloudflare R2 storage'
                        'gcs:add a Google Cloud Storage'
                        'wasabi:add a Wasabi storage'
                    )
                    _describe -t commands 'xvc storage new provider' ncmds && ret=0
                    ;;
                remove|R)
                    _arguments \
                        '(-n --name)'{-n,--name=}'[name of the storage to delete]:storage name:' && ret=0
                    ;;
                list|l) ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_xvc "$@"
