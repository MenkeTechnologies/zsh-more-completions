#compdef htseq-qa
# Documentation: https://htseq.readthedocs.io/
# HTSeq: quality-assessment plots of a high-throughput sequencing read file

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --type)'{-t,--type}'=[input file format]:type:(sam solexa-export fastq solexa-fastq)' \
  '(-o --outfile)'{-o,--outfile}'=[output PDF filename]:pdf file:_files' \
  '(-r --readlength)'{-r,--readlength}'=[maximum read length]:int' \
  '(-g --gamma)'{-g,--gamma}'=[gamma factor for contrast adjustment]:float' \
  '(-n --nosplit)'{-n,--nosplit}'[single-column plot, no aligned/unaligned split]' \
  '(-m --maxqual)'{-m,--maxqual}'=[maximum quality score (default 40)]:int' \
  '*:read file:_files' && ret=0

return ret
