#compdef mafToSnpBed
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: find SNPs in MAF and build a bed with their functional consequence

local ret=1

_arguments -s -S \
  '1:database:' \
  '2:input maf:_files -g "*.maf"' \
  '3:input genePred:_files' \
  '4:output bed:_files -g "*.bed"' && ret=0

return ret
