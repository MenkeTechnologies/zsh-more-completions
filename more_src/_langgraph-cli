#compdef langgraph-cli
# Documentation: https://github.com/langchain-ai/langgraph/tree/main/libs/cli
# Reference accessed: 2026-05-23
# Verified: langgraph --help (pip langgraph-cli).

# Zsh completion for langgraph-cli - LangGraph API server CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'langgraph command' \
      'new[create project from template]' \
      'dev[run API server locally]' \
      'up[launch API server in Docker]' \
      'build[build API server Docker image]' \
      'dockerfile[generate Dockerfile]' \
      'validate[validate langgraph.json]' \
      'deploy[deploy to LangSmith]' && ret=0
    ;;
  args)
    case $line[1] in
      deploy)
        if (( CURRENT == 3 )); then
          _values 'deploy command' \
            'delete[delete deployment]' \
            'list[list deployments]' \
            'logs[fetch deployment logs]' \
            'revisions[deployment revisions]' && ret=0
        elif [[ $line[2] == revisions ]] && (( CURRENT == 4 )); then
          _values 'revisions command' 'list[list revisions]' && ret=0
        fi
        ;;
      dev)
        _arguments \
          '--host[bind host]:host:_hosts' \
          '--port[bind port]:port:' \
          '--no-reload[disable hot reload]' \
          '--debug-port[debug port]:port:' \
          '--no-browser[do not open browser]' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' && ret=0
        ;;
      up|build)
        _arguments '(-c --config)'{-c+,--config=}'[config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
