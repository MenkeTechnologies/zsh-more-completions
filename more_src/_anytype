#compdef anytype
# Documentation: https://man.archlinux.org/search?q=anytype
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU]' \
  '--user-data-dir=[user data directory]:dir:_files -/' \
  '*::passthrough:_files' && ret=0

return ret
