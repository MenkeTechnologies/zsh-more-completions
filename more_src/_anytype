#compdef anytype
# Documentation: https://github.com/anyproto/anytype-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--disable-gpu[disable GPU]' \
  '--user-data-dir=[user data directory]:dir:_files -/' \
  '*::passthrough:_files' && ret=0

return ret
