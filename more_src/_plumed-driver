#compdef plumed-driver
# Documentation: https://www.plumed.org/doc-v2.9/user-doc/html/driver.html
# plumed driver: post-process an existing trajectory with PLUMED

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-debug[print special options for regtests]' \
  '--plumed=[PLUMED input file]:file:_files' \
  '--timestep=[simulation timestep in ps]:ps' \
  '--trajectory-stride=[frame output frequency]:stride' \
  '--multi=[number of replicas for multi-environment mode]:replicas' \
  '--noatoms[skip trajectory reading; use only colvar files]' \
  '--parse-only[read input file and exit]' \
  '--restart[enable restart behavior]' \
  '--dump-full-virial[dump all 9 virial components with forces]' \
  '--shortcut-ofile=[output file for shortcut expansion info]:file:_files' \
  '--length-units=[units for length]:units' \
  '--mass-units=[units for mass in pdb/mc files]:units' \
  '--charge-units=[units for charge in pdb/mc files]:units' \
  '--kt=[thermal energy kBT]:kt' \
  '--dump-forces=[write forces to file]:file:_files' \
  '--dump-forces-fmt=[force output format]:fmt' \
  '--pdb=[PDB file with masses and charges]:file:_files -g "*.pdb"' \
  '--mc=[file with masses/charges from DUMPMASSCHARGE]:file:_files' \
  '--box=[box dimensions]:box' \
  '--natoms=[number of atoms]:natoms' \
  '--initial-step=[starting step number]:step' \
  '--debug-forces[compare numerical and analytical force derivatives]' \
  '--ixyz=[trajectory in xyz format]:file:_files -g "*.xyz"' \
  '--igro=[trajectory in gro format]:file:_files -g "*.gro"' \
  '--idlp4=[trajectory in DL_POLY_4 format]:file:_files' \
  '--ixtc=[trajectory in xtc format]:file:_files -g "*.xtc"' \
  '--itrr=[trajectory in trr format]:file:_files -g "*.trr"' \
  '--mf_dcd=[molfile trajectory in dcd format]:file:_files -g "*.dcd"' \
  '--mf_pdb=[molfile trajectory in pdb format]:file:_files -g "*.pdb"' \
  '--mf_gro=[molfile trajectory in gro format]:file:_files -g "*.gro"' \
  '--mf_xtc=[molfile trajectory in xtc format]:file:_files -g "*.xtc"' \
  '--mf_trr=[molfile trajectory in trr format]:file:_files -g "*.trr"' && ret=0

return ret
