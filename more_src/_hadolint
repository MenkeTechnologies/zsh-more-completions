#compdef hadolint

# Zsh completion for hadolint - Dockerfile linter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*'{-i,--ignore}'[ignore a rule]:rule' \
  '*--trusted-registry[set trusted registry]:registry' \
  '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
  '(-f --format)'{-f,--format}'[output format]:format:(tty json checkstyle codeclimate gitlab_codeclimate gnu codacy sonarqube sarif)' \
  '(-t --failure-threshold)'{-t,--failure-threshold}'[exit with failure code if rules above threshold]:threshold:(error warning info style ignore none)' \
  '--no-fail[always exit with zero exit code]' \
  '--no-color[disable colorized output]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--file-path-in-report[file path to use in report]:path' \
  '--strict-labels[do not permit labels not in label-schema]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:Dockerfile:_files -g "*(Dockerfile*|*.dockerfile)"' && ret=0

return ret
