#compdef hadolint
# Documentation: https://github.com/hadolint/hadolint
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for hadolint - Dockerfile linter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging to stderr]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(tty json checkstyle codeclimate gitlab_codeclimate gnu codacy sonarqube sarif)' \
  '(-t --failure-threshold)'{-t+,--failure-threshold=}'[exit non-zero only at or above this severity]:threshold:(error warning info style ignore none)' \
  '*'{-i+,--ignore=}'[ignore a rule code]:rule:' \
  '*--error=[treat rule as error severity]:rule:' \
  '*--warning=[treat rule as warning severity]:rule:' \
  '*--info=[treat rule as info severity]:rule:' \
  '*--style=[treat rule as style severity]:rule:' \
  '*--trusted-registry=[whitelist a Docker registry]:registry:' \
  '*--require-label=[require label (label:type)]:labelschema:' \
  '--strict-labels[warn about unlisted labels]' \
  '--disable-ignore-pragma[disable inline ignore comments]' \
  '--no-fail[always exit with zero status]' \
  '--no-color[disable colorized output]' \
  '--file-path-in-report=[file path to use in report]:path:' \
  '*:Dockerfile:_files -g "*(Dockerfile*|*.dockerfile)"' && ret=0

return ret
