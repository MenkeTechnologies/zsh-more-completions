#compdef spyql
# _spyql — SpyQL Python-embedded SQL-like data processor (Daniel Moura, Python); click
# upstream: https://github.com/dcmoura/spyql

_spyql() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--input-options=+[input options key=value]:str:' \
        '-Oi+[input options key=value]:str:' \
        '--output-options=+[output options key=value]:str:' \
        '-Oo+[output options key=value]:str:' \
        '--verbose-stats[verbose stats]' \
        '-V[verbose stats]' \
        '--ttext-on-error=+[text on error]:str:' \
        '--unbuffered[unbuffered output]' \
        '--warn-as-error[warn as error]' \
        '--no-output-header[no output header]' \
        '--clean-output-after=+[clean output rows after seconds]:n:' \
        '*:query:'
}

_spyql "$@"
