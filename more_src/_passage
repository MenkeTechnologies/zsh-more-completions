#compdef passage

# Zsh completion for passage - password store using age encryption

local curcontext="$curcontext" state line ret=1

_passage_entries() {
  local prefix="${PASSAGE_DIR:-$HOME/.passage/store}"
  if [[ -d "$prefix" ]]; then
    local -a entries
    entries=(${${(f)"$(find "$prefix" -name '*.age' -type f 2>/dev/null)"}#$prefix/})
    entries=(${entries%.age})
    _describe -t entries 'entry' entries
  fi
}

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize the password store'
      'ls:list entries'
      'find:find entries matching a pattern'
      'show:show an entry'
      'grep:search entries for a pattern'
      'insert:insert a new entry'
      'edit:edit an entry'
      'generate:generate a new password'
      'rm:remove an entry'
      'mv:move or rename an entry'
      'cp:copy an entry'
      'git:run a git command'
      'otp:manage OTP tokens'
      'help:show help'
      'version:show version'
    )
    _describe -t commands 'passage command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      init)
        _arguments -s \
          '(-p --path)'{-p,--path}'[sub-folder path]:folder' \
          ':age identity' && ret=0
        ;;
      show)
        _arguments -s \
          '(-c --clip)'{-c,--clip}'[copy line to clipboard]:line number' \
          '(-q --qrcode)'{-q,--qrcode}'[display as QR code]:line number' \
          ':entry:_passage_entries' && ret=0
        ;;
      insert)
        _arguments -s \
          '(-e --echo)'{-e,--echo}'[echo input]' \
          '(-m --multiline)'{-m,--multiline}'[multiline input]' \
          '(-f --force)'{-f,--force}'[overwrite existing entry]' \
          ':entry:_passage_entries' && ret=0
        ;;
      generate)
        _arguments -s \
          '(-n --no-symbols)'{-n,--no-symbols}'[do not use symbols]' \
          '(-c --clip)'{-c,--clip}'[copy to clipboard]' \
          '(-i --in-place)'{-i,--in-place}'[replace first line only]' \
          '(-f --force)'{-f,--force}'[overwrite existing entry]' \
          ':entry:_passage_entries' \
          ':length' && ret=0
        ;;
      rm)
        _arguments -s \
          '(-r --recursive)'{-r,--recursive}'[remove recursively]' \
          '(-f --force)'{-f,--force}'[do not prompt for confirmation]' \
          ':entry:_passage_entries' && ret=0
        ;;
      mv)
        _arguments -s \
          '(-f --force)'{-f,--force}'[overwrite destination]' \
          ':old entry:_passage_entries' \
          ':new entry:_passage_entries' && ret=0
        ;;
      cp)
        _arguments -s \
          '(-f --force)'{-f,--force}'[overwrite destination]' \
          ':source entry:_passage_entries' \
          ':destination entry:_passage_entries' && ret=0
        ;;
      edit)
        _arguments ':entry:_passage_entries' && ret=0
        ;;
      find|grep)
        _arguments ':search term' && ret=0
        ;;
      ls)
        _arguments ':subfolder:_passage_entries' && ret=0
        ;;
      git)
        _arguments '*::git args:_git' && ret=0
        ;;
      otp)
        local -a otp_cmds=(
          'code:generate OTP code'
          'insert:insert OTP secret'
          'append:append OTP secret'
          'uri:show OTP URI'
          'validate:validate OTP secret'
        )
        if (( CURRENT == 2 )); then
          _describe -t commands 'otp command' otp_cmds && ret=0
        else
          _passage_entries && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
