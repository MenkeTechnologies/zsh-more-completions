#compdef device-injector
# _device-injector — containerd NRI sample plugin: injects host device nodes into containers per pod-annotation
# upstream: https://github.com/containerd/nri
# Flags from plugins/device-injector/device-injector.go on tip.

_device-injector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket-path=[path of the NRI socket file]:socket:_files' \
        '--verbose[enable verbose logging]'
}

_device-injector "$@"
