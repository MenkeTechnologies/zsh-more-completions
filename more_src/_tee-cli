#compdef tee-cli
# _tee-cli — GNU coreutils tee read from stdin write to stdout and files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_tee-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[append, not overwrite]' \
        '--append[append, not overwrite]' \
        '-i[ignore SIGINT]' \
        '--ignore-interrupts[ignore SIGINT]' \
        '-p[diagnose write errors on non-pipes]' \
        '--output-error=+[mode]:m:(warn warn-nopipe exit exit-nopipe)' \
        '*:files:_files'
}

_tee-cli "$@"
