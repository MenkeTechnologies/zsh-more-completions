#compdef codebook-lsp
# Documentation: https://man.archlinux.org/search?q=codebook-lsp
# Reference accessed: 2026-05-16

# Language server — common Node LSP transports (see upstream for extras).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(--version)'--version'[version]' \
  '(--stdio)'--stdio'[use stdio]' \
  '(--node-ipc)'--node-ipc'[Node IPC transport]' \
  '(--socket)'--socket'[port or host:port]' \
  '(--pipe)'--pipe'[pipe transport]' \
  '(--clientProcessId)'--clientProcessId'[parent PID]' \
  '*::args:_normal' && ret=0

return ret
