#compdef codebook-lsp
# Documentation: https://github.com/blopker/codebook
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Spell checker for code, exposed as an LSP server.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'serve:start language server on STDIN/STDOUT'
  'lint:spell check files (experimental)'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'codebook-lsp command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (lint)
        _arguments \
          '--suggest[show spelling suggestions]' \
          '--unique[report each misspelled word once]' \
          '*:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
