#compdef nwg-look

# Zsh completion for nwg-look - GTK settings editor for Wayland

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --apply)'{-a,--apply}'[apply settings without GUI]' \
  '(-x --export)'{-x,--export}'[export current settings to stdout]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]'
