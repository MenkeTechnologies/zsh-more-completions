#compdef sgpt

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--model=[model to use]:model' \
  '-s[shell mode - generate shell commands]' \
  '--shell[shell mode - generate shell commands]' \
  '--describe-shell[describe shell command]' \
  '-c[code mode - generate code]' \
  '--code[code mode - generate code]' \
  '--editor[open editor for input]' \
  '--cache[enable caching]' \
  '--no-cache[disable caching]' \
  '--temperature=[sampling temperature]:temperature' \
  '--top-p=[top-p sampling]:top_p' \
  '--md[markdown output]' \
  '--no-md[plain text output]' \
  '--chat=[name of chat session]:session' \
  '--repl=[start REPL]:session' \
  '--show-chat=[show previous chat]:session' \
  '--list-chats[list all chats]' \
  '--role=[use predefined role]:role' \
  '--create-role=[create new role]:role' \
  '--list-roles[list all roles]' \
  '--show-role=[show role definition]:role' \
  '--no-functions[disable function calling]' \
  '*:prompt:' && return 0
