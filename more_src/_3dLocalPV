#compdef 3dLocalPV
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dLocalPV.html
# AFNI: local principal vector of a 3D+time dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-input[input 3D+time dataset]:dataset:_files' \
  '-mask[mask dataset]:mset:_files' \
  '-automask[create mask from input]' \
  '-prefix[output dataset prefix]:ppp:_files' \
  '-prefix2[second output dataset prefix]:qqq:_files' \
  '-evprefix[output eigenvalue dataset prefix]:ppp:_files' \
  '-nbhd[neighborhood definition string]:nnn:' \
  '-despike[despike time series first]' \
  '-polort[polynomial detrend order]:p:' \
  '-vnorm[L2-normalize each time series first]' \
  '-vproj[project onto local PV subspace]::ndim:' \
  '*:dataset:_files' && ret=0

return ret
