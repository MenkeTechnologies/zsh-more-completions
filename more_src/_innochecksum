#compdef innochecksum
# Documentation: innochecksum --help (MySQL)
# Source: InnoDB offline file checksum utility.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,-I,--help,--info}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbose (progress every 5s)]' \
    {-c,--count}'[print page count and exit]' \
    {-s+,--start-page=}'[start at this page]:n:' \
    {-e+,--end-page=}'[end at this page]:n:' \
    {-p+,--page=}'[check only this page]:n:' \
    {-C+,--strict-check=}'[strict checksum algorithm]:algo:(crc32 innodb none)' \
    {-n,--no-check}'[ignore checksum verification]' \
    {-a+,--allow-mismatches=}'[max mismatches allowed]:n:' \
    {-w+,--write=}'[rewrite checksum algorithm]:algo:(crc32 innodb none)' \
    {-S,--page-type-summary}'[count each page type]' \
    {-D+,--page-type-dump=}'[dump page type info]:file:_files' \
    {-l+,--log=}'[log output file]:file:_files' \
    ':filename:_files -g "*.ibd"' \
    && ret=0

return ret
