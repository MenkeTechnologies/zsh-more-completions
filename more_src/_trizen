#compdef trizen

# Zsh completion for trizen - lightweight AUR helper

_arguments -s -S \
  '(-S --sync)'{-S,--sync}'[synchronize packages]' \
  '(-Q --query)'{-Q,--query}'[query the package database]' \
  '(-R --remove)'{-R,--remove}'[remove packages]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade or add packages]' \
  '(-D --database)'{-D,--database}'[modify the package database]' \
  '(-F --files)'{-F,--files}'[query the files database]' \
  '(-G --getpkgbuild)'{-G,--getpkgbuild}'[get PKGBUILD from AUR]' \
  '(- *)'{-V,--version}'[display version]' \
  '(- *)'{-h,--help}'[display help]' \
  '(-s --search)'{-s,--search}'[search package names]' \
  '(-u --sysupgrade)'{-u,--sysupgrade}'[upgrade installed packages]' \
  '(-y --refresh)'{-y,--refresh}'[download fresh package databases]' \
  '(-c --clean)'{-c,--clean}'[remove old packages from cache]' \
  '(-i --info)'{-i,--info}'[view package information]' \
  '(-q --quiet)'{-q,--quiet}'[show less information]' \
  '--noconfirm[do not ask for confirmation]' \
  '--needed[do not reinstall up-to-date packages]' \
  '--noedit[do not edit PKGBUILDs]' \
  '--clone-dir[set clone directory]:directory:_files -/' \
  '--makepkg-conf[set makepkg config]:file:_files' \
  '--pacman-conf[set pacman config]:file:_files' \
  '--aur[restrict to AUR packages]' \
  '--repo[restrict to repository packages]' \
  '--devel[check -git packages for updates]' \
  '--show-ood[show out-of-date flagged packages]' \
  '*:package'
