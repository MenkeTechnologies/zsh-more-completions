#compdef GetPileupSummaries
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/contamination/GetPileupSummaries.java
# GATK4: tabulate pileup metrics for inferring contamination

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-V --variant)'{-V,--variant}'[VCF of variants and allele frequencies]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-O --output)'{-O,--output}'[output table]:file:_files' \
  '(-min-af --minimum-population-allele-frequency)'{-min-af,--minimum-population-allele-frequency}'[minimum population allele frequency to consider]:val:' \
  '(-max-af --maximum-population-allele-frequency)'{-max-af,--maximum-population-allele-frequency}'[maximum population allele frequency to consider]:val:' \
  '*:options:_files' && ret=0

return ret
