#compdef pkpolygonize
# Documentation: https://pktools.nongnu.org/html/pkpolygonize.html
# polygonize raster image to vector

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input image file]:file:_files' \
  '(-m --mask)'{-m,--mask}'[All pixels in the mask band with a value other than zero will be consi]:file:_files' \
  '(-o --output)'{-o,--output}'[Output vector file]:file:_files' \
  '(-f --f)'{-f,--f}'[Output OGR file format]:value:' \
  '(-b --band)'{-b,--band}'[the band to be used from input file]:value:' \
  '(-nodata --nodata)'{-nodata,--nodata}'[Disgard this nodata value when creating polygons.]:value:' \
  '(-n --name)'{-n,--name}'[the field name of the output layer]:value:' \
  '*:file:_files' && ret=0

return ret
