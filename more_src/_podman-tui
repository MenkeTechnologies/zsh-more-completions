#compdef podman-tui

_podman-tui() {
  _arguments \
    '--connection=[connection name]:connection' \
    '--log-file=[log file path]:file:_files' \
    '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]'
}

_podman-tui "$@"
