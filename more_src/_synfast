#compdef synfast
# Documentation: https://healpix.sourceforge.io/html/fac_synfast.htm
# HEALPix: synthesize a map from a power spectrum or a_lm

local ret=1

_arguments -s -S \
  '(-d --double -s --single)'{-d,--double}'[use double precision]' \
  '(-d --double -s --single)'{-s,--single}'[use single precision (default)]' \
  '*:parameter file:_files' && ret=0

return ret
