#compdef funclatency funclatency-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/funclatency.py argparse)
# Reference accessed: 2026-05-29
# funclatency — time kernel/user functions and print a latency histogram (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-i --interval)'{-i,--interval=}'[summary interval, in seconds]:sec:' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace, in seconds]:sec:' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-u --microseconds -m --milliseconds)'{-u,--microseconds}'[microsecond histogram]' \
  '(-u --microseconds -m --milliseconds)'{-m,--milliseconds}'[millisecond histogram]' \
  '(-F --function)'{-F,--function}'[show a separate histogram per function]' \
  '(-r --regexp)'{-r,--regexp}'[use regular expressions (default is "*" wildcards only)]' \
  '(-l --level)'{-l,--level=}'[set the level of nested or recursive functions]:level:' \
  '(-v --verbose)'{-v,--verbose}'[print the BPF program (for debugging purposes)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pattern (search expression for functions e.g. "vfs_read" or "lib\:\:malloc"):' \
  && ret=0

return ret
