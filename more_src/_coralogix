#compdef coralogix coralogix-cli cxctl
# _coralogix — Coralogix observability platform CLI (Coralogix, Go); spf13/cobra
# upstream: https://github.com/coralogix/coralogix-cli

_coralogix() {
    local -a sub=(
        'auth:authenticate'
        'config:manage CLI config'
        'query:run log query'
        'live:tail live logs'
        'archive:archive log queries'
        'parser:manage parsing rules'
        'team:manage teams'
        'tco:tco policies'
        'enrichment:enrichment custom data'
        'rules:manage rules'
        'alert:manage alerts'
        'webhook:manage webhooks'
        'group:manage groups'
        'user:manage users'
        'role:manage roles'
        'apikey:manage api keys'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[Coralogix api key]:str:' \
        '--domain=+[Coralogix domain]:domain:(eu1.coralogix.com eu2.coralogix.com us1.coralogix.com us2.coralogix.com app.coralogix.in coralogix.us app.coralogixsg.com)' \
        '--config=+[config file]:file:_files' \
        '--profile=+[profile]:profile:' \
        '--output=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coralogix subcommand' sub ;;
        args)
            case $words[1] in
                parser|rules|alert|webhook|group|user|role|apikey|enrichment) _arguments \
                    '1:cmd:(list get create update delete import export)' \
                    '--id=+[resource id]:id:' \
                    '*:arg:' ;;
                query|live) _arguments \
                    '--query=+[query]:str:' \
                    '-q+[query]:str:' \
                    '--app=+[application]:str:' \
                    '--subsystem=+[subsystem]:str:' \
                    '--severity=+[severity]:sev:(debug verbose info warn error critical)' \
                    '--from=+[from]:str:' \
                    '--to=+[to]:str:' \
                    '--limit=+[limit]:n:' ;;
                archive) _arguments \
                    '1:cmd:(list run cancel get)' \
                    '*:arg:' ;;
                tco) _arguments \
                    '1:cmd:(list get create update delete reorder)' \
                    '*:arg:' ;;
                team) _arguments \
                    '1:cmd:(list create delete)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_coralogix "$@"
