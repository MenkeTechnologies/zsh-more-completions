#compdef clang-cache
# Documentation: https://github.com/swiftlang/llvm-project/blob/next/clang/tools/driver/clang-cache.cpp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# clang-cache is a wrapper that runs a clang command with CAS-backed caching.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*::clang command:_normal' && ret=0

return ret
