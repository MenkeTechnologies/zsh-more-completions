#compdef llamafile
# Documentation: https://github.com/Mozilla-Ocho/llamafile/blob/main/docs/running_llamafile.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--cli[run in CLI mode]' \
  '--chat[run in chat mode]' \
  '--server[run in server mode]' \
  '--port=[port to listen on]:port:' \
  '--host=[host address to bind to]:host:' \
  '(-m --model)'{-m,--model}'[path to model weights file]:model file:_files' \
  '-ngl+[number of layers to offload to GPU]:layers:' \
  '(-c --ctx-size)'{-c,--ctx-size}'[context size]:size:' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
  '-n+[max tokens to generate]:count:' \
  '-p+[prompt text]:prompt:' \
  '-e[process prompt escape sequences]' \
  '--temp=[temperature for sampling]:temperature:' \
  '--top-p=[top-p sampling]:value:' \
  '--top-k=[top-k sampling]:value:' \
  '(-b --batch-size)'{-b,--batch-size}'[batch size for prompt processing]:size:' \
  '--seed=[random seed]:seed:' \
  '--grammar=[BNF grammar constraint]:grammar:' \
  '--mirostat=[Mirostat sampling]:mode:(0 1 2)' \
  '--interactive[run in interactive mode]' \
  '--color[colorize output]' \
  '--no-display-prompt[do not display the prompt]' \
  '--jinja[enable Jinja template support]' \
  '--mmproj=[multimodal projector file]:file:_files' \
  '--image=[image file input for multimodal models]:file:_files' \
  && ret=0

return ret
