#compdef llamafile

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--server[run in server mode]' \
  '--nobrowser[do not open browser on server start]' \
  '--port[port to listen on]:port:' \
  '--host[host to bind to]:host:' \
  '(-m --model)'{-m,--model}'[path to model file]:model file:_files' \
  '(-ngl --n-gpu-layers)'{-ngl,--n-gpu-layers}'[number of layers to offload to GPU]:layers:' \
  '(-c --ctx-size)'{-c,--ctx-size}'[context size]:size:' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:' \
  '--temp[temperature for sampling]:temperature:' \
  '--top-p[top-p sampling]:value:' \
  '--top-k[top-k sampling]:value:' \
  '--repeat-penalty[repetition penalty]:penalty:' \
  '(-b --batch-size)'{-b,--batch-size}'[batch size for prompt processing]:size:' \
  '--embedding[enable embedding mode]' \
  '--mlock[lock model in memory]' \
  '--no-mmap[do not memory-map the model]' \
  '--verbose[enable verbose output]' \
  '--fast[use fast preset]' \
  '--precise[use precise preset]' \
  '--unsecure[disable security features]' \
  '--chat-template[chat template to use]:template:' \
  '--listen[address to listen on]:address:' \
  '--mmproj[path to multimodal projector]:file:_files' \
  && ret=0

return ret
