#compdef microk8s

# Zsh completion for microk8s - MicroK8s Kubernetes CLI

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'add-node:Generate a connection string for a node to join the cluster'
  'config:Show the MicroK8s kubeconfig'
  'ctr:Interact with containerd'
  'dashboard-proxy:Enable and proxy the Kubernetes dashboard'
  'dbctl:Manage the MicroK8s datastore'
  'disable:Disable addon(s)'
  'enable:Enable addon(s)'
  'helm:Run Helm commands'
  'helm3:Run Helm 3 commands'
  'inspect:Inspect the MicroK8s installation'
  'join:Join a MicroK8s cluster'
  'kubectl:Run kubectl commands'
  'leave:Leave a MicroK8s cluster'
  'refresh-certs:Refresh TLS certificates'
  'remove-node:Remove a node from the cluster'
  'reset:Reset MicroK8s to a clean state'
  'start:Start MicroK8s'
  'status:Show MicroK8s status'
  'stop:Stop MicroK8s'
  'version:Show the MicroK8s version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'microk8s command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      enable)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:addon:(community dashboard dns gpu helm helm3 host-access hostpath-storage ingress metallb metrics-server observability prometheus rbac registry storage)' && ret=0
        ;;
      disable)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:addon:(community dashboard dns gpu helm helm3 host-access hostpath-storage ingress metallb metrics-server observability prometheus rbac registry storage)' && ret=0
        ;;
      status)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--format=[output format]:format:(short yaml)' \
          '--timeout=[timeout in seconds]:seconds' \
          '--wait-ready[wait until MicroK8s is ready]' \
          '-a[show addon status]' && ret=0
        ;;
      join)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--worker[join as a worker node]' \
          '1:connection string' && ret=0
        ;;
      remove-node)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--force[force removal]' \
          '1:node' && ret=0
        ;;
      inspect)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      kubectl|helm|helm3|ctr)
        _arguments '*:arguments' && ret=0
        ;;
    esac
    ;;
esac

return ret
