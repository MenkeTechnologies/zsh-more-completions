#compdef imaxima
# Documentation: https://man.archlinux.org/search?q=imaxima
# Reference accessed: 2026-05-16

# imaxima: Emacs/Lisp inline-image frontend for Maxima
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*:script:_files -g "*.(mac|wxm)"' && ret=0
return ret
