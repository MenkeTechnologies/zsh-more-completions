#compdef kzonecheck
# Documentation: https://man.archlinux.org/search?q=kzonecheck
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --origin)'{-o,--origin}'+[zone origin]:origin:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --dnssec)'{-d,--dnssec}'+[validate DNSSEC]:flag:(on off auto)' \
  '(-p --print)'{-p,--print}'[print zone after parsing]' \
  '(-t --time)'{-t,--time}'+[time for DNSSEC validation]:unix_time:' \
  '1:zonefile:_files' && ret=0

return ret
