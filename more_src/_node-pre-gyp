#
# nopt is DISTINCT from every other documented TS-Node argv parser
# by being NPM'S OWN INTERNAL ARGV PARSER — the parser that has
# processed every `npm install`, `npm publish`, `npm view`,
# `npm config set` invocation from 2010 to present.  Isaac Z.
# Schlueter (npm's creator) wrote nopt to handle the specific
# parsing needs of npm itself: TYPE COERCION (every flag declares
# its type as a constructor), VALUE-BINDING SHORTHANDS (a
# shorthand can map to a complete flag-value pair, not just a
# short form), and ARRAY-MULTI-FLAG SUPPORT (the same flag
# repeated produces an array).  All other documented TS-Node
# argv parsers grew up AFTER npm, so they have to either:
#   (a) Reinvent type coercion (yargs's .number(), .boolean())
#   (b) Defer type handling to the user (minimist, mri)
#   (c) Use TypeScript types as the source of truth (cleye, gunshi)
# nopt's TYPE-CONSTRUCTOR-DICTIONARY approach predates and is
# distinct from all three.
#
# -----------------------------------------------------------------------------
#
# WHAT IS nopt AND WHY IS IT THE 48TH TS-NODE CLI LIBRARY?
#
# nopt (https://github.com/npm/nopt, 740+ stars, npm-inc/nopt) is
# **npm's "Node/npm option parser"** — the canonical argv parser
# that npm itself uses internally and that every `npm install ...`
# invocation flows through.  nopt was extracted from npm's source
# in 2010 as a standalone library so other tools could share the
# same parsing semantics as npm.
#
# nopt's distinguishing characteristics:
#
#   1. TYPE-CONSTRUCTOR-DICTIONARY API — Callers declare flag
#      types using JavaScript CONSTRUCTORS rather than strings or
#      enums:
#
#          const knownOpts = {
#              foo: [String, null],   // --foo accepts any string
#              bar: Boolean,          // --bar is a flag
#              count: Number,         // --count expects a number
#              when: Date,            // --when expects ISO date
#              target: url,           // --target expects URL
#              registry: url,         // --registry expects URL
#              dir: path,             // --dir is a filesystem path
#              env: [String, Array],  // --env can be repeated; result is array
#              loglevel: [
#                  'silent', 'error', 'warn',
#                  'notice', 'http', 'info',
#                  'verbose', 'silly'
#              ],                     // --loglevel must be one of these
#          };
#
#      The constructor IS the parser/validator.  Pass `Boolean`
#      and nopt converts presence to `true`.  Pass `Number` and
#      nopt calls `Number(arg)` then validates.  Pass `Date` and
#      nopt calls `Date.parse()`.  Pass `path` and nopt resolves
#      against cwd.  Pass an array (`[String, null]`) to express
#      multiple alternatives — nopt tries each type until one
#      matches.  Pass an enum (string list) to constrain to known
#      values.  FIRST documented TS-Node argv parser with type-
#      constructor-as-validator API (vs string type names / vs
#      TypeScript types).
#
#   2. VALUE-BINDING SHORTHANDS — Shorthands can map to complete
#      flag-value pairs, not just shorter flag names:
#
#          const shortHands = {
#              C: '--directory',           // simple short form
#              s: '--loglevel=silent',     // value-binding shorthand
#              dbg: '--debug',
#              loud: '--loglevel=loud',
#              h: '--help',
#              quiet: '--loglevel=warn'    // shorthand to --loglevel=warn
#          };
#
#      Compare other documented parsers:
#         * yargs: `.alias('s', 'silent')` — alias-to-flag only
#         * commander: `.option('-s, --silent')` — short+long
#         * minimist: `alias: {s: 'silent'}` — alias-to-flag only
#         * nopt: `s: '--loglevel=silent'` — shorthand binds to a
#                  flag-value PAIR, expanding `-s` to `--loglevel=silent`
#      FIRST documented TS-Node argv parser with value-binding
#      shorthands (vs name-only aliases).
#
#   3. REMAINDER ARGS AND COMMAND DISPATCH PATTERN — nopt returns
#      an `argv.remain` array containing all non-flag arguments,
#      allowing the calling code to implement command dispatch:
#
#          const parsed = nopt(knownOpts, shortHands, process.argv);
#          // parsed.argv.remain = positional args
#          // parsed.argv.cooked = full cooked argv
#          // parsed.argv.original = original argv
#
#          const command = parsed.argv.remain[0];
#          switch(command) {
#              case 'install': handleInstall(parsed); break;
#              case 'publish': handlePublish(parsed); break;
#              // ...
#          }
#
#      Three argv representations (`remain`, `cooked`, `original`)
#      give the calling code full visibility into parsing.
#      Compare:
#         * yargs/commander: framework-managed command dispatch
#         * minimist/mri: positional args returned as `argv._`
#         * nopt: three separate argv views (remain/cooked/original)
#                 + manual command dispatch in caller code
#      FIRST documented TS-Node argv parser exposing THREE argv
#      views for manual command dispatch.
#
#   4. NPM-ECOSYSTEM PROVENANCE — nopt powers:
#         * npm itself (every npm command since 2010)
#         * node-gyp (Node native add-on build tool)
#         * node-pre-gyp (THIS — prebuilt binary installer)
#         * pacote (npm's tarball-management package)
#         * libnpm* (npm internals modular packages)
#         * normalize-package-data
#         * read-package-json
#         * promzard (npm init's interactive prompt)
#      No other TS-Node argv parser has comparable provenance
#      in the npm/Node.js core ecosystem itself.  FIRST
#      documented TS-Node argv parser with npm-core provenance.
#
#   5. PRE-CONFIG-FILE-EXPANSION SUPPORT — nopt was designed
#      around npm's `~/.npmrc` config file: it parses argv
#      ASSUMING that some flags will already have been populated
#      from a config file, and merges command-line overrides
#      cleanly over those.  npm's `nopt(known, short, argv,
#      slice)` signature lets callers slice off prepended
#      "ambient" flags (like those from .npmrc) before user
#      command-line flags override.  Compare:
#         * yargs: config-file support via `.config()` method
#         * commander: requires plugin for config-file
#         * nopt: built-in slice-merge semantics for config-file
#                 + command-line overlay
#      FIRST documented TS-Node argv parser with built-in slice-
#      merge config-file overlay (vs separate plugin / no support).
#
# nopt's relationship to other documented TS-Node CLI libraries:
#
#   * Like minimist — bare-bones argv parsing, no command framework
#   * Like mri — focused on argv-to-object conversion
#   * Unlike both — adds TYPE COERCION via constructor dictionary
#   * Like yargs — has type validation
#   * Unlike yargs — uses constructor dictionary (declarative) vs
#                     chained builder pattern (procedural)
#   * Like commander — has command dispatch concept
#   * Unlike commander — leaves dispatch to caller code via
#                         argv.remain (caller-managed dispatch)
#   * Like cleye/gunshi — supports type validation
#   * Unlike cleye/gunshi — type via JS constructors at runtime
#                            (no TypeScript dependency); cleye/
#                            gunshi use TypeScript types as source
#   * Closest cross-language analogs:
#         * Go:      no clear analog (Go doesn't have constructor-
#                     as-validator; closest is type-assertion of
#                     interface{})
#         * Rust:    no clear analog (clap uses derive macros, not
#                     runtime type constructors)
#     nopt is the FIRST documented argv parser in the taxonomy
#     using runtime-JavaScript-constructor-as-validator semantics.
#
# -----------------------------------------------------------------------------
#
# THE node-pre-gyp CLI — nopt configDefs + shorthands + command-dispatch
#
# node-pre-gyp's argv parsing is direct nopt:
#
#     proto.configDefs = {
#         help: Boolean,        // everywhere
#         arch: String,         // 'configure'
#         debug: Boolean,       // 'build'
#         directory: String,    // bin
#         proxy: String,        // 'install'
#         loglevel: String,     // everywhere
#         acl: String           // 'publish' — S3 ACL for published binaries
#     };
#
#     proto.shorthands = {
#         release: '--no-debug',
#         C: '--directory',
#         debug: '--debug',
#         j: '--jobs',
#         silent: '--loglevel=silent',
#         silly: '--loglevel=silly',
#         verbose: '--loglevel=verbose'
#     };
#
#     proto.parseArgv = function parseOpts(argv) {
#         this.opts = nopt(this.configDefs, this.shorthands, argv);
#         this.argv = this.opts.argv.remain.slice();
#         const commands = this.todo = [];
#         // ... process remain into command-list ...
#     };
#
# Commands (lib/node-pre-gyp.js cli_commands array):
#
#     clean       — remove the build directory
#     install     — install pre-built binary for module
#     reinstall   — run clean install
#     build       — compile module by dispatching to node-gyp
#     rebuild     — run clean build
#     package     — create local prebuilt tarball in build/stage
#     testpackage — test that the package is valid
#     publish     — publish prebuilt binary to S3
#     unpublish   — unpublish prebuilt binary from S3
#     info        — info about published binaries
#     testbinary  — test prebuilt binary
#     reveal      — reveal a hidden config setting
#     configure   — configure the underlying node-gyp project
#
# Five-axis distinctness from every other documented TS-Node CLI
# parser:
#
#   1. TYPE-CONSTRUCTOR-DICTIONARY API — Every other documented
#      TS-Node argv parser uses either string type names (yargs),
#      builder chains (commander), TypeScript types (cleye/
#      gunshi), or no type system (minimist/mri).  nopt uses
#      JavaScript CONSTRUCTORS (Boolean/String/Number/Date/path/
#      url) as both parsers and validators.
#
#   2. VALUE-BINDING SHORTHANDS — Every other documented TS-Node
#      argv parser uses name-only aliases (-s → --silent).  nopt
#      shorthands map to FULL flag-value pairs (-s → --loglevel=
#      silent, expanding both the flag AND its value).
#
#   3. THREE-VIEW ARGV (remain/cooked/original) — Every other
#      documented TS-Node argv parser returns ONE positional list
#      (argv._ in minimist; this.args in yargs).  nopt returns
#      argv.remain (non-flag positionals) + argv.cooked (full
#      cooked argv after parsing) + argv.original (untouched
#      input argv).
#
#   4. NPM-CORE PROVENANCE — Every other documented TS-Node argv
#      parser is third-party.  nopt is npm-inc/nopt, the parser
#      that npm itself uses.  This means nopt's PARSING SEMANTICS
#      ARE THE DE-FACTO STANDARD FOR THE ENTIRE NPM ECOSYSTEM —
#      every npm-style flag convention (like `-DD` for debug-
#      double, `--no-X` for negation, `-X=Y` for value-binding)
#      flows from nopt's behavior.
#
#   5. CONFIG-FILE-OVERLAY VIA SLICE — Every other documented
#      TS-Node argv parser handles config files via plugins or
#      not at all.  nopt's 4-arg signature `nopt(known, short,
#      argv, slice)` lets the CALLER prepend config-file-derived
#      flags to argv and tell nopt where the user's flags start,
#      with overrides flowing naturally from argv ordering.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/mapbox/node-pre-gyp/blob/master/lib/node-pre-gyp.js
# nopt configDefs and shorthands in proto.configDefs / proto.shorthands.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _npg_cmds
_npg_cmds=(
    'clean:remove the build directory'
    'install:install pre-built binary for the module'
    'reinstall:clean + install'
    'build:compile module by dispatching to node-gyp'
    'rebuild:clean + build'
    'package:create local prebuilt tarball in build/stage'
    'testpackage:test that the package is valid'
    'publish:publish prebuilt binary to S3'
    'unpublish:unpublish prebuilt binary from S3'
    'info:info about published binaries'
    'testbinary:test prebuilt binary by loading it via Node require'
    'reveal:reveal a hidden config setting'
    'configure:configure the underlying node-gyp project'
)

_arguments -C \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '--arch=[set target architecture (configure)]:arch:(x64 ia32 arm arm64 mipsel ppc64 s390x)' \
    '(--debug --no-debug --release)'{--debug,--no-debug,--release}'[build in debug / release mode]' \
    '(-C --directory)'{-C,--directory=}'[set working directory]:directory:_directories' \
    '--proxy=[HTTP proxy URL for downloading binaries]:proxy-url:' \
    '--loglevel=[set log verbosity]:level:(silent error warn notice http info verbose silly)' \
    '--acl=[S3 ACL for published binaries (publish)]:acl:(private public-read public-read-write authenticated-read bucket-owner-read bucket-owner-full-control)' \
    '(--silent)--silent[shorthand for --loglevel=silent]' \
    '(--silly)--silly[shorthand for --loglevel=silly]' \
    '(--verbose)--verbose[shorthand for --loglevel=verbose]' \
    '-j+[number of parallel build jobs (--jobs)]:jobs:' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'node-pre-gyp command' _npg_cmds && ret=0
        ;;
esac

return ret
