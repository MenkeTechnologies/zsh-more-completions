#compdef sql_exporter
# Documentation: https://github.com/burningalchemist/sql_exporter
# Database-agnostic Prometheus exporter that runs SQL queries

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-version[print version information]' \
  '-web.listen-address=[address to listen on for web interface and telemetry]:addr' \
  '-web.metrics-path=[path under which to expose metrics]:path' \
  '-web.enable-reload[enable reload collector data handler]' \
  '-web.config.file=[TLS/BasicAuth configuration file path]:file:_files' \
  '-config.file=[SQL Exporter configuration file path]:file:_files' \
  '-config.check[check configuration and exit]' \
  '-config.enable-ping[enable ping for targets]' \
  '-config.ignore-missing-values[ignore results with missing values]' \
  '-config.data-source-name=[data source name overriding the config file]:dsn' \
  '-config.target-label=[target label name]:label' \
  '-log.format=[set log output format]:format:(logfmt json)' \
  '-log.level=[set log level]:level' \
  '-log.file=[log file to write to (empty for stderr)]:file:_files' && ret=0

return ret
