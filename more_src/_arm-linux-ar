#compdef arm-linux-ar arm-linux-gnueabi-ar arm-linux-gnueabihf-ar
# _arm-linux-ar — GNU binutils arm-linux-ar CLI cross-arch archive utility creating modifying extracting from static library archives .a for ARMv7 ARMv6 ARMv5 Linux build environments adding deleting member object files in archive listing thin-archive S indexing for fast symbol lookup (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_arm-linux-ar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--target=+[bfd]:str:' \
        '--plugin=+[plugin]:file:_files -g "*.so *.dylib"' \
        '*:archive and members:_files -g "*.a *.o"'
}

_arm-linux-ar "$@"
