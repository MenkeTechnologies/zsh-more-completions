#compdef agixt-cli
# Documentation: https://github.com/Joshua-XT/AGiXT
# Reference accessed: 2026-05-23
# Verified: agixt --help (pip agixt package).

# Zsh completion for agixt-cli - AGiXT agent orchestration CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'agixt command' \
      'start[start AGiXT server]' \
      'stop[stop AGiXT server]' \
      'restart[restart AGiXT server]' \
      'logs[view AGiXT logs]' \
      'env[manage environment variables]' \
      'register[register new user]' \
      'login[login to AGiXT server]' \
      'logout[logout and invalidate session]' \
      'whoami[show login status]' \
      'prompt[send prompt to agent]' \
      'conversations[list and select conversations]' && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments '--local[start locally instead of Docker]' && ret=0
        ;;
      logs)
        _arguments '(-f --follow)'{-f,--follow}'[follow logs]' && ret=0
        ;;
      login)
        _arguments \
          '--email[email]:email:' \
          '--magic-link[request email login link]' && ret=0
        ;;
      register|prompt)
        _arguments '--email[email]:email:' && ret=0
        ;;
    esac
    ;;
esac

return ret
