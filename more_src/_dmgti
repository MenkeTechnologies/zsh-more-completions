#compdef dmgti
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/dmgti.html
# Create a Good Time Interval file from a table expression

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input timeline table file]:infile:_files' \
  'outfile=[output GTI file]:outfile:_files' \
  'userlimit=[GTI constraint expression]:userlimit:' \
  'mtlfile=[output copy of smoothed MTL]:mtlfile:_files' \
  'lkupfile=[lookup table of MTL columns]:lkupfile:_files' \
  'smooth=[apply smoothing factors]:smooth:(yes no)' \
  'clobber=[overwrite existing output]:clobber:(yes no)' \
  'verbose=[verbosity level 0-5]:verbose:(0 1 2 3 4 5)' \
  '*:argument:_files' && ret=0

return ret
