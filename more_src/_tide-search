#compdef tide-search
# Documentation: https://crux.ms/commands/tide-search.html
# Crux tide-search: search MS/MS spectra against a tide peptide index.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--precursor-window=[precursor matching tolerance]:value' \
  '--precursor-window-type=[units for precursor window]:type:(mass mz ppm)' \
  '--auto-precursor-window=[auto-estimate precursor window]:mode:(false warn fail)' \
  '--min-precursor-charge=[minimum charge state]:charge' \
  '--max-precursor-charge=[maximum charge state]:charge' \
  '--override-charges=[search all charge states]:bool:(T F)' \
  '--mz-bin-width=[bin size for m/z discretization]:width' \
  '--mz-bin-offset=[location of first bin left edge]:offset' \
  '--auto-mz-bin-width=[auto-estimate mz-bin-width]:mode:(false warn fail)' \
  '--fragment-tolerance=[mass tolerance (Da) for peak pair scoring]:tol' \
  '--isotope-error=[isotope error offsets]:list' \
  '--deisotope=[deisotope with ppm tolerance]:ppm' \
  '--min-peaks=[minimum peaks to search a spectrum]:n' \
  '--score-function=[scoring method]:fn:(xcorr combined-p-values)' \
  '--skip-preprocessing[skip spectrum preprocessing]' \
  '--remove-precursor-peak=[remove peaks around precursor m/z]:bool:(T F)' \
  '--remove-precursor-tolerance=[tolerance (Th) around precursor]:tol' \
  '--spectrum-min-mz=[lowest m/z to search]:mz' \
  '--spectrum-max-mz=[highest m/z to search]:mz' \
  '--scan-number=[single scan or range to search]:range' \
  '--use-flanking-peaks=[include flanking peaks]:bool:(T F)' \
  '--use-neutral-loss-peaks=[consider neutral loss ions]:bool:(T F)' \
  '--num-threads=[number of threads (0=auto)]:n' \
  '--concat=[report targets and decoys in one file]:bool:(T F)' \
  '--top-match=[matches to report per spectrum]:n' \
  '--spectrum-parser=[MS/MS file parser]:parser:(pwiz mstoolkit)' \
  '--use-z-line=[get precursor mass from Z line]:bool:(T F)' \
  '--store-index=[store generated binary index]:path:_files -/' \
  '--store-spectra=[store binarized spectra]:path:_files' \
  '--txt-output=[output tab-delimited results]:bool:(T F)' \
  '--pin-output=[output Percolator PIN file]:bool:(T F)' \
  '--pepxml-output=[output pepXML]:bool:(T F)' \
  '--mzid-output=[output mzIdentML]:bool:(T F)' \
  '--mztab-output=[output mzTab]:bool:(T F)' \
  '--sqt-output=[output SQT]:bool:(T F)' \
  '--mass-precision=[precision for masses in output]:n' \
  '--precision=[precision for scores in output]:n' \
  '--print-search-progress=[print progress every n spectra]:n' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--fileroot=[prefix for output filenames]:prefix' \
  '--overwrite=[replace existing files]:bool:(T F)' \
  '--parameter-file=[configuration file]:file:_files' \
  '--verbosity=[verbosity level 0-60]:level' \
  '*:spectra/index:_files' && ret=0

return ret
