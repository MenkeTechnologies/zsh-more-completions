#compdef pcp-vmstat
# Documentation: https://man.archlinux.org/search?q=pcp-vmstat
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[show active/inactive memory]' \
  '-d[show disk stats]' \
  '-f[show fork stats]' \
  '-s[show vm event counters]' \
  '-w[wide output]' \
  '-S+[size unit]:unit:(k K m M)' \
  '-A+[archive]:file:_files' \
  '-H+[host]:host:_hosts' \
  '-O+[origin]:time:' \
  '-Z+[timezone]:tz:' \
  '*:interval count:' && ret=0

return ret
