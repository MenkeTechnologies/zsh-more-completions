#compdef pcp-vmstat
# Documentation: https://man7.org/linux/man-pages/man1/pcp-vmstat.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-a+[retrieve metrics from PCP archive files]:archive:_files' \
  '--archive=[retrieve metrics from PCP archive files]:archive:_files' \
  '-A+[align initial sample to natural time boundary]:align:' \
  '--align=[align initial sample to natural time boundary]:align:' \
  '-g[start with pmtime GUI for archive replay]' \
  '--guimode[start with pmtime GUI for archive replay]' \
  '-h+[fetch metrics from pmcd on specified host]:host:_hosts' \
  '--host=[fetch metrics from pmcd on specified host]:host:_hosts' \
  '-H+[file containing hostnames]:hostsfile:_files' \
  '-K+[control DSO PMDAs for local context]:spec:' \
  '--spec-local=[control DSO PMDAs for local context]:spec:' \
  '-l[print last 7 characters of hostname]' \
  '-L[use local context without PMCD]' \
  '--local-PMDA[use local context without PMCD]' \
  '-n+[alternative Performance Metrics Name Space]:pmnsfile:_files' \
  '--namespace=[alternative Performance Metrics Name Space]:pmnsfile:_files' \
  '-O+[origin time within window]:time:' \
  '--origin=[origin time within window]:time:' \
  '-p+[attach to existing pmtime instance]:port:' \
  '--guiport=[attach to existing pmtime instance]:port:' \
  '-P[pause between updates for archive replay]' \
  '--pause[pause between updates for archive replay]' \
  '-s+[number of samples]:samples:' \
  '--samples=[number of samples]:samples:' \
  '-S+[restrict report to records at/after start time]:time:' \
  '--start=[restrict report to records at/after start time]:time:' \
  '-t+[reporting interval]:interval:' \
  '--interval=[reporting interval]:interval:' \
  '-T+[restrict report to records before/at end time]:time:' \
  '--finish=[restrict report to records before/at end time]:time:' \
  '-x[report extended CPU metrics]' \
  '-z[use host timezone]' \
  '--hostzone[use host timezone]' \
  '-Z+[timezone specification]:tz:' \
  '--timezone=[timezone specification]:tz:' \
  '*:interval count:' && ret=0

return ret
