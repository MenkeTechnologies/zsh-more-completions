#compdef autoexpect-bin
# _autoexpect-bin — autoexpect recorder shim (Don Libes); generates expect scripts from interactive sessions
# upstream: https://core.tcl-lang.org/expect

_autoexpect-bin() {
    _arguments \
        '-quiet[no banner]' \
        '-verbose[verbose]' \
        '-f+[output script]:file:_files -g "*.exp"' \
        '-promptmode[interactively prompt for prompt regex]' \
        '*::command:_command_names -e'
}

_autoexpect-bin "$@"
