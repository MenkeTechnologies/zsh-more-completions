#compdef getdns_query
# Documentation: https://man.archlinux.org/search?q=getdns_query
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-a[perform asynchronous resolution]' \
  '-A[address lookup (getdns_address)]' \
  '-B[batch mode (read queries from stdin)]' \
  '-c[print API information]' \
  '-D[set edns0 do bit]' \
  '-d[clear edns0 do bit]' \
  '-F+[read from file]:file:_files' \
  '-G[general lookup]' \
  '-H+[hostname lookup]:host:_hosts' \
  '-i[print API information and quit]' \
  '-I[interactive mode]' \
  '-j[output as JSON]' \
  '-J[output as JSON pretty-printed]' \
  '-k[print root trust anchors]' \
  '-K+[set pubkey pinset file]:file:_files' \
  '-n[batch synchronous mode]' \
  '-p[pretty-print response]' \
  '-P+[transport protocol]:proto:(UDP TCP TLS UDP_FIRST_AND_FALL_BACK_TO_TCP TCP_ONLY TLS_ONLY)' \
  '-q[quiet]' \
  '-r[resolution type recursing]' \
  '-R+[set retransmission timeout]:ms:' \
  '-s[resolution type stub]' \
  '-S[service lookup]' \
  '-t+[set timeout]:ms:' \
  '-T+[set transport]:proto:' \
  '-u[use UDP only]' \
  '-U[use UDP with fallback to TCP]' \
  '-x[do not follow CNAMEs]' \
  '-X[suppress dnssec status output]' \
  '-z+[lookup zone]:zone:' \
  '-Z+[set DNSSEC trust anchors]:file:_files' \
  '@+[set upstream DNS]:server:_hosts' \
  '+specify_class=+[query class]:class:(IN CH HS NONE ANY)' \
  '+dnssec_return_status[return DNSSEC validation status]' \
  '+dnssec_return_only_secure[return only secure responses]' \
  '+return_call_reporting[report call timings]' \
  '*:name:' && ret=0

return ret
