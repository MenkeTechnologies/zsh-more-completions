#compdef brew-cask
# _brew-cask — Homebrew Cask GUI macOS app installer subcommand alias (Homebrew team, Ruby); custom argparse
# upstream: https://github.com/Homebrew/homebrew-cask

_brew-cask() {
    local -a sub=(
        'install:install casks'
        'uninstall:uninstall casks'
        'reinstall:reinstall casks'
        'upgrade:upgrade installed casks'
        'list:list installed casks'
        'outdated:list outdated casks'
        'info:show cask info'
        'fetch:download cask without install'
        'audit:audit cask'
        'cat:print cask file'
        'create:create new cask'
        'doctor:diagnose cask state'
        'edit:edit cask'
        'home:open cask homepage'
        'style:check cask style'
        'zap:remove all files installed by cask'
        'search:search casks'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-quarantine[no quarantine]' \
        '--force[force]' \
        '-f[force]' \
        '--require-sha[require sha]' \
        '--skip-cask-deps[skip cask deps]' \
        '--no-binaries[no binaries]' \
        '--language=+[language]:str:' \
        '--appdir=+[appdir]:dir:_files -/' \
        '--colorpickerdir=+[colorpickerdir]:dir:_files -/' \
        '--prefpanedir=+[prefpanedir]:dir:_files -/' \
        '--qlplugindir=+[qlplugindir]:dir:_files -/' \
        '--mdimporterdir=+[mdimporterdir]:dir:_files -/' \
        '--dictionarydir=+[dictionarydir]:dir:_files -/' \
        '--fontdir=+[fontdir]:dir:_files -/' \
        '--servicedir=+[servicedir]:dir:_files -/' \
        '--input-methoddir=+[input-methoddir]:dir:_files -/' \
        '--internet-plugindir=+[internet-plugindir]:dir:_files -/' \
        '--screen-saverdir=+[screen-saverdir]:dir:_files -/' \
        '--audio-unit-plugindir=+[audio-unit-plugindir]:dir:_files -/' \
        '--vst-plugindir=+[vst-plugindir]:dir:_files -/' \
        '--vst3-plugindir=+[vst3-plugindir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'brew cask subcommand' sub ;;
        args)
            case $words[1] in
                install|reinstall|uninstall|info|outdated|fetch|home|search|audit|cat|edit|zap) _arguments '*:cask:' ;;
                list) _arguments \
                    '--full-name[show full names]' \
                    '-1[one per line]' ;;
                create) _arguments '*:token:' ;;
                style) _arguments \
                    '--fix[fix violations]' \
                    '*:cask:' ;;
            esac
            ;;
    esac
}

_brew-cask "$@"
