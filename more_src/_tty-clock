#compdef tty-clock

# Zsh completion for tty-clock - terminal clock display

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-s[show seconds]' \
  '-S[screensaver mode]' \
  '-b[bold font]' \
  '-c[center clock]' \
  '-C+[set color (0-7)]:color:(0 1 2 3 4 5 6 7)' \
  '-f+[time format string]:format' \
  '-t[12-hour format]' \
  '-B[enable blinking colon]' \
  '-r[rainbow mode]' \
  '-n[no title bar]' \
  '-D[date mode]' \
  '-d+[delay between updates in seconds]:delay' \
  '-x+[x position]:x position' \
  '-y+[y position]:y position'
