#compdef pcp-numastat
# _pcp-numastat — PCP-based NUMA memory statistics (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/numastat/pcp-numastat.1 SYNOPSIS.

_pcp-numastat() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)-V[show version]' \
        '-m[show memory information]' \
        '-n[show numeric node IDs]' \
        '-w+[column width]:n:' \
        '*-p+[per-process NUMA stats]:process:'
}

_pcp-numastat "$@"
