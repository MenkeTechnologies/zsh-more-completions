#compdef webcrack
# Documentation: https://man.archlinux.org/search?q=webcrack
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output directory for bundled files]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[overwrite output directory]' \
  '(-m --mangle)'{-m,--mangle}'[mangle variable names]' \
  '--no-jsx[do not decompile JSX]' \
  '--no-unpack[do not extract modules from the bundle]' \
  '--no-deobfuscate[do not deobfuscate code]' \
  '--no-unminify[do not unminify code]' \
  '*::file:_files -g "*.{js,mjs,cjs,html}"' && ret=0

return ret
