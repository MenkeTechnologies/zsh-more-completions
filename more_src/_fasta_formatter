#compdef fasta_formatter
# Documentation: https://manpages.debian.org/testing/fastx-toolkit/fasta_formatter.1.en.html
# FASTX-Toolkit: reformat (re-wrap or tabulate) a FASTA file

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-w+[max sequence line width for output (0 = single line)]:width' \
  '-t[output tabulated format instead of FASTA]' \
  '-e[output empty sequences (default is to discard them)]' \
  '-i+[FASTA/Q input file (default STDIN)]:input file:_files' \
  '-o+[FASTA/Q output file (default STDOUT)]:output file:_files' && ret=0

return ret
