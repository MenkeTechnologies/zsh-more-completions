#compdef keptn

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'abort:stop running sequence execution'
  'add-resource:add config resources to a project'
  'auth:authenticate with Keptn'
  'completion:generate shell completion scripts'
  'configure:configure Keptn settings'
  'create:create projects, services, or secrets'
  'delete:remove projects, services, or secrets'
  'generate:generate documentation, specs, or support archives'
  'get:retrieve info about Keptn resources'
  'install:install Keptn on Kubernetes'
  'pause:pause sequence execution'
  'resume:resume paused sequences'
  'send:send events to Keptn'
  'set:set configuration values'
  'status:display Keptn status'
  'trigger:initiate delivery sequences or evaluations'
  'uninstall:remove Keptn from Kubernetes'
  'update:modify projects or secrets'
  'upgrade:update Keptn installation'
  'version:show CLI version'
)

_arguments -C \
  '--config-file=[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '--mock[mock mode]' \
  '(-n --namespace)'{-n,--namespace=}'[namespace]:namespace:' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-y --yes)'{-y,--yes}'[assume yes]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'keptn subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _values 'create target' 'project' 'service' 'secret' && ret=0
        ;;
      (trigger)
        _values 'trigger target' 'delivery' 'evaluation' 'sequence' && ret=0
        ;;
      (get)
        _values 'get target' 'event' 'project' 'secret' 'service' 'stage' && ret=0
        ;;
      (delete)
        _values 'delete target' 'project' 'service' 'secret' && ret=0
        ;;
      (update)
        _values 'update target' 'project' 'secret' && ret=0
        ;;
      (install)
        _arguments \
          '(-c --creds)'{-c,--creds=}'[creds file]:file:_files' \
          '--endpoint-service-type=[service type]:type:(ClusterIP LoadBalancer NodePort)' \
          '--hide-sensitive-data[hide sensitive data]' \
          '(-s --insecure-skip-tls-verify)'{-s,--insecure-skip-tls-verify}'[skip TLS verify]' \
          '(-p --platform)'{-p,--platform=}'[platform]:platform:(kubernetes openshift)' \
          '(-u --use-case)'{-u,--use-case=}'[use case]:case:' && ret=0
        ;;
      (auth)
        _arguments \
          '(-a --api-token)'{-a,--api-token=}'[API token]:token:' \
          '(-e --endpoint)'{-e,--endpoint=}'[endpoint URL]:url:' \
          '(-c --export)'{-c,--export}'[export credentials]' \
          '--oauth[use OAuth]' \
          '--oauth-client-id=[OAuth client id]:id:' \
          '--oauth-client-secret=[OAuth client secret]:secret:' \
          '--oauth-discovery=[OAuth discovery URL]:url:' \
          '--oauth-logout[OAuth logout]' \
          '--oauth-scopes=[OAuth scopes]:scopes:' \
          '(-s --secure)'{-s,--secure}'[secure mode]' \
          '(-i --skip-namespace-listing)'{-i,--skip-namespace-listing}'[skip namespace listing]' && ret=0
        ;;
    esac
    ;;
esac

return ret
