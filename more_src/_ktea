#compdef ktea
# Documentation: https://man.archlinux.org/search?q=ktea
# Reference accessed: 2026-05-16

# Zsh completion for ktea — Kafka TUI (github.com/jonas-grgt/ktea)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--config[path to config file]:file:_files' && ret=0

return ret
