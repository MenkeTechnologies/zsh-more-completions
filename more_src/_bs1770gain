#compdef bs1770gain

local -a arguments

arguments=(
  '--ebu[EBU R128 mode (default)]'
  '--atsc[ATSC A/85 mode]'
  '--replaygain[ReplayGain 2.0 mode]'
  '-a[album / integrated loudness mode]'
  '-b[audio file mode (individual files)]'
  '(-o --output)'{-o,--output}'=[output folder]:directory:_files -/'
  '--suffix=[output file suffix]:suffix:'
  '(-i --integrated)'{-i,--integrated}'[show integrated loudness]'
  '(-s --shortterm)'{-s,--shortterm}'[show short-term loudness]'
  '(-m --momentary)'{-m,--momentary}'[show momentary loudness]'
  '(-r --range)'{-r,--range}'[show loudness range]'
  '(-p --truepeak)'{-p,--truepeak}'[show true peak]'
  '--samplepeak[show sample peak]'
  '--norm=[target loudness in LUFS]:lufs:'
  '--preamp=[pre-amplification in dB]:dB:'
  '--drc=[dynamic range compression ratio]:ratio:'
  '--apply[apply gain to output files]'
  '--stereo[downmix to stereo]'
  '(-l --lfe)'{-l,--lfe}'=[LFE channel weight]:weight:'
  '--xml[output results as XML]'
  '--time[show processing time]'
  '(-h --help)'{-h,--help}'[show help]'
  '-V[show version]'
  '*:audio file:_files -g "*.(mp3|flac|ogg|opus|m4a|wav|aiff|wv|ape)"'
)

_arguments -s -S $arguments
