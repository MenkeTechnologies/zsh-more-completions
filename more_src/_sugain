#compdef sugain
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/amplitudes/sugain.c
# SUGAIN - apply various types of gain

local ret=1

_arguments -s -S \
  'panel=[=1 gain whole data set]:p:(0 1)' \
  'tpow=[multiply data by t^tpow]:t:' \
  'epow=[multiply data by exp(epow*t)]:e:' \
  'etpow=[multiply data by exp(epow*t^etpow)]:e:' \
  'gpow=[take signed gpow-th power of scaled data]:g:' \
  'agc=[1 = automatic gain control]:a:(0 1)' \
  'gagc=[1 = agc with gaussian taper]:g:(0 1)' \
  'wagc=[agc window in seconds]:w:' \
  'trap=[zero values whose magnitude exceeds trapval]:t:' \
  'clip=[clip values whose magnitude exceeds clipval]:c:' \
  'pclip=[clip any value greater than clipval]:p:' \
  'nclip=[clip any value less than clipval]:n:' \
  'qclip=[clip by quantile on absolute values]:q:' \
  'qbal=[1 = balance traces by qclip and scale]:q:(0 1)' \
  'pbal=[1 = balance traces by dividing by rms]:p:(0 1)' \
  'mbal=[1 = balance by subtracting the mean]:m:(0 1)' \
  'maxbal=[1 = balance by subtracting the max]:m:(0 1)' \
  'scale=[multiply data by overall scale factor]:s:' \
  'norm=[divide data by overall scale factor]:n:' \
  'bias=[bias data by adding an overall bias value]:b:' \
  'jon=[1 means tpow=2 gpow=.5 qclip=.95]:j:(0 1)' \
  'verbose=[=1 echoes info]:v:(0 1)' \
  'mark=[apply gain by tr.mark flag]:m:(0 1)' \
  'vred=[reducing velocity for use with tpow]:v:' \
  'tmpdir=[directory path for temp files]:dir:_files -/' \
  '*:SU file:_files' && ret=0

return ret
