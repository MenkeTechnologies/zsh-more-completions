#compdef ricochet-refresh

# Ricochet Refresh: anonymous Tor-based instant messenger
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--profile=[profile directory]:dir:_files -/' \
  '--debug[enable debug logging]' \
  '*::ricochet-refresh args:_files' && ret=0
return ret
