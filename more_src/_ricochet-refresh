#compdef ricochet-refresh
# Documentation: https://github.com/blueprint-freespeech/ricochet-refresh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ricochet-refresh: anonymous IM client over Tor (Ricochet successor)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--debug[verbose logging]' \
  '*::ricochet-refresh args:_files' && ret=0
return ret
