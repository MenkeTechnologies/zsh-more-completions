        '*-pkg[packages to load before running tests]:pkg:' \
        '*-flags[compile-time flags as symbols]:flag symbol:' \
        '*-named[run only tests with these names]:test name:' \
        '*-tagged[run only tests with these tags]:tag:' \
        '*-not-tagged[exclude tests with these tags]:tag:' \
        '-log[write test log to file]:log file:_files' \
        '(- *)-help[show help for run-test]' \
        '*:source file:_files -g "*.stanza"'
}

(( $+functions[_stanza_analyze_dependencies] )) ||
_stanza_analyze_dependencies() {
    _arguments \
        '-o[output dependency report file]:report:_files' \
        '-graphviz[output GraphViz DOT file]:dot file:_files -g "*.dot"' \
        '-build-target[analyze a proj build target instead of files]' \
        '-pkg[restrict analysis to .pkg dir]:pkg dir:_files -/' \
        '(- *)-help[show help for analyze-dependencies]' \
        '*:source/target:_files -g "*.(stanza|proj)"'
}

(( $+functions[_stanza_doc] )) ||
_stanza_doc() {
    _arguments \
        '-o[output documentation directory (required)]:output dir:_files -/' \
        '-pkg-filter[regex pattern for packages to include]:pattern:' \
        '-fig-filter[regex pattern for figures to include]:pattern:' \
        '-toc-renamer[TOC rename mapping file]:file:_files' \
        '-trace[emit trace logs during doc generation]' \
        '-platform[target platform]:platform:_stanza_platforms' \
        '-build-target[generate docs from proj build target]' \
        '(- *)-help[show help for doc]' \
        '*:source file:_files -g "*.(stanza|proj)"'
}

(( $+functions[_stanza_definitions_database] )) ||
_stanza_definitions_database() {
    _arguments \
        '-o[output definitions-database file (required)]:db file:_files' \
        '-merge-with[merge into existing definitions database]:existing db:_files' \
        '*-stanza-files[stanza source files to include]:source file:_files -g "*.stanza"' \
        '(- *)-help[show help for definitions-database]'
}

(( $+functions[_stanza_check_docs] )) ||
_stanza_check_docs() {
    _arguments \
        '-accept[accept changes to doc snapshots]' \
        '(- *)-help[show help for check-docs]' \
        '*:source file:_files -g "*.(stanza|proj)"'
}

_stanza "$@"
