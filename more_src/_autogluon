#compdef autogluon autogluon-cli
# _autogluon — Amazon AutoGluon multi-modal automated machine learning toolkit tabular vision time-series text (autogluon team, Python); argparse
# upstream: https://github.com/autogluon/autogluon

_autogluon() {
    local -a sub=(
        'fit:train a model'
        'predict:make predictions'
        'evaluate:evaluate a model'
        'tabular:tabular subcommands'
        'multimodal:multimodal subcommands'
        'vision:vision subcommands'
        'timeseries:time-series subcommands'
        'text:text subcommands'
        'serve:serve a model'
        'deploy:deploy a model'
        'cloud:cloud subcommands'
        'info:show installation info'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--time-limit=+[seconds]:n:' \
        '--presets=+[preset]:p:(best_quality high_quality medium_quality good_quality interpretable optimize_for_deployment ignore_text)' \
        '--num-gpus=+[N]:n:' \
        '--num-cpus=+[N]:n:' \
        '--memory-limit=+[GiB]:f:' \
        '--seed=+[N]:n:' \
        '--verbosity=+[level]:l:(0 1 2 3 4)' \
        '--debug[debug mode]' \
        '--output=+[model save path]:dir:_files -/' \
        '-o+[model save path]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'autogluon subcommand' sub ;;
        args)
            case $words[1] in
                fit) _arguments \
                    '--train-data=+[train data]:file:_files -g "*.csv *.parquet *.pkl *.json"' \
                    '--tuning-data=+[tuning data]:file:_files' \
                    '--label=+[target column]:str:' \
                    '--eval-metric=+[metric]:str:' ;;
                predict|evaluate) _arguments \
                    '--model-path=+[model dir]:dir:_files -/' \
                    '--data=+[data file]:file:_files' ;;
                tabular|multimodal|vision|timeseries|text) _arguments '1:cmd:(fit predict evaluate transform)' ;;
                cloud) _arguments '1:cloud cmd:(deploy invoke list delete)' ;;
            esac
            ;;
    esac
}

_autogluon "$@"
