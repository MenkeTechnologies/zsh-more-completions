#compdef git-quiltimport
# Documentation: https://git-scm.com/docs/git-quiltimport
# Source: git/git git-quiltimport.sh — apply a series of patches from a quilt patchset (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--author=-[author name <email> for patches without any]:author:_default' \
    '(-n --dry-run)'{-n,--dry-run}'[show what would happen without applying]' \
    '--patches=-[path to the quilt patches]:dir:_files -/' \
    '--series=-[path to the quilt series file]:file:_files' \
    '--keep-non-patch[keep non-patch hunks too]' \
    && ret=0

return ret
