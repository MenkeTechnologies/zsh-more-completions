#compdef shadow-cljs

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'compile:compile a build once'
  'watch:compile and watch a build'
  'release:make release build'
  'check:check a build for errors'
  'server:start the shadow-cljs server'
  'start:start server in background'
  'stop:stop the running server'
  'restart:restart the server'
  'cli-info:show CLI info'
  'info:show project info'
  'pom:print POM'
  'classpath:print classpath'
  'cljs-repl:open ClojureScript REPL'
  'clj-repl:open Clojure REPL'
  'node-repl:open standalone Node.js REPL'
  'browser-repl:open browser REPL'
  'run:run a function'
  'help:show help'
  'init:initialise shadow-cljs.edn'
  'aot-clear-cache:clear AOT cache'
  'npm-deps:print npm deps'
  'project-info:project info'
  'pkg-info:package info'
  'release-snapshot:release snapshot'
  'create-pom:create POM'
  'install:install npm deps'
  'outdated:check outdated deps'
  'test:run tests'
  'test-once:run tests once'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-A --aliases)'{-A+,--aliases=}'[deps.edn aliases]:aliases:' \
  '--config=[shadow-cljs.edn config]:file:_files' \
  '--cli-info[CLI info]' \
  '--source-maps[enable source maps]' \
  '--pseudo-names[pseudo names]' \
  '--force-spawn[force spawn]' \
  '--debug-port=[nrepl debug port]:port:' \
  '--ssh[connect to remote server via ssh]' \
  '--via=[transport]:t:(socket http embedded)' \
  '--no-color[disable colored output]' \
  '--verbose[verbose output]' \
  '--config-merge=[merge edn into config]:edn:' \
  '*-X+[deps.edn aliases]:alias:' \
  '*-D+[deps.edn aliases]:alias:' \
  '*-J+[JVM opts]:opt:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'shadow-cljs command' commands && ret=0 ;;
esac

return ret
