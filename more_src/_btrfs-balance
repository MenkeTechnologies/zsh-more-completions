#compdef btrfs-balance
# _btrfs-balance — btrfs-progs btrfs balance (rebalance chunks across the underlying btrfs devices; start/pause/resume/cancel/status subcommands; -d data, -m metadata, -s system filters with optional convert= and profile filters (raid0/raid1/raid1c3/raid1c4/raid5/raid6/raid10/single/dup))
# upstream: https://github.com/kdave/btrfs-progs
# Subcommands from btrfs-progs cmds/balance.c on tip.

_btrfs-balance() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'balance command' '(start status pause cancel resume)' ;;
        args)
            case $line[1] in
                start) _arguments \
                    '-d+[data filters]:filters:(convert profiles soft usage devid drange vrange limit stripes)' \
                    '-m+[metadata filters]:filters:' \
                    '-s+[system filters]:filters:' \
                    '-f[force convert to dup/single]' \
                    '--enqueue[queue if another balance running]' \
                    '--full-balance[full balance]' \
                    '--background[run in background]' \
                    '-v[verbose]' \
                    '*:filesystem:_files -/' ;;
                status) _arguments '-v[verbose]' '*:filesystem:_files -/' ;;
                cancel|pause|resume) _arguments '*:filesystem:_files -/' ;;
            esac
            ;;
    esac
}

_btrfs-balance "$@"
