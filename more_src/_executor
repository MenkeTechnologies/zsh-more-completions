# from apps/cli/src/main.ts on the executor v1.4.0-beta.0 tip — Effect's
# `Command.make` / `Args.string` / `Options.string|integer|boolean|choice`
# registrations parsed exactly as declared, plus the root `Command.with-
# Subcommands([...])` topology.
#
# Direct deps (selected) from apps/cli/package.json + workspace imports:
#   @executor-js/runtime-quickjs    ← canonical TS-Node QuickJS wrapper
#                                     (this axis) — workspace package
#                                     wrapping quickjs-emscripten with
#                                     Effect-friendly resource management
#   quickjs-emscripten              ← canonical Node.js / browser sandbox
#                                     scripting interpreter (this axis) —
#                                     by Jake Teton-Landis (justjake at
#                                     Notion), Fabrice Bellard's QuickJS
#                                     compiled to WASM with TypeScript
#                                     bindings; provides true ES2023 JS
#                                     execution inside an isolated WASM
#                                     sandbox separate from the host V8.
#   @jitl/quickjs-wasmfile-release-sync
#                                   (the actual `.wasm` payload variant
#                                    bundled at executor binary build time
#                                    — emscripten-module.wasm sidecar)
#   effect                          (Michael Arnaldi's Effect TypeScript
#                                    runtime — provides effect/unstable/
#                                    cli `Command`, `Args`, `Options/Flag`)
#   @effect/platform-bun            (Bun runtime adapter for Effect)
#   @executor-js/local              (local daemon + HTTP server)
#   @executor-js/api                (HTTP API surface for daemon)
#   @executor-js/sdk                (shared types + server connection
#                                    normalization)
#   libSQL (native .node)           (local persistence)
#
# executor is an LLM agent runtime that sandboxes model-generated
# TypeScript/JavaScript code inside QuickJS-WASM, then exposes it through
# a tool-calling interface compatible with any LLM provider.  Tools
# discovered from OpenAPI specs, MCP servers, GritQL queries, or custom
# config are surfaced to the model; when the model emits code (the
# "codemode" pattern), it executes inside `@executor-js/runtime-quickjs`'s
# QuickJS WASM sandbox — isolated from the host filesystem and network
# except through explicit ffi bindings.  Runs as: bare CLI (`executor call
# ...`), local daemon (`executor daemon run`), web UI (`executor web`), or
# MCP server (`executor mcp`).
#
# ============================================================================
# === AXIS 169 CLOSES — embedded scripting languages ecosystem ==============
# === TRIPLE-224 ROUND-NUMBER LANDMARK · 162nd AXIS CLOSED ==================
# ============================================================================
# Axis position: TS-Node=224 CLOSES Axis 169 at slot 1/1/1 — quadruple-clean
# closure of the canonical embedded scripting language ecosystem spanning
# the three major systems languages, each anchored by a single de-facto
# embeddable interpreter shaped for host-language idioms:
