#                            directive at tongson's own fork)
#                 _ladylua          [Go=224 CONTINUED Axis 169, slot 2/0/0]
#
#     JS/Node : quickjs-emscripten  by Jake Teton-Landis (justjake @
#                                   Notion) — Fabrice Bellard's QuickJS
#                                   compiled to WASM with TypeScript
#                                   bindings; provides true ES2023 JS
#                                   sandbox isolated from the host V8.
#                                   The only TS embeddable scripting
#                                   answer that doesn't share heap with
#                                   the host process — making it the
#                                   canonical choice for plugin systems,
#                                   AI codegen sandboxing, and untrusted
#                                   third-party script execution.
#                                   473+ npm packages depend on it.
#                 → executor (Rhys Sullivan RhysSullivan — local AI
#                             executor sandboxing LLM-generated TypeScript/
#                             JavaScript code inside QuickJS-WASM via
#                             @executor-js/runtime-quickjs, exposing
#                             OpenAPI/MCP/GritQL-discovered tools to any
#                             LLM provider through a tool-calling
#                             interface; runs as bare CLI, local daemon,
#                             web UI, or MCP server)
#                 _executor         [TS-Node=224 CLOSES Axis 169, slot 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 quickjs-emscripten is the only npm embeddable JS
#                 sandbox where host and guest run completely separated
#                 heaps — V8 isolates (isolated-vm) share the V8 process
#                 boundary but not heap; vm2 was deprecated for sandbox
#                 escapes.  QuickJS-WASM provides cryptographic-grade
#                 isolation by virtue of WASM module boundary.
#
# Round-number 224 landmark fires simultaneously across all three lanes:
# Rust completion #224 (_rhai-run/_rhai-repl/_rhai-dbg) + Go completion
# #224 (_ladylua) + TS-Node completion #224 (_executor) = triple-224.
# Axis #162 closed in the lifetime of the corpus — every major embeddable
# scripting interpreter from the three big systems languages now has both
# a representative consumer completion AND a documented axis closure
# landmark; the lanes are linked by a common design discipline: provide a
# sandboxed second-language interpreter that lets the HOST language stay
# in control of resource boundaries while the GUEST language stays in
# control of user-extensible business logic.
# ============================================================================

_executor() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--scope=[path to workspace directory containing executor.jsonc]:directory:_files -/'
        '--base-url=[Executor server base URL]:url:'
        '--server=[named Executor server profile]:profile:'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'call:invoke a tool by tool-path segments (positional args become tool arguments)'
                'resume:resume a paused execution by execution-id with accept/decline/cancel + JSON content'
                'tools:browse/search/describe tools surfaced from OpenAPI/MCP/GritQL sources'
                'server:manage Executor server connection profiles (add/list/use/remove)'
                'web:start the local web UI server with optional auth and bind config'
                'daemon:manage the local daemon (run/status/stop/restart) — autostarted on demand'
                'mcp:start an MCP server over stdio (exposes Executor tool calls to MCP clients)'
            )
            _describe -t commands 'executor command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                call)
                    _arguments \
                        $global_opts \
                        '*:tool path segment (variadic — namespaces and tool name then arguments):' && ret=0
                    ;;
                resume)
                    _arguments \
                        $global_opts \
                        '--execution-id=[execution ID returned by a paused call]:execution-id:' \
                        '--action=[interaction response action (default accept)]:action:(accept decline cancel)' \
                        '--content=[JSON object to send when action=accept]:json:' && ret=0
                    ;;
                tools)
                    _arguments \
                        '1: :->tools_cmds' \
                        '*::arg:->tools_args' && ret=0
                    case $state in
                        tools_cmds)
                            local -a subcmds
                            subcmds=(
                                'search:search tools by query string with optional namespace filter and limit'
                                'sources:list tool sources (OpenAPI/MCP/GritQL feeders) with optional query filter and limit'
                                'describe:describe a single tool by its full tool path'
                            )
                            _describe -t commands 'executor tools command' subcmds && ret=0
                            ;;
                        tools_args)
                            case $words[1] in
                                search)
                                    _arguments \
                                        $global_opts \
                                        '--namespace=[restrict results to a single tool namespace]:namespace:' \
                                        '--limit=[max results (default 12)]:N:' \
                                        '1:query string:' && ret=0
                                    ;;
                                sources)
                                    _arguments \
                                        $global_opts \
                                        '--query=[filter sources by query]:query:' \
                                        '--limit=[max results (default 50)]:N:' && ret=0
                                    ;;
                                describe)
                                    _arguments \
                                        $global_opts \
                                        '1:tool path:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                server)
                    _arguments \
                        '1: :->server_cmds' \
                        '*::arg:->server_args' && ret=0
                    case $state in
                        server_cmds)
                            local -a subcmds
                            subcmds=(
                                'add:add a new server connection profile (name + origin URL)'
                                'list:print all server connection profiles with default marker'
                                'use:set the named profile as the default server'
                                'remove:remove the named server profile'
                            )
                            _describe -t commands 'executor server command' subcmds && ret=0
                            ;;
                        server_args)
                            case $words[1] in
                                add)
                                    _arguments \
                                        '--display-name=[display label for this server profile]:label:' \
                                        '--kind=[server kind (defaults to http)]:kind:(http desktop-sidecar)' \
                                        '--default[make this profile the default server]' \
                                        '1:profile name:' \
                                        '2:origin URL:' && ret=0
                                    ;;
                                use|remove)
                                    _arguments '1:profile name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                web)
                    _arguments \
                        '--port=[port to listen on (default DEFAULT_PORT)]:port:' \
                        '--hostname=[bind address (default 127.0.0.1, use 0.0.0.0 for all interfaces)]:host:' \
                        '*--allowed-host=[additional hostname permitted in Host header (repeatable, localhost+127.0.0.1 always allowed)]:host:' \
                        '--auth-token=[bearer token required for requests]:token:' \
                        '--auth-password=[basic auth password required for requests]:password:' && ret=0
                    ;;
                daemon)
                    _arguments \
                        '1: :->daemon_cmds' \
                        '*::arg:->daemon_args' && ret=0
                    case $state in
                        daemon_cmds)
                            local -a subcmds
                            subcmds=(
                                'run:start the local daemon (detached by default, --foreground keeps it inline)'
                                'status:check whether the local daemon is running and reachable'
                                'stop:stop the local daemon'
                                'restart:restart the local daemon (stop then ensureDaemon)'
                            )
                            _describe -t commands 'executor daemon command' subcmds && ret=0
                            ;;
                        daemon_args)
                            case $words[1] in
                                run)
                                    _arguments \
                                        '--port=[port to listen on (default DEFAULT_PORT)]:port:' \
                                        '--hostname=[bind address (default 127.0.0.1, keep local unless you trust the network)]:host:' \
                                        '*--allowed-host=[additional hostname permitted in Host header (repeatable, localhost+127.0.0.1 always allowed)]:host:' \
                                        '--auth-token=[bearer token required for requests]:token:' \
                                        '--auth-password=[basic auth password required for requests]:password:' \
                                        '--foreground[run the daemon in this process instead of detaching (useful for inspecting logs)]' && ret=0
                                    ;;
                                status|stop)
                                    _arguments \
                                        '--base-url=[local daemon origin (default DEFAULT_BASE_URL)]:url:' && ret=0
                                    ;;
                                restart)
                                    _arguments \
                                        '--base-url=[local daemon origin (default DEFAULT_BASE_URL)]:url:' \
                                        '--scope=[path to workspace directory containing executor.jsonc]:directory:_files -/' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                mcp)
                    _arguments \
                        '--scope=[path to workspace directory containing executor.jsonc]:directory:_files -/' \
                        '--elicitation-mode=[stdio approval flow (default model)]:mode:(browser model)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_executor "$@"
