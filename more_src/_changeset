#compdef changeset

# Zsh completion for Changesets CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--empty[create an empty changeset]' \
  '--open[open created changeset in editor]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'add:Add a new changeset'
      'version:Apply changesets and update versions'
      'publish:Publish changed packages to npm'
      'status:Show current changeset status'
      'pre:Enter or exit pre-release mode'
      'tag:Create git tags for published packages'
      'init:Initialize changesets in a project'
    )
    _describe -t commands 'changeset command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      version)
        _arguments -s -S \
          '--snapshot=[create snapshot release]:tag' \
          '--no-changelog[skip changelog generation]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '--otp=[one-time password for npm]:otp' \
          '--tag=[npm dist-tag]:tag' \
          '--no-git-tag[do not create git tags]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      status)
        _arguments -s -S \
          '--since=[show changes since ref]:git ref' \
          '--output=[write status to file]:output file:_files' \
          '--verbose[show verbose output]' \
          '-h[show help]' \
          '--help[show help]' && ret=0
        ;;
      pre)
        _arguments -s -S \
          '-h[show help]' \
          '--help[show help]' \
          '1:action:(enter exit)' \
          '2:pre-release tag' && ret=0
        ;;
    esac
    ;;
esac

return ret
