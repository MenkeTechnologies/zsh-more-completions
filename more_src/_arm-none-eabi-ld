#compdef arm-none-eabi-ld
# _arm-none-eabi-ld — Arm Limited arm-none-eabi-ld CLI for the bare-metal ARM cross-linker producing ELF binaries linker scripts symbol resolution garbage collection sections relax memory regions output (arm team, C); getopt
# upstream: https://developer.arm.com/Tools%20and%20Software/GNU%20Toolchain

_arm-none-eabi-ld() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-A+[set arch]:str:' \
        '--architecture=+[set arch]:str:' \
        '-b+[target]:str:' \
        '--format=+[target]:str:' \
        '-e+[entry]:str:' \
        '--entry=+[entry]:str:' \
        '-E[export dynamic]' \
        '--export-dynamic[export dynamic]' \
        '-f+[auxiliary]:str:' \
        '-F+[filter]:str:' \
        '-G+[max size]:n:' \
        '-i[incremental]' \
        '-l+[library]:str:' \
        '--library=+[library]:str:' \
        '-L+[search dir]:dir:_files -/' \
        '--library-path=+[search dir]:dir:_files -/' \
        '-M[link map]' \
        '--print-map[link map]' \
        '-n[no page align]' \
        '--nmagic[no page align]' \
        '-N[set text and data]' \
        '--omagic[set text and data]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-O+[optimization level]:n:' \
        '-q[emit relocs]' \
        '--emit-relocs[emit relocs]' \
        '-r[relocatable]' \
        '--relocatable[relocatable]' \
        '-R+[symbol-table]:file:_files' \
        '-s[strip-all]' \
        '--strip-all[strip-all]' \
        '-S[strip-debug]' \
        '--strip-debug[strip-debug]' \
        '-t[trace files]' \
        '--trace[trace files]' \
        '-T+[script]:file:_files -g "*.ld"' \
        '--script=+[script]:file:_files -g "*.ld"' \
        '-u+[undefined symbol]:str:' \
        '--undefined=+[undefined symbol]:str:' \
        '-x[discard all locals]' \
        '--discard-all[discard all locals]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-y+[symbol]:str:' \
        '--trace-symbol=+[symbol]:str:' \
        '-Y+[default search path]:dir:_files -/' \
        '-Bstatic[static]' \
        '-Bdynamic[dynamic]' \
        '-EB[big endian]' \
        '-EL[little endian]' \
        '--build-id[build id]' \
        '--gc-sections[garbage collect sections]' \
        '--no-gc-sections[no garbage collect sections]' \
        '--print-gc-sections[print gc sections]' \
        '--cref[cross reference]' \
        '*:object files:_files -g "*.o *.a *.so *.elf"'
}

_arm-none-eabi-ld "$@"
