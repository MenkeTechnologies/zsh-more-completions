#compdef maple maplesoft xmaple cmaple
# _maple — Maplesoft Maple symbolic and numerical mathematical computing environment for engineers researchers (maplesoft team, C/Java); custom argparse
# upstream: https://www.maplesoft.com

_maple() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[secure mode no system calls]' \
        '--secure[secure mode no system calls]' \
        '-t+[time limit seconds]:n:' \
        '--time-limit=+[time limit seconds]:n:' \
        '-T+[CPU time limit]:n:' \
        '--cpu-time=+[CPU time limit]:n:' \
        '-i+[input file]:file:_files -g "*.mpl *.mw *.maple"' \
        '--input=+[input file]:file:_files -g "*.mpl *.mw *.maple"' \
        '-l+[command file]:file:_files' \
        '--lib=+[library file]:file:_files' \
        '-b+[base library]:dir:_files -/' \
        '--base=+[base library]:dir:_files -/' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-n[no init]' \
        '--no-init[no init]' \
        '-p+[plot driver]:p:(java jvm dx postscript x11 cmaple inline none)' \
        '--plot=+[plot driver]:p:(java jvm dx postscript x11 cmaple inline none)' \
        '-A+[autosaves seconds]:n:' \
        '--autosave=+[autosaves seconds]:n:' \
        '-r+[restart file]:file:_files' \
        '--restart=+[restart file]:file:_files' \
        '-w+[warning level]:l:(0 1 2 3)' \
        '--warnlevel=+[warning level]:l:(0 1 2 3)' \
        '-z+[hardware mode]:m:(software hardware)' \
        '--hardware=+[mode]:m:(software hardware)' \
        '-x[no console]' \
        '--noscreen[no console]' \
        '-e[expanded form]' \
        '--prolong[prolong]' \
        '--standalone[standalone]' \
        '--launchpad[launchpad]' \
        '*:input file:_files -g "*.mpl *.mw *.maple"'
}

_maple "$@"
