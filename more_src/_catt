#compdef catt

# Zsh completion for catt - Cast All The Things (Chromecast CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cast:cast a video/URL to Chromecast'
  'cast_site:cast a website to Chromecast'
  'add:add a video to queue'
  'remove:remove a video from queue'
  'clear:clear queue'
  'play_toggle:toggle play/pause'
  'pause:pause playback'
  'play:resume playback'
  'stop:stop playback'
  'rewind:rewind by seconds'
  'ffwd:fast forward by seconds'
  'seek:seek to position'
  'volume:set volume'
  'volumeup:increase volume'
  'volumedown:decrease volume'
  'status:show playback status'
  'info:show device info'
  'scan:scan for devices'
  'write_config:write config file'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --device)'{-d,--device}'[target device]:device' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'catt command' commands && ret=0
    ;;
esac

return ret
