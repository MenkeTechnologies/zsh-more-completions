#compdef b-prolog bprolog bp
# _b-prolog — Neng-Fa Zhou Afany Software b-prolog CLI BProlog open-source standards-compliant Prolog system with CHR constraint handling rules action rules tabling-mode CLPFD finite-domain solver action-rule deferred-mode tabled-mode for AI logic-programming research applications (Afany Software team, C); custom argparse
# upstream: http://www.picat-lang.org/bprolog/

_b-prolog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i[batch mode interactive]' \
        '-g+[goal]:str:' \
        '--goal=+[goal]:str:' \
        '-f+[file]:file:_files -g "*.pl *.bp"' \
        '--file=+[file]:file:_files -g "*.pl *.bp"' \
        '-cl+[file]:file:_files -g "*.pl *.bp"' \
        '-c+[file]:file:_files -g "*.pl *.bp"' \
        '-b+[bytecode]:file:_files -g "*.out *.bp"' \
        '-s+[stack size kw]:n:' \
        '--stack=+[N]:n:' \
        '-h+[heap size kw]:n:' \
        '--heap=+[N]:n:' \
        '-t+[trail size kw]:n:' \
        '--trail=+[N]:n:' \
        '-d+[debug]' \
        '-tab+[table size]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-batch[batch mode]' \
        '*:program:_files -g "*.pl *.bp"'
}

_b-prolog "$@"
