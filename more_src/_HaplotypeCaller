#compdef HaplotypeCaller
# Documentation: https://github.com/broadinstitute/gatk/blob/master/src/main/java/org/broadinstitute/hellbender/tools/walkers/haplotypecaller/HaplotypeCaller.java
# GATK4: call germline SNPs and indels via local re-assembly of haplotypes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-I --input)'{-I,--input}'[input BAM/CRAM file]:file:_files -g "*.(bam|cram|sam)"' \
  '(-R --reference)'{-R,--reference}'[reference FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-O --output)'{-O,--output}'[file to which variants should be written]:file:_files' \
  '(-D --dbsnp)'{-D,--dbsnp}'[dbSNP file to populate the ID column]:file:_files -g "*.(vcf|vcf.gz)"' \
  '(-L --intervals)'{-L,--intervals}'[genomic intervals to operate on]:intervals:_files' \
  '(-ERC --emit-ref-confidence)'{-ERC,--emit-ref-confidence}'[reference confidence mode]:mode:(NONE BP_RESOLUTION GVCF)' \
  '*'{-GQB,--gvcf-gq-bands}'[exclusive upper bounds for reference confidence GQ bands]:n:' \
  '(-SM --sample-name)'{-SM,--sample-name}'[name of single sample to use from a multi-sample bam]:name:' \
  '*'{-comp,--comparison}'[comparison VCF file]:file:_files -g "*.(vcf|vcf.gz)"' \
  '--floor-blocks[output band lower bound for each GQ block]' \
  '--dragen-mode[enable DRAGEN-GATK features]' \
  '*:options:_files' && ret=0

return ret
