#compdef gnubg
# Documentation: https://man.archlinux.org/search?q=gnubg
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --no-bearoff)'{-b,--no-bearoff}'[do not load bearoff databases]' \
  '(-c --commands)'{-c,--commands}'+[execute commands]:cmds:' \
  '(-d --datadir)'{-d,--datadir}'+[data directory]:dir:_files -/' \
  '(-l --lang)'{-l,--lang}'+[language]:lang:' \
  '(-L --logfile)'{-L,--logfile}'+[log file]:file:_files' \
  '(-n --new-weights)'{-n,--new-weights}'+[create new weights]:size:' \
  '(-p --python)'{-p,--python}'+[python script]:file:_files -g "*.py"' \
  '(-q --quiet)'{-q,--quiet}'[disable sound]' \
  '(-r --no-rc)'{-r,--no-rc}'[do not read .gnubgrc]' \
  '(-s --splash)'{-s,--splash}'[no splash screen]' \
  '(-t --tty)'{-t,--tty}'[start tty mode]' \
  '(-w --window-system-only)'{-w,--window-system-only}'[GUI only]' \
  '*:file:_files -g "*.{sgf,mat,gam}"' && ret=0

return ret
