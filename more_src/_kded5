#compdef kded5 kded6
# _kded5 — KDE5/6 background service daemon CLI alias (KDE Project, C++); QCommandLineParser
# upstream: https://invent.kde.org/frameworks/kded

_kded5() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-all[show all help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--check[check module loading]' \
        '--replace[replace running kded]' \
        '--platform=+[Qt platform plugin]:str:' \
        '*:arg:'
}

_kded5 "$@"
