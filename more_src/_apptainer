#compdef apptainer

# Zsh completion for apptainer - container platform (formerly Singularity)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build a container image'
  'cache:manage the local cache'
  'capability:manage Linux capabilities for users and groups'
  'config:manage various apptainer configuration'
  'delete:delete an image from a remote library'
  'exec:run a command within a container'
  'inspect:show metadata for an image'
  'instance:manage container instances'
  'key:manage OpenPGP keys'
  'oci:manage OCI containers'
  'overlay:manage an EXT3 overlay image'
  'plugin:manage apptainer plugins'
  'pull:pull an image from a URI'
  'push:upload an image to a library'
  'registry:manage authentication to OCI/Docker registries'
  'remote:manage apptainer remote endpoints'
  'run:run the user-defined default command within a container'
  'search:search a container library'
  'shell:run a shell within a container'
  'sign:attach digital signature to a container image'
  'sif:manipulate SIF files'
  'test:run the user-defined tests within a container'
  'verify:verify digital signatures attached to a container image'
  'version:show the version for apptainer'
)

local -a global_flags=(
  '(- *)'{-h,--help}'[help for apptainer]'
  '--debug[print debugging information]'
  '--nocolor[print without color output]'
  '-q[only print errors and warnings]'
  '--quiet[only print errors and warnings]'
  '-s[only print errors]'
  '--silent[only print errors]'
  '-v[print additional information]'
  '--verbose[print additional information]'
)

local -a runtime_flags=(
  '*'{-B,--bind}'[user-defined bind mount spec]:bind spec:'
  '(-e --cleanenv)'{-e,--cleanenv}'[clean environment before running container]'
  '(-c --contain)'{-c,--contain}'[use minimal /dev and empty other directories]'
  '(-C --containall)'{-C,--containall}'[contain everything, PID, IPC, etc]'
  '(-f --fakeroot)'{-f,--fakeroot}'[run container in new user namespace as uid 0]'
  '--home[home directory specification]:home dir:'
  '--hostname[set container hostname]:hostname:'
  '--net[enable VM network virtualization]'
  '--network[specify desired network type]:network type:'
  '--nv[enable NVIDIA GPU support]'
  '--rocm[enable ROCm GPU support]'
  '(-w --writable)'{-w,--writable}'[mount container writable]'
  '--writable-tmpfs[mount container root writable with tmpfs overlay]'
  '*--overlay[use an overlay image]:overlay image:_files'
  '(-S --scratch)'{-S,--scratch}'[include a scratch directory]:scratch dir:'
  '--pwd[initial working directory]:directory:'
  '--app[set an application to run inside a container]:app name:'
  '--no-home[do not mount users home directory]'
  '--dns[list of DNS server for container]:dns servers:'
  '*--env[pass environment variable to container]:env (KEY=VALUE):'
  '--env-file[pass environment from file to container]:env file:_files'
  '*--security[enable security features]:security option:'
  '--userns[run container in a new user namespace]'
  '--uts[run container in a new UTS namespace]'
  '--pid[run container in a new PID namespace]'
  '--ipc[run container in a new IPC namespace]'
  '--nohttps[use HTTP instead of HTTPS for communicating with library]'
  '--disable-cache[do not use or create cache]'
  '--docker-login[login to a Docker repository interactively]'
)

_arguments -s -S \
  $global_flags \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'apptainer command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (exec|run|shell|test)
        _arguments -s -S \
          $global_flags \
          $runtime_flags \
          ':image:_files' \
          '*:arguments:' && ret=0
        ;;
      (build)
        _arguments -s -S \
          $global_flags \
          '(-f --fakeroot)'{-f,--fakeroot}'[build with fakeroot]' \
          '--force[overwrite an image file if it exists]' \
          '--sandbox[build into a sandbox directory]' \
          '--section[only run specific section of deffile]:section:(setup post files environment test labels pre)' \
          '--json[interpret build definition as JSON]' \
          '--no-cleanup[do not clean up bundle on failure]' \
          '--nohttps[use HTTP instead of HTTPS]' \
          '--disable-cache[do not use cache]' \
          ':image:_files' \
          ':definition:_files' && ret=0
        ;;
      (pull)
        _arguments -s -S \
          $global_flags \
          '--force[overwrite an image file if it exists]' \
          '--dir[download images to the specified directory]:directory:_directories' \
          '--disable-cache[do not use or create cache]' \
          '--nohttps[use HTTP instead of HTTPS]' \
          '--docker-login[login to a Docker repository interactively]' \
          ':image URI:' && ret=0
        ;;
      (push)
        _arguments -s -S \
          $global_flags \
          ':image:_files' \
          ':library URI:' && ret=0
        ;;
      (inspect)
        _arguments -s -S \
          $global_flags \
          '--json[print structured JSON]' \
          '--app[inspect a specific app]:app name:' \
          '--deffile[show the definition file]' \
          '--environment[show the container environment]' \
          '--helpfile[show the helpfile]' \
          '--labels[show the labels]' \
          '--runscript[show the runscript]' \
          '--startscript[show the startscript]' \
          '--test[show the test script]' \
          ':image:_files' && ret=0
        ;;
      (instance)
        local -a instance_cmds=(
          'list:list running instances'
          'start:start a container instance'
          'stop:stop a container instance'
        )
        _arguments -s -S \
          '1:instance command:->instance_cmd' \
          '*::args:' && ret=0
        case $state in
          (instance_cmd)
            _describe -t commands 'instance command' instance_cmds && ret=0
            ;;
        esac
        ;;
      (cache)
        local -a cache_cmds=(
          'clean:remove all or specific cached data'
          'list:list cached data'
        )
        _arguments -s -S \
          '1:cache command:->cache_cmd' \
          '*::args:' && ret=0
        case $state in
          (cache_cmd)
            _describe -t commands 'cache command' cache_cmds && ret=0
            ;;
        esac
        ;;
      (remote)
        local -a remote_cmds=(
          'add:add a new remote endpoint'
          'get-login-password:get a remote login password'
          'list:list all remote endpoints'
          'login:login to a remote endpoint'
          'logout:logout from a remote endpoint'
          'remove:remove an existing remote endpoint'
          'status:check the status of a remote endpoint'
          'use:set a remote as default'
        )
        _arguments -s -S \
          '1:remote command:->remote_cmd' \
          '*::args:' && ret=0
        case $state in
          (remote_cmd)
            _describe -t commands 'remote command' remote_cmds && ret=0
            ;;
        esac
        ;;
      (key)
        local -a key_cmds=(
          'export:export a public or private key'
          'import:import a key'
          'list:list keys'
          'newpair:create a new key pair'
          'pull:pull a key from a keyserver'
          'push:push a key to a keyserver'
          'remove:remove a local public key'
          'search:search for a key on a keyserver'
        )
        _arguments -s -S \
          '1:key command:->key_cmd' \
          '*::args:' && ret=0
        case $state in
          (key_cmd)
            _describe -t commands 'key command' key_cmds && ret=0
            ;;
        esac
        ;;
      (search)
        _arguments -s -S \
          $global_flags \
          ':search query:' && ret=0
        ;;
      (sign|verify)
        _arguments -s -S \
          $global_flags \
          '--keyidx[key index to use]:key index:' \
          ':image:_files' && ret=0
        ;;
      (version)
        ;;
      (*)
        _arguments -s -S $global_flags '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
