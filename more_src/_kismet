#compdef kismet kismet_server kismet_drone
# _kismet — Mike Kershaw kismet (passive wireless network detector + sniffer; -f config file, -c capture source spec, -p override capture path, -t override log title, -n no log, -s silent, -v verbose, -V version, --override allow conflict override, --no-line-wrap, --no-ncurses; reads /etc/kismet/kismet.conf for global config)
# upstream: https://github.com/kismetwireless/kismet
# Flags from kismet kismet_server/kismet_server.cc on tip.

_kismet() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files' \
        '*-c+[capture source]:source:' \
        '-p+[log path]:dir:_files -/' \
        '-t+[log title]:title:' \
        '-n[no log]' \
        '-s[silent]' \
        '-v[verbose]' \
        '--override+[override file]:file:_files' \
        '--no-line-wrap[no line wrap]' \
        '--no-ncurses[no ncurses]'
}

_kismet "$@"
