#compdef wasm-shell
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/tools/wasm-shell.cpp
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/support/command-line.cpp
# Reference accessed: 2026-05-27
# Verified: upstream src/tools/wasm-shell.cpp main() uses bare Options (only base --help/--version/--debug)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[output version information and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to stderr]:context (optional):' \
  '*:input file:_files -g "*.{wast,wat}"' && ret=0

return ret
