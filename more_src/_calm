#compdef calm
# Documentation: https://man.archlinux.org/search?q=calm
# Reference accessed: 2026-05-16

# finos/architecture-as-code calm-cli (Node); Homebrew: Formula/c/calm-cli.rb installs `calm`

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'calm command' compadd -- generate validate
  ;;
rest)
  case $line[1] in
    generate)
      _arguments -s \
        '(--pattern)'--pattern='[CALM pattern JSON]:pattern:_files -g "*.json"' \
        '(--output)'--output='[output file]:file:_files' && ret=0
      ;;
    validate)
      _arguments -s \
        '(--pattern)'--pattern='[pattern JSON]:pattern:_files -g "*.json"' \
        '(--architecture)'--architecture='[architecture JSON]:arch:_files -g "*.json"' \
        '(--output)'--output='[validation output]:file:_files' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
