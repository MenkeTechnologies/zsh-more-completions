#compdef calm
# Documentation: https://calm.finos.org/working-with-calm/using-the-cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# finos/architecture-as-code calm-cli (Node); Homebrew installs `calm`

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-V)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'calm command' compadd -- generate validate template docify init-ai help
  ;;
rest)
  case $line[1] in
    generate)
      _arguments -s \
        '(-p --pattern)'{-p,--pattern}'=[CALM pattern JSON]:pattern:_files -g "*.json"' \
        '(-o --output)'{-o,--output}'=[output file]:file:_files' && ret=0
      ;;
    validate)
      _arguments -s \
        '(-p --pattern)'{-p,--pattern}'=[pattern JSON]:pattern:_files -g "*.json"' \
        '(-a --architecture)'{-a,--architecture}'=[architecture JSON]:arch:_files -g "*.json"' \
        '--timeline=[timeline file]:file:_files' \
        '(-s --schema-directory)'{-s,--schema-directory}'=[meta-schema dir]:dir:_files -/' \
        '(-f --format)'{-f,--format}'=[output format]:format:(json junit pretty)' \
        '--strict[fail if any warnings reported]' \
        '(-o --output)'{-o,--output}'=[output file]:file:_files' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
