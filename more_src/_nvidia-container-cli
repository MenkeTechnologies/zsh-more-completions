#compdef nvidia-container-cli

# nvidia-container-cli: low-level interface for NVIDIA container runtime
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'info:show driver/device info'
  'configure:configure container'
  'list:list driver components'
)
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-d[debug file]:file:_files' \
  '--debug=[debug file]:file:_files' \
  '-l[load specific kernel module]:module:' \
  '--load-kmods[load required kernel modules]' \
  '-r[hardware capability bits]:bits:' \
  '--root=[chroot root]:dir:_files -/' \
  '-u[user]:user:_users' \
  '--user=[user]:user:_users' \
  '-q[quiet]' \
  '--quiet[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nvidia-container-cli command' commands && ret=0 ;;
esac
return ret
