#compdef nvidia-container-cli
# Documentation: https://github.com/NVIDIA/libnvidia-container/blob/main/src/cli/main.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-container-cli: low-level interface for NVIDIA container runtime
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'info:show driver/device info'
  'configure:configure container'
  'list:list driver components'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d+,--debug=}'[log debug information to file]:file:_files' \
  '(-k --load-kmods)'{-k,--load-kmods}'[load kernel modules]' \
  '(-n --no-pivot)'{-n,--no-pivot}'[do not use pivot_root]' \
  '--no-create-imex-channels[do not auto-create IMEX channel device nodes]' \
  '(-r --root)'{-r+,--root=}'[path to driver root directory]:dir:_files -/' \
  '(-l --ldcache)'{-l+,--ldcache=}'[path to system DSO cache]:file:_files' \
  '(-u --user)'{-u+,--user=}'[user/group for privilege separation]:uid[:gid]' \
  '--quiet[suppress output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nvidia-container-cli command' commands && ret=0 ;;
esac
return ret
