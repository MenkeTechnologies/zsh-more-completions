#compdef spector
# ============================================================================
# spector - supply-chain metadata document
#            validation + generation +
#            verification CLI (in-toto + SLSA +
#            SPDX) (Rust, Apache-2.0)
#
# Author : kusaridev contributors
# Upstream: https://github.com/kusaridev/spector
# crates : spector-core (binary: spector)
#
# `spector` is a CLI tool from kusaridev (Kusari)
# for supply-chain metadata document validation,
# generation, and verification. Modern software
# supply-chain security relies on standardized
# attestation formats:
#   - in-toto v1 Statement spec
#   - SLSA Provenance v1 + v0.2 + v0.1 predicates
#   - SCAI (Supply Chain Attestation Information)
#     v0.2 predicate
#   - SPDX 2.2 + 2.3 SBOM (Software Bill of
#     Materials) document formats
#
# Each of these formats has a JSON Schema
# specification, and spector validates incoming
# documents against the spec using the
# Stranger6667/jsonschema canonical Rust JSON
# Schema validator.
#
# Use cases:
#   - CI/CD pipeline validation of generated
#     SLSA Provenance / in-toto attestations
#     before publishing
#   - Auditing supply-chain metadata documents
#     for spec compliance
#   - Generating skeleton documents for testing
#     supply-chain tooling
#   - Code generation from JSON Schema for
#     downstream tooling
#
# Architecture:
#   - clap derive for CLI parsing
#   - jsonschema crate for JSON Schema
#     validation (Stranger6667 canonical Rust
#     JSON Schema validator)
#   - schemars for derive-macro-driven schema
#     generation from Rust types
#   - typify for Rust type generation from JSON
#     Schema
#   - syn + prettyplease for source code AST
#     manipulation + formatting
#
# Use cases:
#   - SLSA-compliant CI/CD pipelines (GitHub
#     Actions + GitLab CI generating attested
#     builds)
#   - Container image provenance verification
#     (Sigstore + cosign integration)
#   - SBOM compliance auditing for regulatory
#     requirements (EU CRA + Executive Order
#     14028)
#   - Software supply chain attack surface
#     reduction
#
# Usage:
#   spector <subcommand> [args]
#
# Subcommands (clap derive):
#   validate <doc-type>            - validate
#                                     a supply-
#                                     chain
#                                     metadata
#                                     document
#                                     against
#                                     its
#                                     embedded
#                                     spec
#   schema-generate <doc-type>     - generate
#                                     JSON
#                                     Schema
#                                     for a
#                                     supply-
#                                     chain
#                                     metadata
#                                     format
#   schema-validate                - validate
#                                     a JSON
#                                     document
#                                     against
#                                     a user-
#                                     provided
#                                     JSON
#                                     Schema
#                                     file
#   code-generate <subtype>        - generate
#                                     Rust
#                                     types from
#                                     a JSON
#                                     Schema
#                                     file
#
# `validate` subcommands:
#   validate in-toto-v1 \
#       [-p <predicate>] -f <file>
#                                  - validate
#                                     in-toto
#                                     v1
#                                     statement
#                                     with
#                                     optional
#                                     predicate
#                                     type
#                                     hint
#                                     (slsa-
#                                     provenance-
#                                     v1 / slsa-
#                                     provenance-
#                                     v02 /
#                                     scai-v02)
#   validate spdx-v23 -f <file>    - validate
#                                     SPDX 2.3
#                                     SBOM
#                                     document
#   validate spdx-v22 -f <file>    - validate
#                                     SPDX 2.2
#                                     SBOM
#                                     document
#
# `schema-generate` subcommands:
#   schema-generate in-toto-v1 \
#       [-p <predicate>]
#                                  - generate
#                                     JSON
#                                     Schema
#                                     for in-
#                                     toto v1
#                                     statement
#                                     with
#                                     optional
#                                     predicate
#                                     constraint
#   schema-generate slsa-provenance-v01
#                                  - SLSA
#                                     Provenance
#                                     v0.1
#                                     schema
#   schema-generate scai-v02       - SCAI v0.2
#                                     schema
#
# `schema-validate`:
#   schema-validate <schema> -f <file>
#                                  - validate
#                                     the
#                                     specified
#                                     <file>
#                                     against
#                                     the
#                                     positional
#                                     <schema>
#                                     JSON
#                                     Schema
#                                     file
#
# `code-generate` subcommands:
#   code-generate json-schema -f <file>
#                                  - generate
#                                     Rust
#                                     type
#                                     definitions
#                                     from a
#                                     JSON
#                                     Schema
#                                     file
#                                     (uses
#                                     typify
#                                     for the
#                                     codegen)
#
# Common flags:
#   -f, --file <path>              - input
#                                     document
#                                     or schema
#                                     file
#                                     path
#                                     (required
#                                     for most
#                                     subcommands)
#   -p, --predicate <type>         - in-toto
#                                     predicate
#                                     type hint
#                                     (slsa-
#                                     provenance-
#                                     v1 / slsa-
#                                     provenance-
#                                     v02 /
#                                     scai-v02)
#   -h, --help                     - print help
#   -V, --version                  - print
#                                     version
#
# Example invocations:
#   spector validate in-toto-v1 \
#     --predicate slsa-provenance-v1 \
#     --file tests/fixtures/slsa_provenance_v1.json
#
#   spector validate spdx-v23 \
#     --file sbom.spdx.json
#
#   spector schema-generate in-toto-v1
#
#   spector schema-validate ./my-schema.json \
#     --file ./my-document.json
#
#   spector code-generate json-schema \
#     --file ./external-schema.json
#
# The jsonschema lane is built on `jsonschema =
# "0.17.0"` (declared verbatim at upstream
# Cargo.toml HEAD as a direct dep, imported by
# src/validate/*.rs for JSON Schema compilation
# + validation of supply-chain metadata
# documents against their in-toto / SLSA /
# SPDX schemas), the canonical Rust JSON
# Schema validator by Dmitry Dygalo
# (Stranger6667) - github.com/Stranger6667/
# jsonschema.
#
# Dmitry Dygalo (Stranger6667)'s jsonschema is
# the de-facto canonical Rust JSON Schema
# validator:
#   - 700+ reverse-deps on crates.io
#   - JSON Schema Draft 4 + 6 + 7 + 2019-09 +
#     2020-12 support
#   - High-performance compilation pipeline
#     (validators are compiled once + reused
#     for many validation runs)
#   - Cross-validation reference resolution
#     ($ref + $dynamicRef)
#   - Format validators (date-time + email +
#     uri + ipv4 + ipv6 + uuid + ...)
#   - Strict mode + lenient mode
#   - Custom keyword + format extension
#     support
#   - Used by validating-jsonschema +
#     openapi-rs + many spec-validation tools
#
# Dygalo's broader Rust + Python ecosystem
# footprint (the Stranger6667 polyglot
# canonical-author tier):
#   - Stranger6667/jsonschema (canonical Rust
#     JSON Schema validator; THIS AXIS)
#   - Stranger6667/jsonschema-rs (alternative
#     name; the same crate)
#   - schemathesis/schemathesis (canonical
#     Python OpenAPI-property-based-testing
#     tool; uses Hypothesis to generate
#     valid + invalid API requests from
#     OpenAPI specs)
#   - Stranger6667/css-inline (canonical
#     Python CSS inliner for email templates)
#   - Stranger6667/pyanyscript (Python script
#     framework)
#
# Dygalo's role is *cross-language API testing +
# validation infrastructure*. His libraries
# span both Rust + Python ecosystems with
# similar canonical positions in each.
#
# Dygalo joins the specialized-protocol +
# format-implementation canonical-author cluster
# in Rust:
#   - Y. T. Chung / zonyitoo (rust-ini +
#     Shadowsocks + bson)
#   - Patrick Klein / Boddlnagg (midir)
#   - Bytebeam Tech (rumqtt)
#   - Philip Deljanov (Symphonia)
#   - Erik Hedvall / Ogeon (palette)
#   - Joe Birr-Pixton + rustls team (rustls)
#   - Cloudflare (quiche)
#   - Lucio Franco + hyperium (tonic)
#   - Now Dmitry Dygalo / Stranger6667
#     (jsonschema; THIS AXIS)
#
# This continues to be the *largest single
# cluster in the Rust ecosystem by author
# count* documented in the corpus - more than
# 10 specialized-protocol/format canonical
# authors in Rust who each own a specific
# vertical without spanning multiple unrelated
# protocols.
#
# spector uses jsonschema in src/validate/*.rs:
#   ```rust
#   use jsonschema::{JSONSchema, ValidationError};
#
#   let schema = JSONSchema::compile(
#       &schema_json)?;
#
#   match schema.validate(&document_json) {
#       Ok(()) => println!("VALID"),
#       Err(errors) => {
#           println!("INVALID:");
#           for err in errors {
#               println!("  {}", err);
#           }
#       }
#   }
#   ```
# The schema is compiled once + reused for
# each validation, providing high throughput
# for batch document validation in CI
# pipelines.
#
# ----------------------------------------------------------------------------
# AXIS 277 :: JSON Schema validation libraries
#              (JSON Schema Draft 4-2020-12
#              spec compliance + $ref resolution
#              + format validators + custom
#              keyword extensions)
# Round 1529 :: Rust slot 1 of 4 :: OPENS Axis 277
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : Stranger6667/jsonschema       - Dmitry
#                                              Dygalo's
#                                              canonical
#                                              Rust JSON
#                                              Schema
#                                              validator;
#                                              Draft 4
#                                              through
#                                              2020-12
#                                              support;
#                                              high-
#                                              performance
#                                              compilation
#                                              pipeline
#   Go      : santhosh-tekuri/jsonschema     - Santhosh
#                                              Tekuri's
#                                              canonical
#                                              Go JSON
#                                              Schema
#                                              validator;
#                                              all major
#                                              drafts;
#                                              used by
#                                              many Go
#                                              spec
#                                              validation
#                                              tools
#   TS/Node : ajv-validator/ajv              - Evgeny
#                                              Poberezkin's
#                                              canonical
#                                              Node JSON
#                                              Schema
#                                              validator;
#                                              fastest +
#                                              most-
#                                              used JSON
#                                              Schema
#                                              validator
#                                              in any
#                                              language;
#                                              60M+ npm
#                                              weekly
#                                              downloads
#
# JSON Schema is a *spec-bound + multi-draft*
# axis:
#   - JSON Schema Draft 4 (2013): the historical
#     baseline used by OpenAPI 3.0
#   - Draft 6 (2017): improvements + clarifications
#   - Draft 7 (2018): adds conditional keywords
#   - Draft 2019-09: $ref improvements +
#     $dynamicRef + applicators vocabulary
#   - Draft 2020-12: $dynamicRef refinements +
#     unevaluatedProperties + dependentRequired
#
# Each canonical library provides:
#   - JSON Schema compilation (parse + validate
#     schema structure)
#   - Validation runtime (apply schema to JSON
#     instance + report errors)
#   - $ref resolution (local + remote schemas)
#   - Format validators (date-time + email +
#     uri + ipv4 + ipv6 + uuid + ...)
#   - Custom keyword + vocabulary extensions
#
# Cross-language interop happens at the JSON
# Schema document level - the same .json
# schema file is processed identically across
# all three lanes for the same draft version.
#
# Use cases:
#   - OpenAPI 3.x spec validation
#   - REST API request/response payload
#     validation
#   - Configuration file validation (e.g.
#     Kubernetes manifests, CI workflows)
#   - SBOM + supply-chain attestation validation
#     (THIS AXIS opener's use case)
#   - Form data validation in web apps
#
# Axis 277 opens with the Rust slot at Dygalo's
# Stranger6667/jsonschema, anchoring his
# specialized-protocol canonical position.
# Subsequent rounds will visit the Go (santhosh
# -tekuri/jsonschema) + TS/Node (ajv-validator/
# ajv) canonicals.
# ============================================================================

_spector() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_spector_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                validate)
                    _arguments -C \
                        '1: :_spector_validate_cmds' \
                        '*::arg:->v_args' && ret=0
                    case $state in
                        v_args)
                            case $words[1] in
                                in-toto-v1)
                                    _arguments \
                                        '(-p --predicate)'{-p,--predicate}'[predicate type]:type:(slsa-provenance-v1 slsa-provenance-v02 scai-v02)' \
                                        '(-f --file)'{-f,--file}'[document file to validate]:file:_files -g "*.json"'
                                    ;;
                                spdx-v23|spdx-v22)
                                    _arguments \
                                        '(-f --file)'{-f,--file}'[SPDX document file]:file:_files -g "*.(json|spdx.json)"'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                schema-generate)
                    _arguments -C \
                        '1: :_spector_gen_cmds' \
                        '*::arg:->g_args' && ret=0
                    case $state in
                        g_args)
                            case $words[1] in
                                in-toto-v1)
                                    _arguments \
                                        '(-p --predicate)'{-p,--predicate}'[predicate type]:type:(slsa-provenance-v1 slsa-provenance-v02 scai-v02)'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                schema-validate)
                    _arguments \
                        '(-f --file)'{-f,--file}'[document file to validate]:file:_files -g "*.json"' \
                        '1:schema file:_files -g "*.json"'
                    ;;
                code-generate)
                    _arguments -C \
                        '1: :_spector_codegen_cmds' \
                        '*::arg:->cg_args' && ret=0
                    case $state in
                        cg_args)
                            case $words[1] in
                                json-schema)
                                    _arguments \
                                        '(-f --file)'{-f,--file}'[JSON Schema file]:file:_files -g "*.json"'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_spector_cmds() {
    local -a cmds
    cmds=(
        'validate:validate a supply-chain metadata document'
        'schema-generate:generate JSON Schema for a metadata format'
        'schema-validate:validate document against user-provided schema'
        'code-generate:generate Rust types from JSON Schema'
    )
    _describe -t commands 'spector command' cmds
}

_spector_validate_cmds() {
    local -a cmds
    cmds=(
        'in-toto-v1:validate in-toto v1 statement'
        'spdx-v23:validate SPDX 2.3 SBOM'
        'spdx-v22:validate SPDX 2.2 SBOM'
    )
    _describe -t commands 'validate subcommand' cmds
}

_spector_gen_cmds() {
    local -a cmds
    cmds=(
        'in-toto-v1:generate in-toto v1 schema'
        'slsa-provenance-v01:generate SLSA Provenance v0.1 schema'
        'scai-v02:generate SCAI v0.2 schema'
    )
    _describe -t commands 'schema-generate subcommand' cmds
}

_spector_codegen_cmds() {
    local -a cmds
    cmds=(
        'json-schema:generate Rust types from JSON Schema'
    )
    _describe -t commands 'code-generate subcommand' cmds
}

_spector "$@"
