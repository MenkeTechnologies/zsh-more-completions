#compdef bcd
# Documentation: man bcd(6)
# Source: openbsd/src games/bcd/bcd.c — convert to/from antique punched cards (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[decode cards back to text]' \
    '-l[use 80-column cards]' \
    '*:string:_default' \
    && ret=0

return ret
