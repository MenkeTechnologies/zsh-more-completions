#compdef sassc

# Zsh completion for sassc - Sass C implementation compiler

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '(-t --style)'{-t,--style}'[output style]:style:(nested expanded compact compressed)' \
  '(-l --line-numbers --line-comments)'{-l,--line-numbers,--line-comments}'[emit comments showing line numbers]' \
  '(-I --load-path)'{-I,--load-path}'[add load path]:path:_directories' \
  '(-P --plugin-path)'{-P,--plugin-path}'[set plugin path]:path:_directories' \
  '(-m --sourcemap)'{-m,--sourcemap}'[emit source map]' \
  '--sourcemap-file=[specify source map file]:file:_files' \
  '--sourcemap-contents[embed source contents in source map]' \
  '--sourcemap-urls[create file URLs for sources]:urls:(abs rel)' \
  '--sourcemap-root=[specify sourcemap root]:root:_directories' \
  '--no-sourcemap-url[omit source map URL comment]' \
  '(-M --omit-map-comment)'{-M,--omit-map-comment}'[omit source map URL comment]' \
  '(-p --precision)'{-p,--precision}'[set decimal precision]:precision:' \
  '-s[read from stdin]' \
  '--stdin[read from stdin]' \
  '1:input file:_files -g "*.(scss|sass)"' \
  '2:output file:_files -g "*.css"'
