#compdef mimir-tool

# mimir-tool: Grafana Mimir CLI (rules, alertmanager, analyse, backfill, bucket)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'access-control:configure access control'
  'acl:configure access control list'
  'alerts:manage alerts'
  'alertmanager:manage alertmanager configuration'
  'analyse:analyse Grafana dashboards / Prometheus rules'
  'backfill:backfill TSDB blocks'
  'bucket-validation:validate object storage bucket'
  'config:manage config'
  'remote-read:query a remote_read endpoint'
  'rules:manage Prometheus rules'
  'completion:emit shell completion'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--user=[Mimir user]:user:' \
  '--key=[Mimir API key]:key:' \
  '--id=[Mimir tenant id]:id:' \
  '--address=[Mimir base URL]:url:' \
  '--tls-ca-path=[TLS CA path]:file:_files' \
  '--tls-cert-path=[TLS cert path]:file:_files' \
  '--tls-key-path=[TLS key path]:file:_files' \
  '--auth-token=[auth token]:token:' \
  '--no-color[disable color]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mimir-tool command' commands && ret=0 ;;
esac
return ret
