#compdef mimir-tool
# Documentation: https://grafana.com/docs/mimir/latest/manage/tools/mimirtool/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: canonical binary is "mimirtool" (no hyphen); this file covers the
# hyphenated alias some packagers ship. Subcommands mirror upstream mimirtool.

# mimir-tool: Grafana Mimir CLI (rules, alertmanager, analyse, backfill, bucket)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'acl:generate auth headers (label-based access control)'
  'alertmanager:manage tenant Alertmanager configuration'
  'analyze:analyze Grafana dashboards / Prometheus rules'
  'backfill:backfill TSDB blocks into Mimir'
  'bucket-validation:validate object storage bucket'
  'config:configuration tooling (e.g. Cortex to Mimir)'
  'remote-read:query a remote-read endpoint'
  'rules:manage Prometheus rules'
  'completion:emit shell completion'
  'help:show help'
  'version:show version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--user=[Mimir user]:user:' \
  '--key=[Mimir API key]:key:' \
  '--id=[Mimir tenant id]:id:' \
  '--address=[Mimir base URL]:url:' \
  '--tls-ca-path=[TLS CA path]:file:_files' \
  '--tls-cert-path=[TLS cert path]:file:_files' \
  '--tls-key-path=[TLS key path]:file:_files' \
  '--auth-token=[auth token]:token:' \
  '--no-color[disable color]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mimir-tool command' commands && ret=0 ;;
esac
return ret
