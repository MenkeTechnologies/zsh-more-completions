#compdef frpc frps

# Zsh completion for frp - fast reverse proxy

local curcontext="$curcontext" state line ret=1

case $service in
  frpc)
    _arguments -s -S -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '-c+[config file]:file:_files' \
      '1:command:->commands' \
      '*::arg:->args' && ret=0

    case $state in
      commands)
        local -a commands=(
          'http:run HTTP proxy'
          'tcp:run TCP proxy'
          'udp:run UDP proxy'
          'stcp:run secret TCP proxy'
          'xtcp:run peer-to-peer TCP proxy'
          'sudp:run secret UDP proxy'
          'tcpmux:run TCP multiplexer proxy'
          'nathole:NAT hole punching utilities'
          'verify:verify config file'
          'reload:hot-reload config file'
          'status:show proxy status'
          'stop:stop the client'
        )
        _describe -t commands 'frpc command' commands && ret=0
        ;;
      args)
        case $line[1] in
          http|tcp|udp|stcp|xtcp|sudp|tcpmux)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '-c+[config file]:file:_files' \
              '--server-addr=[server address]:address' \
              '--server-port=[server port]:port' \
              '--token=[authentication token]:token' \
              '--log-file=[log file]:file:_files' \
              '--log-level=[log level]:level:(trace debug info warn error)' \
              && ret=0
            ;;
          verify|reload|status|stop)
            _arguments -s -S \
              '(- *)'{-h,--help}'[show help]' \
              '-c+[config file]:file:_files' \
              && ret=0
            ;;
        esac
        ;;
    esac
    ;;
  frps)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '-c+[config file]:file:_files' \
      '--bind-port=[bind port]:port' \
      '--bind-addr=[bind address]:address' \
      '--log-file=[log file]:file:_files' \
      '--log-level=[log level]:level:(trace debug info warn error)' \
      '--token=[authentication token]:token' \
      '--dashboard-port=[dashboard port]:port' \
      && ret=0
    ;;
esac

return ret
