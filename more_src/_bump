#compdef bump

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:create a new version of your documentation'
  'diff:compare two API documents'
  'preview:create a temporary documentation preview'
  'overlay:apply an OpenAPI overlay to an API document'
  'help:show help for any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'bump command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '(-d --doc)'{-d+,--doc=}'[documentation slug or id]:doc:' \
          '(-t --token)'{-t+,--token=}'[API token]:token:' \
          '(-b --branch)'{-b+,--branch=}'[branch name]:branch:' \
          '--auto-create[auto-create the doc if missing]' \
          '--hub=[hub slug or id]:hub:' \
          '--filename-pattern=[filename pattern for hub]:pattern:' \
          '--dry-run[simulate without deploying]' \
          '--mcp-server[deploy a Flower/Arazzo doc to an MCP server]' \
          '*--overlay=[apply overlay (repeatable)]:file:_files' \
          '*::file:_files' && ret=0 ;;
      (diff)
        _arguments \
          '(-d --doc)'{-d+,--doc=}'[documentation slug]:doc:' \
          '(-t --token)'{-t+,--token=}'[API token]:token:' \
          '(-b --branch)'{-b+,--branch=}'[branch name]:branch:' \
          '--hub=[hub slug]:hub:' \
          '--format=[output format]:format:(text json markdown html)' \
          '--expand[expand response]' \
          '--fail-on-breaking[fail on breaking changes]' \
          '--no-fail-on-breaking[do not fail on breaking changes]' \
          '*--overlay=[apply overlay before diff (repeatable)]:file:_files' \
          '*::file:_files' && ret=0 ;;
      (preview)
        _arguments \
          '--live[live update preview on save]' \
          '--open[open URL in browser]' \
          '*::file:_files' && ret=0 ;;
      (overlay)
        _arguments \
          '(-o --out)'{-o+,--out=}'[output file]:file:_files' \
          '*::file:_files' && ret=0 ;;
    esac ;;
esac

return ret
