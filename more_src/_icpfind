#compdef icpfind
# Documentation: https://man.archlinux.org/man/icpfind.1.en
# icpfind: intelligent control point finder for a Hugin .pto project

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto file (required)]:file:_files -g "*.pto"' \
  '(-s --setting)'{-s+,--setting=}'[setting number from Hugin preferences]:number:' \
  '(-m --matches)'{-m+,--matches=}'[number of control points per pair of photos]:number:' \
  '*:pto file:_files -g "*.pto"' && ret=0

return ret
