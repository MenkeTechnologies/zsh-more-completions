#compdef 3dmaskSVD
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dmaskSVD.html
# AFNI: SVD of time series within a mask

local ret=1

_arguments -s -S \
  '-vnorm[L2 normalize all time series before SVD]' \
  '-sval[output singular vectors 0..a (default 0)]:a:' \
  '-mask[mask dataset (default entire dataset)]:mset:_files' \
  '-automask[automatically generate mask]' \
  '-polort[polynomial detrending of order p]:p:' \
  '-bpass[bandpass filter low high]:low:' \
  '*-ort[time series to remove before SVD]:file:_files' \
  '-input[input dataset]:dataset:_files' \
  '*:dataset:_files' && ret=0

return ret
