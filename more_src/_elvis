#compdef elvis
# Documentation: https://elvis.the-little-red-haired-girl.org/elvisman/elvis.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elvis: text editor, a clone of vi/ex (Steve Kirkendall)

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-V[verbose mode (repeat for more detail)]' \
  '-a[load all files simultaneously in separate windows]' \
  '-r[recover edit session after a crash]' \
  '-e[start in ex mode]' \
  '-i[start in input mode]' \
  '-b[set binary option on new buffers]' \
  '-R[mark new buffers as read-only]' \
  '-S[security=safer]' \
  '-SS[security=restricted]' \
  '-f+[use specified session file]:session:_files' \
  '-t+[begin editing at tag location]:tag:' \
  '-c+[execute ex command after loading first file]:command:' \
  '+-[execute ex command after loading first file]:command:' \
  '-o+[redirect messages to log file]:logfile:_files' \
  '-G+[select user interface]:gui:(termcap x11 windows open quiet)' \
  '-w+[set window scroll option]:scroll:' \
  '-B+[set session file block size]:blksize:' \
  '-s[read and execute ex script from stdin]' \
  '-font+[X11 normal font]:font:' \
  '-fn+[X11 normal font]:font:' \
  '-fb+[X11 bold font]:font:' \
  '-fi+[X11 italic font]:font:' \
  '-courier+[use Courier fonts at size]:size:' \
  '-mono[use only black and white]' \
  '-fg+[text color]:color:' \
  '-bg+[background color]:color:' \
  '-fork[run in background]' \
  '-client[connect to existing elvis process]' \
  '*:file:_files' && ret=0

return ret
