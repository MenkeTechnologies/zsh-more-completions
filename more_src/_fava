#compdef fava

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-p+[port to listen on]:port' \
  '--port=[port to listen on]:port' \
  '-H+[host to bind to]:host' \
  '--host=[host to bind to]:host' \
  '--prefix=[URL prefix]:prefix' \
  '-d[debug mode]' \
  '--debug[debug mode]' \
  '--profile[run profiler]' \
  '--profile-dir=[profiler output directory]:directory:_directories' \
  '--read-only[read-only mode]' \
  '--incognito[incognito mode, no file path in title]' \
  '*:beancount file:_files -g "*.beancount"' && ret=0

return ret
