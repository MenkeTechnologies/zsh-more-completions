#compdef create-sdd-project
# Documentation: https://www.npmjs.com/package/create-sdd-project
# Reference accessed: 2026-05-23
# Verified: npm view create-sdd-project bin; npm readme init/upgrade/eject/doctor sections.

# Zsh completion for create-sdd-project - Spec-Driven Development project bootstrapper

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--init[install SDD stack into an existing project]' \
  '--upgrade[upgrade SDD stack files in place]' \
  '--eject[remove SDD stack scaffolding from project]' \
  '--doctor[verify SDD installation health]' \
  '--diff[preview init/upgrade/eject without modifying files]' \
  '--yes[non-interactive mode; skip prompts]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':project name:' && ret=0

return ret
