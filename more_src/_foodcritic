#compdef foodcritic

_arguments -s \
  '*'{-t,--tags=}'[match tags]:tags:' \
  '(-l --list)'{-l,--list}'[list enabled rules]' \
  '(-f --epic-fail)'{-f,--epic-fail=}'[fail on tags]:tags:' \
  '(-c --chef-version)'{-c,--chef-version=}'[Chef version]:version:' \
  '*'{-r,--rule-file=}'[rule file]:file:_files' \
  '(-s --ast-cache-size)'{-s,--ast-cache-size=}'[AST cache size]:n:' \
  '*'{-B,--cookbook-path=}'[cookbook path]:dir:_files -/' \
  '(-C --context)'{-C,--context}'[show matched lines]' \
  '(-C --no-context)--no-context[summary only]' \
  '*'{-E,--environment-path=}'[environment path]:dir:_files -/' \
  '*'{-I,--include=}'[additional rule file]:file:_files' \
  '(-G --search-gems)'{-G,--search-gems}'[search rubygems]' \
  '(-P --progress)'{-P,--progress}'[show progress]' \
  '(-P --no-progress)--no-progress[no progress]' \
  '*'{-R,--role-path=}'[role path]:dir:_files -/' \
  '(-S --search-grammar)'{-S,--search-grammar=}'[grammar file]:file:_files' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-X,--exclude=}'[exclude path]:dir:_files -/' \
  '*:cookbook path:_files -/'
