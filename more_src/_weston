#compdef weston

# Zsh completion for weston (Wayland compositor reference implementation)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-B --backend)'{-B,--backend}'[backend module]:backend:(drm headless pipewire rdp vnc wayland x11)' \
  '(-S --socket)'{-S,--socket}'[Wayland socket name]:socket name' \
  '(-i --idle-time)'{-i,--idle-time}'[idle timeout in seconds]:seconds' \
  '--modules[load additional modules]:modules' \
  '--log[log file path]:log file:_files' \
  '(-c --config)'{-c,--config}'[config file]:config file:_files' \
  '--no-config[do not read config file]' \
  '--debug[enable debug protocol]' \
  '--use-pixman[use pixman renderer]' \
  '--wait-for-debugger[wait for debugger on startup]:seconds' \
  '--flight-rec[enable flight recorder]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--shell[shell module to use]:shell' \
  '--xwayland[enable XWayland]' \
  '--width[set output width]:width' \
  '--height[set output height]:height' \
  '--scale[set output scale]:scale' \
  '--transform[set output transform]:transform:(normal 90 180 270 flipped flipped-90 flipped-180 flipped-270)' \
  '--fullscreen[run in fullscreen mode]' && ret=0

return ret
