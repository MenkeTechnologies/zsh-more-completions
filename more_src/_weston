#compdef weston
# Documentation: https://manpages.debian.org/bookworm/weston/weston.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream weston(1) manpage at the URL above.

# weston: Wayland compositor reference implementation
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-B --backend)'{-B+,--backend=}'[load backend module]:backend:(drm.so headless.so pipewire.so rdp.so vnc.so wayland.so x11.so)' \
  '(-c --config)'{-c+,--config=}'[load custom configuration file]:config file:_files' \
  '--no-config[skip reading weston.ini]' \
  '--debug[enable debug protocol extension]' \
  '(-l --logger-scopes)'{-l+,--logger-scopes=}'[log scopes]:scopes:' \
  '(-f --flight-rec-scopes)'{-f+,--flight-rec-scopes=}'[flight recorder scopes]:scopes:' \
  '(-i --idle-time)'{-i+,--idle-time=}'[idle timeout in seconds]:seconds:' \
  '--log=[append logs to file]:log file:_files' \
  '--xwayland[load XWayland module]' \
  '--modules=[load comma-separated modules]:modules:' \
  '(-S --socket)'{-S+,--socket=}'[Wayland socket name]:socket name:' \
  '--wait-for-debugger[raise SIGSTOP before initialization]' \
  '--renderer=[renderer]:renderer:(gl vulkan pixman)' \
  '--continue-without-input[allow DRM-backend startup without input devices]' \
  '--seat=[seat to use]:seat:' \
  '--display=[connect to specific Wayland display (wayland backend)]:display:' \
  '--output-count=[number of output windows]:N:' \
  '--width=[output width]:width:' \
  '--height=[output height]:height:' \
  '--scale=[output scale]:scale:' \
  '--use-pixman[force pixman renderer]' \
  '--fullscreen[fullscreen output (wayland/x11 backends)]' \
  '--no-input[disable input devices (x11 backend)]' && ret=0

return ret
