#compdef squirrel
# Documentation: https://pyrocko.org/docs/current/apps/squirrel/reference/squirrel.html
# pyrocko: data access infrastructure command-line tool

local ret=1
local context state line
typeset -A opt_args

_arguments -s -C \
  '(-h --help)'{-h,--help}'[display help information]' \
  '--loglevel=[set logging verbosity]:level:(critical error warning info debug)' \
  '--progress=[configure progress reporting]:dest:(terminal log off)' \
  '--threads-loading=[number of threads for file loading]:n' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'squirrel subcommand' \
      'benchmark[run benchmarks]' \
      'catalog[catalog operations]' \
      'check[check dataset consistency]' \
      'codes[print summary of codes]' \
      'coverage[print coverage of data]' \
      'database[database inspection and maintenance]' \
      'dataset[dataset operations]' \
      'files[print summary of files]' \
      'info[print information]' \
      'init[create a dataset description file]' \
      'jackseis[convert waveform archive data]' \
      'merge[merge data]' \
      'nuts[print summary of nuts]' \
      'operators[print available operators]' \
      'persistent[manage persistent selections]' \
      'remove[remove entries]' \
      'response[print instrument responses]' \
      'scan[scan and index files and directories]' \
      'snuffler[open snuffler]' \
      'stationxml[export StationXML]' \
      'summon[fill local cache]' \
      'template[print dataset templates]' \
      'update[update remote source inventories]' && ret=0
    ;;
esac

return ret
