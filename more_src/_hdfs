#compdef hdfs

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'classpath:display the class path needed for Hadoop jars and libraries'
  'dfs:execute filesystem commands on Hadoop-supported filesystems'
  'envvars:show computed Hadoop environment variables'
  'fetchdt:obtain delegation tokens from a NameNode'
  'fsck:run HDFS filesystem checking utility'
  'getconf:retrieve configuration information'
  'groups:return group information for specified usernames'
  'httpfs:start the HttpFS server (HDFS HTTP Gateway)'
  'lsSnapshottableDir:list snapshottable directories'
  'jmxget:extract JMX information from services'
  'oev:offline edits viewer'
  'oiv:offline image viewer'
  'oiv_legacy:offline image viewer for older Hadoop versions'
  'snapshotDiff:determine differences between HDFS snapshots'
  'version:print version information'
  'balancer:execute cluster balancing utility'
  'cacheadmin:manage centralized cache'
  'crypto:manage transparent encryption zones'
  'datanode:start HDFS DataNode'
  'dfsadmin:administrative HDFS client'
  'dfsrouter:run the DFS Router for federation'
  'dfsrouteradmin:manage Router-based federation'
  'diskbalancer:balance data across disk volumes'
  'ec:manage erasure coding policies'
  'haadmin:manage NameNode high availability'
  'journalnode:start a Journal Node'
  'mover:execute data migration utility'
  'namenode:start the NameNode'
  'nfs3:start NFS3 gateway'
  'portmap:start RPC portmap (for NFS3)'
  'secondarynamenode:start Secondary NameNode'
  'storagepolicies:manage storage policies'
  'zkfc:start Zookeeper Failover Controller'
  'verifyMeta:verify HDFS metadata and block files'
  'computeMeta:generate metadata from block files'
  'recoverLease:recover lease on specified path'
  'verifyEC:verify erasure coding correctness'
)

_arguments -C \
  '--config[Hadoop config dir]:dir:_files -/' \
  '--debug[debug output]' \
  '--loglevel[log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--daemon=[start in daemon mode]:mode:(start status stop)' \
  '--workers[execute on all workers]' \
  '--hosts=[hosts file]:file:_files' \
  '--hostnames=[hostnames]:hosts:' \
  '--buildpaths[expand build path]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hdfs subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (fsck)
        _arguments \
          '-delete[delete corrupted files]' \
          '-move[move corrupted files to /lost+found]' \
          '-files[print files being checked]' \
          '-blocks[print block report]' \
          '-locations[print locations of each block]' \
          '-racks[print rack location of each block]' \
          '-includeSnapshots[include snapshots in check]' \
          '-storagepolicies[print storage policy summary]' \
          '-list-corruptfileblocks[print corrupt file blocks]' \
          '-openforwrite[print files opened for write]' \
          '-showprogress[show progress]' \
          '*:path:' && ret=0
        ;;
      (dfsadmin)
        _arguments \
          '-report[report basic filesystem info]' \
          '-safemode+[safe mode op]:op:(enter leave get wait forceExit)' \
          '-saveNamespace[save namespace]' \
          '-rollEdits[roll edit log]' \
          '-restoreFailedStorage+[restore failed storage]:flag:(true false check)' \
          '-refreshNodes[reread hosts/exclude files]' \
          '-finalizeUpgrade[finalize upgrade]' \
          '-rollingUpgrade+[rolling upgrade]:op:(query prepare finalize)' \
          '-printTopology[print rack tree]' \
          '-refreshNamenodes[refresh namenodes]:datanodehost:port:' \
          '-getDatanodeInfo+[get datanode info]:datanodehost:port:' \
          '-deleteBlockPool+[delete block pool]:datanodehost:port blockpoolid [force]:' \
          '-setQuota+[set quota]:quota dirname:' \
          '-clrQuota+[clear quota]:dirname:' \
          '-setSpaceQuota+[set space quota]:quota dirname:' \
          '-clrSpaceQuota+[clear space quota]:dirname:' \
          '-allowSnapshot+[allow snapshot]:snapshotDir:' \
          '-disallowSnapshot+[disallow snapshot]:snapshotDir:' \
          '-shutdownDatanode+[shutdown datanode]:datanodehost:port [upgrade]:' \
          '-evictWriters+[evict writers]:datanodehost:port:' \
          '-fetchImage+[fetch fsimage]:dir:' \
          '-help[show help]' && ret=0
        ;;
      (haadmin)
        _arguments \
          '-transitionToActive+[transition NN to active]:serviceId:' \
          '-transitionToStandby+[transition NN to standby]:serviceId:' \
          '-failover[failover from one NN to another]:from to:' \
          '-getServiceState+[get NN state]:serviceId:' \
          '-checkHealth+[check NN health]:serviceId:' && ret=0
        ;;
      (balancer)
        _arguments \
          '-policy+[balance policy]:policy:(datanode blockpool)' \
          '-threshold+[threshold percentage]:n:' \
          '-exclude+[exclude file or list]:file:_files' \
          '-include+[include file or list]:file:_files' \
          '-source+[source file or list]:file:_files' \
          '-idleiterations+[max idle iterations]:n:' \
          '-asService[run as service]' && ret=0
        ;;
      (oev)
        _arguments \
          '-i+[input file]:file:_files' \
          '-o+[output file]:file:_files' \
          '-p+[output processor]:processor:(binary xml stats)' \
          '-r+[recovery mode]:mode:' \
          '-f[fix edit logs]' \
          '-v[verbose]' && ret=0
        ;;
      (oiv)
        _arguments \
          '-i+[input image file]:file:_files' \
          '-o+[output file]:file:_files' \
          '-p+[output processor]:processor:(Web XML FileDistribution Delimited DetectCorruption ReverseXML)' \
          '-addr+[network address]:addr:' \
          '-maxSize+[max size]:n:' \
          '-step+[step size]:n:' \
          '-delimiter+[delimiter for delimited output]:delim:' && ret=0
        ;;
      (ec)
        _arguments \
          '-setPolicy+[set EC policy]:path -policy:' \
          '-getPolicy+[get EC policy]:path:' \
          '-listPolicies[list EC policies]' \
          '-enablePolicy+[enable policy]:policy:' \
          '-disablePolicy+[disable policy]:policy:' \
          '-removePolicy+[remove policy]:policy:' \
          '-addPolicies+[add policies from XML]:file:_files -g "*.xml"' \
          '-listCodecs[list available codecs]' \
          '-verifyClusterSetup[verify cluster setup]' && ret=0
        ;;
      (cacheadmin)
        _arguments \
          '-addDirective[add a cache directive]' \
          '-modifyDirective[modify directive]' \
          '-listDirectives[list directives]' \
          '-removeDirective+[remove directive]:id:' \
          '-removeDirectives[remove all matching directives]' \
          '-addPool+[add cache pool]:name:' \
          '-modifyPool+[modify pool]:name:' \
          '-removePool+[remove pool]:name:' \
          '-listPools[list pools]' \
          '-help[show help]' && ret=0
        ;;
      (diskbalancer)
        _arguments \
          '-plan+[create plan for datanode]:datanode:' \
          '-execute+[execute plan]:plan-file:_files' \
          '-query+[query plan]:datanode:' \
          '-cancel+[cancel plan]:plan-file:_files' \
          '-report[generate report]' && ret=0
        ;;
      (storagepolicies)
        _arguments \
          '-listPolicies[list storage policies]' \
          '-setStoragePolicy+[set policy]:path policy:' \
          '-getStoragePolicy+[get policy]:path:' \
          '-unsetStoragePolicy+[unset policy]:path:' \
          '-satisfyStoragePolicy+[satisfy policy]:path:' && ret=0
        ;;
      (crypto)
        _arguments \
          '-createZone[create encryption zone]' \
          '-listZones[list encryption zones]' \
          '-provisionTrash[provision trash directory]' \
          '-getFileEncryptionInfo+[get encryption info]:path:' \
          '-help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
