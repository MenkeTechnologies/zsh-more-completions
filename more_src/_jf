#compdef jf

# Zsh completion for jf - JFrog CLI

local curcontext="$curcontext" state line ret=1

_jf_server_ids() {
  local -a ids
  ids=(${(f)"$(jf config show 2>/dev/null | awk '/Server ID:/{print $NF}')"})
  _describe -t server-ids 'server ID' ids
}

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '--url=[JFrog platform URL]:url' \
  '--user=[JFrog username]:user' \
  '--password=[JFrog password]:password' \
  '--access-token=[JFrog access token]:token' \
  '--server-id=[server ID]:server ID:_jf_server_ids' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'rt:Artifactory commands'
      'xr:Xray commands'
      'mc:Mission Control commands'
      'ds:Distribution commands'
      'pipelines:Pipelines commands'
      'config:configuration commands'
      'project:project commands'
      'access:Access commands'
      'transfer-config:transfer configuration'
      'transfer-files:transfer files'
    )
    _describe -t commands 'jf command' commands && ret=0
    ;;
  args)
    case $words[1] in
      rt)
        local -a rt_commands=(
          'upload:upload files'
          'download:download files'
          'search:search files'
          'delete:delete files'
          'copy:copy files'
          'move:move files'
          'props:manage properties'
          'ping:ping Artifactory'
          'repo-create:create repository'
          'repo-delete:delete repository'
          'repo-template:create repo template'
          'build-publish:publish build info'
          'build-collect-env:collect environment variables'
          'build-add-git:add git info to build'
          'build-scan:scan build with Xray'
          'curl:execute raw cURL command'
        )
        _describe -t commands 'Artifactory command' rt_commands && ret=0
        ;;
      xr)
        local -a xr_commands=(
          'scan:scan files'
          'audit:audit project'
          'curl:execute raw cURL command'
        )
        _describe -t commands 'Xray command' xr_commands && ret=0
        ;;
      config)
        local -a config_commands=(
          'add:add server configuration'
          'edit:edit server configuration'
          'remove:remove server configuration'
          'show:show server configuration'
          'use:set default server'
          'export:export server configuration'
          'import:import server configuration'
        )
        _describe -t commands 'config command' config_commands && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)--help[show help]' \
          '--url=[JFrog platform URL]:url' \
          '--server-id=[server ID]:server ID:_jf_server_ids' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
