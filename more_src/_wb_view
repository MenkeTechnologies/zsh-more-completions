#compdef wb_view
# Documentation: https://www.humanconnectome.org/software/connectome-workbench
# HCP Connectome Workbench GUI visualization program

local ret=1

_arguments -s -S \
  '-help[display this usage text]' \
  '-enable-perf[enable graphics performance improvements]' \
  '-graphics-size[set the size of the graphics region]:x:_guard "[0-9]#" X: :y:_guard "[0-9]#" Y' \
  '-logging[set the logging level]:level:(SEVERE WARNING INFO CONFIG FINE FINER FINEST ALL OFF)' \
  '-mac-menu-in-window[macOS: position menus at top of main windows]' \
  '-no-recent-files-dialog[inhibit display of Open Recent Files Dialog at startup]' \
  '-no-splash[obsolete; replaced by -no-recent-files-dialog]' \
  '-recent-files-mode[set the recent files file system access mode]:mode:(ON OFF)' \
  '-scene-load[load the specified scene file and display the scene]:scene-file:_files' \
  '-scene-load-hd[load scene then hide the scene dialog]:scene-file:_files' \
  '-scene-recent[load the most recently loaded scene from its scene file]' \
  '-style[change the window style]:style:(Windows Fusion)' \
  '-spec-load-all[load all files in the given spec file]' \
  '-toolbox[combine Features and Overlay vertical toolboxes]' \
  '-window-size[set the size of the browser window]:x:_guard "[0-9]#" X: :y:_guard "[0-9]#" Y' \
  '-window-pos[set the position of the browser window]:x:_guard "[0-9]#" X: :y:_guard "[0-9]#" Y' \
  '*:file:_files' && ret=0

return ret
