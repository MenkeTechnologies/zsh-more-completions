#compdef ovhdata-cli
# Documentation: https://github.com/ovh/ovhdata-cli
# OVHcloud Data Processing / Data Integration command line tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '*'{-v,--verbose}'[adjust verbosity level]' \
  '--service-name=[OVHcloud service name to use]:service:' \
  '--json-log[output logs in JSON format]' \
  '--no-color[remove colored output]' \
  '--no-spinner[remove spinner animation from output]' \
  '*:command:(completion config debug di login logout me help)' && ret=0

return ret
