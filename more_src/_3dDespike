#compdef 3dDespike
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dDespike.html
# AFNI remove spikes from each voxel time series

local ret=1

_arguments -s -S \
  '-help[show help]' \
  '-ignore[ignore the first I points]:I' \
  '-corder[curve fit order for L1 regression]:L' \
  '-cut[modify default spike threshold values]:c1' \
  '-prefix[output dataset prefix]:prefix' \
  '-ssave[store spikiness measure into dataset]:prefix' \
  '-nomask[process all voxels]' \
  '-dilate[dilation iterations for mask creation]:nd' \
  '(-q -quiet)'{-q,-quiet}'[suppress informational output]' \
  '-localedit[replace spikes with nearest non-spike averages]' \
  '-NEW[accelerated fitting method for longer series]' \
  '-NEW25[more aggressive despiking variant]' \
  '-OLD[revert to original L1 fitting method]' \
  '*:dataset:_files' && ret=0

return ret
