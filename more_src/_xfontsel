#compdef xfontsel
# Documentation: https://man.archlinux.org/man/xfontsel.1.en
# Reference accessed: 2026-05-30
# xfontsel — interactive X11 font selector. Browse fonts, view samples, retrieve XLFD names.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show usage message]' \
  '(- *)-version[show version]' \
  '-pattern+[select subset of fonts matching this pattern]:fontname:' \
  '-print[write selected font specifier to stdout on quit]' \
  '-sample+[sample text for linearly indexed fonts]:text:' \
  '-sample16+[sample text for matrix-encoded fonts]:text16:' \
  '-sampleUCS+[UTF-8 sample text for ISO10646 charset fonts]:textUCS:' \
  '-scaled[enable selection of scaled fonts at arbitrary pixel/point sizes]' \
  && ret=0

return ret
