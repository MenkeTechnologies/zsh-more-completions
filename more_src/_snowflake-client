#compdef snowflake-client
# Documentation: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/snowflake
# Reference accessed: 2026-05-21
# Verified: flags taken directly from client/snowflake.go in upstream snowflake repo.

# snowflake-client: Tor pluggable transport using WebRTC peer
local curcontext="$curcontext" ret=1
_arguments -C \
  '-ice=[comma-separated list of ICE servers]:urls:' \
  '-url=[URL of signaling broker]:url:' \
  '-front=[front domain]:domain:_hosts' \
  '-fronts=[comma-separated list of front domains]:domains:' \
  '-ampcache=[URL of AMP cache to use as a proxy for signaling]:url:' \
  '-sqsqueue=[URL of SQS Queue to use as a proxy for signaling]:url:' \
  '-sqscreds=[credentials to access SQS Queue]:creds:' \
  '-log=[log filename]:file:_files' \
  '-log-to-state-dir[resolve the log file relative to tors pt state dir]' \
  '-keep-local-addresses[keep local LAN address ICE candidates]' \
  '-unsafe-logging[keep sensitive info in the logs]' \
  '-max=[capacity for multiplexed WebRTC peers]:n:' \
  '-version[display version info to stderr and quit]' \
  '-covertdtls-config=[DTLS mimic/randomize config]:mode:(mimic randomize randomizemimic disable)' \
  '-covertdtls-fingerprint=[raw DTLS fingerprint to mimic]:fp:' \
  '*::snowflake-client args:_files' && ret=0
return ret
