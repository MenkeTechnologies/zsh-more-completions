#compdef snowflake-client

# snowflake-client: Tor pluggable transport using WebRTC peer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-ice=[ICE STUN/TURN URLs (comma)]:urls:' \
  '-url=[broker URL]:url:' \
  '-front=[domain to front through]:domain:_hosts' \
  '-fronts=[comma list of domains to front]:domains:' \
  '-ampcache=[AMP cache URL]:url:' \
  '-sqsqueue=[SQS queue URL]:url:' \
  '-sqscreds=[SQS credentials (base64 json)]:b64:' \
  '-log=[log file]:file:_files' \
  '-log-to-state-dir[log into state dir]' \
  '-keep-local-addresses[keep local IPs in SDPs]' \
  '-unsafe-logging[unsafe logging]' \
  '-max=[max number of peers]:n:' \
  '-utls-imitate=[TLS fingerprint]:fp:(hellochrome_auto hellofirefox_auto helloios_auto)' \
  '-utls-nosni[disable SNI in uTLS]' \
  '*::snowflake-client args:_files' && ret=0
return ret
