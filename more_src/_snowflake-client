#compdef snowflake-client

# snowflake-client: Tor Snowflake pluggable transport client
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-ice[ICE STUN/TURN server URLs]:urls:' \
  '-url[Snowflake broker URL]:url:' \
  '-front[broker front domain(s) comma list]:hosts:' \
  '-fronts[front domains list]:hosts:' \
  '-ampcache[AMP cache URL]:url:' \
  '-log[log file]:file:_files' \
  '-log-to-state-dir[write log to state directory]' \
  '-keep-local-addresses[do not strip private IPs from candidates]' \
  '-unsafe-logging[allow sensitive info in logs]' \
  '-max[max concurrent peers]:n:' \
  '-utls-imitate[uTLS fingerprint to imitate]:tls:' \
  '*::snowflake-client args:_files' && ret=0
return ret
