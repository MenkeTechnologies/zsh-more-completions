#compdef ploomber
# Documentation: https://docs.ploomber.io/en/latest/api/cli.html
# Ploomber data pipeline build and orchestration tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '1:command:((
    build\:"execute the pipeline end-to-end"
    status\:"show pipeline status table"
    plot\:"create a pipeline plot"
    task\:"interact with a single task"
    report\:"create an HTML report"
    interact\:"start an interactive session with the DAG"
    examples\:"download example pipelines"
    install\:"install project dependencies"
    nb\:"manage notebooks and scripts"
  ))' \
  '*::arg:->args' && ret=0

return ret
