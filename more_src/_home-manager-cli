#compdef home-manager

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'edit:edit home.nix'
  'option:inspect a Home Manager option'
  'build:build configuration into ./result'
  'instantiate:instantiate the configuration'
  'init:initialize Home Manager files'
  'switch:build and activate'
  'generations:list generations'
  'remove-generations:remove generations'
  'expire-generations:expire generations older than'
  'packages:list installed packages'
  'news:show news'
  'uninstall:uninstall Home Manager'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*-A+[attribute path]:a:' \
  '*-I+[Nix search path]:p:' \
  '*--show-trace[show Nix trace]' \
  '*--option=[k v]:v:' \
  '*-f+[Nix file path]:file:_files -g "*.nix"' \
  '*--file=[Nix file path]:file:_files -g "*.nix"' \
  '*-b+[backup ext]:e:' \
  '*--backup=[backup ext]:e:' \
  '*-n+[do not perform actions]:b:' \
  '*--dry-run[dry run]' \
  '*--keep-going[keep going on errors]' \
  '*--keep-failed[keep failed]' \
  '*--print-build-logs[print build logs]' \
  '*-L[print build logs]' \
  '*--substituters=[csv]:list:' \
  '*--builders=[csv]:list:' \
  '*--cores=[n]:n:' \
  '*--max-jobs=[n]:n:' \
  '*-j+[max jobs]:n:' \
  '*--quiet[quiet]' \
  '*--verbose[verbose]' \
  '*-v[verbose]' \
  '*--flake=[flake]:f:' \
  '*--no-flake[no flake]' \
  '*--debug[debug]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'home-manager command' commands && ret=0 ;;
  (args) _files ;;
esac

return ret
