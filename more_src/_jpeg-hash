#compdef jpeg-hash
# _jpeg-hash — compute a perceptual JPEG hash for fast image comparison (danielgtaylor/jpeg-archive)
# upstream: https://github.com/danielgtaylor/jpeg-archive
# Flags from jpeg-hash.c (getopt_long).

_jpeg-hash() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-s --size)'{-s+,--size=}'[hash size]:n:' \
        ':JPEG file:_files -g "*.(jpg|jpeg)"'
}

_jpeg-hash "$@"
