#compdef rsgiscreatevrts
# Documentation: https://www.rsgislib.org/commandlineutilities.html
# rsgiscreatevrts RSGISLib command line utility

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'[Input base directory]:value:_files' \
  '(-s --search)'{-s,--search}'[The image search string - NOTE NEEDS TO BE IN QUOTES (default\: *.tif)]:value:_files' \
  '(-r --replace)'{-r,--replace}'[Replace VRT file(s) if already exist.]' \
  '*:file:_files' && ret=0

return ret
