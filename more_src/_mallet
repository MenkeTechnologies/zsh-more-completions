#compdef mallet
# Documentation: https://mimno.github.io/Mallet/topics.html
# MALLET machine learning for language toolkit

local ret=1

_arguments -s -S \
  '--input=[input MALLET collection file or directory]:file:_files' \
  '--output=[output file]:file:_files' \
  '--keep-sequence[preserve word order]' \
  '--remove-stopwords[filter common words]' \
  '--use-pipe-from=[use feature extraction rules from a previously trained file]:file:_files' \
  '--num-topics=[the number of topics to use]:n' \
  '--num-iterations=[the number of sampling iterations]:n' \
  '--num-icm-iterations=[iterated conditional modes iterations]:n' \
  '--input-state=[reload a previously saved Gibbs sampling state]:file:_files' \
  '--output-state=[output compressed word-topic assignments]:file:_files' \
  '--output-model=[file to write a serialized topic trainer object]:file:_files' \
  '--output-doc-topics=[file to write topic composition of documents]:file:_files' \
  '--output-topic-keys=[file with top words for each topic]:file:_files' \
  '--optimize-interval=[turn on hyperparameter optimization]:n' \
  '--optimize-burn-in=[iterations before hyperparameter optimization begins]:n' \
  '--inferencer-filename=[create a topic inference tool from the trained model]:file:_files' \
  '--evaluator-filename=[held-out probability estimation tool]:file:_files' \
  '--output-classifier=[file to write the trained classifier]:file:_files' \
  '--classifier=[saved classifier to use]:file:_files' \
  '1:command:(import-dir import-file import-svmlight train-classifier classify-dir classify-file classify-svmlight train-topics infer-topics evaluate-topics prune split bulk-load info)' \
  '*:file:_files' && ret=0

return ret
