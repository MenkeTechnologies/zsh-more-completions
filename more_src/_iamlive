#compdef iamlive

# Zsh completion for iamlive - Generate IAM policies from AWS API calls

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--output-file=[output file for generated policy]:file:_files' \
  '--profile=[AWS profile to use]:profile' \
  '--mode=[capture mode]:mode:(csm proxy)' \
  '--bind-addr=[bind address for proxy mode]:address' \
  '--ca-bundle=[CA bundle file for proxy mode]:file:_files' \
  '--account-id=[AWS account ID]:account-id' \
  '--background[run in background]' \
  '--force-wildcard-resource[force wildcard resource in generated policies]' \
  '--sort-alphabetical[sort actions alphabetically]' \
  '--set-ini[set proxy settings in AWS config]' \
  '--http-only-mode[only capture HTTP requests]' \
  '--csv-output-file=[CSV output file]:file:_files' \
  '--host=[hostname for proxy]:host' \
  && ret=0

return ret
