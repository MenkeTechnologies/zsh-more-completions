#compdef coqwc
# Documentation: https://rocq-prover.org/doc/V8.20.0/refman/practical-tools/utilities.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above (Coq/Rocq utilities).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p[print pretty]' \
  '-s[print spec/proof/comment]' \
  '-r[print to a raw format]' \
  '*:file:_files -g "*.v"' && ret=0

return ret
