#compdef update-my-stuff
# Documentation: https://github.com/jv-k/macup
# Reference accessed: 2026-05-21
# Verified: upstream macos-updatetool script defines these options in show_help() and the embedded --completion output.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --list --list-all)'{-l,--list,--list-all}'[list all apps with status]' \
  '--list-npm[list all npm packages]' \
  '(--list-brew-formulas --list-formulas)'{--list-brew-formulas,--list-formulas}'[list all brew formulas]' \
  '(--list-brew-casks --list-casks)'{--list-brew-casks,--list-casks}'[list all brew casks]' \
  '--list-appstore[list all App Store applications]' \
  '--list-xcode[list Xcode info with status]' \
  '--list-xcode-tools[list Xcode CLT info]' \
  '--outdated[combine with --list-* to show only outdated packages]' \
  '--update-all[perform all updates in sequence]' \
  '--upgrade-brew[upgrade Homebrew formulas]' \
  '--upgrade-npm[upgrade npm packages]' \
  '--upgrade-casks[upgrade Homebrew casks]' \
  '--upgrade-appstore[upgrade App Store apps]' \
  '--upgrade-xcode[upgrade Xcode]' \
  '--upgrade-xcode-tools[upgrade Xcode CLT]' \
  '--install-all[install all]' \
  '--install-brew[install Homebrew formulas]' \
  '--install-npm[install npm packages]' \
  '--install-casks[install Homebrew casks]' \
  '--install-appstore[install App Store apps]' \
  '--install-xcode[install Xcode]' \
  '--install-xcode-tools[install Xcode CLT]' \
  '--completion[generate zsh completion script]' \
  '(-a --add)'{-a,--add}'[add an app to the applist]:app: :category:(appstore npm brew cask)' \
  '(-r --remove)'{-r,--remove}'[remove an app from the applist]:app: :category:(appstore npm brew cask)' && ret=0

return ret
