#compdef felix
# Documentation: https://man.archlinux.org/search?q=felix
# Reference accessed: 2026-05-16

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-l --log)'{-l,--log}'[log file path]:log file:_files' \
  '*:directory:_files -/'
