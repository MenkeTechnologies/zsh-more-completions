#compdef edbg
# Documentation: https://github.com/ataradov/edbg
# CMSIS-DAP SWD programmer for ARM-based microcontrollers

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-b --verbose)'{-b,--verbose}'[output detailed diagnostic information]' \
  '(-d --version)'{-d,--version}'[specify CMSIS-DAP version]:version' \
  '(-x --reset)'{-x,--reset}'[assert reset pin before operations]:duration_ms' \
  '(-e --erase)'{-e,--erase}'[chip erase prior to programming]' \
  '(-p --program)'{-p,--program}'[program the target device]' \
  '(-v --verify)'{-v,--verify}'[verify memory contents]' \
  '(-k --lock)'{-k,--lock}'[lock the chip by setting security bit]' \
  '(-u --unlock)'{-u,--unlock}'[unlock the chip]' \
  '(-r --read)'{-r,--read}'[read entire flash memory contents]' \
  '(-f --file)'{-f,--file}'[binary file for program/verify/read]:file:_files' \
  '(-t --target)'{-t,--target}'[specify target type]:target' \
  '(-l --list)'{-l,--list}'[display available debuggers]' \
  '(-s --serial)'{-s,--serial}'[select debugger by serial number]:serial' \
  '(-c --clock)'{-c,--clock}'[set interface clock frequency in kHz]:freq' \
  '(-o --offset)'{-o,--offset}'[specify operation offset]:offset' \
  '(-z --size)'{-z,--size}'[specify operation size]:size' \
  '(-F --fuse)'{-F,--fuse}'[perform fuse operations]:options' && ret=0

return ret
