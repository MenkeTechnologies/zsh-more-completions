#compdef config-lint
# Documentation: https://github.com/stelligent/config-lint
# Reference accessed: 2026-05-17
# Verified: upstream cli/options.go source at the URL above.

_arguments -s -S \
  '-terraform[use built-in rules for Terraform]' \
  '*-rules=[rules file (may be repeated)]:file:_files' \
  '-tfparser=[Terraform parser version]:version:(tf11 tf12)' \
  '-tags=[run only tests with tags (comma-separated)]:tags:' \
  '-ids=[run only rules in this comma-separated list]:ids:' \
  '-ignore-ids=[ignore the rules in this comma-separated list]:ids:' \
  '-query=[JMESPath expression to query results]:expr:' \
  '-verbose[output a verbose report]' \
  '-search=[JMESPath expression to evaluate against files]:expr:' \
  '-validate[validate rules file]' \
  '-version[get program version]' \
  '-profile=[profile (default options) file]:file:_files' \
  '*-exclude=[filename pattern to exclude]:pattern:' \
  '*-exclude-from=[filename containing exclude patterns]:file:_files' \
  '*-var=[variable value (key=value)]:var:' \
  '-debug[debug logging]' \
  '*:config file:_files'
