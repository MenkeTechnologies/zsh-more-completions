#compdef reshape

# Zsh completion for reshape - PostgreSQL zero-downtime schema migrations

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_reshape_global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-V,--version}'[show version]'
  '--url=[PostgreSQL connection URL]:url:'
  '(-s --schema)'{-s,--schema}'[target schema name]:schema:'
)

_arguments -s -S -C \
  "${_reshape_global_flags[@]}" \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'migration:Manage migrations'
      'complete:Complete the current migration'
      'abort:Abort the current migration'
      'status:Show migration status'
      'remove:Remove Reshape from the database'
    )
    _describe -t commands 'reshape commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      migration)
        _arguments -s -S -C \
          "${_reshape_global_flags[@]}" \
          '1:subcommand:->migration_cmd' \
          '*::arg:->migration_args' && ret=0
        case "$state" in
          migration_cmd)
            local -a migration_commands
            migration_commands=(
              'start:Start a new migration'
            )
            _describe -t commands 'migration commands' migration_commands && ret=0
            ;;
          migration_args)
            case "${line[1]}" in
              start)
                _arguments -s -S \
                  "${_reshape_global_flags[@]}" \
                  '1:migration file:_files -g "*.toml"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      complete|abort|status|remove)
        _arguments -s -S \
          "${_reshape_global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
