#compdef coreutils
# _coreutils — uutils coreutils single-binary multi-call dispatcher Rust rewrite of GNU coreutils (uutils team, Rust); clap-derive
# upstream: https://github.com/uutils/coreutils

_coreutils() {
    local -a sub=(
        '[:not a command]'
        'arch:print machine architecture'
        'b2sum:compute BLAKE2 hash'
        'b3sum:compute BLAKE3 hash'
        'base32:base32 encode/decode'
        'base64:base64 encode/decode'
        'basename:strip directory'
        'basenc:base encode/decode'
        'cat:concatenate files'
        'chcon:change SELinux context'
        'chgrp:change file group ownership'
        'chmod:change file mode bits'
        'chown:change file owner and group'
        'chroot:run with different root directory'
        'cksum:checksum and count bytes'
        'comm:compare two sorted files'
        'cp:copy files and directories'
        'csplit:split file by lines'
        'cut:remove sections from lines'
        'date:print or set system date'
        'dd:convert and copy a file'
        'df:report file system disk usage'
        'dir:list directory contents'
        'dircolors:setup colors for ls'
        'dirname:strip last component'
        'du:estimate file space usage'
        'echo:display a line of text'
        'env:run program in modified environment'
        'expand:convert tabs to spaces'
        'expr:evaluate expression'
        'factor:factor numbers'
        'false:do nothing unsuccessfully'
        'fmt:format text'
        'fold:wrap input lines'
        'groups:print group memberships'
        'hashsum:compute hash digest'
        'head:print first lines of file'
        'hostid:print host id'
        'hostname:show or set system hostname'
        'id:print user identity'
        'install:copy files setting attributes'
        'join:join two files on common field'
        'kill:send signal to process'
        'link:create hard link'
        'ln:make links between files'
        'logname:print current user login name'
        'ls:list directory contents'
        'md5sum:compute MD5 hash'
        'mkdir:make directories'
        'mkfifo:make FIFOs'
        'mknod:make block or character device'
        'mktemp:make a temp file'
        'more:page through output'
        'mv:move files'
        'nice:run with adjusted priority'
        'nl:number lines of files'
        'nohup:run immune to hangups'
        'nproc:print number of processors'
        'numfmt:reformat numbers'
        'od:dump files in octal/hex'
        'paste:merge lines of files'
        'pathchk:check filename portability'
        'pinky:lightweight finger'
        'pr:convert text files for printing'
        'printenv:print environment'
        'printf:format and print data'
        'ptx:produce permuted index'
        'pwd:print working directory'
        'readlink:print resolved symbolic link'
        'realpath:print resolved path'
        'rm:remove files'
        'rmdir:remove empty directories'
        'runcon:run with SELinux context'
        'seq:print sequence of numbers'
        'sha1sum:compute SHA1 hash'
        'sha224sum:compute SHA-224 hash'
        'sha256sum:compute SHA-256 hash'
        'sha384sum:compute SHA-384 hash'
        'sha512sum:compute SHA-512 hash'
        'sha3sum:compute SHA-3 hash'
        'shred:overwrite file securely'
        'shuf:shuffle lines'
        'sleep:delay for specified time'
        'sort:sort lines of text files'
        'split:split file into pieces'
        'stat:display file or filesystem status'
        'stdbuf:run with stream buffers'
        'stty:print or change terminal settings'
        'sum:print checksum and count'
        'sync:flush filesystem buffers'
        'tac:concatenate reverse'
        'tail:print last lines of file'
        'tee:read from stdin to stdout and files'
        'test:check file types and compare values'
        'timeout:run with a time limit'
        'touch:change file timestamps'
        'tr:translate characters'
        'true:do nothing successfully'
        'truncate:shrink or extend size'
        'tsort:topological sort'
        'tty:print terminal name'
        'uname:print system info'
        'unexpand:convert spaces to tabs'
        'uniq:report or omit repeated lines'
        'unlink:call unlink to remove file'
        'uptime:show uptime'
        'users:print logged-in users'
        'vdir:long listing'
        'wc:print line word byte count'
        'who:show who is logged on'
        'whoami:print current user'
        'yes:repeatedly output a string'
        '--help:show help'
        '--list:list installed utilities'
        '--version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--list[list installed utilities]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'coreutils subcommand' sub ;;
    esac
}

_coreutils "$@"
