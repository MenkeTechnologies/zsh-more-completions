#compdef brownie

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new Brownie project'
  'bake:initialize from a template'
  'compile:compile project contracts'
  'console:launch an interactive console'
  'test:run test suite'
  'run:run a script'
  'accounts:manage local accounts'
  'networks:manage network settings'
  'gui:launch the GUI debugger'
  'analyze:security analysis with MythX'
  'pm:manage packages'
  'ethpm:manage ethPM packages'
  'reverts:track revert strings'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'brownie command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '--force[overwrite existing project]' \
          '1:path:_directories' && ret=0
        ;;
      (bake)
        _arguments '1:template name' '2:path:_directories' && ret=0
        ;;
      (compile)
        _arguments \
          '--all[recompile all contracts]' \
          '--size[show contract sizes]' && ret=0
        ;;
      (console|run)
        _arguments \
          '--network=[network to connect to]:network' \
          '--gas[display gas usage]' \
          '--tb=[traceback verbosity]:level:(0 1 2)' \
          '1:script:_files -g "*.py"' && ret=0
        ;;
      (test)
        _arguments \
          '--network=[network to connect to]:network' \
          '--gas[display gas usage]' \
          '--coverage[generate coverage report]' \
          '--update[only run tests with changed contracts]' \
          '--stateful=[stateful test count]:count' \
          '--failfast[stop on first failure]' \
          '--tb=[traceback verbosity]:level:(0 1 2)' \
          '-n+[number of workers]:count' \
          '-k+[test expression filter]:expression' \
          '-x[stop on first failure]' \
          '-s[show print statements]' \
          '*:test files:_files -g "*.py"' && ret=0
        ;;
      (accounts)
        local -a account_cmds=(
          'list:list available accounts'
          'new:create a new account'
          'import:import a private key'
          'export:export a private key'
          'delete:delete an account'
          'generate:generate a random account'
        )
        _arguments '1:account command:_describe -t account-cmds "account command" account_cmds' && ret=0
        ;;
      (networks)
        local -a network_cmds=(
          'list:list available networks'
          'add:add a new network'
          'modify:modify network settings'
          'delete:delete a network'
          'import:import network from URI'
          'export:export network config'
          'set-provider:set default provider'
        )
        _arguments '1:network command:_describe -t network-cmds "network command" network_cmds' && ret=0
        ;;
      (pm)
        local -a pm_cmds=('list:list packages' 'install:install a package' 'clone:clone a package' 'delete:delete a package')
        _arguments '1:pm command:_describe -t pm-cmds "pm command" pm_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
