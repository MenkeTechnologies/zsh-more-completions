#compdef supef
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/decon_shaping/supef.c
# Wiener predictive error filtering (deconvolution) of SU data

local ret=1

_arguments -s -S \
  'cdp=[CDPs for which minlag maxlag pnoise mincorr maxcorr are set]:cdp' \
  'minlag=[first lag of prediction filter in sec]:minlag' \
  'maxlag=[last lag of prediction filter in sec]:maxlag' \
  'pnoise=[relative additive noise level]:pnoise' \
  'mincorr=[start of autocorrelation window in sec]:mincorr' \
  'maxcorr=[end of autocorrelation window in sec]:maxcorr' \
  'wienerout=[1 to show Wiener filter on each trace]:wienerout:(0 1)' \
  'mix=[array of weights for moving average of autocorrelations]:mix' \
  'outpar=[output parameter file]:file:_files' \
  'method=[interpolation method for cdp values]:method:(linear mono akima spline)' \
  'dt=[time sample interval]:dt' \
  '*:file:_files' && ret=0

return ret
