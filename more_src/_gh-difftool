#compdef gh-difftool gh-prism gh-releaser gh-sizer gh-sql
# Documentation: upstream READMEs at github.com/{speedyleion/gh-difftool,kawarimidoll/gh-prism,carlsberg/gh-releaser,timrogers/gh-sizer,KOBA789/gh-sql}
# Reference accessed: 2026-05-30
# gh-extension family round 8. Sourced from the TypeScript and Rust slices
# of topics/gh-extension. Companions to rounds 158-164.
# Hunt-defer log this round:
#   gh-describe (proudust/gh-describe) — README documents GitHub Actions
#     inputs but doesn't enumerate CLI flag names for the binary
#     invocation. Defer per the gh-grep precedent.
#   gh-news (chmouel/gh-news) — interactive TUI with only bare `gh news`
#     and a config file documented; no CLI flags surface. Skip per
#     bare-TUI-no-surface precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-difftool)
    # speedyleion/gh-difftool — launch a visual difftool over PR changes.
    #   gh difftool [OPTIONS] [PR] [-- <FILES>...]
    _arguments -s -S \
      '(-t --tool)-t+[difftool override]:tool:' \
      '(-t --tool)--tool=[difftool override]:tool:' \
      '--name-only[show only changed filenames]' \
      '--skip-to=[start comparison at file]:file:_files' \
      '--rotate-to=[reorder file queue starting with file]:file:_files' \
      '1:PR number or URL (default: PR for current branch):' \
      '*:limit to files (after --):_files' \
      && ret=0
    ;;

  gh-prism)
    # kawarimidoll/gh-prism — TUI PR review tool.
    #   gh prism <PR_NUMBER>  [--repo owner/repo] [--no-cache]
    #                         [--light | --dark]
    _arguments -s -S \
      '--repo=[owner/repo]:repo:' \
      '--no-cache[disable cache]' \
      '(--light --dark)--light[force light theme]' \
      '(--light --dark)--dark[force dark theme]' \
      '1:PR number:' \
      && ret=0
    ;;

  gh-releaser)
    # carlsberg/gh-releaser — GitFlow release management with GitHub PRs.
    local -a _subcmds
    _subcmds=(
      'start:create a release branch, draft release, and PR'
      'close:merge the PR and publish the GitHub release'
      'update:rename the release branch + update docs to new tag'
      'pr:print the PR number for the current open release'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-releaser subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          start)
            _arguments '1:tag:' && ret=0
            ;;
          update)
            _arguments '1:new tag:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-sizer)
    # timrogers/gh-sizer — git-sizer wrapper over remote repos.
    local -a _subcmds
    _subcmds=(
      'repo:clone, size, and remove a single repository'
      'generate-script:produce automation scripts for batch sizing'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-sizer subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          repo)
            _arguments \
              '--output-format=[output format]:format:(text json)' \
              '1:owner/repo:' && ret=0
            ;;
          generate-script)
            _arguments \
              '--output-format=[output format]:format:(text json)' \
              '1:user or organization:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-sql)
    # KOBA789/gh-sql — query GitHub Projects via SQL.
    #   gh-sql [OPTIONS] <OWNER> <PROJECT_NUMBER>
    # Supports SELECT / DELETE / UPDATE (Title, Assignees, Labels, Milestone, Repository).
    _arguments -s -S \
      '(-e --execute)-e+[non-interactive SQL statement]:sql:' \
      '(-e --execute)--execute=[non-interactive SQL statement]:sql:' \
      '(-o --output)-o+[output format]:format:(table json initial)' \
      '(-o --output)--output=[output format]:format:(table json initial)' \
      '-oj[shortcut for --output json]' \
      '1:owner:' \
      '2:project number:' \
      && ret=0
    ;;

esac

return ret
