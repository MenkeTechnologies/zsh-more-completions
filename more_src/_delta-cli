#compdef delta-cli delta-lake-cli deltactl
# _delta-cli — Linux Foundation Delta Lake delta-cli CLI command-line frontend wrapping the Delta Lake open-source storage layer for Spark Trino Flink Snowflake EMR Databricks providing table-history versions schema vacuum optimize compact restore CDC change-data-feed clone snapshot transaction-log checkpoint protocol-version (Delta Lake team, Rust); cobra
# upstream: https://delta.io/

_delta-cli() {
    local -a sub=(
        'info:show table info'
        'history:show table history'
        'versions:list versions'
        'schema:show schema'
        'metadata:show metadata'
        'snapshot:show snapshot at version'
        'vacuum:run vacuum'
        'optimize:run optimize'
        'compact:compact small files'
        'restore:restore to a version'
        'clone:clone a table'
        'cdc:change data capture'
        'checkpoint:create checkpoint'
        'convert-to-delta:convert Parquet to Delta'
        'protocol:show protocol version'
        'fs:filesystem operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--storage=+[s]:s:(local s3 gcs azure adls hdfs)' \
        '--access-key-id=+[id]:str:' \
        '--secret-access-key=+[secret]:str:' \
        '--region=+[r]:str:' \
        '--endpoint=+[url]:str:' \
        '--retention-hours=+[N]:n:' \
        '--target-version=+[N]:n:' \
        '--dry-run[dry run]' \
        '--enforce-retention[enforce retention]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'delta-cli subcommand' sub ;;
        args)
            _arguments '*:table path:_files -/'
            ;;
    esac
}

_delta-cli "$@"
