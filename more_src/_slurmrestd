#compdef slurmrestd

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-a+[authentication plugin]:plugin:(rest_auth/local rest_auth/jwt)' \
  '-d+[OpenAPI plugin]:plugin:(openapi/slurmctld openapi/dbv0.0.36 openapi/dbv0.0.37 openapi/dbv0.0.38 openapi/dbv0.0.39 openapi/dbv0.0.40 openapi/v0.0.36 openapi/v0.0.37 openapi/v0.0.38 openapi/v0.0.39 openapi/v0.0.40)' \
  '-f+[Slurm config file]:file:_files' \
  '-g+[group]:group:_groups' \
  '-s+[generate OpenAPI spec to file]:file:_files' \
  '-t+[max connections]:n:' \
  '-u+[user]:user:_users' \
  '-v[increase verbosity]' \
  '*:listener:' && ret=0

return ret
