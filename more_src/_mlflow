#compdef mlflow
# Documentation: https://github.com/mlflow/mlflow
# Reference accessed: 2026-05-27
# Verified: upstream mlflow/cli/__init__.py (Click command tree),
# mlflow/models/cli.py, mlflow/experiments.py, mlflow/runs.py.

# Zsh completion for mlflow CLI

local curcontext="$curcontext" state line ret=1

local -a _mlflow_subcommands
_mlflow_subcommands=(
  'run:run an MLflow project from a URI or local path'
  'server:run the MLflow tracking server'
  'ui:launch the MLflow tracking UI (alias for server)'
  'gc:permanently delete runs in the deleted lifecycle stage'
  'doctor:print useful debugging information'
  'artifacts:upload, download, and list artifacts'
  'experiments:manage experiments (create, search, get, delete, restore, rename, csv)'
  'runs:manage runs (list, delete, restore, describe, create, link-traces)'
  'db:database management (upgrade)'
  'deployments:manage deployments to inference targets'
  'models:manage and serve registered models'
  'sagemaker:deploy models to Amazon SageMaker'
  'migrate-filestore:transfer FileStore data to SQLite'
  'traces:manage and evaluate execution traces'
  'scorers:manage GenAI evaluation scoring functions'
  'datasets:manage GenAI evaluation datasets'
  'demo:launch MLflow with demo data'
  'ai-commands:MLflow AI commands for LLM agents'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show MLflow version]' \
  '--env-file=[load environment variables from a .env file]:file:_files' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'mlflow subcommand' _mlflow_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-e --entry-point)'{-e+,--entry-point=}'[entry point in MLproject]:entry:' \
          '(-v --version)'{-v+,--version=}'[git commit or branch]:rev:' \
          '(-P --param-list)*'{-P+,--param-list=}'[parameter as key=value]:param:' \
          '(-A --docker-args)*'{-A+,--docker-args=}'[docker run arg as key=value]:arg:' \
          '--experiment-name=[experiment name]:name:' \
          '--experiment-id=[experiment id]:id:' \
          '(-b --backend)'{-b+,--backend=}'[execution backend]:backend:(local databricks kubernetes)' \
          '(-c --backend-config)'{-c+,--backend-config=}'[backend config file or JSON]:config:_files' \
          '--env-manager=[environment manager]:manager:(local virtualenv uv conda)' \
          '--storage-dir=[storage directory]:dir:_directories' \
          '--run-id=[run id]:id:' \
          '--run-name=[run name]:name:' \
          '--build-image[build a Docker image for the project]' \
          '--docker-auth=[docker registry auth JSON]:auth:' \
          '1:project URI or path:_files' && ret=0
        ;;
      server|ui)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--backend-store-uri=[URI for backend store]:uri:' \
          '--read-replica-backend-store-uri=[read replica backend store URI]:uri:' \
          '--registry-store-uri=[model registry store URI]:uri:' \
          '--default-artifact-root=[default artifact root URI]:uri:' \
          '--artifacts-destination=[artifact destination URI]:uri:' \
          '--serve-artifacts[enable artifact serving]' \
          '--no-serve-artifacts[disable artifact serving]' \
          '--artifacts-only[only serve artifacts]' \
          '(-h --host)'{-h+,--host=}'[host to listen on]:host:' \
          '(-p --port)'{-p+,--port=}'[port to listen on]:port:' \
          '(-w --workers)'{-w+,--workers=}'[number of workers]:n:' \
          '--allowed-hosts=[comma-separated allowed hosts]:hosts:' \
          '--cors-allowed-origins=[comma-separated CORS origins]:origins:' \
          '--disable-security-middleware[disable security middleware]' \
          '--x-frame-options=[X-Frame-Options header]:value:' \
          '--static-prefix=[URL prefix for static files]:prefix:' \
          '--gunicorn-opts=[gunicorn options string]:opts:' \
          '--waitress-opts=[waitress options string]:opts:' \
          '--uvicorn-opts=[uvicorn options string]:opts:' \
          '--expose-prometheus=[expose prometheus metrics on path]:path:' \
          '--app-name=[ASGI/WSGI app name]:name:' \
          '--dev[run in development mode]' && ret=0
        ;;
      gc)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--older-than=[delete runs older than (ISO 8601 duration)]:duration:' \
          '--backend-store-uri=[backend store URI]:uri:' \
          '--artifacts-destination=[artifact destination URI]:uri:' \
          '--run-ids=[comma-separated run ids]:ids:' \
          '--experiment-ids=[comma-separated experiment ids]:ids:' \
          '--logged-model-ids=[comma-separated logged model ids]:ids:' \
          '--jobs=[number of jobs]:n:' \
          '--job-ids=[comma-separated job ids]:ids:' \
          '--tracking-uri=[tracking server URI]:uri:' \
          '--workspace=[Databricks workspace]:workspace:' \
          '--all-workspaces[apply to all workspaces]' && ret=0
        ;;
      doctor)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--mask-envs[mask sensitive environment variables]' && ret=0
        ;;
      experiments)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(create update search get delete restore rename csv)' \
          '*:: :_files' && ret=0
        ;;
      runs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list delete restore describe create link-traces)' \
          '*:: :_files' && ret=0
        ;;
      models)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(serve predict prepare-env generate-dockerfile build-docker update-pip-requirements)' \
          '*:: :_files' && ret=0
        ;;
      artifacts)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(download log-artifact log-artifacts list)' \
          '*:: :_files' && ret=0
        ;;
      db)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(upgrade)' \
          '*:: :_files' && ret=0
        ;;
      deployments)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(create update delete list get predict help run-local explain start-server)' \
          '*:: :_files' && ret=0
        ;;
      sagemaker)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(build-and-push-container run-local push-model deploy-transform-job terminate-transform-job)' \
          '*:: :_files' && ret=0
        ;;
      traces)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(search get delete log evaluate)' \
          '*:: :_files' && ret=0
        ;;
      scorers)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list create delete update)' \
          '*:: :_files' && ret=0
        ;;
      datasets)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list create delete update get)' \
          '*:: :_files' && ret=0
        ;;
      demo)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      migrate-filestore)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' '*:: :_files' && ret=0
        ;;
      ai-commands)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' '*:: :_files' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
