#compdef mlflow

# Zsh completion for mlflow

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'artifacts:manage artifacts'
      'db:manage database'
      'deployments:manage deployments'
      'doctor:diagnose issues'
      'experiments:manage experiments'
      'gc:garbage collect'
      'models:manage models'
      'recipes:manage recipes'
      'run:run an MLflow project'
      'runs:manage runs'
      'sagemaker:manage SageMaker'
      'server:run the MLflow tracking server'
      'ui:launch the MLflow tracking UI'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      server|ui)
        _arguments -s -S \
          '--backend-store-uri=[URI for backend store]:URI' \
          '--default-artifact-root=[default artifact root]:path:_files' \
          '--artifacts-destination=[artifact destination]:URI' \
          '--serve-artifacts[enable artifact serving]' \
          '--no-serve-artifacts[disable artifact serving]' \
          '--artifacts-only[only serve artifacts]' \
          '(-h --host)'{-h,--host}'[host to listen on]:host' \
          '(-p --port)'{-p,--port}'[port to listen on]:port' \
          '(-w --workers)'{-w,--workers}'[number of workers]:workers' \
          '--static-prefix=[URL prefix]:prefix' \
          '--gunicorn-opts=[Gunicorn CLI options]:options' \
          '--dev[run in development mode]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '--entry-point=[entry point]:entry point' \
          '-P[set parameter]:parameter (key=value)' \
          '--experiment-name=[experiment name]:name' \
          '--experiment-id=[experiment ID]:id' \
          '--backend=[execution backend]:backend:(local databricks)' \
          '--storage-dir=[storage directory]:directory:_directories' \
          '--run-name=[run name]:name' \
          '--run-id=[run ID]:id' \
          '--env-manager=[environment manager]:manager:(local virtualenv conda)' \
          '--build-image[build Docker image]' \
          '1:URI or path:_files' && ret=0
        ;;
      experiments)
        _arguments -s -S \
          '1:action:(create delete list rename restore search csv)' && ret=0
        ;;
      models)
        _arguments -s -S \
          '1:action:(serve build-docker predict)' && ret=0
        ;;
    esac
    ;;
esac

return ret
