#compdef aicommits

# Nutlope/aicommits — src/cli.ts (cleye)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--version}'[show version]' \
  '(-g)'{-g+,--generate=}'[generate N messages]:count:' \
  '*'{-x+,--exclude=}'[exclude path from analysis]:path:_files' \
  '(-a)'{-a,--all}'[auto-stage tracked files]' \
  '(-t)'{-t+,--type=}'[commit style]:type:(plain conventional gitmoji)' \
  '(-y)'{-y,--yes}'[skip commit confirmation]' \
  '(-c)'{-c,--clipboard}'[copy message instead of committing]' \
  '(-n)'{-n,--noVerify}'[skip git hooks on commit]' \
  '(-p)'{-p+,--prompt=}'[LLM prompt guidance]:text:' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'config:configure providers'
      'setup:wizard setup'
      'model:choose model'
      'hook:git hook helpers'
      'pr:PR helpers'
      'update:self update'
    )
    _alternative \
      'commands:subcommand:($cmds)' \
      'generate:generate commit:_default' && ret=0
    ;;
  (rest)
    _arguments '*:args:_default' && ret=0
    ;;
esac

return ret
