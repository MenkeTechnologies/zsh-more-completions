#compdef cut-cli
# _cut-cli — GNU coreutils cut remove sections from each line of files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_cut-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b+[bytes list]:str:' \
        '--bytes=+[bytes list]:str:' \
        '-c+[characters list]:str:' \
        '--characters=+[characters list]:str:' \
        '-d+[delimiter]:str:' \
        '--delimiter=+[delimiter]:str:' \
        '-f+[fields list]:str:' \
        '--fields=+[fields list]:str:' \
        '-n[no split multi-byte characters]' \
        '--complement[complement selected bytes/chars/fields]' \
        '-s[only print lines containing delimiter]' \
        '--only-delimited[only print lines containing delimiter]' \
        '--output-delimiter=+[delimiter]:str:' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_cut-cli "$@"
