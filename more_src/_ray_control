#compdef ray_control ray-control
# _ray_control — control RaySession audio session manager via OSC (Houston4444/RaySession)
# upstream: https://github.com/Houston4444/RaySession
# Operations from src/control/ray_control.py (CONTROL/SERVER/SESSION/CLIENT operation tuples).

_ray_control() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--help-all[show full help including all categories]' \
        '--detach[detach from daemon after sending order]' \
        '--port=[connect to daemon on OSC port]:port:' \
        '1:operation:(
            start start_new start_new_hidden stop list_daemons
            get_root get_port get_port_gui_free get_pid get_session_path
            has_local_gui has_gui
            quit change_root set_terminal_command
            list_session_templates list_user_client_templates list_factory_client_templates
            remove_client_template list_sessions
            new_session open_session open_session_off save_session_template
            rename_session set_options has_option
            script_info hide_script_info script_user_action
            auto_export_custom_names export_custom_names import_pretty_names clear_pretty_names
            save save_as_template take_snapshot duplicate open_snapshot
            rename add_executable add_client_template close abort
        )' \
        '*:argument:'
}

_ray_control "$@"
