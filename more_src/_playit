#compdef playit playit-cli
# Documentation: https://github.com/playit-cloud/playit-agent
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for playit-cli (playit-agent)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'version:Print version information'
  'attach:Attach to a running playitd service'
  'start:Start the installed playitd service'
  'stop:Stop the installed playitd service'
  'status:Show the status of the installed playitd service'
  'reset:Remove the secret key so the agent can be re-claimed'
  'secret-path:Show the file path where the playit secret is stored'
  'setup:Provision a new secret to playitd'
  'account:Account management commands'
  'claim:Set up a new playit agent (claim flow)'
)

_arguments -s -S \
  '(-s --stdout)'{-s,--stdout}'[print logs to stdout instead of TUI]' \
  '--socket-path=[override IPC socket or named pipe to reach playitd]:path:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'playit command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (attach)
        _arguments -s -S \
          '(-s --stdout)'{-s,--stdout}'[print logs to stdout instead of TUI]' && ret=0
        ;;
      (account)
        local -a account_cmds=(
          'login-url:generate a login URL'
        )
        _describe -t account 'account subcommand' account_cmds && ret=0
        ;;
      (claim)
        local -a claim_cmds=(
          'generate:generate a random claim code'
          'url:print a claim URL given the code and options'
          'exchange:exchange the claim for the secret key'
        )
        _describe -t claim 'claim subcommand' claim_cmds && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
