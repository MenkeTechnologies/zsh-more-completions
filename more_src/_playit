#compdef playit

# Zsh completion for playit-agent
# https://playit.gg

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'setup:Run the setup process to claim the agent'
  'reset:Reset the local configuration'
  'version:Show version information'
)

_arguments -s -S \
  '--secret=[manually provide the secret key]:key:' \
  '--config=[specify a custom path for the config file]:path:_files' \
  '--version[show version information]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'playit command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (setup|reset|version)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
