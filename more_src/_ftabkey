#compdef ftabkey
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/ftabkey.txt
# Copy a FITS table element to a FITS header keyword

local ret=1

_arguments -s \
  "tblfile=[input FITS table file]:file:_files" \
  "column=[column name]:" \
  "row=[row number]:" \
  "fitsfile=[target FITS file]:file:_files" \
  "keyword=[keyword name to write]:" \
  "element=[vector element number]:" \
  "add=[add keyword if not present]:bool:(yes no)" \
  "*:FITS file:_files" && ret=0

return ret
