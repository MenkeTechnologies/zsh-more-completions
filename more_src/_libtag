#compdef tagreader tagwriter taglib libtag libtag1 libtag-bin
# _libtag — Scott Wheeler TagLib audio metadata library tagreader and tagwriter examples for ID3/Vorbis/APE/MP4/FLAC/Opus tag editing (taglib team, C++); getopt-ish
# upstream: https://github.com/taglib/taglib

_libtag() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[title]:str:' \
        '--title=+[title]:str:' \
        '-a+[artist]:str:' \
        '--artist=+[artist]:str:' \
        '-A+[album]:str:' \
        '--album=+[album]:str:' \
        '-c+[comment]:str:' \
        '--comment=+[comment]:str:' \
        '-g+[genre]:str:' \
        '--genre=+[genre]:str:' \
        '-y+[year]:n:' \
        '--year=+[year]:n:' \
        '-T+[track]:n:' \
        '--track=+[track]:n:' \
        '-D+[disc]:n:' \
        '--disc=+[disc]:n:' \
        '-C+[composer]:str:' \
        '--composer=+[composer]:str:' \
        '-L+[album artist]:str:' \
        '--album-artist=+[album artist]:str:' \
        '-B+[bpm]:n:' \
        '--bpm=+[bpm]:n:' \
        '-r[remove all tags]' \
        '--remove-all[remove all tags]' \
        '-R+[remove tag]:tag:(title artist album comment genre year track disc composer)' \
        '--remove=+[remove tag]:tag:(title artist album comment genre year track disc composer)' \
        '-p[print all properties]' \
        '--print[print all properties]' \
        '-j[print JSON]' \
        '--json[print JSON]' \
        '-s[strip ID3v1]' \
        '--strip-id3v1[strip ID3v1]' \
        '-S[strip ID3v2]' \
        '--strip-id3v2[strip ID3v2]' \
        '-X+[id3v2 frame]:str:' \
        '--id3v2-frame=+[id3v2 frame]:str:' \
        '*:audio file:_files -g "*.mp3 *.flac *.ogg *.oga *.opus *.m4a *.mp4 *.aac *.wav *.aiff *.ape *.wv *.wma *.tta *.mpc"'
}

_libtag "$@"
