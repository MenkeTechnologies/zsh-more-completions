#compdef pslToChain
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: convert psl records to chain records

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-fixStrand[reverse-complement negative target strand PSLs]' \
  '-ignore[ignore negative target strand records]' \
  ':psl in:_files' \
  ':chain out:_files' && ret=0

return ret
