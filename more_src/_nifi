#compdef nifi nifi.sh
# _nifi — Apache NiFi launcher (control script for the standalone NiFi data-flow runtime; subcommands: start, stop, restart, status, run, install, set-conf-dir, dump, env, diagnostics, decommission, status-history; --bootstrapconf bootstrap.conf path, -V show version)
# upstream: https://github.com/apache/nifi
# Subcommands from Apache NiFi nifi-bootstrap on tip.

_nifi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '--bootstrapconf+[bootstrap.conf]:file:_files' \
        '1:command:(start stop restart status run install set-conf-dir dump env diagnostics decommission status-history)' \
        '*::arg:'
}

_nifi "$@"
