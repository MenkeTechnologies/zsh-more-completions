#compdef collapse
# Documentation: https://starlink.eao.hawaii.edu/docs/sun95.htx/sun95ss24.html
# KAPPA COLLAPSE - reduce the number of axes by compressing along an axis

local ret=1

_arguments -C \
  'IN=[input NDF]:NDF file:_files' \
  'OUT=[output NDF]:NDF file:_files' \
  'AXIS=[axis to collapse (index/symbol/SPEC/TIME/SKYLON/SKYLAT)]:axis:' \
  'ESTIMATOR=[estimator for output values]:estimator:(Mean WMean Mode Median FastMed Absdev Cmean Csigma Comax Comin FBad FGood Integ Iwc Iwd Max Min NBad NGood Rms Sigma Sum)' \
  'LOW=[lower bound of axis range]:low:' \
  'HIGH=[upper bound of axis range]:high:' \
  'COMP=[array component]:component:(Data Error Quality Variance)' \
  'CLIP=[k-sigma clipping levels]:clip:' \
  'TRIM=[remove the collapsed axis]:flag:(TRUE FALSE)' \
  'VARIANCE=[use variance to weight values]:flag:(TRUE FALSE)' \
  'WCSATTS=[temporary WCS Frame attribute settings]:atts:' \
  'WLIM=[minimum good-pixel fraction]:wlim:' \
  '*:NDF file:_files' && ret=0

return ret
