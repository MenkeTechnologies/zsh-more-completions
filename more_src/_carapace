#compdef carapace

# Zsh completion for carapace (shell completion engine)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list[list available completers]' \
  '--style=[set style]:style' \
  '--scrub=[remove stored completion data]:completer' \
  '--sandbox=[run in sandbox mode]:shell:(bash elvish fish nushell oil powershell tcsh xonsh zsh)' \
  '--condition=[list conditions for a command]:command' \
  '--run-completer[run as completer]' \
  '--macro=[list macros]' \
  '--schema[show schema]' \
  '1:completer' \
  '2:shell:(bash elvish fish nushell oil powershell tcsh xonsh zsh)' \
  '*:args' && ret=0

return ret
