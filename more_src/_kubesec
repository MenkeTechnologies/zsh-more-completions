#compdef kubesec
# Documentation: https://github.com/controlplaneio/kubesec
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'scan:scan a Kubernetes resource for security risks'
      'http:start an HTTP server for scanning'
      'print-rules:display scanning rules with their scores'
      'help:show help for a command'
    )
    _describe -t commands 'kubesec command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (scan)
        _arguments -s -S \
          '--kubernetes-version=[Kubernetes schema version (x.y.z)]:version:' \
          '--schema-location=[custom schema location URL or path]:location:' \
          '--help[show help]' \
          '*:resource file:_files -g "*.{yaml,yml,json}"' && ret=0
        ;;
      (http)
        _arguments -s -S \
          '--help[show help]' \
          '1:port:' && ret=0
        ;;
      (print-rules)
        _arguments -s -S \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
