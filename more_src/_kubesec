#compdef kubesec

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'scan:scan a Kubernetes resource for security risks'
      'http:start an HTTP server for scanning'
    )
    _describe -t commands 'kubesec command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (scan)
        _arguments -s -S \
          '1:resource file:_files -g "*.{yaml,yml,json}"' \
          '--help[show help]' && ret=0
        ;;
      (http)
        _arguments -s -S \
          '--port=[port to listen on]:port' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
