#compdef agebox
# Documentation: https://github.com/slok/agebox
# age based repository file encryption gitops tool

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--private-keys[directory or path for private keys]:path:_files' \
  '--public-keys[directory for public keys]:path:_files -/' \
  '--all[apply command to all tracked files]' \
  '--dry-run[preview actions without executing]' \
  '--force[force operation]' \
  '--no-decrypt[skip decryption validation]' \
  '--no-log[suppress logging output]' \
  '--delete[remove file from filesystem when untracking]' \
  '--filter[regex pattern to filter files]:regex:_default' \
  '1:command:(init encrypt decrypt reencrypt cat untrack validate)' \
  '*:file:_files' && ret=0

return ret
