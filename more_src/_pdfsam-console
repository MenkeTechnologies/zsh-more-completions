#compdef pdfsam-console

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'concat:concatenate PDFs'
  'split:split PDF'
  'encrypt:encrypt PDFs'
  'decrypt:decrypt PDFs'
  'mix:alternate-page mix'
  'setviewer:set viewer preferences'
  'slideshow:slideshow PDF'
)

_arguments -C \
  '-h[short usage]' \
  '-help[verbose usage]' \
  '-?[short usage]' \
  '-log=[log file]:file:_files' \
  '-overwrite[overwrite output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'pdfsam subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (concat)
        _arguments \
          '*-f[input PDF]:file:_files -g "*.pdf"' \
          '-d[input dir]:dir:_files -/' \
          '-l[list file]:file:_files' \
          '-o[output PDF]:file:_files' \
          '-u[page selection]:spec:' \
          '-pdfversion[version]:ver:' \
          '-compressed[compress]' \
          '-copyfields[preserve form fields]' \
          '-rotation[rotation]:rotation:' && ret=0 ;;
      (split)
        _arguments \
          '-f[input PDF]:file:_files -g "*.pdf"' \
          '-o[output dir]:dir:_files -/' \
          '-s[split type]:type:(BURST ODD EVEN SPLIT NSPLIT SIZE BOOKMARK)' \
          '-n[N value]:n:' \
          '-p[prefix]:prefix:' \
          '-pdfversion[version]:ver:' \
          '-compressed[compress]' && ret=0 ;;
      (encrypt|decrypt)
        _arguments \
          '*-f[input PDF]:file:_files -g "*.pdf"' \
          '-d[input dir]:dir:_files -/' \
          '-o[output dir]:dir:_files -/' \
          '-p[prefix]:prefix:' \
          '-apwd[admin password]:pw:' \
          '-upwd[user password]:pw:' \
          '-etype[encryption type]:type:(rc40 rc128 aes128)' \
          '-allow[allowed actions]:list:' \
          '-pdfversion[version]:ver:' \
          '-compressed[compress]' && ret=0 ;;
      (mix)
        _arguments \
          '-f[first PDF]:file:_files -g "*.pdf"' \
          '-s[second PDF]:file:_files -g "*.pdf"' \
          '-o[output PDF]:file:_files' \
          '-reversefirst[reverse first]' \
          '-reversesecond[reverse second]' \
          '-step[first step]:n:' \
          '-secondstep[second step]:n:' && ret=0 ;;
      (setviewer)
        _arguments \
          '*-f[input PDF]:file:_files -g "*.pdf"' \
          '-d[input dir]:dir:_files -/' \
          '-o[output dir]:dir:_files -/' \
          '-p[prefix]:prefix:' \
          '-pagemode[page mode]:mode:(none outlines thumbs fullscreen ocg attachments)' \
          '-pagelayout[layout]:layout:(singlepage onecolumn twocolumnleft twocolumnright twopageleft twopageright)' \
          '-direction[direction]:dir:(l2r r2l)' && ret=0 ;;
    esac
    ;;
esac

return ret
