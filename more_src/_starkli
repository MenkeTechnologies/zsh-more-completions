#compdef starkli
# Documentation: https://man.archlinux.org/search?q=starkli
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'signer:cryptographic key/signer management'
  'account:Starknet account management'
  'declare:declare a contract class'
  'deploy:deploy a contract via UDC'
  'invoke:send a state-changing invoke transaction'
  'call:read-only call to a contract'
  'balance:check account balance'
  'class-hash:compute contract class hash'
  'class-by-hash:fetch a class by hash'
  'class-at:get class at an address'
  'transaction:transaction inspection commands'
  'transaction-receipt:fetch a transaction receipt'
  'transaction-trace:fetch a transaction trace'
  'transaction-status:fetch a transaction status'
  'block:show a block'
  'block-number:show latest block number'
  'block-hash:show latest block hash'
  'state-update:show a state update'
  'storage:read storage slot'
  'nonce:show account nonce'
  'chain-id:show chain id'
  'syncing:show syncing state'
  'spec-version:show RPC spec version'
  'to-cairo-string:convert ASCII to Cairo short string'
  'parse-cairo-string:parse Cairo short string'
  'mont:Montgomery arithmetic helpers'
  'completions:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--rpc=[Starknet RPC endpoint]:url:' \
  '--network=[network preset]:network:(mainnet sepolia goerli sepolia-integration)' \
  '--account=[account file path]:file:_files -g "*.json"' \
  '--keystore=[keystore file]:file:_files -g "*.json"' \
  '--keystore-password=[keystore password]:password:' \
  '--private-key=[raw private key]:hex:' \
  '--signer=[signer file]:file:_files' \
  '--gas=[gas limit]:n:' \
  '--gas-price=[gas price]:n:' \
  '--max-fee=[max fee]:n:' \
  '--max-fee-raw=[raw max fee in wei]:n:' \
  '--simulate[simulate without sending]' \
  '--estimate-only[only estimate fee]' \
  '--watch[wait for transaction]' \
  '--poll-interval=[receipt poll interval]:ms:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'starkli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (signer)
        _arguments \
          '*::sub:(keystore gen-keypair gen-public)' && ret=0
        case $words[2] in
          (keystore)
            _arguments \
              '*::sub:(new from-key from-seed inspect inspect-private)' && ret=0 ;;
        esac ;;
      (account)
        _arguments \
          '*::sub:(oz argent braavos init deploy fetch info)' && ret=0
        case $words[2] in
          (oz|argent|braavos)
            _arguments '*::sub:(init)' && ret=0 ;;
        esac ;;
      (transaction)
        _arguments '*::sub:(receipt status trace)' && ret=0 ;;
      (completions)
        _arguments '*::shell:(bash zsh fish powershell elvish)' && ret=0 ;;
    esac ;;
esac

return ret
