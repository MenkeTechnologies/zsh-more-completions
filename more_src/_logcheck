#compdef logcheck
# _logcheck — Debian Logcheck logcheck CLI shell-script frontend monitoring system log files for security alerts attacks intrusions running periodically via cron filtering known-good patterns regex-based ignore-rules emitting per-tier reports cracking-attempts system-events attack-events mail-summary administrator notification (Debian team, shell); getopt
# upstream: https://salsa.debian.org/debian/logcheck

_logcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-D[debug rules]' \
        '--debug-rules[debug rules]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '-l+[log file]:file:_files -g "*.log"' \
        '--logfile=+[file]:file:_files -g "*.log"' \
        '-L+[lock file]:file:_files' \
        '--lockfile=+[file]:file:_files' \
        '-S+[state dir]:dir:_files -/' \
        '--statedir=+[dir]:dir:_files -/' \
        '-R+[rule dir]:dir:_files -/' \
        '--rulesdir=+[dir]:dir:_files -/' \
        '-r+[rule file]:file:_files' \
        '--rules=+[file]:file:_files' \
        '-l+[level]:l:(workstation server paranoid)' \
        '--level=+[level]:l:(workstation server paranoid)' \
        '-m+[mail to]:str:' \
        '--mailto=+[address]:str:' \
        '-H+[hostname]:_hosts' \
        '--hostname=+[name]:_hosts' \
        '-t+[temp dir]:dir:_files -/' \
        '--tmpdir=+[dir]:dir:_files -/' \
        '-o[stdout]' \
        '--stdout[stdout]' \
        '-T[do not delete temp files]' \
        '--keep-tmp[keep temp files]' \
        '-p[paranoid mode]' \
        '--paranoid[paranoid mode]' \
        '-s[server mode]' \
        '--server[server mode]' \
        '-w[workstation mode]' \
        '--workstation[workstation mode]' \
        '*::'
}

_logcheck "$@"
