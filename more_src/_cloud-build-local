#compdef cloud-build-local
# Documentation: https://github.com/GoogleCloudPlatform/cloud-build-local
# cloud-build-local - run Google Cloud Build builds locally for debugging

local ret=1

_arguments -s \
  '--help[print the help message]' \
  '--version[print the local builder version]' \
  '--config=[file path of the config file]:file:_files -g "*.{yaml,yml}"' \
  '--substitutions=[key=value pairs separated by comma]:substitutions:' \
  '--dryrun=[lint the config and print but do not run the commands]:bool:(true false)' \
  '--push[push the images to the registry]' \
  '--no-source[prevent Local Builder from using source for this build]' \
  '--bind-mount-source[bind mount the source directory under /workspace]' \
  '--write-workspace=[copy the workspace directory to this host directory]:dir:_files -/' \
  '*:source dir:_files -/' && ret=0

return ret
