#compdef nodenv

# Zsh completion for nodenv - Node.js version manager

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'commands:List all available nodenv commands'
  'completions:List completions for a command'
  'exec:Run an executable with the selected Node version'
  'global:Set or show the global Node version'
  'help:Display help for a command'
  'hooks:List hook scripts for a command'
  'init:Configure the shell environment for nodenv'
  'install:Install a Node version'
  'local:Set or show the local application-specific Node version'
  'prefix:Display the directory where a Node version is installed'
  'rehash:Rehash nodenv shims'
  'root:Display the root directory where versions and shims are kept'
  'shell:Set or show the shell-specific Node version'
  'shims:List existing nodenv shims'
  'uninstall:Uninstall a specific Node version'
  'version:Show the current Node version and its origin'
  'version-file:Detect the file that sets the current nodenv version'
  'version-file-read:Read the version from the specified file'
  'version-file-write:Write a version number to the specified file'
  'version-name:Show the current Node version'
  'version-origin:Explain how the current Node version is set'
  'versions:List installed Node versions'
  'whence:List all versions that contain the given executable'
  'which:Display the full path to an executable'
)

_nodenv_versions() {
  local -a versions
  versions=(${(f)"$(nodenv versions --bare 2>/dev/null)"})
  [[ -n "$versions" ]] && compadd -a versions
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t subcommands 'nodenv command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      global|local|shell)
        _arguments '1:version:_nodenv_versions' && ret=0
        ;;
      install)
        _arguments \
          '-s[skip if already installed]' \
          '-f[force installation even if version is already installed]' \
          '-k[keep source tree after installation]' \
          '-v[verbose mode]' \
          '--list[list all available versions]' \
          '1:version:' && ret=0
        ;;
      uninstall)
        _arguments \
          '-f[force removal without prompting]' \
          '1:version:_nodenv_versions' && ret=0
        ;;
      exec)
        _arguments \
          '1:command:_command_names' \
          '*:arguments:' && ret=0
        ;;
      prefix|which|whence)
        _arguments '1:version or command:_nodenv_versions' && ret=0
        ;;
      rehash|versions|version|version-name|version-origin|root|init|shims|commands)
        ;;
      completions|hooks)
        _arguments '1:command:' && ret=0
        ;;
      help)
        _describe -t subcommands 'nodenv command' subcommands && ret=0
        ;;
      version-file-read)
        _arguments '1:file:_files' && ret=0
        ;;
      version-file-write)
        _arguments '1:file:_files' '2:version:_nodenv_versions' && ret=0
        ;;
    esac
    ;;
esac

return ret
