#compdef susmgauss2
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/filters/susmgauss2.c
# SMOOTH a uniformly sampled 2d array of velocities using a Gaussian filter

local ret=1

_arguments -s -S \
  'a1=[a1]:a1:' \
  'a2=[a2]:a2:' \
  '*:file:_files' && ret=0

return ret
