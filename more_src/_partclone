# Documentation: https://manpages.ubuntu.com/manpages/noble/man8/partclone.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --source)'{-s,--source}'+[source file or device]:src:_files' \
  '(-o --output)'{-o,--output}'+[output file or device]:out:_files' \
  '(-O --overwrite)'{-O,--overwrite}'+[overwrite target if exists]:file:_files' \
  '(-r --restore)'{-r,--restore}'[restore mode]' \
  '(-c --clone)'{-c,--clone}'[clone mode]' \
  '(-b --dev-to-dev)'{-b,--dev-to-dev}'[device-to-device mode]' \
  '(-D --domain)'{-D,--domain}'[generate ddrescue domain log]' \
  '--offset_domain=[offset for domain log]:offset:' \
  '--restore_raw_file[create raw file for loop device]' \
  '(-R --rescue)'{-R,--rescue}'[continue past read errors]' \
  '(-C --no_check)'{-C,--no_check}'[skip size/free-space checks]' \
  '(-N --ncurse)'{-N,--ncurse}'[use ncurses TUI]' \
  '-X[output messages in dialog format]' \
  '(-I --ignore_fschk)'{-I,--ignore_fschk}'[ignore filesystem check]' \
  '--ignore_crc[ignore CRC errors]' \
  '(-F --force)'{-F,--force}'[force progress]' \
  '(-f --UI-fresh)'{-f,--UI-fresh}'+[UI refresh interval]:sec:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress]' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:(1 2 3)' \
  '(-l --logfile)'{-l,--logfile}'+[log file]:file:_files' \
  '(-z --buffer_size)'{-z,--buffer_size}'+[read/write buffer size]:bytes:' && ret=0

return ret
