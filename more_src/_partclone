#compdef partclone partclone.ext2 partclone.ext3 partclone.ext4 partclone.ntfs partclone.fat32 partclone.fat16 partclone.fat12 partclone.exfat partclone.xfs partclone.btrfs partclone.f2fs partclone.hfsplus partclone.apfs partclone.minix partclone.reiserfs partclone.reiser4 partclone.jfs partclone.ufs partclone.vmfs partclone.nilfs2 partclone.swap partclone.dd partclone.restore partclone.chkimg partclone.info partclone.imager
# Documentation: https://manpages.ubuntu.com/manpages/noble/man8/partclone.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --source)'{-s,--source}'+[source file or device]:src:_files' \
  '(-o --output)'{-o,--output}'+[output file or device]:out:_files' \
  '(-O --overwrite)'{-O,--overwrite}'+[overwrite target if exists]:file:_files' \
  '(-r --restore)'{-r,--restore}'[restore mode]' \
  '(-c --clone)'{-c,--clone}'[clone mode]' \
  '(-b --dev-to-dev)'{-b,--dev-to-dev}'[device-to-device mode]' \
  '(-D --domain)'{-D,--domain}'[generate domain map for ddrescue]' \
  '(-R --rescue)'{-R,--rescue}'[continue past read errors]' \
  '(-C --no_check)'{-C,--no_check}'[do not check size of source/target]' \
  '(-I --ignore_fschk)'{-I,--ignore_fschk}'[ignore filesystem check]' \
  '(-i --ignore_crc)'{-i,--ignore_crc}'[ignore CRC errors]' \
  '(-F --force)'{-F,--force}'[force on dirty filesystems]' \
  '(-f --UI-fresh)'{-f,--UI-fresh}'+[UI refresh interval]:sec:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress]' \
  '(-d --debug)'{-d,--debug}'+[debug level]:level:(0 1 2 3)' \
  '(-L --logfile)'{-L,--logfile}'+[log file]:file:_files' \
  '(-N --note)'{-N,--note}'+[note for image]:note:' \
  '(-a --offset_domain)'{-a,--offset_domain}'+[offset for domain log]:off:' \
  '(-T --buffer_size)'{-T,--buffer_size}'+[buffer size]:bytes:' \
  '(-z --buffer-size)'{-z,--buffer-size}'+[buffer size]:bytes:' && ret=0

return ret
