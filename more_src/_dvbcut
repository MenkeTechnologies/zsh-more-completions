#compdef dvbcut
# Documentation: https://manpages.debian.org/testing/dvbcut/dvbcut.1.en.html
# Frame-precise MPEG transport stream cutter for DVB recordings. Flags from dvbcut main.cpp argument parser.

local ret=1

_arguments -s -S \
  '-generateidx[generate index only, no GUI]' \
  '-idx[use/write index file]:index file:_files' \
  '-batch[run in batch (non-interactive) mode]' \
  '-cut[cutting rule list (4:3, 16:9, TS, TS2 or frame/timestamp list)]:cut spec:' \
  '-exp[exported output file name]:output:_files' \
  '-format[export format (0=MPEG program stream/DVD)]:format:(0 1 2)' \
  '-automarker[auto markers at boundaries (0=none 1=start 2=end 3=both)]:marker:(0 1 2 3)' \
  '-voracious[disable cache-friendly mode]' \
  '*:mpeg file:_files' && ret=0

return ret
