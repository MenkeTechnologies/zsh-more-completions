#compdef in-toto-record
# Documentation: https://in-toto.readthedocs.io/en/latest/command-line-tools/in-toto-record.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# in-toto-record: incrementally record materials/products into an in-toto link metadata file
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --step-name)'{-n,--step-name}'=[step name]:name:' \
  '(-P --password)'{-P,--password}'[prompt for key password]' \
  '(-g --gpg)'{-g,--gpg}'=[GPG key id]:keyid:' \
  '--gpg-home=[GPG home directory]:dir:_files -/' \
  '(-k --key)'{-k,--key}'=[signing key file]:file:_files' \
  '--key-type=[signing key type]:type:(ed25519 rsa ecdsa)' \
  '*'{-e,--exclude}'=[exclude pattern]:pattern:' \
  '(-b --base-path)'{-b,--base-path}'=[base path]:dir:_files -/' \
  '(-l --lstrip-paths)'*{-l,--lstrip-paths}'=[lstrip path prefix]:prefix:' \
  '--use-dsse[use DSSE wrapper]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '1:action:(start stop)' \
  '*::arg:->args' && ret=0

case $line[1] in
  (start)
    _arguments '*'{-m,--materials}'=[material path]:path:_files' && ret=0
    ;;
  (stop)
    _arguments \
      '*'{-p,--products}'=[product path]:path:_files' \
      '(-d --metadata-directory)'{-d,--metadata-directory}'=[metadata output dir]:dir:_files -/' && ret=0
    ;;
esac
return ret
