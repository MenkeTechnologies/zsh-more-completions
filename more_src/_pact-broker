#compdef pact-broker

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'publish:publish pacts to a broker'
  'list-latest-pact-versions:list latest pact versions'
  'get-pacts:download pacts'
  'create-environment:create an environment'
  'update-environment:update an environment'
  'delete-environment:delete an environment'
  'describe-environment:describe an environment'
  'list-environments:list environments'
  'record-deployment:record a deployment'
  'record-undeployment:record an undeployment'
  'record-release:record a release'
  'record-support-ended:record support ended'
  'can-i-deploy:check if a deployment is safe'
  'can-i-merge:check if a merge is safe'
  'create-or-update-pacticipant:create or update a pacticipant'
  'describe-pacticipant:describe a pacticipant'
  'list-pacticipants:list pacticipants'
  'create-webhook:create a webhook'
  'create-or-update-webhook:create or update a webhook'
  'delete-webhook:delete a webhook'
  'test-webhook:test a webhook'
  'delete-branch:delete a branch'
  'create-version-tag:create a version tag'
  'delete-version-tag:delete a version tag'
  'describe-version:describe a version'
  'create-or-update-version:create or update a version'
  'generate-uuid:generate a UUID'
  'provider-states:list provider states'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --broker-base-url)'{-b,--broker-base-url=}'[broker base URL]:url:' \
  '(-u --broker-username)'{-u,--broker-username=}'[broker username]:user:_users' \
  '(-p --broker-password)'{-p,--broker-password=}'[broker password]:password:' \
  '(-k --broker-token)'{-k,--broker-token=}'[broker token]:token:' \
  '(-o --output)'{-o,--output=}'[output format]:format:(json text table pretty)' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'pact-broker subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (publish)
        _arguments \
          '(-a --consumer-app-version)'{-a,--consumer-app-version=}'[consumer app version]:version:' \
          '(-h --branch)'{-h,--branch=}'[branch]:branch:' \
          '*'{-t,--tag=}'[tag]:tag:' \
          '(-g --tag-with-git-branch)'{-g,--tag-with-git-branch}'[tag with git branch]' \
          '--merge[merge with existing pact]' \
          '--build-url=[CI build URL]:url:' \
          '*:pact:_files -g "*.json"' && ret=0
        ;;
      (can-i-deploy|can-i-merge)
        _arguments \
          '*'{-a,--pacticipant=}'[pacticipant]:name:' \
          '*'{-e,--version=}'[version]:version:' \
          '*--ignore=[ignore pacticipant]:name:' \
          '(-l --latest)'{-l,--latest=}'[latest tag]:tag:' \
          '--branch=[branch]:branch:' \
          '--main-branch[use main branch]' \
          '--to-environment=[target environment]:env:' \
          '--retry-while-unknown=[retries]:n:' \
          '--retry-interval=[retry interval seconds]:secs:' \
          '--dry-run[dry run]' && ret=0
        ;;
      (create-or-update-pacticipant|describe-pacticipant)
        _arguments \
          '--name=[pacticipant name]:name:' \
          '--display-name=[display name]:name:' \
          '--main-branch=[main branch]:branch:' \
          '--repository-url=[repository URL]:url:' && ret=0
        ;;
      (record-deployment|record-undeployment|record-release|record-support-ended)
        _arguments \
          '(-a --pacticipant)'{-a,--pacticipant=}'[pacticipant]:name:' \
          '(-e --version)'{-e,--version=}'[version]:version:' \
          '--environment=[environment]:env:' \
          '--application-instance=[application instance]:instance:' && ret=0
        ;;
      (create-environment|update-environment)
        _arguments \
          '--name=[environment name]:name:' \
          '--display-name=[display name]:name:' \
          '--production[production environment]' \
          '--contact-name=[contact name]:name:' \
          '--contact-email-address=[contact email]:email:' \
          '--uuid=[environment UUID]:uuid:' && ret=0
        ;;
      (test-webhook|describe-environment|delete-environment)
        _arguments \
          '--uuid=[UUID]:uuid:' && ret=0
        ;;
    esac
    ;;
esac

return ret
