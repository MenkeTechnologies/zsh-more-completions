#compdef torbrowser-launcher
# _torbrowser-launcher — install / launch / update Tor Browser (micahflee/torbrowser-launcher)
# upstream: https://github.com/micahflee/torbrowser-launcher
# Flags from torbrowser_launcher/__init__.py (argparse).

_torbrowser-launcher() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--settings[open Tor Browser Launcher settings]'
        '*:URL to load:'
    )
    _arguments $args
}

_torbrowser-launcher "$@"
