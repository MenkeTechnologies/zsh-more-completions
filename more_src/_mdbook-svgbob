#compdef mdbook-svgbob
# _mdbook-svgbob — render ASCII boxes as SVG via svgbob in mdbook (boozook/mdbook-svgbob)
# upstream: https://github.com/boozook/mdbook-svgbob
# Subcommands from src/cli.rs (clap).

_mdbook-svgbob() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-svgbob "$@"
