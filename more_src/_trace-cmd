#compdef trace-cmd

# Zsh completion for trace-cmd (Linux kernel tracing command-line tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'record:Record a trace'
  'start:Start tracing without recording'
  'stop:Stop the kernel from recording'
  'restart:Restart recording'
  'extract:Extract data from the kernel buffer'
  'reset:Disable all tracing and clear buffers'
  'report:Read and display a trace file'
  'stream:Start tracing and stream to stdout or network'
  'profile:Start profiling and report results'
  'hist:Display a histogram of events'
  'stat:Display the current tracing status'
  'options:List available tracing options'
  'show:Show the contents of tracing files'
  'list:List available events, plugins, and options'
  'listen:Listen for incoming connections from record -N'
  'split:Split a trace file into smaller files'
  'snapshot:Take a snapshot of the running trace'
  'stack:Display the kernel stack trace'
  'check-events:Parse format strings for events'
  'dump:Dump the meta data of a trace file'
  'convert:Convert a trace file'
  'clear:Clear the ftrace buffer'
  'attach:Attach to a running trace-cmd session'
  'agent:Run as an agent for remote tracing'
  'setup-guest:Set up vsock tracing for a guest'
  'mem:Show memory usage of trace'
)

_arguments -s -S -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'trace-cmd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      record|start|stream|profile)
        _arguments -s -S \
          '(-e --event)'{-e,--event}'=[Enable event]:event' \
          '(-p --plugin)'{-p,--plugin}'=[Use specified tracer plugin]:plugin' \
          '(-l --func)'{-l,--func}'=[Limit tracing to specified function]:function' \
          '(-g --graph)'{-g,--graph}'=[Set function_graph tracer]:function' \
          '(-n --notrace)'{-n,--notrace}'=[Do not trace specified function]:function' \
          '(-T --stacktrace)'{-T,--stacktrace}'[Enable stacktraces on events]' \
          '(-f --filter)'{-f,--filter}'=[Filter expression]:expression' \
          '(-R --trigger)'{-R,--trigger}'=[Event trigger]:trigger' \
          '(-o --output)'{-o,--output}'=[Output file]:file:_files' \
          '(-O --option)'{-O,--option}'=[Set tracing option]:option' \
          '(-d --delay)'{-d,--delay}'=[Delay recording by ms]:milliseconds' \
          '-C+[Set clock source]:clock' \
          '-b+[Set kernel buffer size in kilobytes]:size' \
          '-B+[Create a sub buffer instance]:instance' \
          '-N+[Send trace data to host]:host\:port' \
          '-t[Use the system time for timestamps]' \
          '-D[Full disable of tracing before enabling events]' \
          '-s+[Set sleep time between reads in microseconds]:usecs' \
          '-r+[Set the priority of the recording]:priority' \
          '*:command:_command_names -e' && ret=0
        ;;
      report)
        _arguments -s -S \
          '(-i --input)'{-i,--input}'=[Input trace file]:file:_files' \
          '(-F --filter)'{-F,--filter}'=[Filter events]:filter' \
          '(-l --latency)'{-l,--latency}'[Show latency format]' \
          '(-w --wakeup)'{-w,--wakeup}'[Show wakeup events]' \
          '-R[Show raw format]' \
          '-t[Print full timestamps]' \
          '--cpu=[Only display events for given CPU]:cpu' \
          '--check-events[Parse format strings]' && ret=0
        ;;
      list)
        _arguments -s -S \
          '-e[List available events]' \
          '-t[List available tracers]' \
          '-o[List available options]' \
          '-f[List available filter functions]' \
          '-P[List loaded tracer plugins]' \
          '-B[List buffer instances]' \
          '-C[List available clocks]' && ret=0
        ;;
      show)
        _arguments -s -S \
          '-c[Show trace_pipe_raw content]' \
          '-p[Show set tracing plugins]' \
          '-f[Show set tracing functions]' \
          '-B+[Show for given buffer instance]:instance' && ret=0
        ;;
      split)
        _arguments -s -S \
          '(-i --input)'{-i,--input}'=[Input trace file]:file:_files' \
          '(-o --output)'{-o,--output}'=[Output file prefix]:prefix' \
          '-c+[Split by number of CPUs]:cpus' \
          '-s+[Start at time]:time' \
          '-m+[End at time]:time' && ret=0
        ;;
    esac
    ;;
esac

return ret
