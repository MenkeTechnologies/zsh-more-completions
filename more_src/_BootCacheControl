#compdef BootCacheControl

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start recording history and play back the playlist'
  'stop:stop recording history and write playlist to file'
  'mount:notify the boot cache of a new mount'
  'jettison:jettison the cache'
  'statistics:print statistics for the currently-active cache'
  'debugbuffer:print the debug buffer, if available'
  'tag:insert the end-prefetch tag'
  'merge:merge playlist files into one'
  'print:print the contents of the playlist file'
  'unprint:read a playlist from standard input and write to file'
  'truncate:truncate the playlist file to a given count'
  'generalize:modify the playlist to apply to any root volume'
)

_arguments -C \
  '-v[verbose]' \
  '-vv[more verbose]' \
  '-vvv[even more verbose]' \
  '-f+[playlist file]:file:_files' \
  '-t+[batch number offset]:batch:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'BootCacheControl command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (merge)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
