#compdef hevi

# Zsh completion for hevi hex viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[print help]' \
  '-v[print version]' \
  '--color[enable coloring]' \
  '--no-color[disable coloring]' \
  '--uppercase[uppercase hex]' \
  '--lowercase[lowercase hex]' \
  '--size[show size at end]' \
  '--no-size[hide size]' \
  '--offset[show offset column]' \
  '--no-offset[hide offset]' \
  '--ascii[show ASCII column]' \
  '--no-ascii[hide ASCII]' \
  '--skip-lines[skip identical lines]' \
  '--no-skip-lines[do not skip identical lines]' \
  '--raw[raw output format]' \
  '--show-palette[print color palette]' \
  '--parser[parser name]:parser:(elf pe qoi data)' \
  '1:file:_files' && ret=0

return ret
