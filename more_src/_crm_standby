#compdef crm_standby
# Documentation: https://www.mankier.com/8/crm_standby
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# crm_standby: query/set/delete a Pacemaker node standby attribute
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[display help, then exit]' \
  '(- *)--version[display version information, then exit]' \
  '*-V[increase debug output]' \
  '*--verbose[increase debug output]' \
  '(-q --quiet)'{-q,--quiet}'[print only the value when querying]' \
  '(-G --query)'{-G,--query}'[query current standby value]' \
  '(-v --update)'{-v+,--update=}'[set standby value]:value:(on off yes no true false)' \
  '(-D --delete)'{-D,--delete}'[let standby use default value]' \
  '(-N --node)'{-N+,--node=}'[node to operate on]:node:' \
  '(-l --lifetime)'{-l+,--lifetime=}'[lifetime]:lifetime:(reboot forever)' \
  '(-i --id)'{-i+,--id=}'[XML ID for the standby attribute]:id:' && ret=0
return ret
