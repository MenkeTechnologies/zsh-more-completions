#compdef crm_standby

# crm_standby: get/set node standby state
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-V[verbose]' \
  '-G[query standby value]' \
  '--query[query standby value]' \
  '-v[set standby (yes|no)]:value:(on off yes no true false)' \
  '--update=[set standby (yes|no)]:value:(on off yes no true false)' \
  '-D[delete standby attribute]' \
  '--delete[delete standby attribute]' \
  '-N[node name]:node:' \
  '--node=[node name]:node:' \
  '-l[lifetime]:lifetime:(reboot forever)' \
  '--lifetime=[lifetime]:lifetime:(reboot forever)' \
  '--output-as=[output format]:fmt:(text xml html)' \
  '*::crm_standby args:_files' && ret=0
return ret
