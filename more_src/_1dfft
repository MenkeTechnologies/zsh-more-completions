#compdef 1dfft
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/1dfft.html
# Compute absolute value of FFT of columns in an AFNI 1D file

local ret=1

_arguments -s -S \
  '-ignore[skip the first sss lines in the input file]:sss' \
  '-use[use only uuu lines of the input file]:uuu' \
  '-nfft[set FFT length to nnn]:nnn' \
  '-tocx[save Re and Im parts of transform in 2 columns]' \
  '-fromcx[convert 2 column complex input into 1 column real output]' \
  '-hilbert[with -fromcx, inverse FFT does the Hilbert transform]' \
  '-nodetrend[skip the detrending of the input]' \
  '*:file:_files' && ret=0

return ret
