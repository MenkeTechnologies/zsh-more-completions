#compdef hivemind

_arguments \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-f,--procfile}'[specify Procfile]:file:_files' \
  {-p,--port}'[specify port]:port:' \
  {-l,--processes}'[specify processes to run]:processes:' \
  {-r,--root}'[specify root directory]:dir:_directories' \
  {-t,--title}'[specify window title]:title:' \
  '--color[force color output]' \
  {-d,--daemon}'[run in background]' \
  {-T,--no-prefix}'[disable process name prefix]' \
  '--no-timestamp[disable timestamps]' \
  '--shutdown-timeout[specify shutdown timeout in seconds]:seconds:' \
  '*:procfile:_files'
