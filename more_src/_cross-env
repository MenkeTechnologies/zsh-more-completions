#compdef cross-env cross-env-shell
# Documentation: https://github.com/kentcdodds/cross-env
# Reference accessed: 2026-05-17
# Verified: upstream README — cross-env has no flags of its own beyond
# --help and --version; everything else is forwarded as command argv after
# VAR=value pairs.

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '*:command:_command_names -e'
