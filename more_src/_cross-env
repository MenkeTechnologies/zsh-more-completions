#compdef cross-env cross-env-shell
# Documentation: https://man.archlinux.org/search?q=cross-env
# Reference accessed: 2026-05-16

# Zsh completion for cross-env - cross-platform environment variable setter

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '*:command:_command_names -e'
