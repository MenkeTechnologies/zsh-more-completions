#compdef kubectl-gadget
# _kubectl-gadget — Inspektor Gadget kubectl plugin (inspektor-gadget/inspektor-gadget)
# upstream: https://github.com/inspektor-gadget/inspektor-gadget
# Subcommands from cmd/kubectl-gadget/main.go + deploy.go on tip.

_kubectl-gadget() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-n --namespace)'{-n,--namespace=}'[Kubernetes namespace]:ns:' \
        '--context=[kubeconfig context]:ctx:' \
        '--cluster=[kubeconfig cluster]:cluster:' \
        '--user=[kubeconfig user]:user:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--server=[apiserver URL]:url:_urls' \
        '--token=[bearer token]:token:' \
        '--insecure-skip-tls-verify[skip TLS verification]' \
        '--certificate-authority=[CA cert file]:file:_files' \
        '--gadget-namespace=[gadget DaemonSet namespace]:ns:' \
        '--gadget-image=[gadget DaemonSet image]:image:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                deploy:'install Inspektor Gadget into the cluster'
                undeploy:'remove Inspektor Gadget from the cluster'
                run:'run a gadget'
                attach:'attach to a running gadget instance'
                operator:'operator-related commands'
                image:'manage gadget OCI images (build/push/pull/list/tag/inspect)'
                version:'print version'
                debug:'debug commands'
                trace:'run a built-in trace gadget'
                snapshot:'run a snapshot gadget'
                advise:'run a security-advisor gadget'
                profile:'run a profile gadget'
                top:'run a top-N gadget'
                audit:'run an audit gadget'
                completion:'generate shell completion scripts'
            )
            _describe -t commands 'kubectl-gadget command' cmds
            ;;
        args)
            case $words[1] in
                deploy)
                    _arguments \
                        '--image=[gadget container image]:image:' \
                        '--image-pull-policy=[image pull policy]:policy:(Always IfNotPresent Never)' \
                        '--quiet[suppress informational output]' \
                        '--debug[enable debug logs in DaemonSet]' \
                        '--liveness-probe=[enable liveness probe]:bool:(true false)' \
                        '--node-selector=[node selector for the DaemonSet]:sel:' \
                        '--toleration=[Pod toleration JSON]:json:' \
                        '--seccomp-profile=[seccomp profile to use]:profile:' \
                        '--app-armor-profile=[AppArmor profile]:profile:' \
                        '--hook-mode=[runtime hook mode]:mode:(auto crio fanotifyplus podinformer nri)' \
                        '--fallback-pod-informer=[fallback to PodInformer]:bool:(true false)' \
                        '--experimental[enable experimental features]'
                    ;;
                completion)
                    _arguments '*::shell:(bash zsh fish powershell)'
                    ;;
            esac
            ;;
    esac
}

_kubectl-gadget "$@"
