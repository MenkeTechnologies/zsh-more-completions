#compdef got

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize new repository'
      'import:import repository contents'
      'clone:clone a repository'
      'checkout:check out repository into work tree'
      'update:update work tree'
      'status:show modification status of files'
      'log:show repository log'
      'diff:diff objects or work tree'
      'blame:annotate file content'
      'tree:list files in a tree'
      'ref:manage references'
      'branch:manage branches'
      'tag:manage tags'
      'add:schedule file addition'
      'remove:schedule file removal'
      'patch:apply patches'
      'revert:revert uncommitted changes'
      'commit:write changes to repository'
      'send:send changes to remote'
      'cherrypick:cherry-pick commits'
      'backout:backout commits'
      'rebase:rebase branch'
      'histedit:edit commit history'
      'integrate:integrate branch'
      'merge:merge branch'
      'stage:stage changes'
      'unstage:unstage changes'
      'cat:print object content'
      'info:display work tree information'
      'cleanup:remove redundant pack files'
    )
    _describe -t commands 'got command' commands && ret=0
    ;;
esac

return ret
