#compdef gitui

# Zsh completion for gitui (terminal git UI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --directory)'{-d,--directory}'[set working directory]:directory:_directories' \
  '(-l --logging)'{-l,--logging}'[enable logging to file]' \
  '(-w --watcher)'{-w,--watcher}'[poll interval for filesystem changes]:interval (seconds)' \
  '(-t --theme)'{-t,--theme}'[set color theme]:theme file:_files' \
  '--bugreport[generate bug report information]' \
  '--notify-watcher[use notify-based file system watcher]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
