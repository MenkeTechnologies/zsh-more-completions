#compdef Dinvestigate
# Documentation: https://github.com/millanek/Dsuite
# Dsuite Dinvestigate: window-based follow-up analyses for trios.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --window)'{-w+,--window=}'[window size,step in SNPs]:size,step:' \
  '(-n --run-name)'{-n+,--run-name=}'[run name for output files]:name:' \
  '*:file:_files' && ret=0

return ret
