#compdef dcrctl
# _dcrctl — Decred Project dcrctl JSON-RPC client CLI for dcrd and dcrwallet daemons issuing getblockchaininfo getblock getnewaddress sendfrom listunspent purchaseticket revoketicket getstakeinfo getvotedetails ticketbuyer mixconfig (decred team, Go); flag
# upstream: https://github.com/decred/dcrd

_dcrctl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files -g "*.conf dcrctl.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf dcrctl.conf"' \
        '-s+[rpc server host:port]:str:' \
        '--rpcserver=+[rpc server host:port]:str:' \
        '-u+[rpc user]:str:' \
        '--rpcuser=+[rpc user]:str:' \
        '-P+[rpc password]:str:' \
        '--rpcpass=+[rpc password]:str:' \
        '-c+[ca cert file]:file:_files -g "*.cert *.pem"' \
        '--rpccert=+[ca cert file]:file:_files -g "*.cert *.pem"' \
        '--notls[no TLS]' \
        '--testnet[use testnet]' \
        '--simnet[use simnet]' \
        '--regnet[use regnet]' \
        '--wallet[connect to wallet]' \
        '--skipverify[skip server cert verification]' \
        '-l[list commands]' \
        '--listcommands[list commands]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent listtransactions sendtoaddress sendfrom sendmany getnewaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate getrawtransaction createrawtransaction signrawtransaction sendrawtransaction decoderawtransaction addnode getpeerinfo purchaseticket listtickets stakepoolinfo redeemticket revoketicket getstakeinfo getvotedetails getvotechoices voteversion ticketbuyer mixconfig stake-pool reusemixaccount sweepaccount)'
}

_dcrctl "$@"
