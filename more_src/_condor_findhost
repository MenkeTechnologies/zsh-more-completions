#compdef condor_findhost
# Documentation: https://man.archlinux.org/search?q=condor_findhost
# Reference accessed: 2026-05-16

# condor_findhost: locate suitable hosts in the pool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-help[show help]' \
  '-version[show version]' \
  '-pool[pool]:pool:' \
  '-rank[rank expression]:expr:' \
  '-constraint[constraint expression]:expr:' \
  '-n[number of hosts]:n:' \
  '*::condor_findhost args:_files' && ret=0
return ret
