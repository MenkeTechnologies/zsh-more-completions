#compdef condor_findhost
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_findhost.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# condor_findhost: locate suitable hosts in the HTCondor pool.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-m[only search for entire machines (not individual slots)]' \
  '-n[number of machines to find]:num:' \
  '-c[constraint expression]:c_expr:' \
  '-r[rank expression for machine selection]:r_expr:' \
  '-p[central manager host name (pool)]:centralmanagerhostname:' \
  '*::condor_findhost args:_files' && ret=0
return ret
