#compdef ruby-prof
# Documentation: https://github.com/ruby-prof/ruby-prof/blob/master/bin/ruby-prof
# fast code profiler for Ruby

local ret=1

_arguments -s -S \
  '--allow_exceptions[raise exceptions during profiling instead of suppressing]' \
  '(-E --eval-noprof)'{-E+,--eval-noprof=}'[execute Ruby statements without profiling]:code' \
  '--exclude=[comma-separated methods to exclude]:methods' \
  '--exclude-common[remove commonly-used methods from the profile]' \
  '(-f --file)'{-f+,--file=}'[write results to a file]:file:_files' \
  '(-m --min_percent)'{-m+,--min_percent=}'[minimum percent threshold for inclusion]:percent' \
  '--mode=[measurement type]:mode:(wall process allocations memory)' \
  '(-p --printer)'{-p+,--printer=}'[output format]:printer:(flat graph graph_html call_tree call_stack dot multi)' \
  '(-R --require-noprof)'{-R+,--require-noprof=}'[require a library without profiling]:library:_files' \
  '(-s --sort)'{-s+,--sort=}'[sort results by]:sort:(total self wait child)' \
  '--track_allocations[enable allocation tracking during profiling]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:script:_files' && ret=0

return ret
