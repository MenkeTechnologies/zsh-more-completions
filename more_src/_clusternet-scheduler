#compdef clusternet-scheduler
# _clusternet-scheduler — Clusternet multi-cluster workload scheduler (clusternet/clusternet)
# upstream: https://github.com/clusternet/clusternet
# Flags from pkg/scheduler/options/options.go (pflag).

_clusternet-scheduler() {
    _arguments \
        '--config=[scheduler configuration file]:file:_files -g "*.(yml|yaml|json)"' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[Kubernetes API server address]:url:_urls'
}

_clusternet-scheduler "$@"
