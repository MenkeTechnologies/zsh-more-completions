#compdef 3dBrickStat
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dBrickStat.html
# AFNI compute max and/or min voxel values of a dataset

local ret=1

_arguments -s -S \
  '-help[display help screen]' \
  '-quick[retrieve info from header only (default)]' \
  '-slow[read entire dataset to find min and max]' \
  '-min[display minimum value]' \
  '-max[display maximum value (default)]' \
  '-mean[display mean value]' \
  '-sum[display sum of all values]' \
  '-var[display variance]' \
  '-stdev[display standard deviation]' \
  '-count[display number of voxels included]' \
  '-volume[display volume of included voxels in microliters]' \
  '-positive[include only positive voxel values]' \
  '-negative[include only negative voxel values]' \
  '-zero[include only zero voxel values]' \
  '-non-positive[include only voxel values 0 or negative]' \
  '-non-negative[include only voxel values 0 or greater]' \
  '-non-zero[include only voxel values not equal to 0]' \
  '-absolute[use absolute value of voxels]' \
  '-nan[include only NaN or inf voxel values]' \
  '-nonan[exclude non-number voxel values]' \
  '-mask[mask dataset for voxel inclusion]:mask:_files' \
  '-mrange[accept mask values between MIN and MAX]:min:' \
  '-mvalue[accept only mask values equal to VAL]:val:' \
  '-automask[automatically compute mask]' \
  '-percentile[write percentile values across range]:start:' \
  '-perclist[output specified percentiles]:n:' \
  '-median[shortcut for 50th percentile]' \
  '-perc_quiet[print only percentile results]' \
  '-ver[print author and version info]' \
  '*:dataset:_files' && ret=0

return ret
