#compdef steam

# Zsh completion for steam - Valve Steam client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-applaunch[launch an app by ID]:app id' \
  '-bigpicture[start in Big Picture mode]' \
  '-cafeapplaunch[launch an app in Cafe mode]:app id' \
  '-console[open with developer console]' \
  '-cef-disable-gpu[disable GPU in CEF]' \
  '-cef-disable-sandbox[disable CEF sandbox]' \
  '-cef-in-process-gpu[enable in-process GPU rendering]' \
  '-cef-force-32bit[force 32-bit CEF]' \
  '-clearbeta[opt out of Steam Client beta]' \
  '-complete_install_via_http[force HTTP for downloads]' \
  '-condebug[log console output to console.log]' \
  '-debug_steamapi[enable Steam API debug logging]' \
  '-dev[developer mode]' \
  '-forcedesktopscaling[force desktop scaling factor]:scale' \
  '-forceservice[force steamservice.so usage]' \
  '-fulldesktopres[use full desktop resolution for Big Picture]' \
  '-gameoverlayrenderer[specify overlay renderer path]:path:_files' \
  '-login[login with credentials]:username:' \
  '-lognetapi[log network API]' \
  '-logon[logon to Steam]' \
  '-master_ipc_name_override[override master IPC name]:name' \
  '-no-browser[disable built-in browser]' \
  '-no-cef-sandbox[disable CEF sandbox]' \
  '-nofriendsui[disable new friends UI]' \
  '-nojoy[disable joystick support]' \
  '-nominidumps[disable crash dumps]' \
  '-norepairfiles[skip file repair]' \
  '-noverifyfiles[skip file verification]' \
  '-opengl[force OpenGL rendering]' \
  '-reset[reset Steam configuration]' \
  '-shutdown[shut down running Steam client]' \
  '-silent[start Steam silently in the tray]' \
  '-single_core[run on single core]' \
  '-skipstreamingdrivers[skip streaming driver check]' \
  '-steamos[enable SteamOS mode]' \
  '-tcp[force TCP connections]' \
  '-tenfoot[start in Big Picture mode]' \
  '-textonly[text-only mode]' \
  '-vulkan[force Vulkan rendering]' \
  '-windowed[start in windowed mode]' \
  '*:URI or game ID:' && ret=0

return ret
