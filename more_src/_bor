#compdef bor
# Documentation: upstream internal/cli/ at github.com/maticnetwork/bor
# Reference accessed: 2026-05-30 via gh api inspection of every
# command factory entry in internal/cli/command.go and the 207-entry
# server flag list in internal/cli/server/flags.go.
# Polygon Bor R80 — Polygon PoS execution layer (geth fork). The
# `bor` binary is built from cmd/cli/main.go and uses Mitchellh/cli
# (NOT cobra) for command dispatch. Subcommands are stored in a
# factory map with space-separated names ("snapshot prune-state" etc.)

local curcontext="$curcontext" state line ret=1

local -a _top_cmds _account_subs _chain_subs _debug_subs _peers_subs _snapshot_subs
_top_cmds=(
  'server:run the Bor node'
  'version:show Bor version'
  'dumpconfig:dump the configuration in TOML format'
  'debug:debugging subcommands (pprof/block)'
  'chain:chain subcommands (watch/sethead)'
  'account:account subcommands (new/import/list)'
  'peers:peer subcommands (add/remove/list/status)'
  'status:show node status'
  'fingerprint:show Bor fingerprint (chain config + genesis hash)'
  'attach:attach a JavaScript console to a running Bor node'
  'bootnode:run a discovery bootnode'
  'removedb:remove blockchain and state databases'
  'snapshot:snapshot subcommands (prune-state/prune-block/inspect-ancient-db)'
  'purge-whitelisted-entries:purge whitelisted checkpoint and milestone entries'
  'backfill-statesync-txs:backfill state-sync transactions'
  'help:show help'
)
_account_subs=( new import list )
_chain_subs=( watch sethead )
_debug_subs=( pprof block )
_peers_subs=( add remove list status )
_snapshot_subs=( prune-state prune-block inspect-ancient-db )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-): :->topcmd' \
  '(-)*:: :->topcmd_args' \
  && ret=0

case $state in
  topcmd)
    _describe -t commands 'bor command' _top_cmds && ret=0
    ;;
  topcmd_args)
    case $words[1] in
      server)
        _arguments -s -S \
          '--chain=[chain name (mainnet/mumbai/amoy/dev) or path to genesis]:chain:(mainnet mumbai amoy dev)' \
          '--identity=[node identity]:name:' \
          '--verbosity=[log verbosity 0-5]:level:(0 1 2 3 4 5)' \
          '--datadir=[data directory]:dir:_directories' \
          '--datadir.ancient=[ancient data directory]:dir:_directories' \
          '--keystore=[keystore directory]:dir:_directories' \
          '--config=[config file path]:file:_files -g "*.toml"' \
          '--db.engine=[database engine]:engine:(pebble leveldb)' \
          '--syncmode=[sync mode]:mode:(full snap fast)' \
          '--gcmode=[garbage collection mode]:mode:(full archive)' \
          '--state.scheme=[state trie scheme]:scheme:(hash path)' \
          '--snapshot=[enable snapshot-tree DB]' \
          '--mine[enable mining]' \
          '--miner.etherbase=[miner address]:addr:' \
          '--miner.gaslimit=[block gas limit]:N:' \
          '--miner.gasprice=[minimum gas price]:wei:' \
          '--ethstats=[ethstats endpoint user:pass@host]:endpoint:' \
          '--cache=[total cache size in MB]:N:' \
          '--cache.database=[database cache size %]:N:' \
          '--cache.trie=[trie cache size %]:N:' \
          '--cache.gc=[GC cache size %]:N:' \
          '--cache.snapshot=[snapshot cache size %]:N:' \
          '--cache.preimages[enable preimage recording]' \
          '--txpool.locals=[local senders allowlist]:addrs:' \
          '--txpool.nolocals[disable price exemption for local transactions]' \
          '--txpool.pricelimit=[minimum gas price tip]:N:' \
          '--txpool.pricebump=[price bump %]:N:' \
          '--txpool.globalslots=[max executable slots]:N:' \
          '--txpool.globalqueue=[max non-executable slots]:N:' \
          '--http[enable the HTTP-RPC server]' \
          '--http.addr=[HTTP-RPC listen address]:addr:' \
          '--http.port=[HTTP-RPC listen port]:port:' \
          '--http.api=[HTTP-RPC API enable list (comma-separated)]:apis:' \
          '--http.corsdomain=[allowed CORS domains (comma-separated)]:domains:' \
          '--http.vhosts=[allowed virtual hostnames (comma-separated)]:vhosts:' \
          '--ws[enable WS-RPC server]' \
          '--ws.addr=[WS-RPC listen address]:addr:' \
          '--ws.port=[WS-RPC listen port]:port:' \
          '--ws.api=[WS-RPC API enable list]:apis:' \
          '--ws.origins=[allowed WS origins]:origins:' \
          '--graphql[enable GraphQL-RPC server]' \
          '--authrpc.addr=[engine API listen address]:addr:' \
          '--authrpc.port=[engine API listen port]:port:' \
          '--authrpc.jwtsecret=[engine API JWT secret file]:file:_files' \
          '--ipcdisable[disable IPC-RPC server]' \
          '--ipcpath=[IPC-RPC socket path]:file:_files' \
          '--bind=[network listen address (host:port)]:addr:' \
          '--port=[P2P listen port]:port:' \
          '--maxpeers=[max connected peers]:N:' \
          '--maxpendpeers=[max pending peers]:N:' \
          '--bootnodes=[bootnodes (comma-separated enodes)]:enodes:' \
          '--nat=[NAT port-mapping (any/upnp/pmp/extip:IP)]:nat:' \
          '--netrestrict=[restrict P2P connections to CIDR list]:cidrs:' \
          '--nodekey=[P2P node key file]:file:_files' \
          '--nodekeyhex=[P2P node key (hex)]:hex:' \
          '--nodiscover[disable peer discovery]' \
          '--v4disc=[discovery v4]:bool:(true false)' \
          '--v5disc=[discovery v5]:bool:(true false)' \
          '--metrics[enable metrics collection]' \
          '--metrics.expensive[enable expensive metrics]' \
          '--metrics.influxdb[enable InfluxDB metrics export]' \
          '--metrics.influxdb.endpoint=[InfluxDB endpoint URL]:url:' \
          '--metrics.influxdb.database=[InfluxDB database]:db:' \
          '--metrics.influxdbv2[enable InfluxDB v2 metrics export]' \
          '--metrics.influxdb.token=[InfluxDB v2 auth token]:token:' \
          '--metrics.influxdb.bucket=[InfluxDB v2 bucket]:bucket:' \
          '--metrics.influxdb.organization=[InfluxDB v2 organization]:org:' \
          '--metrics.prometheus-addr=[Prometheus listen address]:addr:' \
          '--unlock=[accounts to unlock (comma-separated)]:addrs:' \
          '--password=[password file for accounts]:file:_files' \
          '--allow-insecure-unlock[allow insecure account unlocking when HTTP is enabled]' \
          '--lightkdf[reduced-strength account KDF (faster but less secure)]' \
          '--disable-bor-wallet[disable the Bor-internal wallet]' \
          '--grpc.addr=[gRPC server address]:addr:' \
          '--grpc.token=[gRPC auth token]:token:' \
          '--dev[run dev chain with simulated proof-of-authority]' \
          '--dev.period=[dev block period seconds]:N:' \
          '--parallelevm.enable[enable parallel EVM execution]' \
          '--parallelevm.procs=[parallel EVM workers]:N:' \
          '--parallelevm.enforce[enforce parallel EVM execution]' \
          '--bor.heimdall=[Heimdall URL]:url:' \
          '--bor.withoutheimdall[start Bor without Heimdall connection]' \
          '--bor.runheimdall[run Heimdall service]' \
          '--bor.runheimdallargs=[args to pass to internal Heimdall]:args:' \
          '--bor.useheimdallapp[use Heimdall app directly]' \
          && ret=0
        ;;
      account)
        _arguments \
          '1:account subcommand:($_account_subs)' \
          '*::arg:' && ret=0
        ;;
      chain)
        _arguments \
          '1:chain subcommand:($_chain_subs)' \
          '*::arg:' && ret=0
        ;;
      debug)
        _arguments \
          '1:debug subcommand:($_debug_subs)' \
          '--server=[Bor RPC server address]:addr:' \
          '--output=[output file]:file:_files' \
          '--seconds=[capture duration in seconds]:N:' \
          && ret=0
        ;;
      peers)
        _arguments \
          '1:peers subcommand:($_peers_subs)' \
          '--address=[Bor RPC server address (default 127.0.0.1:3131)]:addr:' \
          '*::peer arg:' && ret=0
        ;;
      snapshot)
        _arguments \
          '1:snapshot subcommand:($_snapshot_subs)' \
          '--datadir=[data directory]:dir:_directories' \
          '--datadir.ancient=[ancient data directory]:dir:_directories' \
          '--bloomfilter.size=[bloom filter size in MB]:N:' \
          && ret=0
        ;;
      attach)
        _arguments \
          '1:endpoint (default ipc):' \
          '--exec=[command to execute inline]:js:' \
          '--preload=[preload JS files (comma-separated)]:files:_files' \
          '--jspath=[base path for js scripts]:dir:_directories' && ret=0
        ;;
      status|fingerprint|version)
        _arguments \
          '--address=[Bor RPC server address (default 127.0.0.1:3131)]:addr:' \
          && ret=0
        ;;
      dumpconfig)
        _arguments \
          '--config=[config file path]:file:_files -g "*.toml"' \
          '--chain=[chain to use for defaults]:chain:(mainnet mumbai amoy dev)' \
          && ret=0
        ;;
      bootnode)
        _arguments \
          '--bind=[listen address]:addr:' \
          '--genkey=[generate new node key into file]:file:_files' \
          '--writeaddress[write out node ID and exit]' \
          '--nodekey=[node key file]:file:_files' \
          '--nodekeyhex=[node key (hex)]:hex:' \
          '--nat=[NAT mode]:nat:' \
          '--netrestrict=[CIDR restrictions]:cidrs:' \
          '--verbosity=[log verbosity]:level:(0 1 2 3 4 5)' \
          '--metrics=[enable metrics]:bool:(true false)' \
          '--metrics.influxdb=[enable InfluxDB metrics]:bool:(true false)' \
          '--metrics.prometheus-addr=[Prometheus listen address]:addr:' \
          && ret=0
        ;;
      removedb)
        _arguments \
          '--datadir=[data directory]:dir:_directories' \
          && ret=0
        ;;
      purge-whitelisted-entries)
        _arguments \
          '--address=[Bor RPC server address]:addr:' \
          && ret=0
        ;;
      backfill-statesync-txs)
        _arguments \
          '--datadir=[data directory]:dir:_directories' \
          '--start=[start block number]:N:' \
          '--end=[end block number]:N:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
