#compdef caper
# Documentation: https://github.com/ENCODE-DCC/caper/blob/master/caper/caper_args.py
# caper: Cromwell-assisted pipeline executor wrapping Cromwell/WDL for GCP, AWS and HPC

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize Caper configuration file'
  'run:run a single workflow without a server'
  'server:run a Cromwell server'
  'submit:submit a workflow to a Cromwell server'
  'abort:abort running/pending workflows on a Cromwell server'
  'unhold:release hold of workflows on a Cromwell server'
  'list:list running/pending workflows on a Cromwell server'
  'metadata:retrieve metadata JSON for workflows from a Cromwell server'
  'troubleshoot:troubleshoot workflow problems from metadata or workflow IDs'
  'debug:identical to troubleshoot'
  'hpc:subcommand for HPCs'
  'gcp_monitor:tabulate task resource data collected on GCP instances'
  'gcp_res_analysis:linear resource analysis on monitoring data'
  'cleanup:cleanup outputs of workflows'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '--conf=[Caper configuration file]:file:_files' \
  '--debug[print debug logging]' \
  '--backend=[backend to run a workflow]:backend:(gcp aws Local local slurm sge pbs lsf)' \
  '--singularity=[URI or path for Singularity image]:image' \
  '--docker=[URI for Docker image]:image' \
  '--conda=[default Conda environment name]:env' \
  '--file-db=[default DB file for Cromwell HyperSQL database]:file:_files' \
  '--db=[type of Cromwell database]:db:(in-memory file mysql postgresql)' \
  '--port=[port for Caper server]:port' \
  '--mysql-db-port=[MySQL database TCP/IP port]:port' \
  '--leader-job-name=[leader job name for a submitted workflow]:name' \
  '--cromwell=[path or URI for Cromwell JAR]:jar:_files' \
  '--max-concurrent-tasks=[maximum number of concurrent tasks]:count' \
  '--max-concurrent-workflows=[maximum number of concurrent workflows]:count' \
  '--inputs=[workflow inputs JSON file]:file:_files -g "*.json"' \
  '--options=[workflow options JSON file]:file:_files -g "*.json"' \
  '--labels=[workflow labels JSON file]:file:_files -g "*.json"' \
  '--imports=[zip file of imported subworkflows]:file:_files -g "*.zip"' \
  '--dry-run[do not actually run/submit, just print]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'caper command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
