#compdef mpstat-cli
# _mpstat-cli — sysstat mpstat report processors related statistics CLI alias (sysstat team, C); custom argparse
# upstream: https://github.com/sysstat/sysstat

_mpstat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[same as -u -I ALL -P ALL]' \
        '-I+[interrupt level]:m:(CPU SUM ALL SCPU)' \
        '-N+[numa nodes]:str:' \
        '-n[node stats]' \
        '-o+[output format]:f:(JSON)' \
        '-P+[cpu]:str:' \
        '-T+[topology]:str:' \
        '-u[CPU utilization]' \
        '*:interval count:'
}

_mpstat-cli "$@"
