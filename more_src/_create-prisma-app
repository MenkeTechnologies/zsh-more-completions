#compdef create-prisma-app
# Documentation: https://www.npmjs.com/package/create-prisma-app
# Reference accessed: 2026-05-24
# Verified: npx create-prisma-app --help.

# Zsh completion for create-prisma-app - Prisma project scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':project name:' && ret=0

return ret
