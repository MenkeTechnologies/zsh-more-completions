_mautrix-whatsapp() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show bridge version]' \
        '--version-json[print JSON version info and quit]' \
        '(-c --config)'{-c+,--config=}'[config file (default config.yaml)]:file:_files -g "*.{yml,yaml}"' \
        '(-n --no-update)'{-n,--no-update}'[do not save updated config to disk]' \
        '(-e --generate-example-config)'{-e,--generate-example-config}'[write example config and exit]' \
        '(-r --registration)'{-r+,--registration=}'[appservice registration file (default registration.yaml)]:file:_files -g "*.{yml,yaml}"' \
        '(-g --generate-registration)'{-g,--generate-registration}'[generate registration and exit]' \
        '--ignore-unsupported-database[run despite newer DB schema]' \
        '--ignore-foreign-tables[run despite foreign tables in DB]' \
        '--ignore-unsupported-server[run despite outdated homeserver]'
}

_mautrix-whatsapp "$@"
