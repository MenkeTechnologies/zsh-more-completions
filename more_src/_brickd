#compdef brickd
# Documentation: https://man.archlinux.org/search?q=brickd
# Reference accessed: 2026-05-16

# brickd: Tinkerforge Brick Daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '--daemon[run as daemon]' \
  '--debug[enable debug]' \
  '--check-config[only check config]' \
  '--config=[config file]:file:_files' \
  '*::brickd args:_files' && ret=0
return ret
