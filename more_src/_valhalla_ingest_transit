#compdef valhalla_ingest_transit
# Documentation: https://github.com/valhalla/valhalla
# Ingest GTFS transit feeds into Valhalla intermediate transit data.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to JSON config file]:file:_files -g "*.json(-.)"' \
  '(-j --concurrency)'{-j+,--concurrency=}'[number of threads (default all)]:n:_default' && ret=0

return ret
