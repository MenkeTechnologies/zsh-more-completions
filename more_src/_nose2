#compdef nose2
# Documentation: https://docs.nose2.io/en/latest/usage.html
# nose2 - unittest-based test runner

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --start-dir)'{-s,--start-dir}'[directory to start discovery]:dir:_files -/' \
  '(-t --top-level-directory --project-directory)'{-t,--top-level-directory,--project-directory}'[top level directory of project]:dir:_files -/' \
  '(-c --config)'{-c,--config}'[config files to load if they exist]:config:_files' \
  '--no-user-config[do not load user config files]' \
  '--no-plugins[do not load any plugins]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '--quiet[enable quiet output]' \
  '(-B --output-buffer)'{-B,--output-buffer}'[enable output buffer]' \
  '(-D --debugger)'{-D,--debugger}'[enter pdb on test fail or error]' \
  '--collect-only[collect but do not run tests]' \
  '--log-capture[enable log capture]' \
  '(-P --print-hooks)'{-P,--print-hooks}'[print names of hooks in order of execution]' \
  '*:testName:' && ret=0

return ret
