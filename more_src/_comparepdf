#compdef comparepdf
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/comparepdf.1.html
# comparepdf - compare two PDF files

local ret=1

_arguments -s -S \
  '(-ct --compare -ca)-ct[text mode comparison (default)]' \
  '(-ca --compare -ct)-ca[appearance/visual comparison]' \
  '--compare=[comparison mode]:mode:(text appearance)' \
  '-v=[verbosity level]:level:(0 1 2)' \
  '--verbose=[verbosity level]:level:(0 1 2)' \
  '1:first PDF:_files -g "*.pdf"' \
  '2:second PDF:_files -g "*.pdf"' && ret=0

return ret
