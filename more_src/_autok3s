#compdef autok3s
# Documentation: https://github.com/cnrancher/autok3s
# AutoK3s: lightweight tool for simplifying the cluster management of K3s

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable log debug level]' \
  '1:command:(addon airgap completion create delete describe explorer join kubectl list serve ssh upgrade version)' \
  '*::arg:->args' && ret=0

return ret
