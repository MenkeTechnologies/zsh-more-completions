#compdef condor_top
# Documentation: https://htcondor.readthedocs.io/en/latest/man-pages/condor_top.html
# display the activity of an HTCondor daemon over time

local ret=1

_arguments -s -S \
  '-h[display the list of options]' \
  '-l[live, continually updating mode]' \
  '(-H -history --history)'{-H,-history,--history}'[read the two most recent daemon history ClassAds]' \
  '-p[query the daemon via the specified central manager]:hostname:_hosts' \
  '-n[query the daemon with the given name]:name' \
  '-d[delay between ClassAd updates in seconds]:delay' \
  '-c[display the given set of columns]:columnset:(default runtime count all)' \
  '-s[sort table by the given column]:sortcolumn' \
  '-attrs[comma-delimited additional ClassAd attributes to monitor]:attrs' \
  '-collector[monitor a condor_collector]' \
  '-negotiator[monitor a condor_negotiator]' \
  '-master[monitor a condor_master]' \
  '-schedd[monitor a condor_schedd]' \
  '-startd[monitor a condor_startd]' && ret=0

return ret
