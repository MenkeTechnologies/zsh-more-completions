#compdef tempo-vulture
# Documentation: https://man.archlinux.org/search?q=tempo-vulture
# Reference accessed: 2026-05-16

# tempo-vulture: synthetic trace generator for testing Tempo
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--tempo-base-url=[Tempo base URL]:url:' \
  '--tempo-search-url=[Tempo search URL]:url:' \
  '--tempo-org-id=[org id]:id:' \
  '--tempo-push-url=[push URL]:url:' \
  '--tempo-username=[username]:user:_users' \
  '--tempo-password=[password]:pass:' \
  '--tempo-retention-duration=[retention duration]:duration:' \
  '--tempo-search-backoff=[search backoff]:duration:' \
  '--tempo-write-backoff=[write backoff]:duration:' \
  '--tempo-read-backoff=[read backoff]:duration:' \
  '--tempo-long-write-backoff=[long write backoff]:duration:' \
  '--tempo-push-frequency=[push frequency]:duration:' \
  '--prometheus-listen-address=[prometheus listen]:addr:' \
  '*::tempo-vulture args:_files' && ret=0
return ret
