#compdef argon2
# Documentation: argon2 usage (password-hashing competition winner CLI)
# Source: P-H-C/phc-winner-argon2 - argon2{i,d,id} password hashing reference CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print usage]' \
    '(-i -d -id)-i[Argon2i (default)]' \
    '(-i -d -id)-d[Argon2d]' \
    '(-i -d -id)-id[Argon2id]' \
    '-t+[number of iterations (default 3)]:n:' \
    '(-m -k)-m+[memory cost as 2^N KiB (default 12)]:n:' \
    '(-m -k)-k+[memory cost in KiB (default 4096)]:n:' \
    '-p+[parallelism / threads (default 1)]:n:' \
    '-l+[hash output length in bytes (default 32)]:n:' \
    '(-e -r)-e[output only encoded hash]' \
    '(-e -r)-r[output only raw bytes of the hash]' \
    '-v+[Argon2 version]:version:(10 13)' \
    '1:salt (at least 8 chars):' \
    && ret=0

return ret
