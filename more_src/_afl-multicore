#compdef afl-multicore
# Documentation: https://github.com/rc0r/afl-utils
# Wrapper to start/resume multiple parallel afl-fuzz instances (afl-utils)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[afl-multicore config file]:file:_files' \
  '(-s --startup-delay)'{-s,--startup-delay}'=[wait time in seconds after starting each afl instance]:seconds' \
  '(-t --test)'{-t,--test}'[perform a test run with a single interactive afl instance]' \
  '(-v --verbose)'{-v,--verbose}'[do not redirect subprocess stderr/stdout to /dev/null]' \
  '1:command:(start resume add)' \
  '2:jobs:' && ret=0

return ret
