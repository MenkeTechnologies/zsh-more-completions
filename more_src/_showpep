#compdef showpep
# showpep - Display protein sequences with features in pretty format

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[display help information]' \
  '-sequence[input protein sequence(s)]:file:_files' \
  '-format[display format (0-3)]:format:' \
  '-things[display elements order]:things:' \
  '-outfile[output file name]:file:_files' \
  '-uppercase[regions to display in uppercase]:regions:' \
  '-highlight[regions to mark with HTML colors]:regions:' \
  '-annotation[text annotations for regions]:annotation:' \
  '-sourcematch[filter features by source name]:source:' \
  '-typematch[filter features by type]:type:' \
  '-minscore[minimum feature score]:score:' \
  '-maxscore[maximum feature score]:score:' \
  '-tagmatch[filter features by tag type]:tag:' \
  '-valuematch[filter features by tag values]:value:' \
  '-stricttags[show only matching tag/value pairs]' \
  '-threeletter[display proteins using three-letter codes]' \
  '-number[add sequence line numbering]' \
  '-width[characters per display line]:width:' \
  '-length[page line length]:length:' \
  '-margin[margin width for numbering]:margin:' \
  '-name[toggle sequence ID display]' \
  '-description[toggle sequence description display]' \
  '-offset[start numbering from value]:offset:' \
  '-html[format output for HTML]' \
  '-auto[turn off prompts]' \
  '-version[display version number]' \
  '*:sequence file:_files' && ret=0

return ret
