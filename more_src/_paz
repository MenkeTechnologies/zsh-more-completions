#compdef paz
# Documentation: http://psrchive.sourceforge.net/manuals/paz/
# PSRCHIVE: RFI mitigation (zap channels and sub-integrations).

local ret=1

_arguments -s -S \
  '-h[show full list of options]' \
  '-x+[extract specified sub-integrations]:subints:' \
  '-s+[delete specified sub-integrations]:subints:' \
  '(-w -W)'{-w,-W}'+[zero weight specified sub-integrations]:subints:' \
  '(-z -Z)'{-z,-Z}'+[zero weight specified frequency channels]:chans:' \
  '-p+[interpolate over every pth phase bin]:p:' \
  '-L[apply lawn mowing algorithm to clean phase bins]' \
  '-r[automatic channel zapping (median smoothed diff)]' \
  '*:archive:_files' && ret=0

return ret
