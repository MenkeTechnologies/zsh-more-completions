#compdef olive olive-editor
# _olive — Olive Team olive-editor free open-source non-linear video editor with node-based compositing (olive-editor team, C++); custom argparse
# upstream: https://github.com/olive-editor/olive

_olive() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--platform=+[Qt platform]:p:(xcb wayland eglfs offscreen)' \
        '--style=+[Qt style]:str:' \
        '--display=+[X display]:str:' \
        '--audio-backend=+[backend]:b:(portaudio alsa jack pulseaudio sdl wasapi coreaudio)' \
        '--export=+[output file]:file:_files' \
        '--export-preset=+[preset]:str:' \
        '--export-video-codec=+[codec]:str:' \
        '--export-audio-codec=+[codec]:str:' \
        '--export-resolution=+[WIDTHxHEIGHT]:str:' \
        '--export-framerate=+[fps]:n:' \
        '--export-sample-rate=+[Hz]:n:' \
        '--export-format=+[format]:str:' \
        '--export-in=+[in time]:str:' \
        '--export-out=+[out time]:str:' \
        '--start-renderer[only render via CLI]' \
        '--lang=+[locale]:str:' \
        '--enable-experimental[enable experimental features]' \
        '--reset-config[reset settings]' \
        '--portable[portable mode]' \
        '*:project:_files -g "*.ove *.olv"'
}

_olive "$@"
