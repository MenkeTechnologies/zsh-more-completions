#compdef wtransform
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/wtransform.html
# Obtain wavelet transform coefficients for poisson image data

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[input file (FITS primary image or extension)]:file:_files' \
  'srclist=[stack of per-scale candidate source output files]:file:_files' \
  'correl=[stack of per-scale correlation output images]:file:_files' \
  'nbkg=[stack of normalized background output images]:file:_files' \
  'bkg=[stack of plain background images]:file:_files' \
  'thresh=[stack of per-scale detection threshold images]:file:_files' \
  'outputinfix=[extra text for output filenames]:outputinfix:' \
  'exptime=[exposure time in seconds]:exptime:' \
  'expfile=[exposure time image file]:file:_files' \
  'expcor=[correction type]:expcor:(fast full none)' \
  'expthresh=[minimum relative exposure threshold]:expthresh:' \
  'bkgtime=[background livetime in seconds]:bkgtime:' \
  'bkginput=[pre-computed background image file]:file:_files' \
  'bkgerrinput=[use background error from bkginput]:bkgerrinput:(yes no)' \
  'xscales=[wavelet scale sizes in x direction (pixels)]:xscales:' \
  'yscales=[wavelet scale sizes in y direction (pixels)]:yscales:' \
  'clobber=[overwrite existing outputs]:clobber:(yes no)' \
  'correlerr=[include error image in correlation output]:correlerr:(yes no)' \
  'nbkgerr=[include error image in normalized background]:nbkgerr:(yes no)' \
  'bkgerr=[include error image in plain background]:bkgerr:(yes no)' \
  'maxiter=[maximum cleansing iterations per scale]:maxiter:' \
  'iterstop=[iteration stopping threshold]:iterstop:' \
  'sigthresh=[final detection significance threshold]:sigthresh:' \
  'bkgsigthresh=[cleansing iteration significance threshold]:bkgsigthresh:' \
  'falsesrc=[false sources allowed per scale]:falsesrc:' \
  'sigcalfile=[simulation results file for false-source algorithm]:file:_files' \
  'log=[write log to file instead of stdout]:log:(yes no)' \
  'verbose=[debugging output level]:verbose:(0 1 2 3 4 5)' \
  'stall=[debugger rendezvous mode]:stall:(yes no)' && ret=0

return ret
