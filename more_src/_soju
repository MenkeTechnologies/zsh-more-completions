#compdef soju

# Zsh completion for soju - IRC bouncer

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-config[config file]:file:_files' \
  '-listen[listening address]:address:' \
  '-tls-cert[TLS certificate file]:file:_files' \
  '-tls-key[TLS key file]:file:_files' \
  '-db[database driver]:driver:(sqlite3 postgres)' \
  '-db-source[database source/path]:source:' \
  '-hostname[server hostname]:hostname:_hosts' \
  '-title[server title]:title:' \
  '-motd[path to MOTD file]:file:_files' \
  '-accept-proxy-ip[accept PROXY protocol from IPs]:ips:' \
  '-max-user-networks[max networks per user]:number:' \
  '-debug[enable debug logging]' \
  '-version[show version]' && return 0
