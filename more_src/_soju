#compdef soju
# Documentation: https://soju.im/doc/soju.1.html
# Reference accessed: 2026-05-16
# Verified: upstream soju.im soju(1) manpage. soju takes its TLS,
# database, hostname, MOTD, etc. from soju.cfg — only -config/-debug
# /-listen/-help are top-level CLI flags.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -tls-cert/-tls-key/-db/-db-source/-hostname/-title/-motd
# /-accept-proxy-ip/-max-user-networks/-version flags (these are
# soju.cfg directives, not CLI flags).

# soju: IRC bouncer (emersion/soju)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h -help)-h[show help]' \
  '(-h -help)-help[show help]' \
  '-config[config file path]:file:_files' \
  '-debug[enable debug logging]' \
  '*-listen[listen URI (default \:6697; repeatable)]:uri:' && ret=0
return ret
