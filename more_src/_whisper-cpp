#compdef whisper-cpp whispercpp
# _whisper-cpp — ggml.ai whisper.cpp speech-to-text C++ port of Whisper CLI alias (Georgi Gerganov / ggml-org, C++); custom argparse
# upstream: https://github.com/ggml-org/whisper.cpp

_whisper-cpp() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--threads=+[threads]:n:' \
        '-t+[threads]:n:' \
        '--processors=+[processors]:n:' \
        '-p+[processors]:n:' \
        '--offset-t=+[offset ms]:n:' \
        '-ot+[offset ms]:n:' \
        '--offset-n=+[offset n]:n:' \
        '-on+[offset n]:n:' \
        '--duration=+[duration ms]:n:' \
        '-d+[duration ms]:n:' \
        '--max-context=+[max context]:n:' \
        '-mc+[max context]:n:' \
        '--max-len=+[max segment length]:n:' \
        '-ml+[max segment length]:n:' \
        '--split-on-word[split on word]' \
        '-sow[split on word]' \
        '--best-of=+[best of]:n:' \
        '-bo+[best of]:n:' \
        '--beam-size=+[beam size]:n:' \
        '-bs+[beam size]:n:' \
        '--word-thold=+[word threshold]:f:' \
        '-wt+[word threshold]:f:' \
        '--entropy-thold=+[entropy threshold]:f:' \
        '-et+[entropy threshold]:f:' \
        '--logprob-thold=+[logprob threshold]:f:' \
        '-lpt+[logprob threshold]:f:' \
        '--temperature=+[temperature]:f:' \
        '-tp+[temperature]:f:' \
        '--temperature-inc=+[temperature inc]:f:' \
        '-tpi+[temperature inc]:f:' \
        '--no-fallback[no fallback]' \
        '-nf[no fallback]' \
        '--no-speech-thold=+[no speech threshold]:f:' \
        '-nth+[no speech threshold]:f:' \
        '--debug-mode[debug mode]' \
        '-debug[debug mode]' \
        '--translate[translate to English]' \
        '-tr[translate to English]' \
        '--diarize[stereo diarization]' \
        '-di[stereo diarization]' \
        '--tinydiarize[tinydiarize]' \
        '-tdrz[tinydiarize]' \
        '--no-timestamps[no timestamps]' \
        '-nt[no timestamps]' \
        '--language=+[language]:lang:(auto en zh de es ru ko fr ja pt tr pl ca nl ar sv it id hi fi vi he uk el ms cs ro da hu ta no th ur hr bg lt la mi ml cy sk te fa lv bn sr az sl kn et mk br eu is hy ne mn bs kk sq sw gl mr pa si km sn yo so af oc ka be tg sd gu am yi lo uz fo ht ps tk nn mt sa lb my bo tl mg as tt haw ln ha ba jw su)' \
        '-l+[language]:lang:' \
        '--detect-language[detect language]' \
        '-dl[detect language]' \
        '--prompt=+[initial prompt]:str:' \
        '--model=+[model path]:file:_files -g "*.bin *.gguf"' \
        '-m+[model path]:file:_files -g "*.bin *.gguf"' \
        '--file=+[input audio file]:file:_files' \
        '-f+[input audio file]:file:_files' \
        '--output-txt[output txt]' \
        '-otxt[output txt]' \
        '--output-vtt[output vtt]' \
        '-ovtt[output vtt]' \
        '--output-srt[output srt]' \
        '-osrt[output srt]' \
        '--output-lrc[output lrc]' \
        '-olrc[output lrc]' \
        '--output-words[output words csv]' \
        '-owts[output words csv]' \
        '--output-csv[output csv]' \
        '-ocsv[output csv]' \
        '--output-json[output json]' \
        '-oj[output json]' \
        '--output-json-full[output json full]' \
        '-ojf[output json full]' \
        '--output-file=+[output filename base]:file:_files' \
        '-of+[output filename base]:file:_files' \
        '--print-special[print special]' \
        '-ps[print special]' \
        '--print-colors[print colors]' \
        '-pc[print colors]' \
        '--print-progress[print progress]' \
        '-pp[print progress]' \
        '--no-prints[no prints]' \
        '-np[no prints]' \
        '--suppress-regex=+[suppress regex]:str:' \
        '--gpu-device=+[gpu device]:n:' \
        '-gd+[gpu device]:n:' \
        '--flash-attn[flash attention]' \
        '-fa[flash attention]' \
        '--use-gpu=+[use gpu]:b:(true false)' \
        '*:audio:_files'
}

_whisper-cpp "$@"
