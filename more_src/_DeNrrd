#compdef DeNrrd
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/DeNrrd.cxx — convert NRRD diffusion-weighted images to NIfTI (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:inImage.nrrd:_files -g "*.{nrrd,nhdr}"' \
    '2:outImage.nii:_files -g "*.{nii,nii.gz}"' \
    '3:gradients.txt:_files -g "*.txt"' \
    && ret=0

return ret
