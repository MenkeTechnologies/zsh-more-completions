#compdef allure-commandline
# _allure-commandline — Qameta Software allure-commandline CLI command-line frontend to the Allure test report tool generating multi-language framework-agnostic interactive HTML report from JUnit JSON XML-based test result directories supporting trend graphs categories suites history attachments behaviors tags for downstream CI integration (Qameta Software team, Java); custom argparse
# upstream: https://docs.qameta.io/allure/

_allure-commandline() {
    local -a sub=(
        'generate:generate the static report from results'
        'serve:start a webserver with live report'
        'open:open previously generated report'
        'help:show help'
        'completion:generate shell completion'
        'plugin:plugin management'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.properties"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.properties"' \
        '--config-directory=+[dir]:dir:_files -/' \
        '--profile=+[name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'allure subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--report-dir=+[dir]:dir:_files -/' \
                    '--clean[clean output dir]' \
                    '--name=+[name]:str:' \
                    '--single-file[single file output]' \
                    '*:results dir:_files -/' ;;
                serve) _arguments \
                    '-h+[host]:_hosts' \
                    '--host=+[host]:_hosts' \
                    '-p+[port]:n:' \
                    '--port=+[port]:n:' \
                    '*:results dir:_files -/' ;;
                open) _arguments \
                    '-h+[host]:_hosts' \
                    '--host=+[host]:_hosts' \
                    '-p+[port]:n:' \
                    '--port=+[port]:n:' \
                    '*:report dir:_files -/' ;;
            esac
            ;;
    esac
}

_allure-commandline "$@"
