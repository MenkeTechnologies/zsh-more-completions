#compdef scribus

# Zsh completion for scribus - Scribus desktop publishing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-splash[do not show splash screen]' \
  '-ns[do not show splash screen]' \
  '--no-gui[do not start the GUI]' \
  '-ng[do not start the GUI]' \
  '-l[language override]:language code' \
  '--lang=[language override]:language code' \
  '-la[list available languages]' \
  '--langs-available[list available languages]' \
  '-fi[use specified font directory]:dir:_directories' \
  '--font-info[show installed fonts]' \
  '-pi[show plugin info]' \
  '--profile-info[show color profile info]' \
  '-pr[run in Python script mode]:python script:_files -g "*.py"' \
  '--python-script=[run Python script]:python script:_files -g "*.py"' \
  '--prefs=[use specified preferences file]:file:_files -g "*.xml"' \
  '-u[upgrade preferences to latest version]' \
  '--upgradecheck[check for upgrades at startup]' \
  '--display=[set X display]:display' \
  '*:file:_files -g "*.sla"' && ret=0

return ret
