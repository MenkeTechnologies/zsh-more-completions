#compdef mdimport
# Documentation: https://www.unix.com/man-page/osx/1/mdimport/
# Source: Apple macOS — Spotlight importer driver (per-file metadata extraction).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-g[load plugin (skip system importers)]:plugin:_files' \
    '-V[print timing information]' \
    '(- *)-A[print all attributes + localizations and exit]' \
    '(- *)-X[print schema file and exit]' \
    '-r[reimport files for UTIs claimed by plugin]:plugin:' \
    '-p[print performance information]' \
    '(- *)-L[print installed importers and exit]' \
    '-d[debug level]:level:(1 2 3 4)' \
    '-n[do not actually set attributes (debug)]' \
    '-w[wait msecs between scanning files]:ms:' \
    '*:file:_files' \
    && ret=0

return ret
