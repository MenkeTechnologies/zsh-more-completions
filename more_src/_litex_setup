#compdef litex_setup
# Documentation: https://github.com/enjoy-digital/litex/blob/master/litex_setup.py
# LiteX installer/updater for the LiteX git repositories and toolchains

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--init[initialize Git repositories]' \
  '--update[update Git repositories]' \
  '--install[install Git repositories]' \
  '--user[install in user-mode]' \
  '--break-system-packages[pass pip --break-system-packages when outside a venv]' \
  '--config=[install config]:config:(minimal standard full)' \
  '--tag=[use version from release tag]:tag:' \
  '--gcc=[install specified GCC toolchain]:toolchain:(riscv mips powerpc openrisc lm32)' \
  '--dev[development-mode (no auto-update, git@ URLs)]' \
  '--freeze[freeze and display current config]' \
  '--freeze-output=[write frozen repository definitions to file]:file:_files' \
  '*:command:(init update install gcc)' && ret=0

return ret
