#compdef ffplay
# Documentation: https://manpages.debian.org/ffplay.1
# Source: FFmpeg — minimal SDL multimedia player + decoder/filtergraph debugger.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x[force displayed width]:px:' \
    '-y[force displayed height]:px:' \
    '-fs[start in fullscreen]' \
    '-an[disable audio]' \
    '-vn[disable video]' \
    '-sn[disable subtitles]' \
    '-ast[audio stream specifier]:spec:' \
    '-vst[video stream specifier]:spec:' \
    '-sst[subtitle stream specifier]:spec:' \
    '-ss[seek to position]:pos:' \
    '-t[play duration (seconds)]:duration:' \
    '-bytes[seek by bytes]:flag:(0 1 -1)' \
    '-nodisp[disable graphical display]' \
    '-noborder[borderless window]' \
    '-volume[initial playback volume 0-100]:vol:' \
    '-f[force format]:fmt:' \
    '-window_title[window title]:title:' \
    '-seek_interval[seek interval (seconds) for left/right]:seconds:' \
    '-showmode[display mode]:mode:(video waves rdft 0 1 2)' \
    '-i[input URL]:url:_files' \
    '-loop[loop playback N times]:n:' \
    '-stats[show progress/statistics]' \
    '-fast[faster (non-spec-compliant) decoding]' \
    '-genpts[generate missing PTS]' \
    '-sync[stream sync clock]:clock:(audio video ext)' \
    '-autoexit[exit at end of playback]' \
    '-exitonkeydown[exit on any key]' \
    '-exitonmousedown[exit on any mouse button]' \
    '-vf[video filtergraph]:graph:' \
    '-af[audio filtergraph]:graph:' \
    '-hide_banner[suppress banner]' \
    '-loglevel[log level]:level:(quiet panic fatal error warning info verbose debug trace)' \
    '-pix_fmt[pixel format]:fmt:(yuv420p yuv420p10le yuv422p yuv444p rgb24 rgba bgr24 gray nv12 nv21)' \
    '*:input file:_files' \
    && ret=0

return ret
