#compdef codecept codeception

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:run tests'
  'build:generate suites'
  'bootstrap:set up a test suite'
  'clean:clean output directory'
  'completion:dump shell autocompletion script'
  'console:interactive console'
  'dry-run:run tests without executing'
  'generate\:cest:generate Cest file'
  'generate\:cept:generate Cept file'
  'generate\:command:generate a custom command'
  'generate\:environment:generate environment config'
  'generate\:feature:generate Gherkin feature file'
  'generate\:groupobject:generate group extension'
  'generate\:helper:generate helper class'
  'generate\:pageobject:generate page object'
  'generate\:scenarios:generate text scenarios from tests'
  'generate\:snapshot:generate snapshot class'
  'generate\:stepobject:generate step object'
  'generate\:suite:generate test suite'
  'generate\:test:generate test file'
  'gherkin\:snippets:generate step definitions from feature files'
  'gherkin\:steps:print step definitions'
  'init:create Codeception test directory structure'
  'self-update:update Codeception'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[use custom path for configuration]:config:_files' \
  '--config=[use custom path for configuration]:config:_files' \
  '-v[verbose]' \
  '-vv[more verbose]' \
  '-vvv[debug]' \
  '--no-ansi[disable ANSI output]' \
  '--ansi[force ANSI output]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'codeception command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      run)
        _arguments -s -S \
          '-g+[only run tests with specified group]:group' \
          '--group=[only run tests with specified group]:group' \
          '-s+[run tests in specified suite]:suite' \
          '--suite=[run tests in specified suite]:suite' \
          '--steps[show steps in output]' \
          '--debug[show debug output]' \
          '--coverage[run with code coverage]' \
          '--coverage-html=[generate HTML coverage report]:directory:_directories' \
          '--coverage-xml=[generate XML coverage report]:file:_files' \
          '--coverage-text=[print text coverage report]:file:_files' \
          '--coverage-phpunit=[generate PHPUnit coverage report]:file:_files' \
          '--no-rebuild[do not rebuild actor classes]' \
          '-f[stop after first failure]' \
          '--fail-fast[stop after first failure]' \
          '--env=[run in specified environment]:environment' \
          '--override=[override config values]:config' \
          '--no-exit[do not finish with exit code]' \
          '--html=[generate HTML report]:file:_files' \
          '--xml=[generate JUnit XML report]:file:_files' \
          '--skip=[skip specified groups]:group' \
          '--skip-group=[skip specified groups]:group' \
          '--no-artifacts[do not store artifacts]' \
          '--seed=[set random seed]:seed' \
          '--shard=[set shard]:current/total' \
          '*:test file:_files -g "*.php"' && ret=0
        ;;
    esac
    ;;
esac

return ret
