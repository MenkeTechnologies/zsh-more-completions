#compdef listor

# EMBOSS listor: write a list of sequences (OR / AND / NOT / XOR) of two sets
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-firstsequences=[first sequence set]:USA:_files' \
  '-secondsequences=[second sequence set]:USA:_files' \
  '-operator=[set logic operator]:op:(OR AND XOR NOT)' \
  '-outfile=[output list file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
