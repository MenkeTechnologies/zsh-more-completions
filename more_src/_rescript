#compdef rescript

# Zsh completion for ReScript - strongly typed language that compiles to JavaScript

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'build:build the project'
  'clean:clean the project'
  'format:format ReScript source files'
  'convert:convert ReasonML code to ReScript syntax'
  'dump:dump data for debugging'
  'help:display help'
)

_arguments -s -S \
  '1:command:->command' \
  '-h[show help]' \
  '-v[show version]' \
  '-version[show version]' \
  '-w[watch mode]' \
  '-with-deps[build with dependencies]' \
  '-verbose[verbose output]' \
  '-warn-error[treat warnings as errors]' \
  '-ws[WebSocket host\:port]:host\:port:' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rescript command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '-w[watch mode]' \
          '-with-deps[build with dependencies]' \
          '-verbose[verbose output]' && ret=0
        ;;
      (format)
        _arguments -s -S \
          '-all[format all .res and .resi files in the current directory]' \
          '-stdin[read from stdin]:extension:(.res .resi)' \
          '-check[check formatting but do not write]' \
          '*:files:_files -g "*.res(i|)"' && ret=0
        ;;
      (convert)
        _arguments -s -S \
          '-all[convert all .re and .rei files in the current directory]' \
          '*:files:_files -g "*.re(i|)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
