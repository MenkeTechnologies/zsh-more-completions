#compdef compreffor
# Documentation: https://github.com/googlefonts/compreffor
# CFF table subroutinizer for FontTools

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*'{-v,--verbose}'[print more messages to stdout; repeat for more]' \
  '(-c --check)'{-c,--check}'[verify that the outputted font is valid]' \
  '(-d --decompress)'{-d,--decompress}'[decompress source before compressing]' \
  '(-n --nrounds)'{-n,--nrounds}'=[number of iterations to run the algorithm]:n' \
  '(-m --max-subrs)'{-m,--max-subrs}'=[limit the number of subroutines per INDEX]:n' \
  '--generate-cff[also save binary CFF table data as INPUT.cff]' \
  '--py[use pure Python method instead of C++ extension]' \
  '--chunk-ratio=[percentage size of chunks for pure Python method]:ratio' \
  '(-p --processes)'{-p,--processes}'=[number of concurrent processes (pure Python)]:n' \
  '1:input font:_files -g "*.(ttf|otf|TTF|OTF)"' \
  '2:output font:_files' && ret=0

return ret
