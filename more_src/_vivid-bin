#compdef vivid
# _vivid-bin — vivid LS_COLORS generator (David Peter / sharkdp, Rust); yaml theme + filetype DB → LS_COLORS export
# upstream: https://github.com/sharkdp/vivid

_vivid-bin() {
    local -a sub=(
        'generate:generate LS_COLORS for a theme'
        'preview:render preview of a theme'
        'themes:list available themes'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --database)'{-d,--database}'+[filetype database yaml]:file:_files -g "*.yml"' \
        '(-c --color-mode)'{-c,--color-mode}'+[color mode]:mode:(8-bit 24-bit)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vivid subcommand' sub ;;
        args)
            case $words[1] in
                generate|preview) _arguments '1:theme:' ;;
            esac
            ;;
    esac
}

_vivid-bin "$@"
