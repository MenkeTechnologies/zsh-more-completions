#compdef gerrit

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'apropos:search Gerrit documentation'
  'ban-commit:ban a commit by SHA-1'
  'check-project-access:check project access'
  'cleanup-draft-comments:remove orphan draft comments'
  'close-connection:close a remote SSH connection'
  'convert-ref-storage:convert ref storage'
  'create-account:create a Gerrit account'
  'create-branch:create a new branch'
  'create-group:create an internal group'
  'create-project:create a new project'
  'flush-caches:flush server caches'
  'gc:run garbage collection'
  'index:index commands'
  'kill:kill a running task'
  'logging:logging level commands'
  'ls-groups:list user groups'
  'ls-members:list members of a group'
  'ls-projects:list visible projects'
  'ls-user-refs:list user refs'
  'migrate-externalids-to-insensitive:migrate external IDs'
  'plugin:plugin commands'
  'ps:list active tasks'
  'query:execute a query against the Gerrit data store'
  'receive-pack:invoke git-receive-pack'
  'reload-config:reload configuration'
  'rename-group:rename a group'
  'review:apply review labels and comments'
  'sequence:sequence number commands'
  'set-account:edit a Gerrit account'
  'set-head:set HEAD of a project'
  'set-members:set members of a group'
  'set-project:edit a project configuration'
  'set-project-parent:set project parent'
  'set-reviewers:set reviewers on a change'
  'set-topic:set topic on a change'
  'show-caches:show cache statistics'
  'show-connections:show open SSH connections'
  'show-queue:show task queue'
  'stream-events:stream events to standard output'
  'suexec:execute as another user'
  'test-submit:test a submit rule or type'
  'version:show server version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--trace[enable request tracing]' \
  '--trace-id=[trace id]:id:' \
  '--deadline=[request deadline]:duration:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'gerrit subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (index)
        _values 'index action' 'activate' 'start' 'changes' 'changes-in-project' && ret=0
        ;;
      (logging)
        _values 'logging action' 'ls-level' 'set-level' && ret=0
        ;;
      (plugin)
        _values 'plugin action' 'add' 'enable' 'install' 'ls' 'reload' 'remove' 'rm' && ret=0
        ;;
      (sequence)
        _values 'sequence action' 'set' 'show' && ret=0
        ;;
      (test-submit)
        _values 'test-submit action' 'rule' 'type' && ret=0
        ;;
      (ls-projects)
        _arguments \
          '--format=[output format]:format:(text json json_compact)' \
          '--show-branch=[branch info]:branch:' \
          '--description[show description]' \
          '-r[match by regex]' \
          '--all[show all]' && ret=0
        ;;
    esac
    ;;
esac

return ret
