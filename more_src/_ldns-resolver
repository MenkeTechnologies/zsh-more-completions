#compdef ldns-resolver
# _ldns-resolver — NLnet Labs ldns-resolver (DNS stub resolver demo: resolve QNAME QTYPE through a given upstream, optionally with DNSSEC validation; -s upstream, -p port, -t TCP, -d DNSSEC validation, -4 IPv4 only, -6 IPv6 only, -e EDNS UDP size; positional QNAME and QTYPE)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-resolver.c on tip.

_ldns-resolver() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-s+[upstream]:host:_hosts' \
        '-p+[port]:port:' \
        '-t[use TCP]' \
        '-d[DNSSEC validation]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-e+[EDNS UDP size]:bytes:' \
        '1:QNAME:' \
        '2:QTYPE:(A AAAA NS MX TXT CNAME PTR SOA DS DNSKEY RRSIG NSEC NSEC3 CAA TLSA SVCB HTTPS SRV ANY)'
}

_ldns-resolver "$@"
