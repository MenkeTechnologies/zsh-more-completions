#compdef mris_ca_label
# Documentation: https://surfer.nmr.mgh.harvard.edu/fswiki/mris_ca_label
# FreeSurfer: assign anatomical labels to a surface using a GCS classifier

local ret=1

_arguments -s -S \
  '(- *)--help[print help info]' \
  '(- *)--version[print version info]' \
  '-sdir[subjects directory]:dir:_files -/' \
  '-orig[original surface filename (default smoothwm)]:filename' \
  '-long[refine initial labeling read-in from -r]' \
  '-r[file containing precomputed parcellation]:filename:_files' \
  '-novar[set all covariance matrices to identity]' \
  '-nbrs[neighborhood size (default 2)]:number' \
  '-f[apply mode filter number times (default 10)]:number' \
  '-t[parcellation table input file]:filename:_files' \
  '-p[output label probability per vertex]:filename:_files' \
  '-v[diagnostic level]:number' \
  '-w[write gibbs snapshots every N iters]:number:filename' \
  '*:argument:_files' && ret=0

return ret
