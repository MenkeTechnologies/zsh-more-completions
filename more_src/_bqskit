#compdef bqskit bqskit-cli
# _bqskit — Berkeley Quantum Synthesis Toolkit numerical circuit synthesis optimization and compilation framework (BQSKit team, Python); argparse
# upstream: https://github.com/BQSKit/bqskit

_bqskit() {
    local -a sub=(
        'compile:compile a circuit'
        'synthesize:synthesize unitary'
        'partition:partition a circuit'
        'optimize:run optimization passes'
        'simulate:simulate a circuit'
        'server:run BQSKit server'
        'client:run BQSKit client'
        'manager:run BQSKit manager'
        'runtime:runtime subcommands'
        'visualize:visualize circuit'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--optimization-level=+[level]:l:(1 2 3 4)' \
        '-O+[level]:l:(1 2 3 4)' \
        '--num-workers=+[N]:n:' \
        '--num-cpus=+[N]:n:' \
        '--max-synthesis-size=+[N]:n:' \
        '--target=+[target]:str:' \
        '--basis-gates=+[gates csv]:str:' \
        '--coupling-graph=+[graph file]:file:_files' \
        '--cost-function=+[cost]:c:(HilbertSchmidtResiduals HilbertSchmidtCost FrobeniusCost FrobeniusNoPhaseCost FullHilbertSchmidtResidualsGenerator)' \
        '--seed=+[seed]:n:' \
        '--server-host=+[host]:host:_hosts' \
        '--server-port=+[port]:port:_ports' \
        '--manager-host=+[host]:host:_hosts' \
        '--manager-port=+[port]:port:_ports' \
        '--no-progress-bar[no progress bar]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bqskit subcommand' sub ;;
        args)
            case $words[1] in
                compile|synthesize|optimize|simulate|partition) _arguments \
                    '--input-format=+[format]:f:(qasm qasm3 qpy quil pickle json)' \
                    '--output-format=+[format]:f:(qasm qasm3 qpy quil pickle json)' \
                    '-o+[output file]:file:_files' \
                    '*:circuit:_files -g "*.qasm *.qasm3 *.qpy *.quil *.pkl *.json"' ;;
                server|manager) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--worker-port=+[port]:port:_ports' \
                    '--log-level=+[level]:l:(debug info warning error critical)' ;;
                runtime) _arguments '1:runtime cmd:(start stop status)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_bqskit "$@"
