#compdef cilium-agent
# Documentation: https://docs.cilium.io/en/stable/cmdref/cilium-agent/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cilium-agent: Cilium per-node agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--agent-health-port=[health status API port]:port:' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--config=[config file]:file:_files' \
  '--cluster-name=[cluster name]:name:' \
  '--cluster-id=[cluster id]:n:' \
  '--debug[enable debug]' \
  '--debug-verbose=[debug verbose]:opts:' \
  '--routing-mode=[routing mode]:mode:(native tunnel)' \
  '--tunnel-protocol=[tunnel protocol]:proto:(vxlan geneve)' \
  '--ipv4-range=[per-node IPv4 endpoint prefix]:cidr:' \
  '--ipv6-range=[per-node IPv6 endpoint prefix]:cidr:' \
  '--enable-ipv4=[enable IPv4]:bool:(true false)' \
  '--enable-ipv6=[enable IPv6]:bool:(true false)' \
  '--enable-bpf-masquerade=[enable BPF masquerade]:bool:(true false)' \
  '--enable-host-firewall=[enable host firewall]:bool:(true false)' \
  '--enable-policy=[enable policy]:mode:(default always never)' \
  '--enable-l7-proxy=[enable L7 proxy]:bool:(true false)' \
  '--enable-endpoint-routes=[endpoint routes]:bool:(true false)' \
  '--enable-local-redirect-policy[enable LRP]' \
  '--enable-host-port=[enable hostPort]:bool:(true false)' \
  '--enable-node-port=[enable nodePort]:bool:(true false)' \
  '--enable-external-ips=[enable externalIPs]:bool:(true false)' \
  '--enable-l2-announcements=[enable L2 announcements]:bool:(true false)' \
  '--enable-svc-source-range-check=[enable service source range check]:bool:(true false)' \
  '--enable-runtime-device-detection[runtime device detection]' \
  '--enable-encryption-strict-mode-egress=[strict egress encryption]:bool:(true false)' \
  '--enable-encryption-strict-mode-ingress=[strict ingress encryption]:bool:(true false)' \
  '--kube-proxy-replacement=[kube-proxy replacement]:mode:(true false partial probe disabled)' \
  '--bpf-lb-mode=[BPF LB mode]:mode:(snat dsr hybrid)' \
  '--bpf-lb-acceleration=[BPF LB acceleration]:mode:(disabled native best-effort)' \
  '--bpf-map-dynamic-size-ratio=[memory ratio for dynamic BPF maps]:ratio:' \
  '--devices=[network devices]:list:' \
  '--encryption-mode=[encryption mode]:mode:(ipsec wireguard)' \
  '--monitor-aggregation=[monitor aggregation]:level:(none low medium maximum)' \
  '--metrics=[metrics list]:list:' \
  '--prometheus-serve-addr=[Prometheus listen addr]:addr:' \
  '--operator-prometheus-serve-addr=[operator metrics addr]:addr:' \
  '--api-rate-limit=[API rate limit]:rate:' \
  '--k8s-namespace=[k8s namespace]:ns:' \
  '--k8s-api-server=[k8s API URL]:url:' \
  '--k8s-kubeconfig-path=[kubeconfig path]:file:_files' \
  '--enable-k8s=[enable Kubernetes clientset]:bool:(true false)' \
  '--cni-chaining-mode=[CNI chaining mode]:mode:(portmap aws-cni flannel generic-veth none)' \
  '--cni-exclusive=[CNI exclusive mode]:bool:(true false)' \
  '--cni-conf-dir=[CNI conf dir]:dir:_files -/' \
  '--cni-bin-dir=[CNI bin dir]:dir:_files -/' \
  '--socket-path=[socket path]:file:_files' \
  '--log-driver=[log driver]:driver:(syslog journal)' \
  '--log-opt=[log driver options]:opts:' \
  '--enable-hubble=[enable hubble]:bool:(true false)' \
  '--hubble-listen-address=[hubble listen]:addr:' \
  '--hubble-metrics=[hubble metrics list]:list:' \
  '--hubble-disable-tls[disable hubble TLS]' \
  '*::cilium-agent args:_files' && ret=0
return ret
