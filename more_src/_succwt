#compdef succwt
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/transforms/succwt.c
# Complex continuous wavelet transform of seismic traces

local ret=1

_arguments -s -S \
  'noct=[noct]:noct:' \
  'nv=[nv]:nv:' \
  'fmax=[fmax]:fmax:' \
  'p=[p]:p:' \
  'c=[c]:c:' \
  'k=[k]:k:' \
  'fs=[fs]:fs:' \
  'df=[df]:df:' \
  'dt=[dt]:dt:' \
  'verbose=[verbose]:verbose:' \
  'ntr=[ntr]:ntr:' \
  'ix1=[ix1]:ix1:' \
  'nt=[nt]:nt:' \
  'mode=[mode]:mode:' \
  'key=[key]:key:' \
  '*:file:_files' && ret=0

return ret
