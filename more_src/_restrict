#compdef restrict
# Documentation: https://man.archlinux.org/search?q=restrict
# Reference accessed: 2026-05-16

# EMBOSS restrict: tabulate restriction enzyme cleavage sites with cut
# positions, fragment sizes, and isoschizomer grouping.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[force qualifier prompts]' '-debug[debug log]' '-verbose[verbose]' \
  '-warning[warnings]' '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence(s)]:sequence USA:_files' \
  '-enzymes=[enzymes (comma-list, "all", "@file")]:enzymes:' \
  '-sitelen=[minimum recognition-site length]:length:(4 5 6 7 8 9 10)' \
  '-min=[minimum cuts per sequence]:cuts:' \
  '-max=[maximum cuts per sequence]:cuts:' \
  '-solofragment[include enzymes that cut once or zero times]' \
  '-single[force single-cut enzymes]' \
  '-blunt[blunt-end enzymes]' \
  '-sticky[sticky-end enzymes]' \
  '-ambiguity[allow ambiguity codes]' \
  '-plasmid[circular sequence]' \
  '-methylation[respect methylation blocking]' \
  '-commercial[commercial enzymes only]' \
  '-alphabetic[output sorted alphabetically by enzyme]' \
  '-fragments[list fragment lengths produced]' \
  '-name[include sequence name in output]' \
  '-limit[show only one isoschizomer per pair]' \
  '-rformat=[restriction enzyme report format]:format:(table embl excel feattable gff3 pir simple swiss tagseq listfile)' \
  '-outfile=[output file]:file:_files' \
  '*:DNA sequence:_files' && ret=0

return ret
