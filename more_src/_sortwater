#compdef sortwater
# CCP4: sort water molecules by the protein chain they belong to

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'XYZIN[input coordinate file]:coordinates:_files -g "*.(pdb|cif|ent|brk)"' \
  'XYZOUT[output coordinate file]:output:_files' \
  '*:keyword:(CARBON CHAINS DISTANCE NCS SYMMETRY VERBOSE WATER WCHAINS END)' && ret=0

return ret
