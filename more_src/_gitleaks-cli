#compdef gitleaks

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'detect:detect secrets in a Git history (deprecated)'
  'git:detect secrets in a Git history'
  'dir:detect secrets in a directory'
  'directory:detect secrets in a directory'
  'protect:protect uncommitted changes (deprecated)'
  'stdin:detect secrets from stdin'
  'version:show version'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.toml"' \
  '*--baseline-path=[baseline path]:file:_files' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:l:(debug info warn error fatal panic)' \
  '*--no-color[no color output]' \
  '*--max-decode-depth=[max decode depth]:n:' \
  '*--max-archive-depth=[max archive depth]:n:' \
  '*--ignore-gitleaks-allow[ignore gitleaks:allow]' \
  '*-v[verbose]' \
  '(-r --report-path)'{-r+,--report-path=}'[report path]:file:_files' \
  '(-f --report-format)'{-f+,--report-format=}'[report format]:f:(json csv junit sarif template)' \
  '*--exit-code=[exit code]:n:' \
  '*--source=[source]:dir:_files -/' \
  '(--redact)--redact+[redact percent]:n:' \
  '*--enable-rule=[enable rule csv]:list:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gitleaks command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (detect|git|dir|directory)
        _arguments \
          '(--no-git)--no-git[treat as plain dir]' \
          '(--pre-commit)--pre-commit[scan staged files]' \
          '(--log-opts)--log-opts=[git log opts]:opts:' \
          '(--diagnostics)--diagnostics=[diagnostics]:list:' \
          '(--diagnostics-dir)--diagnostics-dir=[dir]:dir:_files -/' \
          '(--max-target-megabytes)--max-target-megabytes=[mb]:n:' \
          '(--follow-symlinks)--follow-symlinks[follow symlinks]' \
          '*: :_files' && ret=0 ;;
      (stdin)
        _arguments '*: :' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
