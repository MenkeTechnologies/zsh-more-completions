#compdef simctl

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'addmedia:add photos/videos to simulator'
  'boot:boot a device'
  'clone:clone an existing device'
  'create:create a new device'
  'delete:delete devices'
  'diagnose:collect diagnostic information'
  'erase:erase device content and settings'
  'get_app_container:print app container path'
  'getenv:print environment variable'
  'icloud_sync:trigger iCloud sync'
  'install:install an app on a device'
  'io:set up device IO capabilities'
  'keychain:manipulate device keychain'
  'launch:launch an application'
  'list:list available devices, runtimes, etc'
  'logverbose:enable or disable verbose logging'
  'openurl:open a URL on a device'
  'pair:create a pair between watch and phone'
  'pair_activate:activate a pair'
  'pbcopy:copy to pasteboard of device'
  'pbpaste:paste from pasteboard of device'
  'pbsync:sync pasteboard from host to device'
  'privacy:grant/revoke/reset privacy permissions'
  'push:send a simulated push notification'
  'rename:rename a device'
  'runtime:manage simulator runtimes'
  'shutdown:shutdown a device'
  'spawn:spawn a process on a device'
  'status_bar:set or clear status bar overrides'
  'terminate:terminate an app on device'
  'ui:manage UI settings'
  'uninstall:uninstall an app from device'
  'unpair:unpair two devices'
  'upgrade:upgrade a device to a newer runtime'
)

_arguments -s -S \
  '--set=[device set path]:path:_directories' \
  '--profiles=[profiles path]:path:_directories' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'simctl command' commands && ret=0
    ;;
  (args)
    local -a devices
    devices=(${(f)"$(xcrun simctl list devices -j 2>/dev/null | python3 -c 'import json,sys;d=json.load(sys.stdin);[print(x["udid"]+":"+x["name"].replace("\\\\","").replace(":","")) for r in d.get("devices",{}).values() for x in r]' 2>/dev/null)"})

    case ${line[1]} in
      (boot|shutdown|erase|clone|rename|upgrade)
        _arguments '1:device:_describe -t devices "device" devices' && ret=0
        ;;
      (create)
        _arguments \
          '1:device name' \
          '2:device type' \
          '3:runtime' && ret=0
        ;;
      (delete)
        _arguments \
          '--all[delete all devices]' \
          '--unavailable[delete unavailable devices]' \
          '*:device:_describe -t devices "device" devices' && ret=0
        ;;
      (install)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:app path:_files -g "*.app"' && ret=0
        ;;
      (uninstall)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:bundle identifier' && ret=0
        ;;
      (launch)
        _arguments \
          '--console[pipe stdout/stderr to current terminal]' \
          '--stdout=[redirect stdout]:file:_files' \
          '--stderr=[redirect stderr]:file:_files' \
          '-w[wait for app to exit]' \
          '1:device:_describe -t devices "device" devices' \
          '2:bundle identifier' \
          '*:launch arguments' && ret=0
        ;;
      (terminate)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:bundle identifier' && ret=0
        ;;
      (openurl)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:URL' && ret=0
        ;;
      (push)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:bundle identifier' \
          '3:JSON file:_files -g "*.json"' && ret=0
        ;;
      (privacy)
        _arguments \
          '1:action:(grant revoke reset)' \
          '2:service:(all calendar contacts-limited contacts location location-always photos photos-add media-library microphone motion reminders siri speech)' \
          '3:device:_describe -t devices "device" devices' \
          '4:bundle identifier' && ret=0
        ;;
      (list)
        _arguments \
          '-j[JSON output]' \
          '--json[JSON output]' \
          '-v[verbose output]' \
          '1:filter:(devices devicetypes runtimes pairs)' && ret=0
        ;;
      (io)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:operation:(screenshot recordVideo)' \
          '*:arguments' && ret=0
        ;;
      (status_bar)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:action:(override clear)' \
          '--time=[set time]:time' \
          '--dataNetwork=[data network]:type:(wifi 3g 4g lte lte-a lte+ 5g 5g+ 5g-uwb)' \
          '--wifiMode=[wifi mode]:mode:(searching active failed)' \
          '--wifiBars=[wifi signal bars]:bars:(0 1 2 3)' \
          '--cellularMode=[cellular mode]:mode:(notSupported searching active failed)' \
          '--cellularBars=[cellular signal bars]:bars:(0 1 2 3 4)' \
          '--batteryState=[battery state]:state:(charging charged discharging)' \
          '--batteryLevel=[battery level]:level' && ret=0
        ;;
      (ui)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:option:(appearance content_size increase_contrast)' \
          '3:value' && ret=0
        ;;
      (spawn)
        _arguments \
          '-s[standalone spawn]' \
          '-w[wait for process to exit]' \
          '1:device:_describe -t devices "device" devices' \
          '2:path to executable:_files' \
          '*:arguments' && ret=0
        ;;
      (addmedia)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '*:media files:_files' && ret=0
        ;;
      (get_app_container)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:bundle identifier' \
          '3:container:(app data groups)' && ret=0
        ;;
      (keychain)
        _arguments \
          '1:device:_describe -t devices "device" devices' \
          '2:action:(reset)' && ret=0
        ;;
      (runtime)
        local -a runtime_cmds=('add:add a runtime' 'delete:delete a runtime' 'list:list runtimes' 'match-policy:show runtime matching policy')
        _arguments '1:runtime command:_describe -t runtime-cmds "runtime command" runtime_cmds' && ret=0
        ;;
    esac
    ;;
esac

return ret
