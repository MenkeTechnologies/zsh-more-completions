#compdef imessage-exporter

# Zsh completion for imessage-exporter (ReagentX/imessage-exporter). Flags from imessage-exporter/src/app/options.rs (clap builder).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --diagnostics)'{-d,--diagnostics}'[print diagnostics and exit]' \
  '(-f --format)'{-f,--format=}'[export format]:format:(txt html)' \
  '(-c --copy-method)'{-c,--copy-method=}'[attachment copy mode]:mode:(clone basic full disabled)' \
  '(-p --db-path)'{-p,--db-path=}'[path to chat.db or iOS backup root]:path:_files' \
  '(-r --attachment-root)'{-r,--attachment-root=}'[custom attachments root]:path:_directories' \
  '(-a --platform)'{-a,--platform=}'[source platform]:platform:(macOS iOS)' \
  '(-o --export-path)'{-o,--export-path=}'[output directory]:path:_directories' \
  '(-s --start-date)'{-s,--start-date=}'[include messages on or after (YYYY-MM-DD)]:date:' \
  '(-e --end-date)'{-e,--end-date=}'[include messages before (YYYY-MM-DD)]:date:' \
  '(-l --no-lazy)'{-l,--no-lazy}'[omit loading=lazy on HTML img tags]' \
  '(-m --custom-name)'{-m,--custom-name=}'[custom label for owner messages]' \
  '(-i --use-caller-id)'{-i,--use-caller-id}'[use owner caller ID instead of Me]' \
  '(-b --ignore-disk-warning)'{-b,--ignore-disk-warning}'[skip free disk space check]' \
  '(-t --conversation-filter)'{-t,--conversation-filter=}'[comma-separated handles to filter]' \
  '(-x --cleartext-password)'{-x,--cleartext-password=}'[encrypted iOS backup password]' \
  '(-n --contacts-path)'{-n,--contacts-path=}'[contacts DB path]:path:_files'
