#compdef nordvpn

# Zsh completion for nordvpn - NordVPN CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'account:show account information'
  'cities:show available cities for a country'
  'connect:connect to VPN'
  'countries:show available countries'
  'disconnect:disconnect from VPN'
  'groups:show available server groups'
  'login:log into NordVPN account'
  'logout:log out of NordVPN account'
  'meshnet:manage Meshnet'
  'rate:rate your last connection'
  'register:register a new NordVPN account'
  'set:set configuration options'
  'settings:show current settings'
  'status:show connection status'
  'version:show version'
  'allowlist:manage allowlist'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'nordvpn command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      connect)
        _arguments \
          '(-g --group)'{-g,--group}'[specify server group]:group' \
          '1:country or server' && ret=0
        ;;
      set)
        local -a settings=(
          'autoconnect:enable/disable auto-connect'
          'cybersec:enable/disable CyberSec'
          'defaults:restore default settings'
          'dns:set custom DNS servers'
          'firewall:enable/disable firewall'
          'ipv6:enable/disable IPv6'
          'killswitch:enable/disable Kill Switch'
          'lan-discovery:enable/disable LAN discovery'
          'meshnet:enable/disable Meshnet'
          'notify:enable/disable notifications'
          'obfuscate:enable/disable obfuscation'
          'protocol:set connection protocol'
          'technology:set connection technology'
          'threatprotectionlite:enable/disable Threat Protection Lite'
          'virtual-location:enable/disable virtual location'
        )
        _describe -t settings 'setting' settings && ret=0
        ;;
      rate)
        _arguments '1:rating:(1 2 3 4 5)' && ret=0
        ;;
      allowlist)
        local -a allowlist_cmds=(
          'add:add to allowlist'
          'remove:remove from allowlist'
        )
        _describe -t commands 'allowlist command' allowlist_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
