# -----------------------------------------------------------------------------
#
# THE avo CLI — yargs + date-fns + inquirer + ora + got + configstore + jwt
#
# avo's CLI is in cli.ts (TypeScript, ~3500 lines).  Uses yargs:
#
#     import yargs from 'yargs';
#     import { hideBin } from 'yargs/helpers';
#     import dateFns from 'date-fns';
#     import ora from 'ora';
#     import inquirer from 'inquirer';
#     import got from 'got';
#     import Configstore from 'configstore';
#     import jwt from 'jsonwebtoken';
#     ...
#     yargs(hideBin(process.argv))
#         .usage('$0 command')
#         .option('v', { alias: 'verbose', type: 'boolean' })
#         .command({ command: 'init', ... })
#         .command({ command: 'pull [source]', ... })
#         .command({ command: 'checkout [branch]', aliases: ['branch'], ... })
#         .command({ command: 'source <command>', ... })
#         .command({ command: 'status [source]', ... })
#         .command({ command: 'merge main', aliases: ['merge master'], ... })
#         .command({ command: 'conflict', aliases: ['resolve', 'conflicts'], ... })
#         .command({ command: 'edit', ... })
#         .command({ command: 'login', ... })
#         .command({ command: 'logout', ... })
#         .command({ command: 'whoami', ... })
#         .demandCommand(1, 'must provide a valid command')
#         .help()
#         .version()
#         .parse();
#
# Subcommands (12, including hidden track-install):
#   init                       Initialize an Avo workspace
#   pull [source]              Pull analytics wrappers from workspace
#   checkout [branch]          Switch branches (alias: branch)
#   source <add|remove|rm>     Manage sources for the current project
#   status [source]            Show Avo implementation status
#   merge main                 Pull main branch into current (alias: merge master)
#   conflict                   Resolve git conflicts in Avo files
#                              (aliases: resolve, conflicts)
#   edit                       Open Avo workspace in browser
#   login                      Log into Avo platform
#   logout                     Log out from Avo platform
#   whoami                     Shows currently logged-in user
#
# Pull-specific options:
#   --branch BRANCH            Pull from specified branch
#   -f, --force                Force overwrite of local files
#   --forceFeatures            Force pull features
#
# date-fns is used in cli.ts for `format()` to render Avo
# workspace last-update timestamps + `formatDistanceToNow()` for
# "last pulled 3 hours ago" relative time labels in `avo status`.
#
# Five-axis distinctness from chrono (R645) + dateparse (R646):
#
#   1. MODULAR FUNCTIONAL API — every function a named import;
#      chrono is a comprehensive crate; dateparse is a single-
#      function library.  date-fns: 200+ tree-shakeable functions.
#
#   2. IMMUTABLE OPERATIONS on stdlib Date — pure functions
#      return new Date; chrono uses its own types; dateparse
#      returns stdlib *time.Time.  date-fns: stdlib Date with
#      pure-function operations.
#
#   3. NO CUSTOM TYPE — operates on stdlib Date; chrono has its
#      own DateTime<Tz>; dateparse returns stdlib *time.Time
#      (also no custom type but only a parser).  date-fns: full
#      operations vocabulary on stdlib Date.
#
#   4. 90+ LOCALES separately importable — chrono has chrono-tz
#      for timezones; dateparse has no locale support.  date-fns:
#      en-US / fr / de / ja / zh-CN / 90+ locales tree-shaken.
#
#   5. SASHA-KOSS / KOSSNOCORP ECOSYSTEM PROVENANCE — distinct
#      from Tolnay (Rust serde), Sorhus (Node CLI utils), Cobra
#      (Go).  date-fns: Sasha Koss + 700+ contributor community.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/avohq/avo/blob/main/cli.ts
# yargs .command() / .option() definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _avo_cmds _avo_source_cmds
_avo_cmds=(
    'init:Initialize an Avo workspace in the current folder'
    'pull:Pull analytics wrappers from Avo workspace'
    'checkout:Switch branches'
    'branch:Switch branches (alias for checkout)'
    'source:Manage sources for the current project'
    'status:Show the status of the Avo implementation'
    'merge:Pull the Avo main branch into your current branch'
    'conflict:Resolve git conflicts in Avo files'
    'resolve:Resolve git conflicts in Avo files (alias)'
    'conflicts:Resolve git conflicts in Avo files (alias)'
    'edit:Open the Avo workspace in your browser'
    'login:Log into the Avo platform'
    'logout:Log out from the Avo platform'
    'whoami:Shows the currently logged in username'
    'help:show help for a subcommand'
)
_avo_source_cmds=(
    'add:Add a source to this project'
    'remove:Remove a source from this project'
    'rm:Remove a source from this project (alias)'
)

_arguments -C \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'avo subcommand' _avo_cmds && ret=0
        ;;
    args)
        case $words[1] in
            pull)
                _arguments \
                    '--branch=[pull from specified branch]:branch:_default' \
                    '(-f --force)'{-f,--force}'[force overwrite of local files]' \
                    '--forceFeatures[force pull features]' \
                    '*:source:_default' \
                    && ret=0
                ;;
            source)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'source subcommand' _avo_source_cmds && ret=0
                fi
                ;;
            merge)
                _values 'merge target' 'main' 'master' && ret=0
                ;;
            checkout|branch)
                _message 'branch name' && ret=0
                ;;
            status)
                _message 'source (optional)' && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _avo_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
