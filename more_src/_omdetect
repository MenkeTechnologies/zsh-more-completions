#compdef omdetect
# Documentation: https://xmm-tools.cosmos.esa.int/external/sas/current/doc/omdetect/node4.html
# Detect sources on OM product images and perform aperture photometry

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-V --verbosity)'{-V,--verbosity}'+[set verbosity level]:level' \
  '--set=[name of OM product FITS image file]:file:_files' \
  '--outset=[name of output OM source list file]:file:_files' \
  '--wdxset=[OM priority-window data auxiliary file]:file:_files' \
  '--nsigma=[number of sigma above background for a detection]:value' \
  '--minsignificance=[minimum significance for SRCLIST inclusion]:value' \
  '--levelimage=[name of image of island detections]:file:_files' \
  '--backgroundimage=[name of background image file]:file:_files' \
  '--regionfile=[name of ds9 region file]:file:_files' \
  '--detectextended=[use extended-source detection algorithm]:bool:(yes no)' \
  '--psfphotometryenabled=[enable PSF fitting photometry]:bool:(yes no)' \
  '--neighboursforpsfphotometry=[min neighbours to implement PSF-photometry]:n' \
  '--psfphotometryset=[output source list with PSF-photometry]:file:_files' \
  '--maxrawcountrate=[max raw count-rate above which PSF photometry is off]:value' \
  '--backgroundmethod=[background method to use]:method:(1 2 3 4 5)' \
  '*:param=value:_default' && ret=0

return ret
