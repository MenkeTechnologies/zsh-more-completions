#compdef virt-freezer
# _virt-freezer — KubeVirt helper that issues guest-agent freeze/thaw to quiesce a VM for snapshots
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-freezer/virt-freezer.go on tip.

_virt-freezer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--freeze[freeze VM]' \
        '--unfreeze[unfreeze VM]' \
        '--name=[name of the VirtualMachineInstance]:name:' \
        '--namespace=[namespace of the VirtualMachineInstance]:ns:' \
        '--unfreezeTimeoutSeconds=[seconds to wait before automatic unfreeze]:n:'
}

_virt-freezer "$@"
