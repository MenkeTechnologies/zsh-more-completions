#compdef swc

# Zsh completion for swc (Rust-based JavaScript/TypeScript compiler)

local curcontext="$curcontext" state line ret=1

_swc_compile_flags() {
  _arguments -s \
    '(-o --out-file)'{-o,--out-file}'[output file]:file:_files' \
    '(-d --out-dir)'{-d,--out-dir}'[output directory]:directory:_files -/' \
    '--env-name[environment name]:name' \
    '--no-swcrc[do not use .swcrc config]' \
    '--ignore[glob pattern to ignore]:glob' \
    '--only[only compile files matching glob]:glob' \
    '(-w --watch)'{-w,--watch}'[watch for file changes]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
    '(-s --source-maps)'{-s,--source-maps}'[generate source maps]:type:(true false inline both)' \
    '--source-map-target[source map target file]:file:_files' \
    '--source-file-name[source file name]:name' \
    '--source-root[source root directory]:directory:_files -/' \
    '*'{-C,--config}'[configuration key=value pair]:config' \
    '--config-file[path to config file]:file:_files' \
    '--sync[invoke synchronously]' \
    '--log-watch-compilation[log watch compilation]' \
    '--extensions[file extensions to compile]:extensions' \
    '--strip-leading-paths[strip leading paths]' \
    '--copy-files[copy non-compilable files]' \
    '--include-dotfiles[include dotfiles]' \
    '--filename[filename for stdin]:name' \
    '--no-update-latest-ast[do not update latest AST]' \
    '--delete-dir-on-start[delete output directory on start]' \
    '(- *)--help[show help message]' \
    '(- *)--version[show version]' \
    '*:input files:_files'
}

_swc_minify_flags() {
  _arguments -s \
    '(-o --out-file)'{-o,--out-file}'[output file]:file:_files' \
    '(-d --out-dir)'{-d,--out-dir}'[output directory]:directory:_files -/' \
    '--source-maps[generate source maps]:type:(true false inline both)' \
    '*'{-C,--config}'[configuration key=value pair]:config' \
    '(- *)--help[show help message]' \
    '(- *)--version[show version]' \
    '*:input files:_files'
}

_swc() {
  local -a commands=(
    'compile:compile files'
    'c:compile files'
    'minify:minify files'
  )

  _arguments -C \
    '(- *)--help[show help message]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::args:->args' && ret=0

  case $state in
    command)
      _describe -t commands 'swc command' commands && ret=0
      ;;
    args)
      case $words[1] in
        compile|c)
          _swc_compile_flags && ret=0
          ;;
        minify)
          _swc_minify_flags && ret=0
          ;;
      esac
      ;;
  esac

  return ret
}

_swc "$@"
