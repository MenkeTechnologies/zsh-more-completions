#compdef sdas8051

# sdas8051: SDCC 8051 assembler
# Documentation: https://sdcc.sourceforge.net/doc/sdccman.pdf
# Reference accessed: 2026-05-16
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '*::sdas8051 args:_files' && ret=0
return ret
