#compdef notmuch-mutt
# Documentation: https://manpages.debian.org/bookworm/notmuch-mutt/notmuch-mutt.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm notmuch-mutt(1) manpage OPTIONS + COMMANDS.
# Removed from prior file: fabricated --version (the tool does not document
# one) and bogus man.archlinux.org search URL.

# notmuch-mutt: notmuch search integration helper for mutt
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'search:search messages and present results as a maildir'
  'thread:show all messages in the same thread as the input'
  'tag:add or remove tags on matching messages'
)
_arguments -C \
  '(-h --help)'{-h,--help}'[show usage]' \
  '(-o --output-dir)'{-o,--output-dir=}'[store results as symlinks under this maildir]:dir:_files -/' \
  '(-p --prompt)'{-p,--prompt}'[prompt for search terms (search command only)]' \
  '(-r --remove-dups)'{-r,--remove-dups}'[remove duplicate Message-IDs from results]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'notmuch-mutt command' commands && ret=0 ;;
esac
return ret
