#compdef cargo-tree

# Zsh completion for cargo tree

_arguments -s -S \
  '(-p --package)'{-p+,--package=}'[package to display tree for]:package:' \
  '--workspace[display tree for all workspace members]' \
  '--exclude=[exclude specific packages]:package:' \
  '--all-features[activate all available features]' \
  '--features=[space or comma separated list of features]:features:' \
  '--no-default-features[do not activate default feature]' \
  '--target=[filter dependencies for target triple]:target triple:' \
  '(-i --invert)'{-i+,--invert=}'[invert the tree direction and focus on given package]:package:' \
  '--prune=[prune the given package from display]:package:' \
  '--depth=[maximum display depth of the dependency tree]:depth:' \
  '--no-dedupe[do not de-duplicate repeated dependencies]' \
  '(-d --duplicates)'{-d,--duplicates}'[show only packages with multiple versions]' \
  '(-e --edges)'{-e+,--edges=}'[kinds of dependencies to display]:kinds:(features normal build dev all no-normal no-build no-dev no-proc-macro)' \
  '--prefix=[change the prefix for each line]:prefix:(depth indent none)' \
  '--no-proc-macro[do not include proc-macro dependencies]' \
  '(-f --format)'{-f+,--format=}'[format string for each package]:format:' \
  '--charset=[character set for tree display]:charset:(utf8 ascii)' \
  '--manifest-path=[path to Cargo.toml]:manifest path:_files -g "*.toml"' \
  '(-v --verbose)'{-v,--verbose}'[use verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[do not print cargo log messages]' \
  '--color=[coloring]:when:(auto always never)' \
  '--frozen[require Cargo.lock and cache are up to date]' \
  '--locked[require Cargo.lock is up to date]' \
  '--offline[run without accessing the network]' \
  '(-h --help)'{-h,--help}'[show help]'
