#compdef testdisk
# Documentation: https://man.archlinux.org/search?q=testdisk
# Reference accessed: 2026-05-16

# Zsh completion for testdisk - data recovery tool

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '/log[create a testdisk.log file]' \
  '/debug[add debug info to log]' \
  '/nolog[do not create a log file]' \
  '/cmd=[run command line]:device commands:' \
  '/list[display current partition table]' \
  '/all[try to recover all partitions]' \
  '*:disk device:_files -g "/dev/*"'
