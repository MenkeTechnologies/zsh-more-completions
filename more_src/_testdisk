#compdef testdisk testdisk_static
# Documentation: https://www.cgsecurity.org/testdisk_doc/
# Reference accessed: 2026-05-17
# Verified: cgsecurity/testdisk upstream documentation. Uses legacy
# /option syntax (DOS-port heritage); no GNU --long flags. Real
# switches: /debug, /log, /nolog, /cmd, /list, /all.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --help/--version (testdisk has no GNU-style help/
# version flags).

# Zsh completion for testdisk - data recovery tool

_arguments -s -S \
  '/log[create a testdisk.log file]' \
  '/debug[add debug info to log]' \
  '/nolog[do not create a log file]' \
  '/cmd[run scripted command on device]' \
  '/list[display current partition table]' \
  '/all[try to recover all partitions]' \
  '*:disk device:_files -g "/dev/*"'
