#compdef udp2raw

_arguments -s \
  '-c[run as client]' \
  '-s[run as server]' \
  '-l=[local listen ip\:port]:host\:port:' \
  '-r=[remote ip\:port]:host\:port:' \
  '(-k --key)'{-k,--key}'=[password]:pw:' \
  '--raw-mode=[raw mode]:mode:(faketcp udp icmp)' \
  '--cipher-mode=[cipher]:cipher:(aes128cbc xor none)' \
  '--auth-mode=[auth]:auth:(hmac_sha1 md5 crc32 simple none)' \
  '(-a --auto-rule)'{-a,--auto-rule}'[auto iptables]' \
  '(-g --gen-rule)'{-g,--gen-rule}'[print iptables rule]' \
  '--disable-anti-replay[disable anti-replay]' \
  '--source-ip=[source IP]:ip:' \
  '--source-port=[source port]:port:' \
  '--conf-file=[config file]:file:_files' \
  '--fifo=[named pipe]:file:_files' \
  '--log-level=[log level]:level:(0 1 2 3 4 5 6)' \
  '--log-position[log file:line]' \
  '--disable-color[no color]' \
  '--disable-bpf[disable BPF]' \
  '--sock-buf=[buffer KB]:n:' \
  '--force-sock-buf[bypass sysctl limit]' \
  '--seq-mode=[seq mode]:mode:(0 1 2 3 4)' \
  '--lower-level=[lower level]:value:' \
  '--gen-add[gen and add iptables]' \
  '--keep-rule[keep iptables rule]' \
  '--clear[clear iptables]' \
  '(- *)'{-h,--help}'[show help]'
