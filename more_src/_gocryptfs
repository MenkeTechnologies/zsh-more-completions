#compdef gocryptfs

# Zsh completion for gocryptfs - encrypted overlay filesystem

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-aessiv[use AES-SIV encryption (for reverse mode)]' \
  '-allow_other[allow other users to access the mount]' \
  '-badname=[replace invalid filenames]:pattern' \
  '-config=[path to configuration file]:config file:_files' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-ctlsock=[create control socket]:socket path:_files' \
  '-d[enable debug output (implies -fg)]' \
  '-debug[enable debug output (implies -fg)]' \
  '-devrandom[use /dev/random for generating master key]' \
  '-e[alias for -exclude]:pattern' \
  '-exclude=[exclude pattern from reverse view]:pattern' \
  '-exec[allow program execution from the filesystem]' \
  '-extpass=[use external program for password entry]:command' \
  '-fg[stay in the foreground]' \
  '-force_owner=[override file ownership]:uid:gid' \
  '-forcedecode[force decoding of encrypted files even if integrity check fails]' \
  '-fsck[check filesystem for corruption]' \
  '-fsname=[set filesystem name in /etc/mtab]:name' \
  '-fusedebug[enable FUSE debug output]' \
  '-hkdf[use HKDF to derive sub-keys]' \
  '-i=[alias for -idle]:duration' \
  '-idle=[auto-unmount after specified idle time]:duration' \
  '-info[display filesystem information]' \
  '-init[initialize encrypted directory]' \
  '-ko=[pass additional options to the kernel]:options' \
  '-longnamemax=[hash filenames longer than this value]:length' \
  '-masterkey=[mount with explicit master key]:key' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-nodev[ignore device special files]' \
  '-noexec[disallow program execution]' \
  '-nofail[do not fail if mount fails]' \
  '-nonempty[allow mounting over non-empty directories]' \
  '-noprealloc[disable preallocation]' \
  '-nosuid[ignore suid/sgid bits]' \
  '-nosyslog[do not redirect output to syslog]' \
  '-notifypid=[send USR1 to PID after mount]:PID' \
  '-o=[pass mount options]:options' \
  '-one-file-system[do not cross filesystem boundaries]' \
  '-openssl=[use OpenSSL crypto backend]:enabled:(true false auto)' \
  '-passwd[change password]' \
  '-plaintextnames[do not encrypt file names]' \
  '-q[quiet mode - minimal output]' \
  '-quiet[quiet mode - minimal output]' \
  '-raw64[use raw base64 encoding for file names]' \
  '-reverse[reverse mode - encrypt plaintext directory]' \
  '-ro[mount read-only]' \
  '-rw[mount read-write (default)]' \
  '-scryptn=[set scrypt cost parameter N]:N' \
  '-serialize_reads[serialize read operations]' \
  '-sharedstorage[enable shared storage mode]' \
  '-speed[run crypto speed test]' \
  '-suid[allow suid/sgid bits to take effect]' \
  '-trace=[write execution trace to file]:file:_files' \
  '-v[display version and exit]' \
  '-version[display version and exit]' \
  '-wpanic[crash on warnings (for debugging)]' \
  '-xchacha[use XChaCha20-Poly1305 encryption]' \
  '-zerokey[use all-zero dummy master key (for debugging)]' \
  '1:cipher directory:_files -/' \
  '2:mount point:_files -/' && ret=0

return ret
