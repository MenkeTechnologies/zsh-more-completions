#compdef tootctl

# Zsh completion for tootctl - Mastodon administration CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'accounts:manage accounts'
  'cache:manage the cache'
  'domains:manage domains'
  'email-domain-blocks:manage e-mail domain blocks'
  'emoji:manage custom emoji'
  'feeds:manage home timeline feeds'
  'ip-blocks:manage IP blocks'
  'maintenance:various maintenance utilities'
  'media:manage media files'
  'preview-cards:manage preview cards'
  'search:manage the search engine'
  'settings:manage dynamic settings'
  'statuses:manage statuses'
  'upgrade:execute upgrade tasks'
  'version:show Mastodon version'
  'self-destruct:remove all data from this Mastodon instance'
)

local -a accounts_subcommands=(
  'approve:approve pending accounts'
  'backup:request a backup for an account'
  'create:create a new user'
  'cull:remove remote accounts that no longer exist'
  'delete:delete a user'
  'follow:make all local accounts follow an account'
  'merge:merge two remote accounts into one'
  'modify:modify a user'
  'refresh:refresh remote user data and files'
  'reject:reject pending accounts'
  'rotate:generate and broadcast new keys'
  'unfollow:make all local accounts unfollow an account'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tootctl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (accounts)
        _arguments '1:subcommand:->subcmd' && ret=0
        case $state in
          (subcmd) _describe -t sub 'accounts subcommand' accounts_subcommands && ret=0 ;;
        esac
        ;;
      (media)
        _arguments '1:subcommand:(lookup refresh remove remove-orphans usage)' && ret=0
        ;;
      (cache)
        _arguments '1:subcommand:(clear recount)' && ret=0
        ;;
      (domains)
        _arguments '1:subcommand:(crawl purge)' && ret=0
        ;;
      (emoji)
        _arguments '1:subcommand:(export import purge)' && ret=0
        ;;
      (feeds)
        _arguments '1:subcommand:(build clear)' && ret=0
        ;;
      (search)
        _arguments '1:subcommand:(deploy)' && ret=0
        ;;
      (statuses)
        _arguments '1:subcommand:(cull remove)' && ret=0
        ;;
    esac
    ;;
esac

return ret
