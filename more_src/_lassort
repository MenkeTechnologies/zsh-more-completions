#compdef lassort
# LAStools: sort points of a LAS/LAZ file by various criteria

local ret=1

_arguments -s -S \
  '-help[display help]' \
  '-version[report tool version]' \
  '-gui[launch with GUI]' \
  '-demo[run in demo mode]' \
  '(-v -verbose)'{-v,-verbose}'[enable verbose output]' \
  '-vv[very verbose output]' \
  '-gps_time[sort by GPS timestamps]' \
  '-point_source[sort by point source ID (flightline)]' \
  '-return_number[sort by return number]' \
  '-scanner[sort by scanner channel]' \
  '-user_data[sort by user data field]' \
  '-bucket_size+[resolution of quad tree cells (default 1)]:size' \
  '-levels+[subtiling levels for tiled files]:n' \
  '-average+[coarsen until average points per cell match]:n' \
  '-extra_pass[extra read pass to count points]' \
  '*-i+[input file(s)]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-merged[merge input files]' \
  '-olas[output as uncompressed LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
