#compdef lasoverage
# Documentation: https://github.com/LAStools/LAStools
# LAStools: find and flag/remove overage points in overlapping flightlines

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-version[display tool version]' \
  '-gui[launch with GUI]' \
  '-demo[run in demo mode]' \
  '(-v -verbose)'{-v,-verbose}'[enable verbose output]' \
  '-step+[grid resolution in meters (default 1)]:meters' \
  '-classify_as+[assign overage points to class (default 12)]:code' \
  '-entire_overlap[process entire overlap instead of just overage]' \
  '-flag_as_overlap[mark overage with overlap flag (LAS 1.4+)]' \
  '-flag_as_withheld[mark overage with withheld flag]' \
  '-remove_overage[delete overage points from output]' \
  '-recover_flightlines[reconstruct flightline info from GPS gaps]' \
  '-recover_flightlines_interval+[recover flightlines using n-second gaps]:seconds' \
  '-files_are_flightlines[treat each input file as separate flightline]' \
  '-feet[interpret coordinates in feet]' \
  '*-i+[input file or wildcard]:input:_files -g "*.(las|laz|LAS|LAZ)"' \
  '-o+[output file]:output:_files' \
  '-odir+[output directory]:dir:_files -/' \
  '-odix+[output filename suffix]:suffix' \
  '-olas[output as LAS]' \
  '-olaz[output as compressed LAZ]' \
  '-cores+[process on n parallel cores]:n' \
  '*:file:_files -g "*.(las|laz|LAS|LAZ)"' && ret=0

return ret
