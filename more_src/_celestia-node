#compdef celestia-node
# Documentation: https://man.archlinux.org/search?q=celestia-node
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--keyring.backend=[Keyring backend]:backend:(test file os kwallet pass)' \
  '--node.store=[Node store root directory]:directory:_directories' \
  '--core.ip=[Remote core endpoint]:host:' \
  '--core.grpc.port=[Remote core gRPC port]:port:' \
  '--rpc.port=[Node JSON-RPC port]:port:' \
  '--gateway.port=[Gateway listen port]:port:' \
  '--p2p.network=[Bootstrap network id]:network:' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'bridge:Run a bridge node'
      'full:Run a full storage node'
      'light:Run a light node'
      'docgen:Dump CLI documentation'
      'version:Print release metadata'
      'config:Manipulate config.toml'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
