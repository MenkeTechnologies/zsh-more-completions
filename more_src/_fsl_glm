#compdef fsl_glm
# Documentation: https://git.fmrib.ox.ac.uk/fsl/melodic/-/blob/master/fsl_glm.cc
# fsl_glm - general linear model fitting on time series or images

local ret=1

_arguments -s -S \
  '(-i --in)'{-i,--in}'[input file (matrix or 3D/4D image)]:file:_files' \
  '(-d --design)'{-d,--design}'[GLM design matrix (time courses or image)]:file:_files' \
  '(-c --contrasts)'{-c,--contrasts}'[matrix of t-statistics contrasts]:file:_files' \
  '(-f --ftests)'{-f,--ftests}'[matrix of F-tests on contrasts]:file:_files' \
  '(-o --out)'{-o,--out}'[output file name for GLM parameter estimates]:file:_files' \
  '(-m --mask)'{-m,--mask}'[mask image for spatial regression]:file:_files' \
  '--dof=[set degrees of freedom explicitly]:dof:' \
  '--des_norm[switch on normalisation of design matrix columns]' \
  '--dat_norm[switch on normalisation of data time series]' \
  '--vn[perform MELODIC variance normalisation on data]' \
  '--demean[switch on demeaning of design and data]' \
  '--out_cope[output COPEs (contrasts of parameter estimates)]:file:_files' \
  '--out_z[output Z-stats]:file:_files' \
  '--out_t[output t-stats]:file:_files' \
  '--out_p[output uncorrected p-values for t/F-stats]:file:_files' \
  '--out_f[output F-stats]:file:_files' \
  '--out_pf[output p-value for full model fit]:file:_files' \
  '--out_res[output residuals]:file:_files' \
  '--out_varcb[output variance of COPEs]:file:_files' \
  '--out_sigsq[output residual noise variance sigma-square]:file:_files' \
  '--out_data[output pre-processed data]:file:_files' \
  '--out_vnscales[output scaling factors for variance normalisation]:file:_files' \
  '--debug[switch on debugging output]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
