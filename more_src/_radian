#compdef radian
# Documentation: https://github.com/randy3k/radian
# Reference accessed: 2026-05-27
# Verified: upstream radian/app.py optparse parser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '--r-binary=[path to the R binary radian should launch]:file:_files -g "*"' \
  '--profile=[path to a custom .radian_profile]:file:_files' \
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[suppress R startup messages]' \
  '--no-environ[skip site and user environment files]' \
  '--no-site-file[skip the site-wide Rprofile]' \
  '--no-init-file[skip the user R profile]' \
  '--local-history[force per-directory history file]' \
  '--global-history[force global history file]' \
  '--no-history[disable history loading and saving]' \
  '--vanilla[combine --no-save --no-restore --no-site-file --no-init-file --no-environ]' \
  '--save[save workspace on exit]' \
  '--ask-save[prompt before saving workspace]' \
  '--restore-data[restore previously saved objects]' \
  '--debug[enable radian debug mode]' \
  '--no-save[do not save workspace on exit]' \
  '--no-restore-data[do not restore saved objects]' \
  '--no-restore-history[do not restore history]' \
  '--no-restore[do not restore anything]' \
  '--no-readline[disable readline-style line editing]' \
  '--interactive[force interactive() to return TRUE]' \
  '*:file:_files' && ret=0

return ret
