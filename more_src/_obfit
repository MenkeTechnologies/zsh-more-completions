#compdef obfit
# obfit — superimpose/align molecular structures by SMARTS pattern

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  ':SMARTS pattern for alignment:' \
  ':reference file:_files -g "*.{sdf,mol,mol2,pdb,xyz,smi,cml}"' \
  ':target file:_files -g "*.{sdf,mol,mol2,pdb,xyz,smi,cml}"'
