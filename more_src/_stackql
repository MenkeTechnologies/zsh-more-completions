#compdef stackql

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[Show help]' \
  '(- *)--version[Show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a subcmds
    subcmds=(
      'exec:Execute a StackQL query'
      'shell:Start an interactive shell'
      'registry:Manage provider registries'
    )
    _describe -t commands 'stackql subcommand' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      exec)
        _arguments -s -S \
          '--infile[Input SQL file]:file:_files -g "*.sql"' \
          '--outfile[Output file]:file:_files' \
          '--output[Output format]:format:(json table csv text)' \
          '--delimiter[CSV delimiter]:delimiter:' \
          '--hideheaders[Hide column headers]' \
          '--auth[Authentication config file]:file:_files' \
          '--tls.insecure[Disable TLS verification]' \
          '--help[Show help]' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '--auth[Authentication config file]:file:_files' \
          '--tls.insecure[Disable TLS verification]' \
          '--output[Output format]:format:(json table csv text)' \
          '--colorscheme[Color scheme]:scheme:' \
          '--help[Show help]' && ret=0
        ;;
      registry)
        _arguments -s -S -C \
          '1: :->regcmd' \
          '*:: :->regargs' && ret=0
        case $state in
          regcmd)
            local -a reg_subcmds
            reg_subcmds=(
              'pull:Pull a provider from the registry'
              'list:List available providers'
            )
            _describe -t commands 'registry subcommand' reg_subcmds && ret=0
            ;;
          regargs)
            _arguments -s -S \
              '--help[Show help]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
