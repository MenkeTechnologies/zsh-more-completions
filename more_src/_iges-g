#compdef iges-g
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=iges-g&sektion=1
# BRL-CAD IGES to geometry database converter

local ret=1

_arguments -s \
  '-N[name single solid created with -n or -t]:name' \
  '-n[combine all rational B-spline surfaces into one spline solid]' \
  '-d[convert IGES drawings to 2D NMG objects]' \
  '-3[like -d but retain 3D form]' \
  '-t[convert all trimmed surfaces to single NMG solid]' \
  '-p[convert BREP objects to NMG solids (default BOT)]' \
  '-x[librt debug flag]:flag' \
  '-X[NMG debug flag]:flag' \
  '-o[output BRL-CAD database]:output:_files -g "*.g"' \
  '*:input.iges:_files' && ret=0

return ret
