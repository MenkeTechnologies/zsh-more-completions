#compdef gomodifytags

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-file[file to modify]:file:_files -g "*.go"' \
  '-struct[struct name to modify]:struct name:' \
  '-field[field name to modify (requires -struct)]:field name:' \
  '-line[line number or range (e.g. 5 or 5,8)]:line range:' \
  '-offset[byte offset of the cursor position]:byte offset:' \
  '-all[select all structs in the file]' \
  '-add-tags[comma-separated list of tag keys to add]:tag keys:' \
  '-remove-tags[comma-separated list of tag keys to remove]:tag keys:' \
  '-add-options[comma-separated list of tag options to add]:tag options:' \
  '-remove-options[comma-separated list of tag options to remove]:tag options:' \
  '-clear-tags[clear all tags]' \
  '-clear-options[clear all tag options]' \
  '-transform[transform tag name]:transform type:(snakecase camelcase lispcase pascalcase keep)' \
  '-sort[sort tags by key]' \
  '-override[override existing tag values]' \
  '-skip-unexported[skip unexported fields]' \
  '-template[tag value template]:template:' \
  '-format[output format]:format:(source json)' \
  '-modified[read modified file content from stdin]' \
  '-quiet[suppress output]' \
  '-w[write result to source file]' \
  '(- *)--help[show help]' && ret=0

return ret
