#compdef riscv64-linux-as riscv64-linux-gnu-as riscv64-unknown-linux-gnu-as riscv64-unknown-elf-as
# _riscv64-linux-as — GNU binutils riscv64-linux-as CLI cross-arch GAS assembler for RV64GC RV64GCV little-endian Linux SiFive U54 U74 Allwinner D1 StarFive VisionFive HiFive producing ELF64 object files supporting compressed C extension Zfh Zfinx Zba Zbb Zbc Zbs V vector extensions march mabi (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_riscv64-linux-as() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-J[no warnings about signed overflow]' \
        '-K[allow modify .word section]' \
        '-W[suppress warnings]' \
        '--no-warn[suppress warnings]' \
        '--fatal-warnings[treat warnings as errors]' \
        '--warn[issue warnings]' \
        '-Z[generate object file even after errors]' \
        '-I+[include path]:dir:_files -/' \
        '-L[keep local symbols]' \
        '--keep-locals[keep local symbols]' \
        '-o+[output object]:file:_files -g "*.o *.elf"' \
        '-R[fold data section into text section]' \
        '--statistics[print statistics]' \
        '-g[generate debug info]' \
        '--gen-debug[generate debug info]' \
        '--gstabs[generate stabs debug]' \
        '--gdwarf-2[generate DWARF2]' \
        '--gdwarf-3[generate DWARF3]' \
        '--gdwarf-4[generate DWARF4]' \
        '--gdwarf-5[generate DWARF5]' \
        '-march=+[arch]:a:(rv64gc rv64imac rv64imafdc rv64imafdcv rv32gc rv32imac rv32imafdc rv32e rv32em rv64g rv64imafc)' \
        '-mabi=+[abi]:a:(ilp32 ilp32f ilp32d ilp32e lp64 lp64f lp64d)' \
        '-mno-arch-attr[no arch attributes]' \
        '-march-attr[add arch attributes]' \
        '-mrelax[enable relaxation]' \
        '-mno-relax[disable relaxation]' \
        '-mcheck-constraints[check ISA constraints]' \
        '-mno-csr-check[no CSR validity check]' \
        '-mcsr-check[CSR validity check]' \
        '-mlittle-endian[little endian]' \
        '-mbig-endian[big endian]' \
        '-EL[little endian]' \
        '-EB[big endian]' \
        '*:assembly file:_files -g "*.s *.S *.asm"'
}

_riscv64-linux-as "$@"
