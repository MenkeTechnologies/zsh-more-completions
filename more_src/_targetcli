#compdef targetcli

# targetcli: Linux LIO SCSI target shell (kernel target_core_mod)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-b[batch mode (read commands from arg)]:command:' \
  '--batch[batch mode]:command:' \
  '-c[read config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '*::targetcli command path:_files' && ret=0
return ret
