#compdef vcfkeepinfo
# Documentation: https://github.com/vcflib/vcflib/blob/master/doc/vcfkeepinfo.md
# Keep only the named INFO fields in a VCF, stripping the rest

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:VCF file:_files -g "*.(vcf|vcf.gz)"' && ret=0

return ret
