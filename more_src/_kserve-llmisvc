#compdef kserve-llmisvc
# _kserve-llmisvc — KServe LLMInferenceService controller (kserve/kserve)
# upstream: https://github.com/kserve/kserve
# Flags from cmd/llmisvc/main.go + controller-runtime zap.Options on tip.

_kserve-llmisvc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--metrics-secure=[serve metrics over HTTPS]:bool:(true false)' \
        '--webhook-port=[webhook server port]:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--health-probe-addr=[health probe bind address]:host\:port:' \
        '--enable-http2=[allow HTTP/2 on metrics/webhook]:bool:(true false)' \
        '--storage-migration-timeout=[storage-version migration total retry budget]:dur:' \
        '--storage-migration-poll-interval=[post-backoff migration poll interval]:dur:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kserve-llmisvc "$@"
