#compdef veusz
# Documentation: https://veusz.github.io/docs/veusz.man.txt
# veusz - scientific plotting and graphing application

local ret=1

_arguments -s \
  '--help[display the options to the program and exit]' \
  '--version[display version information and exit]' \
  '--unsafe-mode[do not check opened scripts for unsafe Python commands]' \
  '--listen[read Veusz commands from stdin, execute them, write results to stdout]' \
  '--quiet[in listening mode, do not open a window; execute commands quietly]' \
  '--export=[export the next document to the given graphics file]:file:_files' \
  '--export-option=[set an export option (dpi, color, page, antialias, quality, backcolor, pdfdpi, svgtextastext)]:option' \
  '--plugin=[load the Veusz plugin FILE when starting]:file:_files' \
  '*:document:_files -g "*.vsz"' && ret=0

return ret
