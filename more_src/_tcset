#compdef tcset
# Documentation: https://man.archlinux.org/search?q=tcset
# Reference accessed: 2026-05-16

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tc-command[show tc commands]' \
  '--tc-script[generate tc script]' \
  '--debug[debug output]' \
  '--quiet[quiet]' \
  '--import-setting[import setting]' \
  '--overwrite[overwrite existing]' \
  '--change[change existing rules]' \
  '--add[add rules]' \
  '--debug-query[debug DB query]' \
  '--stacktrace[show stacktrace]' \
  '--rate=[rate]:rate:' \
  '--bandwidth-rate=[bandwidth rate]:rate:' \
  '--delay=[delay]:duration:' \
  '--delay-distro=[delay distribution]:n:' \
  '--delay-distribution=[distribution]:dist:(normal pareto paretonormal)' \
  '--loss=[packet loss]:percent:' \
  '--duplicate=[duplication]:percent:' \
  '--corrupt=[corruption]:percent:' \
  '--reordering=[reordering]:percent:' \
  '--limit=[queue limit]:n:' \
  '--shaping-algo=[algorithm]:algo:(htb tbf)' \
  '--iptables[use iptables]' \
  '--mtu=[MTU]:n:' \
  '--burst=[burst]:size:' \
  '--direction=[direction]:dir:(outgoing incoming)' \
  '--network=[network]:cidr:' \
  '--dst-network=[dest network]:cidr:' \
  '--src-network=[source network]:cidr:' \
  '--port=[port]:port:' \
  '--dst-port=[dest port]:port:' \
  '--src-port=[source port]:port:' \
  '--ipv6[IPv6 mode]' \
  '--exclude-dst-network=[exclude dest network]:cidr:' \
  '--exclude-src-network=[exclude source network]:cidr:' \
  '--exclude-dst-port=[exclude dest port]:port:' \
  '--exclude-src-port=[exclude source port]:port:' \
  '--docker[Docker mode]' \
  '--src-container=[source container]:container:' \
  '--dst-container=[dest container]:container:' \
  ':device:_net_interfaces'
