#compdef tcset
# Documentation: https://tcconfig.readthedocs.io/en/latest/pages/usage/tcset/index.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--tc-command[display tc commands without executing]' \
  '--tc-script[generate executable shell script]' \
  '--debug[enable debug output]' \
  '--quiet[suppress execution logs]' \
  '--debug-query[debug query printing]' \
  '--stacktrace[print stack trace]' \
  '--import-setting[import settings from config file]' \
  '--overwrite[overwrite existing rules]' \
  '--change[change existing rules]' \
  '--add[add rule alongside existing ones]' \
  '--rate=[bandwidth rate]:rate:' \
  '--bandwidth-rate=[bandwidth rate]:rate:' \
  '--delay=[network latency]:duration:' \
  '--delay-distro=[latency distribution variance]:n:' \
  '--delay-distribution=[distribution type]:dist:(normal pareto paretonormal)' \
  '--loss=[packet loss rate]:percent:' \
  '--duplicate=[packet duplication rate]:percent:' \
  '--corrupt=[corruption rate]:percent:' \
  '--reordering=[reordering rate]:percent:' \
  '--limit=[max queued packets]:n:' \
  '--shaping-algo=[shaping algorithm]:algo:(htb tbf)' \
  '--iptables[use iptables]' \
  '--mtu=[MTU size]:n:' \
  '--burst=[HTB burst size]:size:' \
  '--direction=[traffic direction]:dir:(outgoing incoming)' \
  '--network=[destination IP/network]:cidr:' \
  '--dst-network=[destination network]:cidr:' \
  '--src-network=[source network]:cidr:' \
  '--port=[destination port]:port:' \
  '--dst-port=[destination port]:port:' \
  '--src-port=[source port]:port:' \
  '--ipv6[IPv6 mode]' \
  '--exclude-dst-network=[exclude destination network]:cidr:' \
  '--exclude-src-network=[exclude source network]:cidr:' \
  '--exclude-dst-port=[exclude destination port]:port:' \
  '--exclude-src-port=[exclude source port]:port:' \
  '--docker[target Docker container]' \
  '--src-container=[source container]:container:' \
  '--dst-container=[destination container]:container:' \
  ':device:_net_interfaces'
