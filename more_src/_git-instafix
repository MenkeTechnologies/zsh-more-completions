#compdef git-instafix
# Documentation: https://github.com/quodlibetor/git-instafix
# git instafix — fix an old commit in your history with your currently-staged changes.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-m --max-commits)'{-m+,--max-commits=}'[max commits to show when finding merge point]:count:' \
  '(-P --commit-message-pattern)'{-P+,--commit-message-pattern=}'[amend a commit by its subject-line pattern]:pattern:' \
  '(-u --default-upstream-branch)'{-u+,--default-upstream-branch=}'[branch to not go past when finding merge point]:branch:__git_branch_names' \
  '--require-newline=[require a newline when confirming y/n questions]:bool:(true false)' \
  '--help-themes[show the possible color themes for output]' \
  '--theme=[use this syntax-highlighting theme]:theme:' && ret=0

return ret
