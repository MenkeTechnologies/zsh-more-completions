#compdef s6-permafailon
# Documentation: source-direct extraction from upstream skarnet/s6
# src/supervision/s6-permafailon.c USAGE string. No subgetopt; pure
# positional-argument tool.
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 permafailon R123c — service-death-rate auto-disabler.
# Designed to be placed in a servicedir's finish script. If the
# service has died `deathcount` times within `seconds` seconds with
# any of the exit statuses in `statuslist`, s6-permafailon triggers
# a permafailure (the service is brought down permanently and not
# restarted) by chain-loading prog.

_arguments -s -S \
  '1:rolling window in seconds:' \
  '2:death count threshold:' \
  '3:comma-separated list of fatal exit statuses:' \
  '*:program and arguments:_command_names -e'
