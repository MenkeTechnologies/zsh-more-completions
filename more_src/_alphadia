#compdef alphadia
# Documentation: https://alphadia.readthedocs.io/en/latest/methods/command-line.html
# alphaDIA: modular open-source DIA proteomics search engine

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '(-o --output)'{-o,--output}'[output directory]:dir:_files -/' \
  '*'{-f,--file}'[raw data input file]:file:_files' \
  '(-d --directory)'{-d,--directory}'[directory containing raw data input files]:dir:_files -/' \
  '(-r --regex)'{-r,--regex}'[regex to match raw files in directory]:regex:' \
  '(-l --library)'{-l,--library}'[spectral library]:file:_files' \
  '--fasta[fasta file(s) to generate or annotate the library]:file:_files' \
  '(-c --config)'{-c,--config}'[config yaml to update the default config]:file:_files' \
  '--config-dict[Python dict to update the default config]:dict:' \
  '--quant-dir[directory containing quantification results]:dir:_files -/' \
  '--check[verify installation and version]' && ret=0

return ret
