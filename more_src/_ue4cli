#compdef ue4 ue4cli

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help'
  'setroot:set engine root'
  'clearroot:clear engine root'
  'clearcache:clear cached values'
  'root:print engine root'
  'version:print engine version'
  'editor:run the editor'
  'build-target:build a specific target'
  'run:run the project'
  'gen:generate project files'
  'build:build the project'
  'clean:clean the project'
  'test:run automation tests'
  'package:package the project'
  'libs:list third-party libraries'
  'cxxflags:print C++ flags'
  'ldflags:print linker flags'
  'cmakeflags:print CMake flags'
  'includedirs:print include dirs'
  'libfiles:print library files'
  'defines:print preprocessor defines'
  'uat:run the Unreal Automation Tool'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ue4cli subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (version)
        _values 'format' major minor patch full short && ret=0
        ;;
      (run)
        _arguments '--debug[debug mode]' '*:arg: ' && ret=0
        ;;
      (test)
        _arguments \
          '--withrhi[run RHI tests]' \
          '--list[list tests]' \
          '--all[run all tests]' \
          '--filter=[filter pattern]:filter:' \
          '*:test: ' && ret=0
        ;;
      (cxxflags|cmakeflags|includedirs|libfiles|defines)
        _arguments \
          '--multiline[multi-line output]' \
          '--nodefaults[no defaults]' \
          '*:lib: ' && ret=0
        ;;
      (ldflags)
        _arguments \
          '--multiline[multi-line output]' \
          '--flagsonly[flags only]' \
          '--nodefaults[no defaults]' \
          '*:lib: ' && ret=0
        ;;
      (setroot)
        _arguments '1:engine root:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
