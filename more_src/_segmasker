#compdef segmasker
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK279684/
# BLAST+ tool to mask low-complexity regions of protein sequences (SEG)
# Flags from NCBI C++ Toolkit src/app/segmasker/segmasker.cpp

local ret=1

_arguments -s -S \
  '-h[show brief help]' \
  '-help[show detailed help]' \
  '-version[show version]' \
  '-in=[input file name]:file:_files' \
  '-out=[output file name]:file:_files' \
  '-infmt=[format of the masker input]:format:(fasta blastdb)' \
  '-outfmt=[format of the masker output]:format:(interval fasta maskinfo_asn1_bin maskinfo_asn1_text seqloc_asn1_bin seqloc_asn1_text)' \
  '-window=[SEG window]:int:' \
  '-locut=[SEG locut]:float:' \
  '-hicut=[SEG hicut]:float:' \
  '-parse_seqids[parse Seq-ids in FASTA input]' && ret=0

return ret
