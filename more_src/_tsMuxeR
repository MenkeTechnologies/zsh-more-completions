#compdef tsMuxeR tsmuxer
# Documentation: https://github.com/justdan96/tsMuxer/blob/master/docs/USAGE.md
# Transport stream muxer for remuxing/muxing elementary streams. Global MUXOPT flags from USAGE.md.

local ret=1

_arguments -s -S \
  '--pcr-on-video-pid[do not allocate a separate PID for PCR, use video PID]' \
  '--new-audio-pes[use byte 0xfd instead of 0xbd for AC3/True-HD/DTS]' \
  '--vbr[use variable bitrate]' \
  '--minbitrate=[lower limit of VBR bitrate]:bps:' \
  '--maxbitrate=[upper limit of VBR bitrate]:bps:' \
  '--cbr[muxing mode with a fixed bitrate]' \
  '--vbv-len=[length of the virtual buffer in milliseconds]:ms:' \
  '--no-asyncio[do not create a separate thread for writing]' \
  '--auto-chapters=[insert a chapter every <n> minutes]:minutes:' \
  '--custom-chapters=[semicolon delimited list of hh:mm:ss.zzz]:chapters:' \
  '--demux[demux mode: store selected audio and video tracks separately]' \
  '--blu-ray[mux as a BD disc]' \
  '--blu-ray-v3[mux to UHD BD discs]' \
  '--avchd[mux to AVCHD disc]' \
  '--cut-start=[trim the beginning of the file]:time:' \
  '--cut-end=[trim the end of the file]:time:' \
  '--split-duration=[split output into several files by duration]:seconds:' \
  '--split-size=[split output by maximum file size]:size:' \
  '--right-eye[use base video stream for right eye]' \
  '--start-time=[timestamp of the first video frame]:time:' \
  '--mplsOffset=[number of the first MPLS file]:n:' \
  '--m2tsOffset=[number of the first M2TS file]:n:' \
  '--insertBlankPL[add an additional short playlist]' \
  '--blankOffset=[blank playlist number]:n:' \
  '--label=[disk label when muxing to ISO]:label:' \
  '--extra-iso-space=[extra space in 64K units for ISO metadata]:n:' \
  '--constant-iso-hdr[generate an ISO header independent of program version]' \
  '*:file:_files' && ret=0

return ret
