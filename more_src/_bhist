#compdef bhist
# Documentation: https://www.ibm.com/docs/en/spectrum-lsf/10.1.0?topic=commands-bhist
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# bhist: show LSF job history
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-a[all jobs]' \
  '-d[done only]' \
  '-p[pending only]' \
  '-r[running only]' \
  '-s[suspended only]' \
  '-u[user]:user:_users' \
  '-q[queue]:queue:' \
  '-J[job name]:name:' \
  '-G[user group]:group:_groups' \
  '-D[show event details]' \
  '-w[wide format]' \
  '-l[long format]' \
  '-t[time range]:range:' \
  '-n[last N events]:n:' \
  '*:jobid:' && ret=0
return ret
