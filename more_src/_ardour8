#compdef ardour8 Ardour8
# Documentation: https://github.com/Ardour/ardour/blob/master/ardour.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --bypass-plugins)'{-b,--bypass-plugins}'[bypass plugins]' \
  '(-c --name)'{-c,--name}'+[session name]:name:' \
  '(-d --disable-plugins)'{-d,--disable-plugins}'[disable plugins]' \
  '(-D --debug)'{-D,--debug}'+[debug flags]:flags:' \
  '(-k --keybindings)'{-k,--keybindings}'+[keybindings]:file:_files' \
  '(-m --menus)'{-m,--menus}'+[menus]:file:_files' \
  '(-n --no-splash)'{-n,--no-splash}'[no splash]' \
  '(-N --new)'{-N,--new}'+[new session name]:name:' \
  '(-O --no-hw-optimizations)'{-O,--no-hw-optimizations}'[no hw opts]' \
  '(-P --no-connect-ports)'{-P,--no-connect-ports}'[no port connect]' \
  '(-S --sync)'{-S,--sync}'[start with sync]' \
  '(-T --template)'{-T,--template}'+[template]:tpl:' \
  '(-U --uuid)'{-U,--uuid}'+[uuid]:uuid:' \
  '*:session:_files -g "*.ardour"' && ret=0

return ret
