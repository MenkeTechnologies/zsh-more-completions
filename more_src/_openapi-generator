#compdef openapi-generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'generate:generate code from an OpenAPI spec'
      'validate:validate an OpenAPI spec'
      'list:list available generators'
      'config-help:show config options for a generator'
      'meta:create a new generator module'
      'batch:generate code in batch from configs'
      'author:utilities for authoring generators'
      'completion:generate shell completion script'
    )
    _describe -t commands 'openapi-generator command' commands
    ;;
  args)
    case $words[1] in
      generate)
        _arguments -s -S \
          '(-g --generator-name)'{-g,--generator-name}'[generator name]:generator' \
          '(-i --input-spec)'{-i,--input-spec}'[OpenAPI spec location]:spec:_files' \
          '(-o --output)'{-o,--output}'[output directory]:dir:_directories' \
          '(-c --config)'{-c,--config}'[config file]:config:_files' \
          '(-t --template-dir)'{-t,--template-dir}'[template directory]:dir:_directories' \
          '(-a --auth)'{-a,--auth}'[authorization header]:auth' \
          '--api-package[package for generated API classes]:package' \
          '--model-package[package for generated model classes]:package' \
          '--invoker-package[root package for generated code]:package' \
          '--group-id[groupId in pom.xml]:groupId' \
          '--artifact-id[artifactId in pom.xml]:artifactId' \
          '--artifact-version[artifact version in pom.xml]:version' \
          '--library[library template]:library' \
          '(-p --additional-properties)'{-p,--additional-properties}'[additional properties]:key=value' \
          '--type-mappings[type mappings]:mappings' \
          '--import-mappings[import mappings]:mappings' \
          '--instantiation-types[instantiation types]:types' \
          '--language-specific-primitives[language primitives]:primitives' \
          '--reserved-words-mappings[reserved words mappings]:mappings' \
          '--server-variables[server variable overrides]:variables' \
          '--git-host[git host]:host' \
          '--git-repo-id[git repo ID]:repo' \
          '--git-user-id[git user ID]:user' \
          '--release-note[release note]:note' \
          '--http-user-agent[HTTP user agent]:user-agent' \
          '--skip-validate-spec[skip spec validation]' \
          '--strict-spec[strict spec behavior]:strict:(true false)' \
          '--enable-post-process-file[enable post-processing]' \
          '--generate-alias-as-model[generate alias as model]' \
          '--minimal-update[only write changed files]' \
          '-s[skip file overwrite confirmation]' \
          '--skip-overwrite[skip file overwrite confirmation]' \
          '--dry-run[dry run, show files that would be generated]' \
          '-v[verbose output]' \
          '--verbose[verbose output]' && ret=0
        ;;
      validate)
        _arguments -s -S \
          '(-i --input-spec)'{-i,--input-spec}'[OpenAPI spec location]:spec:_files' \
          '--recommend[provide recommendations]' && ret=0
        ;;
      config-help)
        _arguments -s -S \
          '(-g --generator-name)'{-g,--generator-name}'[generator name]:generator' \
          '--named-header[header includes generator name]' \
          '--no-format[skip formatting]' \
          '-o[output file]:file:_files' \
          '--output[output file]:file:_files' \
          '--markdown-header[markdown header]' \
          '-f[output format]:format:(text markdown yamlsample)' \
          '--format[output format]:format:(text markdown yamlsample)' \
          '--full-details[show full details]' && ret=0
        ;;
      batch)
        _arguments -s -S \
          '--includes-base-dir[base directory for includes]:dir:_directories' \
          '--fail-fast[fail on first error]' \
          '--clean[clean output before generation]' \
          '-r[root directory for output]:dir:_directories' \
          '--root-dir[root directory for output]:dir:_directories' \
          '--threads-count[number of threads]:threads' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '*:config files:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret