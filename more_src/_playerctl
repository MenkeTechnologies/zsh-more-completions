#compdef playerctl

# Zsh completion for playerctl - MPRIS media player controller

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'play:command the player to play'
  'pause:command the player to pause'
  'play-pause:toggle between play and pause'
  'stop:command the player to stop'
  'next:skip to the next track'
  'previous:skip to the previous track'
  'position:print or set the playback position'
  'volume:print or set the volume'
  'status:get the play status'
  'metadata:print metadata information'
  'open:open a URI with the player'
  'loop:print or set the loop status'
  'shuffle:print or set the shuffle status'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[print version]' \
  '(-p --player)'{-p,--player}'[target player]:player:->players' \
  '(-i --ignore-player)'{-i,--ignore-player}'[ignore player]:player:->players' \
  '(-a --all-players)'{-a,--all-players}'[control all players]' \
  '(-f --format)'{-f,--format}'[format string for output]:format' \
  '(-F --follow)'{-F,--follow}'[block and output when properties change]' \
  '(-l --list-all)'{-l,--list-all}'[list all available players]' \
  '(-s --no-messages)'{-s,--no-messages}'[suppress diagnostic messages]' \
  '1:command:->command' \
  '*:argument' && ret=0

case $state in
  command)
    _describe -t commands 'playerctl command' commands && ret=0
    ;;
  players)
    local -a players
    players=(${(f)"$(playerctl --list-all 2>/dev/null)"})
    _describe -t players 'player' players && ret=0
    ;;
esac

return ret
