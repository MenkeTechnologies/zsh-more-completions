#compdef scil_dwi_extract_b0
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_dwi_extract_b0.html
# Scilpy: extract b0 volume(s) from a DWI

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--block-size -s)'{--block-size,-s}'=[block size for loading data]:size' \
  '--b0_threshold=[b0 threshold]:thr' \
  '--single-image[output a single b0 image]' \
  '--skip_b0_check[skip b0 existence validation]' \
  '(--all --mean --cluster-mean --cluster-first)--all[extract all b0 volumes]' \
  '(--all --mean --cluster-mean --cluster-first)--mean[extract mean of b0 volumes]' \
  '(--all --mean --cluster-mean --cluster-first)--cluster-mean[extract mean per cluster]' \
  '(--all --mean --cluster-mean --cluster-first)--cluster-first[extract first per cluster]' \
  '-f[force overwrite]' \
  '-v[verbosity level]::level:(DEBUG INFO WARNING ERROR)' \
  '1:in_dwi:_files' \
  '2:in_bval:_files' \
  '3:in_bvec:_files' \
  '4:out_b0:_files' && ret=0

return ret
