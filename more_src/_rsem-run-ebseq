#compdef rsem-run-ebseq
# Documentation: https://github.com/deweylab/RSEM/blob/master/README.md
# RSEM: call EBSeq to compute differential expression statistics

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--ngvector=[grouping info for isoform-level DE analysis]:ngvec file:_files -g "*.ngvec"' \
  '1:data matrix file:_files' \
  '2:conditions (comma-separated replicate counts):' \
  '3:output file:_files' && ret=0

return ret
