#compdef primersearch
# Documentation: https://man.archlinux.org/search?q=primersearch
# Reference accessed: 2026-05-16

# EMBOSS primersearch: search a DNA set with a primer pair file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[DNA sequence(s) to search]:DNA USA:_files' \
  '-infile=[primer pair input file]:file:_files' \
  '-mismatchpercent=[allowed primer mismatch percent]:pct:' \
  '-snucleotide[treat as nucleic acid sequence]' \
  '-sprotein[treat as protein sequence]' \
  '-outfile=[primer match report file]:file:_files' \
  '*:DNA USA:_files' && ret=0
return ret
