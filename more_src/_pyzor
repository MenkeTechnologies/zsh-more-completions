#compdef pyzor
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/pyzor.1.html
# spam-catcher client using a collaborative filtering network

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-d[enable debugging output]' \
  '--homedir=[Pyzor home directory]:dir:_files -/' \
  '--mbox[treat input as a unix mailbox]' \
  '1:command:(check report whitelist discover ping genkey digest predigest local_whitelist local_unwhitelist)' && ret=0

return ret
