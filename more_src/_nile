#compdef nile
# _nile — Nile multi-tenant Postgres CLI (niledatabase/cli)
# upstream: https://github.com/niledatabase/cli
# Subcommands from src/index.ts (commander).

_nile() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--no-color[disable colorized output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'connect:connect to Nile cloud'
                'workspace:manage Nile workspaces'
                'db:manage Nile databases'
                'tenants:manage tenants in the selected database'
                'config:set or read CLI config'
                'users:manage users'
                'local:manage local development environment'
                'auth:manage Nile auth integration'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                local) _arguments '1:sub:(start stop restart status logs)' ;;
                auth) _arguments '1:sub:(quickstart env login logout)' ;;
                db) _arguments '1:sub:(list create show delete connect)' ;;
                tenants) _arguments '1:sub:(list create show delete)' ;;
            esac
            ;;
    esac
}

_nile "$@"
