#compdef typeorm

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:generate initial TypeORM project structure'
  'migration\:create:create empty migration file'
  'migration\:generate:generate migration from entity changes'
  'migration\:run:run pending migrations'
  'migration\:revert:revert last migration'
  'migration\:show:show all migrations and their status'
  'entity\:create:create a new entity file'
  'subscriber\:create:create a new subscriber file'
  'schema\:sync:synchronize schema with database'
  'schema\:log:show SQL that schema sync would execute'
  'schema\:drop:drop all tables in database'
  'query:execute a SQL query'
  'cache\:clear:clear query result cache'
  'version:show TypeORM version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-d+[path to data source]:datasource file:_files' \
  '--dataSource=[path to data source]:datasource file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'typeorm command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (migration:create)
        _arguments \
          '-d+[path to data source]:datasource file:_files' \
          '--dataSource=[path to data source]:datasource file:_files' \
          '1:migration name' && ret=0
        ;;
      (migration:generate)
        _arguments \
          '-d+[path to data source]:datasource file:_files' \
          '--dataSource=[path to data source]:datasource file:_files' \
          '-p[pretty print generated SQL]' \
          '--pretty[pretty print generated SQL]' \
          '-o[output TypeORM 0.2 style migration]' \
          '1:migration name' && ret=0
        ;;
      (migration:run|migration:revert|migration:show)
        _arguments \
          '-d+[path to data source]:datasource file:_files' \
          '--dataSource=[path to data source]:datasource file:_files' \
          '-t[log queries to stdout]' \
          '--transaction=[transaction mode]:mode:(all none each)' && ret=0
        ;;
      (entity:create|subscriber:create)
        _arguments '1:name' && ret=0
        ;;
      (schema:sync|schema:log|schema:drop)
        _arguments \
          '-d+[path to data source]:datasource file:_files' \
          '--dataSource=[path to data source]:datasource file:_files' && ret=0
        ;;
      (query)
        _arguments \
          '-d+[path to data source]:datasource file:_files' \
          '--dataSource=[path to data source]:datasource file:_files' \
          '1:SQL query' && ret=0
        ;;
      (init)
        _arguments \
          '--name=[project name]:name' \
          '--database=[database type]:database:(mysql mariadb postgres cockroachdb sqlite better-sqlite3 mssql oracle mongodb)' \
          '--express[include Express setup]' \
          '--docker[include Docker setup]' && ret=0
        ;;
    esac
    ;;
esac

return ret
