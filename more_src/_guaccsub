#compdef guaccsub
# _guaccsub — GUAC collect-sub service (guacsec/guac)
# upstream: https://github.com/guacsec/guac
# Flags from cmd/guaccsub/cmd/root.go + pkg/cli/store.go (cobra).

_guaccsub() {
    local -a args
    args=(
        '--csub-listen-port=[port to listen on for the collect-sub service]:port:'
        '--csub-tls-cert-file=[TLS certificate (PEM)]:file:_files -g "*.pem"'
        '--csub-tls-key-file=[TLS key (PEM)]:file:_files -g "*.pem"'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
    )
    _arguments -s $args
}

_guaccsub "$@"
