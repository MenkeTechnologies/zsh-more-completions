#compdef pulumi-policy

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'disable:disable a policy'
  'enable:enable a policy'
  'group:policy group commands'
  'ls:list policies for an org'
  'new:create new policy pack project'
  'publish:publish a policy pack'
  'rm:remove a policy pack'
  'validate-config:validate a policy config'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--logflow[log flow]' \
  '*--logtostderr[log to stderr]' \
  '*--non-interactive[non-interactive]' \
  '*--profiling=[profile dir]:dir:_files -/' \
  '*--tracing=[tracing endpoint]:e:' \
  '*-v[verbose]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pulumi-policy command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (enable|disable)
        _arguments \
          '(--config)--config=[config file]:file:_files -g "*.json"' \
          '(--policy-version)--policy-version=[version]:v:' \
          '*: :' && ret=0 ;;
      (publish)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (new)
        _arguments \
          '(--dir)--dir=[output dir]:dir:_files -/' \
          '(--force)--force[force overwrite]' \
          '(--generate-only -g)'{-g,--generate-only}'[generate only]' \
          '(--name)--name=[name]:n:' \
          '(--description)--description=[description]:d:' \
          '*: :_files -/' && ret=0 ;;
      (group)
        _arguments \
          '1:subcommand:(ls)' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
