#compdef csv2rec
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-S --strict)'{-S,--strict}'[strict mode]' \
  '(-e --field-separator)'{-e,--field-separator=}'[field separator character]:separator' \
  '(-t --type)'{-t,--type=}'[record type name]:type name' \
  '(-d --delimiter)'{-d,--delimiter=}'[delimiter character]:delimiter' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:CSV file:_files -g "*.csv(-.)"' && ret=0
return ret
