#compdef charon charon-systemd charon-cmd
# _charon — strongSwan charon IKEv2 daemon and charon-cmd command-line variant for IKE SA establishment IPsec configuration EAP authentication TPM2 attestation and openssl-backed cryptography (strongswan team, C); getopt
# upstream: https://github.com/strongswan/strongswan

_charon() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[debug level]:n:(0 1 2 3 4)' \
        '--debug=+[level]:n:(0 1 2 3 4)' \
        '-d[no daemon]' \
        '--no-daemon[no daemon]' \
        '-f+[plugin to disable]:str:' \
        '--no-plugin=+[plugin]:str:' \
        '-i+[initiate connection]:str:' \
        '--initiate=+[connection]:str:' \
        '-c+[connection]:str:' \
        '--connection=+[connection]:str:' \
        '-n+[connection name]:str:' \
        '-p+[child SA policy]:str:' \
        '-l+[load CA cert]:file:_files -g "*.pem *.crt *.der"' \
        '--ca=+[CA cert]:file:_files -g "*.pem *.crt *.der"' \
        '-s+[secret type]:t:(psk rsa pubkey eap ike-psk)' \
        '-S+[secret value]:str:' \
        '-r+[remote identity]:str:' \
        '--remote=+[identity]:str:' \
        '-L+[local identity]:str:' \
        '--local=+[identity]:str:' \
        '-H+[host]:h:_hosts' \
        '--host=+[host]:h:_hosts' \
        '-P+[port]:n:' \
        '-A+[auth]:a:(psk pubkey eap-radius eap-md5 eap-mschapv2 eap-tls eap-ttls eap-peap eap-aka eap-sim eap-gtc eap-identity xauth-pam xauth-eap)' \
        '--proposals=+[csv proposals]:str:' \
        '--esp=+[csv proposals]:str:' \
        '--ike=+[csv proposals]:str:' \
        '--dh=+[dh group]:g:(modp1024 modp2048 modp3072 modp4096 modp6144 modp8192 ecp192 ecp224 ecp256 ecp384 ecp521 curve25519 curve448)' \
        '--reauth=+[seconds]:n:' \
        '--rekey=+[seconds]:n:' \
        '--lifetime=+[seconds]:n:' \
        '-u[trace usage]' \
        '--trace[trace usage]' \
        '--use-syslog[use syslog]' \
        '--logfile=+[file]:file:_files'
}

_charon "$@"
