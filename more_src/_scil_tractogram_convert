#compdef scil_tractogram_convert
# Documentation: https://scilpy.readthedocs.io/en/latest/scripts/scil_tractogram_convert.html
# Convert a tractogram between formats

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--legacy_vtk[apply the older VTK format, compatible with MI-Brain]' \
  '--no_bbox_check[skip validation of bounding box during loading/saving]' \
  '--reference=[reference anatomy for tck/vtk/fib/dpy]:nifti:_files -g "*.nii *.nii.gz"' \
  '-v+[verbose logging level]:level:(DEBUG INFO WARNING ERROR)' \
  '-f[overwrite existing output files without prompting]' \
  '1:in_tractogram:_files -g "*.trk *.tck *.vtk *.fib *.dpy"' \
  '2:output_name:_files -g "*.trk *.tck *.vtk *.fib *.dpy"' && ret=0

return ret
