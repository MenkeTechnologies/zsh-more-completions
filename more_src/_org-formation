#compdef org-formation
# Documentation: https://man.archlinux.org/search?q=org-formation
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:initialize org-formation working folder'
      'validate:validate organization template'
      'describe:print changes / stack info'
      'perform-tasks:execute tasks against accounts'
      'create-org-template:create organization template file'
      'print-stacks:emit CloudFormation templates'
      'update:update stacks from task file'
      'update-stacks:update stacks in org'
      'validate-tasks:validate tasks file'
      'completion:shell completion'
    )
    _describe -t commands 'org-formation command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '--organization-file=[path to template]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
