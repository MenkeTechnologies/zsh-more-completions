#compdef qemu-bridge-helper
# Documentation: https://man.archlinux.org/search?q=qemu-bridge-helper
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--use-vnet[use vnet header]' \
  '--br=+[bridge name]:bridge:' \
  '--fd=+[file descriptor]:fd:' && ret=0

return ret
