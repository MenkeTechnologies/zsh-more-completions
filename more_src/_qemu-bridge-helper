#compdef qemu-bridge-helper
# Documentation: https://github.com/qemu/qemu/blob/master/qemu-bridge-helper.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--use-vnet[use vnet header]' \
  '--br=+[bridge name]:bridge:' \
  '--fd=+[file descriptor]:fd:' && ret=0

return ret
