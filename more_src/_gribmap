#compdef gribmap
# Documentation: http://cola.gmu.edu/grads/gadoc/
# GrADS utility: build an index/map between a .ctl descriptor and GRIB data

local ret=1

_arguments -s -S \
  '-i[GrADS descriptor (.ctl) file]:ctl file:_files -g "*.ctl"' \
  '-v[verbose output]' \
  '-t0[base time map]' \
  '-0[use first record for reference time]' \
  '-e[examine GRIB records]' \
  '-u[update an existing descriptor/index file]' \
  '-new[upgrade metadata in the index file]' \
  '-old[downgrade the version of an index file]' \
  '*:ctl file:_files -g "*.ctl"' && ret=0

return ret
