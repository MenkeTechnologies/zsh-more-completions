#compdef xmlToSql
# UCSC kent: convert XML dump into a normalized relational database

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-prefix=[name to prefix all tables with]:name:' \
  '-textField=[name to use for text field]:name:' \
  '-maxPromoteSize=[max size of element promoted to a field]:n:' \
  ':in xml:_files -g "*.xml"' \
  ':in dtd:_files -g "*.dtd"' \
  ':in stats:_files' \
  ':out dir:_files -/' && ret=0

return ret
