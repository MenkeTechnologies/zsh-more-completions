#compdef rtabmap-console
# Documentation: https://github.com/introlab/rtabmap/blob/master/tools/ConsoleApp/main.cpp
# Run RTAB-Map on a dataset from the command line

local ret=1

_arguments -s -S \
  '(-h -help --help)'{-h,-help,--help}'[show help]' \
  '-quiet[do not show log for every image]' \
  '-rate[acquisition time in seconds]:sec' \
  '-rateHz[acquisition rate in Hz]:hz' \
  '-repeat[repeat the process on the data set n times]:n' \
  '-createGT[generate a ground truth file]' \
  '-gt[compute precision/recall with ground truth matrix]:path:_files' \
  '-start_at[start processing at image number]:n' \
  '-skip[skip images while reading directory]:n' \
  '-v[get version of RTAB-Map]' \
  '-input[load previous database if it exists]:path:_files -g "*.db"' \
  '*:path:_files' && ret=0

return ret
