#compdef pd-server
# Documentation: https://github.com/pingcap/pd
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-V,--version}'[show version]' \
  '--name[PD member name]:name' \
  '--data-dir[data directory path]:directory:_directories' \
  '--client-urls[URLs for client traffic]:urls' \
  '--advertise-client-urls[advertise URLs for client traffic]:urls' \
  '--peer-urls[URLs for peer traffic]:urls' \
  '--advertise-peer-urls[advertise URLs for peer traffic]:urls' \
  '--config[configuration file path]:config file:_files' \
  '--initial-cluster[initial cluster configuration]:cluster config' \
  '--join[join an existing PD cluster]:urls' \
  '--force-new-cluster[force to create a new one-member cluster]' \
  '--log-level[log level]:level:(debug info warn error fatal)' \
  '-L[log level]:level:(debug info warn error fatal)' \
  '--log-file[log file path]:log file:_files' \
  '--cacert[path to CA certificate]:CA cert:_files' \
  '--cert[path to TLS certificate]:cert:_files' \
  '--key[path to TLS key]:key:_files' \
  '--metrics-addr[prometheus pushgateway address]:address'
