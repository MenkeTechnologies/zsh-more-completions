#compdef portablectl
# _portablectl — systemd portablectl (manage portable services packaged as disk images; subcommands: list, status, inspect, attach, detach, reattach, is-attached; --profile selects a profile fragment (default/strict/trusted/non-strict), --copy, --enable, --now, --runtime, --extension, --no-block)
# upstream: https://github.com/systemd/systemd (src/portable)
# Subcommands from systemd src/portable/portablectl.c on tip.

_portablectl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-H+[host:port]:host:_hosts' \
        '-M+[container]:container:' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--profile=*[profile]:profile:(default strict trusted nonstrict)' \
        '--copy=*[copy semantics]:semantics:(copy auto symlink mixed)' \
        '*--extension+[extension image]:file:_files' \
        '--enable[enable units after attach]' \
        '--now[start units after attach]' \
        '--runtime[runtime only]' \
        '--no-reload[skip daemon-reload]' \
        '--cat[concatenate]' \
        '-q[quiet]' \
        '--json=*[json mode]:mode:(short pretty off)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'portablectl command' '(list status inspect attach detach reattach is-attached set-attached help)' ;;
        args) _arguments '*:image or unit:_files' ;;
    esac
}

_portablectl "$@"
