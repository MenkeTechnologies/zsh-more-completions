#compdef cpan
# Documentation: cpan -h
# Source: Perl cpan — interact with CPAN from the command line.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[create CPAN autobundle]' \
    '-A[show maintainers for modules]' \
    '-c[run make clean]' \
    '-C[show Changes files]' \
    '-D[show details / out-of-date modules]' \
    '-f[force install (skip prereq fail)]' \
    '-F[force install (ignore prereq tests)]' \
    '-g[download module to current directory]' \
    '-h[show help]' \
    '-i[install modules]' \
    '-I[install with local\:\:lib]' \
    '-j+[use config file]:file:_files' \
    '-J[dump current config]' \
    '-l[list installed modules]' \
    '-L[show modules authored by user]' \
    '-m[make modules]' \
    '-M+[use mirror URL]:url:' \
    '-n[do not actually install (dry-run)]' \
    '-O[show outdated modules]' \
    '-p+[mirror override]:url:' \
    '-P[show preferred mirrors]' \
    '-r[recompile installed modules]' \
    '-s[start a shell with CPAN.pm context]' \
    '-t[test modules]' \
    '-T[do not test (with -i)]' \
    '-u[upgrade out-of-date modules]' \
    '-v[print version]' \
    '-V[print configurations / paths]' \
    '-w[turn warnings on]' \
    '-x[search by description (in mirror)]' \
    '-X[show CPAN.pm install paths]' \
    '*:module:' \
    && ret=0

return ret
