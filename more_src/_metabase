#compdef metabase

# Zsh completion for Metabase - business intelligence tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'db:database management commands'
  'driver:driver management'
  'dump:dump application data'
  'environment:show environment variables'
  'help:show help'
  'load:load application data'
  'migrate:run database migrations'
  'profile:print profile information'
  'reset-password:reset user password'
  'rotate-encryption-key:rotate encryption key'
  'seed:seed database with sample data'
  'version:show version'
)

_arguments -s -S \
  '-Dmb.db.type=[database type]:type:(h2 postgres mysql)' \
  '-Dmb.db.host=[database host]:host:_hosts' \
  '-Dmb.db.port=[database port]:port:' \
  '-Dmb.db.dbname=[database name]:name:' \
  '-Dmb.db.user=[database user]:user:' \
  '-Dmb.db.pass=[database password]:password:' \
  '-Dmb.jetty.host=[HTTP server host]:host:' \
  '-Dmb.jetty.port=[HTTP server port]:port:' \
  '-Dmb.jetty.ssl=[enable SSL]:bool:(true false)' \
  '-Dmb.jetty.ssl-port=[SSL port]:port:' \
  '-Dmb.jetty.keystore=[SSL keystore]:file:_files' \
  '-Dmb.jetty.keystore-password=[keystore password]:password:' \
  '-Dmb.encryption-secret-key=[encryption key]:key:' \
  '1:command:->command' && ret=0

case "$state" in
  command)
    _describe -t commands 'metabase command' commands && ret=0
    ;;
esac

return ret
