#compdef wrecon
# Documentation: https://cxc.cfa.harvard.edu/ciao/ahelp/wrecon.html
# Combine wavelet transform coefficients into sources

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'infile=[the input data set]:file:_files' \
  'sourcefile=[file containing the output source list]:file:_files' \
  'scellfile=[image showing the source cells]:file:_files' \
  'imagefile=[output reconstructed, noise-free source image]:file:_files' \
  'regfile=[file for ASCII region output]:file:_files' \
  'clobber=[existing outputs will be overwritten]:clobber:(yes no)' \
  'ellsigma=[size, in sigmas, of elliptical source regions]:ellsigma:' \
  'srclist=[stack of candidate source correlation maxima]:file:_files' \
  'correl=[stack of correlation images from each scale]:file:_files' \
  'nbkg=[stack of normalized background images]:file:_files' \
  'bkginput=[pre-determined background input image]:file:_files' \
  'bkgerrinput=[use background error in file bkginput[2]]:bkgerrinput:(yes no)' \
  'defnbkgfile=[default normalized background file]:file:_files' \
  'fluxfile=[stack of flux images at each scale pair]:file:_files' \
  'outputinfix=[extra text to insert in output filenames]:outputinfix:' \
  'xscales=[must be identical to that used in wtransform]:xscales:' \
  'yscales=[must be identical to that used in wtransform]:yscales:' \
  'fluxscales=[which x, y scales for flux calculations]:fluxscales:' \
  'expfile=[image of exposure time for dataset]:file:_files' \
  'exptime=[time of the exposure, in seconds]:exptime:' \
  'expthresh=[relative exposure threshold]:expthresh:' \
  'bkgtime=[livetime of predetermined background (seconds)]:bkgtime:' \
  'psffile=[FITS file of psf information from mkpsfmap]:file:_files' \
  'stall=[mode to rendezvous a debugger with wrecon]:stall:(yes no)' \
  'log=[if no, log information will go to stdout]:log:(yes no)' \
  'verbose=[level of log output]:verbose:(0 1 2 3 4 5)' && ret=0

return ret
