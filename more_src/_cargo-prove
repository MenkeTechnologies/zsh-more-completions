#compdef cargo-prove
# Documentation: https://raw.githubusercontent.com/succinctlabs/sp1/dev/crates/cli/src/bin/cargo-prove.rs
# Reference accessed: 2026-05-27
# Verified: upstream ProveCliCommands enum in crates/cli/src/bin/cargo-prove.rs and per-command structs in crates/cli/src/commands/, BuildArgs in crates/build/src/lib.rs

local curcontext="$curcontext" state line ret=1

local -a _cargo_prove_subcommands
_cargo_prove_subcommands=(
  'new:create a new SP1 project from the project template'
  'build:build an SP1 guest program to an ELF'
  'vkey:print the verification key of an SP1 program'
  'build-toolchain:build the cargo-prove RISC-V toolchain'
  'install-toolchain:install the prebuilt cargo-prove RISC-V toolchain'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cargo-prove subcommand' _cargo_prove_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--bare[scaffold a bare-bones project (no host)]' \
          '--evm[scaffold an EVM-compatible project template]' \
          '--version=[version of sp1-project-template to use (branch or tag)]:ref:' \
          '1:project name:' && ret=0
        ;;
      build)
        _arguments \
          '--docker[run compilation in a Docker container for reproducible builds]' \
          '--tag=[ghcr.io/succinctlabs/sp1 image tag to use with Docker]:tag:' \
          '--features=[space or comma separated features to activate]:features:' \
          '--rustflags=[extra rustc flags to pass through]:flags:' \
          '--no-default-features[do not activate the default feature]' \
          '--ignore-rust-version[ignore the rust-version field in Cargo.toml]' \
          '--locked[assert that Cargo.lock will remain unchanged]' \
          '(-p --packages)'{-p+,--packages=}'[build only the specified packages]:package:' \
          '--binaries=[build only the specified binaries]:binary:' \
          '--bin=[build only the specified binaries]:binary:' \
          '--elf-name=[output ELF binary name]:name:' \
          '--output-directory=[copy the compiled ELF to this directory]:dir:_files -/' \
          '--out-dir=[copy the compiled ELF to this directory]:dir:_files -/' \
          '--workspace-directory=[top-level workspace directory for the Docker invocation]:dir:_files -/' \
          '--workspace-dir=[top-level workspace directory for the Docker invocation]:dir:_files -/' \
          '--warning-level=[warning message verbosity]:level:' \
          '--no-docker-cache[disable Docker volume caching for cargo registry and git deps]' && ret=0
        ;;
      vkey)
        _arguments \
          '--elf=[path to the ELF file to compute the verification key for]:file:_files' \
          '--program=[crate name used to generate the ELF file]:crate:' && ret=0
        ;;
      install-toolchain)
        _arguments \
          '(-t --token)'{-t+,--token=}'[GitHub authentication token (GITHUB_TOKEN)]:token:' && ret=0
        ;;
      build-toolchain)
        _arguments && ret=0
        ;;
      *)
        _arguments '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
