#compdef counterfeiter
# Documentation: https://github.com/maxbrunsfeld/counterfeiter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# counterfeiter - Go test double / fake generator for interfaces.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o+[output path for generated fake]:output file:_files' \
  '-p[print to stdout, do not write a file]' \
  '-generate[process //counterfeiter:generate directives]' \
  '--fake-name=[custom name for the generated fake type]:name:' \
  '-header=[custom header file]:header file:_files' \
  '1:source path or package:_files -g "*.go"' \
  '2:interface name:' && ret=0

return ret
