#compdef counterfeiter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-o+[output file]:output file:_files' \
  '-p[generate package-level fake]' \
  '-generate[scan for go:generate directives]' \
  '-fake-name=[custom fake name]:name:' \
  '-header=[custom header file]:header file:_files' \
  '-q[quiet mode]' \
  '1:source file or package:_files -g "*.go"' \
  '2:interface name:' && ret=0

return ret
