#compdef hgLoadMafSummary
# UCSC kent: load a MAF summary table into the database

local ret=1

_arguments -s -S \
  '-mergeGap=[maximum gap size for merging regions (default 500)]:n' \
  '-minSize=[merge blocks smaller than this value (default 10000)]:n' \
  '-maxSize=[break up blocks larger than this value (default 50000)]:n' \
  '-minSeqSize=[skip alignments when reference is shorter than N bases]:n' \
  '-test[suppress database loading, create .tab files only]' \
  '1:database:' \
  '2:table:' \
  '3:maf file:_files -g "*.maf"' && ret=0

return ret
