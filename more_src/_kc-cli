#compdef kc-cli kcctl
# _kc-cli — Red Hat Keycloak control plane CLI alias (keycloak team, Java); jbang/quarkus
# upstream: https://github.com/keycloak/kcctl

_kc-cli() {
    local -a sub=(
        'config:credentials:store login credentials'
        'config:truststore:configure truststore'
        'config:show:show config'
        'login:login to keycloak'
        'logout:logout'
        'whoami:show current user'
        'get:get resource'
        'create:create resource'
        'update:update resource'
        'delete:delete resource'
        'list:list resources'
        'export:export realm'
        'import:import realm'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:reset-password:reset user password'
        'user:get:get user'
        'user:add-role:assign role'
        'user:remove-role:remove role'
        'realm:list:list realms'
        'realm:create:create realm'
        'realm:delete:delete realm'
        'role:list:list roles'
        'role:create:create role'
        'role:delete:delete role'
        'client:list:list clients'
        'client:create:create client'
        'client:delete:delete client'
        'group:list:list groups'
        'group:create:create group'
        'group:delete:delete group'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--server=+[server URL]:url:_urls' \
        '--realm=+[realm]:str:' \
        '--user=+[user]:user:_users' \
        '--password=+[password]:str:' \
        '--client=+[client]:str:' \
        '--client-secret=+[client secret]:str:' \
        '--no-config[no config]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--insecure[skip TLS verification]' \
        '--format=+[output format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kc subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '1:server URL:_urls' \
                    '--realm=+[realm]:str:' \
                    '--user=+[user]:user:_users' \
                    '--password=+[password]:str:' \
                    '--client=+[client]:str:' \
                    '--client-secret=+[client secret]:str:' ;;
                user:create) _arguments \
                    '--username=+[username]:user:_users' \
                    '--email=+[email]:str:' \
                    '--firstname=+[first name]:str:' \
                    '--lastname=+[last name]:str:' \
                    '--password=+[password]:str:' \
                    '--temporary[temporary password]' \
                    '--enabled=+[bool]:b:(true false)' ;;
                get|create|update|delete|list) _arguments \
                    '1:resource:(users realms roles groups clients sessions events)' \
                    '*:args:' ;;
                export|import) _arguments \
                    '1:realm name:' \
                    '--file=+[file]:file:_files -g "*.{json,yaml,yml}"' \
                    '-f+[file]:file:_files -g "*.{json,yaml,yml}"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kc-cli "$@"
