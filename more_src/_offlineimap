#compdef offlineimap

# Zsh completion for offlineimap - synchronize IMAP mail with a local Maildir

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version and exit]' \
  '(-1)-1[run only one synchronization iteration]' \
  '(-P)-P+[profile directory for debugging output]:directory:_files -/' \
  '(-a)-a+[comma-separated list of accounts to sync]:accounts:' \
  '(-c)-c+[specify alternative config file]:config file:_files' \
  '(-d)-d+[enable debug modes]:debug types:(imap maildir thread sync ui network)' \
  '(-f)-f+[comma-separated list of folders to sync]:folders:' \
  '(-k)-k+[override config option]:section\:option=value:' \
  '(-l)-l+[log file path]:log file:_files' \
  '(-s)-s[log to syslog]' \
  '(-o)-o[one-shot mode: override hold and autorefresh]' \
  '(-q)-q[run only quick sync (do not update flags)]' \
  '(-u)-u+[UI to use]:ui:(Curses.Blinkenlights TTYUI Basic Quiet MachineUI)' \
  '--dry-run[run in dry-run mode (do not alter mail stores)]' \
  '--delete-folder[delete a folder (with caution!)]:folder:' \
  '--migrate-fmd5-using-nametrans[migrate FMD5 hashes using nametrans rules]' \
  '--mbnames-prune[prune mbnames entries]' \
  '--info[output account information]'
