#compdef bgzip
# _bgzip — Heng Li htslib bgzip block compression de-compression utility for BGZF-format compatible with samtools tabix (samtools team, C); getopt
# upstream: https://github.com/samtools/htslib

_bgzip() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c[write on standard output]' \
        '--stdout[write on standard output]' \
        '-d[decompress]' \
        '--decompress[decompress]' \
        '-f[force]' \
        '--force[force]' \
        '-i[create BGZF index]' \
        '--index[create BGZF index]' \
        '-I+[BGZF index file]:file:_files -g "*.gzi"' \
        '--index-name=+[BGZF index file]:file:_files -g "*.gzi"' \
        '-k[keep input file]' \
        '--keep[keep input file]' \
        '-l+[compression level]:n:' \
        '--compress-level=+[compression level]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[BGZF reindex]' \
        '--reindex[BGZF reindex]' \
        '-g+[bytes seek offset]:n:' \
        '--rebgzip[recompress]' \
        '-s+[file size]:n:' \
        '--size=+[file size]:n:' \
        '-S+[range to extract]:str:' \
        '--super=+[range to extract]:str:' \
        '-t[test integrity]' \
        '--test[test integrity]' \
        '-@+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-b+[virtual file offset]:n:' \
        '--offset=+[virtual file offset]:n:' \
        '*:input file:_files'
}

_bgzip "$@"
