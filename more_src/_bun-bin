#compdef bun bunx
# _bun-bin — Bun all-in-one JS runtime + bundler + test runner + package manager (Jarred Sumner, Oven); Zig-implemented JS runtime
# upstream: https://github.com/oven-sh/bun

_bun-bin() {
    local -a sub=(
        'run:run a file or script'
        'test:run tests'
        'x:bunx (execute remote package)'
        'repl:open a JS REPL'
        'create:scaffold from template'
        'install:install all packages'
        'i:alias for install'
        'add:add dependency'
        'a:alias for add'
        'remove:remove dependency'
        'rm:alias for remove'
        'update:update dependencies'
        'link:link package globally'
        'unlink:unlink package'
        'audit:audit deps'
        'outdated:show outdated packages'
        'build:bundle for production'
        'bundle:alias for build'
        'init:create new project'
        'publish:publish to npm'
        'patch:create patch'
        'patch-commit:commit patch'
        'pm:package manager subcommands'
        'upgrade:upgrade bun itself'
        'completions:install shell completions'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--config+[bunfig path]:file:_files -g "bunfig*"' \
        '--silent[silent]' \
        '--cwd+[cwd]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'bun subcommand' sub ;;
        args)
            case $words[1] in
                run|x) _arguments \
                    '--bun[force bun JS runtime]' \
                    '--smol[low-memory mode]' \
                    '--hot[hot reload]' \
                    '--watch[watch and restart]' \
                    '--no-clear-screen[no clear screen]' \
                    '--shell+[shell]:shell:(bun system)' \
                    '*:script:_files -g "*.(js|ts|jsx|tsx|mjs|cjs)"' ;;
                test) _arguments \
                    '--bail[stop on first failure]' \
                    '--coverage[coverage]' \
                    '--coverage-reporter+[reporter]:reporter:(text lcov)' \
                    '--coverage-threshold+[threshold]:f:' \
                    '--watch[watch and rerun]' \
                    '--update-snapshots[update snapshots]' \
                    '--rerun-each+[rerun N times]:n:' \
                    '--reporter+[reporter]:reporter:(default junit)' \
                    '--timeout+[ms timeout]:n:' \
                    '*:test glob:' ;;
                add|a|install|i|update|remove|rm) _arguments \
                    '(-d --dev)'{-d,--dev}'[devDep]' \
                    '(-o --optional)'{-o,--optional}'[optionalDep]' \
                    '(-p --peer)'{-p,--peer}'[peerDep]' \
                    '(-g --global)'{-g,--global}'[global]' \
                    '(-E --exact)'{-E,--exact}'[exact]' \
                    '--save-text-lockfile[text lockfile]' \
                    '--frozen-lockfile[fail on lockfile change]' \
                    '--production[skip dev]' \
                    '--no-save[do not save]' \
                    '--no-cache[skip cache]' \
                    '--no-summary[no summary]' \
                    '*:package:' ;;
                build|bundle) _arguments \
                    '--target+[target]:target:(browser node bun)' \
                    '--outdir+[output dir]:dir:_files -/' \
                    '--outfile+[output file]:file:_files' \
                    '--format+[format]:fmt:(esm cjs iife)' \
                    '--minify[minify]' \
                    '--sourcemap+[sourcemap]:mode:(none external inline linked)' \
                    '--watch[watch + rebuild]' \
                    '--splitting[code splitting]' \
                    '--public-path+[public path]:str:' \
                    '--external+[external]:str:' \
                    '--banner+[banner]:str:' \
                    '--footer+[footer]:str:' \
                    '--root+[root dir]:dir:_files -/' \
                    '--asset-naming+[asset name pattern]:pattern:' \
                    '--entry-naming+[entry name pattern]:pattern:' \
                    '--chunk-naming+[chunk name pattern]:pattern:' \
                    '*:entry:_files' ;;
                init) _arguments \
                    '--yes[skip prompts]' \
                    '(-y)-y[skip prompts]' \
                    '1:dir:_files -/' ;;
                pm) _arguments '1:pm cmd:(bin ls cache rm trust ls hash hash-string hash-print migrate untrusted whoami pack)' '*:args:' ;;
            esac
            ;;
    esac
}

_bun-bin "$@"
