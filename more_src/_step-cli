#compdef step-cli

# Zsh completion for step CLI (Smallstep)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'ca:initialize and manage certificate authority'
      'certificate:manage certificates'
      'completion:print shell completion script'
      'context:manage step contexts'
      'crl:manage certificate revocation lists'
      'crypto:manage cryptographic keys and operations'
      'oauth:handle OAuth flows'
      'path:print step path'
      'ssh:manage SSH certificates'
      'version:print version'
      'help:show help'
    )
    _describe -t commands 'step command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      ca)
        local -a ca_cmds=(
          'init:initialize a certificate authority'
          'bootstrap:initialize environment for a CA'
          'certificate:sign a certificate'
          'health:check CA health'
          'provisioner:manage CA provisioners'
          'renew:renew a certificate'
          'revoke:revoke a certificate'
          'root:download CA root certificate'
          'sign:sign a CSR'
          'token:generate an OTT'
          'admin:manage CA admins'
          'policy:manage CA policies'
          'acme:manage ACME'
        )
        _describe -t commands 'step ca command' ca_cmds && ret=0
        ;;
      certificate)
        local -a cert_cmds=(
          'create:create a certificate or CSR'
          'fingerprint:print certificate fingerprint'
          'format:reformat a certificate'
          'inspect:show certificate details'
          'install:install a root certificate'
          'lint:lint a certificate'
          'needs-renewal:check if certificate needs renewal'
          'sign:sign a CSR'
          'uninstall:uninstall a root certificate'
          'verify:verify a certificate'
          'bundle:bundle certificate with intermediates'
          'key:extract key from certificate'
          'p12:create PKCS#12 bundle'
        )
        _describe -t commands 'step certificate command' cert_cmds && ret=0
        ;;
      crypto)
        local -a crypto_cmds=(
          'change-pass:change key password'
          'hash:generate a hash digest'
          'jwk:manage JSON Web Keys'
          'jws:manage JSON Web Signatures'
          'jwe:manage JSON Web Encryption'
          'jwt:manage JSON Web Tokens'
          'kdf:derive a key using PBKDF2/scrypt/bcrypt/argon2'
          'key:manage cryptographic keys'
          'nacl:NaCl tools'
          'otp:generate one-time passwords'
          'pemutil:PEM utilities'
        )
        _describe -t commands 'step crypto command' crypto_cmds && ret=0
        ;;
      ssh)
        local -a ssh_cmds=(
          'certificate:sign an SSH certificate'
          'check-host:check an SSH host certificate'
          'config:configure SSH'
          'fingerprint:print SSH public key fingerprint'
          'hosts:list known SSH hosts'
          'inspect:show SSH certificate details'
          'list:list SSH certificates'
          'login:add SSH certificate to agent'
          'logout:remove SSH certificate from agent'
          'needs-renewal:check if certificate needs renewal'
          'proxycommand:SSH proxy command helper'
          'rekey:rekey SSH host certificates'
          'renew:renew SSH certificate'
          'revoke:revoke SSH certificate'
        )
        _describe -t commands 'step ssh command' ssh_cmds && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
