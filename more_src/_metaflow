#compdef metaflow
# Documentation: https://github.com/Netflix/metaflow/blob/master/metaflow/cmd/main_cli.py
# Reference accessed: 2026-05-19
# Verified: upstream Netflix/metaflow main CLI source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'help:show available commands'
      'status:show flows accessible from the working tree'
      'configure:configure Metaflow to access the cloud'
      'tutorials:browse and access tutorial episodes'
      'develop:developer utilities'
      'code:work with code packages'
    )
    _describe -t commands 'metaflow command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      configure)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(aws azure gcp kubernetes sandbox reset show export import)' \
          '--profile=[profile name]:profile:' && ret=0
        ;;
      tutorials)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:action:(list pull info)' && ret=0
        ;;
    esac
    ;;
esac

return ret
