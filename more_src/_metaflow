#compdef metaflow

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'configure:configure Metaflow'
      'help:show help'
      'package:package flows'
      'status:show status'
      'tutorials:manage tutorials'
      'version:show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      configure)
        _arguments -s -S \
          '1:backend:(aws azure gcp local)' \
          '--profile=[profile name]:profile' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      tutorials)
        _arguments -s -S \
          '1:action:(pull info list)' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
