#compdef oshmem_info
# Documentation: https://docs.open-mpi.org/en/main/
# OpenSHMEM: display information about the OpenSHMEM installation

local ret=1

_arguments -s \
  '(-a --all)'{-a,--all}'[show all configuration options and MCA parameters]' \
  '--arch[show the architecture OpenSHMEM was compiled on]' \
  '(-c --config)'{-c,--config}'[show configuration options]' \
  '*'{-gmca,--gmca}'+[pass global MCA parameters applicable to all contexts]:param: :value' \
  '(-h --help)'{-h,--help}'[show help/usage message]' \
  '--hostname[show the hostname OpenSHMEM was configured and built on]' \
  '--internal[show internal MCA parameters]' \
  '--level=[show only variables with at most this level (1-9)]:level' \
  '*'{-mca,--mca}'+[pass context-specific MCA parameters]:param: :value' \
  '--param[show MCA parameters]:type: :component' \
  '--parsable[output in machine-parsable format]' \
  '--parseable[output in machine-parsable format]' \
  '--path=[show paths OpenSHMEM was configured with]:type' \
  '--pretty[output in prettyprint format]' \
  '--selected-only[show only variables from selected components]' \
  '(-V --version)'{-V,--version}'[show the version of OpenSHMEM]' && ret=0

return ret
