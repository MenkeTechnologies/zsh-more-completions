#compdef gtf_to_sam
# Documentation: https://raw.githubusercontent.com/cole-trapnell-lab/cufflinks/master/src/gtf_to_sam.cpp
# gtf_to_sam: convert GTF transcripts to SAM (cufflinks utility)

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-r --reference-seq)'{-r,--reference-seq=}'[reference fasta file]:file:_files' \
  '(-F --raw-fpkm)'{-F,--raw-fpkm}'[use FPKM instead of isoform fraction]' \
  '(-v --verbose)'{-v,--verbose}'[verbose status output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]' \
  '*:GTF and out.sam files:_files' && ret=0

return ret
