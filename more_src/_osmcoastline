#compdef osmcoastline
# Documentation: https://docs.osmcode.org/osmcoastline/latest/osmcoastline.html
# Extract the coastline from an OSM planet file and assemble polygons.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[detailed processing information with timing]' \
  '(-d --debug)'{-d,--debug}'[enable debugging output]' \
  '(-b --bbox-overlap)'{-b+,--bbox-overlap=}'[overlap added where split polygons touch]:overlap:_default' \
  '(-c --close-distance)'{-c+,--close-distance=}'[close coastline gaps smaller than distance (0 to disable)]:distance:_default' \
  '(-e --exit-ignore-warnings)'{-e,--exit-ignore-warnings}'[exit 0 even if there are warnings]' \
  '(-f --overwrite)'{-f,--overwrite}'[overwrite output file if it exists]' \
  '(-g --gdal-driver)'{-g+,--gdal-driver=}'[GDAL output driver]:driver:(SQLite GPKG "ESRI Shapefile")' \
  '(-i --no-index)'{-i,--no-index}'[do not create spatial indexes in output]' \
  '(-l --output-lines)'{-l,--output-lines}'[output coastlines as lines]' \
  '(-m --max-points)'{-m+,--max-points=}'[split features to not exceed this point count]:num:_default' \
  '(-o --output-database)'{-o+,--output-database=}'[Spatialite output database (required)]:file:_files' \
  '(-p --output-polygons)'{-p+,--output-polygons=}'[which polygons to output]:type:(land water both none)' \
  '(-r --output-rings)'{-r,--output-rings}'[output rings for debugging]' \
  '(-s --srs)'{-s+,--srs=}'[spatial reference system EPSG code]:epsg:(4326 3857)' \
  '(-S --write-segments)'{-S+,--write-segments=}'[write coastline segments to file]:file:_files' \
  '*:OSM input file:_files -g "*.(osm|osm.bz2|osm.pbf|osm.gz|opl)(-.)"' && ret=0

return ret
