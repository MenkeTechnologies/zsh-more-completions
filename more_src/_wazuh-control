#compdef wazuh-control
# Documentation: https://man.archlinux.org/search?q=wazuh-control
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop restart reload status info enable disable lock unlock)' \
  '*::sub:(auth api cluster database integrator logcollector maild remoted analysisd execd syscheckd modulesd monitord agentlessd agent-status csyslogd download-list-update wmodulesd remoted)' && ret=0

return ret
