#compdef aws-export-credentials

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--profile[AWS profile]:profile:' \
  '--role-arn[role ARN to assume]:arn:' \
  '--role-session-name[session name]:name:' \
  '--credentials-file-profile[profile to write to credentials file]:profile:' \
  '--env-export[export as environment variables]' \
  '--env-export-command[shell for env export]:shell:(bash fish powershell)' \
  '--json[JSON output]' \
  '--exec[execute command with credentials]:command:' \
  '--region[AWS region]:region:' \
  '(-h --help)'{-h,--help}'[show help]' \
  && ret=0

return ret
