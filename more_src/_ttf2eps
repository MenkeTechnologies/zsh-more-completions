#compdef ttf2eps
# Documentation: https://man.archlinux.org/man/ttf2eps.1.en
# ttf2eps - extract glyphs from a TrueType font into EPS files

local ret=1

_arguments -s \
  '--all[extract all glyphs from the font file]' \
  '--name=[specify a glyph by its PostScript character name]:ps-name:' \
  '--unicode=[specify a glyph by its Unicode encoding (hexadecimal)]:hex:' \
  '--glyph=[specify a glyph by its TrueType glyph number]:num:' \
  '*:TrueType font file:_files -g "*.(ttf|TTF)(-.)"' && ret=0

return ret
