#compdef litecoin-tx
# Documentation: https://github.com/litecoin-project/litecoin (src/bitcoin-tx.cpp SetupBitcoinTxArgs + configure.ac BITCOIN_TX_NAME=litecoin-tx)
# Reference accessed: 2026-05-29
# Litecoin Core standalone transaction builder/parser (Bitcoin Core fork).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '(- *)-help[print help and exit]' \
  '(- *)-?[print help and exit]' \
  '(- *)-h[print help and exit]' \
  '-create[create new, empty TX]' \
  '-json[select JSON output]' \
  '-txid[output only the hex-encoded transaction id]' \
  '(-testnet -signet -regtest)-testnet[use Litecoin testnet]' \
  '(-testnet -signet -regtest)-signet[use Litecoin signet]' \
  '(-testnet -signet -regtest)-regtest[use Litecoin regression test mode]' \
  '-chain=[chain to use]:chain:(main test signet regtest)' \
  '*:command (delin=N delout=N in=TXID\:VOUT outaddr=VAL\:ADDR outpubkey=VAL\:KEY outmultisig=... outscript=... outdata=DATA locktime=N nversion=N replaceable[=N] sign=SIGHASH load=NAME\:FILE set=NAME\:JSON):' \
  && ret=0

return ret
