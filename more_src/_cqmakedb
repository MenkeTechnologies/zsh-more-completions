#compdef cqmakedb
# Documentation: https://github.com/ruben2020/codequery/blob/master/makedb/main.cpp
# Build a CodeQuery sqlite3 database from cscope and ctags databases

local ret=1

_arguments -s -S \
  '(-h)-h[display help]' \
  '(-v)-v[display version]' \
  '-s+[CodeQuery sqlite3 database file to create]:database:_files' \
  '-c+[cscope.out file path]:cscope file:_files' \
  '-t+[ctags tags file path]:tags file:_files' \
  '-p[vacuum/compact the database]' \
  '-d[debug mode]' \
  '*:file:_files' && ret=0

return ret
