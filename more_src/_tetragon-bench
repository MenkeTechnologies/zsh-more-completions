# Cilium tetragon-bench R152b — performance/throughput benchmark
# harness for the Tetragon eBPF security observability runtime.
# Sister tool to the already-covered `tetragon` daemon and
# `tetra` CLI from cilium/tetragon.

_arguments -s -S \
  '-rb-size=[perf ring buffer size (default 65535)]:bytes:' \
  '-debug[enable debugging]' \
  '-json-encode[JSON-encode events and measure encoding overhead]' \
  '-baseline[run a baseline benchmark without tetragon]' \
  '-print[print events as JSON to stdout]' \
  '-store[store events as JSON to stdout]' \
  '-trace=[trace benchmark to run (default "none")]:bench:(none tcp connect listen socket-accept syscall write open)' \
  '-crd=[CRD to start tetragon with (default "none")]:file:_files -g "*.(yaml|yml)"' \
  '-csv=[store stats to CSV file (default "none")]:file:_files' \
  '-name=[benchmark name (for output labeling)]:name:'
