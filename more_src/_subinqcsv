#compdef subinqcsv
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/headers/subinqcsv.c
# SUBINQCSV - input Q-records or parameters, interpolate, output Q-records

local ret=1

_arguments -s -S \
  'qin=[input file containing q-records]:f:_files' \
  'qout=[output file for q-records]:f:_files' \
  'rfile=[read a K-file with 3D grid definition]:f:_files' \
  'check=[1 print checking details]:c:(0 1)' \
  'inloc=[input location option (1-7)]:i:(1 2 3 4 5 6 7)' \
  'keyloc=[location key name]:k:' \
  'extrapi=[extrapolation in igi direction (0-3)]:e:(0 1 2 3)' \
  'extrapc=[extrapolation in igc direction (0-3)]:e:(0 1 2 3)' \
  'extrapt=[extrapolation in time direction]:e:' \
  'igiout=[output igi location values]:i:' \
  'igcout=[output igc location values]:i:' \
  'iecho=[echo input cell centre values]:i:(0 1 2)' \
  'invp2=[invert velocity squared interpolation]:i:' \
  'outind=[output independent dimension values]:o:' \
  'outlist=[output value name list]:o:' \
  'formtv=[format of time-velocity values]:f:' \
  'formxy=[format of x-y coordinate values]:f:' \
  'cdp=[cdp location values]:c:' \
  'offs=[offset values]:o:' \
  'tims=[time values]:t:' \
  'tnmo=[NMO time values]:t:' \
  'vnmo=[NMO velocity values]:v:' \
  'vels=[velocity values]:v:' \
  'tstat=[time static values]:t:' \
  'dpth=[depth values]:d:' \
  'ename=[name of the entry being processed]:e:' \
  '*:SU file:_files' && ret=0

return ret
