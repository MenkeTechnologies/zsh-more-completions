#compdef btrfs-debugfs
# _btrfs-debugfs — btrfs-progs btrfs-debugfs (Josef Bacik's debugfs-style dumper for btrfs metadata; -d device, -t tree id to dump, -a all trees, -b block to inspect; reads on-disk metadata from an unmounted device for forensic + dev work)
# upstream: https://github.com/kdave/btrfs-progs (contrib/btrfs-debugfs)
# Flags from btrfs-progs contrib/btrfs-debugfs.py on tip.

_btrfs-debugfs() {
    _arguments \
        '-h[show help]' \
        '-d+[device]:device:_files -g "/dev/*"' \
        '-t+[tree id]:tree:(root extent chunk dev fs csum quota uuid free_space data_reloc log)' \
        '-a[all trees]' \
        '-b+[block number]:block:' \
        '-f+[file]:file:_files' \
        '-r+[root id]:rootid:' \
        '*:path:_files'
}

_btrfs-debugfs "$@"
