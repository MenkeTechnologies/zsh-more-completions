#compdef virtio-forwarder
# _virtio-forwarder — Spirent virtio-forwarder (userspace DPDK-based packet forwarder bridging guest virtio-net to PCI passthrough devices on the host; -c CPU mask, -n memory channels, --huge-dir hugepage dir, --proc-type primary|secondary|auto, --syslog, --log-level, --port pci-addr, --no-huge, --vhost-socket-path)
# upstream: https://github.com/Spirent/openvswitch-vsa
# Flags from virtio-forwarder src/main.c on tip.

_virtio-forwarder() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[CPU mask hex]:mask:' \
        '-n+[memory channels]:n:' \
        '--huge-dir+[hugepage dir]:dir:_files -/' \
        '--proc-type+[type]:type:(primary secondary auto)' \
        '--syslog[log via syslog]' \
        '--log-level+[level]:level:(emerg alert crit err warning notice info debug)' \
        '*--port+[PCI addr]:addr:' \
        '--no-huge[disable hugepages]' \
        '--vhost-socket-path+[dir]:dir:_files -/' \
        '--virtio-cpu+[mask]:mask:' \
        '--pci-cpu+[mask]:mask:'
}

_virtio-forwarder "$@"
