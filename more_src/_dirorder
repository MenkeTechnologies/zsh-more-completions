#compdef dirorder
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dirorder.html
# Source: MRtrix3/mrtrix3 cmd/dirorder.cpp — reorder directions to optimise acquisition (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-cartesian[output [x y z] instead of [az el]]' \
    '1:input directions:_files' \
    '2:output directions:_files' \
    && ret=0

return ret
