#compdef pt-index-usage
# Documentation: https://man.archlinux.org/search?q=pt-index-usage
# Reference accessed: 2026-05-16

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--charset=[charset]:charset:' \
  '--create-save-results-database[auto-create save db]' \
  '--databases=[databases to analyze]:dbs:' \
  '--defaults-file=[defaults file]:file:_files' \
  '--drop=[drop unused indexes]:flag:(non-unique unique any)' \
  '--empty-save-results-tables[empty save tables first]' \
  '--host=[host]:host:_hosts' \
  '--ignore-databases=[databases to ignore]:list:' \
  '--ignore-tables=[tables to ignore]:list:' \
  '--password=[password]:pw:' \
  '--port=[port]:port:' \
  '--progress=[progress format]:fmt:' \
  '--quiet[quiet]' \
  '--query=[single query to analyze]:sql:' \
  '--report-format=[report format]:fmt:(drop_unused_indexes summary)' \
  '--save-results-database=[save results db]:db:' \
  '--socket=[socket]:file:_files' \
  '--tables=[tables to analyze]:tables:' \
  '--user=[user]:user:' \
  '*:slow_log:_files' && ret=0

return ret
