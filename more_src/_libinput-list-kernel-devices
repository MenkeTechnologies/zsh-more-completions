#compdef libinput-list-kernel-devices
# _libinput-list-kernel-devices — list input devices from the Linux kernel (libinput/libinput)
# upstream: https://gitlab.freedesktop.org/libinput/libinput
# Flags from tools/libinput-list-kernel-devices.py (argparse).

_libinput-list-kernel-devices() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--hid[show HID device info instead of input events]'
}

_libinput-list-kernel-devices "$@"
