#compdef hayabusa

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'csv-timeline:Create CSV timeline'
      'json-timeline:Create JSON/JSONL timeline'
      'logon-summary:Show logon summary'
      'eid-metrics:Show event ID metrics'
      'pivot-keywords-list:List pivot keywords'
      'search:Search by keyword or regex'
      'level-tuning:Tune detection levels'
      'list-contributors:List sigma rule contributors'
      'list-profiles:List output profiles'
      'set-default-profile:Set default output profile'
      'update-rules:Update detection rules'
      'help:Show help for commands'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-d --directory)'{-d,--directory}'=[directory of evtx files]:dir:_files -/' \
      '(-f --file)'{-f,--file}'=[single evtx file]:file:_files -g "*.evtx"' \
      '(-o --output)'{-o,--output}'=[output file]:file:_files' \
      '(-r --rules)'{-r,--rules}'=[rules directory or file]:path:_files' \
      '(-C --clobber)'{-C,--clobber}'[overwrite output file]' \
      '(-l --live-analysis)'{-l,--live-analysis}'[analyze live Windows system]' \
      '(-L --logon-summary)'{-L,--logon-summary}'[show logon summary]' \
      '(-m --min-level)'{-m,--min-level}'=[minimum alert level]:level:(informational low medium high critical)' \
      '(-n --enable-noisy-rules)'{-n,--enable-noisy-rules}'[enable noisy rules]' \
      '--enable-deprecated-rules[enable deprecated rules]' \
      '--enable-unsupported-rules[enable unsupported rules]' \
      '(-e --exact-level)'{-e,--exact-level}'=[exact alert level]:level:(informational low medium high critical)' \
      '--exclude-status=[exclude rules by status]:status:' \
      '--exclude-category=[exclude by category]:category:' \
      '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(-D --debug)'{-D,--debug}'[debug output]' \
      '--no-color[disable color output]' \
      '--no-summary[disable summary]' \
      '-p+[output profile]:profile:(minimal standard verbose all-field-info all-field-info-verbose super-verbose timesketch)' \
      '-P+[output profile file]:file:_files' \
      '-t+[number of threads]:threads:' \
      '--target-file-ext=[target file extensions]:extensions:' \
      '--timeline-end=[end time]:time:' \
      '--timeline-start=[start time]:time:' \
      '--eid-filter[enable EID filter]' \
      '*:evtx file:_files -g "*.evtx"' && ret=0
    ;;
esac

return ret
