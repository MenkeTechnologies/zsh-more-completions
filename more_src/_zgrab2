#compdef zgrab2

# Zsh completion for zgrab2 - application layer scanner

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:output file:_files' \
  '(-f --input-file)'{-f,--input-file}'=[input file with targets]:input file:_files' \
  '(-m --metadata-file)'{-m,--metadata-file}'=[metadata output file]:metadata file:_files' \
  '--senders=[number of send goroutines]:count:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--gomaxprocs=[max OS threads]:count:' \
  '--connections-per-host=[max connections per host]:count:' \
  '--read-limit-per-host=[max read bytes per host]:bytes:' \
  '--timeout=[connection timeout in seconds]:seconds:' \
  '--flush[flush output after each result]' \
  '1:module:->modules' \
  '*::arg:->args' && ret=0

case $state in
  modules)
    local -a modules
    modules=(
      'http:Scan HTTP services'
      'ssh:Scan SSH services'
      'tls:Scan TLS services'
      'smtp:Scan SMTP services'
      'imap:Scan IMAP services'
      'pop3:Scan POP3 services'
      'ftp:Scan FTP services'
      'dns:Scan DNS services'
      'mysql:Scan MySQL services'
      'mssql:Scan MSSQL services'
      'oracle:Scan Oracle services'
      'postgres:Scan PostgreSQL services'
      'redis:Scan Redis services'
      'mongodb:Scan MongoDB services'
      'telnet:Scan Telnet services'
      'bacnet:Scan BACnet services'
      'fox:Scan Fox (Niagara) services'
      'modbus:Scan Modbus services'
      'dnp3:Scan DNP3 services'
      's7:Scan Siemens S7 services'
      'ntp:Scan NTP services'
      'ipp:Scan IPP services'
      'smb:Scan SMB services'
      'siemens:Scan Siemens services'
    )
    _describe -t modules 'zgrab2 modules' modules && ret=0
    ;;
  args)
    case ${line[1]} in
      http)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '--endpoint=[HTTP endpoint path]:path:' \
          '--method=[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
          '--user-agent=[user agent string]:user agent:' \
          '--retry-https[retry with HTTPS on failure]' \
          '--max-redirects=[maximum number of redirects]:count:' \
          '--max-size=[maximum response size in bytes]:bytes:' \
          '--raw-headers[include raw headers in output]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      tls)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '--heartbleed[test for Heartbleed vulnerability]' \
          '--version=[TLS version]:version:' \
          '--cipher-suite=[cipher suite]:suite:' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      ssh)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '--client=[SSH client string]:client string:' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      smtp)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '--ehlo=[EHLO domain]:domain:' \
          '--starttls[use STARTTLS]' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      dns)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '--name=[DNS query name]:name:' \
          '--type=[DNS record type]:type:(A AAAA CNAME MX NS TXT SOA ANY)' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      mysql|postgres|redis|mssql|oracle|mongodb|ftp|telnet|pop3|imap)
        _arguments -s -S \
          '--port=[target port]:port:' \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
