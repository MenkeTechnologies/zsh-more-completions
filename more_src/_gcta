#compdef gcta
# Documentation: https://yanglab.westlake.edu.cn/software/gcta/
# GCTA: genome-wide complex trait analysis (GRM, REML, fastGWA, COJO)

local ret=1

_arguments -s -S \
  '--bfile=[load PLINK binary files (.bed/.bim/.fam)]:prefix:_files' \
  '--mbfile=[input multiple PLINK binary files listed in a text file]:file:_files' \
  '--bgen=[read genotype data in bgen format]:file:_files -g "*.bgen"' \
  '--pfile=[input PLINK2 pgen format files]:prefix:_files' \
  '--dosage-mach=[read MACH output format files]:file:_files' \
  '--out=[output filename root]:prefix' \
  '--keep=[include only individuals from a list file]:file:_files' \
  '--remove=[exclude individuals from a list file]:file:_files' \
  '--update-sex=[update individual sex information]:file:_files' \
  '--geno=[remove SNPs exceeding missingness rate]:rate' \
  '--chr=[analyze specific chromosome]:chr' \
  '--autosome[include all autosomes]' \
  '--extract=[include SNPs from a list]:file:_files' \
  '--exclude=[remove SNPs from a list]:file:_files' \
  '--maf=[minimum allele frequency threshold]:float' \
  '--max-maf=[maximum allele frequency threshold]:float' \
  '--make-grm[compute genetic relationship matrix (binary)]' \
  '--make-grm-gz[generate GRM in compressed text format]' \
  '--make-grm-xchr[estimate GRM from X-chromosome SNPs]' \
  '--make-grm-part=[partition GRM computation for large datasets]:parts' \
  '--grm=[read GRM from binary files]:prefix:_files' \
  '--mgrm=[input multiple GRM files]:file:_files' \
  '--grm-cutoff=[remove individuals exceeding relatedness threshold]:float' \
  '--grm-singleton=[identify unrelated individuals]:float' \
  '--grm-adj=[adjust for imperfect LD]:value' \
  '--make-bK=[set GRM off-diagonals below threshold to zero]:float' \
  '--pca=[perform principal component analysis]:n' \
  '--reml[perform restricted maximum likelihood analysis]' \
  '--reml-priors=[starting values for REML iterations]:values' \
  '--reml-alg=[select algorithm]:alg:(0 1 2)' \
  '--reml-no-constrain[allow negative variance component estimates]' \
  '--reml-maxit=[maximum iteration count]:int' \
  '--reml-lrt=[calculate likelihood ratio test]:value' \
  '--reml-pred-rand[predict random effects using BLUP]' \
  '--pheno=[load phenotype data file]:file:_files' \
  '--mpheno=[specify which trait to analyze]:int' \
  '--qcovar=[input quantitative covariates]:file:_files' \
  '--covar=[input categorical covariates]:file:_files' \
  '--gxe=[specify genotype-by-environment interaction file]:file:_files' \
  '--prevalence=[set disease prevalence for case-control studies]:float' \
  '--mlma[mixed linear model association analysis]' \
  '--fastGWA[ultra-fast mixed model association using sparse GRM]' \
  '--fastGWA-mlm[fast association analysis variant]' \
  '--cojo=[conditional and joint association analysis]:file:_files' \
  '--freq[output allele frequency estimates]' \
  '--ibc[estimate inbreeding coefficients]' \
  '--thread-num=[number of computational threads]:int' \
  '--recode[output genotypes in additive model format]' \
  '--blup-snp=[calculate BLUP solutions for SNP effects]:file:_files' && ret=0

return ret
