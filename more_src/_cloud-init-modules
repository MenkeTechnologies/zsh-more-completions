#compdef cloud-init-modules
# Documentation: https://docs.cloud-init.io/en/latest/reference/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# cloud-init-modules: helper wrapper to invoke cloud-init module set
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--mode=[cloud-init mode]:mode:(init config final)' \
  '--frequency=[execution frequency]:freq:(instance always once)' \
  '*::module names:' && ret=0
return ret
