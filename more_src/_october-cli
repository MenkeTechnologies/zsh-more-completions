#compdef october-cli
# _october-cli — Sam Georges OctoberCMS self-hosted PHP CMS CLI alias (octobercms team, PHP); artisan-based
# upstream: https://github.com/octobercms/october

_october-cli() {
    local -a sub=(
        'october:install:install october'
        'october:env:create .env'
        'october:up:run migrations'
        'october:down:rollback migrations'
        'october:fresh:fresh install'
        'october:passwd:reset password'
        'october:update:run updates'
        'october:util:utility cmds'
        'october:test:test commands'
        'october:mirror:create symlinks'
        'october:bundle:bundle assets'
        'october:scaffold:scaffold'
        'plugin:install:install plugin'
        'plugin:remove:remove plugin'
        'plugin:refresh:refresh plugin'
        'plugin:rollback:rollback plugin'
        'plugin:disable:disable plugin'
        'plugin:enable:enable plugin'
        'plugin:list:list plugins'
        'plugin:check:check plugins'
        'theme:install:install theme'
        'theme:remove:remove theme'
        'theme:use:set active theme'
        'theme:list:list themes'
        'theme:sync:sync theme'
        'theme:check:check theme'
        'cache:clear:clear cache'
        'project:get:get project info'
        'project:set:set project'
        'project:sync:sync project'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'october subcommand' sub ;;
        args)
            case $words[1] in
                plugin:install|plugin:remove|plugin:refresh|plugin:rollback|plugin:disable|plugin:enable|plugin:check) _arguments '1:plugin:' ;;
                theme:install|theme:remove|theme:use|theme:sync|theme:check) _arguments '1:theme:' ;;
            esac
            ;;
    esac
}

_october-cli "$@"
