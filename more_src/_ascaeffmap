#compdef ascaeffmap
# Documentation: https://heasarc.gsfc.nasa.gov/ftools/caldb/help/ascaeffmap.txt
# Generates an ASCA detector efficiency map in detector coordinates

local ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  'phafile=[name of the input spectral file]:pha file:_files' \
  'chip=[CCD chip ID string (SIS only)]:chip:' \
  'pha_lo=[lower boundary of pulse-height channels]:channel:' \
  'pha_hi=[upper boundary of pulse-height channels]:channel:' \
  'outfile=[output file name]:output file:_files' \
  'rmffile=[name of the input RMF file or CALDB]:rmf file:_files' \
  'wmapfile=[name of the input WMAP file]:wmap file:_files' \
  'teldef=[telescope definition file (SIS only)]:teldef file:_files' \
  'clobber=[overwrite existing output file]:flag:(yes no)' \
  'xrteff=[multiply by the XRT effective area]:flag:(yes no)' \
  'gispsf=[convolve with the GIS point spread function]:flag:(yes no)' \
  'bethick=[GIS Be thickness detector map filename]:file:_files' \
  'grid=[GIS grid detector map filename]:file:_files' \
  'xrtrsp=[path to the XRT effective area file]:file:_files' \
  '*:file:_files' && ret=0

return ret
