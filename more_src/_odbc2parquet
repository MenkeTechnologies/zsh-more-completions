#compdef odbc2parquet

# Zsh completion for odbc2parquet

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-c --connection-string)'{-c,--connection-string}'[ODBC connection string]:dsn' \
  '(-q --query)'{-q,--query}'[SQL query]:query' \
  '(-o --output)'{-o,--output}'[Parquet output]:file:_files' \
  '*:: : _message "see odbc2parquet --help"' && ret=0

return ret
