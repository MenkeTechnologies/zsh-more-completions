#compdef hhmake
# Documentation: https://github.com/soedinglab/hh-suite/wiki
# HHmake: build an HHM profile HMM from an input multiple sequence alignment

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-i+[query alignment A2M/A3M/FASTA or query HMM]:input file:_files' \
  '-o+[HMM file to be written to]:hhm file:_files' \
  '-a+[HMM file to be appended to]:hhm file:_files' \
  '-v+[verbose mode]:level:(0 1 2)' \
  '-seq+[max query/template sequences displayed]:int' \
  '-add_cons[make consensus sequence master sequence of query MSA]' \
  '-name+[use this name for HMM]:name' \
  '-id+[maximum pairwise sequence identity]:int' \
  '-diff+[filter MSA by selecting most diverse set]:int' \
  '-cov+[minimum coverage with query]:int' \
  '-qid+[minimum sequence identity with query]:int' \
  '-qsc+[minimum score per column with query]:num' \
  '-neff+[target diversity of alignment]:num' \
  '-M+[input alignment format: a2m/first/percentage]:mode' \
  '-nocontxt[use substitution-matrix instead of context-specific pseudocounts]' \
  '-contxt+[context file for context-specific pseudocounts]:file:_files' \
  '-maxseq+[max number of input rows]:int' \
  '-maxres+[max number of HMM columns]:int' && ret=0

return ret
