#compdef nbmerge
# Documentation: https://man.archlinux.org/search?q=nbmerge
# Reference accessed: 2026-05-16

# nbmerge: three-way merge of Jupyter notebooks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '-i[ignore inputs]' \
  '-o[output notebook]:file:_files -g "*.ipynb"' \
  '--out=[output notebook]:file:_files -g "*.ipynb"' \
  '--no-color[no color]' \
  '-s[ignore sources]' \
  '--strategy=[merge strategy]:strategy:(inline-cells use-base use-local use-remote union mergetool)' \
  '--filter-conflicts[filter conflicts only]' \
  '--merge-strategy=[merge strategy]:strategy:(inline-cells use-base use-local use-remote union mergetool)' \
  '*:base local remote:_files -g "*.ipynb"' && ret=0
return ret
