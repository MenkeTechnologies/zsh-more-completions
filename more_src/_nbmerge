#compdef nbmerge
# Documentation: https://nbdime.readthedocs.io/en/latest/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nbmerge: three-way merge of Jupyter notebooks
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --sources)'{-s,--sources}'[process source cells]' \
  '(-o --outputs)'{-o,--outputs}'[process output cells]' \
  '(-a --attachments)'{-a,--attachments}'[process attachments]' \
  '(-m --metadata)'{-m,--metadata}'[process metadata]' \
  '--out=[output notebook]:file:_files -g "*.ipynb"' \
  '--no-color[disable color output]' \
  '--merge-strategy=[merge strategy]:strategy:(inline use-base use-local use-remote union)' \
  '--input-strategy=[input merge strategy]:strategy:(inline use-base use-local use-remote union)' \
  '--output-strategy=[output merge strategy]:strategy:(inline use-base use-local use-remote union remove clear-all)' \
  '*:base local remote:_files -g "*.ipynb"' && ret=0
return ret
