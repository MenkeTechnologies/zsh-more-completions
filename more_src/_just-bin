#compdef just
# _just-bin — just command runner (Casey Rodarmor, Rust); Makefile-like task runner with first-class shells/templating
# upstream: https://github.com/casey/just

_just-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--alias-style+[alias style]:style:(left right separate)' \
        '--allow-missing[allow missing recipes]' \
        '--changelog[print changelog]' \
        '--check[check formatting]' \
        '--choose[choose recipe via menu]' \
        '--choose-style+[choose style]:style:(default raw verbose)' \
        '--clear-shell-args[clear shell args]' \
        '--color+[color]:when:(auto always never)' \
        '--command+[run command instead]:cmd:' \
        '-c+[run command instead]:cmd:' \
        '--command-color+[command color]:color:(black blue cyan green purple red yellow)' \
        '--completions+[print completions]:shell:(bash zsh fish powershell elvish nushell)' \
        '--dotenv-filename+[dotenv filename]:str:' \
        '--dotenv-path+[dotenv path]:file:_files' \
        '-d+[dotenv path]:file:_files' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--dump[dump justfile]' \
        '--dump-format+[dump format]:fmt:(just json)' \
        '-e[edit justfile]' \
        '--edit[edit justfile]' \
        '--evaluate[evaluate variables]' \
        '--explain[explain recipes]' \
        '--fmt[reformat justfile]' \
        '--global-justfile[use global justfile]' \
        '-g[use global justfile]' \
        '--groups[list groups]' \
        '--init[create new justfile]' \
        '--justfile+[justfile path]:file:_files' \
        '-f+[justfile path]:file:_files' \
        '--list[list recipes]' \
        '-l[list recipes]' \
        '--list-heading+[list heading]:str:' \
        '--list-prefix+[list prefix]:str:' \
        '--list-submodules[list submodules]' \
        '--no-aliases[no aliases]' \
        '--no-deps[no deps]' \
        '--no-dotenv[no dotenv]' \
        '--no-highlight[no highlight]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--set+[set variable]:KEY VAL:' \
        '--shell+[shell to invoke]:shell:_command_names -e' \
        '--shell-arg+[shell arg]:arg:' \
        '--show+[show recipe]:recipe:' \
        '-s+[show recipe]:recipe:' \
        '--summary[summary]' \
        '--timestamp[timestamp output]' \
        '--timestamp-format+[timestamp format]:fmt:' \
        '--unsorted[unsorted]' \
        '-u[unsorted]' \
        '--unstable[enable unstable]' \
        '--variables[print variables]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--working-directory+[working dir]:dir:_files -/' \
        '-d+[working dir]:dir:_files -/' \
        '--yes[skip confirmation]' \
        '*:recipe:'
}

_just-bin "$@"
