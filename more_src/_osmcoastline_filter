#compdef osmcoastline_filter
# Documentation: https://docs.osmcode.org/osmcoastline/latest/osmcoastline_filter.html
# Filter out coastline data from an OSM file for use by osmcoastline.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-f --format)'{-f+,--format=}'[output format (default pbf)]:format:_default' \
  '(-o --output)'{-o+,--output=}'[output OSM file]:file:_files' \
  '*:OSM input file:_files -g "*.(osm|osm.bz2|osm.pbf|osm.gz|opl)(-.)"' && ret=0

return ret
