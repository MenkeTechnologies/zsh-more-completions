#compdef seqmagick
# Documentation: https://github.com/fhcrc/seqmagick
# seqmagick - manipulate and convert sequence files

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:subcommand:(convert mogrify info quality-filter primer-trim extract-ids backtrans-align)' \
  '*::args:_files' && ret=0

return ret
