#compdef blacksheep
# Documentation: https://www.neoteroi.dev/blacksheep/cli/
# BlackSheep CLI - bootstrap projects for the BlackSheep ASGI web framework

local ret=1

local -a cmds
cmds=(
  'create:Bootstrap a new project from a template'
  'templates:Manage project templates'
)

_arguments -s -C \
  '--help[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds) _describe -t commands 'blacksheep command' cmds && ret=0 ;;
  args)
    case $words[1] in
      templates)
        local -a sub
        sub=(
          'list:List available templates'
          'details:Show details for a template'
          'add:Register a new template'
          'remove:Unregister a template'
        )
        _arguments -s \
          '--help[show help]' \
          '-d[template description]:description' \
          '1:subcommand:->subcmds' \
          '*:arg:' && ret=0
        [[ $state == subcmds ]] && { _describe -t subcommands 'templates subcommand' sub && ret=0 }
        ;;
      create) _arguments '--help[show help]' '*:name:' && ret=0 ;;
    esac
    ;;
esac

return ret
