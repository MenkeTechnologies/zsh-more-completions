#compdef glasskube

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--namespace=[Kubernetes namespace]:namespace' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'install:install a package'
      'uninstall:uninstall a package'
      'list:list installed packages'
      'describe:describe a package'
      'update:update packages'
      'configure:configure an installed package'
      'open:open a package in the browser'
      'repo:manage package repositories'
      'bootstrap:bootstrap glasskube in a cluster'
      'version:print version information'
      'completion:generate shell completions'
    )
    _describe -t commands 'glasskube command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' \
          '--version=[package version]:version' \
          '--repo=[repository name]:repository' \
          '--enable-auto-update[enable automatic updates]' \
          '1:package name' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' \
          '1:package name' && ret=0
        ;;
      (list)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '--outdated[show only outdated packages]' && ret=0
        ;;
      (describe)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '1:package name' && ret=0
        ;;
      (update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '(-y --yes)'{-y,--yes}'[skip confirmation prompt]' \
          '--all[update all packages]' \
          '--version=[target version]:version' \
          '1:package name' && ret=0
        ;;
      (configure)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '1:package name' && ret=0
        ;;
      (open)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--namespace=[Kubernetes namespace]:namespace' \
          '1:package name' && ret=0
        ;;
      (repo)
        local -a repo_cmds=(
          'add:add a repository'
          'list:list repositories'
          'remove:remove a repository'
        )
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '1:repo command:_describe -t repo-cmds "repo command" repo_cmds' \
          '*:arguments' && ret=0
        ;;
      (bootstrap)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--type=[installation type]:type:(flux helm)' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
