#compdef ip-link
# Documentation: https://man.archlinux.org/man/ip-link.8.en
# ip link - network device configuration

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ip link command' \
      'add[create virtual link]' \
      'delete[remove virtual link]' \
      'set[change device attributes]' \
      'change[change device attributes]' \
      'show[display device attributes]' \
      'xstats[display extended statistics]' \
      'afstats[display address-family statistics]' \
      'property[manage device properties]' \
      'help[show help]' \
      'link[physical device]' 'name[device name]' 'type[device type]' \
      'mtu[maximum transmission unit]' 'address[link layer address]' \
      'broadcast[broadcast address]' 'txqueuelen[transmit queue length]' \
      'netns[network namespace]' 'numtxqueues[tx queue count]' \
      'numrxqueues[rx queue count]' 'dev[target device]' \
      'up[activate interface]' 'down[deactivate interface]' \
      'master[enslave to device]' 'nomaster[release from master]' \
      'arp[toggle ARP]' 'multicast[toggle multicast]' \
      'promisc[toggle promiscuous mode]' 'xdp[attach/detach XDP program]' \
      'group[assign device group]' 'alias[symbolic name]' && ret=0
    ;;
esac

return ret
