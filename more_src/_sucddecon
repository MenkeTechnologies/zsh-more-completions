#compdef sucddecon
# Documentation: https://raw.githubusercontent.com/JohnWStockwellJr/SeisUnix/master/src/su/main/decon_shaping/sucddecon.c
# Convolution / correlation Deconvolution of SU data with a given filter

local ret=1

_arguments -s -S \
  'filter=[ascii filter values separated by commas]:filter' \
  'sufile=[file containing SU traces to use as filter]:file:_files' \
  'panel=[0 first trace only, 1 decon entire gather trace by trace]:panel:(0 1)' \
  'pnoise=[white noise factor for stabilizing results]:pnoise' \
  'sym=[0 not centered, 1 center the output on each trace]:sym:(0 1)' \
  'verbose=[0 silent, 1 chatty]:verbose:(0 1)' \
  '*:file:_files' && ret=0

return ret
