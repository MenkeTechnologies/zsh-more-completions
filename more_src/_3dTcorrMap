#compdef 3dTcorrMap
# Documentation: https://afni.nimh.nih.gov/pub/dist/doc/program_help/3dTcorrMap.html
# AFNI: voxelwise average correlation maps from a 3D+time dataset

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-input[input 3D+time dataset]:dataset:_files' \
  '-seed[separate seed 3D+time dataset]:dataset:_files' \
  '-mask[mask dataset]:mask:_files' \
  '-automask[create mask from input]' \
  '-polort[polynomial detrend order]:p:' \
  '-bpass[bandpass filter (fbot ftop)]:fbot ftop:' \
  '-ort[time series to project out]:file:_files' \
  '-Gblur[Gaussian blur FWHM in mm]:fwhm:' \
  '-Mseed[radius for averaging seed voxels]:r:' \
  '-Mean[output mean correlation dataset]:prefix:_files' \
  '-Zmean[output mean of arctanh(r)]:prefix:_files' \
  '-Qmean[output mean of r^2]:prefix:_files' \
  '-Pmean[output mean of positive r]:prefix:_files' \
  '-Thresh[count of |r| above threshold]:thr prefix:_files' \
  '-VarThresh[fraction above thresholds (lo hi delta)]:lo hi delta prefix:' \
  '-VarThreshN[normalized variable threshold]:lo hi delta prefix:' \
  '-CorrMap[save full correlation map per voxel]:prefix:_files' \
  '-CorrMask[apply mask to CorrMap output]' \
  '-Aexpr[apply expression and average]:expr prefix:' \
  '-Cexpr[apply expression and count]:expr prefix:' \
  '-Sexpr[apply expression and sum]:expr prefix:' \
  '-Hist[output correlation histogram]:nbin prefix:' \
  '*:dataset:_files' && ret=0

return ret
