#compdef clex
# Documentation: https://manpages.debian.org/bookworm/clex/clex.1.en.html
# Reference accessed: 2026-05-30
# clex — Vlado Potisk's ncurses file manager. Minimal CLI surface (3 flags);
# all behavior is keymap-driven inside the TUI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help and exit]' \
  '(- *)--version[show program version + basic info and exit]' \
  '--log=[append log information to file]:logfile:_files' \
  && ret=0

return ret
