#compdef tinydns-data
# _tinydns-data — djbdns tinydns-data (compile the `data` text file in the current directory into the `data.cdb` consumed by tinydns/walldns/axfrdns; renames data.tmp atomically when done)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from tinydns-data.c on tip; no positional args — looks for ./data.

_tinydns-data() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]'
}

_tinydns-data "$@"
