#compdef nodeadm
# ============================================================================
#  _nodeadm — AWS EKS Node Admin: From zero to Node faster than you can say
#             "Elastic Kubernetes Service"
#
#  Source-direct extraction from
#    https://github.com/awslabs/amazon-eks-ami/blob/main/nodeadm/cmd/nodeadm/main.go
#    https://github.com/awslabs/amazon-eks-ami/blob/main/nodeadm/cmd/nodeadm/{init,config}/*.go
#    https://github.com/awslabs/amazon-eks-ami/blob/main/nodeadm/internal/cli/*.go
#    https://github.com/integrii/flaggy (the flaggy library)
#
#  Maintained by AWS Labs (awslabs/amazon-eks-ami).  2650 GH stars.  nodeadm
#  is the Node Admin bootstrap CLI shipped in AWS-managed EKS AMIs — runs
#  on EC2 instances as they boot into an EKS cluster and bootstraps the
#  containerd + kubelet daemons + retrieves config from IMDS user-data or
#  files.  Sister tools: kubeadm (Kubernetes bootstrapper, in corpus),
#  k3s (K3s server, in corpus), eksctl (EKS provisioning, in corpus).
#
#  CLI library taxonomy update: 7th Go CLI library — integrii/flaggy.
#  Go ecosystem now has 7 documented CLI libraries (cobra/urfave-cli/
#  kingpin/spf13-pflag/alecthomas-kong/alexflint-go-arg/flaggy) — Go's
#  documented-CLI-library count tied for 2nd place behind Rust 9.
#  flaggy is Eric Greer's (integrii) Go CLI parser — designed as a
#  POINTER-BASED alternative to cobra/urfave-cli that AVOIDS the
#  proc-macro/codegen reflection complexity.  Imperative builder where
#  flags are bound to USER-PROVIDED POINTERS (`flaggy.Bool(&dest, "d",
#  "debug", "help")`), subcommands via `flaggy.NewSubcommand("verb")` +
#  `flaggy.AttachSubcommand(sub, position)`.  Used by:
#    - lazydocker (jesseduffield/lazydocker 51225 stars — IN CORPUS)
#    - lazygit (jesseduffield/lazygit 78697 stars — IN CORPUS)
#    - kuberhealthy (Kubernetes synthetic check operator)
#    - nodeadm (THIS — AWS EKS bootstrap CLI)
#    - sleep-on-lan (SR-G/sleep-on-lan)
#  Brings cross-language CLI library taxonomy variant count to 89; Go
#  ecosystem now has 7 documented CLI libraries.
#
#  Surface (verbatim from cmd/nodeadm/*.go):
#
#  Global flag (via flaggy.Bool):
#    -d, --development           Enable development mode for logging
#
#  Subcommands (via cli.NewCommandContainer + flaggy.AttachSubcommand):
#    config                      Manage configuration
#      check                     Verify configuration
#        -c, --config-source URI (repeatable)  Config source URI
#                                              (imds:// or file://)
#      dump                      Dump configuration
#        -c, --config-source URI (repeatable)
#            --config-cache PATH               Resolved config cache file
#        -o, --config-output FILE              Write resolved config (JSON)
#    init                        Initialize this instance as an EKS node
#      -d, --daemon NAME (repeatable)  Specific daemon to bootstrap
#                                      (containerd|kubelet) — TEST USE ONLY
#      -s, --skip PHASE (repeatable)   Phases of bootstrap to skip
#      -c, --config-source URI (repeatable)
#          --config-cache PATH         Resolved config cache file
#
#  Default config sources (when -c not specified):
#    imds://user-data
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - lazydocker (jesseduffield/lazydocker 51225 stars — IN CORPUS)
#    - lazygit (jesseduffield/lazygit 78697 stars — IN CORPUS)
#    - kuberhealthy (kuberhealthy/kuberhealthy 2238 stars — only 3 flags,
#      thin surface)
#    - sleep-on-lan (SR-G/sleep-on-lan 458 stars — narrow Wake-on-LAN)
#    - hkmgr (bensallen/hkmgr — narrow xhyve helper)
# ============================================================================

_nodeadm() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-d --development)'{-d,--development}'[enable development mode for logging]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'config:manage nodeadm configuration'
        'init:initialize this instance as an EKS node'
      )
      _describe -t commands 'nodeadm subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        config)
          if [[ $CURRENT == 2 ]]; then
            local -a sub=(
              'check:verify configuration'
              'dump:dump configuration'
            )
            _describe -t subcommands 'config subcommand' sub
          else
            case $line[2] in
              check)
                _arguments -s -S \
                  '*'{-c,--config-source}'=[config source URI (imds:// or file://)]:URI'
                ;;
              dump)
                _arguments -s -S \
                  '*'{-c,--config-source}'=[config source URI]:URI' \
                  '--config-cache=[resolved config cache file path]:cache file:_files' \
                  '(-o --config-output)'{-o,--config-output}'=[write resolved config (JSON) to file]:file:_files'
                ;;
            esac
          fi
          ;;
        init)
          _arguments -s -S \
            '*'{-d,--daemon}'=[specific daemon to bootstrap (TEST USE ONLY)]:daemon:(containerd kubelet)' \
            '*'{-s,--skip}'=[phase of bootstrap to skip]:phase' \
            '*'{-c,--config-source}'=[config source URI]:URI' \
            '--config-cache=[resolved config cache file path]:cache file:_files'
          ;;
      esac
      ;;
  esac
}

_nodeadm "$@"
