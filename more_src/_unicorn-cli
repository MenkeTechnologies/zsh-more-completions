#compdef unicorn-cli unicorn-tool
# _unicorn-cli — Nguyen Anh Quynh Unicorn unicorn-cli CLI lightweight multi-platform multi-architecture CPU emulator framework command-line frontend around the Unicorn-engine library emulating shellcode hex code from stdin or args supporting x86 x86_64 ARM ARM64 MIPS PowerPC SPARC M68K RISC-V S390X TriCore architecture (Nguyen Anh Quynh team, C); getopt
# upstream: https://www.unicorn-engine.org/

_unicorn-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[address]:str:' \
        '-q[quiet]' \
        '-r+[registers dump]:str:' \
        '-s+[step count]:n:' \
        '-c+[hook callback]:str:' \
        '-m+[mem map base:size]:str:' \
        '-i+[init regs]:str:' \
        '*:arch+hex:_files'
}

_unicorn-cli "$@"
