#compdef newsboat

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-r,--refresh-on-start}'[refresh feeds on start]' \
  {-e,--export-to-opml}'[export feeds as OPML]' \
  '(-i --import-from-opml)'{-i,--import-from-opml}'[import OPML file]:OPML file:_files -g "*.opml"' \
  '(-u --url-file)'{-u,--url-file}'[specify URL file]:URL file:_files' \
  '(-c --cache-file)'{-c,--cache-file}'[specify cache file]:cache file:_files' \
  '(-C --config-file)'{-C,--config-file}'[specify configuration file]:config file:_files' \
  '(-X --vacuum)'{-X,--vacuum}'[compact the cache]' \
  '(-x --execute)'{-x,--execute}'[execute commands]:commands' \
  {-q,--quiet}'[quiet startup]' \
  '(-l --log-file)'{-l,--log-file}'[specify log file]:log file:_files' \
  '(-d --log-level)'{-d,--log-level}'[specify log level]:log level:(1 2 3 4 5 6)' \
  '(-E --export-to-file)'{-E,--export-to-file}'[export articles to file]:output file:_files' \
  '(-I --import-from-file)'{-I,--import-from-file}'[import articles from file]:input file:_files' \
  && ret=0

return ret
