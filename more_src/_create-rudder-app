#compdef create-rudder-app
# Documentation: https://github.com/rudderjs/rudder/blob/main/docs/guide/installation.md
# Reference accessed: 2026-05-24
# Verified: npm view create-rudder-app bin; Rudder installation guide at the URL above.

# Zsh completion for create-rudder-app - RudderJS app scaffolder (alias of create-rudder)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--recipe=[scaffold recipe]:recipe:(web-app saas api-service realtime minimal custom)' \
  '--db=[database]:db:(sqlite postgresql mysql)' \
  '--framework=[frontend framework]:framework:(react vue solid none)' \
  '--styling=[styling preset]:styling:(tailwind+shadcn tailwind plain)' \
  '--packages=[custom package list when recipe is custom]:packages:' \
  '--db-ready=[Postgres/MySQL running now]:ready:(true false)' \
  '--git=[run git init and initial commit]:git:(true false)' \
  '--install=[install deps and run post-scaffold cascade]:install:(true false)' \
  '--json[force JSON output for agents/CI]' \
  '--interactive[force interactive prompt UI]' \
  ':project name:' && ret=0

return ret
