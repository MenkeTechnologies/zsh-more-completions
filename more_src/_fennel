#compdef fennel

# Zsh completion for fennel - Fennel Lisp compiler/interpreter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--repl[start interactive REPL]' \
  '--compile[compile Fennel to Lua]:file:_files -g "*.fnl"' \
  '--eval[evaluate expression]:expression' \
  '-e[evaluate expression]:expression' \
  '--no-searcher[skip installing package.searchers entry]' \
  '--add-fennel-path[add path to fennel.path]:pattern' \
  '--add-macro-path[add path to fennel.macro-path]:pattern' \
  '--add-package-path[add path to package.path]:pattern' \
  '--add-package-cpath[add path to package.cpath]:pattern' \
  '--globals[allow global references]:globals (comma-separated)' \
  '--globals-only[restrict to listed globals]:globals (comma-separated)' \
  '--require-as-include[inline required modules]' \
  '--skip-include[skip inlining specific modules]:modules' \
  '--use-bit-lib[use LuaJIT bit library for bitwise ops]' \
  '--metadata[enable function metadata]' \
  '--no-metadata[disable function metadata]' \
  '--correlate[add line correlation comments in output]' \
  '--load[load and run file]:file:_files -g "*.fnl"' \
  '--no-compiler-sandbox[disable compiler sandbox]' \
  '--compile-binary[compile to standalone binary]:entry file:_files -g "*.fnl"' \
  '--plugin[activate compiler plugin]:plugin file:_files -g "*.fnl"' \
  '--raw[skip Lua module wrapper]' \
  '--indent[custom indentation]:indent string' \
  '--assert-compile[raise on compile errors]' \
  '*:file:_files -g "*.fnl"' && ret=0

return ret
