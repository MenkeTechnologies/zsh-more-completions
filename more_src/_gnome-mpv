#compdef gnome-mpv celluloid
# Documentation: https://github.com/celluloid-player/celluloid/blob/master/src/celluloid-application.c
# Reference accessed: 2026-05-16
# Verified: src/celluloid-application.c g_application_add_main_option calls
# (lines 522-580). All custom options use short_name '\0' so there are no
# short-form aliases.
# Removed from prior file: -h (no short form in g_application_add_main_option
# definitions; only --help long form via GApplication auto-help).

# GNOME MPV / Celluloid: GTK frontend for mpv
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)--version[show release version]' \
  '--enqueue[enqueue files in running instance]' \
  '--new-window[create a new window]' \
  '--mpv-options=[options to pass to mpv]:OPTIONS:' \
  '--role=[set the window role]:role:' \
  '--no-existing-session[do not connect to running instance]' \
  '*:media:_files' && ret=0
return ret
