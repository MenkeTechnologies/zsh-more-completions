#compdef gnome-mpv celluloid
# Documentation: https://celluloid-player.github.io/
# Reference accessed: 2026-05-16

# GNOME MPV / Celluloid: GTK frontend for mpv
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all GTK help]' \
  '(- *)--help-gtk[show GTK help]' \
  '(- *)--version[show version]' \
  '--new-window[start a new window]' \
  '--no-existing-session[do not connect to running instance]' \
  '--enqueue[queue files in running instance]' \
  '--mpv-options=[options to pass through to mpv]:opts:' \
  '*:media:_files' && ret=0
return ret
