#compdef lt localtunnel

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-p,--port}'=[local port to expose]:port' \
  {-h,--host}'=[upstream server URL]:host url' \
  {-s,--subdomain}'=[request specific subdomain]:subdomain' \
  {-l,--local-host}'=[proxy to a hostname other than localhost]:host' \
  '--local-https[tunnel traffic to a local HTTPS server]' \
  '--local-cert=[path to local certificate]:cert file:_files' \
  '--local-key=[path to local key]:key file:_files' \
  '--local-ca=[path to local CA certificate]:ca file:_files' \
  '--allow-invalid-cert[disable certificate checks for local HTTPS]' \
  {-o,--open}'[open tunnel URL in browser]' \
  '--print-requests[print basic request info]' && ret=0

return ret
