#compdef zli
# _zli — zot OCI registry client CLI (project-zot/zot)
# upstream: https://github.com/project-zot/zot
# Subcommands from pkg/cli/client/cli.go (cobra).

_zli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'config:manage zli config (server URLs, defaults)'
                'image:image-level operations against a registry'
                'cve:scan/list CVE info for images'
                'repo:repository-level operations'
                'search:search across registries'
                'server-status:check whether the configured server is up'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config) _arguments '1:sub:(add reset remove update list)' ;;
                image) _arguments '1:sub:(list name digest cve derived base layers)' ;;
                cve) _arguments '1:sub:(list affected fixed-in scan)' ;;
                repo) _arguments '1:sub:(list)' ;;
            esac
            ;;
    esac
}

_zli "$@"
