#compdef suspike
# Documentation: https://github.com/JohnWStockwellJr/SeisUnix/blob/master/src/su/main/synthetics_waveforms_testpatterns/suspike.c
# SUSPIKE - make a small spike data set

local ret=1

_arguments -s -S \
  'nt=[number of time samples]:n:' \
  'ntr=[number of traces]:n:' \
  'dt=[time sampling interval (sec)]:d:' \
  'offset=[offset]:o:' \
  'nspk=[number of spikes]:n:' \
  'ix1=[trace number (from left) for spike #1]:i:' \
  'it1=[time sample to spike #1]:i:' \
  '*:SU file:_files' && ret=0

return ret
