#compdef ANTS
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ANTS.cxx — legacy ANTs registration tool (C++; mixed flag/positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-m+[similarity model: CC/MI/PR/MSQ with spec [fixed,moving,weight,bins/radius]]:spec:_default' \
    '-o+[output filename base]:file:_files' \
    '-i+[max iterations per level (e.g. 30x20x0)]:iters:_default' \
    '-r+[regularization (e.g. Gauss[3,1])]:reg:_default' \
    '-t+[transformation model (Elast[3]/Syn[GradStep,...]/SyN[GradStep,2,...]/Affine/Translation)]:transform:_default' \
    '--number-of-affine-iterations=[affine iterations]:iters:_default' \
    '--rigid-affine=[rigid-only affine]:n:(0 1 true false)' \
    '--use-Histogram-Matching[match intensities between images]' \
    '--MI-option=[MI histogram bins,samples]:spec:_default' \
    '--continue-affine=[continue affine registration]:n:(0 1 true false)' \
    '--do-rigid=[rigid-only at first stage]:n:(0 1 true false)' \
    '--affine-gradient-descent-option=[affine GD spec]:spec:_default' \
    '--initial-affine=[initial affine transform file]:file:_files' \
    '--fixed-image-initial-affine=[fixed-image initial affine transform]:file:_files' \
    '--geodesic=[geodesic SyN flag]:n:_default' \
    '--gaussian-smoothing-sigmas=[per-level Gaussian smoothing sigmas]:spec:_default' \
    '--subsampling-factors=[per-level subsampling factors]:spec:_default' \
    '1:ImageDimension:(2 3 4)' \
    && ret=0

return ret
