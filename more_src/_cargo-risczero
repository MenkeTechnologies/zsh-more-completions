#compdef cargo-risczero
# Documentation: https://raw.githubusercontent.com/risc0/risc0/main/risc0/cargo-risczero/src/lib.rs
# Reference accessed: 2026-05-27
# Verified: upstream Commands enum in risc0/cargo-risczero/src/lib.rs and per-subcommand structs in risc0/cargo-risczero/src/commands/

local curcontext="$curcontext" state line ret=1

local -a _cargo_risczero_subcommands
_cargo_risczero_subcommands=(
  'bake:bake guest code'
  'build:build guest code'
  'build-toolchain:build the riscv32im-risc0-zkvm-elf toolchain'
  'guest:guest commands (experimental feature)'
  'install:install the riscv32im-risc0-zkvm-elf toolchain'
  'new:create a new risczero starter project'
  'verify:verify that a receipt is valid'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'cargo-risczero subcommand' _cargo_risczero_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      new)
        _arguments \
          '--tag=[git tag of the risc0 template repository]:tag:' \
          '--branch=[git branch of the risc0 template repository]:branch:' \
          '--dest=[destination directory for the new project]:dir:_files -/' \
          '--use-git-branch[use a git branch rather than a tag for the template]' \
          '--no-std[scaffold a no_std guest]' \
          '--path=[path to a local template instead of the remote repository]:path:_files -/' \
          '--guest-name=[name of the guest crate inside the new project]:name:' \
          '1:project name:' && ret=0
        ;;
      build)
        _arguments \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '--features=[space or comma separated features to activate]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate the default feature]' \
          '(-p --package)'{-p+,--package=}'[package to build]:package:' \
          '--workspace[build all packages in the workspace]' \
          '--exclude=[exclude a package from the workspace build]:package:' && ret=0
        ;;
      bake)
        _arguments \
          '--manifest-path=[path to Cargo.toml]:file:_files -g "*.toml"' \
          '--features=[space or comma separated features to activate]:features:' \
          '--all-features[activate all available features]' \
          '--no-default-features[do not activate the default feature]' \
          '(-p --package)'{-p+,--package=}'[package to bake]:package:' \
          '--workspace[bake all packages in the workspace]' \
          '--exclude=[exclude a package from the workspace bake]:package:' \
          '--docker[run compilation in a Docker container for reproducible builds]' && ret=0
        ;;
      build-toolchain)
        _arguments \
          '--version=[version tag of the toolchain to build]:tag:' && ret=0
        ;;
      install)
        _arguments \
          '--version=[toolchain version to install]:version:' && ret=0
        ;;
      verify)
        _arguments \
          '--path=[path to the receipt file]:file:_files' \
          '--id=[Bonsai ID of the receipt to download and verify]:id:' \
          '1:image_id:' && ret=0
        ;;
      guest)
        local -a _guest_subs
        _guest_subs=(
          'build:invoke cargo build on the guest crate'
          'test:invoke cargo test --no-run on the guest crate'
        )
        _arguments \
          '--manifest-path=[path to the guest Cargo.toml]:file:_files -g "*.toml"' \
          '--target-dir=[output directory for build artifacts]:dir:_files -/' \
          '1: :->guestcmd' \
          '*:cargo arg:' && ret=0
        if [[ $state == guestcmd ]]; then
          _describe -t commands 'guest subcommand' _guest_subs && ret=0
        fi
        ;;
      *)
        _arguments '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
