#compdef tidb tidb-server

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[TOML config file]:file:_files -g "*.toml"' \
  '--config-check[check config and exit]' \
  '--config-strict[strict config mode]' \
  '--store=[storage engine]:engine:(unistore tikv mocktikv)' \
  '--path=[storage path / PD endpoint]:path_or_endpoint:' \
  '--host=[bind host]:host:_hosts' \
  '-P+[MySQL service port]:port:' \
  '--port=[MySQL service port]:port:' \
  '--socket=[socket path]:file:_files' \
  '--status-host=[status host]:host:_hosts' \
  '--status=[status port]:port:' \
  '--metrics-addr=[Prometheus push gateway addr]:addr:' \
  '--metrics-interval=[Prometheus push interval]:duration:' \
  '--log-file=[log file path]:file:_files' \
  '--log-level=[log level]:level:(debug info warn error fatal)' \
  '--log-slow-query=[slow query log file]:file:_files' \
  '--tz=[time zone]:tz:' \
  '--lease=[schema lease]:duration:' \
  '--token-limit=[concurrent session limit]:n:' \
  '--report-status[report status]' \
  '--repair-mode[enable repair mode]' \
  '*--repair-list=[repaired table list]:tables:' \
  '--proxy-protocol-networks=[proxy protocol allowed networks]:cidr:' \
  '--proxy-protocol-header-timeout=[proxy header timeout]:duration:' \
  '--enable-binlog[enable binlog]' \
  '--initialize-secure[initialize root account securely]' \
  '--initialize-insecure[initialize without password]' \
  '--cors=[CORS allowed origin]:origin:' \
  '*::passthrough:' && ret=0

return ret
