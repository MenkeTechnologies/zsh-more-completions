#compdef osu_get_latency
# Documentation: https://github.com/forresti/osu-micro-benchmarks/blob/master/README
# OSU MPI one-sided (RMA) micro-benchmark

local ret=1

_arguments -s \
  '-w[window initialization method]:method:(create allocate dynamic)' \
  '-s[synchronization type]:sync:(lock flush flush_local lock_all pscw fence)' \
  '-x[number of warmup iterations to skip]:count:' \
  '-i[number of iterations per message length]:count:' \
  '-h[display help message]' && ret=0

return ret
