#compdef staticcheck
# _staticcheck-bin — Go staticcheck linter (Dominik Honnef, Go); 100+ checks for bugs + performance + style
# upstream: https://staticcheck.dev

_staticcheck-bin() {
    _arguments \
        '-checks+[checks list]:checks:' \
        '-fail+[fail on checks]:checks:' \
        '-explain+[explain a check]:check:' \
        '-show-ignored[show ignored]' \
        '-go+[Go version]:ver:' \
        '-tags+[build tags]:tags:' \
        '-tests[include tests]' \
        '-debug.cpuprofile+[CPU profile]:file:_files' \
        '-debug.memprofile+[mem profile]:file:_files' \
        '-debug.match+[match]:str:' \
        '-debug.measure+[measure file]:file:_files' \
        '-debug.no-compile-errors[no compile errors output]' \
        '-debug.repeat-analysis+[repeat]:n:' \
        '-debug.version[print check versions]' \
        '-f+[output format]:fmt:(text json stylish binary sarif)' \
        '-formatter+[output format]:fmt:(text json stylish binary sarif)' \
        '-list-checks[list available checks]' \
        '-merge[merge configs]' \
        '-matrix[matrix config]' \
        '-unused.whole-program[deprecated]' \
        '-v[verbose]' \
        '-version[show version]' \
        '*:packages:'
}

_staticcheck-bin "$@"
