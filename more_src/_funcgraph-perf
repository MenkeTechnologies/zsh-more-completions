#compdef funcgraph-perf
# Documentation: https://github.com/brendangregg/perf-tools/blob/master/man/man8/funcgraph.8
# trace kernel function graph, showing child function calls (perf-tools)

local ret=1

_arguments -s -S \
  '(-h)-h[show usage message]' \
  '-a[all info, same as -HPt]' \
  '-C[measure on-CPU time only]' \
  '-d+[trace duration in seconds, use buffers]:secs' \
  '-D[do not show function duration]' \
  '-H[include column headers]' \
  '-m+[max stack depth to show]:maxdepth' \
  '-p+[trace when this PID is on-CPU]:pid:_pids' \
  '-L+[trace when this thread is on-CPU]:tid' \
  '-P[show process names and PIDs]' \
  '-t[show timestamps]' \
  '-T[comment function tails]' \
  '*:kernel function:' && ret=0

return ret
