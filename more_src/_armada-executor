#compdef armada-executor executor
# _armada-executor — Armada per-cluster executor (relays Armada jobs into Kubernetes Pods + reports their state back to the scheduler)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/executor/main.go on tip; everything except --config is read from the YAML config file (./config/executor or --config) via viper.

_armada-executor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"'
}

_armada-executor "$@"
