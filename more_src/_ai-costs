#compdef ai-costs
# Documentation: https://github.com/patrickespake/ai_cli_management
# Reference accessed: 2026-05-23
# Verified: ai_global_installer.sh ai-costs wrapper (see _ai-manager).

# Zsh completion for ai-costs - AI systems cost analysis

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'ai-costs command' \
      'analysis[show cost analysis]' \
      'help[show help]' && ret=0
    ;;
esac

return ret
