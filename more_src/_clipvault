#compdef clipvault
# Documentation: https://github.com/Rolv-Apneseth/clipvault
# clipvault - clipboard history manager for Wayland, inspired by cliphist

local ret=1
local curcontext="$curcontext" state line

_arguments -s -C \
  '(-d --database)'{-d,--database}'[path to the database file]:database:_files' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'clipvault command' \
      'list[display saved clipboard entries with previews]' \
      'store[listen for clipboard changes and write entries to history]' \
      'get[retrieve a clipboard entry for output]' \
      'delete[remove an entry from history]' \
      'clear[remove all entries from the database]' && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments -s \
          '(-w --max-preview-width)'{-w,--max-preview-width}'[maximum width of the preview column]:width:' \
          '(-r --reverse)'{-r,--reverse}'[reverse the order of the list]' && ret=0
        ;;
      store)
        _arguments -s \
          '--max-entries=[maximum number of entries to store]:count:' \
          '--max-entry-age=[maximum age for entries]:age:' \
          '--max-entry-length=[maximum length for entries]:length:' \
          '--min-entry-length=[minimum length for entries]:length:' \
          '--store-sensitive[store entries marked sensitive]' \
          '--ignore-pattern=[regex pattern of entries to ignore]:pattern:' \
          '--window-ignore-pattern=[regex pattern of source windows to ignore]:pattern:' && ret=0
        ;;
      get|delete)
        _arguments -s \
          '--index=[entry by relative position (0=newest, -1=oldest)]:index:' \
          '1:input:' && ret=0
        ;;
    esac
    ;;
esac

return ret
