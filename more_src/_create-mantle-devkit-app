#compdef create-mantle-devkit-app
# Documentation: https://www.npmjs.com/package/create-mantle-devkit-app
# Reference accessed: 2026-05-24
# Verified: npm view create-mantle-devkit-app bin; npx create-mantle-devkit-app --help output.

# Zsh completion for create-mantle-devkit-app - Mantle x402 and Agent Kit scaffolder

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--x402[create an x402 pay-per-request project]' \
  '--agent-kit[create an Agent Kit DeFi swap project]' \
  '--fullstack[create a fullstack x402 project]' \
  '--backend[create a backend-only x402 project]' \
  '--hono[use Hono backend framework]' \
  '--express[use Express backend framework]' \
  '--npm[use npm as package manager]' \
  '--yarn[use yarn as package manager]' \
  '--pnpm[use pnpm as package manager]' \
  '--bun[use bun as package manager]' \
  '--skip-install[skip dependency installation]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  ':project name:' && ret=0

return ret
