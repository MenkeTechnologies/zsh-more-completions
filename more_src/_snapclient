#compdef snapclient
# Documentation: https://man.archlinux.org/search?q=snapclient
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--list[list audio output devices]' \
  '(-H --host)'{-H,--host}'=[server host]:host:_hosts' \
  '(-p --port)'{-p,--port}'=[server port]:port:' \
  '(-s --soundcard)'{-s,--soundcard}'=[audio output device]:device:' \
  '--player=[audio player]:player:(alsa pulse file)' \
  '--hostID=[host ID]:id:' \
  '(-i --instance)'{-i,--instance}'=[instance number]:instance:' \
  '(-d --daemon)'{-d,--daemon}'=[daemonize]:daemon:(0 1)' \
  '--user=[run as user]:user:_users' \
  '--latency=[latency in ms]:milliseconds:' \
  '--logfilter=[log filter]:filter:(trace debug info notice warning error fatal)' \
  '--logsink=[log sink]:sink:(null system stdout stderr file)' \
  '--sharingmode=[sharing mode]:mode:(shared exclusive)' \
  '--mixer=[mixer mode]:mode:(software hardware script none)' \
  '*:file:_files' && ret=0

return ret
