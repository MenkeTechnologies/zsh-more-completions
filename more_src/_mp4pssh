#compdef mp4pssh
# Documentation: https://github.com/axiomatic-systems/Bento4/blob/master/Source/C%2B%2B/Apps/Mp4Pssh/Mp4Pssh.cpp
# Bento4 MP4 PSSH box editor

local ret=1

_arguments -s -S \
  '*--insert[insert a PSSH box]:system-id-hex\:pssh-data-file' \
  '*--remove[remove a PSSH box by system id]:system-id-hex' \
  '*--replace[replace a PSSH box]:system-id-hex\:pssh-data-file' \
  '*:file:_files -g "*.mp4"' && ret=0

return ret
