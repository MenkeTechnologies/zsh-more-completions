#compdef tpgains
# Documentation: https://lweb.cfa.harvard.edu/sma/miriad/manuals/SMAuguide/smauserhtml/tpgains.html
# Estimate antenna gains from total power measurements

local ret=1

_arguments -s \
  'vis=[input visibility data file]:dataset:_files' \
  'again=[amplitude factor again*sqrt(total_power/systemp)]:again' \
  'rgain=[amplitude factor rgain*sqrt(systemp/total_power)]:rgain' \
  'pgain=[antenna phase shift in degrees per Kelvin]:pgain' \
  'scale=[three coefficients per antenna to scale total power to systemp]:scale' \
  'refant=[reference antenna for relative gains (default 0)]:refant' \
  'out=[output calibration file]:dataset:_files' \
  '*:dataset:_files' && ret=0

return ret
