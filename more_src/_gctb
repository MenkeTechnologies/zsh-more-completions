#compdef gctb
# Documentation: https://gctbhub.cloud.edu.au/software/gctb/
# GCTB Bayesian genome-wide complex trait analysis (SBayesR / BayesS)

local ret=1

_arguments -s -S \
  '--bfile=[PLINK binary file prefix]:prefix:_files' \
  '--pheno=[phenotype file]:file:_files' \
  '--mpheno=[phenotype column index]:col' \
  '--covar=[covariate file]:file:_files' \
  '--random-covar=[random-effect covariate file]:file:_files' \
  '--keep=[keep listed individuals]:file:_files' \
  '--chr=[restrict to chromosome]:chr' \
  '--extract=[extract listed SNPs]:file:_files' \
  '--exclude=[exclude listed SNPs]:file:_files' \
  '--out=[output filename root]:prefix:_files' \
  '--seed=[random seed]:seed' \
  '--chain-length=[MCMC chain length]:n' \
  '--burn-in=[MCMC burn-in iterations]:n' \
  '--out-freq=[output frequency]:n' \
  '--thin=[MCMC thinning interval]:n' \
  '--no-mcmc-bin[do not write MCMC binary samples]' \
  '--bayes=[individual-level Bayesian model]:model' \
  '--sbayes=[summary-data Bayesian model]:model' \
  '--gwfm=[genome-wide fine-mapping]:model' \
  '--fix-pi[fix mixture probabilities]' \
  '--pi=[mixture probabilities]:pi' \
  '--gamma=[scaling factors]:gamma' \
  '--hsq=[starting heritability]:hsq' \
  '--S=[starting S parameter]:s' \
  '--wind=[LD window size]:kb' \
  '--var-random=[random-effect variance]:var' \
  '--ldm=[LD matrix file]:file:_files' \
  '--mldm=[multiple LD matrix list]:file:_files' \
  '--make-full-ldm[build full LD matrix]' \
  '--make-sparse-ldm[build sparse LD matrix]' \
  '--make-shrunk-ldm[build shrunk LD matrix]' \
  '--make-band-ldm[build banded LD matrix]' \
  '--snp=[SNP range for LD matrix]:range' \
  '--gwas-summary=[GWAS summary statistics file]:file:_files' \
  '--impute-n[impute per-SNP sample size]' \
  '--exclude-mhc[exclude MHC region]' \
  '--ambiguous-snp[keep strand-ambiguous SNPs]' \
  '--maf=[minor allele frequency threshold]:maf' \
  '--rsq=[imputation R-squared threshold]:rsq' \
  '--p-value=[p-value threshold]:p' \
  '--unscale-genotype[do not scale genotypes]' \
  '--overlap=[sample overlap proportion]:val' \
  '--robust[robust parameterisation]' \
  '--num-chains=[number of MCMC chains]:n' \
  '--annot=[annotation file]:file:_files' \
  '--thread=[number of threads]:n' \
  '*:file:_files' && ret=0

return ret
