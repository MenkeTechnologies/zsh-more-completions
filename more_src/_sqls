#compdef sqls

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
  '(-l --log)'{-l,--log}'[path to log file]:file:_files' \
  '--trace[enable trace logging]' \
  && ret=0

return ret
