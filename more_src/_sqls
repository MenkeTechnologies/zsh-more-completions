#compdef sqls
# Documentation: https://github.com/lighttiger2505/sqls
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Only -config is documented in the README; flag set is minimal.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-config=[path to config file]:file:_files' \
  && ret=0

return ret
