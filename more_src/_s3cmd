#compdef s3cmd

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '--configure[invoke interactive configuration tool]' \
  '(-c --config)'{-c,--config}'[config file name]:config file:_files' \
  '--access_key[AWS access key]:access key' \
  '--secret_key[AWS secret key]:secret key' \
  '--access_token[AWS access token]:access token' \
  {-n,--dry-run}'[only show what would be done]' \
  {-s,--ssl}'[use HTTPS connection]' \
  '--no-ssl[do not use HTTPS]' \
  {-e,--encrypt}'[encrypt files before uploading]' \
  '--no-encrypt[do not encrypt files]' \
  {-f,--force}'[force overwrite and other dangerous operations]' \
  '--continue[continue interrupted upload]' \
  '--continue-put[continue interrupted upload for multipart]' \
  '--upload-id[use specified upload ID for multipart]:upload ID' \
  {-r,--recursive}'[recursive upload, download or removal]' \
  '--check-md5[check MD5 sums when comparing files]' \
  {-P,--acl-public}'[store objects with ACL allowing read for anyone]' \
  '--acl-private[store objects with default ACL]' \
  '--acl-grant[grant stated permission to a given amazon user]:permission' \
  '--acl-revoke[revoke stated permission for a given user]:permission' \
  {-D,--restore-days}'[number of days for restored object]:days' \
  '--restore-priority[restore priority]:priority:(bulk standard expedited)' \
  '--delete-removed[delete remote objects with no corresponding local file]' \
  '--no-delete-removed[do not delete remote objects]' \
  '--delete-after[delete old files after syncing]' \
  '--delay-updates[put all updated files into place at end]' \
  '--max-delete[do not delete more than NUM files]:number' \
  '--limit[limit number of objects returned]:limit' \
  '--add-destination[additional sync destination]:destination' \
  {-p,--preserve}'[preserve filesystem attributes]' \
  '--no-preserve[do not preserve attributes]' \
  '--exclude[exclude files matching pattern]:pattern' \
  '--exclude-from[read exclude patterns from file]:file:_files' \
  '--rexclude[exclude files matching regex]:regex' \
  '--rexclude-from[read regex exclude patterns from file]:file:_files' \
  '--include[include files matching pattern]:pattern' \
  '--include-from[read include patterns from file]:file:_files' \
  '--rinclude[include files matching regex]:regex' \
  '--rinclude-from[read regex include patterns from file]:file:_files' \
  '--bucket-location[datacentre to create bucket in]:location' \
  '--host[override hostname]:hostname' \
  '--host-bucket[override bucket hostname]:hostname' \
  '--reduced-redundancy[store object with reduced redundancy]' \
  '--no-reduced-redundancy[store object with full redundancy]' \
  '--storage-class[set storage class]:class:(STANDARD REDUCED_REDUNDANCY STANDARD_IA ONEZONE_IA INTELLIGENT_TIERING GLACIER DEEP_ARCHIVE)' \
  '--requester-pays[requester pays mode]' \
  {-m,--mime-type}'[default MIME-type]:mime type' \
  '--guess-mime-type[guess MIME-type from file extension]' \
  '--no-guess-mime-type[do not guess MIME-type]' \
  '--default-mime-type[default MIME-type for unrecognized files]:mime type' \
  '--add-header[add HTTP header]:header:' \
  '--remove-header[remove HTTP header]:header name' \
  '--server-side-encryption[use server-side encryption]' \
  '--server-side-encryption-kms-id[KMS key ID]:key ID' \
  '--encoding[override detected encoding]:encoding' \
  '--verbatim[use the S3 name as given]' \
  '--list-md5[include MD5 sums in bucket listings]' \
  {-H,--human-readable-sizes}'[print sizes in human readable form]' \
  '--ws-index[website index file]:index file' \
  '--ws-error[website error file]:error file' \
  '--expiry-date[objects expiry date]:date' \
  '--expiry-days[objects expiry in days]:days' \
  '--expiry-prefix[objects expiry prefix]:prefix' \
  '--progress[display progress meter]' \
  '--no-progress[do not display progress meter]' \
  '--stats[display stats after transfer]' \
  '--enable[enable feature]:feature' \
  '--disable[disable feature]:feature' \
  {-v,--verbose}'[display more information]' \
  {-d,--debug}'[display debug output]' \
  {-q,--quiet}'[silence output on stdout]' \
  '--ca-certs[path to SSL CA certificate file]:ca certs:_files' \
  '--check-certificate[check SSL certificate]' \
  '--no-check-certificate[do not check SSL certificate]' \
  '--signature-v2[use signature v2]' \
  '--region[specify region]:region' \
  '--multipart-chunk-size-mb[size of each chunk for multipart uploads]:size in MB' \
  '1:command:->command' \
  '*::arg:->args' \
  && ret=0

case $state in
  command)
    local -a commands=(
      'mb:make bucket'
      'rb:remove bucket'
      'ls:list objects or buckets'
      'la:list all objects in all buckets'
      'put:put file into bucket'
      'get:get file from bucket'
      'del:delete file from bucket'
      'rm:delete file from bucket'
      'restore:restore file from Glacier'
      'sync:synchronize a directory tree to S3'
      'du:disk usage by buckets'
      'info:get various information about buckets or files'
      'cp:copy object'
      'modify:modify object metadata'
      'mv:move object'
      'setacl:modify access control list for bucket or files'
      'setpolicy:modify bucket policy'
      'delpolicy:delete bucket policy'
      'setcors:modify bucket CORS'
      'delcors:delete bucket CORS'
      'payer:modify bucket requester pays policy'
      'multipart:show multipart uploads'
      'abortmp:abort a multipart upload'
      'listmp:list parts of a multipart upload'
      'accesslog:enable/disable access logging'
      'sign:sign arbitrary string using the secret key'
      'signurl:sign an S3 URL for temporary access'
      'fixbucket:fix bucket file names'
      'expire:set or delete expiration rule'
      'setlifecycle:upload lifecycle policy for bucket'
      'getlifecycle:get lifecycle policy for bucket'
      'dellifecycle:remove lifecycle policy for bucket'
      'cflist:list CloudFront distributions'
      'cfinfo:display CloudFront distribution details'
      'cfcreate:create CloudFront distribution'
      'cfdelete:delete CloudFront distribution'
      'cfmodify:modify CloudFront distribution'
      'cfinvalinfo:display CloudFront invalidation request details'
      'ws-create:create website from bucket'
      'ws-delete:delete website'
      'ws-info:info about website'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
