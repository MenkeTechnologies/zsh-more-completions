#compdef llvm-bolt
# Documentation: https://github.com/llvm/llvm-project/blob/main/bolt/docs/OptimizingClang.md
# BOLT post-link binary optimizer

local ret=1

_arguments -s \
  '(-help --help)'{-help,--help}'[show help]' \
  '-help-hidden[show hidden options]' \
  '--version[show version]' \
  '-o=[write optimized binary to file]:output:_files' \
  '-data=[profile data file in BOLT format]:data:_files' \
  '-reorder-blocks=[basic block reordering algorithm]:algo:(none normal reverse ext-tsp cache cache+)' \
  '-reorder-functions=[function reordering algorithm]:algo:(none exec-count hfsort hfsort+ cdsort pettis-hansen random user)' \
  '-split-functions[split functions into hot and cold parts]' \
  '-split-all-cold[split all cold code]' \
  '-split-eh[split exception handling code]' \
  '-dyno-stats[print dynamic execution statistics]' \
  '-dyno-stats-all[print all dyno-stats]' \
  '-update-debug-sections[update DWARF debug sections]' \
  '-instrument[instrument binary for profile collection]' \
  '-relocs[use relocations in the binary]' \
  '-use-gnu-stack[use GNU_STACK segment for new code]' \
  '-lite[skip optimization of cold functions]' \
  '-jump-tables=[jump table support]:mode:(none basic move split aggressive)' \
  '-icf=[identical code folding]:mode:(none all safe)' \
  '-funcs=[only process functions matching regex]:regex' \
  '-funcs-file=[only process functions listed in file]:file:_files' \
  '-skip-funcs=[do not process functions matching regex]:regex' \
  '-max-funcs=[maximum number of functions to process]:n' \
  '-keep-nops[do not remove NOP instructions]' \
  '-eliminate-unreachable[eliminate unreachable code]' \
  '-strip-rep-ret[strip repz prefix from ret]' \
  '-simplify-conditional-tail-calls[simplify conditional tail calls]' \
  '-simplify-rodata-loads[simplify loads from read-only data]' \
  '-inline-memcpy[inline memcpy calls]' \
  '-peepholes=[peephole optimizations]:mode' \
  '-frame-opt=[clear caller-saved registers in frames]:mode:(none hot all)' \
  '-shorten-instructions[shorten instructions]' \
  '-cmov-conversion[convert mov to cmov]' \
  '-reg-reassign[reassign registers to use shorter encoding]' \
  '-verify-cfg[verify control flow graph after optimization]' \
  '-print-all[print all functions]' \
  '-print-cfg[print control flow graph]' \
  '-print-disasm[print disassembly]' \
  '-dump-dot-all[dump CFG of all functions in dot format]' \
  '-keep-tmp[preserve temporary files]' \
  '*:input binary:_files' && ret=0

return ret
