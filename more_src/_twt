#compdef twt

# Zsh completion for twt (twitch-tui crate, Xithrius/twitch-tui).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --channel)'{-c,--channel=}'[Twitch channel/login]:channel:' \
  '(-l --log-file)'{-l,--log-file=}'[log file path]:file:_files' \
  '(-v --verbose)'{-v,--verbose=}'[enable debug logs true/false]:bool:(true false)' \
  '(-d --delay)'{-d,--delay=}'[UI tick delay in ms]:int:' \
  '(-m --max-messages)'{-m,--max-messages=}'[ring buffer size]:count:' \
  '(-s --show-datetimes)'{-s,--show-datetimes}'[show timestamps on messages]' \
  '(-p --palette)'{-p,--palette=}'[username color palette]:palette:(pastel vibrant warm cool)' \
  '(-b --badges)'{-b,--badges}'[show Twitch badges]' \
  '(-t --theme)'{-t,--theme=}'[light/dark UI]:theme:(light dark)' \
  '(-f --first-state)'{-f,--first-state=}'[initial UI mode]:state:(start normal help)' \
  '(-u --unsupported-screen-size)'{-u,--unsupported-screen-size}'[warn when terminal too small]'
