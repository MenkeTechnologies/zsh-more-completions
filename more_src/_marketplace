#compdef marketplace
# Documentation: https://github.com/openshift-eng/edge-tooling/blob/main/marketplace
# Reference accessed: 2026-05-19
# Verified: openshift-eng/edge-tooling marketplace script (Plugin Marketplace CLI).
# Removed from prior file: the prior contents were the marketplace bash
# source itself, not a zsh completion. Replaced with a real _marketplace
# function derived from the script's case statement in main().

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list all available plugins'
  'ls:list all available plugins'
  'search:search plugins by name or description'
  'show:show detailed information about a plugin'
  'info:show detailed information about a plugin'
  'validate:validate plugin structure and metadata'
  'new:create new plugin from template'
  'create:create new plugin from template'
  'add:add components to an existing plugin'
  'catalog-update:rebuild marketplace catalog'
  'completion:generate shell completion script'
  'help:show help text'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'marketplace command' commands && ret=0
    ;;
  args)
    case $line[1] in
      new|create|add)
        _arguments \
          '1:plugin name:' \
          '--skill[include a skill]' \
          '--hook[include hooks]' \
          '--mcp[include MCP server config]' \
          '--agent[include agent definition]' && ret=0
        ;;
      completion)
        _values 'shell' bash zsh && ret=0
        ;;
      search)
        _arguments '1:query:' && ret=0
        ;;
      list|ls)
        _arguments '1:filter:' && ret=0
        ;;
    esac
    ;;
esac

return ret
