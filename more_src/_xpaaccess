#compdef xpaaccess
# Documentation: https://github.com/ericmandel/xpa/blob/master/doc/pod/xpaaccess.pod
# Determine whether a template matches registered XPA access points

local ret=1

_arguments -s -S \
  '-c[contact each access point individually]' \
  '-h[display help message]' \
  '-i+[access XPA point on a different machine]:nsinet' \
  '-m+[override XPA_METHOD]:method' \
  '-n[return number of matches instead of yes/no]' \
  '-t+[short,long timeout values]:sval,lval' \
  '-u+[restrict to XPA points from users]:users' \
  '-v[show info about each successful access point]' \
  '-V[show info or error details about each access point]' \
  '--version[show version information]' \
  '1:template' \
  '2::type' && ret=0

return ret
