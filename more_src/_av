#compdef av

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'stack:manage stacked branches'
  'pr:manage pull requests'
  'commit:manage commits'
  'auth:manage authentication'
  'init:initialize av in the repository'
  'fetch:fetch latest branch metadata'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'av command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      stack)
        local -a stack_cmds=(
          'branch:create a new stacked branch'
          'diff:show diff for the current stack'
          'next:navigate to the next branch in the stack'
          'prev:navigate to the previous branch in the stack'
          'restack:rebase the current stack'
          'submit:create/update pull requests for the stack'
          'sync:synchronize the stack with trunk'
          'switch:switch to a different stack'
          'tree:show the stack tree'
          'tidy:tidy up stacks'
          'adopt:adopt an existing branch into a stack'
          'reparent:reparent a branch in the stack'
          'reorder:reorder branches in the stack'
        )
        _arguments -s -S \
          '1:stack command:->stack_cmd' && ret=0
        case "$state" in
          stack_cmd)
            _describe -t commands 'stack subcommand' stack_cmds && ret=0
            ;;
        esac
        ;;
      pr)
        local -a pr_cmds=(
          'create:create a pull request'
          'queue:add pull request to merge queue'
        )
        _arguments -s -S \
          '1:pr command:->pr_cmd' && ret=0
        case "$state" in
          pr_cmd)
            _describe -t commands 'pr subcommand' pr_cmds && ret=0
            ;;
        esac
        ;;
      commit)
        local -a commit_cmds=(
          'create:create a new commit'
          'amend:amend the current commit'
          'split:split the current commit'
          'squash:squash commits'
        )
        _arguments -s -S \
          '1:commit command:->commit_cmd' && ret=0
        case "$state" in
          commit_cmd)
            _describe -t commands 'commit subcommand' commit_cmds && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
