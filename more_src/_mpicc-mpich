#compdef mpicc-mpich
# Documentation: https://www.mpich.org/static/docs/v3.3/www1/mpicc.html
# Reference accessed: 2026-05-16
# Verified: MPICH 3.3 mpicc(1) docs. Pass-through to underlying C
# compiler.
# Removed from prior file: bogus man.archlinux.org search URL.

# mpicc-mpich: MPICH C compiler wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-show[show underlying compiler invocation]' \
  '-compile_info[show compile info]' \
  '-link_info[show link info]' \
  '-echo[echo commands]' \
  '-config=[MPICH config name]:name:' \
  '-cc=[underlying C compiler override]:compiler:_command_names' \
  '-profile=[profiling library]:lib:' \
  '-help[show help]' \
  '-nativelinker[use native linker]' \
  '*:C source:_files -g "*.(c|h|o|a|so)(-.)"' && ret=0
return ret
