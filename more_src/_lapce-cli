#compdef lapce

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --wait)'{-w,--wait}'[wait for editor close]' \
  '(-n --new)'{-n,--new}'[force new window]' \
  '(--proxy)--proxy[run proxy mode]' \
  '*: :_files' && ret=0

return ret
