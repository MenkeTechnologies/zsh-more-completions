#compdef lapce
# Documentation: https://github.com/lapce/lapce/blob/master/lapce-app/src/app.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Alternate compdef alias for the lapce binary. The "--proxy" flag belongs
# to the lapce-proxy binary (a hidden Cli option), not the main lapce CLI,
# so it is intentionally omitted here. Mirrors flags in lapce-app/src/app.rs.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-w --wait)'{-w,--wait}'[do not return instantly when opened in a terminal]' \
  '(-n --new)'{-n,--new}'[launch new window even if Lapce is already running]' \
  '*--plugin-path=[path to plugin to load (for plugin development)]:path:_files -/' \
  '*: :_files' && ret=0

return ret
