#compdef kubectl-datadog
# Documentation: https://github.com/DataDog/datadog-operator/blob/main/docs/kubectl-plugin.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'agent:manage Datadog Agent operations'
      'autoscaling:autoscaling features (technical preview)'
      'clusteragent:manage Cluster Agent operations'
      'completion:generate shell autocompletion scripts'
      'flare:collect a Datadog Operator flare and send it to Datadog'
      'get:get DatadogAgent deployment(s)'
      'helm2dda:map Helm values to DatadogAgent CRD schema'
      'metrics:access metrics functionality'
      'validate:validate configurations'
    )
    _describe -t commands 'kubectl-datadog command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      agent)
        _arguments -s -S '1:subcommand:(check find upgrade)' && ret=0
        ;;
      clusteragent)
        _arguments -s -S '1:subcommand:(leader upgrade)' && ret=0
        ;;
      validate)
        _arguments -s -S '1:subcommand:(ad)' && ret=0
        ;;
    esac
    ;;
esac

return ret
