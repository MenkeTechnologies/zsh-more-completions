#compdef go-carbon
# Golang implementation of Graphite/Carbon server

local ret=1

_arguments -s -S \
  '(-h -help)'{-h,-help}'[show help]' \
  '-check-config[check config and exit]' \
  '-config=[filename of config]:_files' \
  '-config-print-default[print default config]' \
  '-daemon[run in background]' \
  '-pidfile=[pidfile path, only for daemon]:_files' \
  '-version[print version]' && ret=0

return ret
