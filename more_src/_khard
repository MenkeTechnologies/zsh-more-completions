#compdef khard
# Documentation: https://manpages.debian.org/testing/khard/khard.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for khard - console vCard contact manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list all (selected) contacts'
  'ls:list all (selected) contacts'
  'show:show details of a contact'
  'details:show details of a contact'
  'template:print an empty contact template'
  'birthdays:list birthdays'
  'bdays:list birthdays'
  'email:list email addresses'
  'phone:list phone numbers'
  'postaddress:list postal addresses'
  'post:list postal addresses'
  'postaddr:list postal addresses'
  'new:create a new contact'
  'add:create a new contact'
  'add-email:add an email address from stdin to a contact'
  'merge:merge two contacts'
  'edit:edit the data of a contact'
  'modify:edit the data of a contact'
  'ed:edit the data of a contact'
  'copy:copy a contact to another address book'
  'cp:copy a contact to another address book'
  'move:move a contact to another address book'
  'mv:move a contact to another address book'
  'remove:delete a contact'
  'delete:delete a contact'
  'del:delete a contact'
  'rm:delete a contact'
  'addressbooks:list all address books'
  'abooks:list all address books'
  'filename:print the filenames of contacts'
  'file:print the filenames of contacts'
)

_arguments -s -S \
  '(- *)-h[show help message and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-c --config)'{-c,--config}'[configuration file to use]:file:_files' \
  '--debug[enable debug output]' \
  '--skip-unparsable[skip unparsable vcard files]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'khard command' commands && ret=0
    ;;
  args)
    _arguments \
      '(- *)-h[show subcommand help]' \
      '*:search term:' && ret=0
    ;;
esac

return ret
