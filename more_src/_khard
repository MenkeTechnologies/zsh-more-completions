#compdef khard

# Zsh completion for khard - console vCard contact manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list contacts'
  'show:show contact details'
  'birthdays:list birthdays'
  'email:list email addresses'
  'phone:list phone numbers'
  'postaddr:list postal addresses'
  'new:create a new contact'
  'add-email:add email from stdin'
  'merge:merge two contacts'
  'modify:modify a contact'
  'copy:copy a contact to another address book'
  'move:move a contact to another address book'
  'remove:remove a contact'
  'template:create empty contact template'
  'filename:list contact filenames'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '(-a --addressbook)'{-a,--addressbook}'[specify address book]:address book' \
  '(-d --display)'{-d,--display}'[display property]:property:(first_name last_name formatted_name)' \
  '(-g --group-by-addressbook)'{-g,--group-by-addressbook}'[group results by address book]' \
  '(-p --parsable)'{-p,--parsable}'[machine-readable output]' \
  '(-s --search-in-source-files)'{-s,--search-in-source-files}'[search in source files]' \
  '(-S --sort)'{-S,--sort}'[sort field]:field:(first_name last_name formatted_name)' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '(-u --uid)'{-u,--uid}'[filter by UID]:uid' \
  '1:command:->command' \
  '*:search term' && ret=0

case $state in
  command)
    _describe -t commands 'khard command' commands && ret=0
    ;;
esac

return ret
