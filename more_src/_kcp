#compdef kcp

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start embedded etcd and KCP'
  'workspaces:manage workspaces'
  'kubectl:pass-through to kubectl for KCP'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[output kubeconfig path]:file:_files' \
  '--loglevel=[log level]:level:(error warn info debug)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kcp command' commands && ret=0
    ;;
  (args)
    _arguments '*:kcp options or sub-args: _default' && ret=0
    ;;
esac

return ret
