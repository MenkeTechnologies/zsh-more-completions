#compdef ptyxis

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-x --execute)'{-x+,--execute=}'[command to execute]:cmd:_command_names' \
  '--working-directory=[working directory]:dir:_files -/' \
  '-d+[set working directory]:dir:_files -/' \
  '--title=[window title]:title:' \
  '--maximize[start window maximized]' \
  '--standalone[start standalone instance]' \
  '--new-window[open new window]' \
  '--tab[open new tab]' \
  '--tab-with-profile=[open tab with profile UUID]:uuid:' \
  '--profile=[profile UUID]:uuid:' \
  '--display=[X display]:display:' \
  '--gapplication-service[run as application service]' \
  '*: :' && ret=0

return ret
