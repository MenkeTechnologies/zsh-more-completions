#compdef bedops
# Documentation: https://bedops.readthedocs.io/en/latest/content/reference/set-operations/bedops.html
# Documentation: https://github.com/bedops/bedops/blob/master/applications/bed/bedops/src/Input.hpp
# Reference accessed: 2026-05-27
# Verified: upstream Input.hpp argument parser and bedops.rst manual

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--help[show help message and exit]' \
  '--help-everything[show help for the --everything operation]' \
  '--help-union[show help for the --everything (union) operation]' \
  '--help-intersect[show help for the --intersect operation]' \
  '--help-difference[show help for the --difference operation]' \
  '--help-symmdiff[show help for the --symmdiff operation]' \
  '--help-merge[show help for the --merge operation]' \
  '--help-partition[show help for the --partition operation]' \
  '--help-complement[show help for the --complement operation]' \
  '--help-element-of[show help for the --element-of operation]' \
  '--help-not-element-of[show help for the --not-element-of operation]' \
  '--help-chop[show help for the --chop operation]' \
  '--version[show program version and citation info]' \
  '--ec[perform error checking on input compliance]' \
  '--header[accept BED/VCF/GFF/SAM/WIG headers in input files]' \
  '--chrom=[restrict operations to specified chromosome]:chromosome:' \
  '--range=[pad input coordinates (L:R asymmetric or single value symmetric)]:padding:' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-u,--everything}'[concatenate and sort all inputs (union)]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-i,--intersect}'[regions common to all input sets]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-d,--difference}'[regions in first file excluding others]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-s,--symmdiff}'[regions exclusive to each input (symmetric difference)]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-m,--merge}'[flatten overlapping/adjoining regions into contiguous segments]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-p,--partition}'[split overlapping regions into disjoint segments]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-c,--complement}'[output gaps between contiguous ranges]' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-e,--element-of}'[reference elements overlapping query sets]:overlap (bp or N%):' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-n,--not-element-of}'[reference elements NOT overlapping query sets]:overlap (bp or N%):' \
  '(-u --everything -i --intersect -d --difference -s --symmdiff -m --merge -p --partition -c --complement -e --element-of -n --not-element-of -w --chop)'{-w,--chop}'[merge then divide into uniform-length segments]:bp:' \
  '-L[output left-most gap per chromosome (with --complement)]' \
  '--stagger=[offset chop start positions (with --chop)]:nt:' \
  '-x[exclude remainder segments smaller than chop size (with --chop)]' \
  '*:bed file:_files -g "*.(bed|bed.gz|starch|vcf|gff|sam)(-.)"' && ret=0

return ret
