#compdef blender
# Documentation: https://man.archlinux.org/search?q=blender
# Reference accessed: 2026-05-16

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --background)'{-b,--background}'[background mode]' \
  '(-y --enable-autoexec)'{-y,--enable-autoexec}'[enable autoexec]' \
  '(-Y --disable-autoexec)'{-Y,--disable-autoexec}'[disable autoexec]' \
  '(--debug)*--debug[enable all debug]' \
  '(--debug-events)*--debug-events[debug events]' \
  '(--debug-ffmpeg)*--debug-ffmpeg[debug ffmpeg]' \
  '(--debug-handlers)*--debug-handlers[debug handlers]' \
  '(--debug-jobs)*--debug-jobs[debug jobs]' \
  '(--debug-libmv)*--debug-libmv[debug libmv]' \
  '(--debug-cycles)*--debug-cycles[debug cycles]' \
  '(--debug-memory)*--debug-memory[debug memory]' \
  '(--debug-python)*--debug-python[debug python]' \
  '(--debug-depsgraph)*--debug-depsgraph[debug depsgraph]' \
  '(--debug-gpu)*--debug-gpu[debug GPU]' \
  '(-d --debug)*-d[debug]' \
  '(--debug-fpe)*--debug-fpe[FP exceptions]' \
  '--debug-value=[value]:n:' \
  '--debug-exit-on-error[exit on error]' \
  '(--factory-startup)--factory-startup[factory startup]' \
  '(--enable-event-simulate)--enable-event-simulate[event simulate]' \
  '(-a --render-anim)'{-a,--render-anim}'[render animation]' \
  '(-S --scene)'{-S+,--scene=}'[scene name]:s:' \
  '(-f --render-frame)'{-f+,--render-frame=}'[render frame]:n:' \
  '(-s --frame-start)'{-s+,--frame-start=}'[start frame]:n:' \
  '(-e --frame-end)'{-e+,--frame-end=}'[end frame]:n:' \
  '(-j --frame-jump)'{-j+,--frame-jump=}'[frame jump]:n:' \
  '(-o --render-output)'{-o+,--render-output=}'[output path]:p:' \
  '(-E --engine)'{-E+,--engine=}'[render engine]:e:(BLENDER_EEVEE BLENDER_EEVEE_NEXT CYCLES BLENDER_WORKBENCH)' \
  '(-t --threads)'{-t+,--threads=}'[threads]:n:' \
  '(-x --use-extension)'{-x+,--use-extension=}'[use extension]:b:(0 1)' \
  '(-F --render-format)'{-F+,--render-format=}'[render format]:f:(TGA RAWTGA JPEG IRIS IRIZ AVIRAW AVIJPEG PNG BMP HDR TIFF EXR MULTILAYER MPEG CINEON DPX JP2 WEBP)' \
  '(-W --window-fullscreen)'{-W,--window-fullscreen}'[fullscreen]' \
  '(-w --window-border)'{-w,--window-border}'[window border]' \
  '(-p --window-geometry)'{-p+,--window-geometry=}'[geometry]:g:' \
  '(-M --no-window-focus)'{-M,--no-window-focus}'[no window focus]' \
  '(--start-console)--start-console[start console]' \
  '(--no-native-pixels)--no-native-pixels[no native pixels]' \
  '--gpu-backend=[GPU backend]:b:(opengl vulkan metal)' \
  '(--audio)--audio=[audio device]:d:(NULL OPENAL SDL JACK COREAUDIO PULSEAUDIO WASAPI)' \
  '--cycles-server[cycles server]' \
  '(-P --python)'{-P+,--python=}'[python script]:file:_files -g "*.py"' \
  '--python-text=[python text block]:t:' \
  '--python-expr=[python expression]:e:' \
  '--python-console[python console]' \
  '--python-exit-code=[exit code on err]:n:' \
  '--python-use-system-env[use system env]' \
  '--addons=[addons csv]:list:' \
  '(-r --register)'{-r,--register}'[register .blend]' \
  '(--register-allusers)--register-allusers[register all users]' \
  '(--unregister)--unregister[unregister .blend]' \
  '(--unregister-allusers)--unregister-allusers[unregister all]' \
  '(-R --register)'{-R,--register}'[register]' \
  '*: :_files -g "*.blend"' && ret=0

return ret
