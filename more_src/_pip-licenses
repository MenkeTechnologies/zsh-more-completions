#compdef pip-licenses

_arguments -s \
  '(-v --version)'{-v,--version}'[show version]' \
  '--python=[python executable]:file:_files' \
  '--from=[license source]:source:(meta classifier mixed all m c mix)' \
  '(-o --order)'{-o,--order}'=[order column]:col:(name license author url count)' \
  '(-f --format)'{-f,--format}'=[output format]:fmt:(plain plain-vertical markdown rst confluence html json json-license-finder csv)' \
  '--summary[license summary]' \
  '--output-file=[output file]:file:_files' \
  '*'{-i,--ignore-packages}'=[ignore]:pkg:' \
  '*'{-p,--packages}'=[only include]:pkg:' \
  '(-s --with-system)'{-s,--with-system}'[include system pkgs]' \
  '(-a --with-authors)'{-a,--with-authors}'[include authors]' \
  '--with-maintainers[include maintainers]' \
  '(-u --with-urls)'{-u,--with-urls}'[include URLs]' \
  '(-d --with-description)'{-d,--with-description}'[include description]' \
  '(-nv --no-version)'{-nv,--no-version}'[no version]' \
  '(-l --with-license-file)'{-l,--with-license-file}'[include license file]' \
  '--no-license-path[no license path]' \
  '--with-notice-file[include notice file]' \
  '--filter-strings[filter strings]' \
  '--filter-code-page=[code page]:cp:' \
  '--fail-on=[fail on licenses]:list:' \
  '--allow-only=[allow only licenses]:list:' \
  '--partial-match[partial match]' \
  '(- *)'{-h,--help}'[show help]'
