#compdef pip-licenses
# Documentation: https://pypi.org/project/pip-licenses/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--python=[python executable]:file:_files' \
  '--from=[license source]:source:(meta classifier mixed all expression)' \
  '--order=[order column]:col:(name license count)' \
  '--format=[output format]:fmt:(plain plain-vertical markdown md m rst rest r confluence c html h json j json-license-finder jlf csv)' \
  '--summary[license summary]' \
  '--output-file=[output file]:file:_files' \
  '--ignore-packages=[ignore packages]:pkg:' \
  '--packages=[only include packages]:pkg:' \
  '--with-system[include system packages]' \
  '--with-authors[include authors]' \
  '--with-maintainers[include maintainers]' \
  '--with-urls[include URLs]' \
  '--with-description[include description]' \
  '--no-version[omit version numbers]' \
  '--with-license-file[include license file path and content]' \
  '--no-license-path[hide license file paths]' \
  '--with-notice-file[include NOTICE file contents]' \
  '--filter-strings[remove unencodable characters]' \
  '--filter-code-page=[code page for filtering]:cp:' \
  '--fail-on=[fail on licenses]:list:' \
  '--allow-only=[allow only licenses]:list:' \
  '--partial-match[partial match for license verification]'
