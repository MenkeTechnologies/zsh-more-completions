#compdef gnostic
# _gnostic — compile OpenAPI specs to proto/JSON/YAML/binary models (google/gnostic)
# upstream: https://github.com/google/gnostic
# Flags from lib/gnostic.go.

_gnostic() {
    _arguments \
        '(- *)--help[show help]' \
        '--pb-out=[write binary proto to PATH]:file:_files' \
        '--text-out=[write text proto to PATH]:file:_files' \
        '--json-out=[write JSON API description to PATH]:file:_files -g "*.json"' \
        '--yaml-out=[write YAML API description to PATH]:file:_files -g "*.(yml|yaml)"' \
        '--errors-out=[write compilation errors to PATH]:file:_files' \
        '--messages-out=[write plugin messages to PATH]:file:_files' \
        '--resolve-refs[explicitly resolve $ref references]' \
        '--time-plugins[report plugin runtimes]' \
        '--no-surface[exclude surface model from plugins]' \
        '1:OpenAPI file:_files -g "*.(json|yml|yaml)"'
}

_gnostic "$@"
