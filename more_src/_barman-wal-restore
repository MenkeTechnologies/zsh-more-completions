#compdef barman-wal-restore
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/barman-wal-restore.1.html
# restore_command based on Barman's get-wal

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-U --user)'{-U,--user}'=[user for the ssh connection to the Barman server]:user' \
  '--port=[port of the Barman server SSH server]:port' \
  '(-s --sleep)'{-s,--sleep}'=[sleep seconds after a failed get-wal request]:seconds' \
  '(-p --parallel)'{-p,--parallel}'=[number of WAL files to prefetch in parallel]:num' \
  '--spool-dir=[spool directory for WAL prefetch]:dir:_files -/' \
  '(-P --partial)'{-P,--partial}'[include partial WAL files in retrieval]' \
  '(-z --gzip)'{-z,--gzip}'[transfer the WAL gzip-compressed]' \
  '(-j --bzip2)'{-j,--bzip2}'[transfer the WAL bzip2-compressed]' \
  '--keep-compression[do not uncompress the retrieved WAL]' \
  '(-c --config)'{-c,--config}'=[configuration file on the Barman server]:file:_files' \
  '(-t --test)'{-t,--test}'[test the connection and configuration]' \
  '1:barman host:_hosts' \
  '2:server name:' \
  '3:wal name:' \
  '4:wal dest:_files' && ret=0

return ret
