#
# THE asynqmon CLI
#
# asynqmon is a single-command web-server CLI
# built on Go's stdlib `flag` package (NOT cobra
# or urfave/cli).  Invocation:
#   asynqmon [flags...]
#
# Every flag has an env-var counterpart for
# Kubernetes-friendly deployment.
#
# Web server flags:
#   -port <N>                         port (default
#                                     8080; env PORT)
#
# Redis connection flags (mutually-exclusive
# topology):
#   -redis-addr <ADDR>                standalone Redis
#                                     (default
#                                     127.0.0.1:6379;
#                                     env REDIS_ADDR)
#   -redis-url <URL>                  Redis URL form
#                                     (overrides
#                                     individual
#                                     flags; env
#                                     REDIS_URL)
#   -redis-cluster-nodes <CSV>        Redis Cluster
#                                     nodes (comma-
#                                     separated
#                                     host:port; env
#                                     REDIS_CLUSTER_NODES)
#
# Redis auth + TLS flags:
#   -redis-db <N>                     non-default DB
#                                     (default 0;
#                                     env REDIS_DB)
#   -redis-password <PW>              password
#                                     (env REDIS_PASSWORD)
#   -redis-tls <SNI>                  TLS server name
#                                     (env REDIS_TLS)
#   -redis-insecure-tls               disable TLS
#                                     cert host
#                                     checks (env
#                                     REDIS_INSECURE_TLS)
#
# UI behavior flags:
#   -read-only                        view-only mode
#                                     (env READ_ONLY)
#   -max-payload-length <N>           UI max payload
#                                     chars (default
#                                     200; env
#                                     MAX_PAYLOAD_LENGTH)
#   -max-result-length <N>            UI max result
#                                     chars (default
#                                     200; env
#                                     MAX_RESULT_LENGTH)
#
# Prometheus flags:
#   -enable-metrics-exporter          enable /metrics
#                                     endpoint (env
#                                     ENABLE_METRICS_EXPORTER)
#   -prometheus-addr <ADDR>           Prometheus
#                                     server URL for
#                                     historical
#                                     charts (env
#                                     PROMETHEUS_ADDR)
#
# Common invocations:
#   # Default — connect to local Redis on 6379, serve UI on 8080
#   asynqmon
#
#   # Custom port
#   asynqmon -port 9090
#
#   # Connect to remote Redis with password
#   asynqmon -redis-addr redis.example.com:6379 \
#            -redis-password secret123
#
#   # Connect via Redis URL (overrides -redis-addr)
#   asynqmon -redis-url redis://user:pass@host:6379/0
#
#   # Connect to Redis Cluster
#   asynqmon -redis-cluster-nodes \
#       node1.cluster:6379,node2.cluster:6379,node3.cluster:6379
#
#   # TLS connection with SNI validation
#   asynqmon -redis-addr redis.example.com:6380 \
#            -redis-tls redis.example.com \
#            -redis-password tlspass
#
#   # Read-only dashboard for production exposure
#   asynqmon -read-only
#
#   # Enable Prometheus metrics exporter
#   asynqmon -enable-metrics-exporter
#
#   # Connect to Prometheus for historical charts
#   asynqmon -prometheus-addr http://prometheus:9090
#
#   # Truncate large payloads in UI
#   asynqmon -max-payload-length 500 -max-result-length 500
#
#   # Kubernetes-style env-var deployment
#   PORT=8080 \
#   REDIS_ADDR=redis-service:6379 \
#   READ_ONLY=true \
#   ENABLE_METRICS_EXPORTER=true \
#   asynqmon
#
#   # Docker run
#   docker run -p 8080:8080 \
#     -e REDIS_ADDR=host.docker.internal:6379 \
#     hibikenmono/asynqmon:latest
#
# OPTIONS (sourced directly from
# https://github.com/hibiken/asynqmon/blob/master/cmd/asynqmon/main.go):
#
# (See documentation above for the complete flag
# set + env-var counterparts.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,-help,--help}'[show help]' \
    '-port=[web UI server port (default 8080)]:port: ' \
    '-redis-addr=[standalone Redis address (default 127.0.0.1:6379)]:addr: ' \
    '-redis-db=[Redis database number (default 0)]:db: ' \
    '-redis-password=[Redis password]:password: ' \
    '-redis-tls=[TLS server name for cert validation]:sni: ' \
    '-redis-url=[Redis URL (overrides individual flags)]:url: ' \
    '-redis-insecure-tls[disable TLS certificate host checks]' \
    '-redis-cluster-nodes=[comma-separated Redis Cluster nodes]:nodes: ' \
    '-max-payload-length=[max UTF-8 chars in payload cell (default 200)]:n: ' \
    '-max-result-length=[max UTF-8 chars in result cell (default 200)]:n: ' \
    '-enable-metrics-exporter[enable Prometheus metrics exporter on /metrics]' \
    '-prometheus-addr=[Prometheus server URL for historical charts]:url: ' \
    '-read-only[restrict UI to read-only mode (no management actions)]' \
    && ret=0

return ret
