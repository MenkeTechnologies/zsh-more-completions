#compdef simpress
# _simpress — The Document Foundation LibreOffice simpress CLI symlink launching LibreOffice Impress the presentation application opening .odp .pptx .ppt .pps .otp template files with options for headless slideshow autoplay show convert-to PDF SWF PNG export from command line scripted batch builds (LibreOffice team, C++); getopt
# upstream: https://www.libreoffice.org/

_simpress() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--writer[start as Writer]' \
        '--calc[start as Calc]' \
        '--draw[start as Draw]' \
        '--impress[start as Impress]' \
        '--show=+[file]:file:_files' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--quickstart[quickstart mode]' \
        '--nologo[no logo]' \
        '--nodefault[no default doc]' \
        '--invisible[no UI window]' \
        '--minimized[start minimized]' \
        '--headless[headless mode]' \
        '--accept=+[connection string]:str:' \
        '--language=+[lang]:str:' \
        '--safe-mode[safe mode]' \
        '--convert-to+[output filter]:str:' \
        '--outdir=+[dir]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name=+[printer]:str:' \
        '--cat[print plain text to stdout]' \
        '--display=+[display]:str:' \
        '*:presentation:_files -g "*.odp *.pptx *.ppt *.pps *.otp *.fodp *.sxi *.sda *.uop"'
}

_simpress "$@"
