#compdef phono3py-coleigplot
# Documentation: https://phonopy.github.io/phono3py/auxiliary-tools.html
# Plot collision-matrix eigenvalues from phono3py results

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--temperature=[temperature to output data at]:temp' \
  '--savetxt[write coleigs to text file]' \
  '*:file:_files' && ret=0

return ret
