#compdef ansible-cmdb
# Documentation: https://man.archlinux.org/search?q=ansible-cmdb
# Reference accessed: 2026-05-16

# CMDB HTML from ansible facts — github.com/fboender/ansible-cmdb (optparse)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-t --template)'{-t,--template}'[template name]:template:(html_fancy)' \
  '(-i --inventory)'{-i,--inventory}'[extra inventory]:inventory file:_files' \
  '(-f --fact-cache)'{-f,--fact-cache}'[inputs are fact-cache files]' \
  '(-p --params)'{-p,--params}'[template params]' \
  '(-d --debug)'{-d,--debug}'[debug output]' \
  '(-q --quiet)'{-q,--quiet}'[suppress warnings]' \
  '(-c --columns)'{-c,--columns}'[only these columns]' \
  '(-C --cust-cols)'{-C,--cust-cols}'[custom columns file]:file:_files' \
  '(-l --limit)'{-l,--limit}'[limit hosts pattern]' \
  '--exclude-cols[exclude columns]' \
  '*::fact tree dir:_files -/' && ret=0

return ret
