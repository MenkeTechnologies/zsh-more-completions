#compdef create-postgres
# Documentation: https://www.npmjs.com/package/create-postgres
# Reference accessed: 2026-05-24
# Verified: npm view create-postgres bin; npx create-postgres --help; npx create-postgres create --help output.

# Zsh completion for create-postgres - temporary Prisma Postgres database CLI

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-V --version)'{-V,--version}'[output version number]'   '(-h --help)'{-h,--help}'[display help for command]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command' create regions && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -C           '(-r --region)'{-r,--region}'[AWS region]:region:(ap-southeast-1 ap-northeast-1 eu-central-1 eu-west-3 us-east-1 us-west-1)'           '(-i --interactive)'{-i,--interactive}'[interactive region selection]'           '(-j --json)'{-j,--json}'[output machine-readable JSON]'           '(-e --env)'{-e,--env}'[write DATABASE_URL to .env file]:file:_files'           '(-t --ttl)'{-t,--ttl}'[auto-delete after duration]:duration:'           '(-c --copy)'{-c,--copy}'[copy connection string to clipboard]'           '(-q --quiet)'{-q,--quiet}'[only output connection string]'           '(-o --open)'{-o,--open}'[open claim URL in browser]'           '(-h --help)'{-h,--help}'[display help for command]' && ret=0
        ;;
      regions)
        _arguments -C           '(-j --json)'{-j,--json}'[output machine-readable JSON]'           '(-h --help)'{-h,--help}'[display help for command]' && ret=0
        ;;
    esac
    ;;
esac

return ret
