#compdef kubectl-mc
# Documentation: https://github.com/jonnylangefeld/kubectl-mc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --regex)'{-r+,--regex=}'[cluster name regex]:pattern' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:kubectl arguments after --:_default'
