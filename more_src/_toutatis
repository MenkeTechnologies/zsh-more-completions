#compdef toutatis
# Documentation: https://github.com/megadose/toutatis
# OSINT: extract information from Instagram accounts via session id.

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --username)'{-u+,--username=}'[Instagram username to extract information from]:username:' \
  '(-i --id)'{-i+,--id=}'[Instagram ID to extract information from]:id:' \
  '(-s --sessionid)'{-s+,--sessionid=}'[Instagram session id for authentication]:sessionid:' && ret=0

return ret
