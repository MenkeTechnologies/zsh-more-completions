#compdef apt-helper

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'download-file:download URL to file'
  'srv-lookup:lookup SRV record'
  'auto-detect-proxy:detect proxy from auto-config'
  'cat-file:cat compressed file'
  'analyze-pattern:analyze APT pattern expression'
  'wait-online:wait for online status'
  'drop-privs:drop privileges before exec'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '*-o+[option override]:opt:' \
  '-c+[config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'apt-helper command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (download-file)
        _arguments \
          '1:URL:' \
          '2:destination file:_files' \
          '3:hash string:' && ret=0 ;;
      (srv-lookup) _arguments '*:URI:' && ret=0 ;;
      (cat-file) _arguments '*:file:_files' && ret=0 ;;
      (analyze-pattern) _arguments '*:pattern:' && ret=0 ;;
    esac ;;
esac

return ret
