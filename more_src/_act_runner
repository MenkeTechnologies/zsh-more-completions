#compdef act_runner
# Documentation: https://gitea.com/gitea/act_runner
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gitea/act_runner — https://github.com/go-gitea/act_runner — typical commands: daemon, act,
# register, generate-config, remove (see upstream `act_runner --help`).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'daemon:run polling daemon'
  'act:run a workflow job payload'
  'register:register runner with Gitea instance'
  'generate-config:generate example config file'
  'remove:unregister runner'
  'healthcheck:report health status'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'act_runner command' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
