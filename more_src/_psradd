#compdef psradd
# Documentation: http://psrchive.sourceforge.net/manuals/psradd/
# PSRCHIVE: combine archives in various ways.

local ret=1

_arguments -s -S \
  '-o+[output file name]:file:_files' \
  '-R[frequency append mode (combine along frequency)]' \
  '-I+[maximum integration length for grouping]:length:' \
  '-e+[file extension for output files]:ext:' \
  '-p+[ephemeris used to generate the phase model]:file:_files' \
  '-j+[preprocessing tasks via psrsh command language]:jobs:' \
  '-T[produce a tscrunched output archive]' \
  '-f+[output filename]:file:_files' \
  '*:archive:_files' && ret=0

return ret
