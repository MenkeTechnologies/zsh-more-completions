#compdef jsonnet-fmt

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-n --max-blank-lines)'{-n,--max-blank-lines}'[max consecutive blank lines]:number' \
  '--string-style[string style]:style:((d\:"double quotes" s\:"single quotes" l\:"leave unchanged"))' \
  '--comment-style[comment style]:style:((h\:"hash comments" s\:"slash comments" l\:"leave unchanged"))' \
  '--indent[number of spaces per indent level]:spaces' \
  '(--no-pad-arrays)--pad-arrays[pad array elements with spaces]' \
  '(--pad-arrays)--no-pad-arrays[do not pad array elements]' \
  '(--no-pad-objects)--pad-objects[pad object fields with spaces]' \
  '(--pad-objects)--no-pad-objects[do not pad object fields]' \
  '(--no-pretty-field-names)--pretty-field-names[use unquoted field names where possible]' \
  '(--pretty-field-names)--no-pretty-field-names[always quote field names]' \
  '(--no-sort-imports)--sort-imports[sort import statements]' \
  '(--sort-imports)--no-sort-imports[do not sort import statements]' \
  '(-i --in-place)'{-i,--in-place}'[edit files in place]' \
  '--test[test if files are already formatted]' \
  '(--help)--help[show help message]' \
  '(--version)--version[show version]' \
  '*:jsonnet files:_files -g "*.{jsonnet,libsonnet}"' \
  && ret=0

return ret
