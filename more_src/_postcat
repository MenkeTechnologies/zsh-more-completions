#compdef postcat

_arguments -s \
  '-b[print message body]' \
  '-c=[config directory]:dir:_files -/' \
  '-d[print decimal record types]' \
  '-e[print envelope]' \
  '-h[print headers]' \
  '-o[print record offsets]' \
  '-q[search by queue id (positional args become queue ids)]' \
  '-v[verbose]' \
  '*:file:_files'
