#compdef agenix-rekey
# _agenix-rekey — rekey age secrets for NixOS hosts (oddlama/agenix-rekey)
# upstream: https://github.com/oddlama/agenix-rekey
# Subcommands & flags from apps/{rekey,edit-view,generate,update-masterkeys}.nix.

_agenix-rekey() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'rekey:rekey all age secrets to host pubkeys'
                'edit:edit an age secret with $EDITOR'
                'view:view an age secret'
                'generate:run generator scripts to (re)generate secrets'
                'update-masterkeys:rotate master identity keys'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                rekey)
                    _arguments \
                        '(-a --add-to-git)'{-a,--add-to-git}'[git-add rekeyed secrets (storageMode=local)]' \
                        '(-d --dummy)'{-d,--dummy}'[emit dummy secrets when rekeying]' \
                        '(-f --force)'{-f,--force}'[rekey everything regardless of cache]' \
                        '--show-out-paths[print outPaths instead of rekeying]' \
                        '--show-drv-paths[print drv paths instead of rekeying]'
                    ;;
                edit|view)
                    _arguments \
                        '(-i --input)'{-i+,--input=}'[encrypt this file instead of opening $EDITOR]:file:_files' \
                        '(-f --force)'{-f,--force}'[force write even if unchanged]' \
                        '(-p --preview)'{-p,--preview}'[preview secret in fzf (insecure)]' \
                        '1:secret file:_files'
                    ;;
                generate)
                    _arguments \
                        '(-f --force-generate)'{-f,--force-generate}'[force regeneration]' \
                        '(-a --add-to-git)'{-a,--add-to-git}'[git-add generated secrets]' \
                        '*'{-t+,--tags=}'[restrict to tag(s)]:tag:' \
                        '*::secrets:'
                    ;;
            esac
            ;;
    esac
}

_agenix-rekey "$@"
