#compdef pacemaker-schedulerd
# Documentation: https://man.archlinux.org/search?q=pacemaker-schedulerd
# Reference accessed: 2026-05-16

# Pacemaker scheduler (PEngine) subdaemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-$,--version}'[show version]' \
  '-V[verbose]' \
  '--verbose[verbose]' \
  '*::pacemaker-schedulerd args:_files' && ret=0
return ret
