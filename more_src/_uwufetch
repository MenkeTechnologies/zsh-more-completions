#compdef uwufetch

_uwufetch() {
    _arguments \
        '(-c --config)'{-c,--config}'[Use custom configuration path]:file:_files' \
        '(-d --distro)'{-d,--distro}'[Manually choose logo/distro]:distro:' \
        '(-h --help)'{-h,--help}'[Print help page]' \
        '(-i --image)'{-i,--image}'[Display logo as image (requires viu)]' \
        '(-l --list)'{-l,--list}'[List all supported distributions]' \
        '(-r --read-cache)'{-r,--read-cache}'[Read from cache file]' \
        '(-v --version)'{-v,--version}'[Print current version]' \
        '(-w --write-cache)'{-w,--write-cache}'[Update system information cache]'
}

_uwufetch "$@"
