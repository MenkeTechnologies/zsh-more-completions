#compdef epestfind
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/epestfind.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS epestfind: find PEST sequences (proteolysis signals) in protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-window=[minimum window size]:size:' \
  '-order=[output order]:order:(score length position)' \
  '-potential[report potential PEST regions]' \
  '-poor[report poor PEST regions]' \
  '-invalid[report invalid PEST regions]' \
  '-map[generate sequence map]' \
  '-mwdata=[molecular weight data file]:file:_files' \
  '-aadata=[amino acid data file]:file:_files' \
  '-threshold=[score threshold]:score:' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfile=[output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
