#compdef hubCheck
# Documentation: https://hgdownload.soe.ucsc.edu/admin/exe/
# UCSC kent: check a track data hub for integrity

local ret=1

_arguments -s -S \
  '-noTracks[do not check remote files for tracks, just trackDb]' \
  '-checkSettings[check trackDb settings to spec]' \
  '-version=[version to validate settings against]:version' \
  '-extra=[accept settings in this file or url]:file:_files' \
  '-level=[reject settings below this support level]:level:(base required)' \
  '-settings[just list settings with support level]' \
  '-genome=[only check this genome]:genome' \
  '-udcDir=[place to put cache for remote bigBed/bigWigs]:dir:_files -/' \
  '-httpsCertCheck=[set the ssl certificate verification mode]:mode:(abort warn log none)' \
  '-httpsCertCheckDomainExceptions=[space separated list of domains to whitelist]:domains' \
  '-printMeta[print the metadata for each track]' \
  '-cacheTime=[set cache refresh time in seconds]:n' \
  '-noSeqNameCheck[skip validation of sequence names in 2bit files]' \
  '-allowWarnings[return 0 exit code when only warnings are found]' \
  '-verbose=[output verbosely]:n' \
  '1:hub.txt url:_files' && ret=0

return ret
