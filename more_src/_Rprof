#compdef Rprof
# Documentation: https://stat.ethz.ch/R-manual/R-devel/library/utils/html/Rprof.html
# R CMD Rprof: post-process profiling information from Rprof()

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print short help message and exit]' \
  '(-v --version)'{-v,--version}'[print version info and exit]' \
  '--lines[print line information]' \
  '--total[print only by total]' \
  '--self[print only by self]' \
  '--linesonly[print only by line (implies --lines)]' \
  '--min%total=[minimum %% to print for by total]:pct:' \
  '--min%self=[minimum %% to print for by self]:pct:' \
  '*:file:_files' && ret=0

return ret
