#compdef sfhwt3d
# Documentation: https://raw.githubusercontent.com/ahay/src/master/user/psava/Mhwt3d.c
# Madagascar: 3D Huygens wavefront tracing traveltimes

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  'verb=[verbosity flag (y/n)]:flag:(y n)' \
  'forceray=[force ray tracing (y/n)]:flag:(y n)' \
  'scaleray=[ray scaling]:n:' \
  'nt=[number of time steps]:n:' \
  'ot=[time origin]:o:' \
  'dt=[time sampling]:d:' \
  'ng=[number of g samples]:n:' \
  'og=[g origin]:o:' \
  'dg=[g sampling]:d:' \
  'nh=[number of h samples]:n:' \
  'oh=[h origin]:o:' \
  'dh=[h sampling]:d:' \
  'xsou=[source x coordinate]:x:' \
  'ysou=[source y coordinate]:y:' \
  'zsou=[source z coordinate]:z:' \
  '*:RSF file:_files' && ret=0

return ret
