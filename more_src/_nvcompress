#compdef nvcompress
# Documentation: https://www.mankier.com/1/nvcompress
# NVIDIA Texture Tools: compress images to DDS

local ret=1

_arguments -s -S \
  '-color[input image is a color map (default)]' \
  '-alpha[input image has an alpha channel]' \
  '-normal[input image is a normal map]' \
  '-tonormal[convert input to normal map]' \
  '-clamp[clamp wrapping mode (default)]' \
  '-repeat[repeat wrapping mode]' \
  '-nomips[disable mipmap generation]' \
  '-premula[premultiply alpha into color channel]' \
  '-mipfilter[mipmap filter]:filter:(box triangle kaiser)' \
  '-float[load as floating point image]' \
  '-rgbm[transform input to RGBM]' \
  '-rangescale[scale image to use entire color range]' \
  '-fast[fast compression]' \
  '-nocuda[do not use cuda compressor]' \
  '-rgb[RGBA format]' \
  '-lumi[LUMINANCE format]' \
  '-bc1[BC1 format (DXT1)]' \
  '-bc1n[BC1 normal map format (DXT1nm)]' \
  '-bc1a[BC1 format with binary alpha (DXT1a)]' \
  '-bc2[BC2 format (DXT3)]' \
  '-bc3[BC3 format (DXT5)]' \
  '-bc3n[BC3 normal map format (DXT5nm)]' \
  '-bc3_rgbm[BC3 RGBM format]' \
  '-bc4[BC4 format]' \
  '-bc5[BC5 format]' \
  '-bc6[BC6 format]' \
  '-bc7[BC7 format]' \
  '-silent[do not output progress messages]' \
  '-dds10[use DirectX 10 DDS format]' \
  '-ktx[use KTX container format]' \
  '-srgb[output in sRGB color space if format allows]' \
  '1:infile:_files' \
  '2:outfile:_files' && ret=0

return ret
