#compdef autoupdate
# Documentation: autoupdate --help (GNU Autoconf)
# Source: update configure.ac to the current Autoconf syntax.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbosely report processing]' \
    {-d,--debug}'[do not remove temporary files]' \
    {-f,--force}'[consider all files obsolete]' \
    '*'{-B+,--prepend-include=}'[prepend directory to search path]:dir:_files -/' \
    '*'{-I+,--include=}'[append directory to search path]:dir:_files -/' \
    '*:template file:_files -g "configure.(ac|in)"' \
    && ret=0

return ret
