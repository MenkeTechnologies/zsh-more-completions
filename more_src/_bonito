#compdef bonito
# Documentation: https://github.com/nanoporetech/bonito/blob/master/bonito/cli/basecaller.py
# PyTorch basecaller for Oxford Nanopore reads

local ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--reference=[reference for alignment (.mmi/.fasta)]:file:_files' \
  '--read-ids=[file of read IDs to basecall]:file:_files' \
  '--device=[compute device]:device' \
  '--seed=[random seed]:n' \
  '--weights=[model weights to load]:n' \
  '--skip[skip already basecalled reads]' \
  '--no-trim[disable adapter trimming]' \
  '--save-ctc[save CTC output for training]' \
  '--revcomp[reverse complement output]' \
  '--rna[basecall RNA reads]' \
  '--recursive[search directories recursively]' \
  '(--no-quantize)--quantize[quantize the model]' \
  '(--quantize)--no-quantize[disable model quantization]' \
  '--overlap=[chunk overlap]:n' \
  '--chunksize=[signal chunk size]:n' \
  '--batchsize=[inference batch size]:n' \
  '--max-reads=[limit number of reads]:n' \
  '--min-qscore=[minimum mean Q-score]:q' \
  '--min-accuracy-save-ctc=[min accuracy to save CTC]:acc' \
  '--alignment-threads=[alignment thread count]:n' \
  '--mm2-preset=[minimap2 preset]:preset' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '1:model directory:_files -/' \
  '2:reads directory:_files -/' && ret=0

return ret
