#compdef iotop
# Documentation: iotop usage on macOS / DTrace
# Source: macOS iotop (DTrace-based) — per-process disk I/O monitor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[do not clear the screen]' \
    '(-D -o -P)-D[print delta times, elapsed (microseconds)]' \
    '(-D -o -P)-o[print disk delta times (microseconds)]' \
    '(-D -o -P)-P[print %I/O (disk delta times)]' \
    '(-j -Z)-j[print project ID]' \
    '(-j -Z)-Z[print zone ID]' \
    '-d+[instance name to snoop]:device:' \
    '-f+[snoop this file only]:file:_files' \
    '-m+[this filesystem only]:mount_point:_files -/' \
    '-t+[print top N lines only]:n:' \
    '1:interval (seconds):' \
    '2:count:' \
    && ret=0

return ret
