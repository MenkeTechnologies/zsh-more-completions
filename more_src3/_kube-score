#compdef kube-score
# Documentation: https://github.com/zegl/kube-score#configuration-options
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'score:score Kubernetes objects'
      'list:list available checks as CSV'
      'version:print version'
      'help:show usage information'
    )
    _describe -t commands 'kube-score command' commands && ret=0
    ;;
  args)
    case $words[1] in
      score)
        _arguments -s -S \
          {-o,--output-format}'=[output format]:format:(human json ci sarif)' \
          '--output-version=[output format version]:version' \
          '*--ignore-test=[disable a test]:test' \
          '*--enable-optional-test=[enable an optional test]:test' \
          '--ignore-container-cpu-limit[disable requirement of a container CPU limit]' \
          '--ignore-container-memory-limit[disable requirement of a container memory limit]' \
          '--disable-ignore-checks-annotations[disable the kube-score/ignore annotations]' \
          '--disable-optional-checks-annotations[disable the kube-score/enable annotations]' \
          '--exit-one-on-warning[exit with code 1 if there are warnings]' \
          '--kubernetes-version=[Kubernetes version to test against]:version' \
          '*'{-v,--verbose}'[enable verbose output, can be set multiple times]' \
          '*:file:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
