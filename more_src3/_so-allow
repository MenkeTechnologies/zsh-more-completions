#compdef so-allow
# _so-allow — Security Onion so-allow CLI for managing firewall allow-list rules updating iptables host_groups and minion mine data to expose Security Onion services analyst nginx mongo es kibana to specified analyst hosts (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-allow() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[ip address or CIDR]:str:' \
        '--ip=+[ip address or CIDR]:str:' \
        '-r+[role]:r:(analyst nginx logstash beats syslog osquery wazuh wazuh-manager-cluster mongo elasticsearch kibana fleet strelka misp playbook hunt thehive cortex docker registry minion master ssh)' \
        '--role=+[role]:r:(analyst nginx logstash beats syslog osquery wazuh mongo elasticsearch kibana fleet strelka misp playbook hunt thehive cortex docker registry minion master ssh)' \
        '-d+[description]:str:' \
        '--description=+[description]:str:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f[force]' \
        '--force[force]' \
        '-l[list current rules]' \
        '--list[list current rules]' \
        '-x[dry-run]' \
        '--dry-run[dry-run]'
}

_so-allow "$@"
