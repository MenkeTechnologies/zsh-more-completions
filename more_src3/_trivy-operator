#compdef trivy-operator
# Documentation: https://github.com/aquasecurity/trivy-operator/blob/main/docs/getting-started/installation/configuration.md
# Reference accessed: 2026-05-16
# Verified: aquasecurity/trivy-operator configuration docs.
# trivy-operator's CLI surface is two flags + many OPERATOR_* env vars
# (all docs map env to behavior, not to CLI flags).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --leader-elect/--target-workloads/--vulnerability-scanner-
# enabled/--target-namespaces/--exclude-namespaces/--scan-job-timeout/
# --scan-job-failure-policy/--operator-namespace etc. (these are env
# vars OPERATOR_*, not CLI flags).

# trivy-operator: aqua trivy K8s operator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--metrics-bind-address=[metrics bind address (default :8080)]:addr:' \
  '--health-probe-bind-address=[health probe bind address (default :9090)]:addr:' && ret=0
return ret
