#compdef klogg glogg
# Documentation: source-direct extraction from upstream
# variar/klogg src/app/cli.h CliParameters constructor's
# QCommandLineParser + QCommandLineOption declarations decoded
# source-direct.  klogg has two modes (GUI vs console) gated on
# the `bool console` constructor arg - the GUI build registers
# multi/load-session/new-session/log/follow/window-width/
# window-height options; the console build registers only the
# pattern option.  Completion lists ALL options since the
# parser silently ignores unknown options across builds.
# nickbnf/glogg src/main.cpp boost::program_options
# `desc.add_options()(...)` chain decoded source-direct -> 7
# user-facing flags + 1 hidden positional (input-file).
# Reference accessed: 2026-05-30 via gh api.
# variar/klogg + nickbnf/glogg R190 — klogg is the actively-
# maintained successor to glogg, both fast Qt-based log file
# viewers / log explorers for large (gigabyte-scale) log files
# with regex filtering, multi-file split-view, follow-tail
# mode, search history, etc.  Sister tools to the heavily-
# covered log-analysis family (lnav, multitail, logwatch +
# wtmpdb + tail + less + dnstop + atop + bottom + btop +
# logcheck + journalctl already in the corpus).

case $service in

  klogg)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-m --multi)'{-m,--multi}'[allow multiple klogg instances simultaneously (pair with -s)]' \
      '(-s --load-session)'{-s,--load-session}'[load the previous session (default when no file is passed)]' \
      '(-n --new-session)'{-n,--new-session}'[do not load the previous session (default when a file is passed)]' \
      '(-l --log)'{-l,--log}'[save the log to a file]' \
      '(-f --follow)'{-f,--follow}'[follow initial opened files (tail-like)]' \
      '(-e --pattern)'{-e+,--pattern=}'[(console mode) pattern to search for]:pattern:' \
      '(-d --debug)'{-d+,--debug=}'[debug verbosity level (default 0)]:level:(0 1 2 3 4 5)' \
      '--window-width=[initial window width (default 1024)]:px:' \
      '--window-height=[initial window height (default 768)]:px:' \
      '*:log file:_files'
    ;;

  glogg)
    # glogg accepts `-d` multiple times to increase verbosity
    # (e.g. `-dddd` for max debug) per the upstream help text
    # "include multiple times for more verbosity".
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print program usage and exit]' \
      '(-v --version)'{-v,--version}'[print version and exit]' \
      '(-m --multi)'{-m,--multi}'[allow multiple glogg instances simultaneously (pair with -s)]' \
      '(-s --load-session)'{-s,--load-session}'[load the previous session (default when no file is passed)]' \
      '(-n --new-session)'{-n,--new-session}'[do not load the previous session (default when a file is passed)]' \
      '(-l --log)'{-l,--log}'[save the log to a file (Windows only)]' \
      '*'{-d,--debug}'[increase debug verbosity (repeatable: -d/-dd/-ddd/-dddd ...)]' \
      '*:log file:_files'
    ;;

esac
