#compdef lhasa
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-q[quiet mode]' \
  '-v[verbose output]' \
  '-w[output directory]:directory:_directories' \
  '-n[dry run / do not overwrite existing files]' \
  '-f[force overwrite existing files]' \
  '1:command:((e\:extract l\:list x\:"extract with paths"))' \
  '2:archive:_files -g "*.{lha,lzh}(-.)"' \
  '*:file:_files' && ret=0
return ret
