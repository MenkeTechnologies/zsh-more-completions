#compdef lapce
# Documentation: https://github.com/lapce/lapce/blob/master/lapce-app/src/app.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Lapce editor. Flags derived from the clap Cli struct in
# lapce-app/src/app.rs (only --new, --wait, --plugin-path, -h/-V, and
# positional paths are accepted; paths support path:line:column syntax).

_lapce() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-n --new)'{-n,--new}'[launch new window even if Lapce is already running]' \
    '(-w --wait)'{-w,--wait}'[do not return instantly when opened in a terminal]' \
    '*--plugin-path=[path to plugin to load (for plugin development)]:path:_files -/' \
    '(-h --help)'{-h,--help}'[print help]' \
    '(-V --version)'{-V,--version}'[print version]' \
    '*:path (file or folder, file accepts path\:line\:column):_files' \
    && ret=0

  return ret
}

_lapce "$@"
