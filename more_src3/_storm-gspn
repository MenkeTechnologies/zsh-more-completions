#compdef storm-gspn
# Documentation: https://github.com/moves-rwth/storm/tree/master/src/storm-gspn-cli
# Reference accessed: 2026-05-27
# Verified: upstream moves-rwth/storm option registrations in
#   src/storm-gspn/settings/modules/{GSPNSettings,GSPNExportSettings}.cpp plus
#   shared GeneralSettings/IOSettings/CoreSettings/DebugSettings/
#   ResourceSettings/JaniExportSettings.
#
# Coverage: full GSPN-specific option set plus shared option groups.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show available options]:filter (optional):' \
  '--version[print version information]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-eps --precision)'{-eps,--precision}'[internal numerical precision]:double:' \
  '(-c --config)'{-c+,--config=}'[read additional options from config file]:file:_files' \
  '(-stats --statistics)'{-stats,--statistics}'[display statistics]' \
  '--debug[enable debug logging]' \
  '--trace[enable trace logging]' \
  '(-l --logfile)'{-l+,--logfile=}'[write log to file]:file:_files' \
  '(-t --timeout)'{-t+,--timeout=}'[abort after N seconds]:seconds:' \
  '(-tm --timemem)'{-tm,--timemem}'[print CPU time and memory at end]' \
  '(-gspn --gspnfile)'{-gspn+,--gspnfile=}'[parse GSPN file]:file:_files' \
  '(-capacities --capacitiesfile)'{-capacities+,--capacitiesfile=}'[per-place capacity invariants]:file:_files' \
  '--capacity=[global capacity invariant for all places]:n:' \
  '(-const --constants)'{-const+,--constants=}'[constant definitions]:assignments:' \
  '--gspn-dot-output=[export GSPN as Graphviz dot]:file:_files' \
  '--to-pnml=[export GSPN in PNML format]:file:_files' \
  '--to-pnpro=[export GSPN in PNPRO format]:file:_files' \
  '--to-json=[export GSPN as JSON]:file:_files' \
  '--to-jani=[export GSPN as JANI]:file:_files' \
  '--addprops[add properties from PNML to output]' \
  '--to-stats=[export GSPN statistics]:file:_files' \
  '--show-stats[print GSPN statistics]' \
  '--location-variables=[automaton.location variables to expose in JANI export]:list:' \
  '--edge-assignments[allow edge assignments in JANI export]' \
  '--flatten[flatten composition in JANI export]' \
  '--globalvars[force global variables in JANI export]' \
  '--localvars[force local variables in JANI export]' \
  '--compactjson[emit compact JSON in JANI export]' \
  '*:GSPN file:_files' && ret=0

return ret
