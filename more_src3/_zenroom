#compdef zenroom
# Documentation: https://github.com/dyne/Zenroom (src/cli-zenroom.c)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_zenroom() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments \
    '-h[print help]' \
    '-i[start interactive Lua mode]' \
    '-z[start Zencode mode]' \
    '-c[load configuration from file]:config:_files' \
    '-a[load data JSON file]:data:_files -g "*.json"' \
    '-k[load keys JSON file]:keys:_files -g "*.json"' \
    '-x[load extra JSON file]:extra:_files -g "*.json"' \
    '-y[load context from file]:context:_files' \
    '-D[print all statements under a scenario]:scenario:' \
    '-v[validate input data]' \
    '-e[execute a Lua one-liner at startup]:code:' \
    '-s[activate seccomp execution \(Linux only\)]' \
    '-l[load an external Lua library from file]:lib:_files -g "*.lua"' \
    '*:script file:_files -g "*.zen *.lua"'
}

_zenroom "$@"
