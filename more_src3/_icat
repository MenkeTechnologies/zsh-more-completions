#compdef icat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/icat.html
# Source: sleuthkit/sleuthkit man/icat.1 — output contents of a file based on its inode number.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[skip over holes in sparse files (absolute address info is lost)]' \
    '-r[use file recovery techniques if file is deleted]' \
    '-s[include slack space in output]' \
    '-v[enable verbose mode, output to stderr]' \
    '-V[display version]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '*:image file or inode:_files' \
    && ret=0

return ret
