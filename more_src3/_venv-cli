#compdef venv-cli python-venv pyvenv
# _venv-cli — CPython venv module CLI alias to create Python virtual environments (PSF, Python); custom argparse
# upstream: https://github.com/python/cpython

_venv-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--system-site-packages[give the venv access to system site packages]' \
        '--symlinks[use symlinks]' \
        '--copies[use copies]' \
        '--clear[delete env dir before creating]' \
        '--upgrade[upgrade env to current Python]' \
        '--without-pip[skip pip installation]' \
        '--prompt=+[prompt prefix]:str:' \
        '--upgrade-deps[upgrade core deps (pip)]' \
        '*:env-dir:_files -/'
}

_venv-cli "$@"
