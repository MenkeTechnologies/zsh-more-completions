#compdef nk2info nk2export
# _libnk2 — libyal Outlook Nickname Cache (.NK2) parser; recovers autocomplete entries (display name, email address, MAPI property bag) used in pre-2010 Outlook
# upstream: https://github.com/libyal/libnk2

_libnk2() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[ascii codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-X[exclusive]' \
        '*:NK2 file:_files -g "*.NK2"'
}

_libnk2 "$@"
