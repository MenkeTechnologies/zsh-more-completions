#compdef texfot
# Documentation: texfot manpage (TeX Live 2026)
# Source: wrap a TeX engine and filter the online transcript for interesting messages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)--help[print help]' \
    '(- *)--version[print version]' \
    '*--accept=[regex of lines to accept]:regex:' \
    '*--ignore=[regex of lines to ignore]:regex:' \
    '(--debug --no-debug)--debug[enable debug output]' \
    '(--debug --no-debug)--no-debug[disable debug output]' \
    '(--interactive --no-interactive)--interactive[interactive mode]' \
    '(--interactive --no-interactive)--no-interactive[non-interactive mode]' \
    '(--quiet --no-quiet)--quiet[quiet mode]' \
    '(--quiet --no-quiet)--no-quiet[verbose mode]' \
    '(--stderr --no-stderr)--stderr[show lines from stderr]' \
    '(--stderr --no-stderr)--no-stderr[hide stderr lines]' \
    '--tee=[file for full output copy (--tee /dev/null to discard)]:file:_files' \
    '1: :_command_names -e' \
    '*::texcmd args:_normal' \
    && ret=0

return ret
