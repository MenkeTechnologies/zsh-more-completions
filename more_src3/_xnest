#compdef Xnest xnest
# Documentation: man Xnest (X.Org)
# Source: nested X server (runs as an X11 window on another X server).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-display+[parent X display]:display:' \
    '-sync[synchronise with parent server]' \
    '-full[use full regeneration of real screen]' \
    '-class+[visual class]:class:(StaticGray GrayScale StaticColor PseudoColor TrueColor DirectColor)' \
    '-depth+[default depth]:int:(1 4 8 15 16 24 32)' \
    '-sss[use software screen saver]' \
    '-geometry+[parent-window geometry]:geom:' \
    '-bw+[parent-window border width]:int:' \
    '-name+[parent-window name]:string:' \
    '-scrns+[number of screens]:int:' \
    '-install[install colormaps directly]' \
    '-parent+[parent window id]:window_id:' \
    && ret=0

return ret
