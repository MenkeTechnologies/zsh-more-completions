#compdef cjxl djxl jxlinfo jxl_emit_encoding_stats jpegli libjxl jxl
# _libjxl — Google JPEG XL libjxl cjxl djxl jxlinfo reference JPEG XL encoder decoder and inspector (libjxl team, C++); custom argparse
# upstream: https://github.com/libjxl/libjxl

_libjxl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q+[quality 0-100]:n:' \
        '--quality=+[quality 0-100]:n:' \
        '-d+[distance]:f:' \
        '--distance=+[distance]:f:' \
        '-e+[effort 1-10]:n:' \
        '--effort=+[effort 1-10]:n:' \
        '-m+[modular mode]:b:(0 1)' \
        '--modular=+[modular mode]:b:(0 1)' \
        '--lossless_jpeg=+[bool]:b:(0 1)' \
        '--lossless[lossless mode]' \
        '--bit_depth=+[N]:n:' \
        '--frame_indexing=+[mode]:m:(0 1 2)' \
        '--progressive[progressive]' \
        '--num_threads=+[N]:n:' \
        '-t+[N]:n:' \
        '--num_reps=+[N]:n:' \
        '--center_x=+[N]:n:' \
        '--center_y=+[N]:n:' \
        '--container=+[bool]:b:(0 1)' \
        '--codestream_level=+[level]:n:' \
        '--epf=+[level]:n:' \
        '--gaborish=+[bool]:b:(0 1)' \
        '--patches=+[bool]:b:(0 1)' \
        '--dots=+[bool]:b:(0 1)' \
        '--noise=+[bool]:b:(0 1)' \
        '--photon_noise_iso=+[N]:n:' \
        '--epf=+[N]:n:' \
        '--xyb=+[bool]:b:(0 1)' \
        '--icc=+[file]:file:_files -g "*.icc *.icm"' \
        '--num_reps=+[N]:n:' \
        '--allow_jpeg_reconstruction=+[bool]:b:(0 1)' \
        '--print_profile=+[bool]:b:(0 1)' \
        '--print_more_stats=+[bool]:b:(0 1)' \
        '--gain_map=+[file]:file:_files' \
        '--alpha_distance=+[F]:f:' \
        '--alpha_premultiplied=+[bool]:b:(0 1)' \
        '--bits_per_sample=+[N]:n:' \
        '--color_space=+[space]:s:(RGB_D65_SRG_Rel_SRG RGB_D65_SRG_Rel_Lin RGB_D65_202_Rel_PeQ RGB_D65_202_Rel_HLG RGB_D65_DCI_Rel_SRG XYB)' \
        '--pixels_to_jpeg_quality=+[N]:n:' \
        '--frame_rate=+[fps]:n:' \
        '--colortransform=+[transform]:t:(YCbCr None YCgCo)' \
        '--print_frames=+[bool]:b:(0 1)' \
        '--no_check[no check]' \
        '*:input output:_files -g "*.jxl *.png *.jpg *.jpeg *.ppm *.pgm *.pfm *.gif *.exr *.apng"'
}

_libjxl "$@"
