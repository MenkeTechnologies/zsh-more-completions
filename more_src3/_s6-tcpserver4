#compdef s6-tcpserver4 s6-tcpserver6
# Documentation: https://skarnet.org/software/s6-networking/s6-tcpserver4.html
# Reference accessed: 2026-05-30
# s6-tcpserver4 / s6-tcpserver6 — TCP server runners (IPv4 / IPv6). Per-connection prog exec.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[output bound port to stdout immediately after binding (useful for readiness)]' \
  '-v+[verbosity (0=errors only, 1=warnings, 2=detailed)]:level:(0 1 2)' \
  '-c+[max concurrent connections (default 40, max 1000)]:N:' \
  '-C+[max connections from a single IP (default 40)]:N:' \
  '-b+[socket backlog queue size]:N:' \
  '-G+[supplementary group list (root only; CSV of numeric GIDs)]:gidlist:' \
  '-g+[change GID after bind (root only)]:gid:_groups' \
  '-u+[change UID after bind (root only)]:uid:_users' \
  '-U[adopt UID/GID from environment (root only)]' \
  '1:bind IP:' \
  '2:port:' \
  '*:program + args:_command_names -e' \
  && ret=0

return ret
