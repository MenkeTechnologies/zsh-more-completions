#compdef velite
# Documentation: https://velite.js.org/reference/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build content with the configured Zod schema'
  'dev:build content in watch mode'
  'init:create a default Velite config (TODO)'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[Velite config file]:file:_files -g "velite.config.{ts,js,mjs,cjs}"' \
  '--clean[clean output directory before build]' \
  '--watch[watch for changes and rebuild]' \
  '--verbose[print additional information]' \
  '--debug[print debug information]' \
  '*::cmd:->cmd' && ret=0

case $state in
  (cmd) _describe -t cmds 'velite command' commands && ret=0 ;;
esac

return ret
