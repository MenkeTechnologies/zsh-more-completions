#compdef svscan
# Documentation: https://cr.yp.to/daemontools/svscan.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (only a single optional directory argument; no flags).

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:service directory:_files -/' && ret=0

return ret
