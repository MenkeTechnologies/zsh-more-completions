#compdef hybrid-analysis hybridanalysis
# _hybrid-analysis — CrowdStrike Falcon Sandbox hybrid-analysis CLI client to the Hybrid-Analysis REST API submitting samples querying detonation reports overview screenshots state-of-art behavioral-analysis MITRE-mapped IOCs YARA-rule-matches network-traffic dropped-files for the public Falcon Sandbox (CrowdStrike team, Python); click
# upstream: https://www.hybrid-analysis.com/

_hybrid-analysis() {
    local -a sub=(
        'submit:submit a file/URL for analysis'
        'overview:fetch report overview'
        'state:fetch report state'
        'screenshots:fetch screenshots'
        'reanalyze:resubmit existing sample'
        'search:search reports'
        'download-pcap:download PCAP'
        'download-sample:download sample'
        'download-memory:download memory dump'
        'download-report:download detailed JSON'
        'environment:list sandbox environments'
        'quota:show quota'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '-e+[environment id]:n:' \
        '--environment-id=+[N]:n:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hybrid-analysis subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments '*:file or URL:_files' ;;
                overview|state|screenshots|download-pcap|download-sample|download-memory|download-report) _arguments '*:sha256/id:' ;;
                search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_hybrid-analysis "$@"
