#compdef iconutil
# Documentation: https://www.unix.com/man-page/osx/1/iconutil/
# Source: Apple macOS — convert between .icns and .iconset directory layouts.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --convert)'{-c+,--convert=}'[convert direction]:format:(icns iconset)' \
    '(-o --output)'{-o+,--output=}'[output file name override]:file:_files' \
    '*:source .icns or .iconset:_files' \
    && ret=0

return ret
