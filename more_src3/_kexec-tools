#compdef kexec
# Documentation: https://man7.org/linux/man-pages/man8/kexec.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kexec: directly boot into a new kernel
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --load)'{-l+,--load=}'[load kernel into the current kernel]:file:_files' \
  '(-p --load-panic)'{-p,--load-panic}'[load panic (kdump) kernel]' \
  '(-u --unload)'{-u,--unload}'[unload the current kexec target kernel]' \
  '(-e --exec)'{-e,--exec}'[execute a currently loaded kernel]' \
  '(-f --force)'{-f,--force}'[force immediate reboot without calling shutdown]' \
  '(-x --no-ifdown)'{-x,--no-ifdown}'[do not bring down network interfaces]' \
  '(-y --no-sync)'{-y,--no-sync}'[do not sync filesystems before reboot]' \
  '(-i --no-checks)'{-i,--no-checks}'[fast reboot, do not check the dump]' \
  '(-s --kexec-file-syscall)'{-s,--kexec-file-syscall}'[use the kexec_file_load syscall]' \
  '(-c --kexec-syscall)'{-c,--kexec-syscall}'[use the kexec_load syscall]' \
  '(-a --kexec-syscall-auto)'{-a,--kexec-syscall-auto}'[try kexec_file_load, fall back to kexec_load]' \
  '(-S --status)'{-S,--status}'[return whether a kernel type is loaded]' \
  '(-d --debug)'{-d,--debug}'[enable debugging messages]' \
  '(-t --type)'{-t+,--type=}'[specify the kernel type]:type:(Beoboot-x86 elf-x86 bzImage-x86 multiboot-x86 multiboot2-x86 elf-ppc64)' \
  '--initrd=[initial ramdisk file]:file:_files' \
  '--append=[append to the kernel command line]:cmdline:' \
  '--command-line=[set the kernel command line]:cmdline:' \
  '--reuse-cmdline[use the kernel command line from the running system]' \
  '--dtb=[device tree blob file]:file:_files' \
  '--mem-min=[lowest memory address to load code into]:addr:' \
  '--mem-max=[highest memory address to load code into]:addr:' \
  '--entry=[jump back address]:addr:' \
  '--load-preserve-context[preserve current kernel context]' \
  '--load-jump-back-helper[load a helper image to jump back to the original kernel]' \
  '--hotplug[support hot-plug update of segments]' \
  '--reuseinitrd[reuse the initrd from the first boot]' \
  '--print-ckr-size[print crash kernel region size]' \
  '*::kexec args:_files' && ret=0
return ret
