# _vienna-rna — Ivo Hofacker ViennaRNA package RNA secondary structure prediction folding partition function thermodynamics (ViennaRNA team, C/C++); custom argparse
# upstream: https://github.com/ViennaRNA/ViennaRNA

_vienna-rna() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-T+[temperature C]:f:' \
        '--temp=+[temperature C]:f:' \
        '-d+[dangling end]:d:(0 1 2 3)' \
        '--dangles=+[dangling end]:d:(0 1 2 3)' \
        '-4[no special tetraloops]' \
        '--noTetra[no special tetraloops]' \
        '--noGU[no GU pairs]' \
        '--noClosingGU[no closing GU pairs]' \
        '-i+[input file]:file:_files -g "*.fa *.fasta *.txt *.aln *.clustal *.stockholm *.sto"' \
        '--infile=+[input file]:file:_files -g "*.fa *.fasta *.txt *.aln *.clustal"' \
        '-o+[output file]:file:_files' \
        '--outfile=+[output file]:file:_files' \
        '-p[partition function]' \
        '--partfunc[partition function]' \
        '-c+[circular sequence]:b:(0 1)' \
        '--circ[circular sequence]' \
        '--noPS[no PostScript]' \
        '--MEA=+[MEA gamma]:f:' \
        '-s+[input from stdin]:b:(0 1)' \
        '-S+[salt mol/L]:f:' \
        '--salt=+[salt mol/L]:f:' \
        '-P+[parameter file]:file:_files -g "*.par"' \
        '--paramFile=+[parameter file]:file:_files -g "*.par"' \
        '--energyModel=+[model]:m:(rnafold dnafold rnamfold)' \
        '--scaling=+[F]:f:' \
        '-w+[window size]:n:' \
        '--winsize=+[window size]:n:' \
        '-W+[max bp span]:n:' \
        '--span=+[max bp span]:n:' \
        '-l+[max base pair span]:n:' \
        '-L+[max loop size]:n:' \
        '--maxBPspan=+[max bp span]:n:' \
        '-u+[unpaired up]:n:' \
        '--ulength=+[unpaired up]:n:' \
        '--canonicalBPonly[only canonical bps]' \
        '--noLP[no lonely pairs]' \
        '--MEA[MEA structures]' \
        '--shape=+[shape file]:file:_files' \
        '--shapeMethod=+[method]:m:(deigan zarringhalam)' \
        '--mod=+[modifications]:str:' \
        '--no-dp[no DP file]' \
        '--no-PS[no PS file]' \
        '*:sequence file:_files -g "*.fa *.fasta *.txt *.aln"'
}

_vienna-rna "$@"
