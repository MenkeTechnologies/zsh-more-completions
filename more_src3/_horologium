#compdef horologium
# _horologium — Prow component that triggers periodic ProwJobs (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/horologium/main.go (flag).

_horologium() {
    _arguments \
        '-dry-run=[whether to make mutating API calls to Kubernetes]:val:(true false)' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_horologium "$@"
