#compdef xmag
# Documentation: man xmag (X.Org)
# Source: magnify part of the X screen.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-mag+[magnification factor]:integer:' \
    '-source+[source region (WxH+X+Y)]:geom:' \
    '-display+[X display]:display:' \
    '-geometry+[window geometry]:geom:' \
    '-bg+[background color]:color:' \
    '-fg+[foreground color]:color:' \
    && ret=0

return ret
