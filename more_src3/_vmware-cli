#compdef vmware-cli vmware-vmrun
# _vmware-cli — Broadcom VMware VMRun control of VMware Workstation/Player CLI alias (Broadcom / VMware, C); custom argparse
# upstream: https://kb.broadcom.com/

_vmware-cli() {
    local -a sub=(
        'start:start virtual machine'
        'stop:stop virtual machine'
        'reset:reset virtual machine'
        'suspend:suspend virtual machine'
        'pause:pause virtual machine'
        'unpause:unpause virtual machine'
        'list:list running VMs'
        'listSnapshots:list snapshots'
        'snapshot:take snapshot'
        'deleteSnapshot:delete snapshot'
        'revertToSnapshot:revert to snapshot'
        'runProgramInGuest:run program in guest'
        'fileExistsInGuest:check if file exists in guest'
        'directoryExistsInGuest:check if directory exists in guest'
        'setSharedFolderState:set shared folder state'
        'addSharedFolder:add shared folder'
        'removeSharedFolder:remove shared folder'
        'enableSharedFolders:enable shared folders'
        'disableSharedFolders:disable shared folders'
        'listProcessesInGuest:list processes in guest'
        'killProcessInGuest:kill process in guest'
        'runScriptInGuest:run script in guest'
        'deleteFileInGuest:delete file in guest'
        'createDirectoryInGuest:create directory in guest'
        'deleteDirectoryInGuest:delete directory in guest'
        'createTempfileInGuest:create temp file in guest'
        'listDirectoryInGuest:list directory in guest'
        'copyFileFromHostToGuest:copy file from host to guest'
        'copyFileFromGuestToHost:copy file from guest to host'
        'renameFileInGuest:rename file in guest'
        'addNetworkAdapter:add network adapter'
        'setNetworkAdapter:set network adapter'
        'removeNetworkAdapter:remove network adapter'
        'listNetworkAdapters:list network adapters'
        'listHostNetworks:list host networks'
        'captureScreen:capture screen'
        'getGuestIPAddress:get guest IP'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-T+[host type]:t:(ws fusion player server esx vc)' \
        '-h+[hostname]:host:_hosts' \
        '-P+[port]:port:' \
        '-u+[username]:str:_users' \
        '-p+[password]:str:' \
        '-gu+[guest username]:str:_users' \
        '-gp+[guest password]:str:' \
        '-vp+[vm-encryption-password]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vmrun subcommand' sub ;;
    esac
}

_vmware-cli "$@"
