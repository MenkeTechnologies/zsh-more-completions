#compdef vep
# Documentation: https://www.ensembl.org/info/docs/tools/vep/script/vep_options.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Ensembl VEP: variant effect predictor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(--help -h)'{--help,-h}'[show help]' \
  '--quiet[silence non-error output]' \
  '--verbose[verbose output]' \
  '-i[input file]:file:_files -g "*.(vcf|vcf.gz|gtf|hgvs)"' \
  '--input_file=[input file]:file:_files' \
  '--format=[input format]:fmt:(vcf id ensembl hgvs region spdi)' \
  '-o[output file]:file:_files' \
  '--output_file=[output file]:file:_files' \
  '--vcf[output VCF format]' \
  '--tab[tab-separated output]' \
  '--json[JSON output]' \
  '--no_stats[no stats file]' \
  '--stats_file=[stats output file]:file:_files' \
  '--stats_html[HTML stats file]' \
  '--stats_text[plain-text stats file]' \
  '--fasta=[reference FASTA]:file:_files -g "*.(fa|fasta|fa.gz)"' \
  '--species=[species]:species:' \
  '--assembly=[genome assembly]:assembly:(GRCh37 GRCh38 GRCm38 GRCm39)' \
  '--dir_cache=[cache directory]:dir:_files -/' \
  '--cache[use cache]' \
  '--offline[offline mode (use cache, no DB)]' \
  '--database[use Ensembl REST API]' \
  '--refseq[use RefSeq transcripts]' \
  '--merged[use merged GENCODE+RefSeq cache]' \
  '--vcf_info_field=[VCF INFO field name]:name:' \
  '--keep_csq[keep existing CSQ in input VCF]' \
  '--fields=[output fields list]:list:' \
  '--regulatory[predict regulatory consequences]' \
  '--protein[output Ensembl protein IDs]' \
  '--symbol[output gene symbols]' \
  '--ccds[output CCDS IDs]' \
  '--canonical[mark canonical transcripts]' \
  '--mane[output MANE transcripts]' \
  '--biotype[output transcript biotype]' \
  '--af[output allele frequencies from 1KG/gnomAD]' \
  '--af_gnomadg[gnomAD genome AF]' \
  '--af_gnomade[gnomAD exome AF]' \
  '--max_af[output maximum AF]' \
  '--sift=[SIFT prediction output]:level:(b s p)' \
  '--polyphen=[PolyPhen output]:level:(b s p)' \
  '--plugin=[plugin name]:plugin:' \
  '--custom=[custom annotation source]:source:' \
  '--gtf=[GTF transcript annotation]:file:_files' \
  '--gff=[GFF3 transcript annotation]:file:_files' \
  '--fork=[fork into N parallel processes]:n:' \
  '--buffer_size=[input buffer size]:n:' \
  '--compress_output=[output compression]:compr:(gzip bgzip)' \
  '*:VCF input file:_files' && ret=0
return ret
