#compdef syz-declextract
# _syz-declextract — extract kernel syscall declarations from clang AST (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-declextract/declextract.go (flag).

_syz-declextract() {
    _arguments \
        '-config=[manager config file]:file:_files -g "*.cfg"' \
        '-coverage=[syzbot coverage jsonl file]:file:_files -g "*.jsonl"' \
        '-arches=[comma-separated arches to extract]:list:'
}

_syz-declextract "$@"
