#compdef xstow
# Documentation: https://manpages.org/xstow
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (xstow manpage OPTIONS section).
# Removed: --ignore= (real is -i / -ignore), --override= (not in docs),
# -ap+ "add copy protection" (real is -absolute-path, takes no arg),
# -al+ (not in docs), -kl+ (not in docs), -f+ for config file (real is -F).
# Fixed: -d/-t (-target is documented), -i (ignore PATTERN), -tr (traversable
# links), -F (load additional config file). xstow uses single-dash long flags.

_arguments -s -S \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)'{-V,-Version}'[show version]' \
  '-dl[set debug level]:level:' \
  '-dm[filter debug module]:module:(ALL ARG MAIN TREE CPPDIR)' \
  '(-n -no)'{-n,-no}'[preview only, no changes]' \
  '(-c -conflicts)'{-c,-conflicts}'[scan for conflicts (implies -n)]' \
  '(-s -simulate)'{-s,-simulate}'[simulate install, ignore permission problems]' \
  '-d+[stow directory (default: cwd)]:stow directory:_directories' \
  '-dir+[stow directory (default: cwd)]:stow directory:_directories' \
  '-target+[target directory (default: parent of stow dir)]:target directory:_directories' \
  '(-v -verbose)'{-v+,-verbose+}'[increase verboseness 0-3]:level:(0 1 2 3)' \
  '(-D -delete)'{-D,-delete}'[uninstall packages]' \
  '(-R -restow)'{-R,-restow}'[reinstall packages]' \
  '(-ap -absolute-path)'{-ap,-absolute-path}'[create symlinks with absolute paths]' \
  '(-tr -traversable)'{-tr+,-traversable+}'[traversable directory links]:pattern:' \
  '-tkt[do not remove traversable link targets]' \
  '-tre[auto-add traversable links matching pattern]:pattern:' \
  '-kd+[keep-dirs: protect directories from removal]:pattern:' \
  '(-i -ignore)'{-i+,-ignore+}'[exclude matching files]:pattern:' \
  '(-cp -copy)'{-cp+,-copy+}'[copy matching files instead of symlinking]:pattern:' \
  '(-f -force)'{-f,-force}'[skip conflicts where possible]' \
  '-F+[load additional config file]:config file:_files' \
  '*:package:_directories' && return 0
