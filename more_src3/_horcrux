#compdef horcrux
# Documentation: upstream cmd/horcrux/cmd/*.go at github.com/strangelove-ventures/horcrux
# Reference accessed: 2026-05-30
# Strangelove horcrux R51 — threshold-signing MPC service for CometBFT
# validators. Distributes validator private keys across multiple signer
# nodes via threshold Ed25519 signatures.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'config:configure horcrux (init/migrate)'
  'start:start the horcrux signer'
  'address:show the validator address'
  'create-cosigner-ed25519-shards:create Ed25519 cosigner shards'
  'create-cosigner-ecies-shards:create ECIES cosigner shards'
  'create-cosigner-rsa-shards:create RSA cosigner shards (DEPRECATED)'
  'elect:elect a new leader (raft)'
  'leader:show current leader'
  'state:inspect or modify sign state (show/set/import)'
  'version:show version'
)

local -a _config_subs
_config_subs=(
  'init:initialize configuration file and home directory'
  'migrate:migrate configuration from legacy format'
)

local -a _state_subs
_state_subs=(
  'show:show the sign state for a specific chain-id'
  's:alias for show'
  'set:set the height for the sign state of a specific chain-id'
  'import:import sign-state from a legacy priv_validator_state.json'
  'i:alias for import'
)

_arguments -C -s -S \
  '--home=[directory for config and data (default $HOME/.horcrux)]:directory:_directories' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'horcrux subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      config)
        _arguments -C \
          '(-): :->confcmd' \
          '(-)*:: :->confcmd_args' && ret=0
        case $state in
          confcmd)
            _describe -t commands 'horcrux config subcommand' _config_subs && ret=0
            ;;
          confcmd_args)
            case $words[1] in
              init)
                _arguments \
                  '(-m --mode)-m+[sign mode]:mode:(threshold single)' \
                  '(-m --mode)--mode=[sign mode]:mode:(threshold single)' \
                  '(-n --node)*-n+[chain node (tcp://addr:port)]:url:' \
                  '(-n --node)*--node=[chain node (tcp://addr:port)]:url:' \
                  '(-c --cosigner)*-c+[cosigner (tcp://addr:p2p-port)]:url:' \
                  '(-c --cosigner)*--cosigner=[cosigner (tcp://addr:p2p-port)]:url:' \
                  '(-t --threshold)-t+[shards for threshold signature]:N:' \
                  '(-t --threshold)--threshold=[shards for threshold signature]:N:' \
                  '(-d --debug-addr)-d+[debug server listen address]:addr:' \
                  '(-d --debug-addr)--debug-addr=[debug server listen address]:addr:' \
                  '(-k --key-dir)-k+[key directory]:directory:_directories' \
                  '(-k --key-dir)--key-dir=[key directory]:directory:_directories' \
                  '--raft-timeout=[cosigner raft timeout (default 500ms)]:duration:' \
                  '--grpc-timeout=[cosigner gRPC timeout (default 500ms)]:duration:' \
                  '(-o --overwrite)-o[overwrite existing config.yaml]' \
                  '(-o --overwrite)--overwrite[overwrite existing config.yaml]' \
                  '--bare[allow initialization without validation]' \
                  '(-g --gprc-address)-g+[gRPC listener address]:addr:' \
                  '(-g --gprc-address)--gprc-address=[gRPC listener address]:addr:' \
                  '--max-read-size=[max read size for connections (default 1048576)]:N:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      start)
        _arguments \
          '--accept-risk[required for single-signer-mode (unsupported)]' && ret=0
        ;;
      state)
        _arguments -C \
          '(-): :->scmd' \
          '(-)*:: :->scmd_args' && ret=0
        case $state in
          scmd)
            _describe -t commands 'horcrux state subcommand' _state_subs && ret=0
            ;;
          scmd_args)
            case $words[1] in
              show|s)
                _arguments '1:chain-id:' && ret=0
                ;;
              set)
                _arguments \
                  '1:chain-id:' \
                  '2:height:' && ret=0
                ;;
              import|i)
                _arguments '1:chain-id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
