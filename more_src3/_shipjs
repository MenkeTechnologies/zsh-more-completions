#compdef shipjs
# Documentation: https://github.com/algolia/shipjs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'setup:interactive project setup wizard (creates ship.config.js)'
  'prepare:bump version, update changelog, open release PR'
  'trigger:run release after PR merge (publish, tag, release notes)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'shipjs subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (setup|prepare|trigger)
        _arguments \
          '(-d --dir)'{-d+,--dir=}'[repo path]:dir:_files -/' \
          '--dry-run[dry run]' \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
