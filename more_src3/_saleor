#compdef saleor
# _saleor — Saleor Cloud commerce CLI (saleor/saleor-cli)
# upstream: https://github.com/saleor/saleor-cli
# Subcommands + flags from src/cli.ts (yargs).

_saleor() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--json[output the data as JSON]' \
        '--short[output data as text]' \
        '(-u --url --instance)'{-u+,--url=,--instance=}'[Saleor instance API URL]:url:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_saleor_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_saleor_commands] )) ||
_saleor_commands() {
    local -a commands
    commands=(
        'info:show CLI / current environment info'
        'status:show login + connectivity status'
        'login:authenticate against Saleor Cloud'
        'logout:remove cached credentials'
        'example:scaffold a Saleor example project'
        'register:register a new Saleor account'
        'trigger:trigger a Saleor Cloud event/webhook'
        'organization:manage Saleor Cloud organizations (alias: org)'
        'environment:manage environments (alias: env)'
        'backup:manage Saleor Cloud backups'
        'task:manage Saleor Cloud tasks'
        'job:alias for task'
        'project:manage Saleor Cloud projects'
        'storefront:create a Next.js storefront (alias: store)'
        'telemetry:manage telemetry preferences (alias: tele, deprecated)'
        'webhook:manage environment webhooks (alias: hook)'
        'app:manage Saleor Apps'
        'vercel:integrate with Vercel'
        'github:integrate with GitHub'
        'open:open a Saleor Cloud resource in the browser'
    )
    _describe -t commands 'saleor command' commands
}

_saleor "$@"
