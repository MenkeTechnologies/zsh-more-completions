#compdef hivexsh hivexml hivexget hivexregedit hivexsh-cli
# _hivexsh — Red Hat libhivex hivexsh interactive shell CLI for inspecting and modifying Windows registry hive files navigating registry hierarchies cd ls lsval del setval add commit list keys (libguestfs team, C); getopt
# upstream: https://github.com/libguestfs/hivex

_hivexsh() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f+[script file]:file:_files -g "*.txt *.sh *.hivex"' \
        '--script-file=+[script file]:file:_files' \
        '-w[allow writes]' \
        '--write[allow writes]' \
        '-r[only show values]' \
        '*:hive file:_files -g "SYSTEM SOFTWARE SAM SECURITY DEFAULT NTUSER.DAT *.hive"'
}

_hivexsh "$@"
