#compdef lpoptions
# Documentation: https://manpages.debian.org/lpoptions
# Source: OpenPrinting/cups systemv/lpoptions.c — list/set CUPS printer options (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[set default destination]:dest:_default' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-E[use encryption]' \
    '-l[list available options]' \
    '*-o+[set option]:name=value:_default' \
    '-p+[printer to operate on]:printer:_default' \
    '*-r+[remove option]:name:_default' \
    '-x+[remove options for printer]:printer:_default' \
    && ret=0

return ret
