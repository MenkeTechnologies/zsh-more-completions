#compdef veewee
# _veewee — Veewee (Thor-based bootstrapper for vagrant/virtualbox/vmware/kvm/parallels boxes from ISO + a definition tree; templates subcommand lists definitions, vbox/kvm/vmfusion/parallels stem each take build/destroy/halt/up/ssh/postinstall-files)
# upstream: https://github.com/jedi4ever/veewee
# Subcommands from veewee lib/veewee/cli.rb on tip.

_veewee() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'veewee command' '(templates list define ssh build destroy halt up validate version export ostype hypervisor copy basebox vbox kvm vmfusion parallels)' ;;
        args)
            case $line[1] in
                vbox|kvm|vmfusion|parallels) _describe -t commands 'sub-action' '(build destroy halt up validate ssh undefine list templates copy export ostype postinstall-files screenshot)' ;;
                templates) _describe -t commands 'templates action' '(list)' ;;
                define|build|destroy|halt|up|ssh|validate|export) _arguments '*:box name:' ;;
            esac
            ;;
    esac
}

_veewee "$@"
