#compdef spamd-setup
# Documentation: man spamd-setup(8)
# Source: openbsd/src libexec/spamd-setup — load spamd blacklists (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[blacklisting mode (spamd and pf tables)]' \
    '-D[daemonize, run in background]' \
    '-d[debug mode, diagnostic output]' \
    '-n[dry run, do not send data]' \
    && ret=0

return ret
