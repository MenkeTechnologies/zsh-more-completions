#compdef hmmer
# Documentation: https://github.com/EddyRivasLab/hmmer/blob/master/src/Makefile.in
# Documentation: http://hmmer.org/
# Reference accessed: 2026-05-27
# Verified: upstream src/Makefile.in PROGS list — no umbrella "hmmer" binary exists.
# HMMER 3.x ships individual executables (hmmalign, hmmbuild, hmmconvert, hmmemit,
# hmmfetch, hmmlogo, hmmpgmd, hmmpgmd_shard, hmmpress, hmmscan, hmmsearch, hmmsim,
# hmmstat, jackhmmer, phmmer, nhmmer, nhmmscan, makehmmerdb, alimask). No combined
# "hmmer" front-end is provided. This file exists as a placeholder so user-defined
# wrappers/aliases named "hmmer" receive file-name completion.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:file:_files' && ret=0
return ret
