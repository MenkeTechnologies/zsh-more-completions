#compdef kibit
# _kibit — Yiannis Spiropoulos kibit Clojure code suggestion tool CLI alias (jonase team, Clojure); leiningen plugin
# upstream: https://github.com/jonase/kibit

_kibit() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--replace[apply replacements]' \
        '--interactive[interactive mode]' \
        '--reporter=+[reporter]:r:(text markdown)' \
        '--rules=+[rule files]:file:_files' \
        '--init-ns=+[init ns]:str:' \
        '--exit-code[non-zero exit on suggestions]' \
        '*:paths:_files'
}

_kibit "$@"
