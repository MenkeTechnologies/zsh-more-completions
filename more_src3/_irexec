#compdef irexec
# Documentation: https://manpages.debian.org/bookworm/lirc/irexec.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# irexec: run commands triggered by LIRC events
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[display usage summary]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-d --daemon)'{-d,--daemon}'[fork to background]' \
  '(-D --loglevel)'{-D,--loglevel=}'[amount of logging information]:level:(error warning info notice debug trace trace2)' \
  '(-n --name)'{-n,--name=}'[program name identifier in lircd.conf]:name:' \
  '*:config file:_files' && ret=0
return ret
