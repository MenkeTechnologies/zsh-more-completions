#compdef kysely kysely-ctl
# Documentation: https://github.com/kysely-org/kysely-ctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kysely-ctl (kysely-org/kysely-ctl). Subcommands taken from the upstream
# README. Removed from prior file: invented --config / -e --environment
# global flags not documented upstream.

_kysely-ctl() {
    local line state
    local -a commands
    commands=(
        'init:scaffold a kysely.config.ts file'
        'migrate\:make:create a new migration file'
        'migrate\:latest:run all pending migrations'
        'migrate\:up:run the next pending migration'
        'migrate\:down:rollback the last executed migration'
        'migrate\:rollback:rollback migrations (requires --all)'
        'migrate\:list:list all migrations'
        'seed\:make:create a new seed file'
        'seed\:run:run all seed files'
        'seed\:list:list all available seed files'
        'sql:execute a SQL query'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'kysely command' commands
            ;;
        args)
            case $line[1] in
                migrate:make|seed:make)
                    _arguments '1:name:'
                    ;;
                migrate:rollback)
                    _arguments '--all[rollback all migrations]'
                    ;;
                sql)
                    _arguments \
                        '(-f --format)'{-f+,--format=}'[output format]:format:(json)' \
                        '1:query:'
                    ;;
            esac
            ;;
    esac
}

_kysely-ctl "$@"
