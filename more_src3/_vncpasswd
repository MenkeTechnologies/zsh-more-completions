#compdef vncpasswd
# _vncpasswd — TigerVNC vncpasswd (create or change a VNC authentication password file; -f reads cleartext from stdin and writes the obfuscated form to stdout, no positional file means default ~/.vnc/passwd)
# upstream: https://github.com/TigerVNC/tigervnc
# Flags from tigervnc unix/vncpasswd/vncpasswd.cxx on tip.

_vncpasswd() {
    _arguments \
        '-f[read cleartext from stdin and write encrypted to stdout]' \
        '-help[show help]' \
        '1:password file:_files'
}

_vncpasswd "$@"
