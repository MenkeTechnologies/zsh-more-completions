#compdef zfs-snapshot
# _zfs-snapshot — OpenZFS zfs snapshot create read-only snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-snapshot() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-r[recursive]' \
        '-o+[property=value]:str:' \
        '*:dataset@name:'
}

_zfs-snapshot "$@"
