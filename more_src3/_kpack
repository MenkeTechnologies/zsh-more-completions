#compdef kpack kp
# _kpack — VMware Tanzu kpack and kp CLI for the Kubernetes-native Cloud Native Buildpacks image building service (vmware-tanzu team, Go); cobra
# upstream: https://github.com/buildpacks-community/kpack-cli

_kpack() {
    local -a sub=(
        'build:build subcommands'
        'image:image subcommands'
        'builder:builder subcommands'
        'clusterbuilder:cluster builder subcommands'
        'clusterstack:cluster stack subcommands'
        'clusterstore:cluster store subcommands'
        'clusterlifecycle:cluster lifecycle subcommands'
        'config:config subcommands'
        'lifecycle:lifecycle subcommands'
        'secret:secret subcommands'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--kubeconfig=+[kubeconfig path]:file:_files' \
        '--context=+[kube context]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[namespace]:str:' \
        '--output=+[format]:f:(yaml json)' \
        '-o+[format]:f:(yaml json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kpack subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments '1:build cmd:(list status logs)' ;;
                image) _arguments '1:image cmd:(create patch save list status delete trigger)' ;;
                builder) _arguments '1:builder cmd:(create patch save list status delete)' ;;
                clusterbuilder) _arguments '1:clusterbuilder cmd:(create patch save list status delete)' ;;
                clusterstack) _arguments '1:clusterstack cmd:(create patch save list status delete)' ;;
                clusterstore) _arguments '1:clusterstore cmd:(create add remove patch save list status delete)' ;;
                config) _arguments '1:config cmd:(canonical-repository default-service-account default-repository lifecycle-image)' ;;
                secret) _arguments '1:secret cmd:(create list delete)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kpack "$@"
