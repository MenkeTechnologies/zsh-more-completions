#compdef xrdsssadmin
# Documentation: https://manpages.opensuse.org/Leap-15.6/xrootd-server/xrdsssadmin.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream manpage only documents `xrdsssadmin [options] command [file]`
# synopsis and points to external sec_config docs (404 at time of access).
# Refusing to fabricate per-flag/per-subcommand completions.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '1:command:' \
  '*:file:_files' && ret=0
return ret
