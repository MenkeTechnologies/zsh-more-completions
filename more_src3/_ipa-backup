#compdef ipa-backup
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-backup.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-backup.1.

# ipa-backup: back up FreeIPA server
local curcontext="$curcontext" ret=1
_arguments -C \
  '--gpg[encrypt backup file]' \
  '--data[backup data only]' \
  '--logs[include IPA service logs in backup]' \
  '--online[perform online backup (requires --data)]' \
  '--disable-role-check[backup despite missing cluster roles]' \
  '(-v --verbose -d --debug)'{-v,--verbose,-d,--debug}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[output only errors]' \
  '--log-file=[log to file]:file:_files' && ret=0
return ret
