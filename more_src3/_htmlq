#compdef htmlq
# Documentation: https://github.com/mgdm/htmlq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# htmlq - like jq, but for HTML.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-t --text)'{-t,--text}'[output only the text content of elements]' \
  '(-a --attribute)'{-a+,--attribute=}'[return value of the specified attribute]:attribute name:' \
  '(-b --base)'{-b+,--base=}'[use specified URL as the base URL]:base URL:_urls' \
  '(-B --detect-base)'{-B,--detect-base}'[detect base URL from <base> tag in document]' \
  '(-f --filename)'{-f+,--filename=}'[read input from specified file]:input file:_files' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print the serialized output]' \
  '(-w --ignore-whitespace)'{-w,--ignore-whitespace}'[ignore whitespace-only text nodes]' \
  '*'{-r+,--remove-nodes=}'[remove nodes matching specified selector]:css selector:' \
  '(-o --output)'{-o+,--output=}'[write output to file]:output file:_files' \
  '*:CSS selector:' && ret=0

return ret
