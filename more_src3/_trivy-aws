#compdef trivy-aws
# _trivy-aws — Aqua Trivy AWS account scanner subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-aws() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--timeout=+[timeout]:dur:' \
        '--format=+[format]:fmt:(table json sarif cyclonedx)' \
        '-f+[format]:fmt:(table json sarif cyclonedx)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--exit-code=+[exit code]:n:' \
        '--ignorefile=+[ignore file]:file:_files' \
        '--region=+[AWS region]:region:' \
        '--account=+[AWS account]:str:' \
        '--profile=+[AWS profile]:str:' \
        '--arn=+[ARN]:str:' \
        '--service=+[service]:list:' \
        '--skip-services=+[skip services]:list:' \
        '--max-cache-age=+[max cache age]:dur:' \
        '--update-cache[update cache]' \
        '--endpoint=+[endpoint URL]:url:_urls' \
        '--compliance=+[compliance spec]:spec:' \
        '--report=+[report mode]:r:(all summary)' \
        '*:arg:'
}

_trivy-aws "$@"
