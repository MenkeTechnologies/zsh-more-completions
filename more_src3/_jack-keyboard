#compdef jack-keyboard
# _jack-keyboard — virtual MIDI keyboard for JACK MIDI (trojanc/jack-keyboard)
# upstream: https://jack-keyboard.sourceforge.net/
# Flags from jack-keyboard(1) man page.

_jack-keyboard() {
    _arguments \
        '-C[enable keyboard-cue overlay]' \
        '-G[disable GUI]' \
        '-K[grab the keyboard globally]' \
        '-T[toggle titlebar visibility]' \
        '(- *)-V[show version]' \
        '-a+[auto-connect to named input port]:port:' \
        '-k[allow connections to other jack-keyboard instances]' \
        '-r+[rate limit in Kbaud (0 = off)]:rate:' \
        '-t[send MIDI with zero time offset]' \
        '-u[send program/bank change on reconnect]' \
        '-c+[initial MIDI channel]:channel:' \
        '-b+[initial MIDI bank]:bank:' \
        '-p+[initial MIDI program]:program:' \
        '-l+[computer keyboard layout]:layout:(QWERTY QWERTZ AZERTY DVORAK)'
}

_jack-keyboard "$@"
