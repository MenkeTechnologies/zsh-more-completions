#compdef logdna-cli logdna
# _logdna-cli — Mezmo LogDNA logdna-cli CLI command-line frontend wrapping the LogDNA now Mezmo cloud-based log aggregation real-time tailing search alerting platform CLI providing register login logout key view config switch tail search export filter app host level api-key service-key share-view alert preset graph board webhook host-tag custom-parser unparsed (Mezmo LogDNA team, JavaScript); commander
# upstream: https://app.mezmo.com/

_logdna-cli() {
    local -a sub=(
        'register:register account'
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'key:print ingestion key'
        'view:view operations'
        'config:configure'
        'switch:switch account'
        'tail:tail logs'
        'search:search logs'
        'export:export logs'
        'alert:alert operations'
        'preset:preset operations'
        'graph:graph operations'
        'board:board operations'
        'webhook:webhook operations'
        'host-tag:host tag operations'
        'parser:custom parser operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--service-key=+[key]:str:' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--account=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--app=+[name]:str:' \
        '-a+[app]:str:' \
        '--host=+[name]:_hosts' \
        '-H+[host]:_hosts' \
        '--level=+[l]:l:(DEBUG INFO NOTICE WARN ERROR CRITICAL ALERT EMERGENCY)' \
        '-l+[level]:l:(DEBUG INFO NOTICE WARN ERROR CRITICAL ALERT EMERGENCY)' \
        '--prefer=+[v]:v:(timestamp _line)' \
        '-p+[prefer]:str:' \
        '--from=+[ts]:str:' \
        '--to=+[ts]:str:' \
        '--size=+[N]:n:' \
        '--tag=+[name]:str:' \
        '-t+[tag]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'logdna subcommand' sub ;;
        args)
            case $words[1] in
                tail|search|export) _arguments '*:query:' ;;
                view|alert|preset|graph|board|webhook|host-tag|parser) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_logdna-cli "$@"
