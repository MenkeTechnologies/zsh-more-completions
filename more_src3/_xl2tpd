#compdef xl2tpd
# _xl2tpd — xelerance xl2tpd (L2TP daemon used as a control/transport layer for IPsec/L2TP and PPPoL2TP VPNs; -c config file, -s secrets file, -p pidfile, -D debug, -f foreground, -v verbose, -C control file path, -t tunnel rws, -a access concentrator, -L listen address, -k kill running daemon; reads /etc/xl2tpd/xl2tpd.conf by default)
# upstream: https://github.com/xelerance/xl2tpd
# Flags from xl2tpd src/xl2tpd.c on tip.

_xl2tpd() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '-s+[secrets file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-D[debug]' \
        '-f[foreground]' \
        '-C+[control file]:file:_files' \
        '-t+[tunnel rws]:n:' \
        '-a+[access concentrator]:ac:' \
        '-L+[listen address]:addr:' \
        '-k[kill running daemon]'
}

_xl2tpd "$@"
