#compdef unsetopt
# Documentation: man zshoptions (zsh)
# Source: zsh — turn off named shell options.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a opts
opts=( ${(k)options} )

_arguments -s \
    '-m[treat names as patterns]' \
    '*:shell option:(${opts})' \
    && ret=0

return ret
