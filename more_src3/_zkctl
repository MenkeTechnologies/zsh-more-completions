#compdef zkctl
# _zkctl — Vitess ZooKeeper lifecycle helper
# upstream: https://github.com/vitessio/vitess
# Subcommands + flags from go/cmd/zkctl/command on tip.

_zkctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--zk.cfg=[ZooKeeper config file]:file:_files' \
        '--zk.myid=[ZooKeeper myid]:n:' \
        '*--zk.extra=[extra ZK option (repeatable)]:opt:' \
        '-v[verbosity level]:n:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize a ZooKeeper data dir + myid'
                'start:start ZooKeeper'
                'shutdown:shut down ZooKeeper'
                'teardown:stop ZooKeeper and remove its data dir'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_zkctl "$@"
