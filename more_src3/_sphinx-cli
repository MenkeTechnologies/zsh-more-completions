#compdef sphinx-cli sphinx-build-cli sphinx-quickstart-cli
# _sphinx-cli — Sphinx Python documentation generator CLI alias (sphinx-doc team, Python); argparse
# upstream: https://github.com/sphinx-doc/sphinx

_sphinx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--show-traceback[show traceback]' \
        '-T[show traceback]' \
        '-b+[builder]:b:(html dirhtml singlehtml htmlhelp qthelp devhelp epub applehelp latex man texinfo text gettext changes xml pseudoxml linkcheck doctest coverage)' \
        '--builder=+[builder]:b:(html dirhtml singlehtml htmlhelp qthelp devhelp epub applehelp latex man texinfo text gettext changes xml pseudoxml linkcheck doctest coverage)' \
        '-a[write all files]' \
        '--write-all[write all files]' \
        '-E[do not use saved env]' \
        '--fresh-env[do not use saved env]' \
        '-t+[tag]:str:' \
        '--tag=+[tag]:str:' \
        '-d+[doctree cache dir]:dir:_files -/' \
        '--doctree-dir=+[doctree cache dir]:dir:_files -/' \
        '-c+[conf.py dir]:dir:_files -/' \
        '--conf-dir=+[conf.py dir]:dir:_files -/' \
        '-C[no conf.py]' \
        '--isolated[no conf.py]' \
        '-D+[override setting]:str:' \
        '--define=+[override setting]:str:' \
        '-A+[html template value]:str:' \
        '--html-define=+[html template value]:str:' \
        '-n[nit-picky mode]' \
        '--nitpicky[nit-picky mode]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-Q[really quiet]' \
        '--silent[really quiet]' \
        '-w+[warning file]:file:_files' \
        '--warning-file=+[warning file]:file:_files' \
        '-W[treat warnings as errors]' \
        '--fail-on-warning[treat warnings as errors]' \
        '--keep-going[keep going on warnings]' \
        '-N[no color]' \
        '--no-color[no color]' \
        '--color[force color]' \
        '-P[show pdb on exception]' \
        '--pdb[show pdb on exception]' \
        '-j+[parallel build]:n:' \
        '--jobs=+[parallel build]:n:' \
        '-M+[make mode]:str:' \
        '--make-mode=+[make mode]:str:' \
        '*:src/out/files:_files'
}

_sphinx-cli "$@"
