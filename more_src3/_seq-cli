#compdef seq-cli
# _seq-cli — GNU coreutils seq print sequence of numbers CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_seq-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f+[printf format]:str:' \
        '--format=+[printf format]:str:' \
        '-s+[separator]:str:' \
        '--separator=+[separator]:str:' \
        '-w[equal width with zero padding]' \
        '--equal-width[equal width with zero padding]' \
        '*:first incr last:'
}

_seq-cli "$@"
