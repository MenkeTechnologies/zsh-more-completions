#compdef taskweaver
# Documentation: https://github.com/microsoft/TaskWeaver
# Reference accessed: 2026-05-22
# Verified: taskweaver/cli/cli.py Click group (init, chat).

# Zsh completion for taskweaver - Microsoft TaskWeaver code-first agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --project)'{-p,--project}'[project directory]:directory:_directories' \
  '--version[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'taskweaver command' \
      'init[initialize TaskWeaver workspace]' \
      'chat[start interactive chat session]' && ret=0
    ;;
esac

return ret
