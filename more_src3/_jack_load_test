#compdef jack_load_test
# Documentation: https://jackaudio.org/
# Source: jackaudio/jack-example-tools tools/load_test.c — stress-test client-load CPU performance.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --timeout)'{-t+,--timeout=}'[wait timeout in microseconds]:usec:' \
    '(- *)'{-h,--help}'[display help message]' \
    '(- *)--version[output version and exit]' \
    && ret=0

return ret
