#compdef signoz
# Documentation: source-direct extraction from upstream
# SigNoz/signoz cmd/root.go (cobra `RootCmd`) + cmd/community/main.go
# (registers server + generate + metastore subcommands via
# `registerServer(...)` / `cmd.RegisterGenerate(...)` /
# `cmd.RegisterMetastore(...)`) + cmd/{server,generate,metastore,
# genconfig,openapi,authz}.go for per-subcommand `Use:` strings
# + nested `Use:` strings under `metastore migrate {sync,up,check}`.
# Reference accessed: 2026-05-30 via gh api.
# SigNoz observability platform R137a — open-source observability
# platform built on OpenTelemetry for logs, metrics, and traces in
# a single pane. Single binary with a Cobra subcommand tree
# `signoz {server | generate {config|web-settings|openapi|authz} |
# metastore migrate {sync|up|check}}`.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '--version[show version]' \
  '1:subcommand:((server\:run-the-signoz-server generate\:generate-artifacts metastore\:metastore-commands))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      server)
        _arguments -s -S \
          '*--config=[path to YAML configuration file (can specify multiple times; later overrides earlier)]:file:_files' \
          && ret=0
        ;;
      generate)
        _arguments -C -s -S \
          '1:artifact-kind:((config\:generate-json-schema-for-config web-settings\:generate-json-schema-for-web-settings openapi\:generate-openapi-schema authz\:generate-authz-permissions-for-frontend))' \
          && ret=0
        ;;
      metastore)
        _arguments -C -s -S \
          '1:metastore-command:((migrate\:run-migrations-for-the-metastore))' \
          '*::: :->metasub' && ret=0
        case "$state" in
          metasub)
            if [[ "${line[1]}" == migrate ]]; then
              _arguments -s -S \
                '1:migrate-kind:((sync\:run-sync-migrations up\:run-up-migrations check\:check-pending-sync-migrations))' \
                && ret=0
            fi
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
