#compdef vikunja
# _vikunja — self-hosted to-do app server (go-vikunja/vikunja)
# upstream: https://github.com/go-vikunja/vikunja
# Subcommands from pkg/cmd/*.go (cobra).

_vikunja() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c+,--config=}'[path to the configuration file]:file:_files -g "*.(yaml|yml|toml|json)"' \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1: :_vikunja_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                web) ;;
                migrate)
                    _arguments \
                        '1: :(rollback list status)' \
                        '*:migrate arg:' && ret=0 ;;
                user)
                    _arguments \
                        '1: :(create delete change-status list reset-password)' \
                        '--username=[username]:name:' \
                        '--email=[email address]:addr:' \
                        '--password=[password]:password:' \
                        '--avatar-provider=[avatar provider]:provider:(default initials gravatar marble upload)' \
                        '--enable[enable the user (with change-status)]' \
                        '--disable[disable the user (with change-status)]' && ret=0 ;;
                dump)
                    _arguments \
                        '(-d --dump)'{-d+,--dump=}'[output dump file]:file:_files -g "*.zip"' && ret=0 ;;
                restore)
                    _arguments '1:dump file:_files -g "*.zip"' && ret=0 ;;
                repair)
                    _arguments \
                        '1: :(file-mime-types orphan-positions projects task-positions)' && ret=0 ;;
                testmail)
                    _arguments '1:recipient email:' && ret=0 ;;
                doctor|healthcheck|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_vikunja_commands] )) ||
_vikunja_commands() {
    local -a commands
    commands=(
        'web:start the Vikunja web server (default)'
        'migrate:run database migrations'
        'user:manage users (create / delete / change-status / list / reset-password)'
        'dump:dump the database, configuration, and attachments into a single zip'
        'restore:restore from a previously created dump zip'
        'repair:run repair routines for known data inconsistencies'
        'doctor:inspect environment and configuration for problems'
        'healthcheck:print a health-check summary suitable for monitoring'
        'testmail:send a test email to verify the SMTP configuration'
        'version:print the Vikunja version'
    )
    _describe -t commands 'vikunja command' commands
}

_vikunja "$@"
