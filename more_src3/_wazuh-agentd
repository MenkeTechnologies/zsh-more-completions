#compdef wazuh-agentd ossec-agentd
# _wazuh-agentd — Wazuh Inc wazuh-agentd CLI for the Wazuh and OSSEC HIDS agent daemon connecting to a manager over OSSEC protocol forwarding syscheck rootcheck logcollector and active-response events (wazuh team, C); getopt
# upstream: https://github.com/wazuh/wazuh

_wazuh-agentd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-dd[double debug]' \
        '-f[foreground]' \
        '--foreground[foreground]' \
        '-t[test configuration]' \
        '--test-config[test configuration]' \
        '-c+[config file]:file:_files -g "*.conf ossec.conf"' \
        '--config=+[config file]:file:_files -g "*.conf ossec.conf"' \
        '-u+[user]:u:_users' \
        '--user=+[user]:u:_users' \
        '-g+[group]:g:_groups' \
        '--group=+[group]:g:_groups' \
        '-D+[home dir]:dir:_files -/' \
        '--home=+[home dir]:dir:_files -/' \
        '-r+[priority]:n:'
}

_wazuh-agentd "$@"
