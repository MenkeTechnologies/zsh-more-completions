#compdef VBoxNetNAT
# Documentation: https://github.com/mirror/vbox/blob/master/src/VBox/NetworkServices/NAT/VBoxNetLwipNAT.cpp
# Reference accessed: 2026-05-21
# Verified: upstream VirtualBox VBoxNetLwipNAT.cpp source (RTGetOpt option array).

# VBoxNetNAT: VirtualBox NAT Network service (lwIP-based)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --network)'{-n+,--network=}'[network name]:name:' \
  '*'{-v,--verbose}'[verbose (repeatable)]' && ret=0
return ret
