#compdef version-bump-prompt
# _version-bump-prompt — interactive package version bumper (JS-DevTools/version-bump-prompt)
# upstream: https://github.com/JS-DevTools/version-bump-prompt
# Flags from src/cli/parse-args.ts (command-line-args).

_version-bump-prompt() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--preid=[pre-release identifier]:preid:(alpha beta rc next)' \
        '(-c --commit)'{-c+,--commit=}'[git commit (optionally with message)]:msg:' \
        '(-t --tag)'{-t+,--tag=}'[git tag (optionally with template)]:tag:' \
        '(-p --push)'{-p,--push}'[git push the commit/tag]' \
        '(-a --all)'{-a,--all}'[include all modified files in the commit]' \
        '--no-verify[skip git hooks]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '--ignore-scripts[skip preversion/postversion scripts]' \
        '1:release type or version:(major minor patch premajor preminor prepatch prerelease prompt)' \
        '*:file to bump:_files'
}

_version-bump-prompt "$@"
