#compdef wordfinder
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/wordfinder.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS wordfinder: match large sequences against another sequence set.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-asequence=[query sequence set]:file:_files' \
  '-bsequence=[target sequence database]:file:_files' \
  '-gapopen=[gap opening penalty]:score:' \
  '-gapextend=[gap extension penalty]:score:' \
  '-outfile=[output filename]:file:_files' \
  '-datafile=[scoring matrix file]:file:_files' \
  '-width=[alignment width]:cols:' \
  '-wordlen=[word length for initial matching]:n:' \
  '-limitmatch=[maximum match score (0=no limit)]:n:' \
  '-limitalign=[maximum alignment length (0=no limit)]:n:' \
  '-lowmatch=[minimum match score (0=no limit)]:n:' \
  '-lowalign=[minimum alignment length (0=no limit)]:n:' \
  '-errfile=[error file]:file:_files' \
  '*:sequence:_files' && ret=0

return ret
