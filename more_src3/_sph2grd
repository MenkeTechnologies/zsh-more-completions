#compdef sph2grd
# Documentation: https://docs.generic-mapping-tools.org/latest/sph2grd.html
# Source: GenericMappingTools/gmt src/sph2grd.c — evaluate spherical-harmonic coefficients onto a grid (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[evaluation type]:mode:(g n)' \
    '-E[evaluate on ellipsoid (default sphere)]' \
    '-F+[Gaussian filter (low/high pass)]:filter:_default' \
    '-G+[output grid file]:file:_files -g "*.{grd,nc}"' \
    '-I+[grid increment]:inc:_default' \
    '-N+[normalisation convention]:norm:(g m s)' \
    '-Q[coefficients use physics phase convention]' \
    '-R+[region]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-r+[grid registration]:reg:(g p)' \
    '-x+[parallel jobs]:n:_default' \
    '*:input table:_files' \
    && ret=0

return ret
