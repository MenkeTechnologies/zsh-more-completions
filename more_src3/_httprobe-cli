#compdef httprobe-cli httprobe
# _httprobe-cli — TomNomNom Tom Hudson httprobe-cli CLI command-line frontend wrapping the httprobe Take a list of domains and probe for working HTTP and HTTPS servers open-source written in Go fast concurrency multiple-ports prefer-https HTTP-HTTPS multiple-schemes timeout-based-detection probe-CIDR custom-resolver stdin-only line-based-input ASCII-tab-delimited (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/httprobe

_httprobe-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[concurrency]:n:' \
        '-t+[timeout ms]:n:' \
        '-p+[probe scheme:port]:str:' \
        '*-p+[probe scheme:port]:str:' \
        '-s[skip default probes]' \
        '-prefer-https[prefer https]' \
        '*:host:'
}

_httprobe-cli "$@"
