#!/bin/zsh
# Add tab completion for `t2` commands for zsh

_t2() {
  local -a commands
  commands=(
    'ap'
    'erase'
    'init'
    'install-drivers'
    'key'
    'list'
    'provision'
    'push'
    'rename'
    'restart'
    'root'
    'run'
    'update'
    'version'
    'wifi'
  )

  if (( CURRENT == 2 ));
    then
    _describe -t commands 'Commands' commands
  fi

  return 0
}

_t2
