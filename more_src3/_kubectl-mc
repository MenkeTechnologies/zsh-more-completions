#compdef kubectl-mc
# Documentation: https://github.com/jonnylangefeld/kubectl-mc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked against
# jonnylangefeld/kubectl-mc pkg/mc/mc.go.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --regex)'{-r+,--regex=}'[regex to filter context names]:pattern:' \
  '(-x --negative-regex)'{-x+,--negative-regex=}'[regex to exclude matches]:pattern:' \
  '(-n --namespaces)'{-n+,--namespaces=}'[comma-separated namespaces override]:namespaces:' \
  '(-l --list-only)'{-l,--list-only}'[just list contexts matching the regex]' \
  '(-p --max-processes)'{-p+,--max-processes=}'[max parallel kubectl executions]:n:' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:' \
  '*:kubectl arguments after --: _default'
