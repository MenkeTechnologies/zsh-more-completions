#compdef scons-cli
# _scons-cli — SCons python build tool CLI alias (SCons Foundation, Python); custom argparse
# upstream: https://github.com/SCons/scons

_scons-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-b[ignored]' \
        '-c[clean targets]' \
        '--clean[clean targets]' \
        '--remove[clean targets]' \
        '-C+[change to dir]:dir:_files -/' \
        '--directory=+[change to dir]:dir:_files -/' \
        '-D[search up for SConstruct]' \
        '--debug=+[debug type]:t:(count duplicate explain findlibs includes memoizer memory objects pdb prepare presub stacktrace time)' \
        '-f+[script file]:file:_files -g "SConstruct sconstruct *.scons"' \
        '--file=+[script file]:file:_files -g "SConstruct sconstruct *.scons"' \
        '--cache-debug=+[cache debug file]:file:_files' \
        '--cache-disable[disable derived-file caching]' \
        '--no-cache[disable derived-file caching]' \
        '--cache-force[populate cache by copying]' \
        '--cache-populate[populate cache by copying]' \
        '--cache-show[print actions cache]' \
        '--cache-readonly[readonly cache]' \
        '--config=+[derived-file caching mode]:m:(auto force cache)' \
        '-i[continue on error]' \
        '--ignore-errors[continue on error]' \
        '-I+[include dir]:list:_files -/' \
        '--include-dir=+[include dir]:list:_files -/' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-l+[max load]:f:' \
        '--max-drift=+[max drift seconds]:n:' \
        '--md5-chunksize=+[md5 chunksize KB]:n:' \
        '-n[dry run]' \
        '--no-exec[dry run]' \
        '--just-print[dry run]' \
        '--dry-run[dry run]' \
        '--recon[dry run]' \
        '--no-md5-progress[no md5 progress]' \
        '--no-site-dir[no site dir]' \
        '--profile=+[profile output]:file:_files' \
        '-q[quiet]' \
        '--question[ask if up to date]' \
        '-Q[no progress messages]' \
        '--quiet[no progress messages]' \
        '--random[random build order]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--no-print-directory[no print directory]' \
        '--site-dir=+[site dir]:dir:_files -/' \
        '--stack-size=+[python stack size]:n:' \
        '--taskmastertrace=+[task master trace file]:file:_files' \
        '-t[touch targets]' \
        '--touch[touch targets]' \
        '-u[search up tree]' \
        '--up[search up tree]' \
        '--search-up[search up tree]' \
        '-U[search up tree (top-level only)]' \
        '--warn=+[warning category]:list:' \
        '-Y+[repository dir]:dir:_files -/' \
        '--repository=+[repository dir]:dir:_files -/' \
        '--srcdir=+[source dir]:dir:_files -/' \
        '*:target:'
}

_scons-cli "$@"
