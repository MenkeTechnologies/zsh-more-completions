#compdef stoolap
# ============================================================================
# stoolap - high-performance embedded SQL database
#            with MVCC transactions (Rust, Apache-2.0)
#
# Author : Stoolap Contributors (stoolap)
# Upstream: https://github.com/stoolap/stoolap
# crates : stoolap (binary: stoolap)
#
# `stoolap` is an embedded SQL database written in Rust
# that emphasizes ANSI-SQL coverage + MVCC concurrency +
# crash-safe on-disk format. The CLI provides both an
# interactive REPL (with rustyline-backed line editing +
# `.stoolap_history`) and a one-shot query mode for use
# in scripts. The on-disk format includes LZ4-compressed
# WAL + LZ4-compressed cold volumes + roaring-bitmap-
# encoded inverted indexes (the broader use case for
# the roaring crate dep).
#
# Usage:
#   stoolap [-d <dsn>] [options]
#   stoolap -d memory://                     # in-memory
#   stoolap -d file:///tmp/mydb              # persistent
#   stoolap -d file:///tmp/mydb -e "SELECT 1"
#
# Flags (clap derive Parser):
#   -d, --db <dsn>          - database path (file://<path>
#                              or memory://; default
#                              memory://)
#   -j, --json              - output query results as
#                              JSON
#   -q, --quiet             - suppress connection messages
#   -l, --limit <n>         - max rows to display (0 =
#                              unlimited; default 40)
#   -e, --execute <sql>     - run one SQL statement +
#                              exit
#   -f, --file <file>       - run SQL statements from a
#                              file
#   -s, --sync <mode>       - WAL sync mode: none /
#                              normal / full
#   -p, --profile <name>    - persistence profile preset:
#                              fast / normal / durable
#   -t, --timeout <ms>      - per-query timeout in ms
#                              (0 = no timeout)
#       --checkpoint-interval <secs>
#                           - checkpoint interval
#                              (default 60)
#       --compact-threshold <count>
#                           - sub-target volumes per
#                              table before merging
#                              (default 4)
#       --wal-max-size <mb> - max WAL file size in MB
#                              before rotation
#                              (default 64)
#       --compression on|off
#                           - LZ4 compression for WAL +
#                              volumes (default on)
#       --keep-snapshots <count>
#                           - backup snapshots per table
#                              (default 3)
#       --no-checkpoint-on-close
#                           - skip checkpoint at
#                              shutdown
#       --snapshot          - create backup snapshot +
#                              exit
#       --restore [<ts>]    - restore from backup
#                              snapshot (optionally a
#                              specific timestamp like
#                              "20260315-100000")
#       --reset-volumes     - force-delete volumes/ dir
#                              before opening (with
#                              --restore for corruption
#                              recovery)
#   -h, --help              - print help
#   -V, --version           - print version
#
# DSN parameters (parsed from the `?param=value`
# query string on the file:// DSN):
#   sync_mode=none|normal|full
#   checkpoint_interval=<seconds>
#   compact_threshold=<count>
#   compression=on|off
#   wal_compression=on|off
#   volume_compression=on|off
#   keep_snapshots=<count>
#   checkpoint_on_close=on|off
#   wal_max_size=<bytes>
#   wal_buffer_size=<bytes>
#   wal_flush_trigger=<bytes>
#   commit_batch_size=<count>
#   sync_interval_ms=<ms>
#   compression_threshold=<bytes>
#   target_volume_rows=<rows>
#
# The roaring lane is built on `roaring = "0.11"` (declared
# verbatim at upstream Cargo.toml HEAD with the comment
# "Compressed bitmap indexes (used by Lucene, Druid,
# Spark)"), the canonical Rust Roaring Bitmap library by
# the RoaringBitmap working group - github.com/
# RoaringBitmap/roaring-rs, 700+ stars on the Rust crate.
# The broader RoaringBitmap umbrella covers ~12 language
# implementations all governed under one GitHub
# organization (github.com/RoaringBitmap), spec-tracked
# against the same Roaring Bitmap specification document.
#
# The Roaring Bitmap data structure (Chambi-Lemire-Kaser-
# Godin, 2014) is a compressed bitmap representation
# that maintains sub-microsecond query latency on
# multi-billion-bit-set sizes while compressing 2-10x
# vs. uncompressed bitmaps. The compression works by
# splitting the universe into 2^16-bit chunks + picking
# the optimal container per chunk (raw bitmap, sorted
# array, or run-length-encoded run list) based on the
# chunk's density. Lookups + intersections + unions
# stay O(N + M) on the chunk-count rather than the
# bit-count.
#
# Roaring is the de-facto bitmap-index data structure
# in modern analytical databases:
#   - Apache Lucene + Elasticsearch (inverted indexes)
#   - Apache Druid (segment-level bitmap indexes)
#   - Apache Spark (DataFrame filter pushdown bitmaps)
#   - ClickHouse (data-skipping indexes)
#   - InfluxDB IOx (Arrow-based bitmap indexes)
#   - stoolap (SQL inverted indexes - THIS BINARY)
#
# stoolap uses roaring bitmaps for inverted indexes -
# every indexed column maintains a roaring bitmap per
# distinct value, mapping value -> set of row IDs.
# Predicate evaluation (`WHERE col = X AND col2 IN
# (...)`) becomes a bitmap intersection + the resulting
# row-ID bitmap drives the row fetch.
#
# ----------------------------------------------------------------------------
# AXIS 250 :: Roaring Bitmap compressed bitmap index
#              data structure (LANDMARK AXIS)
# Round 1448 :: Rust slot 1 of 4 :: OPENS Axis 250
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : RoaringBitmap/roaring-rs    - the Rust
#                                          implementation
#                                          under the
#                                          RoaringBitmap
#                                          umbrella;
#                                          spec-tracked
#                                          against the
#                                          official
#                                          Roaring Bitmap
#                                          specification
#   Go      : RoaringBitmap/roaring       - Daniel
#                                          Lemire's
#                                          reference Go
#                                          implementation;
#                                          Lemire is the
#                                          algorithm's
#                                          co-inventor +
#                                          maintains the
#                                          C + C++ + Go +
#                                          Java reference
#                                          impls under
#                                          the same
#                                          umbrella
#   TS/Node : SalvatorePreviti/roaring-node
#                                       - napi-rs binding
#                                          to the C++
#                                          reference impl
#                                          (CRoaring);
#                                          inherits the
#                                          spec-author-
#                                          maintained
#                                          C++ canonical
#
# Roaring Bitmap is a clean spec-bound axis - the
# RoaringFormatSpec document (github.com/RoaringBitmap/
# RoaringFormatSpec) defines the wire format byte-for-
# byte; compliant implementations produce byte-identical
# serialized bitmaps + cross-deserialize correctly.
#
# Structural commentary on the canonical libraries:
#   - RoaringBitmap/roaring-rs (Rust): the Rust impl
#     under the umbrella; not by Lemire personally but
#     by community maintainers tracking the spec
#   - RoaringBitmap/roaring (Go): Daniel Lemire is
#     the algorithm's CO-INVENTOR (Chambi-Lemire-Kaser-
#     Godin 2014) + the personal maintainer of the Go
#     reference implementation; this is the unique
#     algorithm-author = library-author root-of-trust
#     pattern (similar to BurntSushi's TOML position
#     at Axis 243 + the BLAKE3-team's Rust position
#     at Axis 245)
#   - SalvatorePreviti/roaring-node (Node): napi-rs
#     binding to CRoaring (Lemire's C reference impl);
#     inherits the spec-author-maintained C canonical
#
# Cross-language interop at the wire format level - same
# RoaringFormatSpec byte string round-trips byte-
# identically through all umbrella implementations
# (Rust, Go, Java, C, C++, Python, JavaScript, Swift,
# Haskell, ...). The RoaringFormatSpec spec doc
# coordinates this.
#
# Axis 250 opens at the milestone LANDMARK AXIS with the
# Rust slot at the RoaringBitmap umbrella's Rust
# implementation. Lemire's spec-author = library-author
# root-of-trust pattern is the key structural feature.
# ============================================================================

_stoolap() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-d --db)'{-d,--db}'[database DSN (file://<path> or memory://)]:dsn:' \
        '(-j --json)'{-j,--json}'[output query results as JSON]' \
        '(-q --quiet)'{-q,--quiet}'[suppress connection messages]' \
        '(-l --limit)'{-l,--limit}'[max rows to display (0 = unlimited)]:n:' \
        '(-e --execute)'{-e,--execute}'[run one SQL statement + exit]:sql:' \
        '(-f --file)'{-f,--file}'[run SQL statements from a file]:file:_files -g "*.sql"' \
        '(-s --sync)'{-s,--sync}'[WAL sync mode]:mode:(none normal full)' \
        '(-p --profile)'{-p,--profile}'[persistence profile preset]:profile:(fast normal durable)' \
        '(-t --timeout)'{-t,--timeout}'[per-query timeout in ms (0 = no timeout)]:ms:' \
        '--checkpoint-interval[checkpoint interval in seconds (default 60)]:seconds:' \
        '--compact-threshold[sub-target volumes per table before merging]:count:' \
        '--wal-max-size[max WAL file size in MB before rotation]:MB:' \
        '--compression[LZ4 compression for WAL + volumes]:on/off:(on off)' \
        '--keep-snapshots[backup snapshots per table]:count:' \
        '--no-checkpoint-on-close[skip checkpoint at shutdown]' \
        '--snapshot[create backup snapshot + exit]' \
        '--restore[restore from backup snapshot (optional timestamp)]:timestamp:' \
        '--reset-volumes[force-delete volumes/ dir before opening]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_stoolap "$@"
