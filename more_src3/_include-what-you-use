#compdef include-what-you-use iwyu
# Documentation: https://include-what-you-use.org/
# Source: include-what-you-use/include-what-you-use iwyu_globals.cc — clang-based include analyser (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--check_also=-[also check globs]:glob:_default' \
    '*--keep=-[keep matching includes]:glob:_default' \
    '--transitive_includes_only[treat transitive includes only]' \
    '--verbose=-[verbosity level]:level:_default' \
    '*--mapping_file=-[mapping file]:file:_files' \
    '--no_internal_mappings[disable built-in mappings]' \
    '--no_default_mappings[deprecated alias]' \
    '--prefix_header_includes=-[PCH include policy]:policy:(add keep remove)' \
    '--pch_in_code[allow PCH in code]' \
    '--max_line_length=-[max diagnostic line length]:n:_default' \
    '--comment_style=-[comment style for suggestions]:style:(none short long)' \
    '--no_comments[do not add why-this-include comments]' \
    '--update_comments[update existing why comments]' \
    '--no_fwd_decls[do not suggest forward declarations]' \
    '--quoted_includes_first[sort quoted includes first]' \
    '--cxx17ns[use C++17 nested namespace syntax]' \
    '--error=-[exit non-zero on suggestions]::level:_default' \
    '--error_always=-[always exit non-zero]::level:_default' \
    '*--debug=-[debug flag]:flag:_default' \
    '*--regex=-[regex driver]:engine:(llvm posix)' \
    '*--experimental=-[experimental option]:option:_default' \
    '--export_mappings=-[export effective mappings]:file:_files' \
    '--help[show help]' \
    '--version[show version]' \
    '*:source file or clang arg:_files' \
    && ret=0

return ret
