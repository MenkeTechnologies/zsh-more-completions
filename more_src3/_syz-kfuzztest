#compdef syz-kfuzztest
# _syz-kfuzztest — userspace driver for kernel KFuzzTest targets (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from syz-kfuzztest/main.go (flag).

_syz-kfuzztest() {
    _arguments \
        '-vmlinux=[path to vmlinux binary]:file:_files' \
        '-cooldown=[cooldown between KFuzzTest invocations (seconds)]:s:' \
        '-threads=[number of threads]:n:' \
        '-display=[seconds between console outputs]:s:' \
        '*:enabled target:'
}

_syz-kfuzztest "$@"
