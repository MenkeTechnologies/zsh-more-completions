#compdef wadm
# Documentation: https://github.com/wasmCloud/wadm/blob/main/src/config.rs
# Reference accessed: 2026-05-21
# Verified: upstream WadmConfig struct (clap derive).
# Removed from prior file: bogus man.archlinux.org URL.
# Added: --host-id, --max-jobs, --cleanup-interval, --multitenant per upstream.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-i --host-id)'{-i,--host-id}'=[host ID (random UUIDv4 if absent)]:id:' \
  '(-l --structured-logging)'{-l,--structured-logging}'[structured JSON logs]' \
  '(-t --tracing)'{-t,--tracing}'[enable OpenTelemetry tracing]' \
  '(-e --tracing-endpoint)'{-e,--tracing-endpoint}'=[tracing OTLP endpoint URL]:url:' \
  '-d+[NATS JetStream domain]:domain:' \
  '(-j --max-jobs)'{-j,--max-jobs}'=[max concurrent jobs]:n:' \
  '(-s --nats-server)'{-s,--nats-server}'=[NATS server URL]:url:' \
  '--nats-creds-file=[NATS creds file]:file:_files' \
  '--nats-jwt=[NATS JWT (requires --nats-seed)]:value:' \
  '--nats-seed=[NATS nkey seed (requires --nats-jwt)]:value:' \
  '--nats-tls-ca-file=[TLS CA file]:file:_files' \
  '--manifest-bucket-name=[manifest KV bucket name]:name:' \
  '--state-bucket-name=[state KV bucket name]:name:' \
  '--cleanup-interval=[host heartbeat cleanup seconds]:seconds:' \
  '--api-prefix=[wadm API topic prefix]:prefix:' \
  '--stream-prefix=[internal stream prefix]:prefix:' \
  '--stream-persistence=[stream storage type]:persistence:(file memory)' \
  '--multitenant[enable multitenant mode]'
