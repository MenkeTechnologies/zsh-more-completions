#compdef tkn
# _tkn-bin — Tekton Pipelines CLI (Tekton + RedHat, Go); manage Tekton Pipelines on k8s
# upstream: https://github.com/tektoncd/cli

_tkn-bin() {
    local -a sub=(
        'bundle:manage tekton bundles'
        'chain:manage tekton chains'
        'clustertask:manage cluster tasks'
        'clustertriggerbinding:manage cluster trigger bindings'
        'completion:print shell completion'
        'condition:manage conditions'
        'customrun:manage custom runs'
        'eventlistener:manage event listeners'
        'hub:hub commands'
        'help:show help'
        'pipeline:manage pipelines'
        'pipelinerun:manage pipelineruns'
        'resource:manage resources'
        'task:manage tasks'
        'taskrun:manage taskruns'
        'triggerbinding:manage trigger bindings'
        'triggertemplate:manage trigger templates'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-k+[kubeconfig]:file:_files' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '-c+[kube context]:context:' \
        '--context+[kube context]:context:' \
        '-n+[namespace]:namespace:' \
        '--namespace+[namespace]:namespace:' \
        '--allow-missing-template-keys+[allow missing template keys]:bool:(true false)' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tkn subcommand' sub ;;
        args)
            case $words[1] in
                pipeline) _arguments '1:pipeline cmd:(delete describe export list logs start)' '*:pipeline:' ;;
                pipelinerun) _arguments '1:pipelinerun cmd:(cancel delete describe export list logs)' '*:pipelinerun:' ;;
                task) _arguments '1:task cmd:(delete describe export list logs start)' '*:task:' ;;
                taskrun) _arguments '1:taskrun cmd:(cancel delete describe export list logs)' '*:taskrun:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_tkn-bin "$@"
