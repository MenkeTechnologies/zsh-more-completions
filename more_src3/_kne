#compdef kne kne_cli
# _kne — OpenConfig Kubernetes Network Emulation CLI (creates meshnet-based layer-2 topologies in k8s)
# upstream: https://github.com/openconfig/kne
# Subcommands + persistent flags from cmd/root.go on tip (cobra).

_kne() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config_file=[path to KNE config file]:file:_files' \
        '--kubecfg=[kubeconfig file]:file:_files' \
        '--report_usage[report anonymous usage metrics]' \
        '--report_usage_project_id=[project to report metrics to]:id:' \
        '--report_usage_topic_id=[pubsub topic to report metrics to]:id:' \
        '--progress[display container bring-up progress]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                create:'create a topology'
                delete:'delete a topology'
                show:'show a topology'
                topology:'topology subcommands'
                deploy:'deploy meshnet/cni/ingress dependencies'
                teardown:'teardown meshnet/cni/ingress dependencies'
            )
            _describe -t commands 'kne subcommand' subs
            ;;
        args)
            case $line[1] in
                create)
                    _arguments \
                        '--dryrun[generate topology but do not push to k8s]' \
                        '--timeout=[timeout for pod status polling]:duration:' \
                        '1:topology yaml:_files -g "*.yaml"'
                    ;;
                delete)
                    _arguments \
                        '--skip_wait[skip waiting for resource deletion]' \
                        '1:topology yaml:_files -g "*.yaml"'
                    ;;
                deploy|teardown)
                    _arguments \
                        '1:deployment yaml:_files -g "*.yaml"'
                    ;;
            esac
            ;;
    esac
}

_kne "$@"
