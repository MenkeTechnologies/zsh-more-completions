#compdef sfgraph
# Documentation: http://www.ahay.org/RSF/sfgraph.html
# Source: ahay/src plot/main/graph.c — 1D line/symbol plot to vplot (run `sfdoc stdplot` for shared params).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'depth=[file with values for colored plot]: :_files -g "*.rsf(-.)"' \
    'scalebar=[(y/n) draw scalebar]: :(y n)' \
    'wantframenum=[(y/n) display third-axis position in corner]: :(y n)' \
    'color=[colormap (default j)]: :_default' \
    'nreserve=[reserved colors in palette]: :_default' \
    'bar=[file with scalebar data]: :_files -g "*.rsf(-.)"' \
    'minval=[scalebar minimum value]: :_default' \
    'maxval=[scalebar maximum value]: :_default' \
    'barreverse=[(y/n) reverse scalebar direction]: :(y n)' \
    'pclip=[clip percentile]: :_default' \
    'symbol=[symbol type]: :_default' \
    'symbolsz=[symbol size array]: :_default' \
    'transp=[(y/n) transpose axes]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
