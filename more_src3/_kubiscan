#compdef kubiscan
# Documentation: https://github.com/cyberark/KubiScan
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for KubiScan. Flags derived from KubiScan.py argparse
# definitions in the upstream repo. KubiScan uses Python argparse so multi-
# character short options use a single dash (e.g. -rcr, -rs).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[file path for static API client]:file:_files' \
  '(-rr --risky-roles)'{-rr,--risky-roles}'[list risky Roles]' \
  '(-rcr --risky-clusterroles)'{-rcr,--risky-clusterroles}'[list risky ClusterRoles]' \
  '(-rar --risky-any-roles)'{-rar,--risky-any-roles}'[list risky Roles and ClusterRoles]' \
  '(-rb --risky-rolebindings)'{-rb,--risky-rolebindings}'[list risky RoleBindings]' \
  '(-rcb --risky-clusterrolebindings)'{-rcb,--risky-clusterrolebindings}'[list risky ClusterRoleBindings]' \
  '(-rab --risky-any-rolebindings)'{-rab,--risky-any-rolebindings}'[list risky RoleBindings and ClusterRoleBindings]' \
  '(-rs --risky-subjects)'{-rs,--risky-subjects}'[list risky subjects]' \
  '(-rp --risky-pods)'{-rp,--risky-pods}'[list risky pods/containers]' \
  '(-d --deep)'{-d,--deep}'[deep scan of pods (requires -rp)]' \
  '(-pp --privleged-pods)'{-pp,--privleged-pods}'[list privileged pods/containers]' \
  '(-a --all)'{-a,--all}'[list all risky resources, users, and pods]' \
  '(-cve --cve)'{-cve,--cve}'[scan CVEs]' \
  '(-jt --join-token)'{-jt,--join-token}'[get join token for the cluster]' \
  '(-psv --pods-secrets-volume)'{-psv,--pods-secrets-volume}'[show pods with access to secrets via volume]' \
  '(-pse --pods-secrets-env)'{-pse,--pods-secrets-env}'[show pods with access to secrets via env]' \
  '(-ctx --context)'{-ctx+,--context=}'[context to use]:context:' \
  '(-p --priority)'{-p+,--priority=}'[filter by priority]:priority:(CRITICAL HIGH LOW)' \
  '(-lt --less-than)'{-lt+,--less-than=}'[filter objects existing less than X days]:days:' \
  '(-ns --namespace)'{-ns+,--namespace=}'[namespace scope]:namespace:' \
  '(-k --kind)'{-k+,--kind=}'[kind of the object]:kind:' \
  '(-r --rules)'{-r,--rules}'[show rules (for risky Roles/ClusterRoles)]' \
  '(-e --examples)'{-e,--examples}'[show examples]' \
  '(-n --name)'{-n+,--name=}'[name]:name:' \
  '(-dt --dump-tokens)'{-dt,--dump-tokens}'[dump tokens from pods]' \
  '(-ho --host)'{-ho+,--host=}'[master IP and port]:host:' \
  '(-c --cert-filename)'{-c+,--cert-filename=}'[certificate authority path]:file:_files' \
  '(-cc --client-certificate)'{-cc+,--client-certificate=}'[client certificate path]:file:_files' \
  '(-ck --client-key)'{-ck+,--client-key=}'[client key path]:file:_files' \
  '(-co --kube-config)'{-co+,--kube-config=}'[kube config filename]:file:_files' \
  '(-t --token-filename)'{-t+,--token-filename=}'[token filename]:file:_files' \
  '(-o --output-file)'{-o+,--output-file=}'[output filename]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[hide the banner]' \
  '(-j --json)'{-j+,--json=}'[export to JSON file]:file:_files' \
  '(-nc --no-color)'{-nc,--no-color}'[print without color]' \
  '(-aarbr --associated-any-rolebindings-role)'{-aarbr+,--associated-any-rolebindings-role=}'[associated RB/CRB to Role]:role:' \
  '(-aarbcr --associated-any-rolebindings-clusterrole)'{-aarbcr+,--associated-any-rolebindings-clusterrole=}'[associated RB/CRB to ClusterRole]:clusterrole:' \
  '(-aarbs --associated-any-rolebindings-subject)'{-aarbs+,--associated-any-rolebindings-subject=}'[associated RB/CRB to Subject]:subject:' \
  '(-aars --associated-any-roles-subject)'{-aars+,--associated-any-roles-subject=}'[associated Roles/ClusterRoles to Subject]:subject:' \
  '(-su --subject-users)'{-su,--subject-users}'[list User subjects]' \
  '(-sg --subject-groups)'{-sg,--subject-groups}'[list Group subjects]' \
  '(-ss --subject-serviceaccounts)'{-ss,--subject-serviceaccounts}'[list ServiceAccount subjects]' \
  '(-rru --rolebinding-rules)'{-rru+,--rolebinding-rules=}'[rules of RoleBinding]:rolebinding:' \
  '(-crru --clusterrolebinding-rules)'{-crru+,--clusterrolebinding-rules=}'[rules of ClusterRoleBinding]:clusterrolebinding:' \
  && ret=0

return ret
