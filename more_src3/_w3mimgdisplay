#compdef w3mimgdisplay
# Documentation: https://github.com/tats/w3m/blob/master/w3mimgdisplay.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (GetOption() in source).
# w3mimgdisplay reads pixel-draw commands from stdin (protocol: 0=draw,
# 1=redraw, 2=terminate, 3=sync, 4=nop, 5=get size, 6=clear).
# Added: -margin, -debug per source review on 2026-05-21.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-test[test mode]' \
  '-size[print image size]:file:_files' \
  '-anim[animation frame limit]:n:' \
  '-margin[clear margin (non-negative)]:n:' \
  '-bg[background color]:color:' \
  '-x[x offset]:x:' \
  '-y[y offset]:y:' \
  '-debug[debug output mode]' && ret=0
return ret
