#compdef xfs_quota
# _xfs_quota — xfsprogs xfs_quota (interactive XFS quota tool; -u user / -g group / -p project quotas, -x expert (edit) mode, -d limits to a path within the filesystem, -c run command then exit, -V show version, -f read commands from file)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs quota/init.c on tip.

_xfs_quota() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-u[user quotas]' \
        '-g[group quotas]' \
        '-p[project quotas]' \
        '-x[expert (edit) mode]' \
        '-d+[scope to dir]:dir:_files -/' \
        '-c+[run command]:command:' \
        '-f+[command file]:file:_files' \
        '-D+[device list path]:file:_files' \
        '-P+[mounted path list]:file:_files' \
        '-t+[mtab path]:file:_files' \
        '*:filesystem:_files'
}

_xfs_quota "$@"
