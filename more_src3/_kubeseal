#compdef kubeseal
# Documentation: https://github.com/bitnami-labs/sealed-secrets
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubeseal - Sealed Secrets CLI

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-o --format)'{-o+,--format=}'[output format]:format:(json yaml)' \
  '--cert=[certificate or URL used for encryption]:file:_files' \
  '--controller-name=[name of the sealed secrets controller]:name' \
  '--controller-namespace=[namespace of the sealed secrets controller]:namespace' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--context=[kubeconfig context to use]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace of the sealed secret]:namespace' \
  '--scope=[scope of the sealed secret]:scope:(strict namespace-wide cluster-wide)' \
  '--name=[name of the sealed secret]:name' \
  '--raw[encrypt a raw value and emit to stdout]' \
  '--from-file=[file to encrypt]:file:_files' \
  '(-f --secret-file)'{-f+,--secret-file=}'[input file with secret to encrypt]:file:_files' \
  '(-w --sealed-secret-file)'{-w+,--sealed-secret-file=}'[output file for sealed secret]:file:_files' \
  '--merge-into=[merge into existing sealed secret file]:file:_files' \
  '--re-encrypt[re-encrypt sealed secrets with latest key]' \
  '--rotate[deprecated alias for --re-encrypt]' \
  '--validate[validate a sealed secret]' \
  '--recovery-unseal[unseal with recovery key]' \
  '--recovery-private-key=[private key file for recovery]:file:_files' \
  '--allow-empty-data[allow empty data in secret]' \
  '--fetch-cert[fetch the certificate from the controller]' \
  '*:file:_files'
