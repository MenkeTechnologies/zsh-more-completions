#compdef xgpsspeed
# Documentation: https://gitlab.com/gpsd/gpsd/-/raw/master/man/xgpsspeed.adoc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed: --rotate (not in upstream xgpsspeed man page).
# Fixed: --speedunits values (knots/kmh/mph per upstream; was mph/kph/knots).
# Added: -?, -D/--debug, --host, -p/--port, -device (documented upstream).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --debug)'{-D+,--debug=}'[debug level]:lvl:' \
  '--speedunits=[speed units]:units:(knots kmh mph)' \
  '--maxspeed=[max speedometer value (nautical mode)]:n:' \
  '--landspeed[simple speedometer display]' \
  '--nautical[nautical speedometer]' \
  '--host=[server to connect to]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[port number]:port:' \
  '-device=[device to connect to]:device:_files -W /dev' \
  '*:server:_hosts' && ret=0

return ret
