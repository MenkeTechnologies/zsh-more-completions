#compdef hcloud-cli
# _huaweicloud — Huawei Cloud CLI (hcloud-cli) (Huawei Cloud, Go); call HCS APIs via local CLI tool
# upstream: https://github.com/huaweicloud/huaweicloud-cli

_huaweicloud() {
    local -a sub=(
        'configure:configure profile'
        'auto-completion:auto completion'
        'meta:metadata commands'
        'login:login'
        'logout:logout'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--profile+[profile]:profile:' \
        '-p+[profile]:profile:' \
        '--region+[region]:region:' \
        '-r+[region]:region:' \
        '--access-key+[access key]:str:' \
        '--secret-key+[secret key]:str:' \
        '--project-id+[project id]:str:' \
        '--domain-id+[domain id]:str:' \
        '--cli-output+[output format]:fmt:(json table)' \
        '--cli-query+[JMESPath query]:str:' \
        '--cli-no-paging[no paging]' \
        '--cli-debug[debug]' \
        '--cli-version+[API version]:v:' \
        '--cli-skip-secure-verify[skip TLS]' \
        '--cli-output-num+[output rows]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hcloud-cli subcommand' sub ;;
    esac
}

_huaweicloud "$@"
