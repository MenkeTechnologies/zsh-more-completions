#compdef vkconfig vkconfig-gui
# Documentation: https://github.com/LunarG/VulkanTools/blob/main/vkconfig_cmd/main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream source vkconfig_core/command_line.cpp.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'gui:launch the GUI configurator'
      'layers:manage Vulkan layers'
      'loader:manage loader configurations'
      'reset:reset configurations'
      'doc:generate documentation'
      'settings:generate layer settings file'
      'help:print help'
      'version:print version'
    )
    _describe -t commands 'vkconfig command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      reset)
        _arguments \
          '(-s --soft)'{-s,--soft}'[soft reset]' \
          '(-h --hard)'{-h,--hard}'[hard reset]' && ret=0
        ;;
      layers)
        _arguments \
          '--list[list layers]' \
          '--list-verbose[list layers verbose]' \
          '--path[show layer path]' \
          '--override[override layers]' \
          '--surrender[surrender layers override]' && ret=0
        ;;
      loader)
        _arguments \
          '(-l --list)'{-l,--list}'[list loader configurations]' \
          '(-o --override)'{-o,--override}'[override loader]' \
          '(-s --surrender)'{-s,--surrender}'[surrender loader override]' \
          '(-i --import)'{-i,--import}'+[import config]:file:_files' \
          '(-e --export)'{-e,--export}'+[export config]:file:_files' \
          '(-d --delete)'{-d,--delete}'+[delete config]:name:' && ret=0
        ;;
      doc)
        _arguments \
          '--html[generate HTML documentation]' \
          '--markdown[generate Markdown documentation]' \
          '--settings[generate settings documentation]' && ret=0
        ;;
      settings)
        _arguments \
          '(-g --generate)'{-g,--generate}'[generate settings]' \
          '(-c --configuration)'{-c,--configuration}'+[configuration name]:name:' \
          '(-l --layers)'{-l,--layers}'+[layers list]:layers:' \
          '--layer=[single layer]:layer:' \
          '(-o --output)'{-o,--output}'+[output file]:file:_files' \
          '(-d --output-dir)'{-d,--output-dir}'+[output directory]:dir:_directories' \
          '--dry-run[do not write output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
