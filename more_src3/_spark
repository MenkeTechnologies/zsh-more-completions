#compdef spark-submit
# Documentation: https://spark.apache.org/docs/latest/submitting-applications.html
# Reference accessed: 2026-05-21
# Verified: `spark-submit --help` output from installed binary.

local -a arguments

arguments=(
    '--master[Spark master URL]:url:(local local\[\*\] yarn spark\://HOST\:PORT mesos\://HOST\:PORT k8s\://HOST\:PORT)'
    '--deploy-mode[Deploy mode]:mode:(client cluster)'
    '--class[Application main class (Java/Scala)]:class:'
    '--name[Application name]:name:'
    '--jars[Comma-separated jars to include on classpaths]:jars:_files -g "*.jar"'
    '--packages[Comma-separated Maven coordinates]:packages:'
    '--exclude-packages[Comma-separated groupId:artifactId to exclude]:packages:'
    '--repositories[Additional Maven repositories]:repos:'
    '--py-files[Python .py, .zip, or .egg files for PYTHONPATH]:files:_files -g "*.{py,zip,egg}"'
    '--files[Files placed in working directory of each executor]:files:_files'
    '--archives[Archives to extract into working directory of each executor]:archives:_files -g "*.{tar.gz,tgz,zip}"'
    '(--conf -c)'{--conf,-c}'[Spark configuration property]:key=value:'
    '--properties-file[Properties file]:file:_files -g "*.{properties,conf}"'
    '--load-spark-defaults[Load conf/spark-defaults.conf in addition to --properties-file]'
    '--driver-memory[Driver memory]:memory:'
    '--driver-java-options[Driver Java options]:options:'
    '--driver-library-path[Driver library path]:path:'
    '--driver-class-path[Driver class path]:path:'
    '--driver-cores[Driver cores (cluster mode)]:cores:'
    '--executor-memory[Executor memory]:memory:'
    '--total-executor-cores[Total cores (standalone)]:cores:'
    '--num-executors[Number of executors (YARN/K8s)]:count:'
    '--executor-cores[Cores per executor]:cores:'
    '--queue[YARN queue]:queue:'
    '--proxy-user[User to impersonate]:user:_users'
    '--principal[Kerberos principal]:principal:'
    '--keytab[Path to keytab file]:file:_files'
    '--supervise[Restart driver on failure (standalone)]'
    '--kill[Kill a submission ID]:submission_id:'
    '--status[Check submission status]:submission_id:'
    '--remote[Spark Connect URL (sc://host:port)]:url:'
    '(--verbose -v)'{--verbose,-v}'[Print additional debug output]'
    '--version[Print version]'
    '(--help -h)'{--help,-h}'[Show help]'
    '*:application jar or script:_files -g "*.{jar,py,R}"'
)

_arguments -s -S $arguments
