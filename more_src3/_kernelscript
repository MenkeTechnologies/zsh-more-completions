_kernelscript() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kernelscript_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--btf-vmlinux-path=[BTF vmlinux file path]:path:_files' \
                        '--kfuncs[extract kfuncs from BTF and generate .kh header]' \
                        ':program type or struct_ops:_kernelscript_prog_types' \
                        ':project name:' && ret=0 ;;
                compile)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        '--no-makefile[do not generate Makefile]' \
                        '--test[compile in test mode (only @test funcs become main)]' \
                        '--builtin-path=[path to builtin KernelScript files]:path:_files -/' \
                        '--btf-vmlinux-path=[BTF vmlinux file path]:path:_files' \
                        ':KernelScript source file:_files -g "*.ks"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kernelscript_commands] )) ||
_kernelscript_commands() {
    local -a commands
    commands=(
        'init:initialize a new KernelScript project'
        'compile:compile KernelScript source to C code'
    )
    _describe -t commands 'kernelscript command' commands
}

(( $+functions[_kernelscript_prog_types] )) ||
_kernelscript_prog_types() {
    local -a types
    types=(
        'xdp:XDP packet processor'
        'tc/ingress:TC classifier (ingress)'
        'tc/egress:TC classifier (egress)'
        'tcp_congestion_ops:TCP congestion control struct_ops'
        'sched_ext_ops:Scheduler extension struct_ops'
    )
    _describe -t types 'KernelScript program type' types
}

_kernelscript "$@"
