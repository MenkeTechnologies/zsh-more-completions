#compdef hugsql
# _hugsql — Curtis Summers hugsql sql in clojure CLI alias (layerware team, Clojure); tools.deps function CLI
# upstream: https://github.com/layerware/hugsql

_hugsql() {
    local -a sub=(
        'def-db-fns:define database fns from sql files'
        'def-sqlvec-fns:define sqlvec fns from sql files'
        'def-template-fns:define template fns from sql files'
        'snippets:print snippets'
        'expand:expand parameter substitutions'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--adapter=+[adapter]:a:(next.jdbc clojure.java.jdbc)' \
        '--file=+[sql file]:file:_files -g "*.sql"' \
        '-f+[sql file]:file:_files -g "*.sql"' \
        '--ns=+[output ns]:str:' \
        '-n+[output ns]:str:' \
        '--db-uri=+[db uri]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hugsql subcommand' sub ;;
        args)
            case $words[1] in
                def-db-fns|def-sqlvec-fns|def-template-fns) _arguments \
                    '1:sql file:_files -g "*.sql"' \
                    '--ns=+[ns]:str:' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--quoting=+[quoting]:q:(ansi off mysql)' ;;
                expand) _arguments \
                    '1:sql:' \
                    '--params=+[params edn]:str:' ;;
            esac
            ;;
    esac
}

_hugsql "$@"
