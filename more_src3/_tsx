#compdef tsx
# Documentation: https://github.com/privatenumber/tsx (src/cli.ts + src/watch/index.ts)
# Reference accessed: 2026-05-29
# Node.js runtime enhanced with esbuild for loading TypeScript & ESM.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'watch:re-run on file changes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--no-cache[disable caching]' \
  '--tsconfig=[custom tsconfig.json path]:file:_files -g "tsconfig*.json"' \
  '(-e --eval)'{-e,--eval=}'[execute TypeScript code string]:code:' \
  '(-p --print)'{-p,--print=}'[print result of evaluated code]:code:' \
  '--input-type=[specify input format]:type:(module commonjs)' \
  '--test[run in test mode]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _alternative \
      'commands:tsx subcommand:(($_subcmds))' \
      'files:script:_files -g "*.(ts|tsx|mts|cts|js|jsx|mjs|cjs)"' && ret=0
    ;;
  args)
    case $line[1] in
      watch)
        _arguments \
          '--noCache[disable caching]' \
          '--tsconfig=[custom tsconfig.json path]:file:_files -g "tsconfig*.json"' \
          '--clearScreen[clear screen on rerun]' \
          '*--ignore=[deprecated; use --exclude]:glob:' \
          '*--include=[additional paths/globs to watch]:glob:' \
          '*--exclude=[paths/globs to exclude from watching]:glob:' \
          '*:script:_files -g "*.(ts|tsx|mts|cts|js|jsx|mjs|cjs)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
