#compdef knctl
# Documentation: https://github.com/cppforlife/knctl/blob/master/docs/cmd/knctl.md
# Reference accessed: 2026-05-19
# Verified: upstream cppforlife/knctl command reference (knctl.md,
# knctl_deploy.md).
# Corrected from prior file: removed invented top-level annotate/tag/
# untag/completion/help; added real domain, ingress, uninstall.
# Global flag is --kubeconfig-context (not --context); -n/--namespace
# is per-command (not global). Replaced invented deploy --limit-*/
# --request-* with documented --min-scale/--max-scale/etc.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'basic-auth-secret:manage basic-auth secrets'
  'build:manage container builds'
  'curl:HTTP curl a service endpoint'
  'deploy:create or update a service'
  'domain:manage domains'
  'ingress:manage ingress'
  'install:install Knative components'
  'logs:tail logs of a service or pod'
  'pod:manage pods'
  'revision:manage service revisions'
  'rollout:manage rollouts'
  'route:manage routes'
  'service:manage Knative services'
  'service-account:manage service accounts'
  'ssh-auth-secret:manage SSH-auth secrets'
  'uninstall:uninstall Knative components'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--column=[only show given columns]:column:' \
  '--json[output as JSON]' \
  '--kubeconfig=[kubeconfig file path]:file:_files' \
  '--kubeconfig-context=[override kubeconfig context]:context:' \
  '--tty[force TTY-like output]' \
  '--no-color[disable color output]' \
  '--non-interactive[non-interactive mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'knctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (service)
        _arguments '*::sub:(create list delete show open url annotate label rollout)' && ret=0 ;;
      (revision)
        _arguments '*::sub:(list delete show annotate tag untag)' && ret=0 ;;
      (route)
        _arguments '*::sub:(list show create)' && ret=0 ;;
      (pod)
        _arguments '*::sub:(list)' && ret=0 ;;
      (build)
        _arguments '*::sub:(create list show delete)' && ret=0 ;;
      (deploy)
        _arguments \
          '(-s --service)'{-s+,--service=}'[specified service]:service:' \
          '(-i --image)'{-i+,--image=}'[set image URL]:image:' \
          '(-n --namespace)'{-n+,--namespace=}'[specified namespace]:namespace:' \
          '*'{-e+,--env=}'[set environment variable (ENV_KEY=value)]:env:' \
          '*--env-config-map=[set env var from a config map]:env:' \
          '*--env-secret=[set env var from a secret]:env:' \
          '*'{-a+,--annotation=}'[set annotation (key=value)]:annotation:' \
          '(-d --directory)'{-d+,--directory=}'[set source code directory]:dir:_directories' \
          '--git-url=[set Git URL]:url:' \
          '--git-revision=[set Git revision]:rev:' \
          '--service-account=[set service account name for building]:sa:' \
          '--template=[set template name]:template:' \
          '*--template-arg=[set template argument (key=value)]:arg:' \
          '--min-scale=[autoscaling minimum number of containers]:n:' \
          '--max-scale=[autoscaling maximum number of containers]:n:' \
          '--container-concurrency=[set container concurrency]:n:' \
          '--build-timeout=[set build stage timeout]:timeout:' \
          '--generate-name[set to generate name]' \
          '--watch-revision-ready[wait for new revision to become ready]' \
          '--watch-pod-logs[watch pod logs for new revision]' \
          '(-l --watch-pod-logs-indefinitely)'{-l,--watch-pod-logs-indefinitely}'[watch pod logs indefinitely]' && ret=0 ;;
      (logs)
        _arguments \
          '(-s --service)'{-s+,--service=}'[specified service]:service:' \
          '(-f --follow)'{-f,--follow}'[follow log output]' && ret=0 ;;
      (curl)
        _arguments \
          '(-s --service)'{-s+,--service=}'[specified service]:service:' \
          '*--header=[HTTP header]:header:' && ret=0 ;;
      (install)
        _arguments '*::arg:' && ret=0 ;;
      (basic-auth-secret|ssh-auth-secret)
        _arguments '*::sub:(create delete list)' && ret=0 ;;
      (service-account)
        _arguments '*::sub:(create delete list)' && ret=0 ;;
      (rollout)
        _arguments '*::sub:(manage)' && ret=0 ;;
    esac ;;
esac

return ret
