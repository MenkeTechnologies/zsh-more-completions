#compdef sumpix
# _sumpix — compute statistics over FITS image pixel regions (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from sumpix.c (single-letter getopt-style).

_sumpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-c[compute circular aperture]' \
        '-d[compute standard deviation]' \
        '-e[compute median]' \
        '-h[print column headers]' \
        '-i[print index]' \
        '-l[compute limits]' \
        '-m[compute mean]' \
        '-n+[decimal places]:n:' \
        '-p[print filename at start of line]' \
        '-r[compute variance]' \
        '-s[compute sum]' \
        '-t[tab-separate values]' \
        '-v[verbose output]' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y or list file:_files'
}

_sumpix "$@"
