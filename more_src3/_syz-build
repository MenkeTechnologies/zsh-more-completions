#compdef syz-build
# _syz-build — build syzkaller-compatible kernel images (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-build/build.go (flag).

_syz-build() {
    _arguments \
        '-os=[OS to build]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[architecture to build]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-vm=[VM type to build]:vm:(gce qemu kvm gvisor android)' \
        '-kernel_src=[path to kernel checkout]:dir:_files -/' \
        '-make=[non-default make]:cmd:_command_names -e' \
        '-compiler=[non-default compiler]:cmd:_command_names -e' \
        '-linker=[non-default linker]:cmd:_command_names -e' \
        '-ccache=[ccache executable]:cmd:_command_names -e' \
        '-config=[kernel config file]:file:_files' \
        '-sysctl=[kernel sysctl file]:file:_files' \
        '-cmdline=[kernel cmdline file]:file:_files' \
        '-userspace=[path to userspace for build]:dir:_files -/' \
        '-trace[trace build process and save debug artefacts]'
}

_syz-build "$@"
