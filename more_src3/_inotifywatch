#compdef inotifywatch
# Documentation: https://github.com/inotify-tools/inotify-tools/blob/master/man/inotifywatch.1.in
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local -a events
events=(
  'access' 'modify' 'attrib' 'close_write' 'close_nowrite' 'close'
  'open' 'moved_to' 'moved_from' 'move' 'create' 'delete'
  'delete_self' 'unmount' 'move_self'
)

local -a arguments

arguments=(
  '(-e --event)'{-e,--event}'[watch for specific event]:event:('"${events[*]}"')'
  '(-t --timeout)'{-t,--timeout}'[timeout in seconds]:seconds:'
  '(-r --recursive)'{-r,--recursive}'[watch directories recursively]'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '--fromfile[read filenames from file]:file:_files'
  '--exclude[exclude files matching pattern]:pattern:'
  '--excludei[exclude files matching pattern (case-insensitive)]:pattern:'
  '(-z --zero)'{-z,--zero}'[output table with zero counts]'
  '(-a --ascending)'{-a,--ascending}'[sort ascending by event count]:event:('"${events[*]}"')'
  '(-d --descending)'{-d,--descending}'[sort descending by event count]:event:('"${events[*]}"')'
  '(-P --no-dereference)'{-P,--no-dereference}'[do not follow symlinks]'
  '(-I --inotify)'{-I,--inotify}'[use inotify backend]'
  '(-F --fanotify)'{-F,--fanotify}'[use fanotify backend]'
  '(-S --filesystem)'{-S,--filesystem}'[watch entire filesystem (fanotify)]'
  '(-q --quiet)'{-q,--quiet}'[quiet output]'
  '(-h --help)'{-h,--help}'[show help]'
  '*:file or directory:_files'
)

_arguments -s -S $arguments
