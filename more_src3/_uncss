#compdef uncss
# Documentation: https://github.com/uncss/uncss
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --ignore)'{-i,--ignore}'=[selectors]:selectors:' \
  '(-m --media)'{-m,--media}'=[media queries]:media:' \
  '(-C --csspath)'{-C,--csspath}'=[CSS path]:dir:_files -/' \
  '(-s --stylesheets)'{-s,--stylesheets}'=[extra sheets]:files:_files' \
  '(-S --ignoreSheets)'{-S,--ignoreSheets}'=[ignore sheets]:patterns:' \
  '(-r --raw)'{-r,--raw}'=[raw CSS]:css:' \
  '(-t --timeout)'{-t,--timeout}'=[ms]:ms:' \
  '(-H --htmlroot)'{-H,--htmlroot}'=[HTML root]:dir:_files -/' \
  '(-u --uncssrc)'{-u,--uncssrc}'=[config JSON]:file:_files' \
  '(-n --noBanner)'{-n,--noBanner}'[no banner]' \
  '(-a --userAgent)'{-a,--userAgent}'=[user agent]:ua:' \
  '(-I --inject)'{-I,--inject}'=[inject JS]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '*:file or URL:_files'
