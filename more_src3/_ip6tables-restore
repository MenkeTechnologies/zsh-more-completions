#compdef ip6tables-restore
# _ip6tables-restore — netfilter ip6tables-restore (atomically load a saved IPv6 iptables ruleset; -c restore counters, -n skip table flush (additive), -t TABLE single-table restore, -M modules dir, -T table filter, -v verbose, -V version, -w wait LOCK seconds; positional argument is the input file (default stdin))
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/ip6tables-restore.c on tip.

_ip6tables-restore() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[restore counters]' \
        '-n[no flush (additive)]' \
        '-t+[table]:table:(filter nat mangle raw security)' \
        '-M+[module subdir]:dir:_files -/' \
        '-T+[table]:table:(filter nat mangle raw security)' \
        '-v[verbose]' \
        '-w+[wait seconds]:seconds:' \
        '-W+[wait interval]:microseconds:' \
        '*:input file:_files'
}

_ip6tables-restore "$@"
