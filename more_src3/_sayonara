#compdef sayonara
# _sayonara — Sayonara Player Qt audio player (C++); local library + Spotify radio + last.fm + streaming
# upstream: https://sayonara-player.com

_sayonara() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--play[play]' \
        '--pause[pause]' \
        '--prev[previous]' \
        '--next[next]' \
        '--stop[stop]' \
        '--play-pause[toggle play/pause]' \
        '--vol+[volume]:n:' \
        '--mute[mute toggle]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '*:audio file:_files'
}

_sayonara "$@"
