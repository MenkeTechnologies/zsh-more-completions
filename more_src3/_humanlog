#compdef humanlog
# _humanlog — pretty-print JSON / logfmt logs from stdin (humanlogio/humanlog)
# upstream: https://github.com/humanlogio/humanlog
# Subcommands + flags from cmd/humanlog/{main,config,versions}.go (urfave/cli).

_humanlog() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config=[explicit config file path]:file:_files' \
        '*--skip=[keys to drop when parsing each log entry]:key:' \
        '*--keep=[keys to keep when parsing each log entry]:key:' \
        '--sort-longest=[sort keys by length after lexicographic sort]:bool:(true false)' \
        '--skip-unchanged=[skip keys unchanged from the previous entry]:bool:(true false)' \
        '--truncate[truncate values longer than --truncate-length]' \
        '--truncate-length=[max characters per value (default 15)]:n:' \
        '--color=[color mode]:mode:(auto on off dark light)' \
        '--time-format=[Go time-format string for output]:fmt:' \
        '(-i --ignore-interrupts)'{-i,--ignore-interrupts}'[ignore SIGINT to survive editor pipes]' \
        '*'{-m+,--message-fields=}'[fields to interpret as the log message]:field:' \
        '*'{-t+,--time-fields=}'[fields to interpret as the timestamp]:field:' \
        '*'{-l+,--level-fields=}'[fields to interpret as the log level]:field:' \
        '--api=[humanlog.io API URL]:url:' \
        '--basesite=[humanlog.io base site URL]:url:' \
        '--debug[enable debug logging]' \
        '--use-http1[force HTTP/1.1 for outbound requests]' \
        '--use-protocol=[wire protocol]:proto:(connect grpc grpcweb)' \
        '--otlp-endpoint=[forward parsed logs to this OTLP endpoint]:endpoint:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_humanlog_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                version|versions)
                    _arguments '1:version subcommand:(check update)'
                    ;;
                config|cfg)
                    _arguments '1:config subcommand:(reset-to-defaults show show-defaults set)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_humanlog_commands] )) ||
_humanlog_commands() {
    local -a commands
    commands=(
        'version:humanlog version commands (check / update)'
        'config:manage the humanlog config file (alias: cfg)'
    )
    _describe -t commands 'humanlog command' commands
}

_humanlog "$@"
