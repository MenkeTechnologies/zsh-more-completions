#compdef vlinsert
# Documentation: https://docs.victoriametrics.com/victorialogs/cluster/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# vlinsert: VictoriaLogs cluster insert/ingestion component
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-storageNode=[comma-separated storage nodes]:addrs:' \
  '-storageDataPath=[storage data path]:dir:_files -/' \
  '-retentionPeriod=[retention period]:duration:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-loggerLevel=[logger level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[logger format]:fmt:(default json)' \
  '-loggerOutput=[logger output]:out:(stderr stdout)' \
  '-pprofAuthKey=[pprof auth key]:key:' \
  '-metricsAuthKey=[metrics auth key]:key:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert file]:file:_files' \
  '-tlsKeyFile=[TLS key file]:file:_files' \
  '-tlsCipherSuites=[TLS cipher suites]:list:' \
  '-tlsMinVersion=[TLS min version]:ver:(TLS10 TLS11 TLS12 TLS13)' \
  '-insert.disableCompression[disable compression to storage nodes]' \
  '-insert.disable[disable /insert/* endpoints]' \
  '-internalinsert.disable[disable /internal/insert endpoint]' \
  '-search.maxQueryDuration=[max query duration]:duration:' \
  '*::vlinsert args:_files' && ret=0
return ret
