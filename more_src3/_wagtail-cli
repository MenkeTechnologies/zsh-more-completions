#compdef wagtail-cli
# _wagtail-cli — Torchbox Wagtail Django-based CMS CLI alias (Torchbox / Wagtail team, Python); custom argparse
# upstream: https://github.com/wagtail/wagtail

_wagtail-cli() {
    local -a sub=(
        'start:scaffold a new Wagtail project'
        'updatemodulepaths:update module paths after 2.0 upgrade'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wagtail subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--template=+[template]:str:' \
                    '--name=+[name]:str:' \
                    '*:project-name-and-dir:_files -/' ;;
                updatemodulepaths) _arguments \
                    '--root=+[project root]:dir:_files -/' \
                    '--list[list only]' ;;
            esac
            ;;
    esac
}

_wagtail-cli "$@"
