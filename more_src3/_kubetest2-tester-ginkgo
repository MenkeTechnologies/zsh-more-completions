#compdef kubetest2-tester-ginkgo
# _kubetest2-tester-ginkgo — Ginkgo tester for kubetest2 e2e tests (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from pkg/testers/ginkgo/ginkgo.go (gpflag).

_kubetest2-tester-ginkgo() {
    _arguments \
        '--ginkgo-args=[additional ginkgo binary arguments]:args:' \
        '--parallel=[run this many tests in parallel]:n:' \
        '--skip-regex=[regex of jobs to skip]:regex:' \
        '--provider=[cluster provider for e2e.test]:provider:' \
        '--label-filter=[ginkgo --label-filter expression]:expr:' \
        '--focus-regex=[regex of jobs to focus on]:regex:' \
        '--test-package-url=[URL to download Kubernetes test package]:url:_urls' \
        '--test-package-version=[Kubernetes release tar version]:ver:' \
        '--test-package-dir=[bucket directory for release type]:dir:' \
        '--test-package-marker=[version marker file]:file:' \
        '--test-args=[additional e2e test framework arguments]:args:' \
        '--use-built-binaries[use binaries in _rundir instead of GCS tars]' \
        '--use-binaries-from-path[use binaries in $PATH]' \
        '--timeout=[ginkgo test timeout (Go duration)]:duration:' \
        '*--env=[env variable to pass to ginkgo]:env:'
}

_kubetest2-tester-ginkgo "$@"
