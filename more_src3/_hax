#compdef cargo-hax hax
# _hax — hax: Rust → F* / Coq / EasyCrypt / ProVerif extractor (cryspen/hax)
# upstream: https://github.com/cryspen/hax
# Subcommands from cli/subcommands/src/cargo_hax.rs.

_hax() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-C)'{-C+}'[forward cargo flags inside C{...}C delimiters]:cargo flags:' \
        '--message-format=[diagnostics format]:format:(human json)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_hax_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                into)
                    _arguments \
                        '--include-namespaces=[only include items whose path matches one of these globs]:globs:' \
                        '1:backend:(fstar coq easycrypt proverif lean rust ssprove)' \
                        '*::backend flags:->backend' && ret=0
                    case $state in
                        backend)
                            _arguments \
                                '--z3rlimit=[F\* z3rlimit (only meaningful for fstar)]:rlimit:' \
                                '--admit-smt-queries=[F\* admit_smt_queries setting]:bool:(true false)' \
                                '--interface=[F\* interface generation mode]:mode:(generated public extracted)' \
                                '(- *)'{-h,--help}'[backend help]' && ret=0 ;;
                    esac ;;
                json)
                    _arguments \
                        '--include-namespaces=[only include items whose path matches one of these globs]:globs:' \
                        '-o+[output file]:file:_files' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                lint)
                    _arguments \
                        '1:linter:(hacspec rust)' && ret=0 ;;
                json-schema)
                    _arguments \
                        '-o+[output JSON schema file]:file:_files' && ret=0 ;;
                explain)
                    _arguments \
                        '1:diagnostic id:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_hax_commands] )) ||
_hax_commands() {
    local -a commands
    commands=(
        'into:extract the crate into a target backend'
        'json:dump the typed AST as JSON'
        'lint:run a hax linter over the crate'
        'json-schema:print the JSON schema of the AST exporter'
        'explain:explain a hax diagnostic by id'
    )
    _describe -t commands 'cargo hax command' commands
}

_hax "$@"
