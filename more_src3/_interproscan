#compdef interproscan interproscan.sh
# _interproscan — EMBL-EBI InterProScan protein function classification scanning Pfam SMART PROSITE TIGRFAM PIRSF (EBI team, Java); custom argparse
# upstream: https://www.ebi.ac.uk/interpro/

_interproscan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-i+[input fasta]:file:_files -g "*.fa *.fasta *.faa *.fna *.fa.gz"' \
        '--input=+[input fasta]:file:_files -g "*.fa *.fasta *.faa *.fna *.fa.gz"' \
        '-b+[output base]:str:' \
        '--output-file-base=+[output base]:str:' \
        '-o+[output file]:file:_files' \
        '--outfile=+[output file]:file:_files' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-f+[output format csv]:f:(TSV XML JSON GFF3 HTML SVG)' \
        '--formats=+[output format csv]:f:(TSV XML JSON GFF3 HTML SVG)' \
        '-t+[seq type]:t:(p n)' \
        '--seqtype=+[seq type]:t:(p n)' \
        '-T+[temp dir]:dir:_files -/' \
        '--tempdir=+[temp dir]:dir:_files -/' \
        '-cpu+[N]:n:' \
        '--cpu=+[N]:n:' \
        '-appl+[applications csv]:str:' \
        '--applications=+[applications csv]:str:' \
        '-dp[disable precalculated]' \
        '--disable-precalc[disable precalculated]' \
        '-iprlookup[include InterPro lookup]' \
        '--iprlookup[include InterPro lookup]' \
        '-goterms[include GO terms]' \
        '--goterms[include GO terms]' \
        '-pa[include pathways]' \
        '--pathways[include pathways]' \
        '-ms+[min seq size]:n:' \
        '--minsize=+[min seq size]:n:' \
        '-cad+[chunk size]:n:' \
        '--clusterrunid=+[run id]:str:' \
        '-mode+[mode]:m:(standalone convert)' \
        '--mode=+[mode]:m:(standalone convert)' \
        '-V+[verbose level]:n:' \
        '-verbose[verbose]' \
        '--verbose[verbose]' \
        '-help-format[show format help]' \
        '-disable-residue-annot[disable residue annotation]'
}

_interproscan "$@"
