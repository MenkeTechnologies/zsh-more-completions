#compdef libinput-record
# Documentation: https://man.archlinux.org/man/libinput-record.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--all[record all /dev/input/event* devices (requires --output-file)]' \
  '--autorestart=[end recording after N seconds of inactivity]:seconds:' \
  '(-o --output-file)'{-o+,--output-file=}'[output YAML file]:file:_files' \
  '--grab[exclusively grab opened devices]' \
  '--show-keycodes[show raw keycodes in recording]' \
  '--with-libinput[record libinput events alongside device events]' \
  '--with-hidraw[record hidraw events alongside device events]' \
  '*:device:_files -W /dev/input -g "event*"' && ret=0

return ret
