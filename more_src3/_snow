#compdef snow
# Documentation: https://docs.snowflake.com/en/developer-guide/snowflake-cli/command-reference/overview
# Reference accessed: 2026-05-21
# Verified: upstream Snowflake CLI command reference overview.
# Subcommand categories enumerated by upstream: connection, sql, app,
# snowpark, streamlit, stage, spcs, git, helpers, logs, notebook, dcm,
# cortex, object, bootstrap, dbt, custom-image. Per-subcommand flag
# surface is large and not enumerated here; only top-level subcommand
# dispatch is provided. Global --config-file flag confirmed in
# configure-cli doc.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'connection:manage Snowflake connections'
  'sql:execute Snowflake SQL queries'
  'app:Snowflake Native App Framework commands'
  'snowpark:Snowpark development commands'
  'streamlit:Streamlit in Snowflake commands'
  'stage:manage Snowflake stages'
  'spcs:Snowpark Container Services commands'
  'git:Git repository integration'
  'helpers:utility helpers'
  'logs:view log entries'
  'notebook:Snowflake Notebook commands'
  'dcm:Data Classification Management'
  'cortex:Snowflake Cortex AI/ML commands'
  'object:Snowflake object management'
  'bootstrap:initialize a new project from a template'
  'dbt:dbt workflow integration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-file=[path to config TOML]:file:_files -g "*.toml"' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'snow subcommand' subcommands && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
