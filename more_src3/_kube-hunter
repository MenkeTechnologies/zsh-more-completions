#compdef kube-hunter
# Documentation: https://github.com/aquasecurity/kube-hunter/blob/main/kube_hunter/conf/parser.py
# Reference accessed: 2026-05-19
# Verified: upstream kube_hunter/conf/parser.py argparse definitions.
# Removed from prior file: invented --internal, --dispatch-url,
# --version flags; added real --log-file, --k8s-auto-discover-nodes,
# --service-account-token, --kubeconfig, -c/--custom, --raw-hunter-names,
# --network-timeout, --num-worker-threads; replaced bogus
# man.archlinux.org search URL.

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '--list[list all tests]' \
  '--interface[scan all of the machine network interfaces]' \
  '--pod[run as a pod within the cluster]' \
  '--quick[disable subnet scanning for a quicker scan]' \
  '--include-patched-versions[include patched versions in vulnerability checks]' \
  '--cidr=[scan a specific CIDR]:cidr:' \
  '--mapping[only show the cluster node map]' \
  '--remote=[remote machine(s) to hunt]:remote:' \
  '(-c --custom)'{-c,--custom}'[scan only with given hunters]:hunters:' \
  '--raw-hunter-names[use raw hunter class names in --custom]' \
  '--k8s-auto-discover-nodes[query Kubernetes for all nodes and scan them]' \
  '--service-account-token=[manually set a service account JWT token]:token:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--active[enable active hunting]' \
  '--enable-cve-hunting[enable CVE hunting based on discovered version]' \
  '--log=[set log level]:level:(debug info warning none)' \
  '--log-file=[path to a log file]:file:_files' \
  '--report=[set output format]:format:(plain yaml json)' \
  '--dispatch=[where to send the report]:method:(stdout http)' \
  '--statistics[show hunting statistics]' \
  '--network-timeout=[network operation timeout in seconds]:seconds:' \
  '--num-worker-threads=[number of worker threads to use]:n:'
