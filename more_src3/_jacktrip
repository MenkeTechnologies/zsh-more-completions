#compdef jacktrip
# Documentation: https://github.com/jacktrip/jacktrip
# Reference accessed: 2026-05-27
# Verified: upstream src/Settings.cpp parseInput() longopts table (jacktrip/jacktrip)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-n --numchannels)'{-n+,--numchannels=}'[number of input and output channels]:n:' \
  '--receivechannels=[number of incoming channels]:n:' \
  '--sendchannels=[number of outgoing channels]:n:' \
  '(-s --server)'{-s,--server}'[run in P2P server mode]' \
  '(-c --client)'{-c+,--client=}'[run in P2P client mode, set server IP]:host:_hosts' \
  '(-S --jacktripserver)'{-S,--jacktripserver}'[run in hub server mode]' \
  '(-C --pingtoserver)'{-C+,--pingtoserver=}'[run in ping to server mode, set server IP]:host:_hosts' \
  '(-L --localaddress)'{-L+,--localaddress=}'[set local IP address]:address:' \
  '(-o --portoffset)'{-o+,--portoffset=}'[port offset from 4464]:offset:' \
  '(-B --bindport)'{-B+,--bindport=}'[local TCP/UDP bind port]:port:' \
  '(-P --peerport)'{-P+,--peerport=}'[peer TCP/UDP port]:port:' \
  '(-U --udpbaseport)'{-U+,--udpbaseport=}'[server udp base port (default 61002)]:port:' \
  '(-q --queue)'{-q+,--queue=}'[buffer queue length (or auto)]:queue:' \
  '(-r --redundancy)'{-r+,--redundancy=}'[redundancy factor]:n:' \
  '(-b --bitres)'{-b+,--bitres=}'[audio bit resolution]:bits:(8 16 24 32)' \
  '(-z --zerounderrun)'{-z,--zerounderrun}'[use underrun to zeros mode]' \
  '(-t --timeout)'{-t,--timeout}'[quit after 10 second network timeout]' \
  '(-l --loopback)'{-l,--loopback}'[run in loopback mode]' \
  '(-j --jamlink)'{-j,--jamlink}'[run in JamLink mode]' \
  '(-e --emptyheader)'{-e,--emptyheader}'[use empty header]' \
  '(-J --clientname)'{-J+,--clientname=}'[set client name]:name:' \
  '(-K --remotename)'{-K+,--remotename=}'[client name on hub server]:name:' \
  '--appendthreadid[append thread id to client names]' \
  '(-T --srate)'{-T+,--srate=}'[set sample rate]:rate:(22050 32000 44100 48000 88200 96000 192000)' \
  '(-F --bufsize)'{-F+,--bufsize=}'[set audio buffer size]:size:(16 32 64 128 256 512 1024 2048)' \
  '(-R --rtaudio)'{-R,--rtaudio}'[use RtAudio instead of JACK]' \
  '(-d --deviceid)'{-d+,--deviceid=}'[set RtAudio device id (deprecated)]:id:' \
  '--audiodevice=[set RtAudio devices by name]:name:' \
  '--audioinputdevice=[set RtAudio input device by name]:name:' \
  '--audiooutputdevice=[set RtAudio output device by name]:name:' \
  '--listdevices[list available RtAudio devices and exit]' \
  '(-D --nojackportsconnect)'{-D,--nojackportsconnect}'[do not connect default audio ports]' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '(-V --verbose)'{-V,--verbose}'[verbose mode]' \
  '(-p --hubpatch)'{-p+,--hubpatch=}'[hub auto-patch mode]:mode:((0\:server-to-clients 1\:client-echo 2\:client-fanout 3\:reserved-matrix 4\:full-mix 5\:no-auto))' \
  '(-i --includeserver)'{-i,--includeserver}'[include server audio in hub patch]' \
  '(-u --upmix)'{-u,--upmix}'[upmix mono clients when patching]' \
  '(-I --iostat)'{-I+,--iostat=}'[IO stat timeout in seconds]:seconds:' \
  '(-G --iostatlog)'{-G+,--iostatlog=}'[IO stat log file]:file:_files' \
  '(-f --effects)'{-f+,--effects=}'[outgoing compressor and incoming reverb spec]:spec:' \
  '(-O --overflowlimiting)'{-O+,--overflowlimiting=}'[overflow limiting (i, o, or io)]:mode:(i o io)' \
  '(-a --assumednumclients)'{-a+,--assumednumclients=}'[assumed number of clients for limiter]:n:' \
  '--bufstrategy=[buffer strategy (-1..4)]:n:(-1 0 1 2 3 4)' \
  '--simloss=[simulate packet loss rate]:rate:' \
  '--simjitter=[simulate jitter rate[,delay-rel]]:spec:' \
  '--broadcast=[broadcast output queue length]:n:' \
  '--udprt[use realtime priority for UDP data thread]' \
  '(-A --auth)'{-A,--auth}'[enable hub client/server authentication]' \
  '--certfile=[server authentication certificate]:file:_files' \
  '--keyfile=[server authentication private key]:file:_files' \
  '--credsfile=[server authentication credentials store]:file:_files' \
  '--username=[hub client authentication username]:username:' \
  '--password=[hub client authentication password]:password:' \
  '(-x --examine-audio-delay)'{-x+,--examine-audio-delay=}'[measure audio round-trip latency, set print interval]:seconds:' \
  '--gui[force GUI mode]' \
  '--classic-gui[force classic GUI mode]' \
  '--deeplink=[deeplink URL (jacktrip://...)]:url:' \
  '--iceservers=[ICE servers for WebRTC NAT traversal]:servers:' \
  '(-h --help)'{-h,--help}'[print help and exit]' && ret=0

return ret
