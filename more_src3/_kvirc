#compdef kvirc
# _kvirc — KVIrc graphical IRC client (Qt); scriptable with KVS, supports DCC/CTCP/SSL/IPv6
# upstream: https://github.com/kvirc/KVIrc

_kvirc() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config dir]:dir:_files -/' \
        '(-x --execute)'{-x,--execute}'+[KVS command]:command:' \
        '(-r --remote)'{-r,--remote}'[use existing instance]' \
        '(-n --new)'{-n,--new}'[force new instance]' \
        '(-m --mute)'{-m,--mute}'[disable startup sound]' \
        '(-f --force-startup)'{-f,--force-startup}'[skip startup wizard]' \
        '(-e --external)'{-e,--external}'+[external command]:cmd:' \
        '*:irc URL:_urls'
}

_kvirc "$@"
