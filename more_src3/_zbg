local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 15 subcommands decoded source-direct from
# Command.group at cli.ml:99-114
local -a zbg_subcmds=(
  'clear:clear all local changes (irreversibly)'
  'commit:commit all local changes'
  'done:switch to main branch and delete the previous one'
  'log:show pretty log'
  'new:create a new branch <login>/[description]'
  'push:push the current branch to origin'
  'rebase:rebase current local branch on top of origin/[branch]'
  'continue:add all files and continue with the rebase'
  'stash:stash all local changes'
  'status:show pretty status of local changes'
  'switch:switch to [branch] and sync it with origin'
  'sync:sync local branch with the remote branch'
  'tag:create or delete (and push) tags'
  'uncommit:undo last commit'
  'unstash:unstash last stashed changes'
)

_arguments -C \
  '(- *)'{-h,--help}'[display Core.Command auto-generated help]' \
  '(- *)'{-V,--version}'[display version information]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'zbg subcommand' zbg_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      clear)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[clear forcefully without asking any questions]' \
          '(-h --help)'{-h,--help}'[display clear help]' && ret=0
        ;;
      commit)
        # variadic message positional from anon
        # (sequence ("message" %: string))
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display commit help]' \
          '*:commit message:' && ret=0
        ;;
      done|continue|uncommit|unstash)
        # No-arg commands (Command.Param.return)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' && ret=0
        ;;
      log)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display log help]' \
          '1:commit (default: HEAD):__git_commits 2>/dev/null || true' && ret=0
        ;;
      new)
        # one-or-more description from
        # non_empty_sequence_as_list
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display new help]' \
          '*:branch description:' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(-f --force-with-lease)'{-f,--force-with-lease}'[push forcefully and override changes]' \
          '(-h --help)'{-h,--help}'[display push help]' && ret=0
        ;;
      rebase|switch)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help]' \
          '1:branch (optional):__git_branch_names 2>/dev/null || true' && ret=0
        ;;
      stash)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display stash help]' \
          '1:stash message (optional):' && ret=0
        ;;
      status)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display status help]' \
          '1:commit (default: HEAD):__git_commits 2>/dev/null || true' && ret=0
        ;;
      sync)
        _arguments -s -S \
          '(-f --force)'{-f,--force}'[sync forcefully by overriding local version with remote]' \
          '(-h --help)'{-h,--help}'[display sync help]' && ret=0
        ;;
      tag)
        _arguments -s -S \
          '-d[delete existing tag instead of creating]' \
          '(-h --help)'{-h,--help}'[display tag help]' \
          '1:tag name:__git_tags 2>/dev/null || true' && ret=0
        ;;
    esac
    ;;
esac

return ret
