#compdef tinted-builder-rust
# Documentation: https://github.com/tinted-theming/tinted-builder-rust
# Source: tinted-theming/tinted-builder-rust tinted-builder-rust/src/cli.rs — Base16/Base24 theme builder.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _tb_cmds
_tb_cmds=(
    'build:build the target theme template'
    'sync:clone schemes repo or git pull existing local clone'
)

_arguments -C \
    '(-d --data-dir)'{-d+,--data-dir=}'[path to the data directory]:dir:_files -/' \
    '(-i --ignore)*'{-i+,--ignore=}'[glob of files to ignore in schemes directory]:glob:_default' \
    '(-s --schemes-dir)'{-s+,--schemes-dir=}'[path to the schemes directory]:dir:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'tinted-builder-rust command' _tb_cmds && ret=0
        ;;
    args)
        case $words[1] in
            build)
                _arguments \
                    '(-q --quiet)'{-q,--quiet}'[silence stdout]' \
                    '--sync[sync with latest schemes before build]' \
                    '1:template-dir:_files -/' \
                    && ret=0
                ;;
            sync)
                _arguments '(-q --quiet)'{-q,--quiet}'[silence stdout]' && ret=0
                ;;
        esac
        ;;
esac

return ret
