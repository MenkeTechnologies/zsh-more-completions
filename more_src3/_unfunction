#compdef unfunction
# Documentation: man zshbuiltins (zsh)
# Source: zsh — remove the named functions from the shell.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m[treat names as patterns]' \
    '*:function:_functions' \
    && ret=0

return ret
