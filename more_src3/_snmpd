#compdef snmpd
# _snmpd — OpenBSD snmpd (SNMPv1/v2c/v3 daemon; reads MIB definitions from /usr/share/snmp/mibs/* and serves them per /etc/snmpd.conf with AgentX extension support for application_agentx)
# upstream: https://github.com/openbsd/src (usr.sbin/snmpd)
# Flags from usr.sbin/snmpd/snmpd.8 on tip.

_snmpd() {
    _arguments \
        '-d[do not daemonize + log to stderr]' \
        '-N[show numeric OIDs instead of symbolic names]' \
        '-n[configtest mode]' \
        '*-v[verbose (repeatable)]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/snmpd.conf)]:file:_files'
}

_snmpd "$@"
