#compdef uw8
# ============================================================================
#  _uw8 — MicroW8: WebAssembly-based size-coding platform
#
#  Source-direct extraction from
#    https://github.com/exoticorn/microw8/blob/master/src/main.rs
#    https://github.com/exoticorn/microw8/blob/master/uw8-tool/src/main.rs
#    https://github.com/RazrFalcon/pico-args (the pico-args library)
#
#  Authored by exoticorn (Dennis Ranke).  245 GH stars.  MicroW8 is a
#  size-coding platform targeting WebAssembly carts — write tiny games
#  (≤256 KB cart, ≤16 KB compressed) in WAT/CurlyWas/Wasm and run them
#  in a 320x240 framebuffer with PSG-style audio.  Inspired by PICO-8
#  and TIC-80 but uses WASM as the cart format.  Sister tools: WASM-4
#  (similar concept), pico-8 (Lua-based proprietary), TIC-80 (multi-
#  language cart-based fantasy console).
#
#  CLI library taxonomy update: 9th Rust CLI library — pico-args.
#  uw8 uses `use pico_args::Arguments` — RazrFalcon's pico-args is a
#  NO-DERIVE, NO-PROC-MACRO manual API for ABSOLUTE MINIMUM compiled
#  binary size (~3 KB to compiled output vs clap's ~300 KB).  Caller
#  IMPERATIVELY consumes args via methods like `args.subcommand()`,
#  `args.contains(["-x", "--long"])`, `args.opt_value_from_str(...)`,
#  `args.free_from_str()`.  Used when binary size is critical — e.g.
#  size-coding tools, tiny embedded binaries, demoscene productions.
#  Distinct from:
#    - R275 Rust clap-derive (proc-macro on struct)
#    - R330 Rust bpaf (functional combinator)
#    - R344 Rust google/argh (proc-macro, code-size-optimized)
#    - pico-args has the SMALLEST footprint by far — completely manual
#      caller-consumes API, no derive macros, no reflection, no help-
#      text formatting unless you write it yourself.
#  Brings cross-language CLI library taxonomy variant count to 86;
#  Rust ecosystem now has 9 documented CLI libraries — extends its lead.
#
#  Surface (verbatim from src/main.rs help text + run/pack/unpack/compile):
#
#  Subcommands:
#    version                                      Show version
#    run <file>                                   Run a cart file
#      -t, --timeout <frames>                     Frame timeout
#      -b, --browser                              Use browser runtime
#      -w, --watch                                Watch source for changes
#      -p, --pack                                 Pack cart on load
#      -u, --uncompressed                         Skip compression when packing
#      -l, --level <N>                            Compression level
#      -o, --output <out-file>                    Write loaded cart to file
#      -m, --no-audio                             Disable audio
#    pack <in-file> <out-file>                    Pack WASM into uw8 cart
#      -u, --uncompressed                         Skip compression
#      -l, --level <N>                            Compression level
#    unpack <in-file> <out-file>                  Unpack uw8 cart into WASM
#    compile <in-file> <out-file>                 Compile WAT/CurlyWas to WASM
#      -d, --debug                                Include debug info
#    filter-exports <in-wasm> <out-wasm>          Strip non-uw8 WASM exports
#    help                                         Show help
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - tuc (riquito/tuc 820 stars, cut replacement — IN CORPUS)
#    - rustybuzz (harfbuzz/rustybuzz 662 stars, library not CLI tool)
#    - figdriver-rs (cmatsuoka 0 stars — narrow)
#    - uw8-tool (sibling pico-args binary inside microw8 repo — could
#      be a sister entry; HOLD for future round)
# ============================================================================

_uw8() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'version:show uw8 version'
        'run:run a uw8 cart'
        'pack:pack WASM module into uw8 cart format'
        'unpack:unpack uw8 cart into raw WASM'
        'compile:compile WAT/CurlyWas source to WASM'
        'filter-exports:strip non-uw8 WASM exports'
        'help:show help'
      )
      _describe -t commands 'uw8 subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        run)
          _arguments -s -S \
            '(-t --timeout)'{-t,--timeout}'=[frame timeout]:frames' \
            '(-b --browser)'{-b,--browser}'[use browser runtime]' \
            '(-w --watch)'{-w,--watch}'[watch source for changes]' \
            '(-p --pack)'{-p,--pack}'[pack cart on load]' \
            '(-u --uncompressed)'{-u,--uncompressed}'[skip compression when packing]' \
            '(-l --level)'{-l,--level}'=[compression level]:level' \
            '(-o --output)'{-o,--output}'=[write loaded cart to file]:file:_files' \
            '(-m --no-audio)'{-m,--no-audio}'[disable audio]' \
            '*:cart file:_files -g "*.(uw8|wasm|wat|cwa)"'
          ;;
        pack)
          _arguments -s -S \
            '(-u --uncompressed)'{-u,--uncompressed}'[skip compression]' \
            '(-l --level)'{-l,--level}'=[compression level]:level' \
            '1:input WASM:_files -g "*.wasm"' \
            '2:output uw8 cart:_files -g "*.uw8"'
          ;;
        unpack)
          _arguments \
            '1:input uw8 cart:_files -g "*.uw8"' \
            '2:output WASM:_files -g "*.wasm"'
          ;;
        compile)
          _arguments -s -S \
            '(-d --debug)'{-d,--debug}'[include debug info]' \
            '1:input source:_files -g "*.(wat|cwa)"' \
            '2:output WASM:_files -g "*.wasm"'
          ;;
        filter-exports)
          _arguments \
            '1:input WASM:_files -g "*.wasm"' \
            '2:output WASM:_files -g "*.wasm"'
          ;;
      esac
      ;;
  esac
}

_uw8 "$@"
