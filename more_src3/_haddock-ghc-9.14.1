#compdef haddock-ghc-9.14.1
# Documentation: https://haskell-haddock.readthedocs.io/latest/invoking.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--ghc-version[output expected GHC version]' \
  '--print-ghc-path[output GHC path]' \
  '--print-ghc-libdir[output GHC lib directory]' \
  '--interface-version[print binary interface file version]' \
  '--compatible-interface-versions[print compatible versions]' \
  '-B+[GHC lib dir]:dir:_files -/' \
  {-o+,--odir=}'[output directory]:dir:_files -/' \
  {-l+,--lib=}'[Haddock auxiliary files location]:dir:_files -/' \
  '*'{-i+,--read-interface=}'[read interface from FILE]:file:_files' \
  {-D+,--dump-interface=}'[write interface to FILE]:file:_files' \
  '--show-interface=[display binary interface in human readable form]:file:_files' \
  '--no-compilation[avoid recompilation; load .hi/.hie only]' \
  '--no-tmp-comp-dir[use current dir for compilation output]' \
  '--incremental=[generate doc for a single module]:module:' \
  '--html[output HTML]' \
  '--latex[output LaTeX]' \
  '--hoogle[output for Hoogle]' \
  '--hyperlinked-source[generate hyperlinked source as HTML]' \
  '-p+[prologue file]:file:_files' \
  '--prologue=[prologue file]:file:_files' \
  '-t+[page title]:title:' \
  '--title=[page title]:title:' \
  '--package-name=[package name]:name:' \
  '--package-version=[package version]:version:' \
  '--theme=[HTML theme]:path:_files -/' \
  '--built-in-themes[include built-in themes]' \
  '--use-unicode[enable Unicode in HTML output]' \
  '--source-css=[custom CSS for hyperlinked sources]:file:_files' \
  '--latex-style=[override LaTeX style]:file:_files' \
  '--source-base=[source base URL]:url:' \
  '--source-module=[source module URL pattern]:url:' \
  '--source-entity=[source entity URL pattern]:url:' \
  '--source-entity-line=[source entity line URL pattern]:url:' \
  '--comments-base=[comments base URL]:url:' \
  '--comments-module=[comments module URL]:url:' \
  '--comments-entity=[comments entity URL]:url:' \
  '*--hide=[hide module]:module:' \
  '*--show=[show module]:module:' \
  '--show-all[ignore hide attributes]' \
  '*--show-extensions=[show extensions for module]:module:' \
  '(-q --qual)'{-q+,--qual=}'[qualify identifiers]:mode:(none full local relative)' \
  '--since-qual=[qualify @since annotations]:mode:(always only-external)' \
  '--use-contents=[use existing contents URL]:url:' \
  '--use-index=[use existing index URL]:url:' \
  '--gen-contents[generate HTML contents]' \
  '--gen-index[generate HTML index]' \
  '--base-url=[base URL for static assets]:url:' \
  '*--optghc=[pass option to GHC]:opt:' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-w --no-warnings)'{-w,--no-warnings}'[turn off warnings]' \
  '--print-missing-docs[print info about undocumented entities]' \
  '--trace-args[print arguments received]' \
  '--bypass-interface-version-check[ignore interface version mismatches]' \
  '--mathjax=[custom MathJax URL]:url:' \
  '*:source file:_files -g "*.(hs|lhs|hi)"' && ret=0

return ret
