#compdef lxrandr
# Documentation: https://github.com/lxde/lxrandr/blob/master/src/lxrandr.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxrandr declares no custom CLI options; argv is forwarded to gtk_init()
# which consumes the standard GTK arguments (--display, --help-gtk, ...).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display]:display:' && ret=0

return ret
