#compdef xbmtopbm
# Documentation: man xbmtopbm (Netpbm)
# Source: convert an X11 (or X10) bitmap to a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:bitmap file:_files -g "*.(xbm|bm)"' \
    && ret=0

return ret
