#compdef wcs-grab
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/wcs-grab.1 — interpret an existing WCS header (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '1:input filename:_files -g "*.{fits,fit,fts,wcs}"' \
    '2:FITS extension:_default' \
    '3:output filename:_files' \
    && ret=0

return ret
