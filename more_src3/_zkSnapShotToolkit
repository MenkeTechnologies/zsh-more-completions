#compdef zkSnapShotToolkit zkSnapshotRecursiveSummaryToolkit
# Documentation: https://zookeeper.apache.org/doc/current/zookeeperTools.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '-d[include data content in output]' \
  '-json[format output as JSON]' \
  '*:ZooKeeper snapshot file:_files' && ret=0

return ret
