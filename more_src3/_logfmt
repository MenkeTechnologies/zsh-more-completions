#compdef logfmt
# Documentation: https://github.com/TheEdgeOfRage/logfmt
# Source: TheEdgeOfRage/logfmt config/config.go — logfmt colorizer/filter (Go, go-flags).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-l --level)'{-l+,--level=}'[log level filter]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
    '(-o --output)'{-o+,--output=}'[output field selector (comma-separated)]:fields:_default' \
    '(-e --exclude)'{-e+,--exclude=}'[exclude field selector (comma-separated)]:fields:_default' \
    '(-f --filter)'{-f+,--filter=}'[filter fields (key=value,comma-separated)]:filter:_default' \
    '(-n --no-color)'{-n,--no-color}'[disable color output]' \
    '(-c --force-color)'{-c,--force-color}'[force color output even when piping]' \
    '(-t --no-time)'{-t,--no-time}'[disable time output]' \
    '(-k --keep-empty)'{-k,--keep-empty}'[keep lines with no selected field]' \
    '(-r --raw)'{-r,--raw}'[output only selected field values (lcut-like)]' \
    '(-A --all)'{-A,--all}'[output all fields, preserving order]' \
    '(-B --buffer-size)'{-B+,--buffer-size=}'[expected max line length in bytes]:bytes:_default' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
