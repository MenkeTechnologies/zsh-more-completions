#compdef zfs-change-key
# _zfs-change-key — OpenZFS zfs change-key (rotate the wrapping key for an encryption-root dataset; -l requires the key be currently loaded, -i takes the key inline rather than from keylocation, -o sets new keyformat/keylocation/pbkdf2iters, -r rotates recursively)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c (zfs_do_change_key) on tip.

_zfs-change-key() {
    _arguments \
        '-l[require key currently loaded]' \
        '-i[take key inline]' \
        '*-o+[property=value]:property=value:(keyformat= keylocation= pbkdf2iters=)' \
        '-r[recursive]' \
        '*:dataset:'
}

_zfs-change-key "$@"
