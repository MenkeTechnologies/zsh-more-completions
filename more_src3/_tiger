#compdef tiger
# Documentation: man tiger(8)
# Source: GNU Tiger tiger main script (sh) — UNIX security audit / IDS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose]' \
    '-t[trace mode]' \
    '-h[show help]' \
    '-q[quiet]' \
    '-G[run as cron job (less output)]' \
    '-S[explain results inline with tigexp]' \
    '-H[also generate HTML report]' \
    '-B+[Tiger base/install directory]:dir:_files -/' \
    '-l+[log directory or @syslog-host]:dir:_default' \
    '-w+[work directory]:dir:_files -/' \
    '-b+[binary directory]:dir:_files -/' \
    '(-e -E)-e[explanations: send to syslog/email]' \
    '(-e -E)-E[explanations: append inline to report]' \
    '-c+[config file]:file:_files' \
    '-A+[architecture override]:arch:_default' \
    '-O+[OS override]:os:(Linux SunOS HPUX AIX Darwin FreeBSD)' \
    '-R+[release override]:release:_default' \
    && ret=0

return ret
