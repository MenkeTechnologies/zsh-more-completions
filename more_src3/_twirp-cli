#compdef twirp-cli protoc-gen-twirp
# _twirp-cli — TwitchTV Twirp RPC framework codegen plugin CLI alias (Twitch / TwitchTV, Go); flag
# upstream: https://github.com/twitchtv/twirp

_twirp-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--go_opt=+[go option]:list:' \
        '--twirp_opt=+[twirp option]:list:' \
        '--go_out=+[go output dir]:dir:_files -/' \
        '--twirp_out=+[twirp output dir]:dir:_files -/' \
        '--paths=+[paths mode]:p:(source_relative import)' \
        '--module=+[module path]:str:' \
        '*:proto:_files -g "*.proto"'
}

_twirp-cli "$@"
