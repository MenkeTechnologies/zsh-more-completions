#compdef svelte-kit
# Documentation: https://svelte.dev/docs/kit/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. SvelteKit's only first-party CLI
# command is `sync`; development/build/preview are delegated to Vite.

_sveltekit() {
  local curcontext="$curcontext" state line ret=1

  local -a commands=(
    'sync:create tsconfig.json and generated types for the project'
  )

  _arguments -s -S \
    '1:command:->command' \
    '*:: :->args' \
    && ret=0

  case $state in
    (command)
      _describe -t commands 'svelte-kit command' commands && ret=0
      ;;
  esac

  return ret
}

_sveltekit "$@"
