#compdef ssm-cli
# Documentation: https://docs.aws.amazon.com/systems-manager/latest/userguide/ssm-cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# Only `get-diagnostics` subcommand and `--output table` are documented in the AWS userguide.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'get-diagnostics:run preconfigured diagnostic checks'
)

_arguments -C \
  '--output=[output format]:fmt:(table)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ssm-cli subcommand' subcommands && ret=0
    ;;
esac

return ret
