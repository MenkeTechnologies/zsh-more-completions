#compdef ulogd ulogd2
# Documentation: https://man.archlinux.org/man/ulogd.8
# Reference accessed: 2026-05-21
# Verified: upstream ulogd(8) man page.

_arguments -s \
  '(-d --daemon)'{-d,--daemon}'[fork into background]' \
  '(-c --configfile)'{-c,--configfile=}'[config file]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose to stdout]' \
  '(-l --loglevel)'{-l,--loglevel=}'[log level]:level:(1 3 5 7 8)' \
  '(-u --uid)'{-u,--uid=}'[change UID/GID]:uid:_users' \
  '(-i --info)'{-i,--info=}'[plugin info path]:path:_files' \
  '(-p --pidfile)'{-p,--pidfile=}'[PID file]:file:_files'
