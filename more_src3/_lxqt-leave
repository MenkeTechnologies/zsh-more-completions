#compdef lxqt-leave
# Documentation: https://github.com/lxqt/lxqt-session/blob/master/lxqt-leave/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--logout[logout]' \
  '--lockscreen[lock screen]' \
  '--suspend[suspend]' \
  '--hibernate[hibernate]' \
  '--shutdown[shutdown]' \
  '--reboot[reboot]' && ret=0

return ret
