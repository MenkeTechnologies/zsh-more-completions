#compdef xbps-checkvers
# Documentation: https://man.voidlinux.org/xbps-checkvers.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-C --config)'{-C,--config}'+[XBPS configuration directory]:dir:_directories' \
  '(-D --distdir)'{-D,--distdir}'+[path to void-packages tree]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-e --removed)'{-e,--removed}'[list packages in repos but not in distdir]' \
  '(-f --format)'{-f,--format}'+[format string]:format:' \
  '(-i --ignore-conf-repos)'{-i,--ignore-conf-repos}'[ignore repos in configuration files]' \
  '(-I --installed)'{-I,--installed}'[check installed packages]' \
  '(-m --manual)'{-m,--manual}'[only process listed packages]' \
  '*'{-R,--repository}'+[repository URL]:uri:' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-s --show-all)'{-s,--show-all}'[list all packages with versions]' \
  '--staging[enable staged packages from remote repositories]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files'
