#compdef imapfilter
# Documentation: https://github.com/lefcha/imapfilter/blob/master/doc/imapfilter.1
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for imapfilter - IMAP mail filtering utility

_arguments -s -S \
  '-c[specify configuration file]:config file:_files' \
  '-d[specify debug file]:debug file:_files' \
  '-e[execute inline configuration command]:config string:' \
  '-i[interactive mode after config]' \
  '-l[specify log file]:log file:_files' \
  '-n[dry-run mode]' \
  '-p[specify pid file]:pid file:_files' \
  '-t[specify truststore file]:truststore file:_files' \
  '(- *)-V[show version]' \
  '-v[enable verbose output]'
