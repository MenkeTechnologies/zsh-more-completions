# WHAT IT IS
#   Lune is a standalone Luau runtime ‚Äî a single Rust binary
#   that runs `.lua` / `.luau` scripts (full Luau type-checked
#   dialect, not vanilla Lua) plus a typed standard library
#   that exposes the same `fs / net / process / task / stdio
#   / datetime / serde / regex / luau` surface most Node/Deno
#   scripts use, organized as per-module feature flags so
#   embedded usage can compile only what the script imports.
#   The Roblox subcommand surface (and the `lune-roblox` +
#   `lune-std-roblox` crates) plug into Roblox Studio's data
#   model so the same Lune binary doubles as a CI tool for
#   Roblox experience build pipelines.
#
#   Hot features:
#     ‚Ä¢ `lune build` produces a standalone single-file
#       executable (host-cross-compile via embedded base-exe
#       download) ‚Äî `--target os-arch` picks any supported
#       host/target combo.
#     ‚Ä¢ `lune repl` is a rustyline-driven interactive REPL
#       (the default when invoked with no subcommand).
#     ‚Ä¢ `lune setup` writes language-server type definitions
#       into your editor's Luau-LSP config so import paths
#       resolve.
#     ‚Ä¢ `lune list` enumerates every script under
#       `.lune/`, `lune/`, `~/.lune/`, `~/lune/`, etc.
#
# CLI ARGUMENT GRAMMAR  (verbatim from crates/lune/src/cli/
#                       mod.rs `CliSubcommand` enum + per-
#                       subcommand `*Command` struct clap-
#                       derive declarations; extracted via
#                       `gh api repos/lune-org/lune/contents/
#                       crates/lune/src/cli/...`)
#
#   lune [SUBCOMMAND] [args...]   (default: repl)
#
#   Subcommands:
#     run <SCRIPT_PATH> [<SCRIPT_ARGS>...]
#                                    Run a script.  Resolution
#                                    order:  literal path ‚Üí
#                                    `<path>.luau` ‚Üí
#                                    `<path>.lua` ‚Üí `.lune/
#                                    <path>{.luau,.lua}` ‚Üí
#                                    `lune/<path>{.luau,.lua}`
#                                    ‚Üí `~/.lune/<path>{.luau,
#                                    .lua}` ‚Üí `~/lune/<path>{
#                                    .luau,.lua}`.  All argv
#                                    after the script path are
#                                    forwarded into the
#                                    runtime's `process.args`.
#
#     list                           List scripts available to
#                                    run  (walks the same
#                                    resolution roots as `run`)
#
#     setup                          Set up type definitions
#                                    for your editor  (writes
#                                    Luau-LSP type stubs into
#                                    your home directory)
#
#     build <INPUT> [OPTIONS]        Build a standalone
#                                    executable
#       -o, --output <PATH>            Output file path
#                                      [default: input path
#                                      with executable
#                                      extension]
#       -t, --target <OS-ARCH>         Target spec
#                                      `<os>-<arch>` ‚Äî
#                                      defaults to current
#                                      host
#                                      (linux-x86_64,
#                                       linux-aarch64,
#                                       macos-x86_64,
#                                       macos-aarch64,
#                                       windows-x86_64)
#
#     repl                           Launch an interactive REPL
#                                    (default when no
#                                    subcommand)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `mlua = "0.11.6"` (with `luau` feature)
#   declared in crates/lune/Cargo.toml ‚Äî `mlua` is THE
#   canonical Rust binding crate to the Lua and Luau VMs,
#   maintained by Alex Orlenko (`khvzak`) at
#   mlua-rs/mlua (3,500+ stars; the predominant typed Rust
#   Lua-binding library used by every major Rust application
#   that embeds Lua / Luau ‚Äî Lapce, Helix's plugin host,
#   Eruption RGB engine, fblog log viewer, lune, IronBar
#   status bar, korangar Ragnarok client, mprocs TUI runner,
#   rmpc MPD client, KumoMTA, mise version manager, vector
#   observability pipeline, the gluau game engine, the
#   redox-os/relibc test harness, wezterm config script host,
#   and the Roblox-OSS Luau ecosystem at large).  mlua
#   exposes the typed `Lua::new()` /
#   `Lua::new_with(StdLib::ALL, LuaOptions::new())` /
#   `Lua::new_async()` constructors,
#   the typed `lua.create_table()` /
#   `lua.create_table_with_capacity(narr, nrec)` /
#   `lua.create_array_table(items)` /
#   `lua.create_string(bytes)` /
#   `lua.create_function(fn)` /
#   `lua.create_async_function(async fn)` /
#   `lua.create_thread(coroutine_fn)` /
#   `lua.create_userdata(value)` /
#   `lua.create_proxy::<UserData>()` value factories,
#   the typed `Function::call` /
#   `Function::call_async` / `Function::bind` invocation
#   surface, the typed `Table::set` / `Table::get` /
#   `Table::raw_set` / `Table::raw_get` /
#   `Table::contains_key` / `Table::pairs` /
#   `Table::sequence_values` / `Table::push` /
#   `Table::set_metatable` table API, the typed
#   `UserData` derive macro + `UserDataMethods` /
#   `UserDataFields` registration trait, the typed
#   `IntoLua` / `FromLua` / `FromLuaMulti` conversion
#   pipeline, the typed `MultiValue` variadic accumulator,
#   the typed `RegistryKey` GC-anchor for Rust-side
#   references, the typed `Error::CallbackError {
#   traceback, cause }` /  `Error::RuntimeError(message)` /
#   `Error::SyntaxError { message, incomplete_input }`
#   `Error::ExternalError(<dyn StdError>)` /
#   `Error::CoroutineUnresumable` error variants,
#   coroutine integration (`Thread::resume`, `Thread::status`,
#   `Thread::reset`), the Luau-specific
#   `Lua::sandbox(enable)` / `Lua::set_compiler(Compiler)` /
#   `Compiler::new() .set_optimization_level(level)
#   .set_debug_level(level) .set_type_info_level(level)` API,
#   and the async-runtime-agnostic `LuaSerdeExt` (`to_value`,
#   `from_value`) for JSON-style serde interop.  lune wraps
#   `Lua::new()` in its `mlua-luau-scheduler` workspace
#   crate, which schedules cooperative Luau coroutines on top
#   of an async-runtime task wheel ‚Äî that is the bridge that
#   lets `task.spawn`, `task.delay`, `task.wait`, and the
#   `net.request` / `fs.*` async helpers compose.  Verified
#   via:
#     gh api repos/lune-org/lune/contents/crates/lune/
#         Cargo.toml
#       ‚Üí mlua = { version = "0.11.6", features = ["luau"] }
#       ‚Üí mlua-luau-scheduler = "0.2.3"
#       ‚Üí lune-std-* feature flags
#       ‚Üí [[bin]] name = "lune", path = "src/main.rs"
#     gh api repos/lune-org/lune/contents/Cargo.toml
#       ‚Üí [workspace] members: crates/lune, crates/lune-std,
#                              crates/lune-roblox, crates/lune-
#                              utils, crates/mlua-luau-
#                              scheduler, + 11 lune-std-
#                              <module> crates
#     gh api repos/lune-org/lune/contents/crates/lune/src/
#         cli/mod.rs
#       ‚Üí #[derive(Subcommand)] enum CliSubcommand { Run,
#                                                     List,
#                                                     Setup,
#                                                     Build,
#                                                     Repl }
#       ‚Üí Default::default() = Repl(ReplCommand::default())
#     gh api repos/lune-org/lune/contents/crates/lune/src/
#         cli/{run,list,setup,build/mod,repl}.rs
#       ‚Üí RunCommand { script_path, script_args }
#       ‚Üí ListCommand {}
#       ‚Üí SetupCommand {}
#       ‚Üí BuildCommand { input, output (-o), target (-t) }
#       ‚Üí ReplCommand {} (Default)
#   This entry is the Rust=156 leader bump that OPENS Axis 101
#   (Lua/Luau bindings / mlua) at 1/0/0.  Pairing Go and
#   TS-Node bumps will follow at R994 and R995 (Go=156
#   candidates: gopher-lua / yuin/gopher-lua-libs / gopl-lua
#   users; TS-Node=156 candidates: fengari / wasmoon /
#   luaparse users).
#
#   No completion for `lune` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) ‚Äî confirmed absent.
# ============================================================================

_lune() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_lune_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run)
                    _arguments \
                        '1:script path or name:_files -g "*.luau *.lua"' \
                        '*::script arg:' && ret=0 ;;
                build)
                    _arguments \
                        '(-o --output)'{-o,--output}'=[output file path (defaults to input path with executable extension)]:path:_files' \
                        '(-t --target)'{-t,--target}'=[target spec os-arch (defaults to current host)]:target:(linux-x86_64 linux-aarch64 macos-x86_64 macos-aarch64 windows-x86_64)' \
                        '1:input script:_files -g "*.luau *.lua"' && ret=0 ;;
                list|setup|repl)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_lune_commands] )) ||
_lune_commands() {
    local -a commands
    commands=(
        'run:run a Luau / Lua script'
        'list:list scripts available to run'
        'setup:set up type definitions for your editor'
        'build:build a standalone executable from a Lune script'
        'repl:launch an interactive REPL (default)'
    )
    _describe -t commands 'lune command' commands
}

_lune "$@"
