#compdef leaftoppm
# Documentation: man leaftoppm (Netpbm)
# Source: convert an ILS Interleaf image file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:leaf file:_files' \
    && ret=0

return ret
