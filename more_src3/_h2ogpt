#compdef h2ogpt
# _h2ogpt — H2O.ai h2ogpt query and summarize private documents with LLMs Apache 2.0 (h2oai team, Python); argparse
# upstream: https://github.com/h2oai/h2ogpt

_h2ogpt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--base-model=+[model name]:str:' \
        '--prompt-type=+[prompt type]:p:(human_bot plain instruct human_bot1 anthropic mistral llama2 llama3 chatgpt openchat phi3)' \
        '--gpu=+[gpu index]:n:' \
        '--gpus=+[gpu count]:n:' \
        '--score-model=+[score model]:str:' \
        '--load-8bit=+[bool]:b:(true false)' \
        '--load-4bit=+[bool]:b:(true false)' \
        '--load-half=+[bool]:b:(true false)' \
        '--use-cache=+[bool]:b:(true false)' \
        '--use-flash-attn-2=+[bool]:b:(true false)' \
        '--use-safetensors=+[bool]:b:(true false)' \
        '--share=+[bool]:b:(true false)' \
        '--enable-tts=+[bool]:b:(true false)' \
        '--enable-stt=+[bool]:b:(true false)' \
        '--enable-imagegen=+[bool]:b:(true false)' \
        '--enable-image-cap=+[bool]:b:(true false)' \
        '--enable-doc-upload=+[bool]:b:(true false)' \
        '--enable-pdf-ocr=+[bool]:b:(true false)' \
        '--enable-ocr=+[bool]:b:(true false)' \
        '--enable-vision=+[bool]:b:(true false)' \
        '--cli=+[bool]:b:(true false)' \
        '--cli-loop=+[bool]:b:(true false)' \
        '--prompt=+[initial prompt]:str:' \
        '--user-path=+[user data path]:dir:_files -/' \
        '--langchain-mode=+[mode]:m:(LLMOnly UserData MyData GitData ImageData LlamaLLM ChatBot)' \
        '--langchain-modes=+[modes csv]:str:' \
        '--langchain-action=+[action]:a:(Query Summarize Extract ImageGen)' \
        '--top-k-docs=+[N]:n:' \
        '--gradio-port=+[port]:port:_ports' \
        '--gradio-host=+[host]:host:_hosts' \
        '--openai-server=+[bool]:b:(true false)' \
        '--openai-port=+[port]:port:_ports' \
        '--openai-host=+[host]:host:_hosts' \
        '--auth=+[user:pass csv]:str:' \
        '--auth-filename=+[file]:file:_files' \
        '--api-open=+[bool]:b:(true false)' \
        '--max-new-tokens=+[N]:n:' \
        '--temperature=+[F]:f:' \
        '--top-p=+[F]:f:' \
        '--top-k=+[N]:n:' \
        '--repetition-penalty=+[F]:f:' \
        '--n-jobs=+[N]:n:' \
        '--n-threads=+[N]:n:' \
        '--inference-server=+[server URL]:url:_urls' \
        '--regenerate-clients=+[bool]:b:(true false)' \
        '--llamacpp-dict=+[json]:str:' \
        '--exllama-dict=+[json]:str:' \
        '--rope-scaling=+[json]:str:'
}

_h2ogpt "$@"
