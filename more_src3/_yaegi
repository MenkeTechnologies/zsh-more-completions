#compdef yaegi
# Documentation: https://pkg.go.dev/github.com/traefik/yaegi/cmd/yaegi
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_yaegi_commands() {
  local -a commands=(
    'run:run a Go program'
    'test:test a Go package'
    'extract:extract a Go package for use in yaegi'
    'help:show help'
  )
  _describe -t commands 'yaegi command' commands
}

_arguments -s -S \
  '-e[evaluate string and return]:expression:' \
  '-i[start interactive REPL after file execution]' \
  '-syscall[include syscall symbols]' \
  '-unsafe[include unsafe symbols]' \
  '-unrestricted[include unrestricted symbols]' \
  '-tags[comma-separated list of build tags]:tags' \
  '1:command:_yaegi_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments -s -S \
          '-tags[build tags]:tags' \
          '-syscall[include syscall symbols]' \
          '-unsafe[include unsafe symbols]' \
          '-unrestricted[include unrestricted symbols]' \
          '*:go file:_files -g "*.go"' && ret=0
        ;;
      test)
        _arguments -s -S \
          '-tags[build tags]:tags' \
          '*:go package:_files -/' && ret=0
        ;;
      extract)
        _arguments -s -S \
          '*:go package' && ret=0
        ;;
    esac
    ;;
esac

return ret
