#compdef vapor
# Documentation: https://github.com/vapor/toolbox (Sources/VaporToolbox/New.swift)
# Reference accessed: 2026-05-21
# Verified: upstream Vapor.swift CommandConfiguration registers only New.self.

# Modern Vapor Toolbox (4.x+) provides only the `new` subcommand;
# build/run/test/xcode/heroku/supervisor were removed in toolbox 18+.

_vapor() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1:command:_vapor_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                new)
                    _arguments \
                        '(-t --template)'{-t+,--template=}'[URL of a Git repository to use as template]:url:' \
                        '--branch=[template repository branch to use]:branch:' \
                        '--manifest=[manifest file path (default manifest.yml)]:file:_files' \
                        '(-o --output)'{-o+,--output=}'[directory to place new project in]:dir:_directories' \
                        '--no-git[skip adding Git repository]' \
                        '--no-commit[skip initial commit]' \
                        '--yes[answer yes to all questions]' \
                        '--no[answer no to all questions]' \
                        '(-v --verbose)'{-v,--verbose}'[print additional information]' \
                        '1:project name:'
                    ;;
            esac
            ;;
    esac
}

_vapor_commands() {
    local -a commands
    commands=(
        'new:create a new Vapor project'
    )
    _describe -t commands 'vapor command' commands
}

_vapor "$@"
