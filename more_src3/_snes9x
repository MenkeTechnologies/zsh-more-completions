#compdef snes9x
# Documentation: https://github.com/optixx/snes-sdk/blob/master/snes9x/unix/docs/readme_unix.txt
# Reference accessed: 2026-05-17
# Verified: snes9x readme_unix.txt option reference.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -conf/-displaymode/-mode/-stretch/-keepratio/-aspect/
# -fxrate/-mute/-norewind/-multi/-mouse/-superscope/-justifier/-cheat/
# -script (none documented upstream).

# snes9x: Super Nintendo emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-tr[enable transparency]' \
  '(-hires -hi)-hires[enable hi-res]' \
  '(-hires -hi)-hi[enable hi-res]' \
  '(-y -interpolate)-y[2x display blender]' \
  '(-y -interpolate)-interpolate[2x display blender]' \
  '-y2[scale2x]' \
  '-y3[scale3x]' \
  '-y4[scale4x]' \
  '-y5[scale5x]' \
  '(-nms -nomodeswitch)-nms[no mode switch]' \
  '(-nms -nomodeswitch)-nomodeswitch[no mode switch]' \
  '(-fullscreen -fs)-fullscreen[fullscreen]' \
  '(-fullscreen -fs)-fs[fullscreen]' \
  '(-scale -sc)-scale[scale factor]:n:' \
  '(-scale -sc)-sc[scale factor]:n:' \
  '(-displayframerate -dfr)-displayframerate[show framerate]' \
  '(-ns -nosound)-ns[no sound]' \
  '(-ns -nosound)-nosound[no sound]' \
  '-sk[sound skip 0-3]:n:(0 1 2 3)' \
  '(-stereo -st)-stereo[stereo]' \
  '(-stereo -st)-st[stereo]' \
  '-mono[mono]' \
  '-r[sound quality 0-7]:n:(0 1 2 3 4 5 6 7)' \
  '-soundquality[sound quality 0-7]:n:' \
  '(-ts -threadsound)-threadsound[threaded sound]' \
  '(-sy -soundsync)-soundsync[sync sound]' \
  '(-is -interpolatedsound)-interpolatedsound[interpolated sound]' \
  '(-b -buffersize -bs)-buffersize[buffer size]:n:' \
  '(-f -frameskip)-frameskip[frame skip count]:n:' \
  '-frametime[frame time ms]:ms:' \
  '(-h -cycles)-h[cycle %]:n:' \
  '(-i -interleaved)-interleaved[interleaved ROM]' \
  '-i2[alt interleaved]' \
  '(-hirom -fh -hr)-hirom[force HiROM]' \
  '(-lorom -fl -lr)-lorom[force LoROM]' \
  '(-header -hd)-header[has header]' \
  '(-noheader -nhd)-noheader[no header]' \
  '(-p -pal)-pal[force PAL]' \
  '(-n -ntsc)-ntsc[force NTSC]' \
  '(-l -loadsnapshot)-loadsnapshot[load snapshot]:file:_files' \
  '(-nh -nohdma)-nohdma[no HDMA]' \
  '(-nw -nowindows)-nowindows[no window effects]' \
  '-nopatch[no patches]' \
  '-bsxbootup[BSX boot up]' \
  '(-s -swap)-swap[swap controllers 1&2]' \
  '(-j -nojoy)-nojoy[no joysticks]' \
  '*-joymap1[joystick 1 mapping]:map:' \
  '*-joymap2[joystick 2 mapping]:map:' \
  '*-gg[Game Genie code]:code:' \
  '*-ar[Action Replay code]:code:' \
  '*-gf[Pro Action Replay code]:code:' \
  '-nocheat[disable cheats]' \
  '-cheat[enable cheats]' \
  '-version[show version]' \
  '*:rom:_files -g "*.(smc|sfc|fig|swc)(-.)"' && ret=0
return ret
