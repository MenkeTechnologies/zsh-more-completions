#compdef howl
# Documentation: https://github.com/howl-editor/howl
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Howl: lightweight Lua/MoonScript editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--reuse[reuse running instance]' \
  '--no-reuse[start new instance]' \
  '--run=[run lua module on startup]:module:' \
  '--no-profile[disable user config]' \
  '*:files:_files' && ret=0
return ret
