#compdef kg
# Documentation: https://www.npmjs.com/package/kirograph
# Reference accessed: 2026-05-23
# Verified: npx kirograph --help (kg alias).

# Zsh completion for kg - KiroGraph semantic code graph CLI alias

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:wire up MCP/instructions for an agent workspace'
  'init:initialize KiroGraph in a project'
  'uninit:remove KiroGraph from a project'
  'uninstall:alias for uninit'
  'index:full re-index of a project'
  'sync:incremental sync of changed files'
  'query:find symbols by name'
  'context:get relevant code context for a task'
  'files:list indexed files'
  'path:find connection path between symbols'
  'affected:find tests affected by changes'
  'export:export or open graph dashboard'
  'hotspots:show most-connected symbols'
  'surprising:find unexpected cross-module connections'
  'dead-code:find unreferenced symbols'
  'snapshot:manage graph snapshots'
  'architecture:inspect package architecture'
  'coupling:show package coupling metrics'
  'package:inspect a package'
  'caveman:toggle caveman agent mode'
  'compression:configure output compression'
  'exec:run command with compression'
  'gain:show token savings metrics'
  'mem:search or store agent memory'
  'serve:start MCP server'
  'impact:show blast radius for a symbol'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '--target=[agent target]:target:(kiro claude codex all)'   '--force[skip confirmation or force re-index]'   '-i[ index immediately after init]'   '--index[index immediately after init]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (snapshot)
        _arguments '1:sub:(save diff list)' && ret=0 ;;
      (mem)
        _arguments '1:sub:(search store list)' '--kind=[memory kind]:kind:(decision note)' && ret=0 ;;
      (serve)
        _arguments '--mcp[start MCP server]' && ret=0 ;;
      (*)
        _arguments '*::args:' && ret=0 ;;
    esac ;;
esac

return ret
