#compdef wsfontload
# Documentation: man wsfontload(8)
# Source: netbsd/src usr.sbin/wsfontload — load font into wsfont pool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B[font data right-to-left byte-wise]' \
    '-b[font data right-to-left bit-wise]' \
    '-e+[font encoding (default iso)]:encoding:(iso ibm pcvt iso2 iso7 koi8r)' \
    '-f+[device to operate on (default /dev/wsfont)]:wsdev:_files' \
    '-h+[character height in pixels (default 16)]:height:_default' \
    '(- *)-l[list loaded and built-in fonts]' \
    '-N+[name to refer to the font]:name:_default' \
    '-v[print font properties before loading]' \
    '-w+[character width in pixels (default 8)]:width:_default' \
    '1::font file:_files' \
    && ret=0

return ret
