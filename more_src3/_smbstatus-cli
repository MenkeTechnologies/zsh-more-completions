#compdef smbstatus-cli
# _smbstatus-cli — Samba smbstatus report on current SMB connections CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_smbstatus-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-P[ping smbd]' \
        '--processes[ping smbd]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-L[list locked files only]' \
        '--locks[list locked files only]' \
        '-B[list byte range locks]' \
        '--byterange[list byte range locks]' \
        '-S[list shares only]' \
        '--shares[list shares only]' \
        '-N[list notifies]' \
        '--notify[list notifies]' \
        '-p[list smbd processes only]' \
        '--processes[list smbd processes only]' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-b[print brief]' \
        '--brief[print brief]' \
        '-c+[config file]:file:_files -g "smb.conf"' \
        '--configfile=+[config file]:file:_files -g "smb.conf"' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[debug level]:n:' \
        '--debug-stdout[debug to stdout]' \
        '-l+[log basename]:str:' \
        '--log-basename=+[log basename]:str:' \
        '-n[do not query parent shares]' \
        '--numeric[print numeric uids/gids]' \
        '-fjson[json output]' \
        '--json[json output]' \
        '-t[show profile data only]' \
        '--profile[show profile data only]' \
        '-R[print resolve dns]' \
        '--resolve-uids[resolve uids]' \
        '-f+[stack format]:str:' \
        '*:arg:'
}

_smbstatus-cli "$@"
