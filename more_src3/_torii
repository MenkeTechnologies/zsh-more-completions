  '--achievement.progression_model_name=[model tag for achievement progression events]:tag:'
)

# Search options decoded from SearchOptions at options.rs:924-972.
local -a torii_search_flags=(
  '--search.enabled[enable full-text search API]'
  '--search.max_results=[max search results per table]:n:'
  '--search.min_query_length=[min search query length]:n:'
  '--search.return_snippets[include match snippets in results]'
  '--search.snippet_length=[snippet length in chars]:n:'
