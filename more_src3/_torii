# Runner options decoded from RunnerOptions at options.rs:1007-1052.
local -a torii_runner_flags=(
  '--runner.explorer[enable Cartridge Explorer UI]'
  '--runner.check_contracts[verify configured contracts exist before starting]'
  '--runner.query_threads=[thread-pool size for query handlers]:n:'
  '--runner.indexer_threads=[thread-pool size for indexer workers]:n:'
  '--runner.allocation_strategy=[memory allocator strategy]:strategy:'
)

# gRPC options decoded from GrpcOptions at options.rs:1070-1129.
local -a torii_grpc_flags=(
  '--grpc.addr=[gRPC server address]:ip:'
  '--grpc.port=[gRPC server port]:port:'
  '--grpc.subscription_buffer_size=[gRPC subscription buffer size]:n:'
  '--grpc.optimistic[send optimistic responses before chain confirms]'
  '--grpc.tcp_keepalive_interval=[TCP keepalive interval (seconds)]:n:'
  '--grpc.http2_keepalive_interval=[HTTP/2 keepalive ping interval]:n:'
  '--grpc.http2_keepalive_timeout=[HTTP/2 keepalive timeout]:n:'
  '--grpc.max_message_size=[max gRPC message size (bytes)]:bytes:'
)

# Relay options decoded from RelayOptions at options.rs:71-125.
local -a torii_relay_flags=(
  '--relay.port=[Libp2p TCP/UDP-Quic transport port]:port:'
  '--relay.webrtc_port=[Libp2p WebRTC transport port]:port:'
  '--relay.websocket_port=[Libp2p WebSocket transport port]:port:'
  '--relay.local_key_path=[local identity key file path (auto-generated if omitted)]:file:_files'
  '--relay.cert_path=[local certificate file path for WebRTC (auto-generated if omitted)]:file:_files'
  '--relay.peers=[other torii relays to connect to (comma-separated multiaddrs)]:peers:'
)

_arguments -C \
  $torii_top_flags \
  $torii_indexing_flags \
  $torii_events_flags \
  $torii_http_flags \
  $torii_metrics_flags \
  $torii_erc_flags \
  $torii_messaging_flags \
  $torii_sql_flags \
  $torii_activity_flags \
  $torii_achievement_flags \
  $torii_search_flags \
  $torii_snapshot_flags \
  $torii_runner_flags \
  $torii_grpc_flags \
  $torii_relay_flags && ret=0

return ret
