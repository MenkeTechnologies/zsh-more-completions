#compdef stm32cubemx STM32CubeMX
# _stm32cubemx — STMicroelectronics STM32CubeMX CLI for the graphical and headless STM32 MCU pin-clock-peripheral configurator generating HAL LL CMSIS startup files Makefile MDK IAR projects from .ioc files (st team, Java); custom argparse
# upstream: https://www.st.com/en/development-tools/stm32cubemx.html

_stm32cubemx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '--no-splash[no splash]' \
        '-l+[language]:l:(en fr de zh ja ko)' \
        '--language=+[language]:l:(en fr de zh ja ko)' \
        '-c+[script]:file:_files -g "*.script *.scr *.bat"' \
        '--cmd=+[script]:file:_files -g "*.script *.scr *.bat"' \
        '-batch[batch mode]' \
        '--batch[batch mode]' \
        '--mcu=+[mcu]:str:' \
        '--project=+[name]:str:' \
        '--out=+[dir]:dir:_files -/' \
        '--toolchain=+[t]:t:(MDK-ARM SW4STM32 EWARM CMake STM32CubeIDE Makefile MCSDK GPDSC)' \
        '--export[export project]' \
        '--no-gui[no GUI]' \
        '*:ioc file:_files -g "*.ioc *.json *.csv"'
}

_stm32cubemx "$@"
