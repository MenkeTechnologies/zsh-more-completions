#compdef secret-share-split secret-share-combine
# Documentation: https://github.com/dsprenkels/sss-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (Shamir's secret sharing CLI).
# Notes: secret-share-split takes -n SHARES and -t THRESHOLD; secret-share-combine
# reads shares from stdin and takes no documented flags.

local curcontext="$curcontext" ret=1

if [[ $service == secret-share-split ]]; then
  _arguments -s -S \
    '-n+[number of shares to create]:n:' \
    '-t+[threshold (shares required to recombine)]:t:' && ret=0
else
  _arguments -s -S && ret=0
fi

return ret
