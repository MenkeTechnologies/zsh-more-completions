#compdef teamdctl
# _teamdctl — libteam teamdctl (control a running teamd(8) instance: get/dump state and config, add/remove ports, query port options/config, set runner options; -o output format usbus|dbus|zmq)
# upstream: https://github.com/jpirko/libteam
# Subcommands from libteam teamd/teamd_ctl.c on tip.

_teamdctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-D[dbus transport]' \
        '-Z+[zmq socket]:addr:' \
        '-U[unix socket transport]' \
        '-v[verbose]' \
        '-o+[output format]:format:(text json dump)' \
        '1: :->team' \
        '*::arg:->args'
    case $state in
        team) _message 'teamdev (interface name)' ;;
        args)
            _describe -t commands 'teamdctl command' \
                '(state:show team state config:show config port:add|remove|present|config|update port_config_update|state_dump runner:per-runner config (e.g. setupropr) help)' || \
            _arguments '*:subcommand:'
            ;;
    esac
}

_teamdctl "$@"
