_hisiflash_commands() {
    local commands; commands=(
'flash:Flash a FWPKG firmware package' \
'write:Write raw binary files to flash' \
'write-program:Write a single binary with program data' \
'erase:Erase flash memory' \
'info:Show information about a firmware file' \
'list-ports:List available serial ports' \
'monitor:Open serial monitor' \
'completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'hisiflash commands' commands "$@"
}
