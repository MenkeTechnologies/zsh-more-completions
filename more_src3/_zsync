#compdef zsync
# Documentation: https://manpages.debian.org/testing/zsync/zsync.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream zsync(1) manpage.

# Zsh completion for zsync (efficient file download using rsync algorithm)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-A+[Append authorization credentials for given hostname]:hostname=username:password' \
  '-i+[Additional seed file to scan for reusable blocks]:file:_files' \
  '-k+[Save the downloaded zsync control file as the given name]:file:_files' \
  '-o+[Output filename]:file:_files' \
  '-q[Quiet mode (disable progress bar and download stats)]' \
  '-s[Deprecated alias for -q]' \
  '-u+[Referring URL for relative paths in local .zsync files]:url' \
  '-V[Print version information]' \
  ':zsync control file URL or path' && ret=0

return ret
