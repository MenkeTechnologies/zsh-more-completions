#compdef xclock
# _xclock — X11 xclock (analog or digital clock client; -digital/-analog mode, -update sec refresh interval, -chime ring on hour, -strftime "%fmt" digital format, -hd/-hl/-fg/-bg colors, -fn font)
# upstream: https://gitlab.freedesktop.org/xorg/app/xclock
# Flags from xclock src/Clock.c on tip.

_xclock() {
    _arguments \
        '-digital[digital mode]' \
        '-analog[analog mode]' \
        '-brief[brief digital format]' \
        '-utime[unix time]' \
        '-twelve[12-hour clock]' \
        '-twentyfour[24-hour clock]' \
        '-chime[ring on hour]' \
        '-padding+[padding px]:px:' \
        '-update+[refresh seconds]:seconds:' \
        '-strftime+[strftime format]:fmt:' \
        '-fg+[foreground color]:color:' \
        '-bg+[background color]:color:' \
        '-fn+[font]:font:' \
        '-hd+[hand color]:color:' \
        '-hl+[hand highlight color]:color:' \
        '-norender[skip Xrender]' \
        '-render[force Xrender]' \
        '-sharp[sharp tick marks]' \
        '*:option:'
}

_xclock "$@"
