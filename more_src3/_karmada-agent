#compdef karmada-agent
# Documentation: https://karmada.io/docs/reference/components/karmada-agent/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# --master/--leader-elect-resource-name/--secure-port/--cert-dir/
# --tls-* (not karmada-agent flags); added real cluster-* flags.

# karmada-agent: Karmada Pull-mode member cluster agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--cluster-name=[name of member cluster the agent serves for]:name:' \
  '--cluster-api-endpoint=[APIEndpoint of the cluster]:url:' \
  '--cluster-namespace=[namespace for member cluster secrets]:ns:' \
  '--cluster-provider=[provider of the joining cluster]:provider:' \
  '--cluster-region=[region of the joining cluster]:region:' \
  '--cluster-zones=[zones of the joining cluster]:zones:' \
  '--karmada-kubeconfig=[path to control plane kubeconfig file]:file:_files' \
  '--karmada-context=[cluster context name in control plane kubeconfig]:context:' \
  '--kubeconfig=[paths to kubeconfig]:file:_files' \
  '--cluster-status-update-frequency=[how often to post cluster status]:duration:' \
  '--cluster-lease-duration=[cluster lease expiration period]:duration:' \
  '--health-probe-bind-address=[health probe bind address]:addr:' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--leader-elect[enable leader election]' \
  '--concurrent-cluster-syncs=[concurrent cluster syncs]:n:' \
  '--concurrent-work-syncs=[concurrent work syncs]:n:' \
  '--enable-cluster-resource-modeling[build resource modeling per cluster]' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '--logtostderr[log to stderr]' \
  '*::karmada-agent args:_files' && ret=0
return ret
