#compdef idiff
# Documentation: https://github.com/krish-r/idiff
# Source: krish-r/idiff — pixel-by-pixel image diff CLI in Rust.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--src=[source image file]:file:_files -g "*.(png|jpg|jpeg|bmp|webp)"' \
    '--tgt=[target image file]:file:_files -g "*.(png|jpg|jpeg|bmp|webp)"' \
    '--strict[exit if image dimensions differ]' \
    '--highlight[create an output file highlighting differences]' \
    '--block=[pixel block size for highlighting (default 10)]:n:_default' \
    '(-o --output)'{-o+,--output=}'[output filename without extension]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
