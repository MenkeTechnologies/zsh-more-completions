#compdef text-generation-server
# Documentation: https://github.com/huggingface/text-generation-inference/blob/main/server/text_generation_server/cli.py
# Reference accessed: 2026-05-21
# Verified: upstream CLI source at the URL above.

# HuggingFace text-generation-inference (TGI) Python server CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'serve:launch the inference server'
  'download-weights:retrieve model weights'
  'quantize:perform GPTQ quantization'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'text-generation-server command' commands && ret=0 ;;
esac
return ret
