#compdef hakports
# _hakports — hakluke hakports CLI fast minimal port discovery scanner CLI written in Go reading hostnames or IPs on stdin testing TCP UDP ports concurrently with goroutines emitting open-only or human-readable formats for chaining downstream with httpx nuclei in bug-bounty enumeration pipelines (hakluke team, Go); pflag
# upstream: https://github.com/hakluke/hakports

_hakports() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-p+[ports]:str:' \
        '--ports=+[list]:str:' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-u[UDP scan]' \
        '--udp[UDP scan]' \
        '-r+[retries]:n:' \
        '--retries=+[N]:n:' \
        '--top-ports=+[N]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-f+[format]:f:(plain text csv json human)' \
        '--format=+[format]:f:(plain text csv json human)' \
        '--banner[grab banner]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '*:host:'
}

_hakports "$@"
