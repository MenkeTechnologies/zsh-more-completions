# but a distro umbrella that ships standard OpenJDK tools (java,
# javac, javah, javadoc, javap, jar, jarsigner). No `icedtea7`
# command itself with flags. Conservative stub - users should invoke
# the actual JDK tool (java/javac/etc) directly.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# icedtea7: OpenJDK 7 distro umbrella (no single binary)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
