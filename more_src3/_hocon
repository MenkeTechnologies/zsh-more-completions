#compdef hocon
# _hocon — pyhocon hocon (CLI for HOCON config files: parse, dump as json/properties/yaml/conf, query by dotted path; -i input, -o output, -f format, -p path)
# upstream: https://github.com/chimpler/pyhocon
# Flags from pyhocon pyhocon/tool.py on tip.

_hocon() {
    _arguments \
        '--help[show help]' \
        '-i+[input file]:file:_files' \
        '-o+[output file]:file:_files' \
        '-c[from stdin]' \
        '-f+[output format]:format:(json properties yaml conf hocon)' \
        '-n[no resolve]' \
        '-p+[get value at path]:path:'
}

_hocon "$@"
