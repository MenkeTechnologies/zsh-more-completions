#compdef libsnmp_test snmp_test snmp_perl_test
# _libsnmp — net-snmp library test/example helpers (small libsnmp/example binaries used to verify net-snmp library behaviour and Perl bindings; -v 1|2c|3, -c community, -h host, -o OID, -m MIBs, -V version, -h help; user-facing equivalents are snmpget/snmpwalk so this stub completes only the most-common flags)
# upstream: https://www.net-snmp.org/
# Common flag shape from net-snmp libsnmp/test/* on tip.

_libsnmp() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v+[version]:version:(1 2c 3)' \
        '-c+[community]:community:' \
        '-o+[OID]:oid:' \
        '-m+[MIBs]:mibs:' \
        '1:agent:_hosts' \
        '*:OID:'
}

_libsnmp "$@"
