#compdef sbsign sbverify sbattach sbsiglist sbvarsign sbkeysync
# Documentation: https://manpages.debian.org/testing/sbsigntool/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (per-command man pages).

local curcontext="$curcontext" ret=1

case $service in
  (sbsign)
    _arguments \
      '--engine=[OpenSSL engine to load key]:engine:' \
      '--key=[PEM-encoded RSA private key]:file:_files' \
      '--cert=[x509 certificate file]:file:_files' \
      '--addcert=[additional intermediate certs]:file:_files' \
      '--detached[create detached signature]' \
      '--output=[output file]:file:_files' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbverify)
    _arguments \
      '--cert=[x509 certificate for verification]:file:_files' \
      '--list[list signatures in image]' \
      '--detached=[read signature from separate file]:file:_files' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbattach)
    _arguments \
      '--attach=[set sigfile as the signature table]:file:_files' \
      '--detach=[copy signature table to file]:file:_files' \
      '--remove[remove signature table]' \
      '--signum=[signature index to operate on]:n:' \
      '*:file:_files -g "*.efi"' && ret=0 ;;
  (sbsiglist)
    _arguments \
      '--owner=[signature owner GUID]:guid:' \
      '--type=[signature type]:type:(x509 sha256)' \
      '--output=[output siglist file]:file:_files' \
      '*:input file:_files' && ret=0 ;;
  (sbvarsign)
    _arguments \
      '--engine=[OpenSSL engine to load key]:engine:' \
      '--key=[PEM-encoded RSA private key]:file:_files' \
      '--cert=[x509 certificate file]:file:_files' \
      '--include-attrs[include attributes in output]' \
      '--guid=[EFI GUID for variable]:guid:' \
      '--attr=[variable attributes]:attrs:' \
      '--output=[output file]:file:_files' \
      '*:varname:' && ret=0 ;;
  (sbkeysync)
    _arguments \
      '--efivars-path=[efivars mountpoint]:dir:_files -/' \
      '--verbose[verbose progress info]' \
      '--dry-run[do not update firmware key databases]' \
      '--pk[set PK]' \
      '*--keystore=[read keys from directory]:dir:_files -/' \
      '--no-default-keystores[do not use default keystore dirs]' && ret=0 ;;
esac

return ret
