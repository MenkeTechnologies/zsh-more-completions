#compdef stryker-cli stryker
# _stryker-cli — Stryker Mutator stryker-cli CLI command-line frontend wrapping the Stryker Mutator the most popular Mutation testing framework for the .NET JavaScript and Scala ecosystems open-source written in TypeScript Node CLI mutation testing for JavaScript and friends a JavaScript mutation testing framework providing test runner-Jest-Mocha-Karma-Jasmine-Vitest-Wallaby mutation-score-threshold-break-high-low Sane-watch-mode reporter clear-text json html dashboard plugins test-runners webpack-vite-rollup karma-jasmine-mocha-vitest concurrency time-out-MS mutate (Stryker Mutator team Nico Jansen Simon de Lang Jan Adriaan Aarsman, TypeScript); commander
# upstream: https://stryker-mutator.io/

_stryker-cli() {
    local -a sub=(
        'init:initialize Stryker'
        'run:run mutation tests'
        'reformat:reformat config'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "stryker.conf.* *.json *.js *.cjs *.mjs *.ts"' \
        '--configFile=+[file]:file:_files' \
        '--mutate=+[glob]:str:' \
        '-m+[mutate]:str:' \
        '*--mutate=+[glob]:str:' \
        '--reporters=+[name]:str:' \
        '*--reporters=+[name]:n:(html clear-text progress dots dashboard json mutation-test-elements-report)' \
        '--testRunner=+[name]:n:(jest mocha jasmine karma vitest cucumber tap command)' \
        '--testFramework=+[name]:n:(jasmine mocha jest)' \
        '--concurrency=+[N]:n:' \
        '--maxConcurrentTestRunners=+[N]:n:' \
        '--coverageAnalysis=+[m]:m:(off all perTest)' \
        '--timeoutMS=+[ms]:n:' \
        '--timeoutFactor=+[N]:str:' \
        '--maxTestRunnerReuse=+[N]:n:' \
        '--thresholds.high=+[N]:n:' \
        '--thresholds.low=+[N]:n:' \
        '--thresholds.break=+[N]:n:' \
        '--dashboard.project=+[name]:str:' \
        '--dashboard.version=+[v]:str:' \
        '--dashboard.module=+[name]:str:' \
        '--dashboard.baseUrl=+[url]:str:' \
        '--dashboard.reportType=+[t]:t:(full mutationScore)' \
        '--dryRunOnly[dry run only]' \
        '--ignorePatterns=+[glob]:str:' \
        '*--ignorePatterns=+[glob]:str:' \
        '--ignoreStatic[ignore static]' \
        '--symlinkNodeModules=+[v]:v:(true false)' \
        '--inPlace[in place mutation]' \
        '--logLevel=+[l]:l:(off fatal error warn info debug trace)' \
        '--fileLogLevel=+[l]:l:(off fatal error warn info debug trace)' \
        '--allowConsoleColors=+[v]:v:(true false)' \
        '--plugins=+[name]:str:' \
        '*--plugins=+[name]:str:' \
        '--tempDirName=+[dir]:dir:_files -/' \
        '--cleanTempDir=+[v]:v:(true false)' \
        '--disableTypeChecks=+[glob]:str:' \
        '--disableBail[disable bail]' \
        '--mutator.plugins=+[plugins]:str:' \
        '--mutator.excludedMutations=+[names]:str:' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--clearTextReporter.allowEmojis[allow emojis]' \
        '--commandRunner.command=+[cmd]:str:' \
        '--htmlReporter.fileName=+[file]:file:_files -g "*.html"' \
        '--jsonReporter.fileName=+[file]:file:_files -g "*.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stryker subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_stryker-cli "$@"
