#compdef kuryr kuryrctl
# _kuryr — OpenStack Kuryr Authors kuryr CLI command-line frontend to the Kuryr OpenStack Kubernetes networking integration controller binding the OpenStack Neutron-OVN-OVS networking control-plane to Kubernetes pod networking via Kuryr-Kubernetes Kuryr-Containers-CNI-plugin Octavia-LBaaS-port-binding management (OpenStack team, Python); cobra
# upstream: https://docs.openstack.org/kuryr/

_kuryr() {
    local -a sub=(
        'install:install Kuryr-Kubernetes'
        'uninstall:uninstall Kuryr-Kubernetes'
        'status:show controller status'
        'list:list managed resources'
        'attach:attach port to pod'
        'detach:detach port from pod'
        'sync:reconcile state'
        'ports:port operations'
        'subnets:subnet operations'
        'sg:security group operations'
        'lb:Octavia LBaaS operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--os-auth-url=+[url]:str:' \
        '--os-username=+[user]:str:' \
        '--os-password=+[password]:str:' \
        '--os-project-name=+[project]:str:' \
        '--os-region-name=+[region]:str:' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kuryr subcommand' sub ;;
        args)
            case $words[1] in
                ports|subnets|sg|lb) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_kuryr "$@"
