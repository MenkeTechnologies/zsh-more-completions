#compdef ledgerctl
# Documentation: https://github.com/LedgerHQ/ledgerctl (ledgerwallet/ledgerctl.py click commands)
# Reference accessed: 2026-05-29
# Ledger hardware-wallet device administration CLI.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'send:send raw APDU data to the device'
  'genuine-check:check if device is genuine'
  'genuine_check:check if device is genuine (underscore alias)'
  'list:list installed applications'
  'install:install an application'
  'remote-install:install an application from a remote server'
  'delete:delete an application'
  'remote-delete:delete an application using a remote server'
  'run:run a specified application'
  'install-ca:install a custom certificate authority on the device'
  'install_ca:install a custom certificate authority (underscore alias)'
  'delete-ca:delete custom certificate authority'
  'delete_ca:delete custom certificate authority (underscore alias)'
  'meminfo:display device memory usage'
  'info:display device information'
  'upgrade-firmware:upgrade device firmware'
  'onboard:initialize device from CLI (recovery mode)'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[display exchanged APDU]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'ledgerctl subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments \
          '--apdu[show exchanged APDU traffic]' \
          ':APDU hex bytes:' && ret=0
        ;;
      install)
        _arguments \
          '(-f --force)'{-f,--force}'[force install even if app is already installed]' \
          ':manifest file:_files -g "*.(json|toml)"' && ret=0
        ;;
      remote-install)
        _arguments \
          '--url=[remote app server URL]:url:_urls' \
          ':app name:' \
          ':version:' && ret=0
        ;;
      delete)
        _arguments \
          ':app name:' && ret=0
        ;;
      remote-delete)
        _arguments \
          '--url=[remote app server URL]:url:_urls' \
          ':app name:' && ret=0
        ;;
      run)
        _arguments ':app name:' && ret=0
        ;;
      install-ca|install_ca)
        _arguments \
          ':certificate file:_files' \
          ':CA name:' && ret=0
        ;;
      delete-ca|delete_ca)
        _arguments ':CA name:' && ret=0
        ;;
      onboard)
        _arguments \
          '--pin=[device PIN code]:pin:' \
          '--seed=[BIP39 seed phrase]:seed:' \
          '--identity=[identity number]:n:' \
          '--prefix=[derivation prefix]:prefix:' \
          '--passphrase=[optional passphrase]:passphrase:' && ret=0
        ;;
      upgrade-firmware)
        _arguments \
          '--firmware=[firmware file path]:file:_files' \
          '--key=[firmware key path]:file:_files' \
          '--perso=[perso identifier]:perso:' && ret=0
        ;;
    esac
    ;;
esac

return ret
