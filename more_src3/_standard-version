#compdef standard-version
# Documentation: https://github.com/conventional-changelog/standard-version/blob/master/command.js
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --release-as)'{-r,--release-as=}'[specify release type manually]:release:(major minor patch)' \
  '(-p --prerelease)'{-p,--prerelease=}'[make a pre-release with optional tag id]:tag:' \
  '(-i --infile)'{-i,--infile=}'[read the CHANGELOG from this file]:file:_files' \
  '(-m --message)'{-m,--message=}'[DEPRECATED commit message format]:format:' \
  '(-f --first-release)'{-f,--first-release}'[mark this as the first release]' \
  '(-s --sign)'{-s,--sign}'[sign the git commit and tag]' \
  '(-n --no-verify)'{-n,--no-verify}'[bypass pre-commit/commit-msg git hooks]' \
  '(-a --commit-all)'{-a,--commit-all}'[commit all staged changes]' \
  '--silent[suppress output]' \
  '(-t --tag-prefix)'{-t,--tag-prefix=}'[custom prefix for git tag]:prefix:' \
  '*--scripts=[lifecycle hook scripts (prebump etc.)]:script:' \
  '*--skip=[steps in release process to skip]:step:' \
  '--dry-run[show commands without running]' \
  '--git-tag-fallback[fall back to git tags for version]' \
  '--path=[only include commits under this path]:path:_files -/' \
  '--changelogHeader=[DEPRECATED custom changelog header]:header:' \
  '--preset=[conventional-changelog preset]:preset:' \
  '--lerna-package=[lerna package name for tag extraction]:pkg:' \
  '*--packageFiles=[files containing version]:file:_files' \
  '*--bumpFiles=[additional files to bump version in]:file:_files' && ret=0

return ret
