#compdef lsmake
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lsmake.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lsmake(1) reference.
# Notes: upstream documents LSF-specific extras (-j, -M, -R, -m, -a,
# -c, -E, -G, -T, -u, -V, -x, -y) plus full GNU make 3.81 passthrough.

local ret=1
_arguments -s -S \
  '-j+[max parallel CPU slots from LIM]:n:' \
  '-M+[parallelize subdirectory makes]:n:' \
  '-m+[host and core counts]:hosts:' \
  '-R+[resource requirement]:expr:' \
  '-a+[buffer delay seconds]:seconds:' \
  '-c+[concurrent tasks per core]:n:' \
  '-E[refresh environment for each task]' \
  '-G+[debug level]:level:' \
  '-T[tag output with task ID]' \
  '-u[generate lsmake.dat]' \
  '-V[verbose - show host names]' \
  '-x+[retry failed commands]:n:' \
  '-y[show summary statistics]' \
  '(-C --directory)'{-C+,--directory=}'[change directory]:dir:_files -/' \
  '-f+[makefile]:file:_files' \
  '-k[keep going on errors]' \
  '-n[dry-run mode]' \
  '-p[print database]' \
  '-s[silent]' \
  '-B[always rebuild]' \
  '-e[env overrides makefile]' \
  '-i[ignore errors]' \
  '-r[no built-in rules]' \
  '-W+[treat target as recently modified]:target:' \
  '--debug=[debug level]:level:(a b v i j m)' \
  '--no-print-directory[do not print entering/leaving]' \
  '-h[show help]' \
  '*:target:_files' && ret=0
return ret
