#compdef kubectl-images
# kubectl-images (krew plugin): show container images in a Kubernetes cluster
# https://github.com/chenjiandongx/kubectl-images

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-c --columns)'{-c+,--columns=}'[columns to display]:columns' \
  '(-k --kubeconfig)'{-k+,--kubeconfig=}'[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
  '(-s --sort)'{-s,--sort}'[sort by image name]' \
  '(-u --unique)'{-u,--unique}'[show unique images only]' \
  '(-C --context)'{-C+,--context=}'[kubernetes context]:context' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '--field-selector=[field selector]:selector' \
  '*:resource'
