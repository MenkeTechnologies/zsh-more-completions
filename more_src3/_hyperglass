#compdef hyperglass
# Documentation: https://github.com/thatmattlove/hyperglass
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hyperglass — network looking glass (thatmattlove/hyperglass)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start hyperglass server'
  'build-ui:build the user interface'
  'setup:run initial setup'
  'system-info:print system info for issue reports'
  'secret:generate a secret'
  'clear-cache:clear the persistent cache'
  'plugins:manage plugins'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:subcommand:->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'hyperglass subcommand' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '(-d --direct)'{-d,--direct}'[run in direct/foreground mode]' && ret=0
        ;;
      (build-ui)
        _arguments \
          '--timeout=[override UI build timeout]:seconds' && ret=0
        ;;
    esac ;;
esac

return ret
