#compdef kfp-driver
# _kfp-driver — Kubeflow Pipelines v2 task driver (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/v2/cmd/driver/main.go on tip.

_kfp-driver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--type=[driver type]:type:(ROOT_DAG DAG CONTAINER)' \
        '--pipeline_name=[pipeline context name]:name:' \
        '--run_id=[pipeline run UID]:id:' \
        '--run_name=[pipeline run name]:name:' \
        '--run_display_name=[pipeline run display name]:name:' \
        '--component=[component spec JSON]:json:' \
        '--task=[task spec JSON]:json:' \
        '--runtime_config=[job runtime config JSON]:json:' \
        '--iteration_index=[iteration index (-1 = not iteration)]:n:' \
        '--task_name=[original task name]:name:' \
        '--dag_execution_id=[DAG execution ID]:n:' \
        '--container=[container spec JSON]:json:' \
        '--kubernetes_config=[k8s executor config JSON]:json:' \
        '--ml_pipeline_server_address=[ML pipeline API server host]:host:_hosts' \
        '--ml_pipeline_server_port=[ML pipeline API server port]:port:' \
        '--mlmd_server_address=[MLMD gRPC server host]:host:_hosts' \
        '--mlmd_server_port=[MLMD gRPC server port]:port:' \
        '--execution_id_path=[execution ID output path]:file:_files' \
        '--iteration_count_path=[iteration count output path]:file:_files' \
        '--pod_spec_patch_path=[pod-spec-patch output path]:file:_files' \
        '--cached_decision_path=[cached-decision output path]:file:_files' \
        '--condition_path=[condition output path]:file:_files' \
        '--log_level=[log verbosity]:n:' \
        '--http_proxy=[HTTP proxy URL]:url:_urls' \
        '--https_proxy=[HTTPS proxy URL]:url:_urls' \
        '--no_proxy=[no_proxy hosts]:list:' \
        '--publish_logs=[publish component logs to object store]:bool:(true false)' \
        '--cache_disabled=[disable cache globally]:bool:(true false)' \
        '--ml_pipeline_tls_enabled=[ML pipeline API server uses TLS]:bool:(true false)' \
        '--metadata_tls_enabled=[MLMD uses TLS]:bool:(true false)'
}

_kfp-driver "$@"
