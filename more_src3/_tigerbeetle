#compdef tigerbeetle
# Documentation: https://github.com/tigerbeetle/tigerbeetle/blob/main/src/tigerbeetle/cli.zig
# Reference accessed: 2026-05-21
# Verified: upstream cli.zig at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'format:create a TigerBeetle replica data file'
  'start:run a TigerBeetle replica from an existing data file'
  'version:display build version and compile-time configuration'
  'repl:launch an interactive TigerBeetle client shell'
  'benchmark:experimental performance testing tool'
  'recover:create a replica data file for cluster recovery'
  'inspect:examine internal data structures (experimental)'
  'multiversion:validate multiversion binary compatibility'
  'amqp:change data capture connector for AMQP targets'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tigerbeetle subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (format)
        _arguments \
          '--cluster=[128-bit cluster ID]:id:' \
          '--replica=[zero-based replica index]:n:' \
          '--standby=[index for standby replicas]:n:' \
          '--replica-count=[number of replicas in cluster]:n:' \
          '--development[allow operation without Direct IO]' \
          '--log-debug[enable debug logging]' \
          '*:datafile:_files' && ret=0
        ;;
      (start)
        _arguments \
          '--addresses=[comma-separated IPv4/IPv6 addresses with ports]:addresses:' \
          '--cache-grid=[grid cache size]:size:' \
          '--development[smaller caches and batch sizes]' \
          '--experimental[enable experimental features]' \
          '--log-debug[enable debug logging]' \
          '--log-trace[enable trace logging]' \
          '--statsd=[statsd address]:addr:' \
          '--trace=[trace output path]:file:_files' \
          '--aof-file=[append-only file for transaction logging]:file:_files' \
          '--aof[legacy AOF flag]' \
          '--aof-recovery[accept client timestamps during AOF recovery]' \
          '*:datafile:_files' && ret=0
        ;;
      (recover)
        _arguments \
          '--cluster=[cluster ID]:id:' \
          '--addresses=[replica addresses]:addresses:' \
          '--replica=[zero-based replica index]:n:' \
          '--replica-count=[total replicas]:n:' \
          '--development[disable Direct IO requirement]' \
          '--log-debug[enable debug logging]' \
          '*:datafile:_files' && ret=0
        ;;
      (version)
        _arguments \
          '--verbose[include detailed configuration details]' && ret=0
        ;;
      (repl)
        _arguments \
          '--addresses=[cluster addresses]:addresses:' \
          '--cluster=[cluster ID]:id:' \
          '--verbose[enable verbose output]' \
          '--log-debug[enable debug logging]' \
          '*::command:' && ret=0
        ;;
      (benchmark)
        _arguments \
          '--cache-accounts=[accounts cache size]:size:' \
          '--cache-transfers=[transfers cache size]:size:' \
          '--cache-transfers-pending=[pending transfers cache size]:size:' \
          '--cache-grid=[grid cache size]:size:' \
          '--account-count=[number of accounts (default 10000)]:n:' \
          '--account-count-hot=[hot accounts (default 0)]:n:' \
          '--account-distribution=[account distribution]:dist:(uniform zipfian latest)' \
          '--account-batch-count=[account batch count]:n:' \
          '--transfer-count=[transfer count (default 10000000)]:n:' \
          '--transfer-hot-percent=[transfer hot percent (default 100)]:pct:' \
          '--transfer-pending[use pending transfers]' \
          '--transfer-batch-count=[transfer batch count]:n:' \
          '--transfer-batch-delay=[transfer batch delay]:duration:' \
          '--validate[validate results]' \
          '--checksum-performance[measure checksum performance]' \
          '--query-count=[query count (default 100)]:n:' \
          '--print-batch-timings[display timing details]' \
          '--id-order=[ID order]:order:(sequential random reversed tbid)' \
          '--clients=[client count (default 1)]:n:' \
          '--statsd=[statsd address]:addr:' \
          '--trace=[trace output path]:file:_files' \
          '--no-history[disable history]' \
          '--imported[imported transfers]' \
          '--log-debug[enable debug logging]' \
          '--log-debug-replica[enable debug logging for replica]' \
          '--file=[preserve data file after completion]:file:_files' \
          '--addresses=[connect to cluster]:addresses:' \
          '--seed=[random seed]:n:' && ret=0
        ;;
      (inspect)
        _arguments \
          '1:inspect type:(constants metrics op superblock wal replies grid manifest tables integrity)' \
          '*::args:_files' && ret=0
        ;;
      (multiversion)
        _arguments \
          '--log-debug[enable debug logging]' \
          '*:datafile:_files' && ret=0
        ;;
      (amqp)
        _arguments \
          '--addresses=[cluster addresses]:addresses:' \
          '--cluster=[cluster ID]:id:' \
          '--host=[AMQP broker address]:addr:' \
          '--user=[authentication username]:user:' \
          '--password=[authentication password]:password:' \
          '--vhost=[AMQP virtual host]:vhost:' \
          '--publish-exchange=[target exchange]:exchange:' \
          '--publish-routing-key=[routing key]:key:' \
          '--event-count-max=[max events]:n:' \
          '--idle-interval-ms=[idle interval ms]:ms:' \
          '--requests-per-second-limit=[RPS limit]:n:' \
          '--amqp-timeout-seconds=[AMQP timeout seconds]:n:' \
          '--tigerbeetle-timeout-seconds=[tigerbeetle timeout seconds]:n:' \
          '--timestamp-last=[last timestamp]:ts:' \
          '--verbose[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
