#compdef logstash
# Documentation: https://www.elastic.co/guide/en/logstash/current/running-logstash-command-line.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for logstash - Elastic log pipeline

_arguments \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-f --path.config)'{-f,--path.config}'=[path to config file or directory]:path:_files' \
  '(-e --config.string)'{-e,--config.string}'=[config string]:config' \
  '(-t --config.test_and_exit)'{-t,--config.test_and_exit}'[test config syntax and exit]' \
  '(-r --config.reload.automatic)'{-r,--config.reload.automatic}'[enable automatic config reloading]' \
  '--config.reload.interval=[config reload poll interval]:seconds' \
  '--config.debug[show compiled configuration]' \
  '(-i --interactive)'{-i,--interactive}'[drop to interactive shell]:script' \
  '(-w --pipeline.workers)'{-w,--pipeline.workers}'=[number of pipeline workers]:workers' \
  '(-b --pipeline.batch.size)'{-b,--pipeline.batch.size}'=[max events per batch]:size' \
  '(-u --pipeline.batch.delay)'{-u,--pipeline.batch.delay}'=[batch delay in milliseconds]:ms' \
  '--pipeline.unsafe_shutdown[force shutdown even if there are inflight events]' \
  '--pipeline.id=[pipeline ID]:id' \
  '--pipeline.ordered=[preserve event ordering]:mode:(auto true false)' \
  '--pipeline.ecs_compatibility=[ECS compatibility mode]:mode:(disabled v1 v8)' \
  '--pipeline.batch.output_chunking.growth_threshold_factor=[output batch split threshold]:factor' \
  '--path.data=[directory for runtime data]:dir:_directories' \
  '(-p --path.plugins)'{-p,--path.plugins}'=[path to custom plugins directory]:dir:_directories' \
  '(-l --path.logs)'{-l,--path.logs}'=[directory for logstash log output]:dir:_directories' \
  '--path.settings=[directory for logstash settings]:dir:_directories' \
  '--log.level=[log level]:level:(fatal error warn info debug trace)' \
  '--log.format=[log format]:format:(plain json)' \
  '--log.format.json.fix_duplicate_message_fields[avoid message field collision]' \
  '--api.enabled=[enable/disable HTTP API]:bool:(true false)' \
  '--api.http.host=[API binding host]:host' \
  '--api.http.port=[API port]:port' \
  '--node.name=[custom node name]:name' \
  '--plugin-classloaders[load Java plugins in independent classloaders]' \
  '--enable-local-plugin-development[enable local plugin development mode]' \
  && return 0
