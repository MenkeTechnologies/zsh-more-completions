#compdef hebcal
# Documentation: https://github.com/hebcal/hebcal
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Source: main.go handleArgs (getopt parser)
_arguments -s -S \
  '--help[print options]' \
  '--version[print version]' \
  '(-a --ashkenazi)'{-a,--ashkenazi}'[Ashkenazi transliteration]' \
  '(-e --euro-dates)'{-e,--euro-dates}'[DD.MM.YYYY output]' \
  '(-g --iso-8601)'{-g,--iso-8601}'[YYYY-MM-DD output]' \
  '(-C --city)'{-C,--city}'=-[city for zmanim/candles]:city:' \
  '-8[UTF-8 Hebrew (lang=he)]' \
  '--schottenstein[Schottenstein Yerushalmi]' \
  '--geo=-[lat,lon for solar calcs]:coords:' \
  '(-l --latitude)'{-l,--latitude}'=-[latitude XX,YY]:lat:' \
  '(-L --longitude)'{-L,--longitude}'=-[longitude XX,YY]:lon:' \
  '(-z --timezone)'{-z,--timezone}'=-[override tz id]:tz:' \
  '(-t --today)'{-t,--today}'[output only today]' \
  '(-T --today-brief)'{-T,--today-brief}'[today summary]' \
  '(-X --exit-if-chag)'{-X,--exit-if-chag}'[exit status if Shabbat/Chag]' \
  '--verbose[more logging for exit-if-chag]' \
  '--chag-only[only Chag/Erev]' \
  '--no-julian[no Julian calendar pre-1752]' \
  '(-y --year-abbrev)'{-y,--year-abbrev}'[two-digit year]' \
  '(-r --tabs)'{-r,--tabs}'[tab separated]' \
  '(-w --weekday)'{-w,--weekday}'[include weekday name]' \
  '(-E --24hour)'{-E,--24hour}'[24h clock]' \
  '(-O --sunrise-and-sunset)'{-O,--sunrise-and-sunset}'[daily sunrise/set]' \
  '(-Z --zmanim)'{-Z,--zmanim}'[daily zmanim]' \
  '(-M --molad)'{-M,--molad}'[print molad on Mevarchim]' \
  '(-W --abbrev)'{-W,--abbrev}'[weekly abbreviated view]' \
  '--lang=-[locale titles]:lang:' \
  '(-c --candlelighting)'{-c,--candlelighting}'[candle times]' \
  '(-d --add-hebrew-dates)'{-d,--add-hebrew-dates}'[Hebrew date each day]' \
  '(-D --add-hebrew-dates-for-events)'{-D,--add-hebrew-dates-for-events}'[Hebrew date on event days]' \
  '(-H --hebrew-date)'{-H,--hebrew-date}'[Hebrew range mode]' \
  '(-F --daf-yomi)'{-F,--daf-yomi}'[Daf Yomi]' \
  '--mishna-yomi[Mishna Yomi]' \
  '--nach-yomi[Nach Yomi]' \
  '--yerushalmi[Yerushalmi Yomi]' \
  '--ykk[Yom Kippur Katan]' \
  '--mevarchim[Shabbat Mevarchim]' \
  '(-h --no-holidays)'{-h,--no-holidays}'[skip default holidays]' \
  '(-x --no-rosh-chodesh)'{-x,--no-rosh-chodesh}'[skip Rosh Chodesh]' \
  '(-i --israeli)'{-i,--israeli}'[Israel holiday schedule]' \
  '--no-modern[skip modern holidays]' \
  '--no-mf[skip minor fasts]' \
  '--no-special[skip special Shabbatot]' \
  '(-o --omer)'{-o,--omer}'[count Omer]' \
  '(-s --sedrot)'{-s,--sedrot}'[sedra on Shabbat]' \
  '(-S --daily-sedra)'{-S,--daily-sedra}'[sedra every day]' \
  '(-b --candle-mins)'{-b,--candle-mins}'=-[minutes before sunset]:min:' \
  '(-m --havdalah-mins)'{-m,--havdalah-mins}'=-[minutes after sunset]:min:' \
  '(-G --havdalah-deg)'{-G,--havdalah-deg}'=-[degrees below horizon]:deg:' \
  '*:[[ month ] day ] year:_default'
