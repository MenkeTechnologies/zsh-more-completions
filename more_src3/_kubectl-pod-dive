#compdef kubectl-pod-dive
# kubectl-pod-dive (krew plugin): dive into a node to inspect running pods
# https://github.com/caiobegotti/pod-dive

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(name)' \
  '1:pod name'
