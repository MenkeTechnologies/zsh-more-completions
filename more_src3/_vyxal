#compdef vyxal
# ============================================================================
# _vyxal — zsh completion for Vyxal, the code-golfing programming language
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/Vyxal/Vyxal
#   Author     : Vyxal team  (Lyxal et al.)
#   License    : MIT
#   Stars      : 303
#   Language   : Scala 3 (interpreter, compiles to JVM / JS / Native)
#   Version    : 3.11.0  (build.sc VyxalModule.vyxalVersion)
#   Binary     : vyxal  (scopt programName("vyxal"))
#   Last push  : 2026-05-19
#
# WHAT IT IS
#   Vyxal is "a code-golfing language experience that has aspects of
#   traditional programming languages as well as features specifically
#   for golfing".  It encodes its program text into a custom 256-entry
#   SBCS (single-byte character set) codepage so that an N-byte
#   Vyxal program counts as N bytes for code-golf scoring regardless
#   of how many UTF-8 code units each glyph takes.  Programs are
#   stack-based, infix-light, with implicit input/output and a rich
#   library of single-character ops drawn from the codepage.  A
#   complementary "literate mode" lets the same program be written
#   in ASCII keywords (the literate lexer transpiles to SBCS).
#
# CLI ARGUMENT GRAMMAR  (verbatim from shared/src/vyxal/CLI.scala
#                       scopt OParser builder + shared/src/vyxal/
#                       Flags.scala dynamic Flag enum)
#   vyxal [OPTIONS] [INPUT...]
#   vyxal debug    [OPTIONS]
#
#   Static options (from CLIConfig):
#     -h, --help                Print help and exit
#         --version             Print version (offline mode only)
#         --file <PATH>         File to read the program from
#         --stdin               Read program input from STDIN as argv
#         --code <CODE>         Code to execute directly
#         --recursions <N>      Recursion limit                 [default: 100]
#         --docs-literate <SYM> Print literate-mode mappings for SYM and exit
#         --lexer               Run the SBCS lexer on input (internal)
#         --literate-lexer      Run the literate lexer (internal)
#         --parser              Run the SBCS parser on input (internal)
#         --literate-parser     Run literate-lexer then parser (internal)
#         --fancy-repl          Run the fancy (color/history) REPL
#     -v, --bytes               Read program as raw bytes (code-golf scoring)
#
#   Dynamic interpreter flags (from Flag enum — long-name only listed
#   here;  short names are mostly Unicode glyphs from the SBCS):
#     -X, --trace                       Full traceback on error
#     -l, --literate                    Enable literate mode
#         --inputs-as-strs              Treat all inputs as strings
#         --limit-output                Limit list output to first 100 items
#     -O, --disable-implicit-output     Disable implicit print of top of stack
#     -o, --force-implicit-output       Force implicit print of top of stack
#         --print-pretty                Pretty-print top of stack on exit
#     -G, --print-max                   Print maximum item of top of stack
#     -g, --print-min                   Print minimum item of top of stack
#         --logical-not                 Logical-negate top of stack on exit
#     -W, --wrap-stack                  Wrap entire stack into one list
#     -R, --register-peek               Don't pop from stack when pushing to
#                                       register
#
#   Subcommand:
#     debug                     Run the Vyxal debugger / step-through REPL
#                               (DebugRepl.start over the code from
#                               --code or --file)
#
#   Positional:
#     <INPUT>...                Inputs to the program (repeatable;
#                               each is parsed as a Vyxal value
#                               unless `--inputs-as-strs` is set)
#
#   Environment variable:
#     VYXAL_LOG_LEVEL           scribe logger level
#                               (trace/debug/info/warn/error/fatal)
#
# LANGUAGE-CORPUS POSITION
#   Vyxal is the 151st programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R873
#   (_lazycelery / lapin 2.5 Rust=126 OPENS Axis 71 AMQP/RabbitMQ
#   Client Library) and continued through R874 (_ari-proxy /
#   rabbitmq/amqp091-go v1.8.1 Go=126) and R875 (_shoveljs / amqplib
#   ^0.10.0 TS-Node=126 CLOSES Axis 71 at 1/1/1 three-language
#   symmetry — triple-126 landmark and 64th axis closed).  Vyxal
#   joins EYG (R872 150th — round-number language milestone), Roto
#   (R868 149th), Pipefish (R864 148th), Mochi (R860 147th), Oden
#   (R856 146th), Hop (R852 145th), Lustre via Kind 2 (R848 144th),
#   Ravi (R844 143rd), ZetZ (R840 142nd), Granule (R836 141st),
#   Sixten (R832 140th), Imba (R828 139th), Tao (R824 138th), Dada
#   (R820 137th), Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `vyxal` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_vyxal() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help and exit]' \
        '(- *)--version[print Vyxal version (offline mode only)]' \
        '--file=[file to read the program from]:program file:_files' \
        '--stdin[read program input from STDIN as argv]' \
        '--code=[Vyxal code to execute directly]:code:' \
        '--recursions=[recursion limit (default 100)]:limit:' \
        '--docs-literate=[print literate-mode mappings for a symbol]:symbol:' \
        '--lexer[run the SBCS lexer on input (internal)]' \
        '--literate-lexer[run the literate lexer (internal)]' \
        '--parser[run the SBCS parser on input (internal)]' \
        '--literate-parser[run literate-lexer then parser (internal)]' \
        '--fancy-repl[run the fancy REPL]' \
        '(-v --bytes)'{-v,--bytes}'[read program as raw bytes (code-golf scoring)]' \
        '(-X --trace)'{-X,--trace}'[full traceback on program error]' \
        '(-l --literate)'{-l,--literate}'[enable literate mode]' \
        '--inputs-as-strs[treat all inputs as strings (no eval)]' \
        '--limit-output[limit list output to first 100 items]' \
        '(-O --disable-implicit-output)'{-O,--disable-implicit-output}'[disable implicit print of top of stack]' \
        '(-o --force-implicit-output)'{-o,--force-implicit-output}'[force implicit print of top of stack]' \
        '--print-pretty[pretty-print top of stack on exit]' \
        '(-G --print-max)'{-G,--print-max}'[print maximum item of top of stack]' \
        '(-g --print-min)'{-g,--print-min}'[print minimum item of top of stack]' \
        '--logical-not[logical-negate top of stack on exit]' \
        '(-W --wrap-stack)'{-W,--wrap-stack}'[wrap entire stack into one list]' \
        '(-R --register-peek)'{-R,--register-peek}'[do not pop from stack when pushing to register]' \
        '1: :_vyxal_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                debug)
                    _arguments \
                        '--file=[program file]:program file:_files' \
                        '--code=[inline code]:code:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                *) ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_vyxal_commands] )) ||
_vyxal_commands() {
    local -a commands
    commands=(
        'debug:run the Vyxal debugger / step-through REPL'
    )
    _describe -t commands 'vyxal command' commands
}

_vyxal "$@"
