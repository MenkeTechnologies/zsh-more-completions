#compdef xcodegen
# Documentation: https://github.com/yonaskolb/XcodeGen
# Reference accessed: 2026-05-21
# Verified: Sources/XcodeGenCLI/Commands/{ProjectCommand,GenerateCommand,CacheCommand,DumpCommand}.swift.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate Xcode project from spec'
  'cache:write the project cache'
  'dump:dump resolved project spec'
  'help:show help for a subcommand'
)

_arguments -C \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xcodegen command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
          '(-s --spec)'{-s,--spec=}'[path to project spec]:file:_files -g "*.(yml|yaml|json)"' \
          '(-r --project-root)'{-r,--project-root=}'[project root directory]:directory:_files -/' \
          '(-n --no-env)'{-n,--no-env}'[disable environment variable expansion]' \
          '(-c --use-cache)'{-c,--use-cache}'[use cache; skip regen if unchanged]' \
          '--cache-path=[path to cache file]:file:_files' \
          '(-p --project)'{-p,--project=}'[output directory for project]:directory:_files -/' \
          '--only-plists[generate only plist files]' && ret=0
        ;;
      (cache)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
          '(-s --spec)'{-s,--spec=}'[path to project spec]:file:_files -g "*.(yml|yaml|json)"' \
          '(-r --project-root)'{-r,--project-root=}'[project root directory]:directory:_files -/' \
          '(-n --no-env)'{-n,--no-env}'[disable environment variable expansion]' \
          '--cache-path=[path to cache file]:file:_files' && ret=0
        ;;
      (dump)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
          '(-s --spec)'{-s,--spec=}'[path to project spec]:file:_files -g "*.(yml|yaml|json)"' \
          '(-r --project-root)'{-r,--project-root=}'[project root directory]:directory:_files -/' \
          '(-n --no-env)'{-n,--no-env}'[disable environment variable expansion]' \
          '(-t --type)'{-t,--type=}'[dump format]:format:(swift-dump json yaml parsed-json parsed-yaml summary)' \
          '(-f --file)'{-f,--file=}'[write output to file (default stdout)]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
