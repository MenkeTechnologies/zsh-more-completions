#compdef lloadd
# Documentation: https://www.openldap.org/software/man.cgi?query=lloadd
# Source: openldap/openldap servers/lloadd/main.c — OpenLDAP LDAP load balancer daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-4[listen on IPv4 only]' \
    '-6[listen on IPv6 only]' \
    '-d+[debug level (bitmask or name; ? lists)]:level:_default' \
    '-f+[config file (default lloadd.conf)]:file:_files' \
    '*-h+[LDAP service URLs to listen on]:urls:_default' \
    '-n+[service name for logging]:name:_default' \
    '-s+[syslog debug level]:level:_default' \
    '-l+[syslog facility]:facility:(LOCAL0 LOCAL1 LOCAL2 LOCAL3 LOCAL4 LOCAL5 LOCAL6 LOCAL7 USER DAEMON)' \
    '*-o+[generic option NAME=VALUE]:opt:_default' \
    '-r+[chroot directory]:dir:_directories' \
    '-u+[run as user]:user:_users' \
    '-g+[run as group]:group:_groups' \
    && ret=0

return ret
