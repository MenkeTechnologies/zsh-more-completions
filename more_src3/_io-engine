#compdef io-engine
# _io-engine — OpenEBS Mayastor I/O engine (Rust+SPDK process serving NVMe-oF replicas; one per worker node)
# upstream: https://github.com/openebs/mayastor
# Flags from io-engine/src/core/env.rs MayastorCliArgs on tip (clap).

_io-engine() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-g --grpc-endpoint)'{-g,--grpc-endpoint}'=[DEPRECATED: IP:port for the gRPC server]:hostport:' \
        '--grpc-ip=[IP address for the gRPC server to listen on]:ip:' \
        '--grpc-port=[port for the gRPC server to listen on]:port:' \
        '-R+[Registration gRPC endpoint]:uri:' \
        '*'{-L,--log-components}'=[enable logging for an SPDK sub-component]:component:' \
        '(-F --log-format)'{-F,--log-format}'=[csv log format flags]:fmt:(default compact json color nocolor date nodate host nohost)' \
        '--log-span-events=[tracing span events]:events:(none new enter exit close active full)' \
        '-m+[reactor mask (hex, e.g. 0x1)]:mask:' \
        '-N+[node name reported to the control plane]:name:' \
        '-s+[max hugepage memory (MiB, 0 = no limit)]:n:' \
        '-u[disable use of PCIe devices]' \
        '-r+[path to create the rpc socket]:socket:_files' \
        '-y+[mayastor config YAML file]:file:_files' \
        '--ptpl-dir=[persistence-through-power-loss base directory]:dir:_files -/' \
        '-P+[pool config file]:file:_files' \
        '--huge-dir=[path to hugedir]:dir:_files -/' \
        '--env-context=[extra arguments for the EAL environment]:args:' \
        '-l+[csv list of cores (overrides --reactor-mask)]:cores:' \
        '-p+[persistent-store endpoint]:host:' \
        '--ps-timeout=[persistent store timeout]:duration:' \
        '--ps-retries=[persistent store operation retries]:n:' \
        '--bdev-pool-size=[bdev I/O context pool size]:n:' \
        '--nvme-ctl-pool-size=[NVMe controller I/O context pool size]:n:' \
        '(-T --tgt-iface)'{-T,--tgt-iface}'=[NVMF target interface (ip/mac/name/subnet)]:iface:' \
        '--tgt-crdt=[NVMF target Command Retry Delay (single or 3 csv ints x100ms)]:crdt:' \
        '--api-versions=[csv of gRPC api versions]:csv:' \
        '(-d --diagnose-stack)'{-d,--diagnose-stack}'=[dump stack trace for target PID]:pid:' \
        '--reactor-freeze-detection[enable reactor freeze detection]' \
        '--reactor-freeze-timeout=[reactor freeze detection timeout (s)]:s:' \
        '--lvm[enable experimental LVM pool backend]'
}

_io-engine "$@"
