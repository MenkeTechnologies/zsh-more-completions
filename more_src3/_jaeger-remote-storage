#compdef jaeger-remote-storage
# _jaeger-remote-storage — Jaeger Remote Storage gRPC server (jaegertracing/jaeger)
# upstream: https://github.com/jaegertracing/jaeger
# Flags from cmd/remote-storage/main.go + cmd/internal/flags/{service,admin,flags}.go on tip.

_jaeger-remote-storage() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-file=[Viper config file (json/toml/yaml/hcl/properties)]:file:_files -g "*.(yml|yaml|json|toml|hcl|properties)(-.)"' \
        '--log-level=[log level]:level:(debug info warn error)' \
        '--log-encoding=[log encoding]:fmt:(json console)' \
        '--admin.http.host-port=[admin/health/metrics bind host\:port]:host\:port:' \
        '--feature-gates=[OTEL feature gates (key=bool,...)]:gates:'
}

_jaeger-remote-storage "$@"
