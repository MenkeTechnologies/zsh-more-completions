#compdef xgamma
# Documentation: xgamma -help
# Source: X.Org xgamma — set/query X display gamma.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-display -d)'{-display,-d}'+[X display]:host\:dpy:' \
    '(-quiet -q)'{-quiet,-q}'[quiet output]' \
    '(-screen -s)'{-screen,-s}'+[screen index]:n:' \
    '(- *)'{-version,-v}'[show version]' \
    '-gamma+[gamma value]:f.f:' \
    '-rgamma+[red gamma value]:f.f:' \
    '-ggamma+[green gamma value]:f.f:' \
    '-bgamma+[blue gamma value]:f.f:' \
    && ret=0

return ret
