#compdef zookeeper_exporter zookeeper-exporter
# _zookeeper_exporter — Prometheus exporter for Apache ZooKeeper (dabealu/zookeeper-exporter)
# upstream: https://github.com/dabealu/zookeeper-exporter
# Flags from main.go (flag).

_zookeeper_exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '-location=[metrics URL path]:path:' \
        '-listen=[HTTP bind address]:addr:' \
        '-timeout=[ZK connect timeout (seconds)]:secs:' \
        '-zk-hosts=[comma-separated ZK servers (host:port)]:hosts:' \
        '-zk-tls-auth[enable ZK TLS client auth]' \
        '-zk-tls-auth-cert=[client cert for ZK TLS]:file:_files -g "*.(pem|crt)"' \
        '-zk-tls-auth-key=[client key for ZK TLS]:file:_files -g "*.(pem|key)"'
}

_zookeeper_exporter "$@"
