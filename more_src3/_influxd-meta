#compdef influxd-meta
# Documentation: https://docs.influxdata.com/enterprise_influxdb/v1/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# influxd-meta: meta node for InfluxDB Enterprise
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-config=[config file]:file:_files' \
  '-pidfile=[pid file]:file:_files' \
  '-cpuprofile=[CPU profile]:file:_files' \
  '-memprofile=[memory profile]:file:_files' \
  '-hostname=[hostname]:host:_hosts' \
  '-bind=[bind addr]:addr:' \
  '-auth-type=[auth type]:type:(none basic jwt)' \
  '-user=[user]:user:_users' \
  '-password=[password]:pass:' \
  '*::influxd-meta args:_files' && ret=0
return ret
