#compdef upcloud-cli upctl
# Documentation: https://github.com/UpCloudLtd/upcloud-cli
# Reference accessed: 2026-05-27
# Verified: upstream internal/commands/base/base.go and internal/core/core.go (UpCloudLtd/upcloud-cli)
# Note: the actual binary published by upcloud-cli is `upctl`; this completion targets both names.

local curcontext="$curcontext" state line ret=1
local -a _upctl_subcommands

_upctl_subcommands=(
  'account:Manage account, users, billing, permissions and tokens'
  'all:Operate on all resources at once'
  'auditlog:Audit log operations'
  'database:Managed database operations'
  'filestorage:Managed file storage operations'
  'gateway:Network gateway operations'
  'host:Private cloud host operations'
  'ip-address:IP address operations'
  'kubernetes:Managed Kubernetes (UKS) operations'
  'loadbalancer:Managed load balancer operations'
  'network:SDN private network operations'
  'network-peering:Network peering operations'
  'object-storage:Managed object storage operations'
  'partner:Partner API operations'
  'router:SDN router operations'
  'server:Cloud server operations'
  'server-group:Server group operations'
  'stack:Deploy and destroy preconfigured application stacks'
  'storage:Block storage operations'
  'zone:UpCloud zone information'
  'version:Display software version information'
)

_arguments -C \
  '--config=[configuration file path]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(human json yaml)' \
  '--force-colours[force coloured output despite detected terminal support]' \
  '--no-colours[disable coloured output]' \
  '--debug[print out more verbose debug logs]' \
  '(-t --client-timeout)'{-t+,--client-timeout=}'[client timeout to use in API calls]:duration:' \
  '(-h --help)'{-h,--help}'[help for upctl]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'upctl subcommand' _upctl_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      server)
        local -a _server_sub
        _server_sub=(
          'list:list cloud servers'
          'show:show server details'
          'create:create a new cloud server'
          'modify:modify a cloud server'
          'start:start a stopped server'
          'stop:stop a running server'
          'restart:restart a running server'
          'load:load a CD-ROM into the server'
          'eject:eject a CD-ROM from the server'
          'delete:delete a server'
          'relocate:relocate a server to another host'
          'plan-list:list available server plans'
          'network-interface:manage server network interfaces'
          'storage:manage server storage attachments'
          'firewall:manage server firewall rules'
        )
        _describe -t commands 'server subcommand' _server_sub && ret=0
        ;;
      storage)
        local -a _storage_sub
        _storage_sub=(
          'list:list storages'
          'create:create a new storage'
          'modify:modify a storage'
          'clone:clone a storage'
          'templatize:create a template from a storage'
          'delete:delete a storage'
          'import:import a storage from URL or file'
          'show:show storage details'
          'backup:manage storage backups'
        )
        _describe -t commands 'storage subcommand' _storage_sub && ret=0
        ;;
      ip-address)
        local -a _ip_sub
        _ip_sub=(
          'list:list IP addresses'
          'show:show IP address details'
          'modify:modify an IP address'
          'assign:assign a new IP address'
          'remove:remove an IP address'
        )
        _describe -t commands 'ip-address subcommand' _ip_sub && ret=0
        ;;
      network)
        local -a _network_sub
        _network_sub=(
          'create:create a new SDN private network'
          'list:list SDN private networks'
          'show:show network details'
          'modify:modify a network'
          'delete:delete a network'
        )
        _describe -t commands 'network subcommand' _network_sub && ret=0
        ;;
      network-peering)
        local -a _np_sub
        _np_sub=(
          'list:list network peerings'
          'delete:delete a network peering'
          'disable:disable a network peering'
        )
        _describe -t commands 'network-peering subcommand' _np_sub && ret=0
        ;;
      router)
        local -a _router_sub
        _router_sub=(
          'create:create a router'
          'list:list routers'
          'show:show router details'
          'modify:modify a router'
          'delete:delete a router'
        )
        _describe -t commands 'router subcommand' _router_sub && ret=0
        ;;
      loadbalancer)
        local -a _lb_sub
        _lb_sub=(
          'list:list managed load balancers'
          'show:show load balancer details'
          'delete:delete a load balancer'
          'plans:list available load balancer plans'
        )
        _describe -t commands 'loadbalancer subcommand' _lb_sub && ret=0
        ;;
      kubernetes)
        local -a _k8s_sub
        _k8s_sub=(
          'create:create a new managed Kubernetes cluster'
          'modify:modify a cluster'
          'config:fetch kubeconfig for a cluster'
          'delete:delete a cluster'
          'list:list clusters'
          'show:show cluster details'
          'versions:list supported Kubernetes versions'
          'plans:list cluster plans'
          'nodegroup:manage node groups'
        )
        _describe -t commands 'kubernetes subcommand' _k8s_sub && ret=0
        ;;
      database)
        local -a _db_sub
        _db_sub=(
          'create:create a managed database'
          'list:list databases'
          'show:show database details'
          'types:list available database types'
          'plans:list database plans'
          'start:start a stopped database'
          'stop:stop a running database'
          'delete:delete a database'
          'metrics:show database metrics'
          'session:manage database sessions'
          'properties:show database type properties'
          'index:manage database indices'
        )
        _describe -t commands 'database subcommand' _db_sub && ret=0
        ;;
      object-storage)
        local -a _os_sub
        _os_sub=(
          'create:create a managed object storage region'
          'delete:delete a managed object storage'
          'list:list managed object storage regions'
          'show:show object storage details'
          'regions:list available object storage regions'
          'user:manage object storage users'
          'access-key:manage object storage access keys'
          'network:manage object storage network attachments'
          'bucket:manage object storage buckets'
          'label:manage object storage labels'
        )
        _describe -t commands 'object-storage subcommand' _os_sub && ret=0
        ;;
      account)
        local -a _acct_sub
        _acct_sub=(
          'login:authenticate and persist credentials'
          'show:show current account information'
          'list:list sub-accounts'
          'delete:delete a sub-account'
          'billing:show billing information'
          'create:create a sub-account'
          'permissions:manage account permissions'
          'token:manage API tokens'
        )
        _describe -t commands 'account subcommand' _acct_sub && ret=0
        ;;
      stack)
        local -a _stack_sub
        _stack_sub=(
          'deploy:deploy a preconfigured application stack'
          'destroy:destroy a preconfigured application stack'
        )
        _describe -t commands 'stack subcommand' _stack_sub && ret=0
        ;;
      all)
        local -a _all_sub
        _all_sub=(
          'list:list all resources'
          'purge:purge all resources'
        )
        _describe -t commands 'all subcommand' _all_sub && ret=0
        ;;
      auditlog)
        local -a _audit_sub
        _audit_sub=(
          'export:export audit log entries'
        )
        _describe -t commands 'auditlog subcommand' _audit_sub && ret=0
        ;;
      filestorage)
        local -a _fs_sub
        _fs_sub=(
          'list:list managed file storages'
          'delete:delete a managed file storage'
        )
        _describe -t commands 'filestorage subcommand' _fs_sub && ret=0
        ;;
      gateway)
        local -a _gw_sub
        _gw_sub=(
          'delete:delete a network gateway'
          'list:list network gateways'
          'plans:list available gateway plans'
        )
        _describe -t commands 'gateway subcommand' _gw_sub && ret=0
        ;;
      host)
        local -a _host_sub
        _host_sub=(
          'list:list private cloud hosts'
        )
        _describe -t commands 'host subcommand' _host_sub && ret=0
        ;;
      partner)
        local -a _partner_sub
        _partner_sub=(
          'account:manage partner sub-accounts'
        )
        _describe -t commands 'partner subcommand' _partner_sub && ret=0
        ;;
      server-group)
        local -a _sg_sub
        _sg_sub=(
          'create:create a server group'
          'delete:delete a server group'
          'list:list server groups'
          'modify:modify a server group'
          'show:show server group details'
        )
        _describe -t commands 'server-group subcommand' _sg_sub && ret=0
        ;;
      zone)
        local -a _zone_sub
        _zone_sub=(
          'list:list available zones'
          'devices:show host devices available in zone'
        )
        _describe -t commands 'zone subcommand' _zone_sub && ret=0
        ;;
      *)
        _arguments '*:argument:' && ret=0
        ;;
    esac
    ;;
esac

return ret
