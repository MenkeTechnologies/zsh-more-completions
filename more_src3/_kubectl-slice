#compdef kubectl-slice
# Documentation: https://github.com/patrickdappollonio/kubectl-slice
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --input-file)'{-f+,--input-file=}'[input YAML file]:file:_files' \
  '(-d --input-folder)'{-d+,--input-folder=}'[input folder of YAML files]:dir:_directories' \
  '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:directory:_directories' \
  '(-t --template)'{-t+,--template=}'[go template for output filename]:template:' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-r --recurse)'{-r,--recurse}'[recurse into subfolders]' \
  '(-q --quiet)'{-q,--quiet}'[suppress stdout/stderr output]' \
  '(-s --skip-non-k8s)'{-s,--skip-non-k8s}'[exclude YAMLs without apiVersion/kind/metadata.name]' \
  '--allow-empty-kinds[allow resources with empty kinds]' \
  '--allow-empty-names[allow resources with empty names]' \
  '--dry-run[do not create files, only print]' \
  '*--exclude=[exclude resources matching pattern]:pattern:' \
  '*--exclude-kind=[exclude by resource kind]:kind:' \
  '*--exclude-name=[exclude by resource name]:name:' \
  '*--include=[include resources matching pattern]:pattern:' \
  '*--include-kind=[include by resource kind]:kind:' \
  '*--include-name=[include by resource name]:name:' \
  '--include-triple-dash[include YAML separators in output]' \
  '--prune[remove output directory before writing]' \
  '--sort-by-kind[sort resources by kind]' \
  '--stdout[output to stdout instead of files]' \
  '--extensions=[file extensions to process]:exts:' && ret=0

return ret
