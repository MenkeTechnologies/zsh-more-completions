#compdef tux
# Documentation: https://github.com/EdenEast/tuxmux
# Reference accessed: 2026-05-21
# Verified: upstream src/cmd subcommands (attach, completion, jump, kill, list, wcmd).
# Generated via `tux completion zsh` from clap/Rust crate.

autoload -U is-at-least

_tux() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'--default-config[Dump the default configuration file to stdout]' \
'--edit[Open \$EDITOR for global config file]' \
'--local[Open \$EDITOR for local config file]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tux_commands" \
"*::: :->tux" \
&& ret=0
    case $state in
    (tux)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tux-command-$line[1]:"
        case $line[1] in
            (attach)
_arguments "${_arguments_options[@]}" \
'-p+[Exact path to either attach to existing session or create a new one if none exist]:PATH:_files' \
'--path=[Exact path to either attach to existing session or create a new one if none exist]:PATH:_files' \
'-e[Attach to existing session]' \
'--exists[Attach to existing session]' \
'-d[Use the remote'\''s default branch when multiple worktrees are detected]' \
'--default[Use the remote'\''s default branch when multiple worktrees are detected]' \
'-h[Print help]' \
'--help[Print help]' \
'*::query -- Query to search from. If there is only one result that result will be automatically selected. If there are multiple results then a search field will be presented:' \
&& ret=0
;;
(completion)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
':generator -- Type of shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(jump)
_arguments "${_arguments_options[@]}" \
'-i+[Jump to index in jump list. Index is 1 based]:INDEX: ' \
'--index=[Jump to index in jump list. Index is 1 based]:INDEX: ' \
'-p+[Add path to jump list]:PATH:_files' \
'--path=[Add path to jump list]:PATH:_files' \
'-e[Open jump list file in "\$EDITOR"]' \
'--edit[Open jump list file in "\$EDITOR"]' \
'-l[List jump list]' \
'--list[List jump list]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
&& ret=0
;;
(kill)
_arguments "${_arguments_options[@]}" \
'-a[Kill all sessions]' \
'--all[Kill all sessions]' \
'-x[Use exact match search instead of fuzzy]' \
'--exact[Use exact match search instead of fuzzy]' \
'-h[Print help]' \
'--help[Print help]' \
'*::query -- Query to search from. If there is only one result that result will be automatically selected. If there are multiple results then a search field will be presented:' \
&& ret=0
;;
(list)
_arguments "${_arguments_options[@]}" \
'-a[List all possible session that could be created]' \
'--all[List all possible session that could be created]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(wcmd)
_arguments "${_arguments_options[@]}" \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':window -- Name of the window to execute the command from:' \
'*::cmds -- The command to be executed in the tmux window:' \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_tux_commands] )) ||
_tux_commands() {
    local commands; commands=(
'attach:Create or attach to a tmux session based on the path specified' \
'a:Create or attach to a tmux session based on the path specified' \
'completion:Genreate tm shell completions for your shell to stdout' \
'jump:Store paths and later jump to them by index' \
'j:Store paths and later jump to them by index' \
'kill:Kill a running tmux session' \
'k:Kill a running tmux session' \
'list:List tmux sessions' \
'ls:List tmux sessions' \
'wcmd:Send a command to a execute in a tmux window' \
'w:Send a command to a execute in a tmux window' \
    )
    _describe -t commands 'tux commands' commands "$@"
}
(( $+functions[_tux-attach_commands] )) ||
_tux-attach_commands() {
    local commands; commands=()
    _describe -t commands 'tux-attach commands' commands "$@"
}
(( $+functions[_tux-completion_commands] )) ||
_tux-completion_commands() {
    local commands; commands=()
    _describe -t commands 'tux-completion commands' commands "$@"
}
(( $+functions[_tux-jump_commands] )) ||
_tux-jump_commands() {
    local commands; commands=()
    _describe -t commands 'tux-jump commands' commands "$@"
}
(( $+functions[_tux-kill_commands] )) ||
_tux-kill_commands() {
    local commands; commands=()
    _describe -t commands 'tux-kill commands' commands "$@"
}
(( $+functions[_tux-list_commands] )) ||
_tux-list_commands() {
    local commands; commands=()
    _describe -t commands 'tux-list commands' commands "$@"
}
(( $+functions[_tux-wcmd_commands] )) ||
_tux-wcmd_commands() {
    local commands; commands=()
    _describe -t commands 'tux-wcmd commands' commands "$@"
}

if [ "$funcstack[1]" = "_tux" ]; then
    _tux "$@"
else
    compdef _tux tux
fi
