#compdef lvm
# _lvm — LVM2 Logical Volume Manager top-level CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_lvm() {
    local -a sub=(
        'devtypes:list known device types'
        'dumpconfig:dump LVM config'
        'formats:list supported formats'
        'fullreport:full LVM report'
        'help:show help'
        'lastlog:show last command log'
        'lvchange:change attributes of a LV'
        'lvconvert:convert LV'
        'lvcreate:create LV'
        'lvdisplay:display LV info'
        'lvextend:extend LV'
        'lvm2-activation-generator:generate systemd units for activation'
        'lvmconfig:report LVM config'
        'lvmdevices:report LVM devices'
        'lvmdiskscan:scan disks'
        'lvmpolld:LVM2 polldaemon (lvm)'
        'lvreduce:reduce LV'
        'lvremove:remove LV'
        'lvrename:rename LV'
        'lvresize:resize LV'
        'lvs:show LVs'
        'lvscan:scan for LVs'
        'pvchange:change attributes of a PV'
        'pvck:check PV consistency'
        'pvcreate:create PV'
        'pvdisplay:display PV info'
        'pvmove:move PV extents'
        'pvremove:remove PV'
        'pvresize:resize PV'
        'pvs:show PVs'
        'pvscan:scan PVs'
        'reload:reload LVM config'
        'segtypes:show segment types'
        'tags:show tags'
        'vgchange:change VG attributes'
        'vgck:check VG consistency'
        'vgconvert:convert VG metadata format'
        'vgcreate:create VG'
        'vgdisplay:display VG info'
        'vgexport:export VG'
        'vgextend:extend VG'
        'vgimport:import VG'
        'vgimportclone:import cloned VG'
        'vgimportdevices:import devices into VG'
        'vgmerge:merge VGs'
        'vgmknodes:make VG device nodes'
        'vgreduce:reduce VG'
        'vgremove:remove VG'
        'vgrename:rename VG'
        'vgs:show VGs'
        'vgscan:scan VGs'
        'vgsplit:split VG'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config string]:str:' \
        '--commandprofile=+[command profile]:str:' \
        '--profile=+[profile]:str:' \
        '--metadataprofile=+[metadata profile]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--driverloaded[driver loaded]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '--reportformat=+[report format]:fmt:(basic json json_std)' \
        '--units=+[units]:u:(h H b s k K m M g G t T p P e E)' \
        '--cache=+[cache]:b:(y n)' \
        '--readonly[readonly]' \
        '--yes[yes]' \
        '-y[yes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lvm subcommand' sub ;;
    esac
}

_lvm "$@"
