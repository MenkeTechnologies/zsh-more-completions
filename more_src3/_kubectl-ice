#compdef kubectl-ice
# kubectl-ice (krew plugin): view container info and resources in a Kubernetes cluster
# https://github.com/NimbleArchitect/kubectl-ice

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'cpu:show cpu requests and limits'
      'memory:show memory requests and limits'
      'status:show container statuses'
      'restarts:show restart counts'
      'probes:show liveness and readiness probes'
      'image:show container images'
      'ip:show pod IP addresses'
      'ports:show container ports'
      'volumes:show mounted volumes'
      'capabilities:show security capabilities'
    )
    _describe -t commands 'ice command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
      '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
      '--context=[kubernetes context]:context' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
      '(-c --container)'{-c+,--container=}'[container name]:container' \
      '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
      '--sort=[sort by column]:column' \
      '--tree[display as tree]' \
      '*:pod name' && ret=0
    ;;
esac

return ret
