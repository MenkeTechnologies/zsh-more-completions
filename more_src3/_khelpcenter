#compdef khelpcenter
# Documentation: https://apps.kde.org/khelpcenter/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: KDE help viewer (GUI). KAboutData/QCommandLineParser flags only;
# optional argument is a help topic/URL (e.g. help:/konsole).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including Qt/KF]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '*:help topic or URL:' && ret=0
return ret
