#compdef huniq
# Documentation: https://github.com/koraa/huniq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for huniq - filter unique lines (hash-based)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --count)'{-c,--count}'[prefix lines with occurrence count]' \
  '(-0 --null)'{-0,--null}'[use null character as delimiter]' \
  '(-d --delim)'{-d+,--delim=}'[specify custom delimiter for parsing input]:delim:' \
  '-h[show help]' \
  '*:file:_files' && ret=0

return ret
