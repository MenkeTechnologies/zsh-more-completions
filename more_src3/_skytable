#compdef skytable skyd skysh
# Documentation: https://github.com/skytable/skytable
# Reference accessed: 2026-05-21
# Verified: upstream source: server/src/engine/config.rs + cli/src/args.rs
# at https://github.com/skytable/skytable (branch: next).
# Removed fabricated flags --host/--port/--noart/--nosave/--saveduration/
# --maxclients/--maxcon that do not exist in upstream config.rs.

local curcontext="$curcontext" state line ret=1

case $service in
  (skytable|skyd)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '--config=[config file]:config:_files' \
      '--endpoint=[endpoint as protocol@host:port]:endpoint:' \
      '--mode=[run mode]:mode:(dev prod)' \
      '--tlscert=[TLS certificate path]:cert:_files' \
      '--tlskey=[TLS key path]:key:_files' \
      '--tls-passphrase=[TLS private key passphrase file]:file:_files' \
      '--auth-plugin=[auth driver]:plugin:(pwd)' \
      '--auth-root-password=[root password (>=16 chars)]:password:' \
      '--service-window=[service window in seconds]:seconds:' \
      '1:subcommand:(repair compact backup restore)' \
      '*: :_files' && ret=0
    ;;
  (skysh)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '--endpoint=[endpoint as protocol@host:port]:endpoint:' \
      '--tls-cert=[TLS certificate file]:cert:_files' \
      '--user=[username]:user:' \
      '--password=[password]:password:' \
      '(-e --eval)'{-e,--eval=}'[evaluate command and exit]:command:' \
      '*: :_files' && ret=0
    ;;
esac

return ret
