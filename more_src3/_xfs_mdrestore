#compdef xfs_mdrestore
# _xfs_mdrestore — Silicon Graphics xfsprogs xfs_mdrestore CLI for restoring an XFS metadata-only dump created by xfs_metadump back to a target device file allowing offline xfs_db xfs_repair tools to operate on the metadata image (xfs team, C); getopt
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git

_xfs_mdrestore() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-g[show progress]' \
        '-i[increase size if needed]' \
        '*:metadump-file device:_files -g "*.metadump *.md"'
}

_xfs_mdrestore "$@"
