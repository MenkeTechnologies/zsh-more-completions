#compdef sonic-pi sonic-pi-cli
# Documentation: https://github.com/sonic-pi-net/sonic-pi
# Documentation: https://github.com/Widdershin/sonic-pi-cli
# Reference accessed: 2026-05-27
# Verified: upstream Widdershin/sonic-pi-cli bin/sonic_pi (only --help, -h, and stop subcommand);
# sonic-pi GUI launcher accepts no project-specific CLI arguments beyond Qt's defaults.

local curcontext="$curcontext" state line ret=1
local -a _spi_subcommands

_spi_subcommands=(
  'stop:stop all running music'
)

case $service in
  sonic-pi-cli)
    _arguments -C \
      '(-h --help)'{-h,--help}'[display help text]' \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd)
        _alternative \
          'subcommands:subcommand:(($_spi_subcommands))' \
          'code:ruby code:' && ret=0
        ;;
    esac
    ;;
  sonic-pi|*)
    _arguments \
      '(-h --help)'{-h,--help}'[display help]' \
      '*:file:_files -g "*.rb"' && ret=0
    ;;
esac

return ret
