#compdef yurt-iot-dock
# _yurt-iot-dock — OpenYurt EdgeX Foundry device sync controller (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Flags from cmd/yurt-iot-dock/app/options/options.go (pflag).

_yurt-iot-dock() {
    _arguments \
        '--metrics-bind-address=[metrics endpoint bind address]:host\:port:' \
        '--health-probe-bind-address=[probe endpoint bind address]:host\:port:' \
        '--leader-elect[enable leader election]' \
        '--nodepool=[nodePool the device controller runs in]:name:' \
        '--namespace=[cluster namespace for edge resources]:ns:' \
        '--version=[edge resources deployment version]:ver:' \
        '--core-data-address=[edgex core-data service address]:host\:port:' \
        '--core-metadata-address=[edgex core-metadata service address]:host\:port:' \
        '--core-command-address=[edgex core-command service address]:host\:port:'
}

_yurt-iot-dock "$@"
