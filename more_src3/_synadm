#compdef synadm
# Documentation: https://synadm.readthedocs.io/en/latest/
# Reference accessed: 2026-05-21
# Verified: upstream synadm/cli/__init__.py source on GitHub.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:create or modify synadm configuration'
  'user:user commands (deactivate, password, list, etc.)'
  'room:room commands (list, details, delete, members)'
  'media:media commands (list, quarantine, purge)'
  'history:history retention commands'
  'group:group/community commands'
  'matrix:raw Matrix client-server API access'
  'regtok:registration token commands'
  'notice:server notice commands'
  'raw:raw Admin API request'
  'version:show synadm version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(--debug)--debug[enable debug logging]' \
  '(--verbose -v)'{-v,--verbose}'[verbose logging]' \
  '(--no-confirm)--no-confirm[skip interactive confirmations]' \
  '(--output -o)'{-o+,--output=}'[output format]:format:(human json yaml minified pprint)' \
  '(--config -c)'{-c+,--config-file=}'[config file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'synadm command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (user)
        local -a user_subs=(
          'list:list users'
          'details:show user details'
          'modify:create or modify a user'
          'password:reset a user password'
          'membership:list rooms a user is in'
          'deactivate:deactivate a user'
          'deactivate-regex:bulk deactivate users matching a regex'
          'media:list media uploaded by user'
          'whois:lookup user devices/sessions'
          'login:issue a login token for a user'
          'auth-provider:lookup users by external auth provider ID'
          '3pid:lookup users by third-party identifier'
          'shadow-ban:shadow ban a user'
          'prune-devices:prune inactive user devices'
          'redact:redact a user (admin redact-all events)'
          'redact-status:get redact status'
        )
        _describe -t usub 'user subcommand' user_subs && ret=0 ;;
      (room)
        local -a room_subs=(
          'list:list rooms'
          'details:show room details'
          'members:list room members'
          'state:show room state events'
          'delete:delete a room'
          'block:block a room'
          'unblock:unblock a room'
          'make-admin:promote a user to admin in a room'
          'join:add a user to a room'
          'media:list media in a room'
          'search:search rooms'
        )
        _describe -t rsub 'room subcommand' room_subs && ret=0 ;;
      (media)
        local -a media_subs=(
          'list:list media'
          'quarantine:quarantine a media item'
          'unquarantine:remove quarantine'
          'protect:protect from purge'
          'unprotect:remove protection'
          'purge:purge old media'
          'delete:delete media'
        )
        _describe -t msub 'media subcommand' media_subs && ret=0 ;;
      (regtok)
        local -a rt_subs=(
          'list:list registration tokens'
          'details:show token details'
          'new:create a new token'
          'update:update a token'
          'delete:delete a token'
        )
        _describe -t rtsub 'regtok subcommand' rt_subs && ret=0 ;;
      (history)
        _arguments \
          '*::sub:(list set get delete)' && ret=0 ;;
      (group)
        _arguments \
          '*::sub:(delete)' && ret=0 ;;
      (matrix)
        _arguments \
          '*::sub:(raw login)' && ret=0 ;;
      (notice)
        _arguments \
          '*::sub:(send)' && ret=0 ;;
      (config)
        _arguments \
          '*::config_action:' && ret=0 ;;
      (raw)
        _arguments \
          '(--method -m)'{-m+,--method=}'[HTTP method]:method:(GET POST PUT DELETE)' \
          '*::path_and_body:' && ret=0 ;;
    esac ;;
esac

return ret
