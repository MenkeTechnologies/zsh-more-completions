#compdef inndf
# Documentation: man inndf(8)
# Source: InterNetNews/inn backends/inndf.c — show news disk free / overview usage (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-i[print inode usage]' \
    '-n[print overview article count]' \
    '-o[print overview database disk usage]' \
    '(-F)-f+[file listing filesystems to check]:file:_files' \
    '(-f)-F[use innfeed filesystems list]' \
    '*:directory:_files -/' \
    && ret=0

return ret
