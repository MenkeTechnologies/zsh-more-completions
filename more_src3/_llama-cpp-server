#compdef llama-cpp-server llama-server
# Documentation: https://github.com/ggml-org/llama.cpp/tree/master/tools/server
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# llama.cpp HTTP API server (llama-server)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-m[model file]:file:_files -g "*.gguf"' \
  '--model=[model file]:file:_files -g "*.gguf"' \
  '-a[model alias]:alias:' \
  '--alias=[model alias]:alias:' \
  '-c[ctx size]:n:' \
  '--ctx-size=[ctx size]:n:' \
  '--host=[host]:host:' \
  '--port=[port]:port:' \
  '--api-key=[API key]:key:' \
  '--api-key-file=[API key file]:file:_files' \
  '--ssl-key-file=[SSL key file]:file:_files' \
  '--ssl-cert-file=[SSL cert file]:file:_files' \
  '--threads=[CPU threads]:n:' \
  '-t[CPU threads]:n:' \
  '--threads-batch=[batch threads]:n:' \
  '-tb[batch threads]:n:' \
  '-ngl[GPU layers]:n:' \
  '--n-gpu-layers=[GPU layers]:n:' \
  '--main-gpu=[main GPU]:n:' \
  '--mlock[lock model in memory]' \
  '--no-mmap[disable mmap]' \
  '--mirostat=[mirostat sampling]:mode:(0 1 2)' \
  '--temp=[temperature]:f:' \
  '--top-k=[top-k]:n:' \
  '--top-p=[top-p]:f:' \
  '--min-p=[min-p]:f:' \
  '--repeat-penalty=[repeat penalty]:f:' \
  '--repeat-last-n=[repeat-last-n]:n:' \
  '--batch-size=[batch size]:n:' \
  '-b[batch size]:n:' \
  '--parallel=[parallel slots]:n:' \
  '-np[parallel slots]:n:' \
  '--chat-template=[chat template]:template:' \
  '--system-prompt-file=[system prompt file]:file:_files' \
  '--log-disable[disable logging]' \
  '--cont-batching[enable continuous batching]' \
  '--metrics[expose Prometheus metrics]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '*::llama-cpp-server args:_files' && ret=0
return ret
