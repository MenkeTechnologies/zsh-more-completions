#compdef ufw
# Documentation: man 8 ufw (Ubuntu jammy manpage)
# Reference accessed: 2026-05-29
# UFW — Uncomplicated Firewall, frontend for iptables.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'enable:reload firewall and enable on boot'
  'disable:unload firewall and disable on boot'
  'reload:reload firewall configuration'
  'reset:disable and restore firewall to defaults'
  'status:display firewall status and managed rules'
  'show:show information about the running firewall'
  'allow:create an allow rule'
  'deny:create a deny rule'
  'reject:create a reject rule that notifies the sender'
  'limit:add a rate-limit rule'
  'delete:remove a rule by number or specification'
  'insert:insert a rule at a specified position'
  'prepend:add a rule before all others of its IP type'
  'route:manage rules for routed traffic'
  'default:set default policy for incoming/outgoing/routed'
  'logging:toggle logging or set log level'
  'app:application-profile commands (list/info/update/default)'
  'version:show ufw version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --dry-run)'{-n,--dry-run}'[do not modify the firewall; print what would be done]' \
  '--force[skip confirmation prompts]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'ufw subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      allow|deny|reject|limit)
        _arguments \
          '--in[apply only to incoming traffic]' \
          '--out[apply only to outgoing traffic]' \
          '--on=[interface name]:iface:_net_interfaces' \
          '--log[log new connections matching this rule]' \
          '--log-all[log all packets matching this rule]' \
          '--comment=[free-form annotation]:comment:' \
          '*:port/proto or from/to/app spec:' && ret=0
        ;;
      delete)
        _arguments \
          '*:rule number or full rule spec:' && ret=0
        ;;
      insert)
        _arguments \
          ':position (1-based):' \
          '*:rule spec:' && ret=0
        ;;
      default)
        _arguments \
          ':policy:(allow deny reject)' \
          ':direction:(incoming outgoing routed)' && ret=0
        ;;
      logging)
        _arguments \
          ':state:(on off low medium high full)' && ret=0
        ;;
      status)
        _arguments \
          ':verbosity:(numbered verbose)' && ret=0
        ;;
      show)
        _arguments \
          ':report:(raw builtins before-rules user-rules after-rules logging-rules listening added)' && ret=0
        ;;
      app)
        _arguments \
          '1:app subcommand:(list info update default)' \
          '*:profile name:' && ret=0
        ;;
      route)
        _arguments \
          '1:action:(allow deny reject limit delete insert)' \
          '*:rule spec:' && ret=0
        ;;
    esac
    ;;
esac

return ret
