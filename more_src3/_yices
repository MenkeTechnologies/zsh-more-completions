#compdef yices yices_smt yices_smt2 yices-cli
# _yices — SRI International yices CLI Yices 2 SMT satisfiability modulo theories solver supporting linear arithmetic non-linear-arithmetic bit-vectors arrays uninterpreted-functions SMT-LIB v1 v2 standard reading queries producing sat unsat unknown verdicts model-export-for-CDCL-SAT decision-procedure backend (SRI team, C); getopt
# upstream: https://yices.csl.sri.com/

_yices() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose]:l:(0 1 2 3 4 5)' \
        '--verbose=+[level]:l:(0 1 2 3 4 5)' \
        '--silent[silent]' \
        '--stats[show statistics]' \
        '--timeout=+[sec]:n:' \
        '--mode=+[m]:m:(one-shot multi-checks push-pop interactive)' \
        '--logic=+[l]:l:(NONE AUFLIA AUFLIRA AUFNIRA LIA LRA NIA NRA QF_ABV QF_AUFBV QF_AUFLIA QF_AX QF_BV QF_IDL QF_LIA QF_LRA QF_NIA QF_NRA QF_RDL QF_UF QF_UFBV QF_UFIDL QF_UFLIA QF_UFLRA QF_UFNIA QF_UFNRA UFLRA UFNIA)' \
        '--arith-solver=+[s]:s:(simplex floyd-warshall ifw-mcsat auto)' \
        '--mcsat[use MCSAT]' \
        '--no-print-success[no print success]' \
        '--print-success[print success]' \
        '--produce-models[produce models]' \
        '--produce-unsat-cores[produce unsat cores]' \
        '--produce-proofs[produce proofs]' \
        '--smt2-input[SMT-LIB 2 input]' \
        '--smt-input[SMT-LIB 1 input]' \
        '--ys-input[Yices native input]' \
        '*:smt file:_files -g "*.smt *.smt2 *.ys *.tptp"'
}

_yices "$@"
