#compdef samhain
# Documentation: https://manpages.debian.org/bookworm/samhain/samhain.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-c,--copyright}'[show copyright]' \
  '-t+[checksum test]:test:(init update check)' \
  '--set-checksum-test=[checksum test]:test:(init update check)' \
  '--init2stdout[on init, send db to stdout]' \
  '-r+[recursion depth]:depth:' \
  '--recursion=[recursion depth]:depth:' \
  '(-D --daemon)'{-D,--daemon}'[run as daemon]' \
  '--foreground[run in foreground]' \
  '--forever[loop instead of exiting]' \
  '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
  '--listfile=[path to list file]:file:_files' \
  '--verify-database=[verify against database]:database:_files' \
  '--create-database=[create database from file list]:file-list:_files' \
  '(-a --full-detail)'{-a,--full-detail}'[full detail when listing database]' \
  '--delimited[delimited (CSV-style) database listing]' \
  '--binary[binary database listing]' \
  '--list-filter=[filter list output by file]:file:_files' \
  '-d+[list database entries]:database:_files' \
  '--list-database=[list database entries]:database:_files' \
  '--list-file=[list a single file from database]:file:_files' \
  '(-j --just-list)'{-j,--just-list}'[list logfile without verification]' \
  '-L+[verify signed logfile]:logfile:_files' \
  '--verify-log=[verify signed logfile]:logfile:_files' \
  '-M+[verify email reports]:mailbox:_files' \
  '--verify-mail=[verify email reports]:mailbox:_files' \
  '-H+[compute TIGER192 hash of string]:string:' \
  '--hash-string=[compute TIGER192 hash of string]:string:' \
  '-V+[add key to signed executable]:key@path:' \
  '--add-key=[add key to signed executable]:key@path:' \
  '-s+[syslog severity threshold]:threshold:' \
  '--set-syslog-severity=[syslog severity threshold]:threshold:' \
  '-l+[log file severity threshold]:threshold:' \
  '--set-log-severity=[log file severity threshold]:threshold:' \
  '-m+[mail severity threshold]:threshold:' \
  '--set-mail-severity=[mail severity threshold]:threshold:' \
  '-e+[export severity threshold]:threshold:' \
  '--set-export-severity=[export severity threshold]:threshold:' \
  '-x+[external command severity threshold]:threshold:' \
  '--set-external-severity=[external command severity threshold]:threshold:' \
  '-p+[print severity threshold]:threshold:' \
  '--set-print-severity=[print severity threshold]:threshold:' \
  '--set-prelude-severity=[prelude severity threshold]:threshold:' \
  '--set-database-severity=[database severity threshold]:threshold:' \
  '--enable-trace[enable trace]' \
  '--trace-logfile=[trace log file]:file:_files' \
  '--server-port=[server port number]:port:' \
  '-q[qualified mode (server)]' \
  '--qualified[qualified mode (server)]' \
  '--chroot=[chroot directory (server)]:dir:_directories' \
  '(-G --gen-password)'{-G,--gen-password}'[generate random password (server)]' \
  '-P+[set password (server)]:password:' \
  '--password=[set password (server)]:password:' && ret=0

return ret
