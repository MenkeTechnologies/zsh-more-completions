#compdef loksh
# Documentation: https://man.openbsd.org/ksh.1
# Reference accessed: 2026-05-19
# Verified: OpenBSD ksh(1) (loksh is a Linux port of OpenBSD ksh).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[execute command]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-r[restricted shell]' \
  '-s[read from stdin]' \
  '-o+[set option]:option:(allexport braceexpand bgnice csh-history emacs errexit gmacs ignoreeof interactive-comments login markdirs monitor noclobber noexec noglob nohup nolog notify nounset physical pipefail posix privileged sh trackall verbose vi xtrace)' \
  '+o+[unset option]:option:' \
  '-A+[assign to array]:array name:' \
  '-a[export all variables]' \
  '-b[report background job status immediately]' \
  '-e[exit on error]' \
  '-f[disable globbing]' \
  '-h[hash commands on definition]' \
  '-m[enable job control]' \
  '-n[read commands without executing]' \
  '-p[privileged mode]' \
  '-u[error on unset variables]' \
  '-v[print input lines as read]' \
  '-x[print commands before execution]' \
  '*:script:_files' && ret=0

return ret
