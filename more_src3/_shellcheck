#compdef shellcheck
# Documentation: shellcheck --help
# Source: koalaman/shellcheck — static analysis for shell scripts.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --check-sourced)'{-a,--check-sourced}'[include warnings from sourced files]' \
    '(-C --color)'{-C,--color=-}'[use color]::when:(auto always never)' \
    '*'{-i,--include=}'[consider only these warning types]:codes:' \
    '*'{-e,--exclude=}'[exclude these warning types]:codes:' \
    '--extended-analysis=[perform dataflow analysis]:bool:(true false)' \
    '(-f --format)'{-f,--format=}'[output format]:format:(checkstyle diff gcc json json1 quiet tty)' \
    '(- *)--list-optional[list checks disabled by default]' \
    '--norc[do not look for .shellcheckrc files]' \
    '--rcfile=[prefer this configuration file]:file:_files' \
    '*'{-o,--enable=}'[optional checks to enable]:checks:' \
    '(-P --source-path)*'{-P,--source-path=}'[path when looking for sourced files]:paths:_files -/' \
    '(-s --shell)'{-s,--shell=}'[dialect]:shell:(sh bash dash ksh busybox)' \
    '(-S --severity)'{-S,--severity=}'[minimum severity]:severity:(error warning info style)' \
    '(- *)'{-V,--version}'[print version]' \
    '(-W --wiki-link-count)'{-W,--wiki-link-count=}'[wiki links to show]:n:' \
    '(-x --external-sources)'{-x,--external-sources}'[allow source outside of FILES]' \
    '(- *)--help[show help]' \
    '*:shell script:_files -g "*.{sh,bash,zsh,ksh,dash,bats}"' \
    && ret=0

return ret
