#compdef xosview xosview2
# Documentation: https://manpages.debian.org/bookworm/xosview/xosview.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[show version]' \
  '-name+[X resource name]:name:' \
  '-display+[X display]:display:' \
  '-font+[font]:font:' \
  '-title+[window title]:title:' \
  '-geometry+[geometry WxH+X+Y]:geom:' \
  '-network+[set max bandwidth]:bandwidth:' \
  '-networkBW+[set max bandwidth]:bandwidth:' \
  '-networkBandwidth+[set max bandwidth]:bandwidth:' \
  '-pagespeed+[page speed value]:val:' \
  '-xrm+[X resource string]:resource:' \
  '(+captions)-captions[enable captions]' \
  '(-captions)+captions[disable captions]' \
  '(+labels)-labels[enable labels]' \
  '(-labels)+labels[disable labels]' \
  '(+usedlabels)-usedlabels[enable used labels]' \
  '(-usedlabels)+usedlabels[disable used labels]' \
  '(+cpu)-cpu[enable cpu meter]' \
  '(-cpu)+cpu[disable cpu meter]' \
  '(+cpus)-cpus[enable per-cpu meters]' \
  '(-cpus)+cpus[disable per-cpu meters]' \
  '(+load)-load[enable load meter]' \
  '(-load)+load[disable load meter]' \
  '(+mem)-mem[enable memory meter]' \
  '(-mem)+mem[disable memory meter]' \
  '(+swap)-swap[enable swap meter]' \
  '(-swap)+swap[disable swap meter]' \
  '(+battery)-battery[enable battery meter]' \
  '(-battery)+battery[disable battery meter]' \
  '(+gfx)-gfx[enable graphics meter]' \
  '(-gfx)+gfx[disable graphics meter]' \
  '(+wireless)-wireless[enable wireless meter]' \
  '(-wireless)+wireless[disable wireless meter]' \
  '(+net)-net[enable net meter]' \
  '(-net)+net[disable net meter]' \
  '(+page)-page[enable page meter]' \
  '(-page)+page[disable page meter]' \
  '(+disk)-disk[enable disk meter]' \
  '(-disk)+disk[disable disk meter]' \
  '(+int)-int[enable interrupt meter]' \
  '(-int)+int[disable interrupt meter]' \
  '(+irqrate)-irqrate[enable irq rate meter]' \
  '(-irqrate)+irqrate[disable irq rate meter]' \
  '(+lmstemp)-lmstemp[enable lm sensors temp meter]' \
  '(-lmstemp)+lmstemp[disable lm sensors temp meter]' \
  '(+coretemp)-coretemp[enable core temp meter]' \
  '(-coretemp)+coretemp[disable core temp meter]' \
  '(+acpitemp)-acpitemp[enable ACPI temp meter]' \
  '(-acpitemp)+acpitemp[disable ACPI temp meter]' \
  '(+bsdsensor)-bsdsensor[enable BSD sensor meter]' \
  '(-bsdsensor)+bsdsensor[disable BSD sensor meter]' && ret=0

return ret
