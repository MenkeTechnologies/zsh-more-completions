#compdef vlock
# _vlock — kbd vlock (lock the current Linux console or all VTs until the owner's password unlocks; -a locks all VTs (preventing VT switch), -c locks the current only, -h shows help, -n disables newvt allocation; uses PAM by default)
# upstream: https://github.com/jmtd/vlock
# Flags from vlock-main vlock-main.c on tip.

_vlock() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-a[lock all VTs]' \
        '--all[lock all VTs]' \
        '-c[lock current VT only]' \
        '--current[lock current VT only]' \
        '-n[disable newvt allocation]' \
        '--new[switch to new VT and lock]' \
        '-s[disable SysRq]' \
        '--disable-sysrq[disable SysRq]' \
        '-t+[timeout seconds]:seconds:' \
        '--timeout+[timeout seconds]:seconds:'
}

_vlock "$@"
