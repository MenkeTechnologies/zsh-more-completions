#compdef kbookmarkmerger
# Documentation: https://manpages.debian.org/testing/keditbookmarks/kbookmarkmerger.1.en.html
# Reference accessed: 2026-05-19
# Verified: Debian kbookmarkmerger(1). The man page documents only
# one argument (a directory to scan for bookmark files); no option
# table. STUB: reduced to the documented directory argument plus
# KDE/Qt standard --help/--version. Removed invented Qt flag enums
# (--graphicssystem, --reverse, etc.) and the wrong *.xbel glob.

# kbookmarkmerger: merge bookmark files found in a directory
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show Qt-specific options as well]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '1:directory to scan for bookmark files:_directories' && ret=0
return ret
