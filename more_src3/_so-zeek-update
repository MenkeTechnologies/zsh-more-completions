#compdef so-zeek-update
# _so-zeek-update — Security Onion so-zeek-update CLI for updating Zeek script packages via zeek-pkg refreshing intel feeds reloading running cluster and verifying configuration after each upgrade (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-zeek-update() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-p+[package]:str:' \
        '--package=+[package]:str:' \
        '-f[force]' \
        '--force[force]' \
        '--no-reload[no reload]' \
        '--no-restart[no restart]' \
        '--no-check[no check]' \
        '--dry-run[dry run]' \
        '--check-only[check only]' \
        '--upgrade-all[upgrade all]' \
        '--pin-package=+[package=version]:str:'
}

_so-zeek-update "$@"
