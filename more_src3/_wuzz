#compdef wuzz
# Documentation: https://github.com/asciimoo/wuzz/blob/master/wuzz.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (ParseArgs in wuzz.go).
# Flags from ParseArgs switch statement:
#   -H/--header, -d/--data/--data-binary/--data-urlencode, -j/--json,
#   -X/--request (HTTP method), -t/--timeout (ms),
#   --compressed, -e/--editor, -k/--insecure, -R/--disable-redirects,
#   --tlsv1.0, --tlsv1.1, --tlsv1.2, -1/--tlsv1, -T/--tls (MIN,MAX),
#   -x/--proxy, -F/--form, -f/--file.
# Removed from prior file: -u/--url (URL is positional), -c/--cookie
# (no such flag; --config is in README, not in wuzz.go ParseArgs;
# README also says --config from external location), --help/--version
# (not in ParseArgs - wuzz only consumes recognised args).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*'{-H+,--header=}'[HTTP header in key:value format]:header:' \
  '(-d --data --data-binary --data-urlencode)'{-d+,--data=,--data-binary=,--data-urlencode=}'[POST/PUT/PATCH body data]:data:' \
  '(-j --json)'{-j+,--json=}'[JSON body data]:json:' \
  '(-X --request)'{-X+,--request=}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '(-t --timeout)'{-t+,--timeout=}'[request timeout in milliseconds]:ms:' \
  '--compressed[add Accept-Encoding: gzip, deflate]' \
  '(-e --editor)'{-e+,--editor=}'[external editor]:editor:_command_names -e' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification]' \
  '(-R --disable-redirects)'{-R,--disable-redirects}'[do not follow redirects]' \
  '--tlsv1.0[force TLS 1.0]' \
  '--tlsv1.1[force TLS 1.1]' \
  '--tlsv1.2[force TLS 1.2]' \
  '(-1 --tlsv1)'{-1,--tlsv1}'[allow TLS 1.0-1.2]' \
  '(-T --tls)'{-T+,--tls=}'[TLS version range MIN,MAX]:range:' \
  '(-x --proxy)'{-x+,--proxy=}'[HTTP/SOCKS5 proxy URL]:url:' \
  '(-F --form)'{-F+,--form=}'[multipart form data]:form:' \
  '(-f --file)'{-f+,--file=}'[load request from file]:file:_files' \
  '*::url:_urls' && ret=0

return ret
