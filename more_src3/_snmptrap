#compdef snmptrap snmpinform
# _snmptrap — net-snmp snmptrap / snmpinform (send unsolicited SNMP v1/v2c TRAP or v2c INFORM messages; -v 1|2c|3 version, -c community, -e engine id (v3), -E context engine id, -u user, -l security level; positional: agent ENTERPRISE-OID generic-trap specific-trap uptime [OID type value ...])
# upstream: https://www.net-snmp.org/
# Flags from net-snmp apps/snmptrap.c on tip.

_snmptrap() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v+[version]:version:(1 2c 3)' \
        '-c+[community]:community:' \
        '-e+[engine id]:engineid:' \
        '-E+[context engine id]:engineid:' \
        '-u+[v3 user]:user:_users' \
        '-l+[v3 security level]:level:(noAuthNoPriv authNoPriv authPriv)' \
        '-a+[auth alg]:alg:(MD5 SHA SHA-224 SHA-256 SHA-384 SHA-512)' \
        '-A+[auth password]:password:' \
        '-x+[priv alg]:alg:(DES AES AES-192 AES-256)' \
        '-X+[priv password]:password:' \
        '-m+[MIBs]:mibs:' \
        '-M+[MIB dirs]:dir:_files -/' \
        '1:agent:_hosts' \
        '*:trap arguments:'
}

_snmptrap "$@"
