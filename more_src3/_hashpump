#compdef hashpump
# _hashpump — Brian Wallace HashPump exploits hash length extension attack on MD5 SHA1 SHA-256 SHA-512 (bwall team, C++); custom argparse
# upstream: https://github.com/bwall/HashPump

_hashpump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-s+[original signature hash hex]:str:' \
        '--signature=+[original signature hash hex]:str:' \
        '-d+[original data]:str:' \
        '--data=+[original data]:str:' \
        '-a+[data to append]:str:' \
        '--additional=+[data to append]:str:' \
        '-k+[key length bytes]:n:' \
        '--keylength=+[key length bytes]:n:' \
        '-t[test mode]' \
        '--test[test mode]'
}

_hashpump "$@"
