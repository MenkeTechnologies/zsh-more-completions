#compdef i7z
# _i7z — Abhishek Jaiantilal i7z Intel Core i3 i5 i7 CPU monitoring ncurses tool for cores frequency cstate (ajaiantilal team, C); custom argparse
# upstream: https://github.com/ajaiantilal/i7z

_i7z() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-w+[mode]:m:(s l)' \
        '--write=+[mode]:m:(s l)' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-c[no color]' \
        '--nocolor[no color]' \
        '-r[print to stdout]' \
        '--no-tui[print to stdout]' \
        '-t+[sleep ms]:n:' \
        '--sleep=+[sleep ms]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[delay]:n:' \
        '--delay=+[delay]:n:' \
        '-n[no socket info]' \
        '--nosocket[no socket info]' \
        '--ignore-cpuid-check[ignore cpuid check]' \
        '--no-cpu-check[no cpu check]' \
        '--socket=+[socket]:n:' \
        '--presilent[silent presscan]'
}

_i7z "$@"
