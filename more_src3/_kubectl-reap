#compdef kubectl-reap
# kubectl-reap (krew plugin): delete unused Kubernetes resources
# https://github.com/micnncim/kubectl-reap

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[check all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--dry-run[show what would be deleted]' \
  '--force[skip confirmation prompt]' \
  '--interactive[interactive mode]' \
  '1:resource type:(configmap secret serviceaccount role rolebinding pvc)'
