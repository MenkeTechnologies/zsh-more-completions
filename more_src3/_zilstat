#compdef zilstat
# _zilstat — OpenZFS zilstat (periodic snapshot of ZFS Intent Log behaviour: itx counts, bytes, latencies, transaction commits per second; positional INTERVAL [COUNT] runs continuously; -p parsable, -t time stamp, -v breakdown by pool)
# upstream: https://github.com/openzfs/zfs (cmd/zilstat)
# Flags from openzfs cmd/zilstat on tip.

_zilstat() {
    _arguments \
        '-h[show help]' \
        '-p[parsable output]' \
        '-t[timestamps]' \
        '-v[per-pool breakdown]' \
        '-l+[lines per header]:lines:' \
        '*:interval [count]:'
}

_zilstat "$@"
