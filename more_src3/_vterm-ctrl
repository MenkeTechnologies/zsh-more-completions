#compdef vterm-ctrl
# Documentation: libvterm-0.3.3/bin/vterm-ctrl.c (leonerd libvterm)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# subcommands set-window-title, cursor-shape, find-file, message,
# colorize (these are from emacs-libvterm's vterm_cmd helper, not the
# vterm-ctrl binary from leonerd libvterm).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'reset:reset terminal'
  's8c1t:set 8-bit C1 transmission (off|on)'
  'keypad:keypad mode (app|num)'
  'screen:DECSCNM reverse video (off|on|query)'
  'cursor:DECTCEM cursor visibility (off|on|query)'
  'curblink:DECSCBL cursor blink (off|on|query)'
  'curshape:cursor shape (block|under|bar|query)'
  'mouse:mouse mode (off|click|clickdrag|motion)'
  'reportfocus:focus reporting (off|on|query)'
  'altscreen:alternate screen (off|on|query)'
  'bracketpaste:bracketed paste (off|on|query)'
  'icontitle:set icon and window title (OSC 0)'
  'icon:set icon name (OSC 1)'
  'title:set window title (OSC 2)'
)

_arguments -C \
  '*:: :->command' && ret=0

case $state in
  (command)
    if (( CURRENT == 1 )) || [[ -z $line[1] ]]; then
      _describe -t commands 'vterm-ctrl command' commands && ret=0
    else
      case $words[CURRENT-1] in
        (s8c1t)
          _values 'state' off on && ret=0 ;;
        (keypad)
          _values 'mode' app num && ret=0 ;;
        (screen|cursor|curblink|reportfocus|altscreen|bracketpaste)
          _values 'state' off on query && ret=0 ;;
        (curshape)
          _values 'shape' block under bar query && ret=0 ;;
        (mouse)
          _values 'mode' off click clickdrag motion && ret=0 ;;
        (icontitle|icon|title)
          _message 'title string' && ret=0 ;;
        (*)
          _describe -t commands 'vterm-ctrl command' commands && ret=0 ;;
      esac
    fi
    ;;
esac

return ret
