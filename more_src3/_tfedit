#compdef tfedit
# _tfedit — refactoring tool for Terraform (minamijoyo/tfedit)
# upstream: https://github.com/minamijoyo/tfedit
# Subcommands from cmd/filter.go, cmd/migration.go.

_tfedit() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'filter:apply a built-in filter'
                'migration:generate a migration file for state operations'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                filter)
                    if (( CURRENT == 2 )); then
                        _values 'subcommand' 'awsv4upgrade[upgrade configurations to AWS provider v4]'
                    else
                        _arguments \
                            '(-f --file)'{-f+,--file=}'[input Terraform config file]:file:_files -g "*.tf"' \
                            '(-u --update)'{-u,--update}'[update files in-place]'
                    fi
                    ;;
                migration)
                    if (( CURRENT == 2 )); then
                        _values 'subcommand' 'fromplan[generate from Terraform JSON plan]'
                    else
                        _arguments \
                            '(-f --file)'{-f+,--file=}'[input JSON plan file]:file:_files -g "*.json"' \
                            '(-o --out)'{-o+,--out=}'[output migration file path]:file:_files' \
                            '(-d --dir)'{-d+,--dir=}'[dir attribute for migration file]:dir:_files -/'
                    fi
                    ;;
            esac
            ;;
    esac
}

_tfedit "$@"
