#compdef stencila
# ============================================================================
# stencila - Documents with Scientific Intelligence:
#             executable scientific documents with
#             AI-augmented authoring + Codec format
#             interchange (Rust, Apache-2.0)
#
# Author : Stencila Ltd (Nokome Bentley et al)
# Upstream: https://github.com/stencila/stencila
# crates : stencila-cli (binary: stencila)
#
# `stencila` is a Rust-implemented platform for
# authoring + executing + publishing scientific
# documents. The system treats documents as
# typed-AST `Article` objects with executable code
# blocks ("kernels"), AI-augmented authoring agents
# ("agents" + "skills" + "workflows"), declarative
# format codecs (Markdown / JATS / IPYNB / DOCX /
# PDF / HTML / ...), CRDT-backed collaborative
# editing, and a built-in Cloud sync layer.
#
# Use cases:
#   - Reproducible scientific publishing where the
#     document IS the computation + the AI-authored
#     prose around it
#   - Codec-based format conversion between scientific
#     document formats (Markdown <-> JATS XML <->
#     Jupyter Notebook <-> ...)
#   - Document-server backend for Stencila's hosted
#     editor + Cloud collaboration
#   - LSP server for editor integration with the
#     Stencila document model
#
# Usage:
#   stencila <command> [args] [options]
#
# Commands (clap derive Subcommand; extensive list):
#   new               - create a new document
#   init              - initialize a project
#   config            - view/edit configuration
#   status            - show project status
#   move              - move tracked documents
#   track             - track a file in the project
#   untrack           - untrack a file
#   clean             - clean tracked file state
#   convert           - format conversion via codecs
#   merge             - merge multiple documents
#   sync              - sync with cloud
#   push              - push to cloud
#   pull              - pull from cloud
#   watch             - watch + rebuild on changes
#   unwatch           - stop watching
#   compile           - compile the document
#                       (parse + bind)
#   lint              - lint the document
#   execute           - execute the document's
#                       kernels
#   render            - render the document to a
#                       target format
#   graph             - generate dependency graph
#   open              - open in editor
#   publish           - publish to a destination
#   demo              - run an interactive demo
#   outputs           - list / fetch kernel outputs
#   db                - operate the embedded database
#   workflows         - manage workflows
#   agents            - manage AI agents
#   skills            - manage AI skills
#   models            - manage AI models
#   kernels           - manage executable kernels
#   linters           - manage linter integrations
#   formats           - manage codec/format
#                       registrations
#   themes            - manage themes
#   mcp               - Model Context Protocol server
#   tools             - LLM tool integrations
#   secrets           - manage credentials/secrets
#   auth              - authenticate with the cloud
#   credentials       - manage content credentials
#   serve             - run the HTTP server
#   snap              - snapshot management
#   lsp               - run the Language Server
#                       Protocol server
#   cloud             - cloud-side operations
#   site              - manage publishing sites
#   signin            - sign in to Stencila Cloud
#   signout           - sign out
#   logs              - tail cloud logs
#   upgrade           - upgrade stencila binary
#   uninstall         - uninstall stencila
#
# Global options (clap):
#   -h, --help               - print brief help
#   --help                   - print full help
#   --debug                  - debug logging + full
#                              error reports
#   --trace                  - trace logging + detailed
#                              error reports
#   --log-level <level>      - log level (debug|info|
#                              warn|error|trace)
#   --log-filter <filter>    - module-level log filter
#   --log-format <fmt>       - pretty | json | compact
#   --error-details <which>  - none / auto / all / list
#                              (location,span,env)
#   --error-link             - include report link
#   --no-color               - disable color output
#   --force-color            - force color output
#   --yes                    - assume "yes" to prompts
#   --no                     - assume "no" to prompts
#   --cancel                 - assume "cancel" to
#                              prompts
#
# The lightningcss lane is built on `lightningcss =
# "1.0.0-alpha.71"` (declared verbatim at upstream
# Cargo.toml HEAD as a direct dep, used for CSS
# parsing + minification in the theme + render
# pipeline), the canonical Rust CSS parser by Devon
# Govett (devongovett, foliojs maintainer) -
# github.com/parcel-bundler/lightningcss, 7000+ stars.
#
# lightningcss is an extremely fast CSS parser +
# transformer + minifier written in safe Rust. It
# was created by Devon Govett as part of the Parcel
# 2 bundler effort to replace Parcel's slower Babel/
# PostCSS-based CSS pipeline with a Rust-native
# alternative. The library:
#   - Parses CSS into a typed AST per the CSS
#     Syntax Level 3 + Selectors Level 4 + Media
#     Queries Level 5 + CSS Cascading & Inheritance
#     Level 5 + ~30 other CSS specifications
#   - Implements browser-targeted transforms (vendor
#     prefixing, modern-syntax-to-legacy fallback
#     generation, CSS nesting flattening, custom
#     property auto-fallbacks)
#   - Minifies via dead-code-elimination + property
#     coalescing + selector merging
#   - Generates source maps for downstream debugging
#   - Exposes both a Rust library API + a napi-rs
#     Node binding (npm `lightningcss`)
#
# Govett's multi-axis canonical-author position:
#   - Axis 251 (Brotli): foliojs/brotli (Node slot)
#   - Axis 258 (CSS, THIS AXIS): parcel-bundler/
#     lightningcss (Rust slot canonical) + the
#     lightningcss Node binding (npm `lightningcss`)
#     for the Node ecosystem
#   - + the broader foliojs umbrella: pdfkit
#     (canonical Node PDF) + fontkit (canonical
#     OpenType parser) + restructure (binary data
#     DSL) + dfa (finite automata) + ~30 other
#     packages
#
# Govett joins the multi-axis canonical author
# cohort alongside:
#   - Andrew Gallant / BurntSushi (XXHash + TOML +
#     Snappy + regex + ripgrep + fst + xsv)
#   - Armin Ronacher / mitsuhiko (similar + redis-
#     rs + insta + Flask + Jinja2)
#   - Vincent Prouillet / Keats (bcrypt + jsonwebtoken)
#   - Daniel Lemire (Roaring Bitmap + Bloom filter)
#   - Paul Miller / paulmillr (noble-ed25519 +
#     noble-curves + noble-hashes + noble-ciphers)
#   - Steven Fackler / sfackler (rust-postgres + rust-
#     openssl + log)
#
# What makes Govett unusual: he's the only multi-
# axis canonical author whose footprint spans BOTH
# the Rust + Node ecosystems with libraries that are
# the canonical pick in their respective ecosystem
# (lightningcss in Rust; brotli/pdfkit/fontkit in
# Node).
#
# stencila uses lightningcss in the theme rendering
# pipeline to parse + minify CSS bundled with
# rendered HTML output for the publishing path.
# The theme styles get parsed into the lightningcss
# AST, browser-targeted transforms apply (vendor
# prefixing for the rendered HTML's target audience),
# and the resulting CSS is minified before inclusion
# in the published HTML artifact.
#
# ----------------------------------------------------------------------------
# AXIS 258 :: CSS parser libraries (CSS Syntax L3 +
#              Selectors L4 + ~30 other CSS specs)
# Round 1472 :: Rust slot 1 of 4 :: OPENS Axis 258
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : parcel-bundler/lightningcss  - Devon
#                                            Govett's
#                                            canonical
#                                            Rust CSS
#                                            parser +
#                                            transformer
#                                            + minifier;
#                                            7000+ stars
#   Go      : tdewolff/parse/css           - Taco de
#                                            Wolff's
#                                            multi-format
#                                            parser
#                                            umbrella's
#                                            CSS module;
#                                            de-facto
#                                            Go CSS
#                                            parser
#   TS/Node : postcss                      - Andrey
#                                            Sitnik's
#                                            de-facto
#                                            Node CSS
#                                            parser +
#                                            transformer
#                                            ecosystem;
#                                            ~17000 stars
#
# CSS parsing is a spec-bound axis - the W3C CSS
# Working Group's specifications (CSS Syntax L3 +
# Selectors L4 + the various CSS modules) define the
# grammar byte-for-byte. All three lanes target the
# same specs but emphasize different downstream uses.
#
# Structural commentary on the canonical libraries:
#   - parcel-bundler/lightningcss (Rust): Govett's
#     canonical; written specifically as the Rust-
#     native replacement for Parcel 2's CSS pipeline;
#     also exposes a napi-rs Node binding so Node
#     projects can use the Rust library directly
#   - tdewolff/parse/css (Go): Taco de Wolff's
#     multi-format parser umbrella covers CSS + HTML
#     + JS + JSON + XML + SVG; the CSS module is the
#     de-facto Go CSS parser, but lives inside a
#     broader format-parsing ecosystem
#   - postcss (Node): not just a parser, but a full
#     CSS transformation ecosystem with thousands of
#     plugins for Autoprefixer + cssnano (minifier)
#     + cssnext (modern-CSS transpiler) + Tailwind +
#     Stylelint; the Node CSS canonical for ~10 years
#
# Axis 258 opens with the Rust slot at Govett's
# canonical lightningcss - extending Govett's
# multi-axis canonical position from Brotli (Axis 251
# Node) to CSS parsing (Axis 258 Rust).
# ============================================================================

_stencila() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--debug[debug logging + full error reports]' \
        '--trace[trace logging + detailed error reports]' \
        '--log-level[log level]:level:(trace debug info warn error)' \
        '--log-filter[module-level log filter]:filter:' \
        '--log-format[log format]:fmt:(pretty json compact)' \
        '--error-details[error report detail]:level:(none auto all)' \
        '--error-link[include report URL]' \
        '--no-color[disable color output]' \
        '--force-color[force color output]' \
        '--yes[assume yes to prompts]' \
        '--no[assume no to prompts]' \
        '--cancel[assume cancel to prompts]' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_stencila_cmds' \
        '*::arg:->args' \
    && ret=0

    return ret
}

_stencila_cmds() {
    local -a cmds
    cmds=(
        'new:create a new document'
        'init:initialize a project'
        'config:view/edit configuration'
        'status:show project status'
        'move:move tracked documents'
        'track:track a file in the project'
        'untrack:untrack a file'
        'clean:clean tracked file state'
        'convert:format conversion via codecs'
        'merge:merge multiple documents'
        'sync:sync with cloud'
        'push:push to cloud'
        'pull:pull from cloud'
        'watch:watch + rebuild on changes'
        'unwatch:stop watching'
        'compile:compile the document'
        'lint:lint the document'
        'execute:execute kernels in the document'
        'render:render to a target format'
        'graph:generate dependency graph'
        'open:open in editor'
        'publish:publish to a destination'
        'demo:run an interactive demo'
        'outputs:list / fetch kernel outputs'
        'db:operate the embedded database'
        'workflows:manage workflows'
        'agents:manage AI agents'
        'skills:manage AI skills'
        'models:manage AI models'
        'kernels:manage executable kernels'
        'linters:manage linter integrations'
        'formats:manage codec/format registrations'
        'themes:manage themes'
        'mcp:Model Context Protocol server'
        'tools:LLM tool integrations'
        'secrets:manage credentials/secrets'
        'auth:authenticate with the cloud'
        'credentials:manage content credentials'
        'serve:run the HTTP server'
        'snap:snapshot management'
        'lsp:run Language Server Protocol server'
        'cloud:cloud-side operations'
        'site:manage publishing sites'
        'signin:sign in to Stencila Cloud'
        'signout:sign out'
        'logs:tail cloud logs'
        'upgrade:upgrade stencila binary'
        'uninstall:uninstall stencila'
    )
    _describe -t commands 'stencila command' cmds
}

_stencila "$@"
