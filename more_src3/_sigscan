#compdef sigscan
# Documentation: https://github.com/libyal/libsigscan
# Source: libyal/libsigscan manuals/sigscan.1 — scan files for known binary signatures using libsigscan.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:file:_files' \
    && ret=0

return ret
