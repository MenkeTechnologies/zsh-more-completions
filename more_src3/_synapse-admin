_synapse-admin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[homeserver yaml]:file:_files -g "*.yaml *.yml"' \
        '--config-path=+[homeserver yaml]:file:_files -g "*.yaml *.yml"' \
        '-u+[username]:user:_users' \
        '--user=+[username]:user:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-a[admin user]' \
        '--admin[admin user]' \
        '--no-admin[not admin]' \
        '-r+[matrix server url]:url:_urls' \
        '--server-url=+[matrix server url]:url:_urls' \
        '-k+[registration shared secret]:str:' \
        '--shared-secret=+[registration shared secret]:str:' \
        '-w[no exit on missing data dir]' \
        '--no-progress-bar[no progress bar]' \
        '--curses[curses UI]' \
        '--prefilter[prefilter]' \
        '-n+[postgres uri]:str:' \
        '--target-config=+[target config]:file:_files -g "*.yaml *.yml"' \
        '--batch-size=+[N]:n:' \
        '--coursehunger[course hunger]' \
        '--clear-event-cache[clear event cache]' \
        '-t+[type]:t:(sqlite postgres)' \
        '--target-type=+[type]:t:(sqlite postgres)' \
        '-l+[log file]:file:_files' \
        '--log-config=+[log config]:file:_files -g "*.yaml *.yml"' \
        '--exclude-domain=+[domain]:str:' \
        '*:command:'
}

_synapse-admin "$@"
