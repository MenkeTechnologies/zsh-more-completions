#compdef svu
# Documentation: https://github.com/caarlos0/svu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (source main.go via Cobra flag defs).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--verbose[enable logs]' \
  '--config=[set config file]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'current:print current version'
      'next:print next version (default)'
      'major:print next major version'
      'minor:print next minor version'
      'patch:print next patch version'
      'prerelease:print next prerelease version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '--json[output version as JSON]' \
      '--tag.pattern=[ignore tags not matching pattern]:pattern' \
      '--tag.prefix=[custom tag prefix]:prefix' \
      '--tag.output=[set tag output when printing version]:prefix' \
      '--tag.mode=[tag lookup scope]:mode:(current-branch all-branches)' \
      '--prerelease=[set the version prerelease]:identifier' \
      '--metadata=[set the version metadata]:metadata' \
      '--log.directory=[only use commits changing files in given directories]:dir:_directories' \
      '--always[increment patch if no commits trigger version change]' \
      '--v0[prevent major version increments when current is v0]' \
      && ret=0
    ;;
esac

return ret
