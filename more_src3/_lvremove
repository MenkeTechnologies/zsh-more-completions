#compdef lvremove
# _lvremove — remove logical volume (LVM2); destroy lv and free its extents back to vg
# upstream: https://gitlab.com/lvmteam/lvm2

_lvremove() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '--nohistory[do not preserve history]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '--profile+[config profile]:profile:' \
        '*:lv:'
}

_lvremove "$@"
