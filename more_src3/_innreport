#compdef innreport
# Documentation: man innreport(8)
# Source: InterNetNews/inn scripts/innreport.in — generate INN log reports (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,-help}'[print help]' \
    '(- *)-v[print version]' \
    '-f+[general config file]:file:_files' \
    '-config[check syntax of config file]' \
    '(--html --no-html)--html[HTML output]' \
    '(--html --no-html)--no-html[no HTML output]' \
    '(-g --graph --no-graph)'{-g,--graph}'[generate graphs]' \
    '--no-graph[do not generate graphs]' \
    {-d+,--dir=}'[HTML output directory]:dir:_files -/' \
    {-p+,--path=}'[path]:path:_files' \
    {-w+,--webpath=}'[web image path]:path:_default' \
    {-i+,--index=}'[index file]:file:_files' \
    '(-a --archive --no-archive)'{-a,--archive}'[archive HTML reports]' \
    '--no-archive[no archive]' \
    {-c+,--cycle=}'[archive cycle days]:days:_default' \
    {-s+,--separator=}'[directory separator]:sep:_default' \
    '(--unknown --no-unknown)--unknown[show unknown messages]' \
    '(--unknown --no-unknown)--no-unknown[hide unknown messages]' \
    '(--html-unknown --no-html-unknown)--html-unknown[HTML unknown]' \
    '(--html-unknown --no-html-unknown)--no-html-unknown[no HTML unknown]' \
    '--maxunrec=[max unrecognized messages]:N:_default' \
    '(--casesensitive --no-casesensitive)--casesensitive[case sensitive]' \
    '(--casesensitive --no-casesensitive)--no-casesensitive[case insensitive]' \
    '(--notdaily --no-notdaily)--notdaily[do not run as part of news.daily]' \
    '(--notdaily --no-notdaily)--no-notdaily[run as news.daily]' \
    '*:log file:_files' \
    && ret=0

return ret
