#compdef knative-pong
# _knative-pong — Knative Eventing sample Ping/Pong CloudEvent responder
# upstream: https://github.com/knative/eventing
# Flags from cmd/pong/main.go on tip.

_knative-pong() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--ping=[CloudEvents type to watch for]:type:' \
        '--pong=[CloudEvents type to respond with]:type:'
}

_knative-pong "$@"
