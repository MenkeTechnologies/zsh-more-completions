#compdef zap
# Documentation: https://github.com/zap-zsh/zap
# Reference accessed: 2026-05-21
# Verified: upstream README - minimal zsh plugin manager.

_zap_commands() {
  local -a commands=(
    'update:Update plugins, self, or both (update self|plugins|all)'
    'list:List installed plugins'
    'clean:Remove unused plugins'
    'version:Print version'
  )
  _describe 'command' commands
}

_zap() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)--help[Show help]' \
    '(- *)--version[Print version]' \
    '1:command:_zap_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        update)
          _arguments \
            '1:target:(self plugins all)'
          ;;
      esac
      ;;
  esac
}

_zap "$@"
