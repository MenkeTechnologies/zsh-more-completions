#compdef immuclient
# _immuclient — immudb CLI client (key-value reads/writes + scans + auditing + login against an immudb instance)
# upstream: https://github.com/codenotary/immudb
# Persistent flags from cmd/immuclient/command/init.go on tip; subcommands from cmd/immuclient/command/{login,getcommands,setcommands,scanners,server_info,currentstatus,misc,sql,references,tamperproofing}.go.

_immuclient() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --immudb-port)'{-p+,--immudb-port=}'[immudb port]:port:' \
        '(-a --immudb-address)'{-a+,--immudb-address=}'[immudb host]:host:_hosts' \
        '--config=[config file (default immuclient.toml)]:file:_files' \
        '--username=[immudb username]:user:' \
        '--password=[immudb password (plain or enc:base64)]:pwd:' \
        '--database=[immudb database]:db:' \
        '--tokenfile=[session token file]:file:_files' \
        '(-m --mtls)'{-m,--mtls}'[enable mutual TLS]' \
        '--max-recv-msg-size=[max recv message size (bytes)]:n:' \
        '--servername=[mTLS server name for cert verification]:name:' \
        '--certificate=[server cert file path]:file:_files' \
        '--pkey=[server private key file path]:file:_files' \
        '--clientcas=[client CA cert list path]:file:_files' \
        '--value-only[only print values on get]' \
        '--revision-separator=[separator between key and revision (empty=off)]:sep:' \
        '--roots-filepath=[directory for audit root-hash files]:dir:_files -/' \
        '--dir=[main directory for audit tool]:dir:_files -/' \
        '--audit-username=[audit-mode immudb username]:user:' \
        '--audit-password=[audit-mode immudb password]:pwd:' \
        '--audit-databases=[comma-separated databases to audit]:list:' \
        '--audit-verify-values[verify on-disk value matches committed hash]' \
        '--audit-notification-url=[POST audit results to this URL]:url:_urls' \
        '--audit-notification-username=[audit-notification basic-auth user]:user:' \
        '--audit-notification-password=[audit-notification basic-auth password]:pwd:' \
        '--audit-monitoring-host=[audit-mode monitoring server host]:host:_hosts' \
        '--audit-monitoring-port=[audit-mode monitoring server port]:port:' \
        '--server-signing-pub-key=[public key path for signature verification]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'login:authenticate as a user'
                'logout:invalidate the current session token'
                'use:select a database'
                'get:read a key (supports key@revision)'
                'safeget:tamper-proof read'
                'set:write a key/value'
                'safeset:tamper-proof write'
                'restore:restore key@revision'
                'delete:delete a key'
                'tx:fetch a transaction by id'
                'safetx:tamper-proof tx read'
                'zadd:add to a sorted set'
                'safezadd:tamper-proof sorted-set add'
                'zscan:scan a sorted set'
                'scan:scan keys by prefix'
                'count:count keys'
                'reference:create a key reference'
                'safereference:tamper-proof reference'
                'history:show key revision history'
                'audit-mode:run continuous auditor'
                'status:server health'
                'health:server health (alias)'
                'currentstate:show server current state hash + tx id'
                'check-consistency:verify proof for a tx'
                'inclusion:verify inclusion proof'
                'consistency:verify consistency proof'
                'sql:execute an SQL statement'
                'use-db:switch database (alias of use)'
                'version:show version'
                'man:emit man pages'
                'help:show help'
            )
            _describe -t commands 'immuclient command' subs
            ;;
    esac
}

_immuclient "$@"
