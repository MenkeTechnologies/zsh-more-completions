#compdef kfind
# Documentation: https://invent.kde.org/utilities/kfind/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream src/main.cpp uses KAboutData::setupCommandLine and
# registers a single positional argument "+[searchpath]" (path to
# search); no other custom options. Corrected from prior file: removed
# fabricated --display= (KDE3/X11-era, not in KF6 Qt6) and the bogus
# man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options including Qt options]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '1:search path:_files -/' && ret=0

return ret
