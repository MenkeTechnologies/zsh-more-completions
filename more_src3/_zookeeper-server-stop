#compdef zookeeper-server-stop zookeeper-server-stop.sh
# _zookeeper-server-stop — Apache ZooKeeper zookeeper-server-stop helper CLI for gracefully shutting down a running ZooKeeper ensemble member by signalling the QuorumPeerMain JVM process matched via PID file with configurable timeout (apache team, Bash); getopt
# upstream: https://zookeeper.apache.org/

_zookeeper-server-stop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-pid=+[pid file]:file:_files' \
        '--pid-file=+[pid file]:file:_files' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-f[force]' \
        '--force[force]' \
        '*:additional pid file:_files'
}

_zookeeper-server-stop "$@"
