#compdef HandBrakeCLI
# Documentation: https://handbrake.fr/docs/en/latest/cli/command-line-reference.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for HandBrakeCLI - video transcoder

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[produce JSON progress output]' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity level]:level:(0 1 2)' \
  '(-Z --preset)'{-Z,--preset=}'[select preset by name]:preset:' \
  '(-z --preset-list)'{-z,--preset-list}'[list available presets]' \
  '--preset-import-file=[import preset from file]:file:_files' \
  '--preset-import-gui[import presets from GUI configuration]' \
  '--preset-export=[generate and output a new preset]:name:' \
  '--preset-export-file=[save exported preset to file]:file:_files' \
  '--preset-export-description=[description for new preset]:desc:' \
  '--queue-import-file=[import encode queue from GUI file]:file:_files' \
  '--no-dvdnav[disable libdvdnav]' \
  '(-i --input)'{-i,--input=}'[input file or device]:input:_files' \
  '(-t --title)'{-t,--title=}'[select a title (0 scans all)]:title:' \
  '--min-duration=[minimum title duration in seconds]:seconds:' \
  '--scan[scan selected title only]' \
  '--main-feature[auto-detect and encode main feature]' \
  '--keep-duplicate-titles[retain duplicate titles during scanning]' \
  '(-c --chapters)'{-c,--chapters=}'[chapter range]:range:' \
  '--angle=[select the video angle]:angle:' \
  '--previews=[preview count and storage]:num\:bool:' \
  '--start-at-preview=[begin encoding from preview]:n:' \
  '--start-at=[start encoding at offset]:offset:' \
  '--stop-at=[stop encoding at offset]:offset:' \
  '(-o --output)'{-o,--output=}'[output file]:output:_files' \
  '(-f --format)'{-f,--format=}'[output container format]:format:(av_mp4 av_mkv av_webm)' \
  '(-m --markers)'{-m,--markers}'[add chapter markers]' \
  '--no-markers[exclude chapter markers]' \
  '(-O --optimize)'{-O,--optimize}'[optimize MP4 for HTTP streaming]' \
  '--no-optimize[skip optimization]' \
  '(-I --ipod-atom)'{-I,--ipod-atom}'[add iPod 5G atom]' \
  '--no-ipod-atom[remove iPod compatibility atom]' \
  '--align-av[synchronize A/V stream start times]' \
  '--keep-metadata[preserve source common metadata]' \
  '--no-metadata[disable metadata preservation]' \
  '--inline-parameter-sets[adaptive streaming output]' \
  '(-e --encoder)'{-e,--encoder=}'[video encoder]:encoder:(x264 x264_10bit x265 x265_10bit x265_12bit mpeg4 mpeg2 VP8 VP9 VP9_10bit theora nvenc_h264 nvenc_h265 nvenc_h265_10bit vce_h264 vce_h265 vce_h265_10bit qsv_h264 qsv_h265 qsv_h265_10bit svt_av1 svt_av1_10bit)' \
  '--encoder-preset=[encoder preset]:preset:' \
  '--encoder-preset-list=[list encoder presets]:encoder:' \
  '--encoder-tune=[encoder tune]:tune:' \
  '--encoder-tune-list=[list encoder tunes]:encoder:' \
  '(-x --encopts)'{-x,--encopts=}'[advanced encoder options]:options:' \
  '--encoder-profile=[encoder profile]:profile:' \
  '--encoder-profile-list=[list encoder profiles]:encoder:' \
  '--encoder-level=[encoder level]:level:' \
  '--encoder-level-list=[list encoder levels]:encoder:' \
  '(-q --quality)'{-q,--quality=}'[video quality]:quality:' \
  '(-b --vb)'{-b,--vb=}'[video bitrate in kbps]:bitrate:' \
  '--multi-pass[multi-pass encoding]' \
  '--no-multi-pass[disable multi-pass]' \
  '(-T --turbo)'{-T,--turbo}'[turbo first pass]' \
  '--no-turbo[disable turbo]' \
  '(-r --rate)'{-r,--rate=}'[video framerate]:fps:(5 10 12 15 20 23.976 24 25 29.97 30 48 50 59.94 60)' \
  '--cfr[constant frame rate]' \
  '--vfr[variable frame rate]' \
  '--pfr[peak-limited frame rate]' \
  '--hdr-dynamic-metadata=[preserve HDR metadata]:mode:' \
  '--no-hdr-dynamic-metadata[skip HDR metadata]' \
  '--enable-hw-decoding=[hardware decoding]:engine:(nvdec qsv videotoolbox)' \
  '--disable-hw-decoding[force software decoding]' \
  '--audio-lang-list=[audio languages (ISO 639-2)]:list:' \
  '--all-audio[include all matching language tracks]' \
  '--first-audio[select first matching language track]' \
  '(-a --audio)'{-a,--audio=}'[audio track(s)]:tracks:' \
  '(-E --aencoder)'{-E,--aencoder=}'[audio encoder]:encoder:(av_aac fdk_aac fdk_haac copy:aac ac3 copy:ac3 eac3 copy:eac3 copy:truehd copy:dts copy:dtshd mp3 vorbis flac16 flac24 opus copy)' \
  '--audio-copy-mask=[passthru-allowed codecs]:codecs:' \
  '--audio-fallback=[passthru fallback encoder]:encoder:' \
  '(-B --ab)'{-B,--ab=}'[audio bitrate in kbps]:bitrate:' \
  '(-Q --aq)'{-Q,--aq=}'[audio quality]:q:' \
  '(-C --ac)'{-C,--ac=}'[audio compression]:c:' \
  '(-6 --mixdown)'{-6,--mixdown=}'[audio mixdown]:mixdown:(mono left_only right_only stereo dpl1 dpl2 5point1 6point1 7point1 5_2_lfe)' \
  '--normalize-mix=[normalize mix levels]:track:' \
  '(-R --arate)'{-R,--arate=}'[audio samplerate]:rate:(auto 22.05 24 32 44.1 48)' \
  '(-D --drc)'{-D,--drc=}'[dynamic range compression]:f:' \
  '--gain=[gain in dB]:db:' \
  '--adither=[audio dither method]:method:' \
  '--keep-aname[preserve source audio names]' \
  '--no-keep-aname[discard source audio names]' \
  '(-A --aname)'{-A,--aname=}'[custom audio track names]:names:' \
  '--audio-copy-mask=[allowed copy codecs]:codecs:' \
  '(-w --width)'{-w,--width=}'[output width]:pixels:' \
  '(-l --height)'{-l,--height=}'[output height]:pixels:' \
  '--crop-mode=[crop strategy]:mode:' \
  '--crop=[manual crop]:top\:bottom\:left\:right:' \
  '--crop-threshold-pixels=[pixel difference threshold]:n:' \
  '--crop-threshold-frames=[frame count for crop detection]:n:' \
  '(-Y --maxHeight)'{-Y,--maxHeight=}'[max output height]:pixels:' \
  '(-X --maxWidth)'{-X,--maxWidth=}'[max output width]:pixels:' \
  '--non-anamorphic[1:1 pixel aspect]' \
  '--auto-anamorphic[automatic anamorphic mode]' \
  '--loose-anamorphic[loose anamorphic mode]' \
  '--custom-anamorphic[custom anamorphic mode]' \
  '--display-width=[display width for custom anamorphic]:pixels:' \
  '--keep-display-aspect[preserve display aspect]' \
  '--no-keep-display-aspect[disable aspect preservation]' \
  '--pixel-aspect=[custom pixel aspect]:par_x\:par_y:' \
  '--itu-par[use ITU PAR values]' \
  '--no-itu-par[disable ITU PAR]' \
  '--modulus=[dimension modulus]:n:' \
  '--color-range=[output color range]:range:(auto limited full)' \
  '(-M --color-matrix)'{-M,--color-matrix=}'[color space]:cs:(2020 709 601)' \
  '--comb-detect=[enable comb detection]:settings:' \
  '--no-comb-detect[disable comb detection]' \
  '(-d --deinterlace)'{-d,--deinterlace=}'[yadif deinterlace]:settings:' \
  '--no-deinterlace[disable deinterlace]' \
  '--bwdif=[bwdif deinterlace]:settings:' \
  '--no-bwdif[disable bwdif]' \
  '(-5 --decomb)'{-5,--decomb=}'[decomb filter]:settings:' \
  '--no-decomb[disable decomb]' \
  '(-9 --detelecine)'{-9,--detelecine=}'[detelecine filter]:settings:' \
  '--no-detelecine[disable detelecine]' \
  '(-8 --hqdn3d)'{-8,--hqdn3d=}'[denoise]:settings:' \
  '--no-hqdn3d[disable denoise]' \
  '--denoise=[legacy denoising alias]:settings:' \
  '--nlmeans=[NLMeans denoising]:settings:' \
  '--no-nlmeans[disable NLMeans]' \
  '--nlmeans-tune=[tune NLMeans]:tune:' \
  '--chroma-smooth=[smooth chroma]:settings:' \
  '--no-chroma-smooth[disable chroma smoothing]' \
  '--chroma-smooth-tune=[tune chroma smoothing]:tune:' \
  '--unsharp=[sharpen]:settings:' \
  '--no-unsharp[disable unsharp]' \
  '--unsharp-tune=[tune sharpening]:tune:' \
  '--lapsharp=[Laplacian sharpening]:settings:' \
  '--no-lapsharp[disable lapsharp]' \
  '--lapsharp-tune=[tune lapsharp]:tune:' \
  '(-7 --deblock)'{-7,--deblock=}'[deblock]:settings:' \
  '--no-deblock[disable deblock]' \
  '--deblock-tune=[tune deblock]:tune:' \
  '--rotate=[rotate/flip image]:mode:' \
  '--pad=[add borders]:settings:' \
  '--colorspace=[convert color properties]:cs:' \
  '(-g --grayscale)'{-g,--grayscale}'[encode in grayscale]' \
  '--no-grayscale[disable grayscale]' \
  '--subtitle-lang-list=[subtitle languages]:list:' \
  '--all-subtitles[include all matching subtitles]' \
  '--first-subtitle[select first matching subtitle]' \
  '(-s --subtitle)'{-s,--subtitle=}'[subtitle track(s)]:tracks:' \
  '--keep-subname[preserve subtitle names]' \
  '--no-keep-subname[discard subtitle names]' \
  '(-S --subname)'{-S,--subname=}'[custom subtitle names]:names:' \
  '(-F --subtitle-forced)'{-F,--subtitle-forced=}'[forced subtitle track]:track:' \
  '--subtitle-burned=[burn subtitle track]:track:' \
  '--subtitle-default=[default subtitle track]:track:' \
  '(-N --native-language)'{-N,--native-language=}'[native language code]:code:' \
  '--native-dub[prefer matching audio over subtitles]' \
  '--srt-file=[SRT filename(s)]:files:' \
  '--srt-codeset=[SRT character encoding]:codeset:' \
  '--srt-offset=[SRT timing offset]:ms:' \
  '--srt-lang=[SRT language code]:lang:' \
  '--srt-default=[default SRT track]:track:' \
  '--srt-burn=[burn SRT subtitle]:track:' \
  '--ssa-file=[SSA filename(s)]:files:' \
  '--ssa-offset=[SSA timing offset]:ms:' \
  '--ssa-lang=[SSA language code]:lang:' \
  '--ssa-default=[default SSA track]:track:' \
  '--ssa-burn=[burn SSA subtitle]:track:' \
  '*:input file:_files'
