#compdef hsetroot
# Documentation: https://github.com/hiber-wine/hsetroot

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-screens=[specify target screens (comma-separated)]:screens:' \
  '-center[center image on screen]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-cover[cover screen with image (preserve aspect, crop)]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-fill[fill screen with image (stretch to fit)]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-extend[extend image to fill screen]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-tile[tile image across screen]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-full[scale image to fit screen (preserve aspect)]:image:_files -g "*(#i).(png|jpg|jpeg|bmp|xpm|gif|tiff|tif)"' \
  '-solid[set solid background color]:color:' \
  '-add[add color to image]:color:' \
  '-addd[add color to image (divided)]:color:' \
  '-alpha[set image alpha]:alpha (0-255):' \
  '-tint[tint image with color]:color:' \
  '-blur[gaussian blur]:radius:' \
  '-sharpen[sharpen image]:radius:' \
  '-contrast[adjust contrast]:amount:' \
  '-brightness[adjust brightness]:amount:' \
  '-gamma[adjust gamma]:amount:' \
  '-fliph[flip image horizontally]' \
  '-flipv[flip image vertically]' \
  '-write[write resulting image to file]:output:_files' \
  && return 0
