#compdef voxel2fixel
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/voxel2fixel.html
# Source: MRtrix3/mrtrix3 cmd/voxel2fixel.cpp — copy voxel-wise data into fixel-wise data (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '1:image_in (input voxel image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:fixel_directory_in:_files -/' \
    '3:fixel_directory_out:_files -/' \
    '4:fixel_data_out (filename):_default' \
    && ret=0

return ret
