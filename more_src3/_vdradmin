#compdef vdradmin vdradmind vdradmind.pl
# Documentation: https://github.com/vdr-projects/vdradmin-am
# Reference accessed: 2026-05-21
# Verified: upstream vdr-projects/vdradmin-am vdradmind.pl(1) docs.

# vdradmin: web admin frontend for VDR
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --nofork)'{-n,--nofork}'[do not fork to background]' \
  '(-c --config)'{-c,--config}'[run interactive configuration]' \
  '(-d --cfgdir)'{-d+,--cfgdir=}'[config directory]:dir:_files -/' \
  '(-k --kill)'{-k,--kill}'[kill running vdradmind]' \
  '(-p --pid)'{-p+,--pid=}'[PID file name]:name:' \
  '(-6 --ipv6)'{-6,--ipv6}'[enable IPv6]' \
  '(-s --ssl)'{-s,--ssl}'[enable SSL]' \
  '(-l --log)'{-l+,--log=}'[log level]:level:' && ret=0
return ret
