#compdef ttyflags
# Documentation: man ttyflags(8)
# Source: netbsd/src sbin/ttyflags — set terminal flags from /etc/ttys (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(*)-a[configure all terminals in /etc/ttys]' \
    '-v[verbose, show flag values applied]' \
    '*:tty base name:_default' \
    && ret=0

return ret
