#compdef zeisstopnm
# Documentation: man zeisstopnm (Netpbm)
# Source: convert a Zeiss confocal microscope image to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-pgm -ppm)-pgm[force PGM output]' \
    '(-pgm -ppm)-ppm[force PPM output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:zeiss file:_files' \
    && ret=0

return ret
