#compdef tsfdump tsdump
# _tsfdump — TSDuck tsfdump tsdump MPEG-2 TS hex packet dumper showing PID continuity counters PES headers PCR PTS DTS values and adaptation fields (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsfdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-a[show adaptation field]' \
        '--adaptation-field[show adaptation field]' \
        '-r[raw packet hex]' \
        '--raw[raw packet hex]' \
        '-p+[pid csv]:str:' \
        '--pid=+[pid csv]:str:' \
        '-n+[N packets]:n:' \
        '--max-packets=+[N packets]:n:' \
        '-c[short]' \
        '--no-headers[no headers]' \
        '--headers-only[headers only]' \
        '--payload[show payload]' \
        '--no-payload[no payload]' \
        '--ascii[ASCII output]' \
        '--binary[binary output]' \
        '--decimal[decimal]' \
        '--decoded-data[show decoded data]' \
        '--hexa[hex output]' \
        '--offset[show offsets]' \
        '--no-pid-stats[no PID stats]' \
        '--continuity-counter[continuity counter]' \
        '--pes-headers[show PES headers]' \
        '--pcr-only[PCR only]' \
        '--ts-info[show TS info]' \
        '--time-interval=+[seconds]:n:' \
        '--packet-count=+[N]:n:' \
        '--first-packet=+[N]:n:' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-I+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '--input=+[input plugin]:p:(file null udp ip http https rist srt dektec dvb fork)' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tsfdump "$@"
