#compdef knative-kafka-source-controller
# _knative-kafka-source-controller — Knative Eventing KafkaSource controller (sharedmain)
# upstream: https://github.com/knative-extensions/eventing-kafka-broker
# Flags from control-plane/cmd/kafka-source-controller/main.go + knative.dev/pkg sharedmain on tip.

_knative-kafka-source-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-kafka-source-controller "$@"
