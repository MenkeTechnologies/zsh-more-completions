#compdef unp
# _unp — universal unpacker for many archive formats (mitsuhiko/unp)
# upstream: https://github.com/mitsuhiko/unp
# Flags from unp.py (click).

_unp() {
    _arguments \
        '(- *)--help[show help]' \
        '(-q --silent)'{-q,--silent}'[suppress output]' \
        '(-o --output)'{-o+,--output=}'[output folder]:dir:_files -/' \
        '--unpacker=[force specific unpacker]:name:' \
        '--list-unpackers[list available unpackers]' \
        '--dump-command[print the unpacker command instead of running]' \
        '*:archive file:_files'
}

_unp "$@"
