#compdef jwt
# Documentation: https://github.com/mike-engel/jwt-cli/blob/main/src/cli_config.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jwt-cli (mike-engel/jwt-cli). Corrected from prior file: ES512 is
# NOT a supported alg; --nbf short is -n; added real -k/--kid, -t/--typ,
# --jti, --no-typ, -o/--out, --keep-payload-order; decode uses --date
# and --ignore-exp; removed fabricated --header, --secret-b64,
# --iso8601, --no-verify flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'encode:encode a new JWT'
      'decode:decode a JWT'
    )
    _describe -t commands 'jwt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      encode)
        _arguments -s -S \
          '(-A --alg)'{-A,--alg}'=[algorithm to sign with]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 PS256 PS384 PS512 ES256 ES384 EdDSA)' \
          '(-k --kid)'{-k,--kid}'=[key ID (kid) header]:kid' \
          '(-t --typ)'{-t,--typ}'=[type (typ) header]:typ' \
          '(-S --secret)'{-S,--secret}'=[secret to sign with (@file or b64:...)]:secret' \
          '(-e --exp)'{-e,--exp}'=[expiration claim]:expiration' \
          '(-i --iss)'{-i,--iss}'=[issuer claim]:issuer' \
          '(-s --sub)'{-s,--sub}'=[subject claim]:subject' \
          '(-a --aud)'{-a,--aud}'=[audience claim]:audience' \
          '--jti=[JWT ID claim]:jti' \
          '(-n --nbf)'{-n,--nbf}'=[not before claim]:not before' \
          '*'{-P,--payload}'=[key=value pair to add to the payload]:claim' \
          '--no-iat[do not automatically add an iat claim]' \
          '--no-typ[do not automatically add a typ header]' \
          '--keep-payload-order[keep the payload keys in the given order]' \
          '(-o --out)'{-o,--out}'=[write the JWT to a file]:file:_files' \
          && ret=0
        ;;
      decode)
        _arguments -s -S \
          '(-S --secret)'{-S,--secret}'=[secret to validate with (@file or b64:...)]:secret' \
          '(-A --alg)'{-A,--alg}'=[algorithm to verify with]:algorithm:(HS256 HS384 HS512 RS256 RS384 RS512 PS256 PS384 PS512 ES256 ES384 EdDSA)' \
          '(-j --json)'{-j,--json}'[render the decoded JWT as JSON]' \
          '--date=[display timestamps as ISO 8601 dates (UTC, Local, or offset e.g. -02:00)]:format:(UTC Local)' \
          '--ignore-exp[ignore token expiration during validation]' \
          '(-o --out)'{-o,--out}'=[write the decoded JWT to a file]:file:_files' \
          '1:token' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
