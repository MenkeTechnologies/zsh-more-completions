#compdef h2o-3
# Documentation: https://docs.h2o.ai/h2o/latest-stable/h2o-docs/starting-h2o.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# H2O-3: H2O Java in-memory ML platform launcher

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,-help,--help}'[show help]' \
  '-version[show version]' \
  '-name[cluster name]:name:' \
  '-port[base port for REST API]:port:' \
  '-baseport[starting port to scan for free REST API port]:port:' \
  '-ip[bind IP (IPv4 or IPv6)]:ip:' \
  '-network[network mask CIDR]:mask:' \
  '-flatfile[flatfile of cluster members]:file:_files' \
  '-ice_root[temporary spill directory]:dir:_files -/' \
  '-nthreads[max threads in batch work queue]:n:' \
  '-Xmx[max JVM heap size]:size:' \
  '-Xms[initial JVM heap size]:size:' \
  '-client[launch node in client mode]' \
  '-notify_local[write node status to file]:file:_files' \
  '-context_path[Jetty web context path]:path:' \
  '-flow_dir[directory for saved flows]:dir:_files -/' \
  '-jks[Java keystore file]:file:_files' \
  '-jks_pass[keystore password]:pass:' \
  '-jks_alias[specific keystore certificate alias]:alias:' \
  '-hash_login[enable Jetty HashLoginService]' \
  '-ldap_login[enable Jetty LdapLoginService]' \
  '-kerberos_login[enable Kerberos LoginService]' \
  '-pam_login[enable PAM LoginService]' \
  '-form_auth[enable form-based authentication for Flow]' \
  '-session_timeout[session idle timeout in minutes]:minutes:' \
  '-login_conf[login.conf file]:file:_files' \
  '-internal_security_conf[internal security conf file]:file:_files' \
  '-log_dir[log directory]:dir:_files -/' \
  '-log_level[log level]:level:(TRACE DEBUG INFO WARN ERRR FATAL)' \
  '-features[features level]:level:(stable beta experimental)' \
  '*::h2o-3 args:_files' && ret=0
return ret
