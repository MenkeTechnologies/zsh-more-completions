#compdef initiator mayastor-initiator
# _initiator — Mayastor I/O engine initiator test tool (talks to a single bdev URI and does read/write/NVMe-admin operations)
# upstream: https://github.com/openebs/mayastor
# Source: io-engine/src/bin/initiator.rs on tip; positional URI selects the bdev to drive.

_initiator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--offset=[byte offset for read/write]:n:' \
        '--size=[transfer size in bytes]:n:' \
        '--operation=[operation to perform]:op:(read write nvme-admin connect disconnect)' \
        '--file=[file source/destination for read/write data]:file:_files' \
        '--opcode=[NVMe admin opcode (used with --operation nvme-admin)]:n:' \
        '1:bdev uri:'
}

_initiator "$@"
