#compdef sidplayfp
# _sidplayfp — C64 SID music player using cycle-accurate emulation (libsidplayfp/sidplayfp)
# upstream: https://github.com/libsidplayfp/sidplayfp
# Flags from sidplayfp(1) man page.

_sidplayfp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--help-debug[show additional debug-only options]' \
        '-fo+[fade-out time seconds (a=after, b=before)]:spec:' \
        '-f+[audio output frequency in Hz]:hz:(44100 48000 96000)' \
        '-nf[disable filter emulation]' \
        '-s[stereo playback]' \
        '-m[mono playback]' \
        '*-v+[verbose console output]:level:' \
        '*-q+[quiet console output]:level:' \
        '-b+[start time (mins:secs.milli)]:time:' \
        '-ds+[force dual SID at given address]:addr:' \
        '-ts+[add third SID at given address]:addr:' \
        '*-u+[mute channel (1-9)]:channel:' \
        '*-g+[mute samples (1-3)]:chip:' \
        '-p+[bit precision for file output (16/32)]:bits:(16 32)' \
        '-o+[start track / loop / single options]:spec:' \
        '-t+[play length (mins:secs.milli, 0 = endless)]:time:' \
        '-v+[VIC clock speed (n=NTSC, p=PAL, append f)]:speed:' \
        '-m+[SID chip model (o=6581, n=8580, append f)]:model:' \
        '--digiboost[enable digiboost hack for 8580]' \
        '-r+[resampling mode (i=interpolate, r=resample, append f)]:mode:' \
        '(-w --wav)'{-w-,--wav-}'[create WAV file]::name:_files' \
        '--au-[create AU file]::name:_files' \
        '--resid[use reSID emulation engine]' \
        '--residfp[use reSIDfp emulation engine]' \
        '--hardsid[use HardSID device]' \
        '--exsid[use exSID device]' \
        '--usbsid[use USBSID-Pico device]' \
        '--cpu-debug[CPU register / assembly dumps (debug builds)]' \
        '--delay=[C64 power-on delay (CPU cycles)]:cycles:' \
        '--fcurve=[ReSIDfp filter curve (0.0-1.0 or auto)]:value:' \
        '--frange=[ReSIDfp filter range (0.0-1.0 or auto)]:value:' \
        '-cw+[combined-waveform strength (w/a/s)]:width:(w a s)' \
        '--noaudio[no audio output device]' \
        '--nosid[no SID emulation]' \
        '--none[no audio and no SID emulation]' \
        '*:SID file:_files -g "*.{sid,mus,prg,p00}"'
}

_sidplayfp "$@"
