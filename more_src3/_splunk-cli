#compdef splunk-cli splunk2
# _splunk-cli — Splunk splunk-cli CLI command-line frontend wrapping the Splunk Enterprise on-premises data platform CLI providing add edit delete remove enable disable display list show start stop restart status clean rebuild rolling-restart anonymize cmd btool diag dispatch search rtsearch login logout install-app uninstall-app create-shcluster-bundle help (Splunk Inc team, C); custom argparse
# upstream: https://docs.splunk.com/Documentation/Splunk/latest/Admin/CLIaboutsubsystems

_splunk-cli() {
    local -a sub=(
        'add:add object'
        'edit:edit object'
        'remove:remove object'
        'enable:enable object'
        'disable:disable object'
        'display:display object'
        'list:list objects'
        'show:show object'
        'start:start splunkd'
        'stop:stop splunkd'
        'restart:restart splunkd'
        'status:status'
        'reload:reload conf'
        'clean:clean data'
        'rebuild:rebuild index'
        'rolling-restart:rolling restart'
        'anonymize:anonymize a file'
        'search:run a search'
        'rtsearch:real-time search'
        'login:login'
        'logout:logout'
        'cmd:run an arbitrary cmd'
        'btool:btool inspect'
        'diag:create diag file'
        'dispatch:dispatch search'
        'install:install app'
        'uninstall:uninstall app'
        'apply:apply cluster-bundle'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-auth+[user:password]:str:' \
        '-uri+[url]:str:' \
        '-app+[name]:str:' \
        '-owner+[name]:str:' \
        '-sharing+[s]:s:(user app global)' \
        '-namespace+[ns]:str:' \
        '-search-results-info[show info]' \
        '-output+[fmt]:f:(rawdata table csv auto json xml)' \
        '-preview+[bool]:b:(true false)' \
        '-id+[id]:str:' \
        '-name+[name]:str:' \
        '-index+[name]:str:' \
        '-sourcetype+[name]:str:' \
        '-source+[name]:str:' \
        '-monitor+[path]:_files' \
        '-eventcount+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'splunk subcommand' sub ;;
        args)
            case $words[1] in
                add|edit|remove|enable|disable|display|list|show) _arguments '1:object:(monitor index user role data forwardserver oneshot fifo tcp udp licenser-pools licenses)' '*:arg:' ;;
                btool) _arguments '1:conf:(props transforms indexes inputs outputs server web limits)' '2:op:(list check)' '*:arg:' ;;
                cmd) _arguments '*:cmd:_command_names' ;;
            esac
            ;;
    esac
}

_splunk-cli "$@"
