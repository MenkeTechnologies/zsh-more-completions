#compdef juk
# _juk — KDE jukebox / music manager (KDE/juk)
# upstream: https://github.com/KDE/juk
# Flags from main.cpp (QCommandLineParser; only standard Qt/KDE options + files).

_juk() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--help-all[show help including Qt/KDE options]'
        '(- *)'{-v,--version}'[show version]'
        '--author[print application author info]'
        '--license[print license info]'
        '--desktopfile=[desktop file base name]:name:'
        '*:music file(s):_files -g "*.{mp3,flac,ogg,m4a,wav,opus,wma,mpc,ape,aac,m3u,m3u8}"'
    )
    _arguments -s $args
}

_juk "$@"
