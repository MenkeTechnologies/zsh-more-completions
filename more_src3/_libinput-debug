#compdef libinput-debug libinput-debug-events libinput-debug-gui libinput-debug-tablet
# _libinput-debug — Wayland libinput debug tools CLI alias (Wayland project, C); custom argparse
# upstream: https://gitlab.freedesktop.org/libinput/libinput

_libinput-debug() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--show-keycodes[show keycodes]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '--enable-tap[enable tap]' \
        '--disable-tap[disable tap]' \
        '--enable-drag-lock[enable drag lock]' \
        '--disable-drag-lock[disable drag lock]' \
        '--enable-natural-scrolling[enable natural scrolling]' \
        '--disable-natural-scrolling[disable natural scrolling]' \
        '--enable-left-handed[enable left handed]' \
        '--disable-left-handed[disable left handed]' \
        '--enable-middlebutton[enable middle button emulation]' \
        '--disable-middlebutton[disable middle button emulation]' \
        '--enable-dwt[enable disable-while-typing]' \
        '--disable-dwt[disable disable-while-typing]' \
        '--enable-click-method-clickfinger[clickfinger]' \
        '--enable-click-method-buttonareas[button areas]' \
        '--set-click-method=+[click method]:m:(clickfinger buttonareas none)' \
        '--set-scroll-method=+[scroll method]:m:(two-finger edge button none)' \
        '--set-scroll-button=+[scroll button]:b:' \
        '--set-profile=+[accel profile]:p:(adaptive flat)' \
        '--set-speed=+[pointer speed]:f:' \
        '--apply-to=+[device match]:str:' \
        '--udev=+[udev seat]:str:' \
        '--device=+[device path]:file:_files -g "/dev/input/event*"' \
        '--grab[grab device]' \
        '*:arg:'
}

_libinput-debug "$@"
