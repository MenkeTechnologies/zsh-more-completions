#compdef ko-cli ko
# _ko-cli — Google ko-cli CLI command-line frontend wrapping the ko fast Kubernetes-native publish, image, build, deploy tool for Go applications from Google originally part of Knative open-source written in Go works without Docker by leveraging Go's caching and standard library no-Dockerfile-needed-distroless-builds reads Kubernetes YAML deploys Go binaries to registry rebases image build publish apply create resolve run delete version login completion config (Google ko team Jason Hall Matt Moore, Go); cobra
# upstream: https://ko.build/

_ko-cli() {
    local -a sub=(
        'apply:apply YAML with ko refs replaced'
        'build:build Go binary into image'
        'completion:generate shell completion'
        'create:create resources from manifest with refs replaced'
        'delete:delete resources'
        'login:login to a registry'
        'publish:build and publish image'
        'resolve:resolve YAML refs'
        'run:run an image'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-f+[filename or directory]:_files' \
        '*-f+[filename]:_files' \
        '--filename=+[file]:_files' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-l+[selector]:str:' \
        '--selector=+[sel]:str:' \
        '-W[enable watch]' \
        '--watch[watch]' \
        '-B[disable base import paths]' \
        '--base-import-paths[base import paths]' \
        '-P[preserve import paths]' \
        '--preserve-import-paths[preserve import paths]' \
        '-L[load into local docker daemon]' \
        '--local[load local docker]' \
        '--tags=+[tags]:str:' \
        '*--tags=+[tag]:str:' \
        '-t+[tag]:str:' \
        '*-t+[tag]:str:' \
        '--platform=+[os/arch]:str:' \
        '*--platform=+[os/arch]:str:' \
        '--sbom=+[t]:t:(none cyclonedx go.version-m spdx)' \
        '--sbom-dir=+[dir]:dir:_files -/' \
        '--insecure-registry[allow insecure registry]' \
        '--push=+[v]:v:(true false)' \
        '--base-image=+[image]:str:' \
        '--bare[bare image]' \
        '--debug[debug]' \
        '--image-refs=+[file]:file:_files' \
        '--working-directory=+[dir]:dir:_files -/' \
        '--disable-optimizations[disable optimizations]' \
        '--trimpath=+[v]:v:(true false)' \
        '--gobuild-script=+[file]:_files' \
        '--builder-name=+[name]:str:' \
        '--auth-config=+[file]:file:_files' \
        '-o+[output format]:f:(json yaml)' \
        '--oci-layout-path=+[dir]:dir:_files -/' \
        '--tarball=+[file]:file:_files -g "*.tar"' \
        '--tag-only[only print tag]' \
        '--keychain=+[k]:k:(google github amazon azure)' \
        '*--keychain=+[k]:k:(google github amazon azure)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ko subcommand' sub ;;
        args)
            case $words[1] in
                build|publish|run) _arguments '*:import path:' ;;
                apply|create|delete|resolve) _arguments '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                login) _arguments '1:registry:' ;;
            esac
            ;;
    esac
}

_ko-cli "$@"
