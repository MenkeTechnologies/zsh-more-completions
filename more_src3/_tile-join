#compdef tile-join
# Documentation: https://github.com/mapbox/tippecanoe
# Source: mapbox/tippecanoe tile-join.cpp — merge/filter .mbtiles tilesets (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --output)'{-o+,--output=}'[output mbtiles file]:file:_files -g "*.mbtiles"' \
    '(-e --output-to-directory)'{-e+,--output-to-directory=}'[output to directory]:dir:_files -/' \
    '(-f --force)'{-f,--force}'[overwrite the output if it exists]' \
    '(-i --if-matched)'{-i,--if-matched}'[only output if a join CSV row was found]' \
    '(-A --attribution)'{-A+,--attribution=}'[set attribution string]:text:_default' \
    '(-n --name)'{-n+,--name=}'[set tileset name]:name:_default' \
    '(-N --description)'{-N+,--description=}'[set tileset description]:text:_default' \
    '*'{-p+,--prevent=}'[prevent specific behavior]:flag:_default' \
    '(-c --csv)'{-c+,--csv=}'[join CSV]:file:_files -g "*.csv"' \
    '*'{-x+,--exclude=}'[exclude attribute]:attribute:_default' \
    '(-X --exclude-all)'{-X,--exclude-all}'[exclude all attributes]' \
    '*'{-l+,--layer=}'[only include named layer]:layer:_default' \
    '*'{-L+,--exclude-layer=}'[exclude named layer]:layer:_default' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
    '(-z --maximum-zoom)'{-z+,--maximum-zoom=}'[max zoom level]:n:_default' \
    '(-Z --minimum-zoom)'{-Z+,--minimum-zoom=}'[min zoom level]:n:_default' \
    '(-J --feature-filter-file)'{-J+,--feature-filter-file=}'[filter file]:file:_files' \
    '(-j --feature-filter)'{-j+,--feature-filter=}'[filter expression]:expr:_default' \
    '*'{-R+,--rename-layer=}'[rename layer (old=new)]:rename:_default' \
    '--no-tile-size-limit[do not limit tile size]' \
    '--no-tile-compression[do not gzip-compress tiles]' \
    '--empty-csv-columns-are-null[treat empty CSV cells as null]' \
    '--no-tile-stats[omit tile statistics]' \
    '*:source mbtiles:_files -g "*.mbtiles"' \
    && ret=0

return ret
