#compdef shipwright-image-processing
# _shipwright-image-processing — Shipwright Build helper that pushes/mutates an OCI image (labels, annotations, timestamp, vuln scan)
# upstream: https://github.com/shipwright-io/build
# Flags from cmd/image-processing/main.go on tip.

_shipwright-image-processing() {
    _arguments \
        '--help[print the help]' \
        '--image=[image name in the container registry]:image:' \
        '--secret-path=[directory containing access credentials]:dir:_files -/' \
        '--insecure[treat the container registry as insecure]' \
        '--push=[push the image contained in this directory]:dir:_files -/' \
        '*--annotation=[annotation to add (key=value)]:kv:' \
        '*--label=[label to add (key=value)]:kv:' \
        '--image-timestamp=[Unix timestamp to set as image creation time]:ts:' \
        '--image-timestamp-file=[file containing a Unix timestamp]:file:_files' \
        '--result-file-image-digest=[file to write the image digest to]:file:_files' \
        '--result-file-image-size=[file to write the image size to]:file:_files' \
        '--result-file-image-vulnerabilities=[file to write the image vulnerabilities to]:file:_files' \
        '--vuln-settings=[vulnerability scan settings JSON]:json:' \
        '--vuln-count-limit=[vulnerability-count limit in scan output]:n:'
}

_shipwright-image-processing "$@"
