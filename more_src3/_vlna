#compdef vlna
# Documentation: vlna usage (CSTeX)
# Source: insert non-breaking ties after short Czech/Slovak words in (La)TeX source.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[filter mode: file1->file2 or stdin->stdout]' \
    '-s[silent: no messages to stderr]' \
    '-r[remove backup temporary files (nofilter mode)]' \
    '-v+[set of letters to add tie (default KkSsVvZzOoUuAI)]:letters:' \
    '-x+[code for tie symbol (default 7E)]:hexcode:' \
    '-m[nomath: ignore math modes]' \
    '-n[noverb: ignore verbatim modes]' \
    '-l[LaTeX mode]' \
    '-w[web mode]' \
    '*:tex file:_files -g "*.(tex|ltx|sty)"' \
    && ret=0

return ret
