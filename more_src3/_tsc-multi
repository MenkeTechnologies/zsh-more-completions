#compdef tsc-multi
# _tsc-multi — build multiple TypeScript projects to multiple targets (tommy351/tsc-multi)
# upstream: https://github.com/tommy351/tsc-multi
# Flags from src/cli.ts (yargs .options).

_tsc-multi() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-w --watch)'{-w,--watch}'[watch files and rebuild on change]' \
        '--clean[delete built files (requires rootDir)]' \
        '--verbose[print debug logs]' \
        '--dry[show what would be done without building]' \
        '--force[rebuild all projects]' \
        '--cwd=[current working directory]:dir:_files -/' \
        '--config=[config file path (default $CWD/tsc-multi.json)]:file:_files -g "*.json"' \
        '--compiler=[custom TypeScript compiler]:file:_files' \
        '--maxWorkers=[max concurrent workers]:n:' \
        '*:project or tsconfig.json:_files'
}

_tsc-multi "$@"
