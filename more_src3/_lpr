#compdef lpr
# Documentation: https://manpages.debian.org/lpr
# Source: OpenPrinting/cups berkeley/lpr.c — BSD-style print client (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-U+[username for authentication]:user:_users' \
    '-H+[connect to CUPS server[:port]]:host:_hosts' \
    '-P+[destination printer or class]:printer:_default' \
    '-C+[job class banner]:class:_default' \
    '-J+[job name]:name:_default' \
    '-T+[title for pr]:title:_default' \
    '-i+[indent]:n:_default' \
    '-w+[page width]:n:_default' \
    '-#+[number of copies]:n:_default' \
    '-c[CIFPLOT input]' \
    '-d[DVI input]' \
    '-f[FORTRAN input]' \
    '-g[plot input]' \
    '-n[ditroff input]' \
    '-t[troff input]' \
    '-v[raster image input]' \
    '-l[literal/raw input]' \
    '-p[prettyprint]' \
    '-h[suppress burst page]' \
    '-s[do not use symlinks]' \
    '-m[mail on completion]' \
    '-q[queue file but do not print]' \
    '-r[remove file after printing]' \
    '*-o+[print option]:name=value:_default' \
    '*:file:_files' \
    && ret=0

return ret
