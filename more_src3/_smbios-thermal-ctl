#compdef smbios-thermal-ctl
# Documentation: https://man.archlinux.org/man/extra/libsmbios/smbios-thermal-ctl.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smbios-thermal-ctl: Dell USTT/AAC thermal mode control via SMBIOS
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[show program version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --info)'{-i,--info}'[display supported features of USTT and AAC]' \
  '(-g --get-thermal-info)'{-g,--get-thermal-info}'[display thermal information of system]' \
  '--set-thermal-mode=[set thermal mode]:mode:(balanced cool-bottom quiet performance)' \
  '(-v --verbose)'{-v,--verbose}'[display more verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[minimize program output]' \
  '--trace[enable verbose function tracing]' \
  '--logconfig=[alternate config log]:file:_files' \
  '--security-key=[BIOS pre-calculated security key]:key:' \
  '--password=[BIOS Setup password]:password:' \
  '(-r --rawpassword)'{-r,--rawpassword}'[do not auto-convert password to scancodes]' \
  '--memory-dat=[memory dump file]:file:_files' \
  '--cmos-dat=[CMOS dump file]:file:_files' && ret=0
return ret
