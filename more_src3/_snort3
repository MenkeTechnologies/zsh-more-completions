#compdef snort3 snort
# Documentation: https://github.com/snort3/snort3/blob/master/src/main/snort_module.cc
# Reference accessed: 2026-05-16
# Verified: upstream src/main/snort_module.cc Parameter[] table. ~100 flags;
# common subset listed. Use `snort --help` for the full list.

# snort3: Snort 3 network intrusion detection/prevention system
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-A[set output mode]:mode:' \
  '-B[bind packets to this MAC]:mac:' \
  '-C[print packet payload in ASCII]' \
  '-c[configuration file]:file:_files' \
  '-D[run as daemon]' \
  '-d[dump payload]' \
  '-e[display Ethernet headers]' \
  '-f[fast alert mode]' \
  '-G[set local SID prefix]:n:' \
  '-g[run as group]:group:_groups' \
  '-H[verify reload preprocessor table]' \
  '-i[interface to capture from]:iface:' \
  '-k[checksum mode]:mode:(all noip notcp noudp noicmp none)' \
  '-L[log type]:type:' \
  '-l[logging directory]:dir:_files -/' \
  '-M[log alerts via syslog]' \
  '-Q[enable inline mode]' \
  '-q[quiet]' \
  '-R[include rules file]:file:_files' \
  '-r[read packets from pcap]:file:_files -g "*.pcap"' \
  '-s[snap length]:n:' \
  '-T[test config and exit]' \
  '-t[chroot directory]:dir:_files -/' \
  '-u[run as user]:user:_users' \
  '-v[verbose]' \
  '-y[show year in timestamps]' \
  '--bpf=[BPF filter]:filter:' \
  '--daq=[DAQ module]:module:' \
  '--daq-mode=[DAQ mode]:mode:(passive inline read-file)' \
  '--daq-list[list DAQ modules]' \
  '--pcap-dir=[pcap directory]:dir:_files -/' \
  '--pcap-filter=[pcap filter]:filter:' \
  '--enable-inline-test[enable inline test mode]' \
  '--help-config[show config help]' \
  '--help-module=[show module help]:module:' \
  '--help-modules[list all modules]' \
  '--help-options[show all options]' \
  '--help-plugins[list all plugins]' \
  '--dump-builtin-rules[dump built-in rules]' \
  '--dump-defaults[dump default config]' \
  '--dump-version[dump version info]' \
  '--script-path=[Lua script search path]:path:' \
  '--stdin-rules[read rules from stdin]' \
  '--warn-all[warn about all problems]' && ret=0
return ret
