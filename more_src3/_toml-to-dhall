#compdef toml-to-dhall
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-toml
# Source: dhall-lang/dhall-haskell dhall-toml/src/Dhall/TomlToDhall.hs — convert TOML to Dhall.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--file=[read TOML from FILE instead of stdin]:file:_files' \
    '--output=[write Dhall to FILE instead of stdout]:file:_files' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '1:schema:_files' \
    && ret=0

return ret
