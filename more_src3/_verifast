#compdef verifast vfide
# _verifast — VeriFast: modular separation-logic verifier for C / Rust / Java
# upstream: https://github.com/verifast/verifast
# Flags from src/vfconsole/vfconsole.ml (OCaml Arg.parse).

_verifast() {
    local -a args
    args=(
        '-stats[emit verification statistics]'
        '-json[report result as JSON]'
        '-expect_json_result=[expect JSON result from FILE]:file:_files'
        '-apply_quick_fix=[write VeriFast quick-fix result to FILE]:file:_files'
        '-verbose=[verbose level (-1 file; 1 stmt; 2 prod/cons; 4 SMT)]:level:'
        '-verbose_flag=[enable verbose flag]:flag:(rust_exporter type_pred_defs specializer)'
        '-prover=[SMT prover backend]:prover:(z3 z3v4.5 redux cvc4 external_z3)'
        '-c[compile only; skip link checking]'
        '-shared[file is a library (no main required)]'
        '-allow_assume[allow assume(expr) annotations]'
        '-allow_should_fail[allow //~ annotations marking lines as expected failures]'
        '-allow_ignore_ref_creation[allow //~ignore_ref_creation directives]'
        '-allow_dead_code[allow dead code]'
        '-allow_header=[whitelist a header for inclusion]:header:'
        '-breakpoint=[break symbolic execution at FILE\:LINE]:file\:line:'
        '-focus=[verify only the symbol at FILE\:LINE]:file\:line:'
        '-break_at_node=[break when symbolic execution reaches node spec]:nodes:'
        '-read_options_from_source_file[parse //verifast_options{...} from first line]'
        '-emit_vfmanifest[emit a .vfmanifest file alongside the source]'
        '-check_vfmanifest[verify against an existing .vfmanifest]'
        '-emit_dll_vfmanifest[emit a DLL-style vfmanifest]'
        '-emit_dll_vfmanifest_as=[emit DLL vfmanifest with given name]:name:'
        '-bindir=[set custom bindir with standard library]:dir:_files -/'
        '-vroot=[add a virtual root for include paths (NAME=PATH)]:vroot:'
        '-emit_highlighted_source_files[emit highlighted .html source views]'
        '-dump_per_line_stmt_exec_counts[dump per-line statement execution counts]'
        '-emit_rocq[emit Rocq definitions for foo.rs to foo.v]'
        '-dump_ast=[dump verified module AST to FILE]:file:_files'
        '-dump_ast_with_locs=[dump AST with source locations to FILE]:file:_files'
        '-dump_asts=[dump module + headers ASTs to DIR]:dir:_files -/'
        '-dump_asts_with_locs=[dump module + headers ASTs with locs to DIR]:dir:_files -/'
        '-export=[export path]:path:_files'
        '-provides=[register a `provides` path]:path:_files'
        '-keep_provide_files[keep provide files after linking]'
        '-L+[add directory to manifest search path]:dir:_files -/'
        '-safe_mode[safe mode (for CGI use)]'
        '-link_should_fail[expect linking phase to fail]'
        '-javac[use the Java front end]'
        '-enforce_annotations[enforce annotation requirements]'
        '-rustc_args=[extra rustc command-line arguments (space-separated)]:args:'
        '*:source file:_files -g "*.(c|h|java|rs|jarsrc)"'
    )
    _arguments -s -S $args
}

_verifast "$@"
