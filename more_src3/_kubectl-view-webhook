#compdef kubectl-view-webhook
# Documentation: https://github.com/Trendyol/kubectl-view-webhook
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Uses standard k8s.io/cli-runtime/pkg/genericclioptions.ConfigFlags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[if present, the namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '(-s --server)'{-s+,--server=}'[the address and port of the Kubernetes API server]:server:' \
  '--token=[bearer token for authentication to the API server]:token:' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--client-certificate=[path to a client certificate file for TLS]:file:_files' \
  '--client-key=[path to a client key file for TLS]:file:_files' \
  '--insecure-skip-tls-verify[skip checking server certificate for validity]' \
  '--request-timeout=[length of time before giving up on a single server request]:timeout:' \
  '--tls-server-name=[server name for SNI in the TLS handshake]:name:' \
  '--as=[username to impersonate for the operation]:user:' \
  '--as-group=[group to impersonate for the operation]:group:' \
  '*:webhook name:'
