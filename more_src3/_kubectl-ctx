#compdef kubectl-ctx kubectx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --current)'{-c,--current}'[show current context]' \
  '(-d --delete)'{-d,--delete}'[delete a context]:context:->contexts' \
  '(-u --unset)'{-u,--unset}'[unset current context]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1:context:->contexts' && ret=0

case $state in
  (contexts)
    local -a kube_contexts
    if command -v kubectl &>/dev/null; then
      kube_contexts=(${(f)"$(kubectl config get-contexts -o name 2>/dev/null)"})
    fi
    _describe -t contexts 'kubernetes context' kube_contexts && ret=0
    ;;
esac

return ret
