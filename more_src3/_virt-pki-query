#compdef virt-pki-query virt-pki-validate
# Documentation: https://manpages.debian.org/bookworm/libvirt-clients/virt-pki-validate.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# No `virt-pki-query` binary exists in libvirt-clients; the correct
# upstream tool is `virt-pki-validate`. Both names are accepted via
# #compdef so legacy invocations still complete.

# virt-pki-validate: validate libvirt PKI configuration on a host
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
