#compdef xfs_copy
# Documentation: man xfs_copy(8)
# Source: xfsprogs-dev copy/xfs_copy.c (HEAD) — copy XFS filesystem to one or more targets (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[use buffered I/O (slower, less memory)]' \
    '-d[duplicate (preserve UUID instead of generating new)]' \
    '-L+[log file]:file:_files' \
    '-V[show version]' \
    '1:source device:_files' \
    '*:target device(s):_files' \
    && ret=0

return ret
