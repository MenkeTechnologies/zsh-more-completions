#compdef yozf
# Documentation: https://github.com/MAIF/yozefu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (yozf is the binary name for yozefu).

(( $+functions[_yozefu] )) || autoload -Uz _yozefu 2>/dev/null
if (( $+functions[_yozefu] )); then
  _yozefu "$@"
  return
fi

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cluster=[registered cluster]:cluster:' \
  '--headless[CLI mode]' \
  '--topics=[topics]:topics:' \
  '--format=[format]:format:(json xml text)' && ret=0

return ret
