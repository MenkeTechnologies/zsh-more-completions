#compdef volshell vol.py
# _volshell — interactive Volatility 3 memory analysis shell (volatilityfoundation/volatility3)
# upstream: https://github.com/volatilityfoundation/volatility3
# Flags from volatility3/cli/volshell/__init__.py (argparse).

_volshell() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[JSON config file]:file:_files -g "*.json"' \
        '*'{-e+,--extend=}'[extend config with key=value]:setting:' \
        '(-p --plugin-dirs)'{-p+,--plugin-dirs=}'[semi-colon plugin paths]:paths:' \
        '(-s --symbol-dirs)'{-s+,--symbol-dirs=}'[semi-colon symbol paths]:paths:' \
        '(-o --output-dir)'{-o+,--output-dir=}'[directory for output files]:dir:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[silence default output]' \
        '*'{-v,--verbosity}'[increase verbosity (repeat)]' \
        '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
        '(-f --file)'{-f+,--file=}'[memory image file]:file:_files' \
        '--cache-path=[cache directory]:dir:_files -/' \
        '--clear-cache[clear the cache before running]' \
        '(-u --remote-isf-url)'{-u+,--remote-isf-url=}'[remote ISF URL]:url:' \
        '--offline[do not download ISFs]' \
        '--save-config=[save resolved config to file]:file:_files' \
        '--write-config[write config to disk]' \
        '(--linux --mac --windows)--windows[force Windows OS detection]' \
        '(--linux --mac --windows)--linux[force Linux OS detection]' \
        '(--linux --mac --windows -m --mac)'{-m,--mac}'[force macOS detection]'
}

_volshell "$@"
