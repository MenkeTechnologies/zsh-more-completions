#compdef umpv
# Documentation: https://github.com/mpv-player/mpv/blob/master/TOOLS/umpv
# Reference accessed: 2026-05-21
# Verified: upstream umpv script source. Script doc explicitly states:
# "This only takes filenames as arguments. Custom options can't be used;
# the script interprets them as filenames." No flags supported.
# Removed from prior file: fabricated -h/--help/-v/--version flags.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '*:media file or URL:_files -g "*.(mp4|mkv|webm|avi|mov|flv|wmv|mpg|mpeg|mp3|flac|ogg|opus|m4a|wav|aiff|aac)"' && ret=0

return ret
