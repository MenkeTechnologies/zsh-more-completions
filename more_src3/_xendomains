#compdef xendomains
# Documentation: https://github.com/xen-project/xen/blob/master/tools/hotplug/Linux/init.d/xendomains.in
# Reference accessed: 2026-05-21
# Verified: upstream init script case statement accepts only the actions below.
# Removed prior fabrications: save, shutdown, force-reload.

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:action:(start stop restart reload status)' && ret=0
return ret
