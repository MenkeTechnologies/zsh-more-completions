#compdef lzip lunzip lzcat
# _lzip-bin — lzip LZMA-based lossless compressor (Antonio Diaz Diaz); rigid format with strong integrity checking
# upstream: https://www.nongnu.org/lzip

_lzip-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --trailing-data)'{-a,--trailing-data}'[allow trailing data]' \
        '(-b --member-size)'{-b,--member-size}'+[member size]:bytes:' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-F --recompress)'{-F,--recompress}'[force recompression]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-l --list)'{-l,--list}'[list]' \
        '(-m --match-length)'{-m,--match-length}'+[match length]:n:' \
        '(-n --threads)'{-n,--threads}'+[threads]:n:' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-s --dictionary-size)'{-s,--dictionary-size}'+[dict size]:bytes:' \
        '(-S --volume-size)'{-S,--volume-size}'+[volume size]:bytes:' \
        '(-t --test)'{-t,--test}'[test integrity]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-0)-0[lvl 0]' \
        '(-1)-1[lvl 1]' \
        '(-2)-2[lvl 2]' \
        '(-3)-3[lvl 3]' \
        '(-4)-4[lvl 4]' \
        '(-5)-5[lvl 5]' \
        '(-6)-6[lvl 6 default]' \
        '(-7)-7[lvl 7]' \
        '(-8)-8[lvl 8]' \
        '(-9)-9[best]' \
        '*:file:_files'
}

_lzip-bin "$@"
