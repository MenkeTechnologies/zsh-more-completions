#compdef sveltosctl
# Documentation: https://github.com/projectsveltos/sveltosctl/blob/main/README.md
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a top_cmds=(
  'show:display Sveltos status (addons, resources, usage, dryrun, admin-rbac)'
  'register:register a managed cluster'
  'log-level:manage Sveltos log levels'
  'snapshot:manage cluster configuration snapshots'
  'version:print version'
)

local -a show_cmds=(
  'addons:show deployed add-ons'
  'resources:show resources collected via HealthCheckReport'
  'usage:show ClusterProfile matches and ConfigMap/Secret deployments'
  'dryrun:show dry-run plan'
  'admin-rbac:show tenant admin permissions per cluster'
)

local -a loglevel_cmds=(
  'set:set log level for a component'
  'show:show current log severity settings'
)

local -a register_cmds=(
  'cluster:register a cluster'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds) _describe -t commands 'sveltosctl command' top_cmds && ret=0 ;;
  args)
    case $line[1] in
      show)
        if (( CURRENT == 2 )); then
          _describe -t commands 'show subcommand' show_cmds && ret=0
        else
          _arguments -s -S \
            '--namespace=[filter by cluster namespace]:namespace:' \
            '--cluster=[filter by cluster name]:cluster:' \
            '--profile=[filter by ClusterProfile/Profile]:profile:' \
            '--verbose[enable verbose output]' && ret=0
        fi
        ;;
      register)
        if (( CURRENT == 2 )); then
          _describe -t commands 'register subcommand' register_cmds && ret=0
        else
          _arguments -s -S \
            '--namespace=[cluster namespace]:namespace:' \
            '--cluster=[cluster name]:cluster:' \
            '--fleet-cluster-context=[kubeconfig context]:context:' \
            '--labels=[labels (key=value,key=value)]:labels:' && ret=0
        fi
        ;;
      log-level)
        if (( CURRENT == 2 )); then
          _describe -t commands 'log-level subcommand' loglevel_cmds && ret=0
        else
          _arguments -s -S \
            '--component=[target component]:component:' \
            '--debug[set to debug level]' && ret=0
        fi
        ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
