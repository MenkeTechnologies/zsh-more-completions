#compdef telegram-cli
# Documentation: https://github.com/vysheng/tg/blob/master/debian/telegram-cli.8
# Reference accessed: 2026-05-21
# Verified: upstream debian/telegram-cli.8 manpage in vysheng/tg.
# Removed from prior file: fabricated -h/--help (telegram-cli has no help
# flag in manpage), -e (execute command), -B (binary mode), -T (autoaccept),
# -I (IPv6 toggle), -Z (port — manpage uses -P for port), --version long
# form. Renamed -S (msg dump) -> -S <socket-name> (real meaning).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-u+[username, skips authorization prompt]:user:_users' \
  '-k+[public server key]:file:_files -g "*.pub"' \
  '-v[increase verbosity]' \
  '-N[message num mode]' \
  '-c+[config file name]:file:_files' \
  '-p+[use specified profile]:profile:' \
  '-l+[log level]:level:(0 1 2 3 4 5)' \
  '-f[fetch all messages since registration]' \
  '-E[disable auto-accept of encrypted chats]' \
  '-s+[lua script file]:file:_files -g "*.lua"' \
  '-W[send dialog_list query and wait]' \
  '-C[disable color output]' \
  '-R[disable readline]' \
  '-d[daemon mode]' \
  '-L+[log file name]:file:_files' \
  '-U+[change uid after start]:user:_users' \
  '-G+[change gid after start]:group:_groups' \
  '-D[disable output]' \
  '-P+[port to listen for input commands]:port:' \
  '-S+[unix socket to create]:socket:_files' \
  '*: :' && ret=0

return ret
