#compdef httpdirfs
# Documentation: https://manpages.debian.org/bookworm/httpdirfs/httpdirfs.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httpdirfs - filesystem in userspace for HTTP directory listings (also Airsonic/Subsonic).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[configuration file]:file:_files' \
  '-o+[mount options]:options:' \
  '-f[run in foreground]' \
  '-d[enable debug output]' \
  '-s[single-threaded operation]' \
  '(-u --username)'{-u+,--username=}'[HTTP basic auth username]:username:' \
  '(-p --password)'{-p+,--password=}'[HTTP basic auth password]:password:' \
  '(-P --proxy)'{-P+,--proxy=}'[proxy URL]:url:_urls' \
  '--proxy-username=[proxy username]:username:' \
  '--proxy-password=[proxy password]:password:' \
  '--proxy-cacert=[proxy CA certificate]:file:_files' \
  '--cache[enable local cache]' \
  '--cache-location=[cache directory]:dir:_files -/' \
  '--cacert=[server CA certificate]:file:_files' \
  '--dl-seg-size=[cache download segment size in MB]:MB:' \
  '--max-seg-count=[max download segments]:count:' \
  '--max-conns=[max network connections]:connections:' \
  '--retry-wait=[delay before retrying HTTP requests]:seconds:' \
  '--user-agent=[user agent string]:user agent:' \
  '--no-range-check[disable HTTP range request check]' \
  '--insecure-tls[disable TLS certificate verification]' \
  '--single-file-mode[present single file in virtual directory]' \
  '--sonic-username=[Airsonic/Subsonic username]:username:' \
  '--sonic-password=[Airsonic/Subsonic password]:password:' \
  '--sonic-id3[enable ID3 mode]' \
  '--sonic-insecure[use insecure authentication scheme]' \
  '1:URL:_urls' \
  '2:mountpoint:_files -/' && return 0
