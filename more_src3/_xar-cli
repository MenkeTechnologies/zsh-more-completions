#compdef xar-cli
# _xar-cli — Apple xar eXtensible ARchiver CLI alias (mackyle team, C); custom argparse
# upstream: https://github.com/mackyle/xar

_xar-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--license[show license]' \
        '-c[create archive]' \
        '-x[extract archive]' \
        '-t[list archive]' \
        '--list[list archive]' \
        '-d+[delete file from archive]:str:' \
        '--dump-header[dump xar archive header]' \
        '--dump-toc=+[file]:file:_files' \
        '--list-subdocs[list subdocs]' \
        '--extract-subdoc=+[name]:str:' \
        '--subdoc=+[file]:file:_files' \
        '--subdoc-name=+[name]:str:' \
        '-f+[archive name]:file:_files -g "*.xar"' \
        '--file=+[archive name]:file:_files -g "*.xar"' \
        '-n+[archive name]:file:_files -g "*.xar"' \
        '-C+[directory]:dir:_files -/' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--toc-cksum=+[algorithm]:a:(none md5 sha1 sha256 sha512)' \
        '--file-cksum=+[algorithm]:a:(none md5 sha1 sha256 sha512)' \
        '--exclude=+[regex]:str:' \
        '--no-toc[do not include toc]' \
        '--compression=+[algorithm]:a:(none gzip bzip2 lzma xz)' \
        '--compression-args=+[args]:str:' \
        '-a[no atime preservation]' \
        '--sig-cert=+[file]:file:_files' \
        '--sig-private=+[file]:file:_files' \
        '--strip-components=+[count]:n:' \
        '--with-toc=+[file]:file:_files' \
        '--prop-include=+[prop]:str:' \
        '--prop-exclude=+[prop]:str:' \
        '*:files:_files'
}

_xar-cli "$@"
