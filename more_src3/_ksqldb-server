#compdef ksqldb-server ksql-server-start ksql-server-stop
# _ksqldb-server — Confluent ksqldb-server REST API and processing server for ksqlDB SQL stream-processing engine on Apache Kafka with Kafka Streams query plans materialised views (confluentinc team, Java); CLI properties
# upstream: https://github.com/confluentinc/ksql

_ksqldb-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-daemon[run as daemon]' \
        '--daemon[run as daemon]' \
        '-name+[ksql service id]:str:' \
        '--name=+[ksql service id]:str:' \
        '-loggc[enable GC log]' \
        '--loggc[enable GC log]' \
        '--property=+[key=value]:str:' \
        '--props-file=+[file]:file:_files -g "*.properties"' \
        '--no-color[no color]' \
        '*:properties file:_files -g "*.properties *.conf"'
}

_ksqldb-server "$@"
