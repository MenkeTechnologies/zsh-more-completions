#compdef create-hono
# Documentation: https://github.com/honojs/create-hono
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-t --template)'{-t+,--template=}'[template to use]:template:(aws-lambda bun cloudflare-pages cloudflare-workers deno fastly lambda-edge netlify nextjs nodejs vercel)' \
  '(-i --install)'{-i,--install}'[install dependencies after cloning]' \
  '(-p --pm)'{-p+,--pm=}'[package manager]:pm:(npm yarn pnpm bun deno)' \
  '(-o --offline)'{-o,--offline}'[use local template cache]' \
  '1:project name:' && ret=0

return ret
