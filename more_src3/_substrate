#compdef substrate substrate-node node-template parity-substrate
# _substrate — Parity Technologies substrate node-template generic Substrate blockchain framework node binary (paritytech team, Rust); clap-derive
# upstream: https://github.com/paritytech/polkadot-sdk

_substrate() {
    local -a sub=(
        'key:key subcommands'
        'verify:verify a signature'
        'vanity:generate vanity address'
        'sign:sign a message'
        'build-spec:build chain spec'
        'check-block:check a block'
        'export-blocks:export blocks'
        'export-state:export state'
        'import-blocks:import blocks'
        'revert:revert state'
        'purge-chain:purge chain database'
        'chain-info:show chain info'
        'inspect:inspect storage'
        'benchmark:benchmark subcommands'
        'try-runtime:try runtime upgrades'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--chain=+[chain spec]:c:(dev local staging polkadot kusama westend rococo)' \
        '-d+[base path]:dir:_files -/' \
        '--base-path=+[base path]:dir:_files -/' \
        '--dev[dev mode]' \
        '--alice[insert Alice keys]' \
        '--bob[insert Bob keys]' \
        '--charlie[insert Charlie keys]' \
        '--dave[insert Dave keys]' \
        '--eve[insert Eve keys]' \
        '--ferdie[insert Ferdie keys]' \
        '--validator[run as validator]' \
        '--no-grandpa[disable GRANDPA]' \
        '--name=+[node name]:str:' \
        '--telemetry-url=+[telemetry url]:str:' \
        '--no-telemetry[disable telemetry]' \
        '--port=+[p2p port]:port:_ports' \
        '--listen-addr=+[multiaddr]:str:' \
        '--bootnodes=+[bootnode]:str:' \
        '--reserved-nodes=+[reserved peer]:str:' \
        '--reserved-only[reserved only]' \
        '--public-addr=+[public multiaddr]:str:' \
        '--no-mdns[disable mDNS]' \
        '--node-key=+[node key]:str:' \
        '--node-key-file=+[node key file]:file:_files' \
        '--rpc-port=+[rpc port]:port:_ports' \
        '--rpc-external[expose rpc externally]' \
        '--rpc-cors=+[origin]:str:' \
        '--ws-port=+[ws port]:port:_ports' \
        '--ws-external[expose ws externally]' \
        '--prometheus-port=+[port]:port:_ports' \
        '--prometheus-external[expose prometheus externally]' \
        '--no-prometheus[disable prometheus]' \
        '--unsafe-rpc-external[unsafe rpc external]' \
        '--unsafe-ws-external[unsafe ws external]' \
        '--in-peers=+[N]:n:' \
        '--out-peers=+[N]:n:' \
        '--pool-limit=+[N]:n:' \
        '--pruning=+[mode]:m:(archive constrained 256 1024)' \
        '--state-pruning=+[mode]:m:(archive 256 1024)' \
        '--blocks-pruning=+[mode]:m:(archive 256 1024)' \
        '--db-cache=+[MiB]:n:' \
        '--execution=+[strategy]:s:(native wasm both nativeelsewasm)' \
        '--wasm-execution=+[mode]:m:(interpreted compiled)' \
        '--max-runtime-instances=+[N]:n:' \
        '--keystore-path=+[dir]:dir:_files -/' \
        '--keystore-uri=+[uri]:str:' \
        '--log=+[directives]:str:' \
        '-l+[directives]:str:' \
        '--detailed-log-output[detailed log output]' \
        '--disable-log-color[disable log color]' \
        '--enable-log-reloading[enable log reloading]' \
        '--tracing-targets=+[targets]:str:' \
        '--tracing-receiver=+[receiver]:r:(log telemetry)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'substrate subcommand' sub ;;
        args)
            case $words[1] in
                key) _arguments '1:key cmd:(generate generate-node-key insert inspect inspect-node-key sign verify)' ;;
                benchmark) _arguments '1:benchmark cmd:(pallet overhead block storage extrinsic machine)' ;;
                try-runtime) _arguments '1:try-runtime cmd:(on-runtime-upgrade execute-block follow-chain offchain-worker create-snapshot)' ;;
            esac
            ;;
    esac
}

_substrate "$@"
