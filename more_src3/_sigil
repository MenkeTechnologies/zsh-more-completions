#compdef sigil Sigil
# Documentation: https://github.com/Sigil-Ebook/Sigil
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:epub:_files -g "*.epub"' && ret=0

return ret
