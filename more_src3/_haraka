#compdef haraka
# _haraka — Haraka: Node.js SMTP server (haraka/Haraka)
# upstream: https://github.com/haraka/Haraka
# Flags from bin/haraka (nopt).

_haraka() {
    local -a args
    args=(
        '(-v --version)'{-v,--version}'[show version]'
        '(-h --help)'{-h+,--help=}'[show help (or help for NAME)]:topic:'
        '(-c --configs)'{-c+,--configs=}'[path to the configuration directory]:dir:_files -/'
        '(-i --install)'{-i+,--install=}'[copy the default configs into DIR]:dir:_files -/'
        '(-l --list)'{-l,--list}'[list bundled plugins]'
        '*'{-p+,--plugin=}'[generate a new plugin with the given name]:name:'
        '(-f --force)'{-f,--force}'[overwrite existing files when generating]'
        '--qlist[list the outbound queue]'
        '--qstat[print outbound-queue statistics]'
        '--qempty[empty the outbound queue]'
        '--qunstick=[force delivery for the given domain]:domain:'
        '--graceful[graceful shutdown]'
        '(-o --order)'{-o,--order}'[show registered plugins and their run order]'
        '*'{-t+,--test=}'[plugin test mode]:plugin:'
        '--ip=[IP to use in plugin test mode]:ip:'
        '--helo=[HELO to use in plugin test mode]:hostname:'
        '--ehlo=[EHLO to use in plugin test mode]:hostname:'
        '--envfrom=[envelope MAIL FROM to use in plugin test mode]:address:'
        '*--envrcpt=[envelope RCPT TO to use in plugin test mode]:address:'
        '--message=[message file to use in plugin test mode]:file:_files'
        '--dump-mime[dump the MIME structure and body text]'
        '--dump-stream[dump the MessageStream to stdout]'
        '--skip-deny[continue running hooks after DENY/DENYSOFT]'
        '--set-relay[set connection.relaying in plugin test mode]'
        '--verbose[verbose output]'
        ':haraka path:_files -/'
    )
    _arguments -s -S $args
}

_haraka "$@"
