#compdef smtp-server smtp-server.py python-smtpd aiosmtpd
# _smtp-server — Python aiosmtpd / smtpd reference SMTP server (small libraries that expose smtp-server / python-smtpd CLI wrappers; -p listen port, -l listen address, -h help, -d debug, -n no PROXY, -s slow handler, --version; takes no positional args, useful for inbox testing)
# upstream: https://github.com/aio-libs/aiosmtpd
# Flags from aio-libs/aiosmtpd aiosmtpd/main.py on tip.

_smtp-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-p+[listen port]:port:' \
        '--port+[listen port]:port:' \
        '-l+[listen address]:addr:' \
        '--listen+[listen address]:addr:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-n[no PROXY support]' \
        '-s[slow handler]' \
        '--no-decode-data[no decode data]' \
        '--no-server-cert[no server cert]' \
        '-c+[class]:class:'
}

_smtp-server "$@"
