#compdef tincd
# Documentation: https://www.tinc-vpn.org/documentation/Runtime-options.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-c --config)'{-c,--config=}'[read config from dir]:dir:_files -/' \
  '(-D --no-detach)'{-D,--no-detach}'[do not fork and detach]' \
  '(-d --debug)'{-d,--debug=}'[set debug level]:level:' \
  '(-k --kill)'{-k,--kill=}'[kill running tincd, optional signal]:signal:' \
  '(-n --net)'{-n,--net=}'[use config for netname]:name:' \
  '(-K --generate-keys)'{-K,--generate-keys=}'[generate RSA keypair (default 2048 bits)]:bits:' \
  '*'{-o,--option=}'[set option HOST.KEY=VALUE or KEY=VALUE]:option:' \
  '(-L --mlock)'{-L,--mlock}'[lock tinc into main memory]' \
  '--logfile=[log to file instead of syslog]:file:_files' \
  '--pidfile=[PID file path]:file:_files' \
  '--bypass-security[disable encryption/authentication (debug only)]' \
  '(-R --chroot)'{-R,--chroot}'[change process root directory]' \
  '(-U --user)'{-U,--user=}'[switch to user after init]:user:_users' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]'
