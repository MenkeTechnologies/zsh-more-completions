#compdef trojan
# Documentation: https://github.com/trojan-gfw/trojan/blob/master/src/main.cpp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.json *.yaml *.yml"' \
  '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
  '(-k --keylog)'{-k+,--keylog=}'[TLS keylog file]:file:_files' \
  '(-t --test)'{-t,--test}'[test config file and exit]' \
  '*: :' && ret=0

return ret
