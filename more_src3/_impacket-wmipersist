#compdef impacket-wmipersist
# Documentation: https://github.com/fortra/impacket/blob/master/examples/wmipersist.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-wmipersist: create/remove WMI event consumer/filter persistence
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-com-version[DCOM version (MAJOR:MINOR)]:ver:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (hex)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '1:target (DOMAIN/user[:password]@host):' \
  '2:action:->action' \
  '*::action args:->actargs' && ret=0

case $state in
  action)
    _values 'action' \
      'install[create event consumer/filter]' \
      'remove[remove event consumer/filter]' \
      'list[list event consumers/filters]' && ret=0
    ;;
  actargs)
    case $line[2] in
      install)
        _arguments \
          '-name[event name]:name:' \
          '-vbs[VBS script file]:file:_files' \
          '-filter[WQL filter string]:wql:' \
          '-timer[milliseconds interval]:ms:' && ret=0
        ;;
      remove)
        _arguments '-name[event name]:name:' && ret=0
        ;;
    esac
    ;;
esac
return ret
