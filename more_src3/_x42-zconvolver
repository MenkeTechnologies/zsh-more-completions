#compdef x42-zconvolver zconvolver
# _x42-zconvolver — Robin Gareus x42 zconvolver standalone JACK convolution app and LV2 plugin for impulse-response cabinet and room reverb processing (x42 team, C++); GOption
# upstream: https://github.com/x42/convoLV2

_x42-zconvolver() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-J+[jack client name]:str:' \
        '--jack-name=+[jack client name]:str:' \
        '-S+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[autoconnect]' \
        '--autoconnect[autoconnect]' \
        '-N[no autoconnect]' \
        '--no-autoconnect[no autoconnect]' \
        '-i+[input file]:file:_files -g "*.wav *.flac *.aiff *.aif"' \
        '--ir=+[input IR]:file:_files -g "*.wav *.flac *.aiff *.aif"' \
        '-c+[channels mode]:m:(mono stereo true-stereo)' \
        '--channels=+[channels mode]:m:(mono stereo true-stereo)' \
        '-g+[gain dB]:f:' \
        '--gain=+[gain dB]:f:' \
        '-D+[dry %]:f:' \
        '--dry=+[dry %]:f:' \
        '-W+[wet %]:f:' \
        '--wet=+[wet %]:f:' \
        '-p+[predelay ms]:f:' \
        '--predelay=+[predelay ms]:f:' \
        '-s+[scale]:f:' \
        '--scale=+[scale]:f:' \
        '-b+[block size]:n:' \
        '--block-size=+[block size]:n:' \
        '--no-gui[no GUI]' \
        '*:IR file:_files -g "*.wav *.flac *.aiff *.aif"'
}

_x42-zconvolver "$@"
