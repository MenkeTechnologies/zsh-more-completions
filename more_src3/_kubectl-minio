#compdef kubectl-minio
# Documentation: https://github.com/minio/operator/tree/master/kubectl-minio
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:create the MinIO Operator deployment and CRDs'
      'delete:delete the MinIO Operator deployment and CRDs'
      'tenant:manage MinIO tenants (create/delete/expand/info/upgrade)'
      'proxy:create a local proxy to the Operator Console'
      'version:print version'
    )
    _describe -t commands 'kubectl-minio command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      tenant)
        local -a subs=(
          'create:create a MinIO tenant'
          'delete:delete a MinIO tenant'
          'expand:add volumes/nodes to an existing tenant'
          'info:list pools in a tenant'
          'upgrade:upgrade the MinIO image for a tenant'
        )
        _describe -t subs 'tenant subcommand' subs && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
