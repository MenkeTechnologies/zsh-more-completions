#compdef imapsync-cli
# _imapsync-cli — Gilles Lamiral imapsync IMAP-to-IMAP migration tool CLI alias (imapsync team, Perl); custom argparse
# upstream: https://github.com/imapsync/imapsync

_imapsync-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--host1=+[source host]:host:_hosts' \
        '--host2=+[dest host]:host:_hosts' \
        '--port1=+[source port]:port:' \
        '--port2=+[dest port]:port:' \
        '--user1=+[source user]:_users' \
        '--user2=+[dest user]:_users' \
        '--password1=+[source password]:str:' \
        '--password2=+[dest password]:str:' \
        '--passfile1=+[source pass file]:file:_files' \
        '--passfile2=+[dest pass file]:file:_files' \
        '--ssl1[ssl on source]' \
        '--ssl2[ssl on dest]' \
        '--tls1[tls on source]' \
        '--tls2[tls on dest]' \
        '--nossl1[no ssl source]' \
        '--nossl2[no ssl dest]' \
        '--notls1[no tls source]' \
        '--notls2[no tls dest]' \
        '--ssl1_SSL_version=+[ver]:str:' \
        '--ssl2_SSL_version=+[ver]:str:' \
        '--authmech1=+[auth]:m:(LOGIN PLAIN CRAM-MD5 DIGEST-MD5 NTLM XOAUTH XOAUTH2 OAUTHBEARER)' \
        '--authmech2=+[auth]:m:(LOGIN PLAIN CRAM-MD5 DIGEST-MD5 NTLM XOAUTH XOAUTH2 OAUTHBEARER)' \
        '--authuser1=+[auth user]:_users' \
        '--authuser2=+[auth user]:_users' \
        '--proxyauth1[proxy auth]' \
        '--proxyauth2[proxy auth]' \
        '--folder=+[folder]:str:' \
        '--folderfirst=+[folder]:str:' \
        '--folderlast=+[folder]:str:' \
        '--include=+[regex]:str:' \
        '--exclude=+[regex]:str:' \
        '--prefix1=+[prefix]:str:' \
        '--prefix2=+[prefix]:str:' \
        '--regextrans2=+[expr]:str:' \
        '--regexmess=+[expr]:str:' \
        '--regexflag=+[expr]:str:' \
        '--regexpattern1=+[expr]:str:' \
        '--minage=+[days]:n:' \
        '--maxage=+[days]:n:' \
        '--minsize=+[bytes]:n:' \
        '--maxsize=+[bytes]:n:' \
        '--maxbytespersecond=+[bytes/s]:n:' \
        '--maxmessagespersecond=+[msgs/s]:n:' \
        '--syncinternaldates[sync internal dates]' \
        '--idatefromheader[idate from header]' \
        '--noidatefromheader[no idate from header]' \
        '--delete[delete on source]' \
        '--delete2[delete on dest]' \
        '--delete1emptyfolders[delete empty folders on source]' \
        '--delete2folders[delete folders on dest]' \
        '--expunge1[expunge source]' \
        '--expunge2[expunge dest]' \
        '--noexpunge[no expunge]' \
        '--justfolders[only folders]' \
        '--justfoldersizes[only folder sizes]' \
        '--justbanner[only print banner]' \
        '--justconnect[only test connect]' \
        '--justlogin[only test login]' \
        '--addheader[add header]' \
        '--dry[dry run]' \
        '--debug[debug]' \
        '--debugflags[debug flags]' \
        '--debugcontent[debug content]' \
        '--debugimap1[debug imap source]' \
        '--debugimap2[debug imap dest]' \
        '--debugssl[debug ssl]' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--logfile=+[log file]:file:_files' \
        '--nolog[no log]' \
        '--useheader=+[header]:str:' \
        '--subscribed[only subscribed]' \
        '--subscribe[subscribe dest folders]' \
        '--subscribe_all[subscribe all]' \
        '--no-modulesversion[no modules version]' \
        '--pidfile=+[file]:file:_files' \
        '--pidfilelocking[pid file locking]' \
        '--tmpdir=+[dir]:dir:_files -/' \
        '*:arg:'
}

_imapsync-cli "$@"
