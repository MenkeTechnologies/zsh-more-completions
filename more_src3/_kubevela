#compdef vela kubevela
# Documentation: https://kubevela.io/docs/cli/vela/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for KubeVela - Kubernetes application delivery platform.
# Installed binary is `vela`; some users alias it to `kubevela`. Subcommands
# derived from the upstream CLI reference.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-e --env)'{-e+,--env=}'[specify environment name]:environment:' \
  '(-n --namespace)'{-n+,--namespace=}'[specify namespace]:namespace:' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:create scaffold for an application'
      'up:deploy an application'
      'show:show reference docs for components/traits/policies/workflows'
      'status:show status of an application'
      'ls:list applications'
      'delete:delete an application'
      'env:manage environments'
      'addon:manage KubeVela addons (extensions)'
      'dry-run:test application locally and render Kubernetes resources'
      'live-diff:compare application versions'
      'logs:stream application logs'
      'port-forward:route local ports to service endpoints'
      'exec:run commands in containers'
      'revision:manage application revisions'
      'debug:debug running applications'
      'policy:view and test application policies'
      'workflow:manage application delivery workflows'
      'adopt:import existing resources into applications'
      'uischema:manage UI schemas'
      'component:list and discover components'
      'trait:list and discover traits'
      'def:manage definitions'
      'install:install KubeVela on Kubernetes'
      'uninstall:remove KubeVela'
      'system:manage system information and diagnostics'
      'version:print version information'
      'help:help about any command'
    )
    _describe -t commands 'vela command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      help)
        local -a commands=(
          init up show status ls delete env addon dry-run live-diff logs
          port-forward exec revision debug policy workflow adopt uischema
          component trait def install uninstall system version
        )
        _describe -t commands 'vela command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
