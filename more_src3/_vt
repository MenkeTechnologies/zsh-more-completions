#compdef vt
# Documentation: https://github.com/VirusTotal/vt-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cobra-based; ships its own
# completion via `vt completion zsh`). Top-level surface only.
# Removed from prior file: bogus man.archlinux.org URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'file:retrieve file information'
  'url:retrieve URL information'
  'domain:retrieve domain information'
  'ip:retrieve IP address information'
  'search:Intelligence search'
  'download:download files'
  'scan:submit files/URLs for analysis'
  'analysis:retrieve specific analysis reports'
  'hunting_ruleset:manage LiveHunt YARA rulesets'
  'retrohunt_start:launch retrohunt jobs'
  'retrohunt_matches:retrieve retrohunt matches'
  'init:configure API key interactively'
  'completion:generate shell completion'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --apikey)'{-k+,--apikey=}'[VirusTotal API key]:key:' \
  '--format=[output format]:format:(yaml json csv)' \
  '(-i --include)'{-i+,--include=}'[include fields (path pattern)]:pattern:' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude fields (path pattern)]:pattern:' \
  '--proxy=[HTTP proxy URL]:url:' \
  '1: :->cmd' \
  '*::arg:_default' && ret=0

case $state in
  (cmd) _describe -t commands 'vt command' commands && ret=0 ;;
esac

return ret
