#compdef xmp
# Documentation: https://manpages.debian.org/bookworm/xmp/xmp.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-a+,--amplify=}'[mixer amplification 0-3]:factor:(0 1 2 3)' \
  {-b+,--bits=}'[mixer resolution]:bits:(8 16)' \
  {-c,--stdout}'[mix to stdout]' \
  {-C,--show-comments}'[display comments]' \
  {-d+,--driver=}'[output driver]:driver:' \
  '-D+[device-specific parameter]:parameter:' \
  {-e+,--player-mode=}'[force tracker emulation]:mode:' \
  {-f+,--frequency=}'[sampling rate Hz]:rate:(8000 11025 22050 44100 48000)' \
  {-F,--nofilter}'[disable IT lowpass filter]' \
  {-i+,--interpolation=}'[interpolation method]:type:' \
  {-l,--loop}'[loop module]' \
  '--loop-all[loop entire module list]' \
  {-L,--list-formats}'[list supported formats]' \
  {-m,--mono}'[mono output]' \
  '*'{-M+,--mute=}'[mute channels]:channels:' \
  {-N,--null}'[discard output]' \
  {-o+,--output-file=}'[output to file]:file:_files' \
  {-P+,--pan=}'[panning amplitude %]:n:' \
  {-R,--random}'[play in random order]' \
  {-s+,--start=}'[start at position]:pos:' \
  '*'{-S+,--solo=}'[solo channels]:channels:' \
  {-t+,--time=}'[max playing time s]:seconds:' \
  {-u,--unsigned}'[unsigned samples for file output]' \
  {-v,--verbose}'[verbose output]' \
  {-x,--classic}'[use classic mixers]' \
  {-z+,--sequence=}'[play specific subsong]:n:' \
  {-Z,--all-sequences}'[play all subsongs]' \
  '--fix-sample-loop[halve loop start values]' \
  '--load-only[load and exit]' \
  '--mixer-voices=[max virtual channels]:n:' \
  '--nocmd[disable interactive commands]' \
  '--probe-only[exit after device probe]' \
  '--vblank[force Amiga vblank timing]' \
  '*:tracker module:_files' && ret=0

return ret
