#compdef zenoh-bridge-dds
# Documentation: https://github.com/eclipse-zenoh/zenoh-plugin-dds/blob/master/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zenoh DDS bridge: bridge Cyclone DDS to Zenoh
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files -g "*.json5"' \
  '(-m --mode)'{-m,--mode=}'[session mode]:mode:(peer client)' \
  '*'{-l,--listen=}'[listen endpoint locator]:endpoint:' \
  '*'{-e,--peer=}'[peer locator to connect to]:endpoint:' \
  '--no-multicast-scouting[disable automatic peer/router discovery]' \
  '(-i --id)'{-i,--id=}'[unique zenoh ID hex]:hex:' \
  '--group-member-id=[liveliness supervision ID]:id:' \
  '--rest-http-port=[REST API HTTP port]:port:' \
  '(-d --domain)'{-d,--domain=}'[DDS Domain ID]:id:' \
  '--dds-localhost-only[restrict DDS to localhost]' \
  '--dds-enable-shm[enable DDS shared memory]' \
  '(-f --fwd-discovery)'{-f,--fwd-discovery}'[forward discovery info to remote bridges]' \
  '(-s --scope)'{-s,--scope=}'[scope prefix for DDS traffic]:scope:' \
  '*'{-a,--allow=}'[regex of allowed partition/topic]:regex:' \
  '*--deny=[regex of denied partition/topic]:regex:' \
  '*--max-frequency=[max routing frequency per topic]:freq:' \
  '--queries-timeout=[query timeout in seconds]:secs:' \
  '*'{-w,--generalise-pub=}'[generalise zenoh publications]:keyexpr:' \
  '*'{-r,--generalise-sub=}'[generalise zenoh subscriptions]:keyexpr:' && ret=0
return ret
