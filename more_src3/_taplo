#compdef taplo
# Documentation: https://taplo.tamasfe.dev/cli/introduction.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at github.com/tamasfe/taplo/tree/master/site/site/cli/usage.

# Zsh completion for Taplo TOML toolkit
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '--colors=[colorize output]:mode:(auto always never)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'format:format TOML files'
      'fmt:format TOML files (alias)'
      'check:validate TOML files against schemas'
      'get:get a value from a TOML file'
      'lsp:start the language server'
      'config:manage configuration'
      'completions:generate shell completions'
    )
    _describe -t commands 'taplo command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      format|fmt)
        _arguments -s -S \
          '*'{-o,--option}'=[formatter option override (key=value)]:key=value:' \
          '--check[check formatting without modifying files]' \
          '--force[format documents with syntax errors]' \
          '(- *)'{-h,--help}'[show help message]' \
          '*:file:_files -g "*.toml"' && ret=0
        ;;
      check)
        _arguments -s -S \
          '--schema=[schema URL for validation]:url:' \
          '--schema-catalog=[schema catalog for file matching]:url:' \
          '--default-schema-catalogs[use built-in schema catalogs]' \
          '(- *)'{-h,--help}'[show help message]' \
          '*:file:_files -g "*.toml"' && ret=0
        ;;
      get)
        _arguments -s -S \
          '-f+[input TOML file]:file:_files -g "*.toml"' \
          '-o+[output format]:format:(value json toml)' \
          '(- *)'{-h,--help}'[show help message]' \
          '1:key:' && ret=0
        ;;
      lsp)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '1:transport:(stdio tcp)' \
          '--address=[TCP address (with tcp transport)]:address:' && ret=0
        ;;
      completions)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac
return ret
