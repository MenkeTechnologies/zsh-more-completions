#compdef sqlpage
# Documentation: https://github.com/sqlpage/SQLPage/blob/main/configuration.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# SQLPage is configured via environment variables (SQLPAGE_*) and a config
# file in sqlpage/sqlpage.json. The binary accepts no documented CLI flags
# beyond the standard --help/--version; positional invocation otherwise.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*::arguments: _default' && ret=0

return ret
