#compdef xenstore-watch xenstore-control xenstore-chmod
# Documentation: https://github.com/xen-project/xen/blob/master/docs/man/xenstore-watch.1.pod
#                https://github.com/xen-project/xen/blob/master/docs/man/xenstore-chmod.1.pod
#                https://github.com/xen-project/xen/blob/master/tools/xs-clients/xenstore_control.c
#                https://github.com/xen-project/xen/blob/master/tools/xenstored/control.c
# Reference accessed: 2026-05-21
# Verified: upstream pods plus xenstore_control.c (commands forwarded to xenstored),
# control.c (live-update, log, check, logfile, memreport, print, quota, help).

local curcontext="$curcontext" state line ret=1

case $service in
  (xenstore-watch)
    _arguments -C \
      '(- *)-h[show usage]' \
      '-d+[limit sub-directory depth watched]:depth:' \
      '-n+[stop after receiving NR watch events]:NR:' \
      '*:path:' && ret=0 ;;
  (xenstore-control)
    _arguments -C \
      '1:command:(check log live-update logfile memreport print quota help)' \
      '*: :' && ret=0 ;;
  (xenstore-chmod)
    _arguments -C \
      '(- *)-h[show usage]' \
      '-r[apply permissions to the key and all its children]' \
      '-u[apply permissions to the key and all its parents]' \
      '*: :' && ret=0 ;;
esac

return ret
