#compdef oggenc oggdec ogginfo vorbisgain libvorbis vorbiscomment vorbis-tools
# _libvorbis — Xiph.Org Vorbis oggenc oggdec ogginfo vorbisgain reference Vorbis audio codec encoder decoder utilities (xiph team, C); getopt
# upstream: https://github.com/xiph/vorbis

_libvorbis() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q+[quality -1 to 10]:f:' \
        '--quality=+[quality -1 to 10]:f:' \
        '-b+[bitrate kbps]:n:' \
        '--bitrate=+[bitrate kbps]:n:' \
        '-M+[max bitrate kbps]:n:' \
        '--max-bitrate=+[max bitrate kbps]:n:' \
        '-m+[min bitrate kbps]:n:' \
        '--min-bitrate=+[min bitrate kbps]:n:' \
        '--managed[managed bitrate]' \
        '--resample=+[Hz]:n:' \
        '--downmix[downmix to mono]' \
        '-s+[serial number]:n:' \
        '--serial=+[serial number]:n:' \
        '-R+[Hz]:n:' \
        '--raw-rate=+[Hz]:n:' \
        '-C+[N channels]:n:' \
        '--raw-chan=+[N channels]:n:' \
        '-B+[N bits]:n:' \
        '--raw-bits=+[N bits]:n:' \
        '-r[raw input]' \
        '--raw[raw input]' \
        '--raw-endianness=+[N]:n:(0 1)' \
        '-o+[output file]:file:_files -g "*.ogg *.oga"' \
        '--output=+[output file]:file:_files -g "*.ogg *.oga"' \
        '-n+[output naming]:str:' \
        '--names=+[output naming]:str:' \
        '-c+[comment]:str:' \
        '--comment=+[comment]:str:' \
        '-d+[date]:str:' \
        '--date=+[date]:str:' \
        '-a+[artist]:str:' \
        '--artist=+[artist]:str:' \
        '-N+[track number]:n:' \
        '--tracknum=+[track number]:n:' \
        '-l+[album]:str:' \
        '--album=+[album]:str:' \
        '-G+[genre]:str:' \
        '--genre=+[genre]:str:' \
        '-t+[title]:str:' \
        '--title=+[title]:str:' \
        '--lyrics=+[file]:file:_files' \
        '--lyrics-language=+[lang]:str:' \
        '--ignorelength[ignore length]' \
        '-k[no skeleton]' \
        '--skeleton[skeleton]' \
        '*:input file:_files -g "*.wav *.aiff *.flac *.raw *.ogg *.oga"'
}

_libvorbis "$@"
