# ---------------------------------------------------------------------------
# screego — screen sharing for developers (Go, 10,394★)
#
# upstream: https://github.com/screego/server
# author : Christian Bargmann (cbrgm) + the screego/server collective
# license: GPL-3.0
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from cmd/{command,serve,hash}.go on the screego tip — `urfave/cli` v1
# App + Command + Flag registrations parsed exactly as declared.
#
# Direct deps from go.mod (selected) — screego pulls in the canonical pion
# WebRTC stack directly:
#   github.com/pion/turn/v4         ← TURN server library — relay for
#                                     NAT'd peers; screego embeds it so
#                                     no external TURN server is needed
#   github.com/pion/randutil        (random ID generation for ICE candidates)
#   github.com/pion/dtls/v3         (DTLS handshake for DataChannel SCTP)
#   github.com/pion/stun/v3         (STUN — RFC 5389 binding requests)
#   github.com/pion/transport/v3+v4 (Net abstractions for ICE/TURN/STUN)
#   github.com/pion/logging         (structured logger for pion components)
#   github.com/urfave/cli           (Jeremy Saenz's urfave/cli — the older
#                                    Go CLI framework before Cobra dominated;
#                                    screego pre-dates the cobra migration
#                                    wave so still uses urfave/cli v1 API)
#   github.com/rs/zerolog           (zero-allocation structured logger)
#   golang.org/x/crypto/bcrypt      (password hashing — `screego hash`)
#   golang.org/x/term               (TTY password prompt — `screego hash`)
#
# screego is a self-hosted screen-sharing service for small teams /
# developers / pair-programming: a single binary serves an HTTP/WebSocket
# signaling endpoint AND an embedded TURN relay, peers connect with
# WebRTC DataChannel + screen-capture MediaStream, and the host shares
# their screen to one or many viewers over a single ICE-negotiated peer
# connection.  No cloud, no central server, no Zoom — runs on a $5 VPS.
# All flow control happens via the pion stack: STUN binding requests
# discover external IPs, DTLS secures the channel, SCTP framing carries
# WebRTC data, and the embedded pion/turn server fields TURN-relay
# allocations when peers can't directly reach each other.
#
# === AXIS 170 CONTINUES — pure-language WebRTC stacks (DTLS+ICE+SCTP) ===
# Axis position: Go=225 continues Axis 170 (slot 2/0/0).  Canonical Go
# WebRTC implementation is the `pion/*` organization — Sean DuBois
# (sean-der) + Atsushi Watanabe (at-wat) + the pion collective.  Pion
# was the FIRST production-grade WebRTC stack written outside the Chrome
# libwebrtc C++ codebase, and is now the implementation underneath every
# major Go WebRTC consumer: LiveKit, Janus's go integrations, Twilio's
# media-server experiments, ion-sfu, broadcast-box, screego.  The Rust
# port `webrtc-rs/webrtc` (axis 170 OPENER) is itself a translation of
# the pion API surface — meaning pion is the design ROOT of the
# cross-language WebRTC-in-systems-languages family tree.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=225     _lan-mouse             ← previous round (axis 170 OPENS, 1/0/0)
#   Go=225       ← THIS FILE            (axis 170 continues, slot 2/0/0)
#   TS-Node=225  ← next round           (axis 170 CLOSES at triple-225, 1/1/1)
# ---------------------------------------------------------------------------

_screego() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print the version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'serve:start the HTTP/WS signaling server + embedded pion/turn relay'
                'hash:hash a password into the format used by the users file (bcrypt cost 12)'
                'help:show a list of commands or help for one command'
            )
            _describe -t commands 'screego command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                serve)
                    # serve has no CLI flags — all configuration is via
                    # SCREEGO_* environment variables and / or a config
                    # file at ~/.config/screego/server.config.  See
                    # github.com/screego/server/blob/master/config/config.go
                    # for the full env-var schema (SCREEGO_SERVER_ADDRESS,
                    # SCREEGO_TLS_CERT_FILE, SCREEGO_TLS_KEY_FILE,
                    # SCREEGO_USERS_FILE, SCREEGO_SECRET,
                    # SCREEGO_SESSION_TIMEOUT_SECONDS, SCREEGO_LOG_LEVEL,
                    # SCREEGO_TURN_IP_PROVIDER, SCREEGO_TURN_PORT_RANGE,
                    # SCREEGO_TURN_STRICT_AUTH, etc.).
                    _arguments && ret=0
                    ;;
                hash)
                    _arguments \
                        '--name=[username (required — gets prefixed to the bcrypt hash output as `name:hash`)]:username:' \
                        '--pass=[password (if omitted, read interactively from stdin via golang.org/x/term)]:password:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_screego "$@"
