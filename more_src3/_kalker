#compdef kalker
# Documentation: https://github.com/PaddiM8/kalker
# Reference accessed: 2026-05-19
# Verified: upstream cli/src/main.rs clap args at the URL above.

# Scientific calculator. Corrected from prior file against cli/src/main.rs:
# removed invented --completion, --no-leading-zeroes, --no-notation;
# precision is -p (not bare --precision); added real -a/--angle-unit,
# --eng, -r/--raw, --max-recursion-depth, --no-leading-eq.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --input-file)'{-i,--input-file}'[load a file with predefined variables and functions]:file:_files' \
  '(-p --precision)'{-p,--precision}'[number precision]:digits:' \
  '--eng[engineering mode]' \
  '(-a --angle-unit)'{-a,--angle-unit}'[angle unit]:unit:(rad deg)' \
  '--max-recursion-depth[maximum allowed recursion depth]:depth:' \
  '--no-leading-eq[do not include a leading equal sign in results]' \
  '(-r --raw)'{-r,--raw}'[print only a single number as the result]' \
  '1:expression' && ret=0

return ret
