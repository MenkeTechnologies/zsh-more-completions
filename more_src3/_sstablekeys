#compdef sstablekeys
# Documentation: https://docs.datastax.com/en/cassandra-oss/3.x/cassandra/tools/toolsSStabkeys.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sstablekeys: dump table keys from a Cassandra SSTable Data.db file.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:sstable file:_files -g "*-Data.db"' && ret=0
return ret
