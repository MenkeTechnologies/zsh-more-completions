#compdef jack_midi_dump
# Documentation: https://jackaudio.org/
# Source: jackaudio/jack-example-tools tools/midi_dump.c — dump human-readable JACK MIDI events to stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a -r)-a[absolute timestamps relative to application start]' \
    '(-a -r)-r[relative timestamps to previous MIDI event]' \
    '(- *)-h[display help and exit]' \
    && ret=0

return ret
