#compdef impacket-mssqlinstance
# Documentation: https://github.com/fortra/impacket/blob/master/examples/mssqlinstance.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-mssqlinstance: enumerate MSSQL Browser instances on a target host
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-timeout[response timeout in seconds]:seconds:' \
  '1:host:_hosts' && ret=0
return ret
