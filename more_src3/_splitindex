#compdef splitindex
# Documentation: splitindex --help (0.1 Markus Kohm)
# Source: split a single raw index file into multiple raw index files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-m --makeindex)'{-m+,--makeindex=}'[call PROGNAME instead of makeindex]:program:_command_names -e' \
    '(-i --identify)'{-i+,--identify=}'[regex to match index entries]:regex:' \
    '(-r --resultis)'{-r+,--resultis=}'[pattern for output line content]:pattern:' \
    '(-s --suffixis)'{-s+,--suffixis=}'[pattern for output file suffix]:pattern:' \
    '*'{-v,--verbose}'[be more verbose (repeatable)]' \
    '*:raw index file or makeindex args:_files -g "*.idx"' \
    && ret=0

return ret
