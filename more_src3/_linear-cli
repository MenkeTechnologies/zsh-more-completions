#compdef linear-cli linear
# Documentation: https://github.com/joa23/linear-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Top-level subcommands taken from joa23/linear-cli (token-efficient Linear
# CLI). Other distributions of linear-cli exist (schpet, Finesssee,
# AdiKsOnDev) and use a subset of these names.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authentication management'
  'issues:issue operations (list/get/create/update/comment/react)'
  'issue:alias for issues'
  'i:alias for issues'
  'search:unified search across entities'
  'deps:visualize and manage issue dependencies'
  'projects:project management'
  'project:alias for projects'
  'cycles:cycle operations'
  'cycle:alias for cycles'
  'teams:team information'
  'team:alias for teams'
  'labels:label management'
  'label:alias for labels'
  'users:user queries'
  'user:alias for users'
  'me:current user info'
  'skills:Claude Code skill management'
  'init:initialize project configuration'
  'tasks:export Linear issues to Claude Code task format'
  'config:CLI config helpers'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[output JSON]' \
  '--api-key=[Linear API key (env: LINEAR_API_KEY)]:key:' \
  '--workspace=[active workspace]:workspace:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'linear-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (issues|issue|i)
        _arguments \
          '1:subcommand:(list get create update comment react mine start view pr show delete)' \
          '--mine[only my issues]' \
          '--team=[filter by team]:team:' \
          '--state=[filter by state]:state:' \
          '--priority=[priority filter]:priority:' \
          '--label=[label filter]:label:' \
          '--assignee=[assignee filter]:user:' \
          '--no-assignee[only unassigned]' \
          '--project=[project filter]:project:' \
          '--cycle=[cycle filter]:cycle:' \
          '--title=[issue title]:title:' \
          '--description=[issue description]:desc:' && ret=0 ;;
      (search)
        _arguments '*:query:' && ret=0 ;;
      (deps)
        _arguments '*::sub:(show add remove)' && ret=0 ;;
      (projects|project)
        _arguments '*::sub:(list get create update view show)' && ret=0 ;;
      (cycles|cycle)
        _arguments '*::sub:(list get analyze active view show)' && ret=0 ;;
      (teams|team)
        _arguments '*::sub:(list get labels states members create autolinks)' && ret=0 ;;
      (labels|label)
        _arguments '*::sub:(list create update delete)' && ret=0 ;;
      (users|user)
        _arguments '*::sub:(list get me)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout status)' && ret=0 ;;
      (skills)
        _arguments '*::sub:(list install)' && ret=0 ;;
      (config)
        _arguments '*::sub:(show get set workspace-add workspace-list workspace-switch)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
