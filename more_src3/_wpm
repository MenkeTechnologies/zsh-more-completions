#compdef wpm
# _wpm — measure your typing speed in words per minute (cslarsen/wpm)
# upstream: https://github.com/cslarsen/wpm
# Flags from wpm/commandline.py (argparse).

_wpm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--load-json=[load quotes from JSON file]:file:_files -g "*.json"' \
        '--load=[load quotes from text file]:file:_files' \
        '--tag=[filter by tag]:tag:' \
        '(-s --stats)'{-s,--stats}'[show typing stats from history]' \
        '--cpm[score in characters-per-minute instead of WPM]' \
        '--stats-file=[stats file (default ~/.wpm.csv)]:file:_files' \
        '(-i --id)'{-i+,--id=}'[select quote by id]:id:' \
        '--search=[search quotes by text]:term:' \
        '--short[show only short quotes]' \
        '--monochrome[disable colored output]'
}

_wpm "$@"
