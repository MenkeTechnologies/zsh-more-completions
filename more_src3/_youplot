#compdef youplot uplot
# Documentation: https://github.com/red-data-tools/YouPlot
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o)-o[direct plot to stdout (default stderr)]' \
  '(-O)-O[pass input data to stdout]' \
  '-H[input has a header row]' \
  '-d+[delimiter (default tab)]:delimiter:' \
  '--fmt=[column format]:fmt:(xyy xyxy yx)' \
  '-t+[title]:title:' \
  '-w+[width]:width:' \
  '-h+[height]:height:' \
  '--xlim=[x-axis limits]:xlim:' \
  '--ylim=[y-axis limits]:ylim:' \
  '--nbins=[histogram bins]:bins:' \
  '-c+[color]:color:' \
  '-p[experimental progressive mode]' \
  '--progress[experimental progressive mode]' \
  '--config=[YAML config file]:file:_files' \
  '1:subcommand:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'barplot:draw a horizontal barplot'
      'bar:draw a horizontal barplot'
      'histogram:draw a horizontal histogram'
      'hist:draw a horizontal histogram'
      'lineplot:draw a line chart'
      'line:draw a line chart'
      'lineplots:draw a line chart with multiple series'
      'lines:draw a line chart with multiple series'
      'scatter:draw a scatter plot'
      's:draw a scatter plot'
      'density:draw a density plot'
      'd:draw a density plot'
      'boxplot:draw a horizontal boxplot'
      'box:draw a horizontal boxplot'
      'count:draw a barplot by occurrence count'
      'c:draw a barplot by occurrence count'
      'colors:show list of available colors'
      'color:show list of available colors'
    )
    _describe -t commands 'subcommand' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
