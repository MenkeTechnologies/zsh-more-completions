#compdef unalias
# Documentation: man zshbuiltins (zsh)
# Source: zsh — remove aliases (regular, global, or suffix).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a -s)-a[remove all regular or global aliases]' \
    '(-a -s)-s[remove suffix aliases (with -a removes all)]' \
    '-m[treat names as patterns]' \
    '*:alias:_aliases' \
    && ret=0

return ret
