#compdef lsinfo
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lsinfo.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lsinfo(1) reference.

# lsinfo: show LSF cluster info (types, models, resources)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '-l[long format]' \
  '(-M)-m[show host models in cluster]' \
  '(-m)-M[show all host models from lsf.shared]' \
  '-r[show configured resources]' \
  '-t[show configured host types]' \
  '*:resource:' && ret=0
return ret
