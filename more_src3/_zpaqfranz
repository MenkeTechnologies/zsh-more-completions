#compdef zpaqfranz
# Documentation: https://github.com/fcorbelli/zpaqfranz
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (README + integrated help).
# Includes 7z-like single-letter aliases (a/x/l/t/i/f/s/r/d) plus
# long names (add/extract/list/test/info/find/search/replace/dir/upgrade).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'a:add files to archive (alias for add)'
  'add:add files to archive'
  'x:extract files (alias for extract)'
  'extract:extract files from archive'
  'l:list archive contents (alias for list)'
  'list:list archive contents'
  't:test archive integrity (alias for test)'
  'test:verify archive integrity'
  'i:show archive info (alias for info)'
  'info:display archive information'
  'f:find files in archive (alias for find)'
  'find:find files in archive'
  's:search by substring (alias for search)'
  'search:search by substring'
  'r:replace during extraction (alias for replace)'
  'replace:replace files during extraction'
  'd:directory operations (alias for dir)'
  'dir:directory operations'
  'upgrade:update zpaqfranz itself'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'zpaqfranz command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
