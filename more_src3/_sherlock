#compdef sherlock
# Documentation: https://github.com/sherlock-project/sherlock
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose -d --debug)'{-v,--verbose,-d,--debug}'[verbose/debug output]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-fo --folderoutput)'{-fo+,--folderoutput=}'[output directory]:dir:_directories' \
  '--csv[create CSV report]' \
  '--xlsx[create XLSX report]' \
  '--txt[create TXT report]' \
  '*--site=[specific site to check]:site:' \
  '(-p --proxy)'{-p+,--proxy=}'[proxy URL]:proxy:' \
  '(-j --json)'{-j+,--json=}'[load alternative JSON data]:file:_files' \
  '(-t --timeout)'{-t+,--timeout=}'[request timeout in seconds]:seconds:' \
  '--print-all[print all results (including not found)]' \
  '--print-found[print found results only]' \
  '--no-color[disable colored output]' \
  '(-b --browse)'{-b,--browse}'[browse results in browser]' \
  '(-l --local)'{-l,--local}'[use local data file]' \
  '--nsfw[include NSFW sites]' \
  '--dump-response[dump HTTP responses]' \
  '--ignore-exclusions[ignore site exclusion data]' \
  '*:username:'
