#compdef juicity-server juicity-client
# _juicity — daeuniverse juicity QUIC-based proxy fork of TUIC with multi-user support (juicity team, Go); standard flag package
# upstream: https://github.com/juicity/juicity

_juicity-server() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "*.json"' \
        '--config=+[config file]:file:_files -g "*.json"' \
        '-l+[bind address]:str:' \
        '--listen=+[bind address]:str:' \
        '--certificate=+[cert file]:file:_files -g "*.pem *.crt"' \
        '--private-key=+[key file]:file:_files -g "*.pem *.key"' \
        '--users=+[users json]:str:' \
        '--congestion-control=+[algo]:a:(bbr cubic new_reno)' \
        '--disable-outbounds-protocols=+[protos]:str:' \
        '--fwmark=+[mark]:n:' \
        '--send-through=+[ip]:host:_hosts' \
        '--dial-mode=+[mode]:m:(0 1 2)' \
        '--allow-insecure[allow self-signed certs]' \
        '--cwnd-max=+[N]:n:' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)'
}

_juicity-server "$@"
