#compdef litmus
# Documentation: https://manpages.debian.org/bookworm/litmus/litmus.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# litmus: WebDAV server protocol compliance test suite

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-k --keep-going)'{-k,--keep-going}'[continue testing even if a suite fails]' \
  '(-p --proxy)'{-p,--proxy=}'[use given proxy server URL]:url:' \
  '(-c --client-cert)'{-c,--client-cert=}'[use given PKCS#12 client cert]:cert:_files' \
  '--quiet[compact output format]' \
  '--colour[force colour output]' \
  '--no-colour[disable colour output]' \
  '--system-proxy[use system-defined proxy environment]' \
  '1:URL:_urls' \
  '2:username:_users' \
  '3:password:' && ret=0
return ret
