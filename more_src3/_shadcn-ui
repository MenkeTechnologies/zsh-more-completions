#compdef shadcn shadcn-ui
# Documentation: https://ui.shadcn.com/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_shadcn-ui() {
    local line state
    local -a commands
    commands=(
        'init:Initialize project and install dependencies'
        'add:Add a component to your project'
        'apply:Apply a preset to an existing project'
        'view:View a registry item before installation'
        'search:Search registries for items (alias: list)'
        'list:Alias for search'
        'preset:Manage preset codes'
        'build:Generate the registry JSON files'
        'docs:Get documentation for a component'
        'info:Show project configuration and environment'
        'migrate:Run project transformations'
    )

    _arguments -C \
        '--cwd[Working directory]:dir:_directories' \
        '--silent[Suppress output]' \
        '--help[Show help]' \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'shadcn command' commands
            ;;
        args)
            case $line[1] in
                add)
                    _arguments \
                        '--yes[Skip confirmation prompt]' \
                        '--overwrite[Overwrite existing files]' \
                        '--cwd[Working directory]:dir:_directories' \
                        '--all[Add all available components]' \
                        '--path[Path to add the component to]:path:_files -/' \
                        '--silent[Suppress output]' \
                        '--src-dir[Use src directory]' \
                        '--no-src-dir[Do not use src directory]' \
                        '--css-variables[Use CSS variables]' \
                        '--no-css-variables[Do not use CSS variables]' \
                        '--help[Show help]' \
                        '*:component:'
                    ;;
            esac
            ;;
    esac
}

_shadcn-ui "$@"
