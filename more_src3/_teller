#compdef teller
# Documentation: https://github.com/tellerops/teller
# Reference accessed: 2026-05-21
# Verified: upstream README.
# Removed from prior file: fabricated subcommands 'drift', 'graph', 'mirror'
# (drift exists upstream but mirror/graph are not in README); added 'sh' and
# 'export' subcommands present in upstream README.

# Zsh completion for teller (secrets manager for developers)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new .teller.yml file'
  'run:run a subprocess with secrets injected'
  'show:show current variables with redacted values'
  'sh:shell-compatible variable declarations for eval'
  'env:generate environment file format'
  'scan:search codebase for hardcoded secrets'
  'redact:remove secrets from output/logs'
  'template:populate Tera-formatted templates'
  'copy:sync data between providers'
  'put:write values to providers'
  'delete:remove values from providers'
  'export:output secrets in structured formats'
)

_arguments -s -S \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.yml *.yaml"' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'teller command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments \
          '--reset[reset environment before running]' \
          '--shell[invoke via shell]' \
          '*:command:_command_names -e' && ret=0
        ;;
      (put)
        _arguments '1:key:' '2:value:' && ret=0
        ;;
      (delete)
        _arguments '1:key:' && ret=0
        ;;
      (scan)
        _arguments \
          '--error-if-found[exit non-zero if secrets are found]' \
          '--json[output as JSON]' \
          '-b[binary scan mode]' \
          '*:path:_files' && ret=0
        ;;
      (template)
        _arguments '1:template file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
