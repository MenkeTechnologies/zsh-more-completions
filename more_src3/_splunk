#compdef splunk
# Documentation: https://docs.splunk.com/Documentation/Splunk/latest/Admin/Aboutthecli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Splunk docs.splunk.com blocks automated fetch; cannot verify the
# full subcommand/flag matrix from primary source. Conservative subset
# limited to commonly-documented daemon control commands.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start Splunk daemon'
  'stop:stop Splunk daemon'
  'restart:restart Splunk daemon'
  'status:show daemon status'
  'version:show Splunk version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--accept-license[accept license]' \
  '--answer-yes[answer yes to all prompts]' \
  '--no-prompt[no prompts]' \
  '1: :->subcommand' \
  '*::arg:_default' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'splunk subcommand' subcommands && ret=0
    ;;
esac

return ret
