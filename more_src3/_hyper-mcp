# hyper-mcp — fast, secure MCP server with WebAssembly plugins via Extism/OCI

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--transport=[transport type]:transport:(stdio sse streamable-http)' \
  '--insecure-skip-signature[load unsigned OCI plugins]' \
  '*::arguments:_default'
