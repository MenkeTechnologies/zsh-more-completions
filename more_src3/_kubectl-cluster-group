#compdef kubectl-cluster-group
# Documentation: https://github.com/u2takey/kubectl-clusters
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# cluster-group (u2takey/kubectl-clusters), binary kubectl-cluster-group.
# Usage: kubectl cluster-group [GROUP|all] [KUBECTL_COMMAND ...]
# Groups are defined in a clusters.ini config file; no own flags, the
# kubectl command and args are passed through.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:group:(all)' \
  '*::kubectl command:_default'
