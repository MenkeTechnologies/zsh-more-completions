#compdef tox
# Documentation: https://tox.wiki/en/latest/cli_interface.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'run:run environments'
  'r:run environments'
  'run-parallel:run environments in parallel'
  'p:run environments in parallel'
  'depends:visualize tox environment dependencies'
  'de:visualize tox environment dependencies'
  'list:list environments'
  'l:list environments'
  'devenv:set up a development environment at ENVDIR'
  'd:set up a development environment at ENVDIR'
  'config:show tox configuration'
  'c:show tox configuration'
  'quickstart:quickly create a tox config file'
  'q:quickly create a tox config file'
  'exec:execute an arbitrary command within a tox environment'
  'e:execute an arbitrary command within a tox environment'
  'legacy:legacy entry-point command'
  'le:legacy entry-point command'
  'schema:generate schema for tox configuration'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '(-c --conf)'{-c+,--conf=}'[configuration file/folder]:file:_files -g "*.(ini|toml|cfg)"' \
  '--root=[project root directory]:dir:_files -/' \
  '--workdir=[tox working directory]:dir:_files -/' \
  '(-r --recreate)'{-r,--recreate}'[recreate environments]' \
  '*'{-x+,--override=}'[configuration overrides]:override' \
  '--colored=[enable/disable colored output]:choice:(yes no)' \
  '--result-json=[write JSON results file]:file:_files' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tox subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (run|r|run-parallel|p)
        _arguments \
          '*-e+[run a specific environment]:env' \
          '*-m+[filter by labels]:label' \
          '*-f+[filter by factors]:factor' \
          '--skip-env=[exclude environments matching regex]:regex' \
          '(-n --notest)'{-n,--notest}'[skip test commands]' \
          '(-b --pkg-only)'{-b,--pkg-only}'[packaging only]' \
          '--develop[install in development mode]' && ret=0
        ;;
      (devenv|d)
        _arguments \
          '-e[environment to use]:env' \
          ':directory:_files -/' && ret=0
        ;;
      (depends|de|list|l|config|c|exec|e)
        _arguments \
          '-e[environment]:env' && ret=0
        ;;
    esac
    ;;
esac

return ret
