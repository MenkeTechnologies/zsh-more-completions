#compdef xrdmapc
# Documentation: https://man.archlinux.org/man/xrdmapc.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrdmapc: query CMS manager to map xrootd resources.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  {-f,--format}'+[output format]:format:(text json)' \
  {-l,--list}'+[list scope]:scope:(all m s)' \
  {-q,--quiet}'[do not print error messages to cerr]' \
  {-r,--refresh}'[do not use cached information; refresh the cache]' \
  {-v,--verify}'[verify path existence at each server]' \
  '1:host\:port:_hosts' \
  '2:path:' && ret=0
return ret
