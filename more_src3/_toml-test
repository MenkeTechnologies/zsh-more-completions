#compdef toml-test
# _toml-test — language-agnostic TOML parser conformance tester (toml-lang/toml-test)
# upstream: https://github.com/toml-lang/toml-test
# Subcommands & flags from cmd/toml-test/*.go (zli).

_toml-test() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'test:run a parser/encoder through the test suite'
                'list:list available tests'
                'ls:alias for list'
                'copy:copy tests into a directory'
                'cp:alias for copy'
                'version:print version'
                'help:print help for a topic'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                test)
                    _arguments \
                        '-decoder=[path to decoder binary]:file:_files' \
                        '-encoder=[path to encoder binary]:file:_files' \
                        '-toml=[TOML version to test against]:ver:(1.0.0 1.1.0)' \
                        '-color=[colorize output]:mode:(always never bold html)' \
                        '-parallel=[parallel worker count]:n:' \
                        '-script[output a runnable test script]' \
                        '-int-as-float[accept ints encoded as floats]' \
                        '-errors=[expected error file]:file:_files' \
                        '-timeout=[per-test timeout duration]:duration:' \
                        '-skip-must-err[skip must-error tests]' \
                        '-json[machine-readable JSON output]'
                    ;;
                version) _arguments '-v[show verbose version info]' ;;
            esac
            ;;
    esac
}

_toml-test "$@"
