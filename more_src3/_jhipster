#compdef jhipster
# _jhipster — Spring Boot + Angular/React/Vue web app generator (jhipster/generator-jhipster)
# upstream: https://github.com/jhipster/generator-jhipster
# Flags from cli/program.ts (commander).

_jhipster() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(--force-insight --no-insight)--force-insight[force insight reporting]' \
        '(--force-insight --no-insight)--no-insight[disable insight reporting]' \
        '--force[overwrite every file]' \
        '--dry-run[print conflicts only]' \
        '--whitespace[whitespace changes do not conflict]' \
        '--bail[fail on first conflict]' \
        '--install-path[show jhipster install path]' \
        '--skip-regenerate[do not regenerate identical files]' \
        '--skip-yo-resolve[ignore .yo-resolve files]' \
        '--skip-cache[do not remember prompt answers]' \
        '--skip-install[do not auto-install dependencies]' \
        '--force-install[fail on install dependencies error]' \
        '--ask-answered[show prompts for already configured options]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'app:generate a JHipster application'
                'entity:create a new JPA entity'
                'jdl:apply a JDL file'
                'import-jdl:import a JDL file (deprecated alias)'
                'export-jdl:export current configuration to JDL'
                'spring-controller:generate a Spring controller'
                'spring-service:generate a Spring service'
                'spring-cache-provider:configure cache provider'
                'languages:add new languages'
                'openapi-client:generate openapi clients'
                'ci-cd:configure CI/CD pipeline'
                'upgrade:upgrade JHipster generator'
                'info:get system info for issue reports'
                'init:initialize a new project'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_jhipster "$@"
