#compdef xbps-install
# Documentation: https://man.voidlinux.org/xbps-install.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-A --automatic)'{-A,--automatic}'[set automatic installation mode]' \
  '(-C --config)'{-C,--config}'+[path to XBPS configuration directory]:dir:_directories' \
  '(-c --cachedir)'{-c,--cachedir}'+[path to cache directory]:dir:_directories' \
  '(-D --download-only)'{-D,--download-only}'[only download packages, no install]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-f --force)'{-f,--force}'[force installation/downgrade/reinstall]' \
  '(-I --ignore-file-conflicts)'{-I,--ignore-file-conflicts}'[ignore file conflicts]' \
  '(-i --ignore-conf-repos)'{-i,--ignore-conf-repos}'[ignore repos in configuration files]' \
  '(-M --memory-sync)'{-M,--memory-sync}'[fetch repository data into memory]' \
  '(-n --dry-run)'{-n,--dry-run}'[dry run, show actions only]' \
  '*'{-R,--repository}'+[add repository URL]:url:' \
  '--reproducible[exclude install-date and repository data]' \
  '--staging[enable staged packages from remote repositories]' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-S --sync)'{-S,--sync}'[sync remote repository index]' \
  '(-U --unpack-only)'{-U,--unpack-only}'[unpack only, no configuration]' \
  '(-u --update)'{-u,--update}'[update all installed packages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '(-y --yes)'{-y,--yes}'[assume yes to all questions]' \
  '*:package: ' && ret=0

return ret
