#compdef vkbasalt-cli
# _vkbasalt-cli — DadSchoorse vkBasalt Vulkan post-processing layer CLI alias (DadSchoorse team, C++); custom argparse
# upstream: https://github.com/DadSchoorse/vkBasalt

_vkbasalt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "vkBasalt.conf"' \
        '-c+[config file]:file:_files -g "vkBasalt.conf"' \
        '--effects=+[effect csv]:str:' \
        '--toggle-key=+[key]:str:' \
        '--enable-on-launch=+[bool]:b:(True False)' \
        '--reshade-include-path=+[path]:dir:_files -/' \
        '--reshade-texture-path=+[path]:dir:_files -/' \
        '--depth-capture=+[mode]:b:(on off)' \
        '--cas-sharpness=+[0.0-1.0]:str:' \
        '--dls-sharpness=+[0.0-1.0]:str:' \
        '--dls-denoise=+[0.0-1.0]:str:' \
        '--fxaa-quality-subpix=+[0.0-1.0]:str:' \
        '--fxaa-quality-edge-threshold=+[0.0-1.0]:str:' \
        '--fxaa-quality-edge-threshold-min=+[0.0-1.0]:str:' \
        '--smaa-edge-detection=+[mode]:m:(luma color)' \
        '--smaa-threshold=+[0.0-1.0]:str:' \
        '--smaa-max-search-steps=+[n]:n:' \
        '--smaa-max-search-steps-diag=+[n]:n:' \
        '--smaa-corner-rounding=+[n]:n:' \
        '*:program args:_files'
}

_vkbasalt-cli "$@"
