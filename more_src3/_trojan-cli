#compdef trojan-cli trojan-go
# _trojan-cli — trojan TLS-disguised proxy CLI alias (trojan-gfw team, C++/Go); custom argparse
# upstream: https://github.com/trojan-gfw/trojan

_trojan-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "*.{json,yaml,yml,toml}"' \
        '--config=+[config file]:file:_files -g "*.{json,yaml,yml,toml}"' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-k+[keylog file]:file:_files' \
        '--keylog=+[keylog file]:file:_files' \
        '-t[test config]' \
        '--test[test config]' \
        '*:arg:'
}

_trojan-cli "$@"
