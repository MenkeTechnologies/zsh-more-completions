#compdef hp-uninstall
# Documentation: https://github.com/deepin-community/hplip
# Reference accessed: 2026-05-16
# Verified: upstream deepin-community/hplip uninstall.py.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-uninstall: HPLIP installer uninstaller
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-rest[help in reST format]' \
  '--help-man[help in man format]' \
  '--help-desc[brief description]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '(-g --debug)'{-g,--debug}'[shortcut for -ldebug]' \
  '--gui[run in GUI mode]' \
  '--lang=[language]:lang:' \
  '-n[non-interactive mode (no permission prompts)]' && ret=0
return ret
