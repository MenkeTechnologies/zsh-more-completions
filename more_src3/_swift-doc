#compdef swift-doc
# Documentation: source-direct extraction from upstream
# SwiftDocOrg/swift-doc Sources/swift-doc/main.swift `SwiftDoc:
# ParsableCommand` with `subcommands: [Generate.self,
# Coverage.self, Diagram.self]` + the 3 subcommand source files
# in Sources/swift-doc/Subcommands/ (each is a Swift-Argument-Parser
# `ParsableArguments` struct with `@Option`/`@Argument`/`@Flag`
# property wrappers).
# Reference accessed: 2026-05-30 via gh api.
# SwiftDocOrg swift-doc R137b — Apple Swift documentation
# generator. Built on top of swift-argument-parser; commandName is
# "swift doc" per the CommandConfiguration so it ALSO installs as a
# `swift package` subcommand `swift doc`, but the standalone
# `swift-doc` executable is what this completion covers.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:subcommand:((generate\:generate-documentation coverage\:report-doc-coverage diagram\:generate-symbol-graph-diagram))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      generate)
        _arguments -s -S \
          '(-n --module-name)'{-n+,--module-name=}'[module name (for the documentation header)]:name:' \
          '(-o --output)'{-o+,--output=}'[output path]:dir:_directories' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(html commonmark)' \
          '--base-url=[base URL for relative URLs in generated documents]:url:_urls' \
          '--minimum-access-level=[minimum access level of symbols to include]:level:(private fileprivate internal public open)' \
          '*:input directories with Swift files:_directories' \
          && ret=0
        ;;
      coverage)
        _arguments -s -S \
          '(-o --output)'{-o+,--output=}'[output path for the coverage report]:file:_files' \
          '--minimum-access-level=[minimum access level of symbols considered for coverage]:level:(private fileprivate internal public open)' \
          '*:input directories with Swift files:_directories' \
          && ret=0
        ;;
      diagram)
        _arguments -s -S \
          '--minimum-access-level=[minimum access level of symbols in the diagram]:level:(private fileprivate internal public open)' \
          '*:input directories with Swift files:_directories' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
