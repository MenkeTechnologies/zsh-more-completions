#compdef libgcrypt-config
# Documentation: https://manpages.debian.org/bookworm/libgcrypt20-dev/libgcrypt-config.1.en.html
# Reference accessed: 2026-05-19
# Verified: `libgcrypt-config --help` from installed binary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix[print installation prefix]' \
  '--exec-prefix[print exec prefix]' \
  '--version[show version]' \
  '--api-version[show API version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '--algorithms[show enabled algorithms]' \
  '--host[show host triplet]' && ret=0

return ret
