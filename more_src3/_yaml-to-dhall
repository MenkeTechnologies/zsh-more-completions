#compdef yaml-to-dhall
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-yaml
# Source: dhall-lang/dhall-haskell dhall-yaml/yaml-to-dhall/Main.hs — convert YAML to Dhall.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ytd_cmds
_ytd_cmds=(
    'type:output the inferred Dhall type from a YAML value'
)

_arguments -C \
    '--records-strict[fail if any YAML fields are missing from the expected Dhall type]' \
    '--records-loose[tolerate YAML fields not present in the expected Dhall type]' \
    '--no-keyval-arrays[disable conversion of key-value arrays to records]' \
    '--no-keyval-maps[disable conversion of homogeneous map objects to association lists]' \
    '--omissible-lists[tolerate missing list values, assumed empty]' \
    '--unions-first[accept the first matching union value (default)]' \
    '--unions-none[disallow unions]' \
    '--unions-strict[error if more than one union value matches]' \
    '--file=[read YAML expression from FILE instead of stdin]:file:_files' \
    '--output=[write Dhall expression to FILE instead of stdout]:file:_files' \
    '--ascii[format code using only ASCII syntax]' \
    '--plain[disable syntax highlighting]' \
    '(- *)'{-V,--version}'[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'yaml-to-dhall command' _ytd_cmds && ret=0
        _arguments '1:SCHEMA:_default' && ret=0
        ;;
esac

return ret
