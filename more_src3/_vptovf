#compdef vptovf
# Documentation: vptovf -help (TeX Live 2026)
# Source: kpathsea — translate Virtual Property List (.vpl) into a .vf virtual font + companion .tfm.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '1:vpl input:_files -g "*.vpl"' \
    '2:vf output:_files -g "*.vf"' \
    '3:tfm output:_files -g "*.tfm"' \
    && ret=0

return ret
