#compdef saucectl
# Documentation: https://github.com/saucelabs/saucectl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (internal/cmd directory listing).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'apit:API testing operations'
      'artifacts:fetch job artifacts'
      'builds:list builds'
      'completion:generate shell completion'
      'configure:create credentials.yml'
      'devices:list devices'
      'ini:generate config.yml interactively'
      'jobs:list or inspect jobs'
      'run:execute test suite in Sauce Labs'
      'signup:sign up for a Sauce Labs account'
      'storage:upload and manage app storage'
    )
    _describe -t commands 'saucectl command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
