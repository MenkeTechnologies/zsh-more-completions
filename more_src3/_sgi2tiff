#compdef sgi2tiff
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/sgi2tiff.c — convert SGI RGB image to TIFF (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r+[rows per strip]:rows:_default' \
    '-p+[planar configuration]:config:(contig separate)' \
    '-f+[force FillOrder]:order:(lsb2msb msb2lsb)' \
    '-c+[output compression]:comp:(lzw zip jpeg packbits none)' \
    '1:input.rgb:_files -g "*.{rgb,RGB,sgi}"' \
    '2:output.tif:_files' \
    && ret=0

return ret
