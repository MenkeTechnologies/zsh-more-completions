#compdef testinfra py.test-testinfra
# _testinfra — pytest-testinfra (pytest-based server state validation: --connection picks driver (paramiko/ssh/local/docker/lxc/podman/ansible/kubectl/winrm/saltstack), --hosts comma list, --sudo escalate, --ssh-config picks ssh config)
# upstream: https://github.com/pytest-dev/pytest-testinfra
# Flags from pytest-testinfra testinfra/plugin.py on tip.

_testinfra() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '*-v[verbose]' \
        '--connection+[driver]:driver:(paramiko ssh openssh local docker podman lxc ansible kubectl winrm saltstack chroot)' \
        '*--hosts+[host list]:hosts:_hosts' \
        '--ssh-config+[ssh config]:file:_files' \
        '--ssh-identity-file+[identity file]:file:_files' \
        '--sudo[use sudo]' \
        '--sudo-user+[sudo user]:user:_users' \
        '--ansible-inventory+[inventory]:inventory:_files' \
        '--force-ansible[use Ansible to gather facts]' \
        '--collect-only[collect tests only]' \
        '--lf[run last-failed tests]' \
        '--maxfail+[stop after N failures]:n:' \
        '-k+[expression]:expr:' \
        '-m+[marker]:marker:' \
        '--junit-xml+[junit XML output]:file:_files' \
        '*:test path:_files'
}

_testinfra "$@"
