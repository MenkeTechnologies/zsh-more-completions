#compdef ssmanager
# Documentation: https://github.com/shadowsocks/shadowsocks-rust
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#
# Only flags explicitly documented in the upstream README are listed.
# ssmanager supports many feature-gated options; use `ssmanager -h` for the full list.

_arguments -s \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.json"' \
  '--manager-address=[manager listening address]:addr:' \
  '*-v[verbose]' \
  '(- *)'{-h,--help}'[show help]'
