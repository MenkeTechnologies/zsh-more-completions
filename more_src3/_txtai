#compdef txtai
# _txtai — NeuML txtai semantic search/RAG framework CLI (NeuML, Python); fastapi/uvicorn wrapper
# upstream: https://github.com/neuml/txtai

_txtai() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--config=+[config yaml]:file:_files -g "*.yml *.yaml"' \
        '--host=+[bind host]:host:_hosts' \
        '--port=+[bind port]:port:' \
        '--workers=+[uvicorn workers]:n:' \
        '--reload[reload on changes]' \
        '--log-config=+[uvicorn log config]:file:_files' \
        '--root-path=+[root path]:str:' \
        '--access-log[enable access log]' \
        '--no-access-log[disable access log]' \
        '*:arg:'
}

_txtai "$@"
