#compdef kapacitord
# _kapacitord — InfluxData kapacitord daemon CLI for the TICKscript Kapacitor real-time stream batch alerting engine reading config providing HTTP API loading user-defined functions tasks recordings replays alerts (influxdata team, Go); flag
# upstream: https://github.com/influxdata/kapacitor

_kapacitord() {
    local -a sub=(
        'run:run kapacitord'
        'config:print effective configuration'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-config=+[config file]:file:_files -g "*.toml *.conf"' \
        '--config=+[config file]:file:_files -g "*.toml *.conf"' \
        '-hostname=+[hostname]:str:' \
        '--hostname=+[hostname]:str:' \
        '-pidfile=+[file]:file:_files' \
        '--pidfile=+[file]:file:_files' \
        '-log-file=+[file]:file:_files' \
        '--log-file=+[file]:file:_files' \
        '-log-level=+[level]:l:(DEBUG INFO WARN ERROR FATAL)' \
        '--log-level=+[level]:l:(DEBUG INFO WARN ERROR FATAL)' \
        '-cpu-profile=+[file]:file:_files' \
        '-mem-profile=+[file]:file:_files' \
        '-blockprofile-rate=+[N]:n:' \
        '-mutexprofile-fraction=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kapacitord subcommand' sub ;;
        args) ;;
    esac
}

_kapacitord "$@"
