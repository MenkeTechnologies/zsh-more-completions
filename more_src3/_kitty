#compdef kitty
# Documentation: https://sw.kovidgoyal.net/kitty/invocation/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: --class also aliased --app-id; --name also
# --os-window-tag; added --detached-log, --position, --grab-keyboard,
# --dump-commands, --replay-commands, --dump-bytes, --debug-input;
# removed fabricated --dump-theme/--debug-config/--debug-license.

# Zsh completion for kitty (GPU-accelerated terminal emulator).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(--app-id --class)'{--app-id=,--class=}'[set the WM_CLASS class]:class:' \
  '(--name --os-window-tag)'{--name=,--os-window-tag=}'[set the WM_CLASS name]:name:' \
  '(--title -T)'{--title=,-T+}'[set the OS window title]:title:' \
  '(--config -c)'{--config=,-c+}'[path to the configuration file]:config file:_files' \
  '*'{--override=,-o+}'[override individual configuration options]:option=value:' \
  '(--directory --working-directory -d)'{--directory=,--working-directory=,-d+}'[set the working directory]:directory:_directories' \
  '--detach[detach from the controlling terminal]' \
  '--detached-log=[path to write the log of the detached kitty process to]:file:_files' \
  '--session=[path to a file containing the startup session]:session file:_files' \
  '--hold[remain open after child process exits]' \
  '(--single-instance -1)'{--single-instance,-1}'[run only a single instance of kitty]' \
  '--instance-group=[group for use with single-instance]:group name:' \
  '--wait-for-single-instance-window-close[wait for the single instance window to close]' \
  '--listen-on=[listen on a socket for control messages]:socket address:' \
  '--start-as=[set the initial window state]:state:(normal fullscreen maximized minimized)' \
  '--position=[set the OS window position]:position:' \
  '--grab-keyboard[grab the keyboard]' \
  '(--version -v)'{--version,-v}'[show version]' \
  '--dump-commands[output commands received from child process]' \
  '--replay-commands=[replay previously dumped commands]:file:_files' \
  '--dump-bytes=[path to dump raw bytes received from the child process]:file:_files' \
  '--debug-gl[debug OpenGL]' \
  '--debug-keyboard[print out key events as they are received]' \
  '--debug-rendering[print out rendering commands]' \
  '--debug-input[print out key and mouse events as they are received]' \
  '--debug-font-fallback[print debug information for font fallback selection]' \
  '--watcher=[path to a Python file for custom event handling]:watcher:_files' \
  '1:kitten or command:->subcmd' \
  '*::args:->args' && ret=0

case "$state" in
  subcmd)
    local -a kittens
    kittens=(
      '+kitten:run a kitten'
      '+list-fonts:list available fonts'
      '+runpy:run a Python script'
      '+launch:launch a program in a new kitty window'
      '+edit-config:edit the kitty configuration file'
      '+open:open a file or URL'
      '+complete:output shell completion code'
      '@:control kitty remotely'
    )
    _describe -t commands 'kitty command' kittens && ret=0
    ;;
  args)
    case "${line[1]}" in
      +kitten)
        local -a kitten_names
        kitten_names=(
          'icat:display images in the terminal'
          'diff:a fast side-by-side diff tool'
          'clipboard:copy/paste to the clipboard'
          'unicode_input:input unicode characters'
          'hints:select and act on text matching a regex'
          'themes:change the kitty color theme'
          'ssh:SSH with kitty features'
          'transfer:transfer files'
          'ask:ask the user for input'
          'broadcast:broadcast input to all windows'
          'panel:draw a GPU accelerated panel on your desktop'
          'query_terminal:query the terminal for information'
          'notify:show a desktop notification'
          'hyperlinked_grep:search with clickable results'
          'choose-files:preview and select files'
          'choose-fonts:preview and select fonts'
          'quick-access-terminal:floating quick access terminal'
        )
        _describe -t kittens 'kitten' kitten_names && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
