#compdef s6-svunlink
# _s6-svunlink — s6 supervision s6-svunlink (atomically deregister a service from a scandir; default kills the supervise instance and removes the symlink, -X leaves it running)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-svunlink.c on tip.

_s6-svunlink() {
    _arguments \
        '-X[do not stop the supervise instance; just remove the symlink]' \
        '-t+[timeout (ms)]:ms:' \
        '1:scandir:_files -/' \
        '2:servicename:'
}

_s6-svunlink "$@"
