#compdef ibkr-cli ibkr interactive-brokers ibkr-tws
# _ibkr-cli — Interactive Brokers ibkr-cli CLI command-line frontend wrapping the Interactive Brokers IBKR Client Portal Gateway TWS API managing accounts portfolio positions orders trades market-data scanners alerts contracts options FX futures CFDs warrants secdef historicalData news financial-data fundamentals (Interactive Brokers team, Go); cobra
# upstream: https://www.interactivebrokers.com/

_ibkr-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'portfolio:portfolio operations'
        'position:position operations'
        'order:order operations'
        'trade:trade operations'
        'contract:contract operations'
        'market-data:market data'
        'scanner:scanner operations'
        'alert:alert operations'
        'option:option operations'
        'fx:FX operations'
        'futures:futures operations'
        'cfd:CFD operations'
        'warrant:warrant operations'
        'secdef:security definition'
        'historical:historical data'
        'news:news operations'
        'financial:financial data'
        'fundamental:fundamentals data'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--gateway-url=+[url]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--account=+[id]:str:' \
        '--paper[paper account]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ibkr-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel modify status)' \
                    '--symbol=+[ticker]:str:' \
                    '--side=+[s]:s:(BUY SELL)' \
                    '--order-type=+[t]:t:(MKT LMT STP STP_LMT TRAIL TRAIL_LIMIT MIDPRICE)' \
                    '--quantity=+[N]:n:' \
                    '--price=+[N]:str:' \
                    '--time-in-force=+[t]:t:(DAY GTC IOC FOK OPG)' \
                    '*:order id:' ;;
                account|portfolio|position|trade|contract|alert|option|fx|futures|cfd|warrant|secdef|news|financial|fundamental) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                market-data|historical|scanner) _arguments \
                    '--symbol=+[ticker]:str:' \
                    '--bar-size=+[b]:b:(1min 5min 15min 30min 1hour 1day 1week 1month)' \
                    '--duration=+[d]:str:' ;;
            esac
            ;;
    esac
}

_ibkr-cli "$@"
