#compdef inews
# Documentation: man inews(1)
# Source: InterNetNews/inn frontends/inews.c — post a Usenet article (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[Approved header]:address:_default' \
    '-c+[Control header]:control:_default' \
    '-d+[Distribution header]:dist:_default' \
    '-e+[Expires header]:date:_default' \
    '-f+[From header]:address:_email_addresses' \
    '-F+[References header]:refs:_default' \
    '-m+[Message-ID header]:msgid:_default' \
    '-n+[Newsgroups header]:groups:_default' \
    '-o+[Organization header]:org:_default' \
    '-r+[Reply-To header]:address:_email_addresses' \
    '-t+[Subject header]:subject:_default' \
    '-w+[Followup-To header]:groups:_default' \
    '-D[debug dump article, do not post]' \
    '-N[debug dump article, do not post]' \
    '-E[discard if body empty]' \
    '-O[do not add Organization]' \
    '-P[do not add Sender]' \
    '-R[cancel/revoke (sets Supersedes)]' \
    '-S[do not add signature]' \
    '-Y[force authentication]' \
    '-h[Mode header (h)]' \
    '-p+[NNTP port]:port:_default' \
    '-x+[Path exclusions]:host:_hosts' \
    '-A[ignored (C News compat)]' \
    '-V[ignored (C News compat)]' \
    '-W[ignored (C News compat)]' \
    '-i[ignored (tinews.pl compat)]' \
    '-s[ignored (tinews.pl compat)]' \
    '-X[ignored (tinews.pl compat)]' \
    '-I[do not add Injection-Date]' \
    '-L[do not add Cancel-Key]' \
    '-v[verbose]' \
    '(-)-H[show help]' \
    '1::file:_files' \
    && ret=0

return ret
