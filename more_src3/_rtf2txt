#compdef rtf2txt
# Documentation: eprints rtf2txt
# Source: eprints/eprints3.4 tools/rtf2txt (master) — extract plain text from RTF (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '1:input RTF file:_files -g "*.{rtf,doc}"' \
    '2::output text file:_files -g "*.txt"' \
    && ret=0

return ret
