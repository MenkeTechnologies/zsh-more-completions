#compdef zrythm
# _zrythm — Alexandros Theodotou Zrythm cross-platform digital audio workstation with deep MIDI editing and modular routing (zrythm team, C); custom argparse
# upstream: https://github.com/zrythm/zrythm

_zrythm() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--audio-backend=+[backend]:b:(jack alsa pulseaudio portaudio rtaudio sdl wasapi coreaudio dummy)' \
        '--midi-backend=+[backend]:b:(jack alsa rtmidi wmme wasapi coremidi dummy)' \
        '--buf-size=+[frames]:n:' \
        '--samplerate=+[Hz]:n:' \
        '--dummy[force dummy backends]' \
        '--cyaml-log-level=+[level]:l:(none warning error info debug verbose)' \
        '--log-file=+[log file]:file:_files' \
        '--gen-project=+[project dir]:dir:_files -/' \
        '--print-settings[print settings]' \
        '--reset-to-factory[reset settings]' \
        '--convert-yaml-to-zpj=+[file]:file:_files -g "*.yaml *.yml"' \
        '--convert-zpj-to-yaml=+[file]:file:_files -g "*.zpj"' \
        '--cli[run in CLI mode]' \
        '*:project:_files -g "*.zpj *.yaml"'
}

_zrythm "$@"
