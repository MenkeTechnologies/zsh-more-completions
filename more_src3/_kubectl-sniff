#compdef kubectl-sniff
# Documentation: https://github.com/eldadru/ksniff
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[target namespace]:namespace:' \
  '(-c --container)'{-c+,--container=}'[container name]:container:' \
  '(-i --interface)'{-i+,--interface=}'[pod interface to capture from]:interface:' \
  '(-f --filter)'{-f+,--filter=}'[tcpdump capture filter]:filter:' \
  '(-o --output-file)'{-o+,--output-file=}'[output file (- for stdout)]:file:_files' \
  '(-l --local-tcpdump-path)'{-l+,--local-tcpdump-path=}'[local tcpdump binary path]:path:_files' \
  '(-r --remote-tcpdump-path)'{-r+,--remote-tcpdump-path=}'[remote tcpdump path]:path:' \
  '(-p --privileged)'{-p,--privileged}'[enable privileged mode]' \
  '--image=[sniffer container image]:image:' \
  '--tcpdump-image=[tcpdump container image]:image:' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '1:pod:_default'
