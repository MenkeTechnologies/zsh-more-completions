#compdef kmag
# Documentation: https://man.archlinux.org/man/kmag.1.en
# Reference accessed: 2026-05-19
# Verified: Arch kmag(1) manpage — SYNOPSIS is bare `kmag`, no kmag-
# specific options; only generic kf6options(7)/qt6options(7).
# Removed Qt4-era invented flags: --help-qt, --help-kde,
# --graphicssystem, --display, --platformpluginpath, --reverse, etc.
# STUB: KDE/Qt6 standard options only.

# KMag: KDE screen magnifier
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including Qt]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' && ret=0
return ret
