#compdef stew
# Documentation: https://github.com/marwanhawari/stew
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for stew - binary package manager for GitHub releases

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'install:install a binary from GitHub releases / URL / Stewfile'
      'search:search GitHub repositories'
      'browse:browse available releases for a repository'
      'upgrade:upgrade installed binaries'
      'uninstall:uninstall a binary'
      'rename:rename an installed binary (interactive)'
      'list:list installed binaries'
      'config:configure stew installation paths'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '*:repo or stewfile:_files' \
          && ret=0
        ;;
      (search|browse)
        _arguments \
          '*:repo (owner/name):' \
          && ret=0
        ;;
      (uninstall)
        _arguments \
          '--all[uninstall all binaries]' \
          '*:binary:' \
          && ret=0
        ;;
      (rename)
        _arguments \
          '*:binary:' \
          && ret=0
        ;;
      (upgrade)
        _arguments \
          '--all[upgrade all binaries]' \
          '*:binary:' \
          && ret=0
        ;;
      (list)
        _arguments \
          '--tags[include version tags in output]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
