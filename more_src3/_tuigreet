#compdef tuigreet
# Documentation: https://github.com/apognu/tuigreet
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'=[enable debug logging to file]:file:_files' \
  '(-c --cmd)'{-c,--cmd}'=[default command to run]:command:_command_names' \
  '--env=[set environment variable]:var=value' \
  '(-s --sessions)'{-s,--sessions}'=[Wayland session directories]:dirs' \
  '--session-wrapper=[wrapper for non-X11 sessions]:command:_command_names' \
  '(-x --xsessions)'{-x,--xsessions}'=[X11 session directories]:dirs' \
  '--xsession-wrapper=[wrapper for X11 initialization]:command' \
  '--no-xsession-wrapper[disable X11 session wrapping]' \
  '(-w --width)'{-w,--width}'=[width of prompt container]:width' \
  '(-i --issue)'{-i,--issue}'[show /etc/issue]' \
  '(-g --greeting)'{-g,--greeting}'=[greeting message]:message' \
  '(-t --time)'{-t,--time}'[show current time]' \
  '--time-format=[time format string]:format' \
  '(-r --remember)'{-r,--remember}'[remember last logged-in user]' \
  '--remember-session[remember last session]' \
  '--remember-user-session[remember session per user]' \
  '--user-menu[show user selection menu]' \
  '--user-menu-min-uid=[minimum UID for user menu]:uid' \
  '--user-menu-max-uid=[maximum UID for user menu]:uid' \
  '--theme=[theme string for colors]:theme' \
  '--asterisks[display asterisks for password input]' \
  '--asterisks-char=[character for password masking]:char' \
  '--window-padding=[padding inside window]:padding' \
  '--container-padding=[padding inside container]:padding' \
  '--prompt-padding=[row spacing]:padding' \
  '--greet-align=[greeting alignment]:align:(left center right)' \
  '--power-shutdown=[shutdown command]:command' \
  '--power-reboot=[reboot command]:command' \
  '--power-no-setsid[do not use setsid for power commands]' \
  '--kb-command=[F-key for command menu (1-12)]:key' \
  '--kb-sessions=[F-key for sessions menu (1-12)]:key' \
  '--kb-power=[F-key for power menu (1-12)]:key'
