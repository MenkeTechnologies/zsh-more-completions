#compdef weston-image
# _weston-image — Weston Wayland weston-image CLI demo client opening an image file via gdk-pixbuf or pixman compositing it onto a wl_surface inside the running weston compositor to validate buffer formats damage tracking subsurface transformations for diagnostic visual testing (Weston team, C); getopt
# upstream: https://gitlab.freedesktop.org/wayland/weston

_weston-image() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--fullscreen[fullscreen]' \
        '--maximized[maximized]' \
        '*:image files:_files -g "*.png *.jpg *.jpeg *.bmp *.tiff *.svg *.gif *.webp"'
}

_weston-image "$@"
