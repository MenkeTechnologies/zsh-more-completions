#compdef kubectl-cnf
# Documentation: https://github.com/hedgieinsocks/kubectl-cnf
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (kubectl-cnf script source).

# kubectl-cnf (hedgieinsocks/kubectl-cnf): switch between k8s configs.
# Only -h/--help and -v/--version; all other behavior is via env vars
# (KCNF_DIR, KCNF_NO_SHELL, KCNF_COPY_CLIP, ...). Optional positional is a
# config name substring filter.

_arguments -s -S \
  '(- *)'{-h,--help}'[show this message]' \
  '(- *)'{-v,--version}'[show plugin version]' \
  '*:config filter:_default'
