#compdef llvm-config
# _llvm-config-bin — LLVM build configuration query tool (LLVM project, C++); print compile/link flags for embedding LLVM
# upstream: https://github.com/llvm/llvm-project

_llvm-config-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--assertion-mode[print assertion mode]' \
        '--bindir[print bin dir]' \
        '--build-mode[print build mode]' \
        '--build-system[print build system]' \
        '--cflags[print C compile flags]' \
        '--cmakedir[print cmake dir]' \
        '--components[print all components]' \
        '--cppflags[print C++ preprocessor flags]' \
        '--cxxflags[print C++ compile flags]' \
        '--has-rtti[print rtti status]' \
        '--host-target[print host target triple]' \
        '--ignore-libllvm[ignore libllvm]' \
        '--includedir[print include dir]' \
        '--ldflags[print linker flags]' \
        '--libdir[print library dir]' \
        '--libfiles[print library files]' \
        '--libnames[print library short names]' \
        '--libs[print -l for libraries]' \
        '--link-shared[force shared link]' \
        '--link-static[force static link]' \
        '--obj-root[print build root]' \
        '--prefix[print prefix]' \
        '--shared-mode[print shared mode]' \
        '--src-root[print source root]' \
        '--system-libs[print system libs]' \
        '--targets-built[print built targets]' \
        '*:component:'
}

_llvm-config-bin "$@"
