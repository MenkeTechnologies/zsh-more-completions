#compdef kstart6 kstart5 kstart
# _kstart6 — KDE kstart (launch a program with Plasma window-manager hints applied: --tray system tray, --fullscreen, --maximize, --skiptaskbar, --desktop N, --keepabove/--keepbelow, --windowclass overrides WM_CLASS)
# upstream: https://invent.kde.org/plasma/plasma-workspace (kstart/kstart.cpp)
# Flags from plasma-workspace kstart/kstart.cpp on tip.

_kstart6() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--service+[desktop file]:file:_files -g "*.desktop"' \
        '--application+[application]:app:_command_names -e' \
        '--url+[URL to open]:url:' \
        '--window+[window title]:title:' \
        '--windowclass+[WM_CLASS]:class:' \
        '--desktop+[desktop number]:n:' \
        '--alldesktops[show on all desktops]' \
        '--currentdesktop[show on current desktop]' \
        '--ontop[stay on top]' \
        '--keepabove[keep above other windows]' \
        '--keepbelow[keep below other windows]' \
        '--tray[run in system tray]' \
        '--skiptaskbar[skip taskbar]' \
        '--skippager[skip pager]' \
        '--maximize[maximize on show]' \
        '--minimize[minimize on show]' \
        '--fullscreen[fullscreen on show]' \
        '--type+[window type]:type:(normal dialog menu toolbar splash utility dock desktop override notification)' \
        '*::command:_command_names -e'
}

_kstart6 "$@"
