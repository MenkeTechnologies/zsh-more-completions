#compdef wordgrinder
# Documentation: https://github.com/davidgiven/wordgrinder
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wordgrinder: word processor for the console.
# Upstream README documents only --lua and --recent; other flags are not
# documented and would need a man page reference (not retrievable).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--lua=[run a Lua script]:file:_files -g "*.lua"' \
  '--recent[load the last edited document]' \
  '1:document file:_files -g "*.wg"' && ret=0

return ret
