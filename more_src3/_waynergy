#compdef waynergy
# Documentation: source-direct extraction from upstream
# r-c-f/waynergy src/main.c `static struct sopt optspec[]` table
# (Synergy client uses the libsopt option-parsing library, NOT
# getopt/getopt_long directly). Each `SOPT_INIT*` macro entry was
# decoded for short/long names and help text.
# Reference accessed: 2026-05-30 via gh api.
# r-c-f waynergy R140c — Wayland-native Synergy client (replaces
# the abandoned Barrier project for Wayland users). Connects to a
# Synergy server running on another machine and forwards keyboard/
# mouse events into the local Wayland compositor via wlroots, KDE
# fake-input, or uinput.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --backend)'{-b+,--backend=}'[input backend]:backend:(wlr kde uinput)' \
  '(-c --host)'{-c+,--host=}'[Synergy server host to connect to]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[Synergy server port]:port:' \
  '(-W --width)'{-W+,--width=}'[screen width in pixels (manual override; pair with --height)]:px:' \
  '(-H --height)'{-H+,--height=}'[screen height in pixels (manual override; pair with --width)]:px:' \
  '(-N --name)'{-N+,--name=}'[client screen name (registered with the Synergy server)]:name:' \
  '(-l --logfile)'{-l+,--logfile=}'[log file path]:file:_files' \
  '(-L --loglevel)'{-L+,--loglevel=}'[log verbosity]:level:(0 1 2 3 4 5 6 none error warn info debug debugsyn)' \
  '(-n --no-clip)'{-n,--no-clip}'[do NOT synchronize the clipboard with the server]' \
  '(-e --enable-crypto -E --disable-crypto)'{-e,--enable-crypto}'[enable TLS encryption]' \
  '(-e --enable-crypto -E --disable-crypto)'{-E,--disable-crypto}'[force-disable TLS encryption]' \
  '(-t --enable-tofu)'{-t,--enable-tofu}'[enable trust-on-first-use for TLS certificate pinning]' \
  '--fatal-none[treat normal disconnect (CBYE) as fatal]' \
  '--fatal-ebad[treat protocol errors as fatal]' \
  '--fatal-ebsy[treat EBSY (client name already taken) as fatal]' \
  '--fatal-timeout[treat timeouts as fatal]'
