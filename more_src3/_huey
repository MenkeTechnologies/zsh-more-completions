#compdef huey_consumer huey_consumer.py
# Documentation: https://huey.readthedocs.io/en/latest/consumer.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# huey consumer - run tasks queued via the huey task queue.

local -a arguments

arguments=(
  '(-l --logfile)'{-l+,--logfile=}'[log file path]:file:_files'
  '(-v --verbose)'{-v,--verbose}'[verbose logging (DEBUG)]'
  '(-q --quiet)'{-q,--quiet}'[minimal logging (errors only)]'
  '(-S --simple)'{-S,--simple}'[simple log format]'
  '(-w --workers)'{-w+,--workers=}'[number of workers]:workers:'
  '(-k --worker-type)'{-k+,--worker-type=}'[worker type]:type:(thread process greenlet)'
  '(-n --no-periodic)'{-n,--no-periodic}'[disable periodic task scheduler]'
  '(-d --delay)'{-d+,--delay=}'[polling interval in seconds]:seconds:'
  '(-m --max-delay)'{-m+,--max-delay=}'[max polling interval]:seconds:'
  '(-b --backoff)'{-b+,--backoff=}'[backoff factor for polling]:factor:'
  '(-c --health-check-interval)'{-c+,--health-check-interval=}'[health check interval]:seconds:'
  '(-C --disable-health-check)'{-C,--disable-health-check}'[disable worker health checks]'
  '(-f --flush-locks)'{-f,--flush-locks}'[flush all locks on startup]'
  '(-L --extra-locks)'{-L+,--extra-locks=}'[extra lock names to flush]:locks:'
  '(-M --max-tasks)'{-M+,--max-tasks=}'[restart worker after N tasks]:n:'
  '(-s --scheduler-interval)'{-s+,--scheduler-interval=}'[scheduler check interval]:seconds:'
  '1:huey instance (e.g. app.huey):'
)

_arguments -s -S $arguments
