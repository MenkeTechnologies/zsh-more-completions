#compdef scope-tui
# Documentation: https://github.com/alemidev/scope-tui
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pulse:use PulseAudio Simple api to read from an audio sink'
  'file:use a file from the filesystem and read its content'
  'audio:use new experimental CPAL backend'
  'help:print help message'
)

_arguments -C \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-c --channels)'{-c+,--channels=}'[number of channels to open]:channels:' \
  '(-b --buffer)'{-b+,--buffer=}'[size of audio buffer and width of scope]:size:' \
  '(-r --sample-rate)'{-r+,--sample-rate=}'[sample rate to use]:rate:' \
  '(-t --tune)'{-t+,--tune=}'[tune buffer size to be in tune with given note]:note:' \
  '(-s --scale)'{-s+,--scale=}'[floating point vertical scale (0 to 1)]:scale:' \
  '--scatter[use vintage looking scatter mode instead of line mode]' \
  '--no-reference[do not draw reference line]' \
  '--no-ui[hide UI and only draw waveforms]' \
  '--no-braille[do not use braille dots for drawing lines]' \
  '--palette-color=[palette for scope signal lines]:colors:' \
  '--labels-color=[color for axis labels]:color:' \
  '--axis-color=[color for axis lines]:color:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'scope-tui command' commands && ret=0 ;;
esac

return ret
