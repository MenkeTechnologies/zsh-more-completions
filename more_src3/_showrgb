#compdef showrgb
# Documentation: https://www.x.org/releases/current/doc/man/man1/showrgb.1.xhtml
# Reference accessed: 2026-05-21
# Verified: showrgb is an X11 utility that dumps the RGB color database to
# stdout, optionally from a specified database path argument. Per the X.Org
# manpage synopsis, it takes no options beyond an optional database filename.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:RGB database:_files -g "rgb.txt"' && ret=0

return ret
