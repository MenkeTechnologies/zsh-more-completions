#compdef kjournal kjournaldbrowser
# Documentation: https://invent.kde.org/system/kjournald/-/raw/master/browser/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE kjournald browser main.cpp at the URL above.
# Real binary is kjournaldbrowser; this completion also accepts the
# shorter alias. QCommandLineParser registers only --help, --version
# and -D <path>.

# kjournal/kjournaldbrowser: KDE journald viewer (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-D+[path to journald database folder]:dir:_files -/' && ret=0
return ret
