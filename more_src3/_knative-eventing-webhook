#compdef knative-eventing-webhook
# _knative-eventing-webhook — Knative Eventing admission/conversion webhook (sharedmain)
# upstream: https://github.com/knative/eventing
# Flags from cmd/webhook/main.go + knative.dev/pkg sharedmain on tip.

_knative-eventing-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-eventing-webhook "$@"
