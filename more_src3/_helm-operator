#compdef helm-operator
# Documentation: https://github.com/fluxcd/helm-operator
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (archived project).

# helm-operator: Helm Operator for Kubernetes (archived fluxcd v1 project)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--git-url=[git URL]:url:' \
  '--git-branch=[git branch]:branch:' \
  '--git-path=[git path]:path:' \
  '--git-ci-skip[skip commits with [ci skip]]' \
  '--git-poll-interval=[git poll interval]:duration:' \
  '--git-timeout=[git timeout]:duration:' \
  '--charts-sync-interval=[charts sync interval]:duration:' \
  '--enabled-helm-versions=[enabled Helm versions]:versions:(v3)' \
  '--listen=[listen address]:addr:' \
  '--listen-metrics=[metrics listen address]:addr:' \
  '--log-format=[log format]:fmt:(text fmt json)' \
  '--log-level=[log level]:level:(error warn info debug)' \
  '--workers=[number of workers]:n:' \
  '--tiller-namespace=[tiller namespace]:ns:' \
  '--allow-namespace=[allow namespace]:list:' \
  '--update-chart-deps=[update chart deps]:bool:(true false)' \
  '*::helm-operator args:_files' && ret=0
return ret
