#compdef syz-mutate
# _syz-mutate — generate mutations of syzkaller programs (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-mutate/mutate.go (flag).

_syz-mutate() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-seed=[PRNG seed]:n:' \
        '-len=[number of calls in programs]:n:' \
        '-enable=[comma-separated enabled syscalls]:list:' \
        '-corpus=[corpus file]:file:_files' \
        '-hint-call=[call index to mutate with hints]:n:' \
        '-hint-src=[compared value in the program]:n:' \
        '-hint-cmp=[compare operand in the kernel]:n:' \
        '-strict[parse input program in strict mode]' \
        '1:program file:_files'
}

_syz-mutate "$@"
