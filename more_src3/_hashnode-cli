#compdef hashnode-cli
# _hashnode-cli — Hashnode developer blogging platform CLI alias (Hashnode team, TypeScript); commander
# upstream: https://hashnode.com

_hashnode-cli() {
    local -a sub=(
        'auth:login:save personal access token'
        'auth:logout:clear token'
        'whoami:show current user'
        'publications:list:list publications'
        'publications:get:get publication'
        'posts:list:list posts'
        'posts:get:get post'
        'posts:create:create post'
        'posts:update:update post'
        'posts:delete:delete post'
        'posts:publish:publish draft'
        'posts:from-file:create from markdown'
        'drafts:list:list drafts'
        'drafts:create:create draft'
        'drafts:update:update draft'
        'drafts:delete:delete draft'
        'series:list:list series'
        'series:get:get series'
        'series:create:create series'
        'comments:list:list comments'
        'comments:reply:reply to comment'
        'reactions:add:add reaction'
        'reactions:remove:remove reaction'
        'newsletter:subscribers:list:list subscribers'
        'newsletter:send:send newsletter'
        'feed:user:get user feed'
        'feed:publication:get publication feed'
        'feed:tag:get tag feed'
        'webhooks:list:list webhooks'
        'webhooks:create:create webhook'
        'webhooks:delete:delete webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[access token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hashnode subcommand' sub ;;
        args)
            case $words[1] in
                posts:from-file|posts:create|drafts:create) _arguments \
                    '1:markdown file:_files -g "*.md"' \
                    '--publication-id=+[publication id]:str:' \
                    '--title=+[title]:str:' \
                    '--subtitle=+[subtitle]:str:' \
                    '--slug=+[slug]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--cover-image=+[cover url]:url:_urls' \
                    '--canonical-url=+[canonical url]:url:_urls' \
                    '--series-id=+[series id]:str:' \
                    '--published[publish immediately]' ;;
                posts:get|posts:update|posts:delete|posts:publish|drafts:update|drafts:delete) _arguments '1:post/draft id:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_hashnode-cli "$@"
