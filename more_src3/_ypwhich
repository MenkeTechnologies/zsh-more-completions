#compdef ypwhich
# _ypwhich — OpenBSD ypwhich (report the YP server a client is bound to, or with -m which server is master for a map; -x lists nickname translations)
# upstream: https://github.com/openbsd/src (usr.bin/ypwhich)
# Flags from usr.bin/ypwhich/ypwhich.1 on tip.

_ypwhich() {
    _arguments \
        '-t[skip nickname translation]' \
        '-d+[domain]:domain:' \
        '-h+[query a specific host]:host:_hosts' \
        '-m+[show master for map]:mname:' \
        '-x[list nickname translations]' \
        '*:host:_hosts'
}

_ypwhich "$@"
