#compdef tfm
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/tfm.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS tfm: display documentation for an EMBOSS application
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-program=[EMBOSS program to document]:program:' \
  '-html[output HTML]' \
  '-more[paginate output via UNIX more]' \
  '-odirectory=[output directory]:dir:_files -/' \
  '*:program name:' && ret=0

return ret
