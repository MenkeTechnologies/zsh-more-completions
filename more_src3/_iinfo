#compdef iinfo
# _iinfo — print info about image files (AcademySoftwareFoundation/OpenImageIO)
# upstream: https://github.com/AcademySoftwareFoundation/OpenImageIO
# Flags from src/iinfo/iinfo.cpp (ArgParse).

_iinfo() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[verbose: print all metadata]' \
        '-m+[match metadata names (comma-sep)]:names:' \
        '-f[include filename prefix in output]' \
        '-s[sum/total only]' \
        '-a[all subimages and MIP levels]' \
        '--hash[compute SHA-1 hash]' \
        '--stats[compute pixel statistics]' \
        '*:image file:_files'
}

_iinfo "$@"
