#compdef vercel-ai vercel-ai-cli ai-cli
# _vercel-ai — Vercel AI SDK vercel-ai CLI for AI SDK projects scaffold create stream completion and edge-runtime API route generation in Next.js and React Native (vercel team, TypeScript); commander.js
# upstream: https://github.com/vercel/ai

_vercel-ai() {
    local -a sub=(
        'new:create new AI SDK project'
        'init:initialize AI SDK in existing project'
        'dev:run AI SDK dev server'
        'add:add AI SDK component'
        'list:list components'
        'pull:pull project from Vercel'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
        'preview:preview UI'
        'stream:stream test'
        'agent:agent operations'
        'tools:tools operations'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--cwd=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vercel-ai subcommand' sub ;;
        args)
            case $words[1] in
                new|init) _arguments \
                    '--template=+[t]:t:(rsc-chat ui-chat agent rag tool-use ui-tool-use stream-text generate-text image-generation transcription)' \
                    '-t+[t]:t:(rsc-chat ui-chat agent rag tool-use ui-tool-use)' \
                    '--provider=+[p]:p:(openai anthropic google azure cohere mistral groq fireworks together perplexity vertex bedrock)' \
                    '--framework=+[f]:f:(next nuxt sveltekit solid astro react-native expo)' \
                    '--package-manager=+[pm]:p:(npm yarn pnpm bun deno)' \
                    '*:project name:' ;;
                add) _arguments \
                    '--provider=+[p]:p:(openai anthropic google azure cohere mistral groq fireworks together perplexity vertex bedrock)' \
                    '*:component:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_vercel-ai "$@"
