#compdef keystone-cli kstool
# _keystone-cli — Nguyen Anh Quynh Keystone keystone-cli kstool CLI assembler framework command-line frontend around the Keystone library assembling text instructions from stdin or args producing hex-encoded byte stream output supporting x86 x86_64 ARM ARM64 MIPS PowerPC SPARC SystemZ Hexagon EVM RISC-V WebAssembly multiple syntax dialects (Nguyen Anh Quynh team, C); getopt
# upstream: https://www.keystone-engine.org/

_keystone-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[address]:str:' \
        '-q[quiet]' \
        '-S+[syntax]:s:(att intel nasm masm gas radix16)' \
        '*:arch+code:_files'
}

_keystone-cli "$@"
