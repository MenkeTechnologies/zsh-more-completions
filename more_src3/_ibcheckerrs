#compdef ibcheckerrs
# Documentation: https://man7.org/linux/man-pages/man8/ibcheckerrs.8.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ibcheckerrs: validate IB port(s) and report errors above threshold.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[increase verbosity level]' \
  '-G[use GUID address argument (Port GUID)]' \
  '-N[use mono rather than color mode]' \
  '-nocolor[use mono rather than color mode]' \
  '-b[brief mode (only report if errors are present)]' \
  '-s[display the predefined thresholds]' \
  '-T+[use specified threshold file]:threshold file:_files' \
  '-C+[channel adapter name]:ca name:' \
  '-P+[channel adapter port]:ca port:' \
  '-t+[override default timeout for solicited MADs]:timeout (ms):' \
  '*:lid/guid or port:' && ret=0
return ret
