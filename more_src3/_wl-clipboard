#compdef wl-copy wl-paste
# Documentation: https://github.com/bugaevc/wl-clipboard
# Reference accessed: 2026-05-21
# Verified: getopt_long tables in upstream src/wl-copy.c and src/wl-paste.c.

# Zsh completion for wl-clipboard - Wayland clipboard utilities

case "$service" in
  wl-copy)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '(-p --primary)'{-p,--primary}'[use the primary selection]' \
      '(-n --trim-newline)'{-n,--trim-newline}'[trim trailing newline]' \
      '(-o --paste-once)'{-o,--paste-once}'[serve one paste request and exit]' \
      '(-f --foreground)'{-f,--foreground}'[stay in foreground (do not daemonize)]' \
      '(-c --clear)'{-c,--clear}'[clear the clipboard]' \
      '(-S --sensitive)'{-S,--sensitive}'[mark content as sensitive]' \
      '(-t --type)'{-t+,--type=}'[set MIME type]:mime type:' \
      '(-s --seat)'{-s+,--seat=}'[Wayland seat]:seat:' \
      '*:text to copy:'
    ;;
  wl-paste)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-v --version)'{-v,--version}'[show version]' \
      '(-p --primary)'{-p,--primary}'[use the primary selection]' \
      '(-n --no-newline)'{-n,--no-newline}'[do not append trailing newline]' \
      '(-l --list-types)'{-l,--list-types}'[list offered MIME types]' \
      '(-w --watch)'{-w,--watch}'[run command on each clipboard change]:command:_command_names -e' \
      '(-t --type)'{-t+,--type=}'[request specific MIME type]:mime type:' \
      '(-s --seat)'{-s+,--seat=}'[Wayland seat]:seat:'
    ;;
esac
