#compdef ujust
# Documentation: source-direct extraction from upstream
# ublue-os/packages packages/ublue-os-just/src/ujust —
#   the 3-line shell wrapper:
#     #!/usr/bin/bash
#     /usr/bin/just --justfile /usr/share/ublue-os/justfile "${@}"
# Reference accessed: 2026-05-30 via gh api.
#
# ujust is the **Universal Blue (ublue-os) just-wrapper** —
# trivially exec's `just` with `--justfile=/usr/share/ublue-os/
# justfile` so users can run distro-specific recipes (Bazzite /
# Bluefin / Aurora / Aurora-DX / Bluefin-DX / Bluefin-DX-NVIDIA
# / Bazzite-DX / etc.) without specifying the path each time.
# Sister tool to R224's apx + R225's abroot family — the
# Universal Blue atomic-distro answer to the same problem space
# that Vanilla OS solves with apx/abroot.
#
# Critical extraction note: ujust is a SHELL WRAPPER that
# forwards ALL of just's flag set + a recipe-name positional.
# This completion does TWO things differently from a plain
# `_just` completion:
#   1. Discovers recipes dynamically from the SYSTEM justfile
#      at /usr/share/ublue-os/justfile (not the user's CWD)
#      via `ujust --list --unsorted` at completion time
#   2. Forwards the standard just flag set so flags like
#      `--show RECIPE` work as expected
#
# Critical extraction note: the system justfile is INSTALLED
# by the distro's Containerfile build (e.g. ublue-os/bazzite's
# Containerfile pulls /usr/share/ublue-os/justfile from
# ublue-os/main) so recipe content varies per distro:
#   - Bazzite (gaming): install-steam, install-proton-ge, ...
#   - Bluefin (cloud-native): toolbox-distrobox, devcontainer-up
#   - Aurora (KDE): kde-settings, install-kde-discover, ...
# Completion does NOT hard-code recipe names since they're
# install-dependent; it queries the live system justfile.

local -a recipes
# Get recipes from the system justfile.  Use `--list --unsorted
# --justfile /usr/share/ublue-os/justfile` for reliability —
# parse the `recipe_name # description` lines.
if [[ -r /usr/share/ublue-os/justfile ]]; then
  recipes=( ${(f)"$(ujust --list --unsorted 2>/dev/null | command sed -n -E 's/^ +([a-zA-Z][-a-zA-Z0-9_]*)( .*)?$/\1/p' 2>/dev/null)"} )
fi

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-l --list)'{-l,--list}'[list available recipes from the system justfile]' \
  '--list-heading=[set the recipe-list heading]:text:' \
  '--list-prefix=[set the recipe-list line prefix]:text:' \
  '--show=[show source for a recipe]:recipe:($recipes)' \
  '--unsorted[when listing, do not sort recipes alphabetically]' \
  '(-n --dry-run)'{-n,--dry-run}'[print what would run without executing]' \
  '--verbose[verbose output]' \
  '--quiet[suppress all output]' \
  '--summary[show a recipe summary]' \
  '--variables[list variables]' \
  '--evaluate[evaluate and print assignments]' \
  '--changelog[show changelog]' \
  '--choose[interactively choose a recipe via fzf]' \
  '--chooser=[command for --choose]:cmd:_command_names -e' \
  '--dotenv-path=[path to .env file]:file:_files' \
  '--shell=[shell to use for recipes]:shell:_command_names -e' \
  '--shell-arg=[shell arg]:arg:' \
  '--set[set a variable: NAME VALUE]:name: :value:' \
  '*:recipe (from /usr/share/ublue-os/justfile):($recipes)'
