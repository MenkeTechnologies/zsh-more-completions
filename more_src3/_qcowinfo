#compdef qcowinfo
# Documentation: https://github.com/libyal/libqcow
# Source: libyal/libqcow manuals/qcowinfo.1 — display info about a QEMU Copy-On-Write (QCOW v1/v2) disk image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:QCOW image:_files' \
    && ret=0

return ret
