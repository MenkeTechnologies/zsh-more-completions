#compdef iptables-apply ip6tables-apply
# _iptables-apply — netfilter iptables-apply (safely load a new iptables ruleset by prompting for confirmation within a configurable timeout — if the operator doesn't confirm the original rules are restored, protecting remote SSH access; -t timeout seconds, -w/--apply ruleset file, -V version, --version; positional argument is the ruleset file)
# upstream: https://git.netfilter.org/iptables
# Flags from netfilter/iptables iptables/iptables-apply on tip.

_iptables-apply() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-t+[timeout seconds]:seconds:' \
        '--timeout+[timeout seconds]:seconds:' \
        '-w[apply ruleset]' \
        '--apply[apply ruleset]' \
        '1:ruleset file:_files'
}

_iptables-apply "$@"
