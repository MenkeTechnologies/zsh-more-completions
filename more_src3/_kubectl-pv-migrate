#compdef kubectl-pv-migrate
# kubectl-pv-migrate (krew plugin): migrate data between PersistentVolumes
# https://github.com/utkuozdemir/pv-migrate

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--source-namespace=[source PVC namespace]:namespace:_guard "^-*" namespace' \
  '--dest-namespace=[destination PVC namespace]:namespace:_guard "^-*" namespace' \
  '--source-context=[source kubernetes context]:context' \
  '--dest-context=[destination kubernetes context]:context' \
  '--source-kubeconfig=[source kubeconfig]:file:_files' \
  '--dest-kubeconfig=[destination kubeconfig]:file:_files' \
  '--source-path=[subpath within source PVC]:path' \
  '--dest-path=[subpath within destination PVC]:path' \
  '--strategies=[migration strategies to try]:strategies' \
  '--rsync-image=[rsync container image]:image' \
  '--sshd-image=[sshd container image]:image' \
  '--dest-delete-extraneous-files[delete extraneous files at dest]' \
  '--ignore-mounted[migrate even if PVC is mounted]' \
  '--no-chown[skip chown of dest files]' \
  '--no-progress-bar[disable progress bar]' \
  '--loglevel=[log level]:level:(trace debug info warn error)' \
  '1:source PVC name' \
  '2:destination PVC name'
