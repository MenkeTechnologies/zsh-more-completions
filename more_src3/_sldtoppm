#compdef sldtoppm
# Documentation: man sldtoppm (Netpbm)
# Source: convert an AutoCAD slide (SLD) file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-adjust[adjust aspect ratio]' \
    '-dir[directory of slide library]' \
    '(-height -ysize)'{-height+,-ysize+}'[output height]:s:' \
    '-info[print slide info and exit]' \
    '(-lib -Lib)'{-lib+,-Lib+}'[slide library name]:name:' \
    '-scale+[output scale]:s:' \
    '-verbose[verbose output]' \
    '(-width -xsize)'{-width+,-xsize+}'[output width]:s:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:slide file:_files -g "*.(sld|slb)"' \
    && ret=0

return ret
