#compdef kpsexpand
# Documentation: kpsexpand --help (kpathsea / TeX Live)
# Source: TeX kpsexpand — expand $variables/~ in a string using kpathsea.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--cnf-line=[parse STRING as configuration line]:string:' \
    '--debug=[kpathsea debug bitmask]:n:' \
    '(- *)--help[show help]' \
    '--progname=[program name for kpathsea]:name:' \
    '--time-statistics[print runtime statistics]' \
    '--var-value=[print value of named variable]:variable:' \
    '(- *)--version[show version]' \
    '*:string to expand:' \
    && ret=0

return ret
