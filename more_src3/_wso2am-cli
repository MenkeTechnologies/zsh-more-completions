#compdef wso2am-cli apictl
# _wso2am-cli — WSO2 wso2am-cli CLI command-line frontend wrapping the WSO2 API Manager Open-Source Hybrid open-source API Management platform full lifecycle WSO2 apictl command-line interface CLI tool for the WSO2 API Manager written in Go init add update delete get import export list change-status secret token aliases envs login logout vcs status add api-revision update api search undeploy ai mg microgateway deploy environments env-set logout-from cloud throttle-policy mediation-policies subscription-policies application application-policies (WSO2 team Selvaratnam Uthaiyashankar Sumedha Rubasinghe Sanjeewa Malalgoda, Go); cobra
# upstream: https://wso2.com/api-manager/

_wso2am-cli() {
    local -a sub=(
        'add:add resources'
        'add-env:add environment'
        'ai:AI features'
        'aliases:alias operations'
        'application:application operations'
        'bundle:bundle operations'
        'change-status:change status'
        'clear-tenant:clear tenant'
        'completion:generate shell completion'
        'delete:delete resources'
        'export:export resources'
        'gen:generate resources'
        'get:get resources'
        'import:import resources'
        'init:initialize a project'
        'install:install components'
        'k8s:Kubernetes operations'
        'login:authenticate'
        'logout:revoke session'
        'mg:Microgateway operations'
        'remove-env:remove environment'
        'search:search resources'
        'secret:secret operations'
        'set:set CLI configurations'
        'set-mode:set CLI mode'
        'token:token operations'
        'undeploy:undeploy resource'
        'update:update resources'
        'vcs:VCS integration'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '-e+[environment]:str:' \
        '--environment=+[name]:str:' \
        '-u+[username]:_users' \
        '--username=+[user]:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-k[insecure]' \
        '--insecure[skip TLS verify]' \
        '--token=+[token]:str:' \
        '--apim-version=+[v]:str:' \
        '-t+[tenant]:str:' \
        '--tenant=+[name]:str:' \
        '--apim=+[url]:str:' \
        '--registration=+[url]:str:' \
        '--token-endpoint=+[url]:str:' \
        '--admin=+[url]:str:' \
        '--api=+[url]:str:' \
        '--devportal=+[url]:str:' \
        '-d+[dir]:dir:_files -/' \
        '--directory=+[dir]:dir:_files -/' \
        '-f[force overwrite]' \
        '--force[force]' \
        '--preserve-provider[preserve provider]' \
        '--update-if-exists[update if exists]' \
        '--update-resources[update resources]' \
        '--enable-rotation[enable token rotation]' \
        '--scope=+[scope]:str:' \
        '--params=+[file]:file:_files -g "*.yaml *.yml"' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--owner=+[name]:_users' \
        '-r+[rev id]:str:' \
        '--rev=+[id]:str:' \
        '--format=+[fmt]:f:(json yaml table)' \
        '--output=+[fmt]:f:(json yaml table)' \
        '-o+[output]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'apictl subcommand' sub ;;
        args)
            case $words[1] in
                add|update|delete|get|export|import|search|change-status) _arguments '1:type:(api api-product api-products apis app application applications policy throttle-policy subscription-policy application-policy advanced-policy custom-policy api-revision env environments key-managers ai-provider rate-limit user role scope)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                mg) _arguments '1:op:(login init deploy undeploy api)' '*:arg:' ;;
            esac
            ;;
    esac
}

_wso2am-cli "$@"
