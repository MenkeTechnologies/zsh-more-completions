#compdef log
# Documentation: log help (macOS 26)
# Source: Apple unified logging system controller (collect/show/stream/stats/config).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'collect:gather system logs into a .logarchive'
    'config:view or change logging system settings'
    'diagnose:diagnose an archive for issues'
    'erase:delete system logging data'
    'repack:repack a log archive using a predicate'
    'show:view/search system logs'
    'stream:watch live system logs'
    'stats:show system logging statistics'
    'emit:emit a log message into the log store'
    'help:show help for a verb'
)

_log_cmd_show() {
    _arguments -s \
        '--backtrace[show backtraces]' '--no-backtrace[hide backtraces]' \
        '--debug[show Debug events]' '--no-debug[hide Debug events]' \
        '--info[show Info events]' '--no-info[hide Info events]' \
        '--loss[show loss events]' '--no-loss[hide loss events]' \
        '--signpost[show signposts]' '--no-signpost[hide signposts]' \
        '--color[color output mode]:mode:(auto always none)' \
        '--directory[event directory]:dir:_files -/' \
        '--end[end date]:date:' \
        '--last[last N events or boot]:limit:' \
        '--pager[paginate with less]' '--no-pager[disable pager]' \
        '--predicate[filter events with NSPredicate]:predicate:' \
        '--process[filter by pid or process]:pid or name:_pids' \
        '--realtime[annotate output with Real-Time]' \
        '--source[annotate with source file/line]' \
        '--start[start date]:date:' \
        '--style[output style]:style:(default syslog json ndjson compact)' \
        '--timezone[timezone (local or tz name)]:tz:' \
        '--mach-continuous-time[show mach continuous time]' \
        '--unreliable[annotate with unreliable flag]' \
        '*:logarchive:_files -g "*.logarchive"'
}

_log_cmd_stream() {
    _arguments -s \
        '--backtrace[show backtraces]' '--no-backtrace[hide backtraces]' \
        '--color[color output mode]:mode:(auto always none)' \
        '--level[include events at level and below]:level:(default info debug)' \
        '--predicate[filter events with NSPredicate]:predicate:' \
        '--process[stream from pid or process]:pid or name:_pids' \
        '--user[stream from uid or user]:user:_users' \
        '--source[annotate with source file/line]' \
        '--style[output style]:style:(default syslog json ndjson compact)' \
        '--timeout[terminate after duration]:timeout:' \
        '--type[event type filter]:type:(activity log trace)' \
        '--mach-continuous-time[show mach continuous time]' \
        '--unreliable[annotate with unreliable flag]' \
        '--ignore-dropped[suppress dropped-message output]'
}

_log_cmd_collect() {
    _arguments -s \
        '--device[collect from first connected device]' \
        '--device-name[collect from device with name]:name:' \
        '--device-udid[collect from device with UDID]:udid:' \
        '--directory[collect from directory]:dir:_files -/' \
        '--last[collect logs starting N ago]:duration:' \
        '--output[output logarchive path]:path:_files' \
        '--size[limit collection size]:size:' \
        '--start[start time]:time:' \
        '--predicate[NSPredicate filter]:predicate:'
}

_log_cmd_config() {
    _arguments -s \
        '--category[get/set settings for category]:name:' \
        '--json[output status as JSON (with --status)]' \
        '--mode[set mode (key:value,key:value)]:modes:' \
        '--process[get/set settings for pid or process]:pid or name:_pids' \
        '--reset[reset settings to defaults]' \
        '--status[show current settings]' \
        '--subsystem[get/set settings for subsystem]:name:'
}

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
    '1:command:->verbs' \
    '*::args:->args' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
    args)
        case $words[1] in
            show) _log_cmd_show && ret=0 ;;
            stream) _log_cmd_stream && ret=0 ;;
            collect) _log_cmd_collect && ret=0 ;;
            config) _log_cmd_config && ret=0 ;;
            help) _describe -t verbs verb verbs && ret=0 ;;
        esac
        ;;
esac

return ret
