#compdef log
# Documentation: https://keith.github.io/xcode-man-pages/log.1.html
# Source: Apple macOS — Unified Logging system CLI (queries os_log / .logarchive / tracev3).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:general help or per-subcommand help'
            'collect:collect system logs into a .logarchive'
            'config:configure / reset / read logging settings'
            'diagnose:print diagnostic info for a given archive'
            'emit:emit a log message to the system logging facility'
            'erase:delete selected log data'
            'show:show system log / archive / tracev3 contents'
            'stats:breakdown of events in a log datastore/archive/tracev3/tailspin/apple trace'
            'stream:stream activities / log / trace messages live'
            'repack:repack predicate-matching logs into a new logarchive'
        )
        _describe -t subcmds 'log command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            show|stream|stats|repack)
                _arguments \
                    '--predicate=[NSPredicate filter expression]:predicate:' \
                    '--info[include info-level messages]' \
                    '--debug[include debug-level messages]' \
                    '--signpost[include signpost activities]' \
                    '--last=[only items in last duration (e.g. 1h, 30s)]:duration:' \
                    '--start=[items after timestamp]:start:' \
                    '--end=[items before timestamp]:end:' \
                    '--style=[output style]:style:(default compact json syslog ndjson)' \
                    '--color=[color output]:when:(always auto never)' \
                    '*--process=[filter to process name/PID]:proc:' \
                    '--source[include source-code locations]' \
                    '--archive=[read from .logarchive]:archive:_files' \
                    && ret=0
                ;;
            collect)
                _arguments \
                    '--last=[collect last N {m,h,d}]:duration:' \
                    '--start=[collect from timestamp]:start:' \
                    '--output=[output .logarchive path]:archive:_files' \
                    '--size=[approximate target size]:size:' \
                    && ret=0
                ;;
            *)
                _files
                ;;
        esac
        ;;
esac

return ret
