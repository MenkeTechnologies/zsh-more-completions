#compdef hakrawler2
# _hakrawler2 — hakluke Luke Stephens hakrawler2 CLI command-line frontend wrapping the hakrawler fast golang web crawler for gathering URLs and JavaScript file locations open-source written in Go simple-and-quick-discovery-of-endpoints-in-target-website both-from-the-target-site-and-its-third-party-content-CDNs-JS-files robots.txt sitemap.xml depth-flag concurrency unique include-subdomains include-all-third-parties scope insecure-skip-TLS-checks plain-text wallet-related-domains (hakluke Luke Stephens team, Go); flag
# upstream: https://github.com/hakluke/hakrawler

_hakrawler2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[depth]:n:' \
        '-depth=+[N]:n:' \
        '-t+[threads]:n:' \
        '-u[unique URLs]' \
        '-unique[unique URLs]' \
        '-s[show source]' \
        '-w[include wayback URLs]' \
        '-subs[include subdomains]' \
        '-i[insecure]' \
        '-insecure[skip TLS verify]' \
        '-proxy+[url]:str:' \
        '-timeout+[sec]:n:' \
        '-dr[disable redirects]' \
        '-h+[header]:str:' \
        '*-h+[header]:str:' \
        '-headers=+[headers]:str:' \
        '-fr[follow redirects]' \
        '-json[JSON output]' \
        '*:url:'
}

_hakrawler2 "$@"
