#compdef xsv-cli
# _xsv-cli — Andrew Gallant xsv fast CSV toolkit in Rust CLI alias (BurntSushi team, Rust); custom argparse via docopt
# upstream: https://github.com/BurntSushi/xsv

_xsv-cli() {
    local -a sub=(
        'cat:concatenate CSV files'
        'count:count rows in CSV'
        'fixlengths:make rows fixed length'
        'flatten:show one column at a time'
        'fmt:reformat CSV with different delimiter/quoting'
        'frequency:build frequency tables of each column'
        'headers:show or transform headers'
        'help:show help'
        'index:create index for fast random access'
        'input:read CSV with funky quoting/escaping'
        'join:joins two CSV data sets'
        'partition:partition CSV by a column value'
        'reverse:reverse rows'
        'sample:sample N random rows'
        'search:find rows matching pattern'
        'select:select columns'
        'slice:slice rows'
        'sort:sort rows'
        'split:split into multiple files'
        'stats:column statistics'
        'table:show as aligned table'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xsv subcommand' sub ;;
        args)
            case $words[1] in
                cat|count|fixlengths|flatten|fmt|frequency|headers|input|reverse|slice|sort|stats|table) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--no-headers[no headers]' \
                    '-n[no headers]' \
                    '--delimiter=+[delimiter]:str:' \
                    '-d+[delimiter]:str:' \
                    '*:files:_files -g "*.csv"' ;;
                join) _arguments \
                    '1:columns1:' \
                    '2:input1:_files -g "*.csv"' \
                    '3:columns2:' \
                    '4:input2:_files -g "*.csv"' \
                    '--left[left outer join]' \
                    '--right[right outer join]' \
                    '--full[full outer join]' \
                    '--cross[cross join]' \
                    '--nulls[allow nulls]' \
                    '--no-case[case insensitive]' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
                search) _arguments \
                    '1:regex:' \
                    '*:files:_files -g "*.csv"' \
                    '--select=+[select columns]:str:' \
                    '-s+[select columns]:str:' \
                    '--invert-match[invert match]' \
                    '-v[invert match]' \
                    '--no-case[case insensitive]' \
                    '-i[case insensitive]' \
                    '--flag=+[flag column]:str:' \
                    '-f+[flag column]:str:' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
                select) _arguments \
                    '1:select columns:' \
                    '*:files:_files -g "*.csv"' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
                split) _arguments \
                    '1:output dir:_files -/' \
                    '2:input:_files -g "*.csv"' \
                    '--size=+[rows per file]:n:' \
                    '-s+[rows per file]:n:' \
                    '--jobs=+[jobs]:n:' \
                    '-j+[jobs]:n:' \
                    '--filename=+[filename template]:str:' ;;
                sample) _arguments \
                    '1:sample size:' \
                    '*:files:_files -g "*.csv"' \
                    '--seed=+[seed]:n:' \
                    '--no-headers[no headers]' ;;
                index) _arguments '*:files:_files -g "*.csv"' ;;
            esac
            ;;
    esac
}

_xsv-cli "$@"
