#compdef shiv
# Documentation: https://shiv.readthedocs.io/en/latest/cli-reference.html
# Reference accessed: 2026-05-21
# Verified: upstream CLI reference at the URL above.
# Removed unverified flags: -r/--requirement, --no-compile-pyc (not in docs).
# Added: --uncompressed (toggle pair with --compressed), -E (short for --extend-pythonpath).

# Zsh completion for shiv - create self-contained Python zipapps

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-o+[output file]:output file:_files' \
  '--output-file=[output file]:output file:_files' \
  '-e+[entry point]:entry point' \
  '--entry-point=[entry point]:entry point' \
  '-c+[console script entry point]:console script' \
  '--console-script=[console script entry point]:console script' \
  '-p+[python interpreter shebang]:python:_files' \
  '--python=[python interpreter shebang]:python:_files' \
  '--site-packages=[include site-packages from a directory]:directory:_directories' \
  '--compressed[compress the zipapp]' \
  '--uncompressed[do not compress the zipapp]' \
  '--compile-pyc[compile .py files to .pyc]' \
  '-E[extend PYTHONPATH with bundled site-packages]' \
  '--extend-pythonpath[extend PYTHONPATH with bundled site-packages]' \
  '--reproducible[make reproducible zipapps (zero timestamps)]' \
  '--no-modify[refuse to run if bootstrap dir is modified]' \
  '--preamble=[path to preamble script]:script:_files -g "*.py"' \
  '--build-id=[custom build ID]:id' \
  '--root=[pip install root]:directory:_directories' \
  '*:packages' && ret=0

return ret
