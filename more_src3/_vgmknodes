#compdef vgmknodes
# _vgmknodes — LVM2 vgmknodes recreate device nodes for VG CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_vgmknodes() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--refresh[refresh]' \
        '--ignorelockingfailure[ignore locking failure]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes]' \
        '--yes[yes]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '*:vg-or-lv:'
}

_vgmknodes "$@"
