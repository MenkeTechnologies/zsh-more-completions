#compdef viking
# Documentation: https://sourceforge.net/projects/viking/
# Reference accessed: 2026-05-21
# Verified: no current authoritative online man page reachable. The
# project is the Viking GPS/Map viewer (SourceForge). Without a
# verifiable CLI reference, restrict to GTK auto-options and file
# arguments to avoid fabrication.
# STUB: upstream CLI reference unavailable; thin completion only.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.{vik,gpx,kml,kmz,fit,igc,nmea,tcx,geojson}"' && ret=0

return ret
