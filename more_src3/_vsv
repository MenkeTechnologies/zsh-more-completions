#compdef vsv
# Documentation: https://github.com/bahamas10/vsv
# Source: bahamas10/vsv src/arguments.rs — Void Service Manager (runit wrapper, Rust clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _vsv_cmds
_vsv_cmds=(
    'status:show process status'
    'enable:enable service(s)'
    'disable:disable service(s)'
    'start:start the service'
    'stop:stop the service'
    'restart:restart the service'
    'reload:reload the service (send SIGHUP)'
)

_arguments -C \
    '(-c --color)'{-c+,--color=}'[color output]:mode:(yes no auto)' \
    '(-d --dir)'{-d+,--dir=}'[service directory (default $SVDIR or /var/service)]:dir:_files -/' \
    '(-l --log)'{-l,--log}'[show log processes (shortcut for status -l)]' \
    '(-t --tree)'{-t,--tree}'[tree view (shortcut for status -t)]' \
    '(-u --user)'{-u,--user}'[user mode (-d ~/runit/service)]' \
    '*'{-v,--verbose}'[increase verbosity]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'vsv command' _vsv_cmds && ret=0
        ;;
esac

return ret
