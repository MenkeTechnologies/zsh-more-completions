#compdef humioctl humio
# Documentation: https://github.com/humio/cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'alerts:manage alerts'
  'cluster:cluster operations'
  'completion:generate shell completion'
  'health:show server health'
  'ingest:send data to LogScale (Humio)'
  'ingest-tokens:manage ingest tokens'
  'license:license commands'
  'packages:manage packages'
  'parsers:manage parsers'
  'profiles:manage CLI configuration profiles'
  'repos:manage repositories'
  'views:manage views'
  'users:manage users'
  'scheduled-searches:manage scheduled searches'
  'status:show server status'
  'login:login to LogScale'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[CLI profile]:profile:' \
  '--config=[config file]:file:_files' \
  '--token=[API token]:token:' \
  '--insecure[skip TLS verification]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'humioctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ingest)
        _arguments \
          '(-r --repo)'{-r+,--repo=}'[target repository]:repo:' \
          '(-o --open)'{-o,--open}'[open the live UI for repo]' \
          '(-p --parser)'{-p+,--parser=}'[parser to use]:parser:' \
          '(-f --fields)*'{-f+,--fields=}'[ad-hoc field key=value]:field:' \
          '*::file:_files' && ret=0 ;;
      (alerts|parsers|repos|users|views|packages|scheduled-searches)
        _arguments '*::sub:(list show install update delete create export rename)' && ret=0 ;;
      (ingest-tokens)
        _arguments '*::sub:(add list show remove)' && ret=0 ;;
      (profiles)
        _arguments '*::sub:(add list show remove)' && ret=0 ;;
      (cluster)
        _arguments '*::sub:(nodes status license)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
