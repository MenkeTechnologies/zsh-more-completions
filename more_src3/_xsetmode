#compdef xsetmode
# Documentation: https://www.x.org/archive/X11R7.5/doc/man/man1/xsetmode.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:device name:' \
  '2:mode:(ABSOLUTE RELATIVE)' && ret=0

return ret
