# -----------------------------------------------------------------------------
# IMSEARCH'S CLI SURFACE (verbatim from src/config.rs + src/main.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   imsearch [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
# Global options:
#   -c, --conf-dir <DIR>          imsearch configuration directory
#                                  (default: platform-default config dir
#                                   ~/.config/imsearch/ on Linux)
#   -h, --help                    Show help (clap built-in)
#       --version                 Show version (clap built-in)
#
# Subcommands (each shows indicatif progress bars during operation):
#   add                           Add image feature points to database.
#                                  Walks input paths, extracts ORB
#                                  descriptors via OpenCV, computes
#                                  BLAKE3 + dHash for dedup, inserts
#                                  into SQLite/RocksDB.
#                                  --threads <N>      Parallel workers
#                                  --batch-size <N>   DB batch size
#                                  --recursive        Recurse into dirs
#                                  --skip-existing    Skip already-hashed
#
#   search <IMAGE>                Search database for similar images.
#                                  Extracts descriptors from the query
#                                  image, queries the FAISS index for
#                                  k-nearest neighbors, returns ranked
#                                  results.
#                                  -k, --top-k <N>    Number of results
#                                  --score-type wilson|count  Ranking
#                                  --output json|table  Output format
#
#   server                        Start the HTTP search API server.
#                                  Axum-based; multipart upload for
#                                  query images; Bearer-token auth.
#                                  --listen <ADDR>    Bind address
#                                  --token <TOKEN>    Auth bearer token
#                                  --workers <N>      Worker threads
#
#   build                         Build the FAISS index from added
#                                  feature points.  Choose HNSW (for
#                                  small-to-medium) or IVF (for very
#                                  large) index types.  Shows progress
#                                  for clustering + quantization.
#                                  --index-type hnsw|ivf
#                                  --m <N>            HNSW connections
#                                  --ef-construction <N>  HNSW build
#                                  --nlist <N>        IVF clusters
#                                  --train-on <N>     IVF training size
#
#   clean                         Clean unused feature points from DB
#                                  to reduce database size.
#                                  --vacuum           SQLite VACUUM
#
#   train                         Train an IVF index quantizer on a
#                                  sample of stored descriptors.
#                                  --sample-size <N>  Training sample
#                                  --nlist <N>        Number of clusters
#                                  --niter <N>        K-means iterations
#
# Environment variables:
#   RUST_LOG=imsearch=debug       Enable debug logging
#                                  (NOT bare RUST_LOG=debug which floods
#                                   the logs with sqlx + other deps)
#
# Configuration:
#   <conf-dir>/config.toml        Database paths, FAISS index settings,
#                                  ORB descriptor parameters, server
#                                  defaults
#
# Typical usage:
#   $ imsearch add ./photos --recursive --threads 8
#   $ imsearch build --index-type hnsw --m 16
#   $ imsearch search query.jpg -k 10 --output table
#   $ imsearch server --listen 0.0.0.0:8080 --token secret
#   $ imsearch clean --vacuum
#
# SIMD acceleration:
#   imsearch detects x86 SIMD features at startup and prints which
#   extension is active (avx512vpopcntdq / avx512f / avx2 / sse4.2 /
#   sse4.1 / sse3 / sse2 / sse / none).  Best performance with
#   avx512vpopcntdq + faiss compiled for the same.
#
# Companion projects:
#   faiss-sys                     Rust bindings to Faiss (Meta's k-NN
#                                  library); imsearch uses faiss-sys
#                                  for the IVF/HNSW index implementations
#   opencv-rust                   Rust bindings to OpenCV; imsearch
#                                  uses opencv-rust for ORB extraction
#   snmalloc-rs                   Snmalloc allocator for high-throughput
#                                  parallel allocation during index build
#
# =============================================================================

_imsearch() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'add:add image feature points to database'
        'search:search database for similar images'
        'server:start HTTP search API server'
        'build:build FAISS index from added feature points'
        'clean:clean unused feature points from database'
        'train:train IVF index quantizer'
    )

    _arguments -C \
        '(-c --conf-dir)'{-c,--conf-dir}'[configuration directory]:dir:_directories' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'imsearch command' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (add)
                    _arguments \
                        '--threads=[parallel workers]:n:' \
                        '--batch-size=[DB batch size]:n:' \
                        '--recursive[recurse into directories]' \
                        '--skip-existing[skip already-hashed images]' \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '*:path:_files' && ret=0
                    ;;
                (search)
                    _arguments \
                        '(-k --top-k)'{-k,--top-k=}'[number of results]:n:' \
                        '--score-type=[ranking method]:type:(wilson count)' \
                        '--output=[output format]:format:(json table)' \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '*:image:_files -g "*.(jpg|jpeg|png|webp|bmp)"' && ret=0
                    ;;
                (server)
                    _arguments \
                        '--listen=[bind address]:addr:' \
                        '--token=[auth bearer token]:token:' \
                        '--workers=[worker threads]:n:' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (build)
                    _arguments \
                        '--index-type=[index type]:type:(hnsw ivf)' \
                        '--m=[HNSW connections]:n:' \
                        '--ef-construction=[HNSW build parameter]:n:' \
                        '--nlist=[IVF cluster count]:n:' \
                        '--train-on=[IVF training sample size]:n:' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (clean)
                    _arguments \
                        '--vacuum[run SQLite VACUUM]' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (train)
                    _arguments \
                        '--sample-size=[training sample size]:n:' \
                        '--nlist=[number of clusters]:n:' \
                        '--niter=[k-means iterations]:n:' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_imsearch "$@"
