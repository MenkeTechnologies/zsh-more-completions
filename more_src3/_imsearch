#
# WHAT IS console-rs/indicatif AND WHY IS IT A DISTINCT 38TH RUST CLI LIBRARY?
#
# console-rs/indicatif (https://github.com/console-rs/indicatif, 5153+ stars)
# is **the console-rs org's "command line progress reporting library for
# Rust"** — the **CANONICAL Rust progress-bar / spinner / multi-progress
# library**.  Released in 2016 by **Armin Ronacher** (the same author as
# dialoguer R518 — Flask creator, Sentry CTO), indicatif is the
# progress-side companion to dialoguer's prompts side.  Together with
# `console` (terminal primitives), the three libraries form the canonical
# console-rs Rust CLI-UX stack.  **The most-deployed progress library
# across the entire Rust ecosystem** — used by cargo's download progress,
# rustup's installer progress, gitoxide's clone progress, restic-rs's
# backup progress, and thousands of other Rust CLIs.
#
# indicatif is DISTINCT from every documented Rust CLI library on FIVE
# specific axes:
#
#   1. PROGRESS-FIRST DESIGN (NOT ARGV PARSER, NOT PROMPT LIBRARY) —
#      indicatif is the FIRST documented Rust CLI library whose primary
#      concern is PROGRESS REPORTING rather than argv parsing or
#      interactive prompts.  Compare:
#         clap / clap-derive:     argv parser
#         structopt / argh / ...: argv parsers
#         cliclack R510:          prompts UNIFIED with spinner+progress
#                                  in a single library
#         inquire R514:           prompts only (no progress)
#         dialoguer R518:         prompts only — DESIGNED TO PAIR WITH
#                                  indicatif for progress
#         indicatif (THIS):       PROGRESS REPORTING only — bars,
#                                  spinners, multi-progress, formatters
#      indicatif occupies the THIRD axis of the CLI-library design space:
#        Axis 1: argv parsing       (clap, structopt, argh, ...)
#        Axis 2: interactive prompts (dialoguer, inquire, cliclack)
#        Axis 3: progress reporting  (indicatif — THIS)
#      **First documented Rust CLI library whose primary concern is
#      PROGRESS REPORTING rather than argv parsing or prompts.**
#
#   2. THREE PROGRESS-TYPE PRIMITIVES (ProgressBar / Spinner / MultiProgress) —
#      indicatif's core API exposes three primary types:
#         use indicatif::{ProgressBar, ProgressStyle, MultiProgress};
#
#         // ProgressBar — known-length task
#         let pb = ProgressBar::new(1000);
#         pb.set_style(ProgressStyle::with_template(
#             "{spinner:.green} [{elapsed_precise}] [{wide_bar:.cyan/blue}] \
#              {pos}/{len} ({eta})"
#         ).unwrap().progress_chars("##-"));
#         for i in 0..1000 {
#             pb.inc(1);
#         }
#         pb.finish_with_message("done");
#
#         // Spinner — unknown-length task
#         let spinner = ProgressBar::new_spinner();
#         spinner.set_message("Working...");
#         spinner.enable_steady_tick(Duration::from_millis(80));
#         do_work();
#         spinner.finish_with_message("done");
#
#         // MultiProgress — coordinate multiple bars
#         let m = MultiProgress::new();
#         let pb1 = m.add(ProgressBar::new(100));
#         let pb2 = m.add(ProgressBar::new(50));
#         // ...
#         m.println("All done!");
#      Compare:
#        cliclack R510:    spinner() + progress_bar() in unified
#                          prompt+progress library
#        dialoguer R518:   no progress support — DESIGNED to compose
#                          with indicatif
#        inquire R514:     no progress support
#        @clack/prompts (JS): spinner() + taskLog() unified
#        Inquirer.js v9:   no progress support — JS uses ora separately
#        indicatif:        THREE-PRIMITIVE design (Bar / Spinner /
#                          MultiProgress) — most mature progress API
#                          in any documented CLI library.
#
#   3. TEMPLATE-STRING STYLING MINI-DSL (`ProgressStyle::with_template`)
#      — indicatif uses a TEMPLATE-STRING MINI-DSL for styling progress
#      bars, with ~25 named placeholders:
#         {bar:WIDTH}          progress bar of given width
#         {wide_bar}           progress bar that fills available width
#         {spinner}            current spinner frame
#         {pos}                current position
#         {len}                total length
#         {percent}            percent complete (0-100)
#         {prefix}             user-set prefix string
#         {msg}                user-set message
#         {elapsed}            elapsed time, human-readable
#         {elapsed_precise}    elapsed time, HH:MM:SS
#         {eta}                ETA, human-readable
#         {eta_precise}        ETA, HH:MM:SS
#         {duration}           elapsed (alias for elapsed)
#         {duration_precise}   elapsed precise (alias)
#         {bytes}              bytes done (human-readable size)
#         {total_bytes}        total bytes (human-readable)
#         {bytes_per_sec}      throughput in bytes/sec
#         {binary_bytes}       binary unit bytes (KiB/MiB/...)
#         {decimal_bytes}      decimal unit bytes (KB/MB/...)
#         {human_pos}          position formatted with thousands sep
#         {human_len}          length formatted with thousands sep
#         {*}                  named user-set value via `set_value()`
#      Plus colored variants like `{bar:.cyan/blue}` (cyan filled,
#      blue empty) and `{spinner:.green}`.  Compare:
#        cliclack R510:    spinner+progress hardcoded styling
#        @clack/prompts:   spinner+progress hardcoded
#        ora (JS):         spinner format strings but simpler
#        indicatif:        TEMPLATE-STRING MINI-DSL with 25+ named
#                          placeholders + color modifiers — most
#                          expressive progress-styling API across
#                          documented prompt+progress libraries.
#
#   4. `ProgressIterator` AUTO-WRAPPING TRAIT — indicatif exposes a
#      trait that any iterator can implement to GAIN A `.progress()`
#      METHOD that auto-wraps the iteration in a progress bar:
#         use indicatif::ProgressIterator;
#         for i in (0..1000).progress() {
#             work(i);
#         }
#         // Or with custom style:
#         for i in items.iter().progress_with_style(custom_style) {
#             process(i);
#         }
#         // Or with rayon for parallel work:
#         use indicatif::ParallelProgressIterator;
#         items.par_iter().progress().for_each(|i| process(i));
#      Compare:
#        cliclack R510:    no iterator-wrapping trait
#        dialoguer R518:   no progress at all
#        @clack/prompts:   no iterator-wrapping
#        indicatif:        AUTO-WRAPPING ITERATOR TRAIT — call
#                          .progress() on any iterator to get a
#                          ProgressBar tied to its length.
#      Composes with rayon for parallel-progress (`par_iter().progress()`).
#
#   5. HUMAN-READABLE FORMATTER TYPES (HumanBytes / HumanDuration /
#      HumanCount) — indicatif provides three formatter types for
#      readable display of common quantities:
#         use indicatif::{HumanBytes, HumanDuration, HumanCount};
#         println!("downloaded {}", HumanBytes(1234567890));
#             // → "1.15 GiB"
#         println!("took {}", HumanDuration(Duration::from_secs(3725)));
#             // → "1h 2m 5s"
#         println!("{} files", HumanCount(1_234_567));
#             // → "1,234,567"
#      Compare:
#        cliclack R510:    no human-readable formatters
#        dialoguer R518:   no human-readable formatters
#        indicatif:        FIRST-CLASS Display-implementing types for
#                          bytes, durations, counts — re-usable across
#                          any code that needs human formatting.
#      These types are used by cargo's download messages, gitoxide's
#      clone-progress estimates, and many other tools that pair
#      indicatif with text output.
#
# Bonus: indicatif has a **`println()` method on MultiProgress** that
# is THREAD-SAFE relative to the displayed bars — log lines printed
# via `multi.println("msg")` appear ABOVE the bars without garbling
# the display.  This is critical for long-running jobs where you want
# both live progress AND occasional log lines.
#
# THE console-rs/indicatif API SURFACE (verbatim from upstream)
#
#   use indicatif::{
#       ProgressBar, ProgressStyle, MultiProgress, ProgressIterator,
#       HumanBytes, HumanDuration, HumanCount,
#   };
#
#   // Known-length progress bar:
#   let pb = ProgressBar::new(total);
#   pb.set_style(ProgressStyle::with_template(
#       "{spinner:.green} [{elapsed_precise}] \
#        [{wide_bar:.cyan/blue}] {pos:>7}/{len:7} ({eta})"
#   ).unwrap().progress_chars("##-"));
#   pb.set_prefix("Downloading");
#   for i in 0..total {
#       pb.inc(1);
#   }
#   pb.finish_with_message("done");
#
#   // Unknown-length spinner:
#   let spinner = ProgressBar::new_spinner();
#   spinner.set_message("Indexing...");
#   spinner.enable_steady_tick(Duration::from_millis(80));
#   do_indexing();
#   spinner.finish_with_message("indexed");
#
#   // Multiple coordinated progress bars:
#   let multi = MultiProgress::new();
#   let pb1 = multi.add(ProgressBar::new(100));
#   let pb2 = multi.add(ProgressBar::new(50));
#   // pb1 and pb2 update independently; multi coordinates rendering
#   multi.println("Both finished!").unwrap();
#
#   // Iterator auto-wrapping:
#   for item in items.iter().progress_count(items.len() as u64) {
#       process(item);
#   }
#
#   // Parallel-progress with rayon:
#   use indicatif::ParallelProgressIterator;
#   items.par_iter().progress().for_each(|item| process(item));
#
#   // Human-readable formatters:
#   println!("Downloaded {}", HumanBytes(bytes_downloaded));
#   println!("Took {}",      HumanDuration(elapsed));
#   println!("{} items",     HumanCount(item_count));
#
# Method surface on ProgressBar:
#   new(len)                  / new_spinner()
#   set_style(style)
#   set_message(msg)          / message()
#   set_prefix(prefix)        / prefix()
#   set_position(pos)         / position()
#   inc(delta)                / inc_length(delta)
#   tick()                    / enable_steady_tick(period)
#   finish()                  / finish_with_message(msg) / finish_and_clear()
#   abandon()                 / abandon_with_message(msg)
#   reset()                   / reset_elapsed() / reset_eta()
#   suspend(|| { ... })       // pause display for synchronous output
#   wrap_read(reader)         // wrap a Reader with progress
#   wrap_write(writer)        // wrap a Writer with progress
#   wrap_iter(iter)           // wrap any Iterator with progress
#
