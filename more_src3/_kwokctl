#compdef kwokctl
# Documentation: https://kwok.sigs.k8s.io/docs/generated/kwokctl/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kwokctl (kubernetes-sigs/kwok). Subcommands and persistent flags taken
# from the upstream `kwokctl --help` output documented at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:manage default configuration'
  'create:create a cluster'
  'delete:delete a cluster'
  'etcdctl:run etcdctl in cluster context'
  'export:retrieve cluster logs'
  'get:get clusters, components, artifacts or kubeconfig'
  'hack:(experimental) low-level helpers'
  'kectl:(experimental) run etcd-like commands directly'
  'kubectl:run kubectl with the cluster kubeconfig'
  'logs:dump component logs'
  'port-forward:forward a local port to a component'
  'scale:scale resources in the cluster'
  'snapshot:cluster snapshot helpers (experimental)'
  'start:start a cluster'
  'stop:stop a cluster'
  'help:help about any command'
)

_arguments -s -S -C \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
  '--dry-run[preview commands without executing]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--name=[cluster name]:name:' \
  '(-v --v)'{-v+,--v=}'[log level (DEBUG/INFO/WARN/ERROR or numeric)]:level:(DEBUG INFO WARN ERROR -4 0 4 8)' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kwokctl command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (create|delete|start|stop|get|scale|snapshot)
        _arguments '1:subcommand:(cluster clusters components artifacts kubeconfig node nodes pod pods deployment)' && ret=0
        ;;
      (*)
        _arguments '*:kwokctl args: _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
