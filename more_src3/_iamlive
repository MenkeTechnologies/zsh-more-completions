#compdef iamlive
# Documentation: https://github.com/iann0036/iamlive
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iamlive: generate IAM policies from observed AWS/Azure/GCP API calls.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--provider=[cloud service provider]:provider:(aws azure gcp)' \
  '--set-ini[update .aws/config to use CSM or CA bundle (AWS)]' \
  '--profile=[AWS profile name (with --set-ini)]:profile:' \
  '--fails-only[include only failed AWS calls (CSM mode, AWS)]' \
  '--output-file=[output file for generated policy]:file:_files' \
  '--refresh-rate=[flush to console at interval seconds]:seconds:' \
  '--sort-alphabetical[sort actions alphabetically]' \
  '--host=[listening host for CSM]:host:' \
  '--background[run in background and print PID]' \
  '--force-wildcard-resource[force wildcard Resource (AWS)]' \
  '--mode=[listening mode]:mode:(csm proxy)' \
  '--bind-addr=[bind address for proxy mode]:address:' \
  '--ca-bundle=[CA cert bundle for proxy mode]:file:_files' \
  '--ca-key=[CA cert key for proxy mode]:file:_files' \
  '--account-id=[AWS account ID for proxy-mode policy]:account-id:' \
  '--override-aws-map=[replace embedded AWS mapping JSON]:file:_files' \
  '--debug[dump HTTP requests in proxy mode]' \
  && ret=0

return ret
