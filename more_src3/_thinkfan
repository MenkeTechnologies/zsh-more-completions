#compdef thinkfan
# Documentation: https://manpages.debian.org/bookworm/thinkfan/thinkfan.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show short help message]' \
  '-s+[maximum seconds between temperature updates (default: 5)]:sec:' \
  '-b+[bias for temperature spike smoothing (-10 to 30, default 15.0)]:bias:' \
  '-c+[load configuration file]:file:_files -g "*.{yaml,yml}"' \
  '-n[do not become a daemon, log to terminal instead of syslog]' \
  '*-q[reduce logging verbosity (stackable)]' \
  '*-v[increase logging verbosity (stackable)]' \
  '-p+[pulsing-fan workaround for older Thinkpads, optional 0-10s depulse]:sec:' \
  '-d[do not read temperature from sleeping disks]' \
  '-D[DANGEROUS mode: disable all sanity checks (may damage hardware)]' && ret=0

return ret
