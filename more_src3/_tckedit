#compdef tckedit
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tckedit.html
# Source: MRtrix3/mrtrix3 cmd/tckedit.cpp + src/dwi/tractography/roi.cpp (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-inverse[output inverse selection]' \
    '-ends_only[only test streamline ends against ROIs]' \
    '*-include+[include ROI]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-include_ordered+[ordered include ROIs]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-exclude+[exclude ROI]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-mask+[propagation mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-number+[output exactly this many streamlines]:n:_default' \
    '-skip+[skip the first N streamlines]:n:_default' \
    '-maxlength+[max streamline length (mm)]:value:_default' \
    '-minlength+[min streamline length (mm)]:value:_default' \
    '-tck_weights_in+[per-streamline weights for input]:file:_files' \
    '-tck_weights_out+[output per-streamline weights]:file:_files' \
    '*:tracks (last is output):_files -g "*.{tck,trk}"' \
    && ret=0

return ret
