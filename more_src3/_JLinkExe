#compdef JLinkExe JLink
# Documentation: https://wiki.segger.com/J-Link_Commander
# Reference accessed: 2026-06-10

# Zsh completion for JLinkExe / JLink - Segger J-Link Commander

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-device[target device name]:device:' \
  '-if[target interface]:interface:(SWD JTAG FINE cJTAG)' \
  '-speed[interface speed in kHz]:speed:(auto adaptive 100 500 1000 2000 4000 5000 8000 10000 12000 15000 20000 25000 30000 50000)' \
  '-autoconnect[auto connect to target]:mode:(0 1)' \
  '-jtagconf[JTAG chain configuration (IRPre,DRPre)]:config:' \
  '-CommanderScript[execute commander script file]:script file:_files' \
  '-CommandFile[execute command file]:command file:_files' \
  '-Log[log file path]:log file:_files' \
  '-RTTTelnetPort[RTT Telnet port number]:port:' \
  '-SelectEmuBySN[select emulator by serial number]:serial number:' \
  '-IP[J-Link IP address or hostname]:IP address:_hosts' \
  '-USB[select J-Link connected via USB]:USB index:(0 1 2 3)' \
  '-ExitOnError[exit on error]:mode:(0 1)' \
  '-NoGui[suppress GUI dialogs]:mode:(0 1)' \
  '-si[select target interface]:interface:(SWD JTAG FINE cJTAG)' \
  '*:command file:_files' && ret=0

return ret
