#compdef liftOver liftover
# _liftOver — UCSC Genome Bioinformatics liftOver convert features between assembly versions using chain files (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/cgi-bin/hgLiftOver

_liftOver() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-bedPlus=+[N]:n:' \
        '-tab[tab-delimited input]' \
        '-positions[positions instead of intervals]' \
        '-minMatch=+[F]:f:' \
        '-multiple[allow multiple output]' \
        '-noSerial[no serial output]' \
        '-minSizeT=+[N]:n:' \
        '-minSizeQ=+[N]:n:' \
        '-minChainT=+[F]:f:' \
        '-minChainQ=+[F]:f:' \
        '-minBlocks=+[F]:f:' \
        '-fudgeThick[fudge thick start/end]' \
        '-genePred[gene prediction format]' \
        '-sample[sample run only]' \
        '-ends=+[N]:n:' \
        '-haploid[haploid genome]' \
        '-errorHelp[show error help]' \
        '-preserveInput[preserve input]' \
        '-chrom=+[chromosome name]:str:' \
        '*:oldFile mapChain newFile unMapped:_files'
}

_liftOver "$@"
