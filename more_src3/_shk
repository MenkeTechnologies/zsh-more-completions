#compdef shk
# Documentation: https://github.com/Kazuki-tam/security-harness-kit/blob/main/docs/commands.md
# Reference accessed: 2026-05-22
# Verified: upstream docs/commands.md at the URL above.

# Zsh completion for shk - local-first security guardrail CLI for AI-assisted development

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-color[disable colored output]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'shk command' \
      'init[create shk.toml policy file]' \
      'status[show project health summary]' \
      'completions[generate shell completion scripts]' \
      'scan[scan paths for secrets and PII]' \
      'mask[redact sensitive content]' \
      'doctor[run project diagnostics]' \
      'env[encrypt, decrypt, and run with env keys]' \
      'secrets[push dotenv payloads to cloud secret managers]' \
      'hooks[install Git or AI tool hooks]' \
      'ci[generate CI workflows]' \
      'skills[manage bundled AI agent skills]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--strict[write medium fail thresholds]' \
          '--force[overwrite existing policy file]' \
          '--yes[non-interactive init]' \
          '--no-npm-hardening[skip package-manager hardening]' && ret=0
        ;;
      completions)
        _arguments '2:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      scan)
        _arguments \
          '--json[JSON report]' \
          '--verbose[include informational skip findings]' \
          '--fail-on[override failure threshold]:severity:(info low medium high critical)' \
          '--include-binary[scan binary-looking files]' \
          '--follow-symlinks[follow symlinks during traversal]' \
          '--staged[scan Git-staged files]' \
          '--git-history[scan committed Git history]' \
          '--preview[preview git-history scope without scanning blobs]' \
          '--ref[git revision or range for --git-history]:ref:' \
          '--since[limit git history by date]:date:' \
          '--max-commits[limit git history traversal]:count:' \
          '--hook-mode[AI tool hook JSON mode]:tool:(claude-code codex cursor)' \
          '--audit[non-blocking hook audit mode]' \
          '--post[post-tool hook mode]' \
          '1:path:_files -/' && ret=0
        ;;
      mask)
        _arguments \
          '--json[masked content and findings as JSON]' \
          '--output[write masked content to file]:file:_files' \
          '--redaction[redaction style]:style:(full match partial)' \
          '--min-severity[minimum severity to mask]:severity:(info low medium high critical)' \
          '--hook-mode[AI tool hook JSON mode]:tool:(claude-code codex cursor)' \
          '--post[post-tool hook mode]' \
          '1:file:_files' && ret=0
        ;;
      doctor)
        if (( CURRENT == 3 )); then
          _values 'doctor command' ignore env version && ret=0
        else
          _arguments '--json[JSON diagnostics]' && ret=0
        fi
        ;;
      env)
        if (( CURRENT == 3 )); then
          _values 'env command' \
            encrypt decrypt run key dotenvx && ret=0
        elif [[ $line[2] == encrypt || $line[2] == decrypt ]]; then
          _arguments \
            '--output[destination file]:file:_files' \
            '--in-place[encrypt source file in place]' \
            '--env[environment label]:env:' \
            '--key[exact private key variable name]:key:' \
            '--force[overwrite existing output]' \
            '--remove-source[delete plaintext source after encrypt]' \
            '1:dotenv file:_files' && ret=0
        elif [[ $line[2] == run ]]; then
          _arguments \
            '*-f[dotenv file]:file:_files' \
            '--file[dotenv file]:file:_files' \
            '--env[environment label]:env:' \
            '--key[private key variable name]:key:' \
            '--' && ret=0
        elif [[ $line[2] == key ]]; then
          if (( CURRENT == 4 )); then
            _values 'env key command' import list delete export && ret=0
          else
            _arguments \
              '--env[environment label]:env:' \
              '--key[private key variable name]:key:' \
              '--stdin[read key from stdin]' \
              '--force[overwrite stored key]' \
              '--all[delete all native keys]' \
              '--instructions[safe handoff instructions only]' && ret=0
          fi
        elif [[ $line[2] == dotenvx ]]; then
          if (( CURRENT == 4 )); then
            _values 'env dotenvx command' import-keys list run delete && ret=0
          elif [[ $line[3] == run ]]; then
            _arguments \
              '--dotenvx-bin[dotenvx executable]:command:_default' \
              '*-f[env file]:file:_files' \
              '--file[env file]:file:_files' \
              '*--key[stored private key name]:key:' \
              '*--env[environment label]:env:' \
              '--' && ret=0
          elif [[ $line[3] == delete ]]; then
            _arguments \
              '--all[delete all stored dotenvx keys]' \
              '--key[exact private key name]:key:' \
              '--env[environment label]:env:' && ret=0
          else
            _arguments '1:keys file:_files' && ret=0
          fi
        fi
        ;;
      secrets)
        if (( CURRENT == 3 )); then
          _values 'secrets command' push && ret=0
        elif [[ $line[2] == push ]]; then
          _arguments \
            '--profile[secrets profile from shk.toml]:profile:' \
            '--provider[secret manager]:provider:(aws gcp)' \
            '--target[blob mode secret name]:target:' \
            '--target-prefix[per-key mode prefix]:prefix:' \
            '--from[source dotenv file]:file:_files' \
            '--mode[storage mode]:mode:(blob per-key)' \
            '--dry-run[preview writes without provider calls]' \
            '--audit[append metadata to .shk/audit.log]' \
            '--confirm[prompt before writing]' \
            '--yes[skip confirmation]' \
            '--create-if-missing[create missing provider secrets]' \
            '--strict[treat dotenv lint warnings as failures]' \
            '--no-scan[skip pre-push PII scan]' \
            '--region[AWS region]:region:' \
            '--project[GCP project]:project:' \
            '--location[GCP location]:location:' \
            '--expected-env[lint hint for values]:env:' && ret=0
        fi
        ;;
      hooks)
        if (( CURRENT == 3 )); then
          _values 'hooks command' install install-ai && ret=0
        elif [[ $line[2] == install ]]; then
          _arguments '--pre-commit[install Git pre-commit hook]' && ret=0
        elif [[ $line[2] == install-ai ]]; then
          _arguments \
            '--dry-run[print planned changes]' \
            '--audit[non-blocking audit hooks]' \
            '--global[user-level config files]' \
            '--tool[target AI tool]:tool:(claude-code codex cursor)' \
            '--fail-closed[Cursor hooks fail closed]' \
            '--apply-deny[Claude Code permissions.deny entries]' \
            '--apply-sandbox[sandbox hardening for supported tools]' && ret=0
        fi
        ;;
      ci)
        if [[ $line[2] == init && $line[3] == github ]]; then
          _arguments \
            '--mode[workflow mode]:mode:(blocking audit)' \
            '--fail-on[blocking severity threshold]:severity:(info low medium high critical)' \
            '--path[path passed to shk scan]:directory:_directories' \
            '--repo[GitHub repo hosting shk releases]:repo:' \
            '--shk-version[release version to install]:version:' \
            '--installer-name[installer asset name]:name:' \
            '--output[workflow destination path]:file:_files' \
            '--dry-run[print workflow YAML]' \
            '--force[overwrite existing workflow]' && ret=0
        elif [[ $line[2] == init ]]; then
          _values 'ci init target' github && ret=0
        fi
        ;;
      skills)
        if (( CURRENT == 3 )); then
          _values 'skills command' list status install && ret=0
        elif [[ $line[2] == install ]]; then
          _arguments \
            '--tool[target tool]:tool:(claude-code codex cursor all)' \
            '--global[user-level skill directories]' \
            '--dry-run[print planned paths]' \
            '--force[overwrite existing skill file]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
