#compdef swarm
# _swarm — Ethereum Foundation Swarm decentralized storage and content distribution daemon historical bzz (ethersphere team, Go); cli.v1
# upstream: https://github.com/ethersphere/swarm

_swarm() {
    local -a sub=(
        'up:upload data'
        'download:download manifest'
        'ls:list manifest contents'
        'manifest:manifest subcommands'
        'fs:fuse mount'
        'db:db subcommands'
        'export:export chunk database'
        'import:import chunk database'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--bzzapi=+[bzz HTTP API url]:url:_urls' \
        '--datadir=+[data dir]:dir:_files -/' \
        '--keystore=+[keystore dir]:dir:_files -/' \
        '--unlock=+[account]:str:' \
        '--password=+[password file]:file:_files' \
        '--bzznetworkid=+[network id]:n:' \
        '--bzzaccount=+[account]:str:' \
        '--bzzport=+[port]:port:_ports' \
        '--corsdomain=+[domains]:str:' \
        '--pprof[enable pprof]' \
        '--pprofaddr=+[pprof bind]:str:' \
        '--pprofport=+[pprof port]:port:_ports' \
        '--cpuprofile=+[file]:file:_files' \
        '--metrics[enable metrics]' \
        '--swap-api=+[swap api]:url:_urls' \
        '--swap[enable swap accounting]' \
        '--ens-api=+[ens contract addr]:str:' \
        '--ens-addr=+[ens addr]:str:' \
        '--encrypt[encrypt uploads]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swarm subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '--recursive[recursive upload]' \
                    '--encrypt[encrypt upload]' \
                    '--defaultpath=+[default path]:str:' \
                    '*:file:_files' ;;
                download) _arguments \
                    '--recursive[recursive download]' \
                    '*:bzz uri:' ;;
                manifest) _arguments '1:manifest cmd:(add update remove)' ;;
                db) _arguments '1:db cmd:(export import status)' ;;
            esac
            ;;
    esac
}

_swarm "$@"
