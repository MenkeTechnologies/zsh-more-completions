#compdef issw
# Documentation: https://github.com/vovkasm/input-source-switcher
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# issw: macOS input source switcher
# Usage: issw [-h] [-l] [-V] [<input-source-id>]

local curcontext="$curcontext" state line ret=1
local -a sources

_arguments -C \
  '(- *)-h[show help message]' \
  '(- *)-l[list all selectable input sources]' \
  '(- *)-V[print version number]' \
  '1:input source id:->ids' && ret=0

case "$state" in
  ids)
    sources=(${(f)"$(issw -l 2>/dev/null)"})
    _describe -t sources 'input source' sources && ret=0
    ;;
esac

return ret
