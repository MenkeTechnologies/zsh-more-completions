#compdef katago
# Documentation: https://github.com/lightvector/KataGo
# Reference accessed: 2026-05-16
# Verified: upstream lightvector/KataGo cpp/main.cpp subcommand table.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated *.gtp glob (KataGo does not consume .gtp files).

# katago: Go playing engine (GTP/analysis)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'gtp:run as GTP engine'
  'benchmark:benchmark with current model+config'
  'analysis:analysis engine (JSON over stdin/stdout)'
  'match:self-play match between configs'
  'genconfig:interactively generate a config'
  'tuner:tune OpenCL parameters'
  'contribute:contribute selfplay games (distributed training)'
  'evalsgf:evaluate an SGF file'
  'genbook:generate opening book'
  'runtests:run internal tests'
  'version:show version'
)

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'katago command' commands && ret=0 ;;
  (args)
    _arguments \
      '-model[neural net model file]:file:_files' \
      '-config[config file]:file:_files -g "*.cfg(-.)"' \
      '-override-config[override config (key=value,...)]:override:' \
      '-help[show help]' \
      '*:sgf:_files -g "*.sgf(-.)"' && ret=0
    ;;
esac

return ret
