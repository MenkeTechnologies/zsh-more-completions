#compdef triggermesh-controller
# _triggermesh-controller — TriggerMesh controller (reconciles Source/Target/Transformation/Flow CRs into Knative-Serving + Eventing resources)
# upstream: https://github.com/triggermesh/triggermesh
# Source: cmd/triggermesh-controller/main.go on tip — sharedmain-based; runtime config lives in ConfigMaps watched by knative.dev/pkg/configmap.

_triggermesh-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_triggermesh-controller "$@"
