#compdef i3bar
# Documentation: https://github.com/i3/i3/blob/next/man/i3bar.man
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display short help message and exit]' \
  '(- *)'{-v,--version}'[display version number and exit]' \
  '(-b --bar_id)'{-b+,--bar_id=}'[bar ID for which to get config from i3]:bar ID:' \
  '(-s --socket)'{-s+,--socket=}'[path to the i3 IPC socket]:socket:_files' \
  '(-t --transparency)'{-t,--transparency}'[enable transparency (RGBA colors)]' \
  '-V[enable verbose output]' && ret=0

return ret
