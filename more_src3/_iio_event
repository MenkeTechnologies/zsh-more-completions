#compdef iio_event
# _iio_event — listen for events from an IIO device (analogdevicesinc/libiio)
# upstream: https://github.com/analogdevicesinc/libiio
# Common flags from utils/iio_common.c (getopt_long). Positional: <device>

_iio_event() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-u --uri)'{-u+,--uri=}'[IIO context URI]:uri:' \
        '(-S --scan)'{-S+,--scan=}'[scan backends]:backends:' \
        '(-a --auto)'{-a+,--auto=}'[auto-detect context]:backends:' \
        '(-T --timeout)'{-T+,--timeout=}'[I/O timeout (ms)]:ms:' \
        '1:device:'
}

_iio_event "$@"
