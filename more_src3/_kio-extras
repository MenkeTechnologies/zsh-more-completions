#compdef kio-extras kio_http_cache_cleaner kio_smb kio_thumbnail kio_fish kio_audiocd
# _kio-extras — KDE KIO Extras helper binaries (per-protocol worker stems shipped by kio-extras: smb / fish / audiocd / thumbnail / http_cache_cleaner; the binaries are launched by KIO worker dispatcher and accept only standard Qt application options (-style, -platform, -session, --help, --version))
# upstream: https://invent.kde.org/network/kio-extras
# Argument shape from kio-extras KIOSlave/* on tip.

_kio-extras() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--style+[Qt style]:style:' \
        '--platform+[Qt platform]:platform:' \
        '--session+[session id]:id:'
}

_kio-extras "$@"
