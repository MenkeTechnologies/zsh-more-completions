#compdef herd-cli herd
# _herd-cli — Laravel Herd one-click macOS/Windows PHP dev environment CLI alias (laravel team, Go/PHP); cobra
# upstream: https://herd.laravel.com

_herd-cli() {
    local -a sub=(
        'start:start services'
        'stop:stop services'
        'restart:restart services'
        'status:show service status'
        'use:switch php version'
        'list:list available php versions'
        'install:install php version'
        'uninstall:uninstall php version'
        'link:link directory'
        'unlink:unlink directory'
        'parked:list parked sites'
        'links:list linked sites'
        'open:open site in browser'
        'edit:edit site config'
        'log:show logs'
        'tinker:launch tinker'
        'composer:run composer'
        'php:run php'
        'node:run node'
        'pnpm:run pnpm'
        'yarn:run yarn'
        'database:open database manager'
        'mysql:run mysql'
        'postgres:run postgres'
        'redis:run redis'
        'ngrok:share via ngrok'
        'expose:share via expose'
        'isolate:isolate php version for site'
        'unisolate:remove isolation'
        'secured:list secured sites'
        'secure:secure site'
        'unsecure:unsecure site'
        'on-latest-php:list sites on latest php'
        'paths:list parked paths'
        'park:park current dir'
        'forget:forget parked path'
        'completion:dump completion'
        'help:show help'
        'update:update herd'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'herd subcommand' sub ;;
        args)
            case $words[1] in
                use|install|uninstall|isolate) _arguments '1:php version:(8.0 8.1 8.2 8.3 8.4)' ;;
                link|unlink|secure|unsecure|open|edit|forget) _arguments '1:site:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_herd-cli "$@"
