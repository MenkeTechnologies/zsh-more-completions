#compdef systemd-homed
# _systemd-homed (systemd home-directory daemon backing systemd-homectl(1) for portable encrypted user home directories using LUKS/fscrypt/CIFS/subvolume; daemon accepts only standard systemd unit args; all user-facing operations live in homectl(1))
# upstream: https://github.com/systemd/systemd (src/home)
# Argument shape from systemd src/home/homed.c on tip.

_systemd-homed() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-homed "$@"
