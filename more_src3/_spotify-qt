#compdef spotify-qt
# _spotify-qt — spotify-qt lightweight Qt6 Spotify client (C++); uses Spotify Web API + librespot for playback
# upstream: https://github.com/kraxarn/spotify-qt

_spotify-qt() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--debug[debug log]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '--display+[X display]:display:' \
        '*:uri:_urls'
}

_spotify-qt "$@"
