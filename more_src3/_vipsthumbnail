#compdef vipsthumbnail
# Documentation: https://www.libvips.org/API/current/Using-vipsthumbnail.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and libvips/libvips
# tools/vipsthumbnail.c master source.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --size)'{-s+,--size=}'[shrink to SIZE or to WIDTHxHEIGHT]:size:' \
  '--path=[output to path FORMAT (e.g. tn_%s.jpg)]:format:' \
  '--output-profile=[export with PROFILE (output ICC)]:profile:_files -g "*.(icc|icm)"' \
  '--input-profile=[import untagged images with PROFILE]:profile:_files -g "*.(icc|icm)"' \
  '(-a --linear)'{-a,--linear}'[process in linear space]' \
  '(-m --smartcrop)'{-m+,--smartcrop=}'[shrink and crop to fill SIZE using STRATEGY]:strategy:(none centre entropy attention low high all)' \
  '(-n --intent)'{-n+,--intent=}'[ICC transform with INTENT]:intent:(perceptual relative saturation absolute)' \
  '--no-rotate[do not auto-rotate by EXIF orientation]' \
  '--vips-concurrency=[evaluate with N concurrent threads]:N:' \
  '--vips-progress[show progress feedback]' \
  '--vips-leak[leak-check on exit]' \
  '--vips-info[show informative messages]' \
  '--vips-cache-max=[cache at most N operations]:N:' \
  '--vips-cache-max-memory=[cache at most N bytes in memory]:N:' \
  '--vips-cache-max-files=[allow at most N open files]:N:' \
  '--vips-novector[disable vectorised versions of operations]' \
  '--vips-version[print libvips version and exit]' \
  '*:image:_files' && ret=0

return ret
