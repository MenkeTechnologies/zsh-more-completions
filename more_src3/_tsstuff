#compdef tsstuff
# _tsstuff — TSDuck tsstuff MPEG-2 TS stuffing utility inserting null packets to achieve a constant target bitrate with adjustable buffer model and PCR-based timing (tsduck team, C++); custom argparse
# upstream: https://github.com/tsduck/tsduck

_tsstuff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-b+[target bitrate bps]:n:' \
        '--target-bitrate=+[bps]:n:' \
        '-r+[reference pid]:n:' \
        '--reference-pid=+[pid]:n:' \
        '-i+[input bitrate bps]:n:' \
        '--input-bitrate=+[bps]:n:' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-p+[final buffer ms]:n:' \
        '--final-inter-packet=+[ms]:n:' \
        '--initial-inter-packet=+[ms]:n:' \
        '--leading-packets=+[N]:n:' \
        '--trailing-packets=+[N]:n:' \
        '--min-distance=+[ms]:n:' \
        '--max-distance=+[ms]:n:' \
        '--pcr-distance=+[ms]:n:' \
        '--buffer-size=+[bytes]:n:' \
        '--continuity-restamp[restamp CC]' \
        '*:input ts file:_files -g "*.ts *.m2ts *.mpeg *.mpg"'
}

_tsstuff "$@"
