#compdef zstdmt
# _zstdmt-bin — zstd multi-threaded mode (Yann Collet); equivalent to `zstd --threads=auto` for parallel zstandard
# upstream: https://github.com/facebook/zstd

_zstdmt-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-z --compress)'{-z,--compress}'[compress (default)]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-t --test)'{-t,--test}'[test integrity]' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-r --recursive)'{-r,--recursive}'[recurse]' \
        '(-o --output)'{-o,--output}'+[output]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-T --threads)'{-T,--threads}'+[threads]:n:' \
        '--long+[long range mode bits]:n:' \
        '--ultra[allow >19 level]' \
        '(-1)-1[fast]' \
        '(-9)-9[lvl 9]' \
        '(-19)-19[max non-ultra]' \
        '(-22)-22[max ultra]' \
        '--adapt[adaptive]' \
        '--rsyncable[rsyncable]' \
        '--no-progress[no progress]' \
        '--no-check[skip integrity check]' \
        '--no-content-size[no content size]' \
        '--single-thread[single thread]' \
        '--train[dictionary train]' \
        '-B+[block size]:n:' \
        '-M+[memory MB]:n:' \
        '*:file:_files'
}

_zstdmt-bin "$@"
