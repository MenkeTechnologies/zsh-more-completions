#compdef skabus-rpcd
# _skabus-rpcd — skabus skabus-rpcd (the actual RPC bus daemon; accepts Unix clients, applies access rules, routes incoming requests to registered interfaces and back; runs inside skabus-rpc-daemon)
# upstream: https://github.com/skarnet/skabus
# Flags from src/rpc/skabus-rpcd.c on tip.

_skabus-rpcd() {
    _arguments \
        '-v+[verbosity]:n:' \
        '-1[print socket info on fd 1 when ready]' \
        '-c+[max simultaneous clients]:n:' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '(-i -x)-i+[accessrules directory]:dir:_files -/' \
        '(-i -x)-x+[accessrules cdb file]:file:_files' \
        '(-S -s)-S[skip cleanup on lame-duck (fast shutdown)]' \
        '(-S -s)-s[clean up on lame-duck (default)]' \
        '(-J -j)-J[do not register peer journal]' \
        '(-J -j)-j[register peer journal (default)]'
}

_skabus-rpcd "$@"
