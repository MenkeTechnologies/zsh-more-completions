_slap() {
    local -a dotted_keys
    dotted_keys=(
        '--header.messageDuration=[header message display duration in ms (default 5000)]:milliseconds:'
        '--header.blinkRate=[header blink rate in ms (default 500)]:milliseconds:'
        '--header.headerPosition=[header position]:position:(top bottom)'
        '--fileBrowser.width=[file browser sidebar width in columns (default 12)]:columns:'
        '--logger.level=[logging verbosity]:level:(silly verbose debug info warn error silent)'
        '--logger.file=[logger output file path]:file:_files'
        '--perf.profile[run under V8 --prof profiler (fork child with --prof execArgv)]'
        '--bindings.new=[key for new tab (default C-n)]:keybinding:'
        '--bindings.open=[key for open file (default C-o)]:keybinding:'
        '--bindings.quit=[key for quit (default C-q)]:keybinding:'
        '--bindings.help=[key for help (default f2)]:keybinding:'
        '--bindings.toggleFileBrowser=[key for toggling file browser (default f10)]:keybinding:'
        '--bindings.togglePaneList=[key for toggling pane list (default C-l)]:keybinding:'
        '--bindings.nextPane=[key for next pane (default C-M-pagedown)]:keybinding:'
        '--bindings.prevPane=[key for previous pane (default C-M-pageup)]:keybinding:'
        '--pane.bindings.close=[key for close pane (default C-w)]:keybinding:'
        '--editorPane.bindings.saveAs=[key for save-as (default C-s)]:keybinding:'
        '--editorPane.bindings.find=[key for find (default C-f)]:keybinding:'
        '--editorPane.bindings.goLine=[key for go-to-line (default C-g)]:keybinding:'
        '--config=[path to slap config ini file]:file:_files -g "*.(ini|conf)"'
    )

    _arguments -s -S \
        '(- *)'{-h,--help}'[show usage info and exit]' \
        '(- *)'{-v,--version}'[show slap@x, node@x, v8@x versions and exit]' \
        $dotted_keys \
        '*:file to open:_files'
}

_slap "$@"
