#compdef schemachange
# Documentation: https://github.com/Snowflake-Labs/schemachange
# Reference accessed: 2026-05-21
# Verified: upstream README/CLI table.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'deploy:apply pending change scripts'
  'render:render a Jinja template script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config-folder=[folder containing schemachange-config.yml]:dir:_files -/' \
  '--config-file-name=[config YAML file name]:file:' \
  '-a+[Snowflake account identifier]:account:' \
  '--snowflake-account=[Snowflake account identifier]:account:' \
  '-u+[Snowflake user]:user:' \
  '--snowflake-user=[Snowflake user]:user:' \
  '-r+[Snowflake role]:role:' \
  '--snowflake-role=[Snowflake role]:role:' \
  '-w+[Snowflake warehouse]:warehouse:' \
  '--snowflake-warehouse=[Snowflake warehouse]:warehouse:' \
  '-d+[Snowflake database]:database:' \
  '--snowflake-database=[Snowflake database]:database:' \
  '-s+[Snowflake schema]:schema:' \
  '--snowflake-schema=[Snowflake schema]:schema:' \
  '--snowflake-authenticator=[authentication method]:auth:(snowflake oauth externalbrowser snowflake_jwt)' \
  '--snowflake-private-key-file=[private key file]:file:_files' \
  '--snowflake-token-file-path=[OAuth token file]:file:_files' \
  '-f+[root folder for change scripts]:dir:_files -/' \
  '--schemachange-root-folder=[root folder for change scripts]:dir:_files -/' \
  '-m+[modules folder for Jinja macros/templates]:dir:_files -/' \
  '--schemachange-modules-folder=[modules folder]:dir:_files -/' \
  '-c+[change history table name]:table:' \
  '--schemachange-change-history-table=[change history table name]:table:' \
  '-V+[variables in JSON format]:json:' \
  '--schemachange-vars=[variables in JSON format]:json:' \
  '--schemachange-create-change-history-table[create change history table if missing]' \
  '-ac[enable autocommit]' \
  '--schemachange-autocommit[enable autocommit]' \
  '--schemachange-dry-run[simulate deployment without executing]' \
  '--out-of-order[allow out-of-order versioned scripts]' \
  '-Q+[QUERY_TAG to include]:tag:' \
  '--schemachange-query-tag=[QUERY_TAG to include]:tag:' \
  '-L+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--schemachange-log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '-C+[connection profile from connections.toml]:name:' \
  '--schemachange-connection-name=[connection profile from connections.toml]:name:' \
  '--schemachange-connections-file-path=[connections.toml path]:file:_files' \
  '--snowflake-session-parameters=[session parameters JSON]:json:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  subcommand)
    _describe -t commands 'schemachange subcommand' subcommands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
