#compdef Jamulus jamulus
# _jamulus — internet low-latency real-time jam session software (jamulussoftware/jamulus)
# upstream: https://github.com/jamulussoftware/jamulus
# Flags from src/main.cpp.

_jamulus() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-i --inifile)'{-i+,--inifile=}'[initialization file name]:file:_files' \
        '(-n --nogui)'{-n,--nogui}'[disable GUI (server / headless client)]' \
        '(-p --port)'{-p+,--port=}'[local UDP port number]:port:' \
        '--jsonrpcport[JSON-RPC port (server only)]:port:' \
        '--jsonrpcsecretfile[file holding JSON-RPC secret]:file:_files' \
        '--jsonrpcbindip[bind JSON-RPC to IP]:ip:' \
        '(-Q --qos)'{-Q+,--qos=}'[QoS value (0-255)]:qos:' \
        '(-t --notranslation)'{-t,--notranslation}'[disable UI translations]' \
        '(-6 --enableipv6)'{-6,--enableipv6}'[enable IPv6 networking]' \
        '(-d --discononquit)'{-d,--discononquit}'[disconnect all on server quit]' \
        '(-e --directoryaddress)'{-e+,--directoryaddress=}'[directory (formerly central) server address]:address:' \
        '--directoryfile[directory entries file]:file:_files' \
        '(-f --listfilter)'{-f+,--listfilter=}'[server list filter]:filter:' \
        '(-F --fastupdate)'{-F,--fastupdate}'[fast network update rate]' \
        '(-l --log)'{-l+,--log=}'[enable logging to file]:file:_files' \
        '(-L --licence)'{-L,--licence}'[require licence acceptance on connect]' \
        '(-o --serverinfo)'{-o+,--serverinfo=}'[server info "name;city;country"]:info:' \
        '--serverpublicip[public IP of the server]:ip:' \
        '(-P --delaypan)'{-P,--delaypan}'[start with delay panning enabled]' \
        '(-R --recording)'{-R+,--recording=}'[recording directory]:dir:_files -/' \
        '--norecord[disable recording on startup]' \
        '(-s --server)'{-s,--server}'[start in server mode]' \
        '--serverbindip[server bind IP]:ip:' \
        '(-T --multithreading)'{-T,--multithreading}'[enable multithreaded server]' \
        '(-u --numchannels)'{-u+,--numchannels=}'[max channels (server)]:n:' \
        '(-w --welcomemessage)'{-w+,--welcomemessage=}'[welcome message (file or text)]:msg:' \
        '(-c --connect)'{-c+,--connect=}'[auto-connect to server address]:address:' \
        '(-j --nojackconnect)'{-j,--nojackconnect}'[do not auto-connect JACK]' \
        '(-M --mutestream)'{-M,--mutestream}'[start with stream muted]' \
        '(-z --startminimized)'{-z,--startminimized}'[start GUI minimized]'
}

_jamulus "$@"
