#compdef instructor
# Documentation: https://github.com/567-labs/instructor
# Reference accessed: 2026-05-23
# Verified: instructor/cli/*.py Typer subcommands.

# Zsh completion for instructor - Instructor OpenAI utilities CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'instructor command' \
      'jobs[monitor and create fine-tuning jobs]' \
      'files[manage files on OpenAI servers]' \
      'usage[check OpenAI API usage]' \
      'batch[manage OpenAI Batch jobs]' \
      'hub[deprecated instructor hub]' \
      'docs[open Instructor documentation]' && ret=0
    ;;
  args)
    case $line[1] in
      docs)
        _arguments ':search query:' && ret=0
        ;;
      jobs)
        if (( CURRENT == 3 )); then
          _values 'jobs command' \
            'watch[watch fine-tuning jobs]' \
            'create-from-id[create job from file ID]' \
            'create-from-file[create job from file]' \
            'cancel[cancel fine-tuning job]' && ret=0
        fi
        ;;
      files)
        if (( CURRENT == 3 )); then
          _values 'files command' \
            'upload[upload file]' \
            'download[download file]' \
            'delete[delete file]' \
            'status[file status]' && ret=0
        elif [[ $line[2] == delete ]]; then
          _arguments ':file ID:' && ret=0
        fi
        ;;
      batch)
        if (( CURRENT == 3 )); then
          _values 'batch command' \
            'list[list batch jobs]' \
            'watch[watch batch jobs]' \
            'create-from-file[create batch from file]' \
            'cancel[cancel batch job]' \
            'delete[delete completed batch job]' \
            'download-file[download batch output file]' \
            'results[retrieve batch results]' && ret=0
        fi
        ;;
      usage|hub)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
