#compdef hcp
# Documentation: https://developer.hashicorp.com/hcp/docs/cli/commands
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate to HCP'
  'iam:manage IAM principals and policies'
  'organizations:interact with the active organization'
  'packer:manage HCP Packer registries'
  'profile:view or edit hcp CLI properties'
  'projects:create and manage HCP projects'
  'vault-secrets:manage HCP Vault Secrets'
  'version:print CLI version'
  'waypoint:manage HCP Waypoint'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--debug[enable debug output]' \
  '*--format=[output format]:format:(json table pretty)' \
  '*--profile=[profile to use]:profile:' \
  '*--project=[HCP project ID]:id:' \
  '*--quiet[minimize output]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'hcp command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac

return ret
