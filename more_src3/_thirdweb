#compdef thirdweb
# Documentation: https://portal.thirdweb.com/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for thirdweb - thirdweb Web3 development CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a web3 app from official templates'
  'install:add thirdweb packages to existing project'
  'build:compile contract and detect thirdweb contract extensions'
  'generate:fetch contract ABIs to generate types'
  'upload:upload file or directory to IPFS'
  'deploy:deploy contracts to blockchains'
  'publish:publish protocol so other devs can deploy'
  'login:authenticate with thirdweb CLI using API secret key'
  'logout:logout of thirdweb CLI'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'thirdweb command' commands && ret=0
    ;;
  args)
    case $words[1] in
      create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--app[create a web3 app]' \
          '--contract[create a web3 contract project]' \
          '--extension[create a smart contract extension]' \
          '--next[initialize as Next.js]' \
          '--vite[initialize as Vite]' \
          '--react-native[initialize as React Native]' \
          '--node[initialize as Node]' \
          '--forge[initialize as Forge]' \
          '--hardhat[initialize as Hardhat]' \
          '--use-npm[bootstrap using npm]' \
          '--use-pnpm[bootstrap using pnpm]' \
          '--framework=[specify preferred framework]:framework:' \
          '--evm[initialize as Ethereum project]' \
          '--template=[start from a template repository]:template:' \
          '--contract-name=[name the new smart contract]:name:' \
          '1::project path:_directories' && ret=0
        ;;
      upload)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:file or directory:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
