#compdef svbump
# Documentation: https://github.com/schpet/svbump
# Reference accessed: 2026-05-23
# Verified: upstream README usage section.

# Zsh completion for svbump - bump semver in JSON/TOML/YAML config files

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'svbump command' \
      'write[modify version in file]' \
      'read[print current version]' \
      'preview[preview bump without writing]' && ret=0
    ;;
  args)
    case $line[1] in
      (write|preview)
        _arguments \
          ':level:(patch minor major)' \
          ':selector:' \
          ':file:_files' && ret=0
        ;;
      (read)
        _arguments \
          ':selector:' \
          ':file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
