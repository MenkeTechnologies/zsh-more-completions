#compdef samu samurai
# Documentation: https://github.com/michaelforney/samurai (samu.c argv parsing)
# Reference accessed: 2026-05-29
# Samurai — small ninja-compatible C build tool.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '(- *)-h[show help]' \
  '-C+[change to directory before building]:dir:_directories' \
  '-f+[build manifest file (default build.ninja)]:file:_files -g "*.ninja"' \
  '-j+[max parallel jobs (0 = auto-detect)]:n:' \
  '-k+[continue after N failures]:n:' \
  '-l+[max load average for job scheduling]:load:' \
  '-n[dry-run mode (do not execute)]' \
  '*-d+[enable debug output]:flag:(explain keepdepfile keeprsp)' \
  '-t+[run a tool and exit]:tool:(clean commands compdb deps graph query recompact restat targets browse)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*-w+[configure warnings]:warning:(dupbuild=err dupbuild=warn)' \
  '*:target:' && ret=0

return ret
