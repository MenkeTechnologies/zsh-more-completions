#compdef knative-heartbeats heartbeats
# _knative-heartbeats — Knative Eventing reference periodic event source
# upstream: https://github.com/knative/eventing
# Flags from cmd/heartbeats/main.go on tip.

_knative-heartbeats() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--eventSource=[CloudEvents source attribute]:uri:' \
        '--eventType=[CloudEvents type attribute]:type:' \
        '--sink=[destination URL to send heartbeats to]:url:_urls' \
        '--cacerts=[CA cert PEM for sink TLS]:cert:' \
        '--label=[label for emitted heartbeats]:label:' \
        '--period=[interval between heartbeats]:dur:' \
        '--msg=[message content (data.msg)]:msg:'
}

_knative-heartbeats "$@"
