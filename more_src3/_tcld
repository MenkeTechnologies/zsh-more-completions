#compdef tcld
# Documentation: https://github.com/temporalio/tcld
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above documents login/apikey/
# namespace/user/user-group/migration/request/version subcommands and the
# --api-key global flag (TEMPORAL_CLOUD_API_KEY env var equivalent).

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'login:user device-code authentication'
  'apikey:manage API keys'
  'namespace:manage Temporal Cloud namespaces'
  'user:manage users'
  'user-group:manage user groups'
  'migration:migration operations (preview)'
  'request:track asynchronous operation status'
  'version:print version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--api-key=[Temporal Cloud API key]:key:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'tcld command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apikey)
        local -a sub=(
          'create:generate a new API key'
          'list:display API keys'
          'delete:remove an API key'
          'enable:enable an API key'
          'disable:disable an API key'
        )
        _describe -t sub 'apikey subcommand' sub && ret=0 ;;
      (namespace)
        local -a sub=(
          'list:show accessible namespaces'
          'get:retrieve namespace details'
          'accepted-client-ca:manage CA certificates'
          'search-attributes:add or rename search attributes'
        )
        _describe -t sub 'namespace subcommand' sub && ret=0 ;;
      (user)
        local -a sub=(
          'list:list users'
          'get:get user details'
          'invite:invite users'
          'delete:remove users'
          'set-account-role:set account-level role'
          'set-namespace-permissions:set per-namespace permissions'
        )
        _describe -t sub 'user subcommand' sub && ret=0 ;;
      (user-group)
        local -a sub=(
          'list:list groups'
          'get:get group details'
          'delete:delete a group'
          'list-members:list group members'
          'add-users:add users to a group'
          'remove-users:remove users from a group'
          'set-access:configure group permissions'
        )
        _describe -t sub 'user-group subcommand' sub && ret=0 ;;
      (migration)
        local -a sub=(
          'start:start a migration'
          'get:get migration status'
          'handover:perform handover'
          'confirm:confirm migration'
          'abort:abort migration'
        )
        _describe -t sub 'migration subcommand' sub && ret=0 ;;
      (request)
        local -a sub=('get:get request status')
        _describe -t sub 'request subcommand' sub && ret=0 ;;
    esac ;;
esac

return ret
