#compdef hwloc-gather-cpuid
# Documentation: man hwloc-gather-cpuid(1)
# Source: open-mpi/hwloc utils/hwloc/hwloc-gather-cpuid.c (master) — dump CPUID for hwloc input (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[logical processor index]:N:_default' \
    '(-q --quiet -s)'{-q,--quiet,-s}'[suppress verbose messages]' \
    '--version[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1::output directory:_files -/' \
    && ret=0

return ret
