#compdef typesense-server
# _typesense-server — Typesense open-source search engine server (Algolia-style typo-tolerant search with vector / hybrid support; serves HTTP API on :8108 + Raft peering on :8107)
# upstream: https://github.com/typesense/typesense
# Flags from src/typesense_server_utils.cpp init_cmdline_options on tip; --data-dir and --api-key are required.

_typesense-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-d --data-dir)'{-d+,--data-dir=}'[data directory (required)]:dir:_files -/' \
        '(-a --api-key)'{-a+,--api-key=}'[bootstrap API key with all permissions (required)]:key:' \
        '(-s --search-only-api-key)'{-s+,--search-only-api-key=}'[deprecated search-only API key]:key:' \
        '--health-rusage-api-key=[API key allowed to read /debug + rusage]:key:' \
        '--analytics-dir=[analytics directory]:dir:_files -/' \
        '--analytics-db-ttl=[analytics event TTL (sec)]:sec:' \
        '--analytics-minute-rate-limit=[/events per-minute rate limit]:n:' \
        '--shutdown-delay-seconds=[shutdown delay after signal]:sec:' \
        '--api-address=[HTTP bind address]:ip:' \
        '--api-port=[HTTP API port]:port:' \
        '--peering-address=[Raft peer bind address]:ip:' \
        '--peering-port=[Raft peer port]:port:' \
        '--peering-subnet=[Raft peer subnet]:cidr:' \
        '--nodes=[path to file with cluster node list]:file:_files' \
        '(-c --ssl-certificate)'{-c+,--ssl-certificate=}'[TLS cert file]:file:_files' \
        '(-k --ssl-certificate-key)'{-k+,--ssl-certificate-key=}'[TLS key file]:file:_files' \
        '--ssl-refresh-interval-seconds=[TLS reload interval]:sec:' \
        '--http-client-ca-certificate=[CA bundle for outbound HTTPS]:file:_files' \
        '--enable-cors=[enable CORS]:bool:(true false)' \
        '--cors-domains=[comma-separated CORS-allowed domains]:list:' \
        '--max-memory-ratio=[max fraction of system memory to use]:frac:' \
        '--snapshot-interval-seconds=[Raft snapshot interval]:sec:' \
        '--snapshot-max-byte-count-per-rpc=[max snapshot bytes per RPC]:bytes:' \
        '--healthy-read-lag=[max read lag before rejecting]:n:' \
        '--healthy-write-lag=[max write lag before rejecting]:n:' \
        '--log-slow-requests-time-ms=[log requests slower than this (ms; -1=off)]:ms:' \
        '--num-collections-parallel-load=[collections loaded in parallel at startup]:n:' \
        '--num-documents-parallel-load=[documents per collection loaded in parallel]:n:' \
        '--thread-pool-size=[request handler thread pool size]:n:' \
        '--log-dir=[log directory]:dir:_files -/' \
        '--config=[INI config file]:file:_files' \
        '--enable-access-logging[enable access log]' \
        '--enable-search-logging[enable search log]' \
        '--enable-search-analytics[enable search analytics]' \
        '--disk-used-max-percentage=[reject writes when disk used >= %]:pct:' \
        '--memory-used-max-percentage=[reject writes when memory used >= %]:pct:' \
        '--skip-writes[skip all writes except config changes]' \
        '--reset-peers-on-error[reset peers on Raft error]' \
        '--log-slow-searches-time-ms=[log searches slower than this (ms; -1=off)]:ms:' \
        '--cache-num-entries=[entries in the in-memory cache]:n:' \
        '--embedding-cache-num-entries=[entries in the embedding cache]:n:' \
        '--analytics-flush-interval=[analytics persist interval (sec)]:sec:' \
        '--housekeeping-interval=[housekeeping interval (sec)]:sec:' \
        '--enable-lazy-filter[evaluate filter_by lazily]' \
        '--db-compaction-interval=[RocksDB compaction interval (sec)]:sec:' \
        '--filter-by-max-ops=[max operations per filter_by clause]:n:' \
        '--max-per-page=[max hits per page]:n:' \
        '--max-group-limit=[max results per group]:n:'
}

_typesense-server "$@"
