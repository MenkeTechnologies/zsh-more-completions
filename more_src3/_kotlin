#compdef kotlin
# Documentation: kotlin -h (JetBrains)
# Source: run Kotlin programs, scripts, or REPL.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-help,-h}'[show help]' \
    '(- *)-version[show Kotlin version]' \
    '-howtorun+[how to run the command]:mode:(guess classfile jar script)' \
    '(-classpath -cp)'{-classpath+,-cp+}'[user classpath]:path:_files -/' \
    '*-D+[set JVM system property]:name=value:' \
    '*-J+[pass option to JVM]:option:' \
    '-no-stdlib[exclude Kotlin stdlib from classpath]' \
    '-no-reflect[exclude Kotlin reflection from classpath]' \
    '-compiler-path+[Kotlin compiler classpath]:path:_files' \
    '*-X-[pass compiler -X flag]:flag:' \
    '(-expression -e)'{-expression+,-e+}'[evaluate expression]:expr:' \
    '-repl[start Kotlin REPL]' \
    '*:script class or jar:_files -g "*.(kts|jar|class)"' \
    && ret=0

return ret
