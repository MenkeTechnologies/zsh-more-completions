#compdef xkill
# Documentation: man xkill(1)
# Source: xkill — force the X server to close a client connection by window selection.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-display[X server displayname]:displayname:' \
    '-id[X resource id of window/client to kill]:resource:' \
    '-button[pointer button number to use (or "any")]:n-or-any:' \
    '-frame[treat root-direct children as top-level windows]' \
    '-all[kill all clients with top-level windows on the screen]' \
    '(- *)-version[print version and exit]' \
    && ret=0

return ret
