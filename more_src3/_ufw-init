#compdef ufw-init
# _ufw-init — ufw helper script (boot-time wrapper that loads /etc/ufw/before*.rules + user.rules + after*.rules from /usr/share/ufw/iptables/init into the kernel; subcommands: start, stop, restart, status, force-reload, flush-all, force-stop; used internally by the ufw systemd unit but exposed for sysadmin diagnostics)
# upstream: https://launchpad.net/ufw
# Subcommands from ufw setup/ufw-init.in on tip.

_ufw-init() {
    _arguments \
        '-h[show help]' \
        '1:command:(start stop restart status force-reload flush-all force-stop)'
}

_ufw-init "$@"
