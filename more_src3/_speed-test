_speed-test() {
    _arguments -s -S \
        '(-j --json)'{-j,--json}'[output the result as JSON]' \
        '(-b --bytes)'{-b,--bytes}'[output the result in megabytes per second (MBps)]' \
        '(-v --verbose)'{-v,--verbose}'[output more detailed information (server, location, distance)]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]'
}

_speed-test "$@"
