#compdef hexdump-cli
# _hexdump-cli — util-linux hexdump ASCII/decimal/hex/octal dump CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_hexdump-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[one-byte octal display]' \
        '--one-byte-octal[one-byte octal display]' \
        '-c[one-byte character display]' \
        '--one-byte-char[one-byte character display]' \
        '-C[canonical hex+ASCII display]' \
        '--canonical[canonical hex+ASCII display]' \
        '-d[two-byte decimal display]' \
        '--two-bytes-decimal[two-byte decimal display]' \
        '-e+[format]:str:' \
        '--format=+[format]:str:' \
        '-f+[format file]:file:_files' \
        '--format-file=+[format file]:file:_files' \
        '-L+[color mode]:c:(auto never always)' \
        '--color=+[color mode]:c:(auto never always)' \
        '-n+[bytes to read]:n:' \
        '--length=+[bytes to read]:n:' \
        '-o[two-byte octal display]' \
        '--two-bytes-octal[two-byte octal display]' \
        '-s+[skip offset]:str:' \
        '--skip=+[skip offset]:str:' \
        '-v[show all data]' \
        '--no-squeezing[show all data]' \
        '-x[two-byte hexadecimal display]' \
        '--two-bytes-hex[two-byte hexadecimal display]' \
        '*:files:_files'
}

_hexdump-cli "$@"
