#compdef lage
# _lage — Microsoft Lage monorepo task runner
# upstream: https://github.com/microsoft/lage

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--concurrency=[max parallel tasks]:number' \
  '--profile[generate a profile for tasks]' \
  '--reporter=[reporter to use]:reporter:(json verbose)' \
  '--grouped[group task output by package]' \
  '--log-level=[log verbosity]:level:(error warn info verbose silly)' \
  '--node=[node args to pass through]:args' \
  '--to=[run up to and including these packages]:packages' \
  '--scope=[run only in these packages]:packages' \
  '--since=[run only for packages changed since ref]:ref' \
  '--ignore=[ignore changes in these paths]:paths' \
  '--no-deps[do not run dependencies]' \
  '--no-dependents[do not run dependents]' \
  '--no-cache[skip reading from cache]' \
  '--reset-cache[invalidate existing cache]' \
  '--continue[continue running on failure]' \
  '--allow-no-target-runs[allow tasks with no matching target]' \
  '--cache[enable or disable caching]:enabled:(true false)' \
  '--only[run the specified tasks only, no dependencies]' \
  '--server[run in server mode]' \
  '--timeout=[task timeout in seconds]:seconds' \
  '*:task:' && ret=0

return ret
