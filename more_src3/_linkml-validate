#compdef linkml-validate
# _linkml-validate — validate data instances against a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from src/linkml/validator/cli.py (click).

_linkml-validate() {
    local -a args
    args=(
        '(-s --schema)'{-s+,--schema=}'[LinkML schema YAML]:file:_files -g "*.(yaml|yml)"'
        '(-C --target-class)'{-C+,--target-class=}'[root class the input(s) instantiate]:class:'
        '--config=[validator YAML configuration]:file:_files -g "*.(yaml|yml)"'
        '--exit-on-first-failure[stop validation at the first error]'
        '--include-context[include source context in error messages]'
        '--no-include-context[omit source context from error messages]'
        '--allow-null-for-optional-enums[treat null as a valid value for optional enum slots]'
        '*--include=[only validate files / classes matching this pattern]:pattern:'
        '--fix[apply auto-fixes to a single YAML / JSON input]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '*:input data file:_files'
    )
    _arguments -s -S $args
}

_linkml-validate "$@"
