#compdef lha
# Documentation: man lha(1)
# Source: jca02266/lha src/lharc.c (master) — LHa archive manager (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--system-kanji-code=[system kanji encoding]:enc:(euc sjis utf8 latin1 cap)' \
    '--archive-kanji-code=[archive kanji encoding]:enc:(euc sjis utf8 latin1 cap)' \
    '--extract-broken-archive[allow extracting broken archives]' \
    '--convert-filename-case[convert filename case]' \
    '--ignore-mac-files[ignore macOS resource forks]' \
    '--timestamp-archive[preserve timestamp on archive]' \
    '--traditional[traditional mode]' \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:((
        a\:add\ files\ to\ archive
        x\:extract\ files\ from\ archive
        e\:extract\ files\ from\ archive
        l\:list\ archive\ contents
        v\:verbose\ list\ archive\ contents
        u\:update\ files\ in\ archive
        d\:delete\ files\ from\ archive
        m\:move\ files\ into\ archive
        c\:create\ archive
        p\:print\ files\ to\ stdout
        t\:test\ integrity\ of\ archive
    ))' \
    '2:archive file:_files -g "*.{lzh,lha}"' \
    '*:file:_files' \
    && ret=0

return ret
