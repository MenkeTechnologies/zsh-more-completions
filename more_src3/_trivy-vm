#compdef trivy-vm
# _trivy-vm — Aqua Trivy VM image scanner subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-vm() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--timeout=+[timeout]:dur:' \
        '--format=+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github)' \
        '-f+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--ignore-unfixed[ignore unfixed]' \
        '--exit-code=+[exit code]:n:' \
        '--ignorefile=+[ignore file]:file:_files' \
        '--scanners=+[scanners]:list:(vuln secret misconfig license)' \
        '--skip-files=+[skip files]:list:' \
        '--skip-dirs=+[skip dirs]:list:_files -/' \
        '--list-all-pkgs[list all packages]' \
        '--vuln-type=+[vuln type]:list:(library os)' \
        '--ignore-policy=+[ignore policy]:file:_files -g "*.rego"' \
        '--skip-db-update[skip db update]' \
        '--db-repository=+[db repo]:str:' \
        '--skip-java-db-update[skip java db update]' \
        '--no-progress[no progress]' \
        '--offline-scan[offline scan]' \
        '--server=+[remote scanner server URL]:url:_urls' \
        '--token=+[server token]:str:' \
        '--token-header=+[server token header]:str:' \
        '--compliance=+[compliance spec]:spec:' \
        '--report=+[report mode]:r:(all summary)' \
        '*:vm-image:_files'
}

_trivy-vm "$@"
