#compdef wasmer-cli
# Documentation: https://github.com/wasmerio/wasmer (lib/cli/src/commands/)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: primary wasmer completion lives in _wasmer. This is the legacy
# wasmer-cli binary name (shares the same flags).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:Add a package to the project'
  'app:Wasmer Edge app commands'
  'auth:Authentication'
  'binfmt:Manage binfmt_misc registration'
  'cache:Manage the Wasmer cache'
  'compile:Compile a WebAssembly binary'
  'config:Show Wasmer configuration'
  'connect:Connect to a remote runtime'
  'container:Container subcommands'
  'create-exe:Create a native executable'
  'create-obj:Create a native object'
  'deploy:Deploy an app to Wasmer Edge'
  'domain:Domain commands'
  'gen-c-header:Generate a C header'
  'init:Initialize a wasmer.toml'
  'inspect:Inspect a wasm/wat file'
  'journal:Journal commands'
  'login:Log in to Wasmer'
  'logout:Log out'
  'namespace:Namespace commands'
  'package:Package commands'
  'publish:Publish a package'
  'run:Run a wasm file'
  'self-update:Update wasmer'
  'ssh:Open SSH to an Edge instance'
  'validate:Validate a WebAssembly binary'
  'wast:Run a WAST test script'
  'completions:Generate completions'
  'help:Show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*-v[increase verbosity]' \
  '*--log-format=[log format]:format:(text json)' \
  '*--registry=[registry URL]:url' \
  '*--token=[token]:token' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wasmer command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--invoke=[function name]:fn' \
          '--addr=[bind address]:addr' \
          '*--env=[env var (KEY=VALUE)]:var' \
          '*--mapdir=[map directory (GUEST:HOST)]:mapping' \
          '*--dir=[pre-open directory]:dir:_directories' \
          '*--coredump-on-trap=[coredump file path]:file:_files' \
          '--enable-all[enable all features]' \
          '--enable-bulk-memory[enable bulk memory]' \
          '--enable-multi-memory[enable multi memory]' \
          '--enable-multi-value[enable multi value]' \
          '--enable-reference-types[enable reference types]' \
          '--enable-simd[enable SIMD]' \
          '--enable-threads[enable threads]' \
          '--llvm[LLVM compiler]' \
          '--cranelift[Cranelift compiler]' \
          '--singlepass[Singlepass compiler]' \
          '*: :_files -g "*.(wasm|wat|webc)"' && ret=0 ;;
      (compile|create-exe|create-obj|inspect|gen-c-header)
        _arguments \
          '-o+[output]:file:_files' \
          '--target=[target triple]:t' \
          '--cpu-features=[CPU features (csv)]:list' \
          '--llvm[LLVM]' \
          '--cranelift[Cranelift]' \
          '--singlepass[Singlepass]' \
          '*: :_files -g "*.(wasm|wat)"' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
