#compdef terralist
# Documentation: https://github.com/terralist/terralist
# Reference accessed: 2026-05-21
# Verified: upstream README — terralist is a self-hosted Terraform/OpenTofu
# private registry server. Primary invocation is `terralist server --config
# config.yaml`. Most configuration goes through the YAML config file rather
# than CLI flags.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'server:start the terralist registry server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t cmds 'terralist command' commands && ret=0 ;;
  args)
    case $line[1] in
      server)
        _arguments \
          '--config=[path to YAML config file]:file:_files -g "*.yaml *.yml"' && ret=0
        ;;
    esac
    ;;
esac

return ret
