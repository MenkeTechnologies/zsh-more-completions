#   * newspeak/somns (R712) — Gilad Bracha's modular Smalltalk
#   * dart (older entry?) — Bak + Lund's mobile/web-focused
#     Smalltalk descendant
#   * toit (R736) — Bak + Lund's microcontroller Smalltalk descendant
#   * strongtalk (R740 THIS) — the OPTIONAL-TYPING + JIT-TYPE-
#     FEEDBACK ancestor of HotSpot + V8 + Dart + Toit
#
# -----------------------------------------------------------------------------
#
# THE strongtalk CLI
#
# strongtalk is invoked as:
#   strongtalk          # full release build
#   strongtalk_fast     # debug + optimization (development)
#   strongtalk_debug    # full debug build with assertions
#
# All three binaries expect the following files in the current
# directory:
#   strongtalk.bst                  Smalltalk image file (system state)
#   .strongtalkrc                   VM configuration options
#
# Common invocations:
#   # Launch full release build (requires strongtalk.bst + .strongtalkrc)
#   cd $STRONGTALK_HOME && strongtalk
#
#   # Launch development build with assertions
#   cd $STRONGTALK_HOME && strongtalk_debug
#
#   # Launch fast build (assertions off, debugging on)
#   cd $STRONGTALK_HOME && strongtalk_fast
#
# OPTIONS:
#
# Strongtalk is image-based — the binary takes minimal command-
# line arguments and loads its configuration from
# `.strongtalkrc` in the working directory.  Most VM behavior
# is controlled by:
#
# Configuration file: .strongtalkrc
#   Lines of the form: option=value
#   Common options:
#     image=<path>           Image file (default: strongtalk.bst)
#     heap=<MB>              Initial heap size in megabytes
#     bootimage=<path>       Alternate boot image
#     verbose=<bool>         Enable verbose VM startup
#     trace=<bool>           Enable JIT trace
#     debug=<bool>           Enable debug mode
#
# Image files:
#   strongtalk.bst           Production image file
#                            (binary snapshot of system state)
#
# Companion binaries:
#   strongtalk_debug         Debug configuration (assertions on)
#   strongtalk_fast          Fast configuration (between debug + release)
#   strongtalk               Release configuration (optimized)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Strongtalk is image-based with minimal CLI; primary
# configuration is via .strongtalkrc.  Provide file
# completion for image-file paths.

_arguments -s -S \
    '1:Strongtalk image file:_files -g "*.bst"' \
    && ret=0

return ret
