#compdef haproxy-cli
# _haproxy-cli — Willy Tarreau HAProxy reliable high-performance TCP/HTTP LB CLI alias (haproxy team, C); custom argparse
# upstream: https://github.com/haproxy/haproxy

_haproxy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-vv[show version + build details]' \
        '-c[check config syntax]' \
        '-cc+[check config conditional]:str:' \
        '-conf+[config file]:file:_files -g "haproxy.cfg"' \
        '-f+[config file or dir]:file:_files -g "haproxy.cfg"' \
        '-D[daemon mode]' \
        '-W[master-worker mode]' \
        '-Ws[master-worker systemd]' \
        '-p+[pid file]:file:_files' \
        '-db[disable backgrounding]' \
        '-de[disable epoll()]' \
        '-dk[disable kqueue()]' \
        '-dl[show all options]' \
        '-dM+[poison free memory]:str:' \
        '-dp[disable poll()]' \
        '-dS[no splice]' \
        '-dV[disable getaddrinfo()]' \
        '-de[disable epoll()]' \
        '-dG[no getaddrinfo]' \
        '-dR[no SO_REUSEPORT]' \
        '-d4[force ipv4]' \
        '-d6[force ipv6]' \
        '-dW[refuse warnings]' \
        '-dF[disable fast-forwarding]' \
        '-dZ[zero warning]' \
        '-dC+[diag check]:str:' \
        '-m+[max memory mb]:n:' \
        '-N+[max connections]:n:' \
        '-n+[max conn per process]:n:' \
        '-q[quiet]' \
        '-st+[pids]:str:' \
        '-sf+[pids (soft)]:str:' \
        '-x+[unix socket]:file:_files' \
        '-S+[bind addresses (master CLI)]:str:' \
        '-V[verbose]' \
        '-L+[local peer name]:str:' \
        '-C+[change directory]:dir:_files -/' \
        '*:arg:'
}

_haproxy-cli "$@"
