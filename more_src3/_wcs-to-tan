#compdef wcs-to-tan
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/wcs-to-tan.1 — approximate any WCS with TAN projection (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-w+[input WCS file]:file:_files -g "*.{wcs,fits,fit}"' \
    '-o+[output TAN WCS file]:file:_files' \
    '-e+[FITS extension to read]:n:_default' \
    '-t[strip TAN-SIP polynomials (force pure TAN)]' \
    '-L[log progress]' \
    '-x+[x-lo (pixels)]:n:_default' \
    '-y+[y-lo (pixels)]:n:_default' \
    '-W+[x-hi (pixels)]:n:_default' \
    '-H+[y-hi (pixels)]:n:_default' \
    '-N+[grid points per side]:n:_default' \
    '-v[verbose]' \
    && ret=0

return ret
