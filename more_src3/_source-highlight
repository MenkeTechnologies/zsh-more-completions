#compdef source-highlight
# Documentation: source-highlight --help (GNU source-highlight)
# Source: syntax-highlight source code to HTML/LaTeX/etc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--detailed-help[show detailed help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-i+,--input=}'[input file (default stdin)]:file:_files' \
    {-o+,--output=}'[output file (or STDOUT)]:file:_files' \
    {-s+,--src-lang=}'[source language]:lang:' \
    '--lang-list[list supported source languages]' \
    '--outlang-list[list supported output languages]' \
    {-f+,--out-format=}'[output format]:fmt:(html html-css xhtml xhtml-css latex texinfo docbook ansi esc esc256 javadoc xml)' \
    {-d,--doc}'[create stand-alone output file]' \
    '--no-doc[cancel implied --doc]' \
    {-c+,--css=}'[CSS file for HTML/XHTML]:file:_files -g "*.css"' \
    '--gen-references=[generate references]:type:(no inline postline postdoc)' \
    '--ctags=[ctags command options]:opts:' \
    '--ctags-file=[ctags file]:file:_files' \
    {-n+,--line-number=-}'[line numbering with separator (default _)]::separator:' \
    '--line-number-ref=-[line numbers as anchors with prefix]::prefix:' \
    '*'{-T+,--title=}'[title for output document]:title:' \
    '--tab=[tab stops]:n:' \
    '--header=[file with header text]:file:_files' \
    '--footer=[file with footer text]:file:_files' \
    '--style-file=[style definition file]:file:_files' \
    '--style-css-file=[CSS style file]:file:_files' \
    '--outlang-def=[output language definition]:file:_files' \
    '--data-dir=[data directory]:dir:_files -/' \
    '--lang-def=[language definition file]:file:_files' \
    '--config-file=[config file]:file:_files' \
    '--output-dir=[output directory]:dir:_files -/' \
    '*--regex-strings=[regex for strings]:regex:' \
    {-q,--quiet}'[suppress informational messages]' \
    {-v,--verbose}'[verbose output]' \
    '--check-lang=[check language definition]:lang:' \
    '--failsafe[output even when language unknown]' \
    '--gen-version[print version in output]' \
    '--no-gen-version[do not print version in output]' \
    '--binary[do not perform end-of-line normalization]' \
    '*:source file:_files' \
    && ret=0

return ret
