#compdef humann humann3
# _humann — Huttenhower Lab humann CLI The HMP Unified Metabolic Analysis Network functional profiler for shotgun metagenomes and metatranscriptomes producing per-sample microbial pathway abundance gene-family coverage taxon-stratified output table joining MetaCyc UniRef90 KEGG MetaPhlAn4 ChocoPhlAn3 (Huttenhower Lab team, Python); argparse
# upstream: https://github.com/biobakery/humann

_humann() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[input file]:file:_files -g "*.fq *.fastq *.fa *.fasta *.sam *.bam *.gz *.bz2 *.biom *.tsv"' \
        '--input=+[file]:file:_files -g "*.fq *.fastq *.fa *.fasta *.sam *.bam *.gz *.bz2 *.biom *.tsv"' \
        '-o+[output directory]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '--output-format=+[fmt]:f:(tsv biom)' \
        '--output-basename=+[name]:str:' \
        '--memory-use=+[m]:m:(minimum maximum)' \
        '--threads=+[N]:n:' \
        '--input-format=+[f]:f:(fastq fastq.gz fasta fasta.gz sam bam biom genetable)' \
        '--metaphlan=+[dir]:dir:_files -/' \
        '--metaphlan-options=+[args]:str:' \
        '--prescreen-threshold=+[N]:n:' \
        '--bypass-prescreen[skip prescreen]' \
        '--bypass-nucleotide-index[skip nucleotide index]' \
        '--bypass-nucleotide-search[skip nucleotide search]' \
        '--bypass-translated-search[skip translated search]' \
        '--bypass-quality-control[skip QC]' \
        '--remove-temp-output[remove temp output]' \
        '--remove-stratified-output[remove stratified output]' \
        '--remove-column-description-output[remove column descriptions]' \
        '--input-format-options=+[opts]:str:' \
        '--diamond=+[file]:file:_files' \
        '--bowtie2=+[file]:file:_files' \
        '--evalue=+[N]:str:' \
        '--annotation-gene-index=+[N]:n:' \
        '--id-mapping=+[file]:file:_files' \
        '--translated-alignment=+[a]:a:(usearch rapsearch diamond)' \
        '--search-mode=+[m]:m:(uniref50 uniref90)' \
        '--nucleotide-database=+[dir]:dir:_files -/' \
        '--protein-database=+[dir]:dir:_files -/' \
        '--utility-mapping=+[dir]:dir:_files -/' \
        '--pathways=+[p]:p:(metacyc unipathway)' \
        '--xipe=+[m]:m:(on off)' \
        '--minpath=+[m]:m:(on off)' \
        '--gap-fill=+[m]:m:(on off)' \
        '--pathways-database=+[file]:file:_files' \
        '--taxonomic-profile=+[file]:file:_files' \
        '*::'
}

_humann "$@"
