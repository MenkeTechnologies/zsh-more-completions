#compdef kool
# Documentation: https://kool.dev/docs/commands-reference/kool
# Reference accessed: 2026-05-19
# Verified: upstream commands reference at the URL above.

# Zsh completion for kool. Added real subcommands and flags
# (--verbose, -w/--working_dir); removed invented -V/--version.

local curcontext="$curcontext" state line ret=1

_kool_commands() {
  local -a commands=(
    'cloud:interact with Kool.dev Cloud and manage deployments'
    'create:create a new project using a preset'
    'docker:create a new container'
    'exec:execute a command inside a running service container'
    'info:print out information about the local environment'
    'logs:display log output from running service containers'
    'preset:install configuration files customized for Kool'
    'recipe:add configuration for a recipe in the current directory'
    'restart:restart running service containers'
    'run:execute a script defined in kool.yml'
    'self-update:update kool to the latest version'
    'share:live share your local environment on the Internet'
    'start:start service containers defined in docker-compose.yml'
    'status:show the status of all service containers'
    'stop:stop and destroy running service containers'
    'completion:generate shell completion script'
  )
  _describe -t commands 'kool command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[help for kool]' \
  '--verbose[increase output verbosity]' \
  '(-w --working_dir)'{-w+,--working_dir=}'[change the working directory for the command]:dir:_files -/' \
  '1: :_kool_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
