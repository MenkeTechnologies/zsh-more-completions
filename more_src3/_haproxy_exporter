#compdef haproxy_exporter
# Documentation: https://github.com/prometheus/haproxy_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--haproxy.scrape-uri=[URI on which to scrape HAProxy]:uri:' \
  '--haproxy.ssl-verify[verify SSL certificates when scraping]' \
  '--haproxy.server-metric-fields=[comma-separated list of server metric fields to export]:fields:' \
  '--haproxy.server-exclude-states=[comma-separated list of server states to exclude]:states:' \
  '--haproxy.timeout=[timeout for trying to get stats]:duration:' && ret=0

return ret
