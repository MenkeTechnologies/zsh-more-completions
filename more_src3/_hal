#compdef hal halyard
# Documentation: https://spinnaker.io/docs/reference/halyard/commands/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Note: halyard is deprecated and no longer supported per upstream.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'admin:administrative tasks for Halyard daemon'
  'backup:create or restore deployment backups'
  'config:edit deployment configuration in ~/.hal/config'
  'deploy:apply your deployment to the target environment'
  'plugins:manage Spinnaker plugins and repositories'
  'shutdown:shutdown the Halyard daemon'
  'spin:install the Spin CLI tool'
  'task:inspect task status'
  'version:show Spinnaker versions or set a version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show Halyard version]' \
  '--ready[check daemon readiness]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-l --log)'{-l+,--log=}'[log level]:level:(TRACE DEBUG INFO WARN ERROR)' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml plain)' \
  '(-c --color)'{-c,--color}'[enable color]' \
  '--no-color[disable color]' \
  '(-a --alpha)'{-a,--alpha}'[enable alpha commands]' \
  '(-d --deployment)'{-d+,--deployment=}'[deployment name]:name:' \
  '--daemon-endpoint=[Halyard daemon URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hal command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '*::sub:(canary ci deploy edit features generate metric-stores notification provider repository security storage stats version webhook artifact)' && ret=0 ;;
      (deploy)
        _arguments \
          '*::sub:(apply collect-logs component-versions connect details rollback)' && ret=0 ;;
      (version)
        _arguments \
          '*::sub:(latest list bom commits)' && ret=0 ;;
      (backup)
        _arguments \
          '*::sub:(create restore)' && ret=0 ;;
      (admin)
        _arguments \
          '*::sub:(publish bom changelog deploy-runtime sso)' && ret=0 ;;
      (task)
        _arguments \
          '*::sub:(get list)' && ret=0 ;;
      (plugins)
        _arguments \
          '*::sub:(list add remove repository)' && ret=0 ;;
    esac ;;
esac

return ret
