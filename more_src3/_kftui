#compdef kftui
# Documentation: https://github.com/hcavarsan/kftray/blob/main/docs/kftui/USAGE.md
# Source: hcavarsan/kftray TUI port-forward manager.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--configs-path=[load configurations from local JSON file]:file:_files -g "*.json"' \
    '--github-url=[import configs from a GitHub repository]:url:_default' \
    '--json=[pass JSON configuration directly]:json:_default' \
    '--stdin[read configurations from standard input]' \
    '--save[store configurations in the local database]' \
    '--flush[clear existing configurations before importing]' \
    '--auto-start[begin all port-forwards immediately after loading]' \
    '--auto-discover[discover services from Kubernetes annotations]' \
    '--context=[Kubernetes context for discovery]:context:_default' \
    '--kubeconfig=[path to kubeconfig file]:file:_files' \
    '--alias-as-domain[enable alias-as-domain for discovered configs]' \
    '--auto-loopback[enable auto loopback address for discovered configs]' \
    '--non-interactive[run without the TUI for automation]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
