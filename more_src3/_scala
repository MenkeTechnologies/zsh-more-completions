#compdef scala
# _scala — Scala launcher / REPL CLI alias (Lightbend / EPFL / Scala Center, Scala); custom argparse
# upstream: https://github.com/scala/scala

_scala() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-V[print extended options]' \
        '-Y[print private options]' \
        '-W[print warning options]' \
        '-bootclasspath+[boot class path]:list:_files' \
        '-classpath+[class path]:list:_files' \
        '-cp+[class path]:list:_files' \
        '-d+[output directory or jar]:dst:_files' \
        '-encoding+[source encoding]:enc:' \
        '-explaintypes[explain type errors]' \
        '-extdirs+[ext dirs]:list:_files -/' \
        '-feature[emit feature warnings]' \
        '-g:+[debug info]:lvl:(none source line vars notailcalls)' \
        '-help-and-exit[show help and exit]' \
        '-i+[script file]:file:_files -g "*.scala *.sc"' \
        '-I+[load file as init]:file:_files' \
        '-e+[execute Scala code]:str:' \
        '-savecompiled[save compiled file]' \
        '-howtorun=+[how to run]:m:(script jar object guess)' \
        '-language:+[language features]:list:' \
        '-nc[no compilation daemon]' \
        '-no-specialization[no specialization]' \
        '-nobootcp[no bootclasspath]' \
        '-nowarn[no warnings]' \
        '-optimise[run optimizations]' \
        '-optimize[run optimizations]' \
        '-print[print program with stdlib types]' \
        '-release+[target release]:n:(8 11 17 21)' \
        '-target+[target class file version]:t:(jvm-1.8 jvm-11 jvm-17 jvm-21)' \
        '-sourcepath+[source path]:list:_files' \
        '-toolcp+[tool class path]:list:_files' \
        '-unchecked[enable unchecked warnings]' \
        '-uniqid[print unique ids]' \
        '-usejavacp[use java classpath]' \
        '-usemanifestcp[use manifest classpath]' \
        '-verbose[verbose]' \
        '-Wconf+[warning config]:str:' \
        '-Werror[warnings as errors]' \
        '-Wdead-code[warn dead code]' \
        '-Wnumeric-widen[warn numeric widening]' \
        '-Wunused:+[warn unused]:list:' \
        '-Wvalue-discard[warn value discard]' \
        '*:file-or-script:_files -g "*.scala *.sc *.jar"'
}

_scala "$@"
