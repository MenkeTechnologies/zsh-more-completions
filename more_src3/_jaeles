#compdef jaeles
# Documentation: https://github.com/jaeles-project/jaeles/blob/master/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cobra flag definitions).

# jaeles: web application fuzzing/testing framework. Rewritten from
# upstream cobra source: removed fabricated -V/--version, -D/--debug,
# --no-output(global)/--passive(global)/--show-time, scan --ba/--ssrf/
# --blc/--mics/--http-port, server -b/-A/-S/--no-cors, config
# init/reload/update/clean/cred subarg list, report --output/--title.
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'scan:scan list of URLs based on selected signatures'
  'server:start the Jaeles REST API server'
  'config:manage Jaeles configuration and signatures'
  'report:generate HTML report from a scan output folder'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file]:file:_files' \
  '--rootDir=[root project directory]:dir:_files -/' \
  '(-B --signDir)'{-B+,--signDir=}'[default signatures folder]:dir:_files -/' \
  '--scanID=[scan ID]:id:' \
  '--proxy=[HTTP proxy]:proxy:' \
  '--timeout=[HTTP timeout]:seconds:' \
  '--retry=[HTTP retry count]:n:' \
  '--delay=[delay between requests]:seconds:' \
  '(-o --output)'{-o+,--output=}'[output folder name]:dir:_files -/' \
  '--json[store output as JSON]' \
  '--passiveOutput=[passive output folder]:dir:_files -/' \
  '--passiveSummary=[passive summary file]:file:_files' \
  '(-O --summaryOutput)'{-O+,--summaryOutput=}'[summary output file]:file:_files' \
  '--summaryVuln=[vulnerable summary output file]:file:_files' \
  '--sverbose[store verbose info in summary file]' \
  '(-R --report)'{-R+,--report=}'[report name]:name:' \
  '--title=[report title name]:title:' \
  '(-G --passive)'{-G,--passive}'[turn on passive detections]' \
  '(-L --level)'{-L+,--level=}'[filter signature by level]:level:(0 1 2 3 4 5)' \
  '--sp=[selector for passive detections]:selector:' \
  '(-c --concurrency)'{-c+,--concurrency=}'[concurrency level]:n:' \
  '(-t --threads)'{-t+,--threads=}'[concurrency inside a single signature]:n:' \
  '(-S --selectorFile)'{-S+,--selectorFile=}'[signature selector from file]:file:_files' \
  '*'{-s+,--signs=}'[signature selector (repeatable)]:selector:' \
  '*'{-x+,--exclude=}'[exclude signature selector (repeatable)]:selector:' \
  '--local[treat input as local path]' \
  '*'{-p+,--params=}'[custom params foo=bar (repeatable)]:param:' \
  '*'{-H+,--headers=}'[custom header (repeatable)]:header:' \
  '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
  '(-f --found)'{-f+,--found=}'[command to run when vulnerable found]:command:' \
  '(-J --format-input)'{-J,--format-input}'[enable special input format]' \
  '--save-raw[save raw request]' \
  '(-N --no-output)'{-N,--no-output}'[do not store output]' \
  '--no-background[do not run background task]' \
  '--refresh=[refresh time for background task]:n:' \
  '--no-db[disable database]' \
  '--single[disable parallel mode]' \
  '(-Q --quietFormat)'{-Q+,--quietFormat=}'[format for quiet output]:format:' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jaeles command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (scan)
        _arguments \
          '(-u --url)'{-u+,--url=}'[target URL]:url:' \
          '(-U --urls)'{-U+,--urls=}'[file containing target URLs]:file:_files' \
          '(-r --raw)'{-r+,--raw=}'[raw request file from Burp]:file:_files' \
          '--html[generate HTML report after scan]' && ret=0 ;;
      (server)
        _arguments \
          '--host=[IP address to bind]:host:' \
          '--port=[port]:port:' \
          '(-A --no-auth)'{-A,--no-auth}'[turn off API server authentication]' && ret=0 ;;
      (config)
        _arguments \
          '--clean[clean old record]' \
          '(-a --action)'{-a+,--action=}'[action]:action:' \
          '--poll[poll all records in OOB config]' \
          '--secret=[secret of Burp Collab]:secret:' \
          '--collab=[Burp Collab file]:file:_files' \
          '--mics[skip importing mics signatures]' \
          '(-y --yes)'{-y,--yes}'[force delete old folder]' \
          '--user=[username]:user:' \
          '--pass=[password]:pass:' \
          '--repo=[signature repo]:repo:' \
          '(-K --key)'{-K+,--key=}'[private key to pull repo]:file:_files' && ret=0 ;;
      (report)
        _arguments \
          '--template=[report template file]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
