#compdef shellcheck-cli shellcheck2
# _shellcheck-cli — Vidar Holen ShellCheck shellcheck-cli CLI command-line frontend wrapping the ShellCheck static analysis tool for shell scripts open-source written in Haskell originally Vidar Holen now community-maintained finds bugs in shell scripts gives helpful suggestions hardens scripts checks SC2086 SC2155 SC2059 sh dash bash ksh shell-types-bash-dash-ksh-bsh-sh-shell-script-issue-detection POSIX-issue Bashisms shellcheck-disable disable-codes severity Werror -s -f -e -i -x -X -W -P -V -C --shell --severity --enable --color --check-sourced --include --exclude --external-sources --source-path --norc --rcfile --wiki-link-count --format --list-optional --extended-analysis (Vidar Holen ShellCheck community team, Haskell); custom argparse
# upstream: https://www.shellcheck.net/

_shellcheck-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[shell]:s:(sh bash dash ksh busybox)' \
        '--shell=+[s]:s:(sh bash dash ksh busybox)' \
        '-S+[severity]:s:(error warning info style)' \
        '--severity=+[s]:s:(error warning info style)' \
        '-f+[format]:f:(checkstyle diff gcc json json1 quiet tty)' \
        '--format=+[f]:f:(checkstyle diff gcc json json1 quiet tty)' \
        '-W+[wiki-link-count]:n:' \
        '--wiki-link-count=+[N]:n:' \
        '-C+[color]:c:(auto always never)' \
        '--color=+[c]:c:(auto always never)' \
        '-e+[exclude codes]:str:' \
        '*-e+[exclude codes]:str:' \
        '--exclude=+[codes]:str:' \
        '*--exclude=+[codes]:str:' \
        '-i+[include codes]:str:' \
        '*-i+[include codes]:str:' \
        '--include=+[codes]:str:' \
        '*--include=+[codes]:str:' \
        '-o+[optional checks]:str:' \
        '*-o+[optional checks]:str:' \
        '--enable=+[optional checks]:str:' \
        '*--enable=+[optional checks]:str:' \
        '-x[external sources]' \
        '--external-sources[external sources]' \
        '-X+[source path]:dir:_files -/' \
        '*-X+[source path]:dir:_files -/' \
        '--source-path=+[dir]:dir:_files -/' \
        '*--source-path=+[dir]:dir:_files -/' \
        '-P+[search path]:dir:_files -/' \
        '*-P+[search path]:dir:_files -/' \
        '-a[check sourced]' \
        '--check-sourced[check sourced]' \
        '--norc[no rc file]' \
        '--rcfile=+[file]:file:_files -g ".shellcheckrc"' \
        '--list-optional[list optional]' \
        '--extended-analysis=+[v]:v:(true false)' \
        '*:script:_files -g "*.sh *.bash *.ksh *.zsh *.dash"'
}

_shellcheck-cli "$@"
