#compdef inspect
# Documentation: https://inspect.aisi.org.uk/options.html
# Reference accessed: 2026-05-21
# Verified: upstream CLI options reference at the URL above.

# Zsh completion for inspect (inspect_ai) - LLM evaluation framework by UK AISI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'inspect command' \
      'eval[run an evaluation]' \
      'eval-retry[retry a failed evaluation]' \
      'eval-set[run a set of evaluations]' \
      'score[score evaluation logs]' \
      'view[start log viewer]' \
      'log[manipulate eval logs]' \
      'cache[manage prompt cache]' \
      'sandbox[manage sandbox environments]' \
      'info[show system info]' \
      'list[list tasks/models/etc]' \
      'trace[manage trace logs]' && ret=0
    ;;
  args)
    case $line[1] in
      eval|eval-set|eval-retry)
        _arguments \
          '--model[model to evaluate]:model:' \
          '--model-base-url[base URL for model API]:url:' \
          '--model-config[model config file]:file:_files' \
          '-M+[model argument]:key=value:' \
          '--model-role[model role]:role:' \
          '--generate-config[generation config file]:file:_files' \
          '--max-tokens[max tokens to generate]:n:' \
          '--system-message[system message]:msg:' \
          '--temperature[sampling temperature]:t:' \
          '--top-p[top-p sampling]:p:' \
          '--top-k[top-k sampling]:k:' \
          '--frequency-penalty[frequency penalty]:pen:' \
          '--presence-penalty[presence penalty]:pen:' \
          '--logit-bias[logit bias]:bias:' \
          '--seed[random seed]:n:' \
          '--stop-seqs[stop sequences]:seqs:' \
          '--num-choices[number of choices]:n:' \
          '--best-of[best-of n]:n:' \
          '--log-probs[include logprobs]' \
          '--top-logprobs[number of top logprobs]:n:' \
          '--cache-prompt[cache prompt]' \
          '--effort[reasoning effort]:effort:(low medium high)' \
          '--verbosity[verbosity level]:level:' \
          '--reasoning-effort[reasoning effort]:effort:' \
          '--reasoning-tokens[reasoning tokens]:n:' \
          '--reasoning-history[reasoning history mode]:mode:' \
          '--response-format[response format]:fmt:' \
          '--parallel-tool-calls[allow parallel tool calls]' \
          '--max-tool-output[max tool output]:n:' \
          '--internal-tools[enable internal tools]' \
          '--max-retries[max retries]:n:' \
          '--timeout[request timeout]:secs:' \
          '--attempt-timeout[per-attempt timeout]:secs:' \
          '--task-config[task config file]:file:_files' \
          '-T+[task argument]:key=value:' \
          '--solver[solver name]:solver:' \
          '--solver-config[solver config file]:file:_files' \
          '-S+[solver argument]:key=value:' \
          '--limit[sample limit]:limit:' \
          '--sample-id[specific sample IDs]:ids:' \
          '--epochs[number of epochs]:n:' \
          '--epochs-reducer[epochs reducer]:reducer:' \
          '--no-epochs-reducer[disable epochs reducer]' \
          '--max-connections[max concurrent connections]:n:' \
          '--max-samples[max concurrent samples]:n:' \
          '--max-dataset-memory[max dataset memory]:size:' \
          '--max-subprocesses[max subprocesses]:n:' \
          '--max-sandboxes[max sandboxes]:n:' \
          '--max-tasks[max concurrent tasks]:n:' \
          '--fail-on-error[fail on any error]' \
          '--no-fail-on-error[do not fail on error]' \
          '--retry-on-error[retry on error]:n:' \
          '--score-on-error[score on error]' \
          '--message-limit[message limit]:n:' \
          '--token-limit[token limit]:n:' \
          '--time-limit[time limit seconds]:secs:' \
          '--working-limit[working time limit]:secs:' \
          '--cost-limit[cost limit]:usd:' \
          '--model-cost-config[model cost config]:file:_files' \
          '--log-dir[log directory]:dir:_directories' \
          '--no-log-samples[do not log samples]' \
          '--no-log-images[do not log images]' \
          '--no-log-realtime[disable realtime logging]' \
          '--log-buffer[log buffer size]:n:' \
          '--log-shared[share logs]' \
          '--log-format[log format]:fmt:(json eval)' \
          '--log-level[log level]:level:(debug info warning error critical)' \
          '--log-level-transcript[transcript log level]:level:' \
          '--no-score[skip scoring]' \
          '--no-score-display[hide score display]' \
          '--sandbox[sandbox environment]:env:(local docker)' \
          '--no-sandbox-cleanup[skip sandbox cleanup]' \
          '--debug[enable debug mode]' \
          '--debug-port[debug port]:port:' \
          '--debug-errors[debug errors]' \
          '--traceback-locals[include locals in tracebacks]' \
          '--display[display style]:style:(full conversation rich plain log none)' \
          '--no-ansi[disable ANSI]' \
          '--approval[approval policy]:file:_files' \
          '--env[environment variable]:var:' \
          '--tags[tags]:tags:' \
          '--metadata[metadata]:meta:' \
          '--run-config[run config file]:file:_files' && ret=0
        ;;
      view)
        _arguments \
          '--log-dir[log directory]:dir:_directories' \
          '--host[host to bind]:host:' \
          '--port[port to bind]:port:' \
          '--no-browser[do not open browser]' && ret=0
        ;;
    esac
    ;;
esac

return ret
