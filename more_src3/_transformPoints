#compdef transformPoints
# Documentation: https://www.openfoam.com/documentation/user-guide/4-mesh-generation-and-conversion/4.5-mesh-manipulation
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/transformPoints/transformPoints.C — translate/rotate/scale mesh points.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-rotateFields[also transform vector and tensor fields]' \
    '-pointSet+[point set to limit transformation to]:set:_default' \
    && ret=0

return ret
