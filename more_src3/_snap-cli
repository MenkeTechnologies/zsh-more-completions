#compdef snap-cli
# _snap-cli — Canonical Snap universal Linux packages CLI alias (Canonical, Go); custom argparse
# upstream: https://github.com/snapcore/snapd

_snap-cli() {
    local -a sub=(
        'abort:abort change'
        'ack:add assertion'
        'alias:set/list aliases'
        'aliases:list aliases'
        'auto-import:import assertions/snaps from external'
        'change:show changes'
        'changes:list changes'
        'connect:connect plug to slot'
        'connections:list connections'
        'create-user:create local user'
        'disable:disable snap'
        'disconnect:disconnect plug/slot'
        'download:download snap'
        'enable:enable snap'
        'find:find snaps'
        'forget:remove snapshot'
        'get:get snap config'
        'help:show help'
        'hold:hold updates'
        'info:show snap info'
        'install:install snap'
        'interface:list interfaces'
        'interfaces:list interfaces'
        'known:show known assertions'
        'list:list installed snaps'
        'login:login to snap store'
        'logout:logout'
        'logs:show service logs'
        'pack:pack snap'
        'prefer:prefer snap (auto-alias)'
        'prepare-image:prepare device image'
        'refresh:refresh snaps'
        'remove:remove snap'
        'restart:restart service'
        'restore:restore snapshot'
        'reboot:reboot device'
        'revert:revert snap'
        'run:run snap command'
        'saved:list saved snapshots'
        'savestate:save snap state'
        'services:list services'
        'set:set snap config'
        'sign-build:sign build'
        'sign:sign assertion'
        'sign-build:sign build'
        'start:start service'
        'stop:stop service'
        'switch:switch to channel'
        'tasks:list tasks'
        'try:try snap'
        'unalias:remove alias'
        'unhold:remove hold'
        'unset:unset config'
        'wait:wait for state'
        'warnings:show warnings'
        'whoami:show current user'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snap subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|refresh|info|find|enable|disable|switch|revert|run|hold|unhold|try|forget|restore|saved) _arguments \
                    '--channel=+[channel]:str:' \
                    '--classic[classic confinement]' \
                    '--devmode[dev mode]' \
                    '--dangerous[dangerous]' \
                    '--jailmode[jail mode]' \
                    '--revision=+[revision]:n:' \
                    '--cohort=+[cohort key]:str:' \
                    '--purge[purge data]' \
                    '*:snap:' ;;
                services|start|stop|restart|logs) _arguments '*:service:' ;;
                connect|disconnect) _arguments '*:plug-slot:' ;;
                interfaces|interface|connections) _arguments '*:interface-or-snap:' ;;
                login) _arguments '*:email:' ;;
            esac
            ;;
    esac
}

_snap-cli "$@"
