#compdef in-toto-verify in-toto-sign in-toto-mock in-toto-match-products
# Documentation: https://github.com/in-toto/in-toto (pyproject.toml console_scripts)
# Sources:
#   in_toto/in_toto_verify.py          (argparse)
#   in_toto/in_toto_sign.py            (argparse)
#   in_toto/in_toto_mock.py            (argparse)
#   in_toto/in_toto_match_products.py  (argparse)
#   in_toto/common_args.py             (shared VERBOSE/QUIET/GPG_HOME/etc.)
# Reference accessed: 2026-05-30
# Multi-stem covers 4 sibling binaries from the in-toto python package. The
# existing repo files _in-toto-run and _in-toto-record cover the other 2.
# Dispatched on $service. Shared verbose/quiet/version flags consolidated.

local curcontext="$curcontext" state line ret=1

# Shared flags reused across all 4 stems.
local -a _shared
_shared=(
  '(- *)--version[show version and exit]'
  '(-q --quiet -v --verbose)'{-v,--verbose}'[show more output]'
  '(-q --quiet -v --verbose)'{-q,--quiet}'[suppress all output]'
  '(- *)'{-h,--help}'[show help]'
)

case $service in
  in-toto-verify)
    _arguments -s -S \
      $_shared \
      '(-l --layout)'{-l,--layout=}'[root layout file specifying the supply chain]:layout file:_files' \
      '*--verification-keys=[layout-signature verification keys (rsa/ed25519/ecdsa)]:key file:_files' \
      '*'{-g,--gpg=}'[GPG keyid in keyring used to verify layout signature]:keyid:' \
      '--gpg-home=[GPG home directory]:dir:_files -/' \
      '--link-dir=[directory with step link metadata (default .)]:dir:_files -/' \
      '--inspection-timeout=[max seconds for inspect subprocess]:seconds:' \
      && ret=0
    ;;

  in-toto-sign)
    _arguments -s -S \
      $_shared \
      '(-f --file)'{-f,--file=}'[link or layout file to sign or verify]:file:_files' \
      '*'{-k,--key=}'[key files used to sign or verify]:key file:_files' \
      '(-p --prompt)'{-p,--prompt}'[prompt for signing key decryption password]' \
      '*'{-g,--gpg=}'[GPG keyids used to sign or verify]:keyid:' \
      '--gpg-home=[GPG home directory]:dir:_files -/' \
      '(-o --output)'{-o,--output=}'[output path for signed metadata]:file:_files' \
      '(-a --append)'{-a,--append}'[add signatures rather than replacing]' \
      '--verify[verify signatures (using --key/--gpg) instead of signing]' \
      && ret=0
    ;;

  in-toto-mock)
    _arguments -s -S \
      $_shared \
      '(-n --name)'{-n,--name=}'[name for resulting `<name>.link` metadata file]:name:' \
      '--use-dsse[generate metadata using DSSE (experimental)]' \
      '*::command and args:_command_names -e' \
      && ret=0
    ;;

  in-toto-match-products)
    _arguments -s -S \
      $_shared \
      '(-l --link)'{-l,--link=}'[link metadata file to match products against]:file:_files' \
      '*'{-p,--paths=}'[paths to local artifacts (default cwd)]:path:_files' \
      '*'{-e,--exclude=}'[gitignore-style pattern to skip artifacts]:pattern:' \
      '*--lstrip-paths=[prefixes to left-strip from artifact paths]:prefix:' \
      && ret=0
    ;;
esac

return ret
