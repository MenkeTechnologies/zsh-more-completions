#compdef sloth
# Documentation: https://github.com/slok/sloth
# Reference accessed: 2026-05-21
# Verified: cmd/sloth/commands/{commands,generate,validate}.go in upstream repo.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'generate:generate Prometheus SLO rules from a SLO spec'
  'validate:validate SLO specs'
  'kubecontroller:run as a Kubernetes controller'
  'server:run sloth as an HTTP server'
  'version:print version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug mode]' \
  '--no-log[disable logger]' \
  '--no-color[disable logger color]' \
  '--logger=[logger type]:type:(default json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'sloth command' commands && ret=0 ;;
  (args)
    case ${line[1]} in
      (generate)
        _arguments \
          '(-i --input)'{-i+,--input=}'[SLO spec input file or directory]:file:_files' \
          '(-o --out)'{-o+,--out=}'[output file or directory (- for stdout)]:file:_files' \
          '(-e --fs-exclude)'{-e+,--fs-exclude=}'[regex to ignore discovered SLO paths]:regex' \
          '(-n --fs-include)'{-n+,--fs-include=}'[regex to include discovered SLO paths]:regex' \
          '*'{-l+,--extra-labels=}'[extra labels (key=value)]:label' \
          '--disable-recordings[disable recording rules generation]' \
          '--disable-alerts[disable alert rules generation]' \
          '*'{-p+,--plugins-path=}'[path to sloth plugins]:path:_files -/' \
          '--slo-period-windows-path=[custom SLO period windows catalog]:dir:_files -/' \
          '--default-slo-period=[default SLO period (default 30d)]:period' \
          '*'{-s+,--slo-plugins=}'[SLO plugin chain declaration (JSON)]:json' \
          '--disable-default-slo-plugins[disable default SLO plugins]' \
          '--k8s-transform-plugin-id=[plugin ID for k8s transform]:id' && ret=0 ;;
      (validate)
        _arguments \
          '(-i --input)'{-i+,--input=}'[SLO spec discovery path]:file:_files' \
          '(-e --fs-exclude)'{-e+,--fs-exclude=}'[regex to ignore discovered SLO paths]:regex' \
          '(-n --fs-include)'{-n+,--fs-include=}'[regex to include discovered SLO paths]:regex' \
          '*'{-l+,--extra-labels=}'[extra labels (key=value)]:label' \
          '*'{-p+,--plugins-path=}'[path to SLI/SLO plugins]:path:_files -/' \
          '--slo-period-windows-path=[custom SLO period windows catalog]:dir:_files -/' \
          '--default-slo-period=[default SLO period (default 30d)]:period' \
          '*'{-s+,--slo-plugins=}'[SLO plugin chain declaration (JSON)]:json' \
          '--disable-default-slo-plugins[disable default SLO plugins]' \
          '--ignore-slo-duplicates[ignore SLO duplicates in specs]' && ret=0 ;;
    esac ;;
esac

return ret
