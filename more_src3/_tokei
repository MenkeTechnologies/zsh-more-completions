#compdef tokei
# Documentation: tokei --help
# Source: count lines of code by language, quickly.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-c+,--columns=}'[strict column width for terminal output]:cols:' \
    '*'{-e+,--exclude=}'[ignore matching files/dirs]:pattern:' \
    {-f,--files}'[print per-file statistics]' \
    {-i+,--input=}'[stats from previous tokei run]:file:_files' \
    '--hidden[count hidden files]' \
    {-l,--languages}'[list supported languages and extensions]' \
    '--no-ignore[do not respect any ignore files]' \
    '--no-ignore-parent[do not respect parent ignore files]' \
    '--no-ignore-dot[do not respect .ignore/.tokeignore]' \
    '--no-ignore-vcs[do not respect VCS ignore files]' \
    {-o+,--output=}'[output format]:fmt:(json yaml cbor toml)' \
    '--streaming=[streaming record format]:fmt:(simple json)' \
    {-s+,--sort=}'[sort by column]:col:(files lines blanks code comments)' \
    {-r+,--rsort=}'[reverse sort by column]:col:(files lines blanks code comments)' \
    {-t+,--types=}'[filter by language types (CSV)]:types:' \
    {-C,--compact}'[no statistics for embedded languages]' \
    {-n+,--num-format=}'[number format]:fmt:(commas dots plain underscores)' \
    '*'{-v,--verbose}'[increase log level (stackable 1-3)]' \
    '*:input path:_files' \
    && ret=0

return ret
