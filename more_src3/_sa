#compdef sa
# Documentation: man sa(8) (BSD)
# Source: sa(8) — print system accounting statistics.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[list all command names (no ***other** bucket)]' \
    '-b[sort cmd stats by (user+sys)/calls]' \
    '-c[also print per-command percentages of total]' \
    '-d[sort/print by average disk I/O ops]' \
    '-D[sort/print by total disk I/O ops]' \
    '-f[force no interactive threshold compare (with -v)]' \
    '-i[do not read summary files]' \
    '-j[print seconds-per-call instead of total minutes]' \
    '-k[sort by cpu-time-average memory usage]' \
    '-K[sort/print by cpu-storage integral]' \
    '-l[separate system and user time]' \
    '-m[per-user statistics rather than per-command]' \
    '-n[sort by number of calls]' \
    '-P+[per-command summary database file]:savacct:_files' \
    '-U+[per-user summary database file]:usracct:_files' \
    '-q[suppress output except error messages]' \
    '-r[reverse order of sort]' \
    '-s[truncate accounting files and merge into summary]' \
    '-t[report real/(user+sys) cpu ratio per command]' \
    '-u[print uid/cpu/mem/IO/cmd per accounting entry]' \
    '-v+[interactive ***junk** stripper at N calls]:cutoff:' \
    '*:accounting file:_files' \
    && ret=0

return ret
