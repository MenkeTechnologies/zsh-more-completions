#compdef imcat
# _imcat — list catalog stars within a FITS image's WCS region (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from imcat.c (single-letter getopt-style).

_imcat() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[initial rotation angle (deg)]:deg:' \
        '-b+[B1950 reference coords]:coords:' \
        '-c+[reference catalog]:cat:(ub1 ub2 ucac4 ucac3 ucac2 gsc2 gsc tycho2 tycho 2mass usno-a2 usno-b1 sao ppm act bsc hip)' \
        '-h[output descriptive header]' \
        '-i[label region with name, not number]' \
        '-j+[J2000 reference coords]:coords:' \
        '-k+[reference catalog magnitude column]:n:' \
        '-l+[image size in X and Y pixels]:size:' \
        '-m+[limiting reference magnitude]:mag:' \
        '-n+[brightest stars to read]:n:' \
        '-o+[Guide Star object class]:cls:' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-q+[SAOimage region shape]:shape:(c d p s x v + o circle diamond square cross plus)' \
        '-r+[region file with shape radius]:radius:' \
        '-s+[sort by]:sort:(ra dec mag none)' \
        '-t[tab-table to stdout]' \
        '-u+[UJ catalog plate number]:n:' \
        '-v[verbose output]' \
        '-w[write output file]' \
        '-x+[reference pixel X Y]:xy:' \
        '-y+[image epoch (FITS date)]:date:' \
        '-z[use AIPS classic WCS]' \
        '*:FITS image:_files -g "*.(fits|fit|fts|imh)"'
}

_imcat "$@"
