#compdef hpcstruct
# _hpcstruct — Rice University HPCToolkit hpcstruct extracts call graph and loop nest information from a binary for attribution (rice-hpctoolkit team, C++); getopt
# upstream: https://github.com/HPCToolkit/hpctoolkit

_hpcstruct() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.hpcstruct *.struct"' \
        '--output=+[output file]:file:_files -g "*.hpcstruct *.struct"' \
        '-j+[N threads]:n:' \
        '--jobs=+[N threads]:n:' \
        '-I+[include path]:dir:_files -/' \
        '--include=+[include path]:dir:_files -/' \
        '-R+[symbol]:str:' \
        '--replace-path=+[old=new]:str:' \
        '-c+[CPU model]:str:' \
        '--cpu=+[CPU model]:str:' \
        '--meas-dir=+[measurement dir]:dir:_files -/' \
        '--gpucfg=+[bool]:b:(yes no)' \
        '--show-warnings[show warnings]' \
        '--show-gaps[show gaps]' \
        '--use-binutils[use binutils]' \
        '--no-cache[no cache]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--gap-tracking[gap tracking]' \
        '--allowinline-mismatch[allow inline mismatch]' \
        '--demangle-style=+[style]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '*:binary or measurement dir:_files'
}

_hpcstruct "$@"
