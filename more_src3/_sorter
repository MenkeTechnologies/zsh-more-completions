#compdef sorter
# Documentation: https://www.sleuthkit.org/sleuthkit/man/sorter.html
# Source: sleuthkit/sleuthkit man/sorter.1 — sort files based on their file type with optional NSRL/known-bad hash lookups.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[minimum size of file to process]:size:' \
    '-e[perform extension mismatch checks (no category index files generated)]' \
    '-E[expert mode for extension mismatch checks]' \
    '-h[create category files in HTML]' \
    '-l[list information to STDOUT (no files written)]' \
    '-md5[calculate MD5 value for each file and save in category file]' \
    '-s[save actual file content to sub-directories in -d directory]' \
    '-sha1[calculate SHA-1 value for each file and save in category file]' \
    '-U[do not save data about unknown file types]' \
    '-v[display verbose information]' \
    '-V[display version]' \
    '-a[location of hash database with known "bad" files]:hash alert:_files' \
    '-c[location of additional configuration file]:config:_files' \
    '-C[location of the ONLY configuration file]:config:_files' \
    '-d[location where all files should be written]:dir:_directories' \
    '-m[mounting point of image being analyzed]:mnt:_directories' \
    '-n[location of NIST NSRL database]:nsrl_db:_files' \
    '-x[location of hash database with known "good" files]:hash exclude:_files' \
    '-i[image type where file system is located]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset from beginning of image to start of file system]:offset:' \
    '-f[file system type of image]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '*:image file:_files' \
    && ret=0

return ret
