#compdef sop
# ============================================================================
# _sop — zsh completion for halcyonnouveau's Soppo, a Go superset
#         compiler with enums + pattern matching + nil safety
#         (161st language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/halcyonnouveau/soppo
#   Author     : halcyonnouveau
#   License    : BSD-3-Clause
#   Stars      : 87
#   Language   : Rust (compiler) / Soppo (.sop source — Go superset)
#   Crate      : soppo v0.11.0
#   Binary     : sop  (Cargo.toml [[bin]] name = "sop",
#                       path = "src/main.rs")
#   Last push  : 2026-05-27
#
# WHAT IT IS
#   Soppo is "Go, with the features it's missing" — halcyonnouveau's
#   superset of Go that adds enums (tagged unions), pattern matching
#   on those enums (with exhaustiveness checking), and compile-time
#   nil-safety analysis on top of every existing Go feature.  The
#   `sop` driver transpiles `.sop` source files into idiomatic Go
#   code under a `gen/` (or configurable) output directory, then
#   shells out to the system `go` toolchain for the actual build /
#   run / test / module-maintenance steps — so Soppo projects
#   ship as ordinary Go binaries with full Go-ecosystem interop.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive
#                       Cli + Command enum)
#   sop <SUBCOMMAND> [args...]
#
#   Subcommands:
#     build [<FILES>...]            Build project or specific files
#                                   (.sop glob patterns).  When
#                                   FILES is empty, uses `sop.mod`
#                                   config.
#       -o, --output <DIR>            Output directory (preserves
#                                     source-tree structure)
#
#     run [-- <ARGS>...]            Build and run the project.
#                                   Anything after `--` is forwarded
#                                   to the running program.
#
#     get <PACKAGES>...             Add Go dependencies (delegates
#                                   to `go get` inside the output
#                                   directory)
#
#     mod <ARGS>...                 Module maintenance (delegates
#                                   to `go mod <ARGS>` inside the
#                                   output directory)
#
#     check [<FILES>...]            Type-check without generating
#                                   code
#
#     test [<PACKAGES>...] [-- <ARGS>...]
#                                   Run tests (transpiles to Go,
#                                   then `go test`).  Trailing args
#                                   after `--` are forwarded to
#                                   `go test`.
#       -r, --run <PATTERN>           Run only tests matching pattern
#                                     (passed to `go test -run`)
#       -v, --verbose                 Verbose output
#       --keep-tmp                    Keep the temporary directory
#                                     for inspection
#
#     fmt [<FILES>...]              Format source files
#       -w, --write                   Write result back to file
#       -l, --list                    List files whose formatting
#                                     differs
#       -d, --diff                    Display diffs instead of
#                                     rewriting
#
#     sniff [<FILES>...]            Lint source files (catch common
#                                   mistakes and improve Soppo code)
#       --ignore <RULE>...            Disable specific lint rules
#                                     (repeatable)
#
#   Standard clap auto-flags:
#     -h, --help                    Show help
#     -V, --version                 Show version
#
# LANGUAGE-CORPUS POSITION
#   Soppo is the 161st programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R913 (_rpg
#   / tokio-postgres 0.7 Rust=136 OPENS Axis 81 PostgreSQL Driver
#   Library) and continued through R914 (_dbaker / jackc/pgx v5.7.2
#   Go=136) and R915 (_pg-god / node-postgres pg ^8.3.0 TS-Node=136
#   CLOSES Axis 81 at 1/1/1 three-language symmetry — triple-136
#   landmark and 74th axis closed).  Soppo joins Cyrus (R912 160th
#   — round-number language milestone), Lumina (R908 159th), Penne
#   (R904 158th), EndBASIC (R900 157th — R900 TRIPLE-9 commit
#   landmark), goboscript (R896 156th), Alan (R892 155th), Mech
#   (R888 154th — triple-8 landmark), Lisette (R884 153rd), Bril
#   (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th), Imba
#   (R828 139th), Tao (R824 138th), Dada (R820 137th), Acton (R816
#   136th), and Stanza (R812 135th).
#
#   No completion for `sop` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
#   The adjacent `sops` in this corpus is Mozilla's secrets-
#   management tool;  this `sop` is the Soppo compiler driver.
# ============================================================================

_sop() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_sop_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
                        '*:Soppo source file:_files -g "*.sop"' && ret=0 ;;
                run)
                    _arguments '*: :_normal' && ret=0 ;;
                get)
                    _arguments '*:Go package:' && ret=0 ;;
                mod)
                    _arguments '*:go mod subcommand:(download edit graph init tidy vendor verify why)' && ret=0 ;;
                check)
                    _arguments '*:Soppo source file:_files -g "*.sop"' && ret=0 ;;
                test)
                    _arguments \
                        '(-r --run)'{-r+,--run=}'[pattern passed to go test -run]:pattern:' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        '--keep-tmp[keep the temporary directory]' \
                        '*:package or file:_files -g "*.sop"' && ret=0 ;;
                fmt)
                    _arguments \
                        '(-w --write)'{-w,--write}'[write result back to file]' \
                        '(-l --list)'{-l,--list}'[list files whose formatting differs]' \
                        '(-d --diff)'{-d,--diff}'[display diffs instead of rewriting]' \
                        '*:Soppo source file:_files -g "*.sop"' && ret=0 ;;
                sniff)
                    _arguments \
                        '*--ignore=[disable specific lint rule (repeatable)]:rule:' \
                        '*:Soppo source file:_files -g "*.sop"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sop_commands] )) ||
_sop_commands() {
    local -a commands
    commands=(
        'build:build project or specific files'
        'run:build and run the project'
        'get:add Go dependencies (delegates to go get)'
        'mod:module maintenance (delegates to go mod)'
        'check:type-check without generating code'
        'test:run tests'
        'fmt:format source files'
        'sniff:lint source files'
    )
    _describe -t commands 'sop command' commands
}

_sop "$@"
