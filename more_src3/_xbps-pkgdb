#compdef xbps-pkgdb
# Documentation: https://man.voidlinux.org/xbps-pkgdb.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-a --all)'{-a,--all}'[process all registered packages]' \
  '--checks=[comma-separated list of checks]:checks:(files dependencies alternatives pkgdb)' \
  '(-C --config)'{-C,--config}'+[XBPS configuration directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-m --mode)'{-m,--mode}'+[set/unset package mode]:mode:(auto manual hold unhold repolock repounlock)' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-u --update)'{-u,--update}'[update pkgdb format]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:pkg: '
