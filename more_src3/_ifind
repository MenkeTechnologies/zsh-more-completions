#compdef ifind
# Documentation: https://www.sleuthkit.org/sleuthkit/man/ifind.html
# Source: sleuthkit/sleuthkit man/ifind.1 — find meta-data structure that has allocated a data unit or filename.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[find all meta-data structures (only with -d data_unit)]' \
    '-v[verbose output to stderr]' \
    '-V[display version]' \
    '-l[list details of each file found with -p (like fls -l)]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '(-n -p)-d[find meta data structure that allocated a given data unit]:data unit:' \
    '(-d -p)-n[find meta data structure pointed to by given file name]:file:' \
    '(-d -n)-p[find unallocated NTFS MFT entries with given parent inode]:par inode:' \
    '-z[timezone (with -p -l)]:zone:' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '*:image file:_files' \
    && ret=0

return ret
