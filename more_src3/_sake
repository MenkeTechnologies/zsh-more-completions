#compdef sake
# Documentation: https://github.com/alajmo/sake (cmd/root.go cobra)
# Reference accessed: 2026-05-29
# sake — task runner for local and remote hosts (Ansible-style, YAML-defined).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'init:initialize a sake.yaml in the current directory'
  'list:list servers/tasks/tags/specs/targets/themes'
  'describe:show details of a server, task, target, theme, etc.'
  'run:run task(s) on selected servers'
  'exec:execute an ad-hoc command on selected servers'
  'ssh:open an interactive SSH session on a server'
  'edit:edit sake.yaml (servers/tasks/targets/themes/specs)'
  'check:validate sake.yaml syntax and references'
  'completion:generate shell completion scripts'
  'gen:generate config templates'
  'gen-docs:generate sake documentation'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-c --config)'{-c,--config=}'[config file path]:file:_files -g "sake*.(yaml|yml)"'
  '(-u --user-config)'{-u,--user-config=}'[user config file path]:file:_files -g "*.(yaml|yml)"'
  '--ssh-config=[SSH config file path]:file:_files'
  '--no-color[disable color output]'
  '(-h --help)'{-h,--help}'[show help]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'sake subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _list _describe_sub _edit
    _list=(
      'servers:list configured servers'
      'tasks:list tasks'
      'tags:list tags'
      'targets:list targets'
      'specs:list specs'
      'themes:list themes'
    )
    _describe_sub=(
      'server:describe a server'
      'task:describe a task'
      'target:describe a target'
      'theme:describe a theme'
      'spec:describe a spec'
    )
    _edit=(
      'server:edit a server entry'
      'task:edit a task entry'
      'target:edit a target entry'
      'theme:edit a theme entry'
      'spec:edit a spec entry'
    )
    case $line[1] in
      list)
        _arguments \
          $_global \
          '1: :->sub' \
          '--output=[output format]:format:(table markdown html json csv)' \
          '--theme=[theme]:theme:' \
          '*--tags=[filter by tag (repeatable)]:tag:' \
          '*--servers=[filter by server (repeatable)]:server:' && ret=0
        [[ $state == sub ]] && _describe -t commands 'list' _list && ret=0
        ;;
      describe)
        _arguments \
          $_global \
          '1: :->sub' && ret=0
        [[ $state == sub ]] && _describe -t commands 'describe' _describe_sub && ret=0
        ;;
      edit)
        _arguments \
          $_global \
          '1: :->sub' && ret=0
        [[ $state == sub ]] && _describe -t commands 'edit' _edit && ret=0
        ;;
      run|exec)
        _arguments \
          $_global \
          '*--servers=[server(s) to target]:server:' \
          '*--tags=[tag(s) to target]:tag:' \
          '*--target=[saved target]:target:' \
          '*--limit=[limit number of servers]:n:' \
          '--parallel[run in parallel across servers]' \
          '--order=[execution order]:order:(inventory sorted random)' \
          '--strategy=[parallel strategy]:strategy:(linear free host-pinned column-pinned column-pinned-grid)' \
          '--silent[suppress task output]' \
          '--ignore-errors[continue past task failures]' \
          '--ignore-unreachable[continue past unreachable hosts]' \
          '--known-hosts-file=[SSH known_hosts file]:file:_files' \
          '*--identity-file=[SSH identity file]:file:_files' \
          '*--env=[env var (key=value, repeatable)]:env:' \
          '--theme=[theme]:theme:' \
          '--output=[output format]:format:(text table markdown html json csv)' \
          '--report=[report type]:type:(recap all)' \
          ':task or command:' && ret=0
        ;;
      ssh)
        _arguments \
          $_global \
          ':server:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      check)
        _arguments \
          $_global \
          '--config=[config file]:file:_files -g "sake*.(yaml|yml)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
