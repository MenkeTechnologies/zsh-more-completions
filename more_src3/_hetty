_hetty() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[output usage text]' \
    '(-v --version)'{-v,--version}'[output version]' \
    '--cert=[path to root CA certificate]:file:_files -g "*.pem"' \
    '--key=[path to root CA private key]:file:_files -g "*.pem"' \
    '--db=[database file path]:file:_files' \
    '--addr=[TCP address to listen on (host:port)]:address:' \
    '--chrome[launch Chrome with proxy preconfigured]' \
    '--verbose[enable verbose logging]' \
    '--json[encode logs as JSON]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'cert:certificate management for trust-store integration'
      )
      _describe -t subcommands 'hetty subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        cert)
          if (( CURRENT == 2 )); then
            local -a certcmds
            certcmds=(
              'install:install certificate to system trust store'
              'uninstall:uninstall certificate from trust stores'
            )
            _describe -t subcommands 'cert subcommand' certcmds
          else
            case "${words[2]}" in
              install|uninstall)
                _arguments -s -S \
                  '(-h --help)'{-h,--help}'[output usage]' \
                  '--cert=[path to certificate]:file:_files -g "*.pem"' \
                  '--firefox[install/uninstall to/from Firefox trust store]' \
                  '--java[install/uninstall to/from Java trust store]' \
                  '--skip-system[skip system trust store]'
                ;;
            esac
          fi
          ;;
      esac
      ;;
  esac
}

_hetty "$@"
