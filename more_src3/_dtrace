#compdef dtrace
# Documentation: https://www.unix.com/man-page/osx/1/dtrace/
# Source: Apple macOS — DTrace dynamic tracer (Sun-derived).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-s[D program source file]:file:_files -g "*.d"' \
    '-p[grab process and exit on completion]:pid:_pids' \
    '-c[run command and exit on completion]:command:_command_names -e' \
    '-P[provider name to trace or list]:provider:' \
    '*-n[probe name to trace or list]:probe:' \
    '-G[generate ELF object containing embedded DOF]' \
    '*-L[append DTrace library search path]:dir:_directories' \
    '*-I[append cpp #include search path]:dir:_directories' \
    '*-D[define name for cpp]:name=value:' \
    '*-U[undefine name for cpp]:name:' \
    '-F[coalesce trace output (function entry/return)]' \
    '(- *)-V[print highest D interface version supported]' \
    '-l[list matching probes]' \
    '-q[quiet mode]' \
    '-v[verbose mode]' \
    '-w[allow destructive actions]' \
    '*-x[set DTrace runtime / D compiler option]:opt=val:' \
    '-X[ISO-C standard version]:level:(a c t s)' \
    '-A[claim anonymous tracing state]' \
    '-Z[allow probes to match zero entities]' \
    '-C[preprocess with cpp]' \
    '-H[print included header files (cpp)]' \
    '-e[exit after compile (do not enable)]' \
    '-o[output file]:file:_files' \
    '*:probe expression:' \
    && ret=0

return ret
