#compdef tpm2_changeauth
# _tpm2_changeauth — tpm2-software tpm2_changeauth change the authorization value for a TPM2 object hierarchy or NV index (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_changeauth() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[object context]:file:_files' \
        '--object-context=+[object context]:file:_files' \
        '-C+[parent context]:file:_files' \
        '--parent-context=+[parent context]:file:_files' \
        '-p+[old auth]:str:' \
        '--object-auth=+[old auth]:str:' \
        '-P+[parent auth]:str:' \
        '--parent-auth=+[parent auth]:str:' \
        '-r+[output private blob]:file:_files' \
        '--private=+[output private blob]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '--rphash=+[rp hash file]:file:_files' \
        '*:new auth:'
}

_tpm2_changeauth "$@"
