#compdef kingfisher
# Documentation: https://github.com/mongodb/kingfisher (src/main.rs clap subcommand registry)
# Reference accessed: 2026-05-29
# MongoDB Kingfisher — secret-detection scanner with live credential validation.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'scan:perform secret scanning across input sources'
  'rules:manage and validate detection rules'
  'view:open the interactive HTML report viewer'
  'config:manage configuration files'
  'validate:direct credential validation'
  'revoke:direct credential revocation'
  'access-map:access-mapping operations'
  'self-update:update the binary to the latest version'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '--config=[kingfisher.yaml project configuration]:file:_files -g "*.(yaml|yml)"'
  '--tls-mode=[TLS certificate validation behavior]:mode:(default insecure tls-insecure)'
  '*'{-v,--verbose}'[increase logging verbosity (stackable)]'
  '--quiet[suppress non-error output]'
  '--user-agent-suffix=[customize HTTP user agent suffix]:suffix:'
  '--no-update-check[skip automatic version check]'
  '--self-update[update the binary before executing command]'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'kingfisher subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _rules _config
    _rules=(
      'check:validate rule syntax, patterns, examples'
      'list:display available rules (pretty or JSON)'
    )
    _config=(
      'init:generate a kingfisher.yaml configuration template'
    )
    case $line[1] in
      scan)
        _arguments \
          $_global \
          '*--path=[scan a local path]:path:_files' \
          '*--git-url=[scan a git repository URL]:url:_urls' \
          '*--github-user=[scan all public repos for a GitHub user]:user:' \
          '*--github-organization=[scan all repos for a GitHub organization]:org:' \
          '*--s3-bucket=[scan an S3 bucket]:bucket:' \
          '*--exclude=[exclude glob (repeatable)]:glob:' \
          '*--skip-word=[skip rules matching word (repeatable)]:word:' \
          '--max-file-size-mb=[skip files larger than this (MB)]:mb:' \
          '--no-binary[skip binary files]' \
          '--no-validate[skip live credential validation]' \
          '--validation-timeout=[validation request timeout (seconds)]:seconds:' \
          '--validation-rps=[max validation requests per second]:rps:' \
          '--format=[output format]:format:(pretty json jsonl sarif)' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '--baseline-file=[ignore findings present in this baseline]:file:_files -g "*.(json|jsonl)"' \
          '--alert-webhook=[send alerts to webhook URL]:url:_urls' \
          '--alert-min-confidence=[minimum confidence to alert on]:level:(low medium high)' \
          '--alert-detail=[alert detail level]:level:(minimal medium full)' && ret=0
        ;;
      rules)
        _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'rules' _rules && ret=0
        ;;
      config)
        _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'config' _config && ret=0
        ;;
      validate|revoke)
        _arguments \
          $_global \
          '--rule=[rule id]:rule:' \
          '--secret=[secret value to validate/revoke]:secret:' \
          '--token-context=[additional token context (JSON)]:json:' && ret=0
        ;;
      view)
        _arguments \
          '--port=[viewer port]:port:' \
          ':report file:_files -g "*.(json|html)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
