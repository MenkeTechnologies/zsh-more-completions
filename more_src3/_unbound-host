#compdef unbound-host
# _unbound-host — NLnet Labs unbound-host (validating DNS lookup utility built on libunbound; shows secure/insecure/bogus DNSSEC status)
# upstream: https://github.com/NLnetLabs/unbound
# Flags from doc/unbound-host.1.in on tip.

_unbound-host() {
    _arguments \
        '(- *)-h[show help + version]' \
        '*-v[verbose (validation status, repeat for more)]' \
        '*-d[debug output to stderr (repeat for more)]' \
        '-c+[query class]:class:(IN CH HS)' \
        '-t+[query type]:type:(A AAAA MX TXT SRV NS SOA CNAME PTR ANY DS DNSKEY RRSIG NSEC NSEC3 CAA TLSA)' \
        '-y+[trust anchor as DS or DNSKEY record]:rr:' \
        '-D[enable DNSSEC validation using default root anchor]' \
        '-f+[trust anchor keyfile (DS/DNSKEY records)]:file:_files' \
        '-F+[BIND named.conf style trusted-key file]:file:_files' \
        '-C+[unbound.conf to prime libunbound with]:file:_files' \
        '-r[use /etc/resolv.conf forwarders]' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '1:hostname:_hosts'
}

_unbound-host "$@"
