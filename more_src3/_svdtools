#compdef svdtools
# _svdtools — ARM CMSIS-SVD manipulation tools (rust-embedded/svdtools)
# upstream: https://github.com/rust-embedded/svdtools
# Subcommands from svdtools/cli.py (click).

_svdtools() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--version[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_svdtools_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                patch)
                    _arguments '1:YAML patch file:_files -g "*.(yaml|yml)"' && ret=0 ;;
                makedeps)
                    _arguments \
                        '1:YAML patch file:_files -g "*.(yaml|yml)"' \
                        '2:dependency makefile output:_files' && ret=0 ;;
                interrupts)
                    _arguments \
                        '--gaps[print gaps in interrupt-number sequence (default)]' \
                        '--no-gaps[do not print gaps in interrupt-number sequence]' \
                        '1:SVD file:_files -g "*.svd"' && ret=0 ;;
                mmap)
                    _arguments '1:SVD file:_files -g "*.svd"' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_svdtools_commands] )) ||
_svdtools_commands() {
    local -a commands
    commands=(
        'patch:patch an SVD file as specified by a YAML file'
        'makedeps:emit Make-style dependency file for an SVD patch'
        'interrupts:list all interrupts described by an SVD file'
        'mmap:generate a text memory map from an SVD file'
        'version:print svdtools library and tool version'
    )
    _describe -t commands 'svdtools command' commands
}

_svdtools "$@"
