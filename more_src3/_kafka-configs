#compdef kafka-configs
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/ConfigCommand.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[Server to connect to]:host\:port:'
    '--bootstrap-controller[Controller to connect to]:host\:port:'
    '--command-config[Property file with configs to pass to Admin Client]:file:_files'
    '--alter[Alter the configuration for the entity]'
    '--describe[List configs for the given entity]'
    '--entity-type[Type of entity]:type:(topics brokers broker-loggers users clients ips client-metrics groups)'
    '--entity-name[Name of entity]:name:'
    '--entity-default[Default entity for entity-type]'
    '--add-config[Key=value pairs of configs to add]:configs:'
    '--add-config-file[Property file with configs to add]:file:_files'
    '--delete-config[Config keys to remove]:keys:'
    '--topic[Topic name]:topic:'
    '--broker[Broker ID]:id:'
    '--broker-defaults[Broker defaults entity]'
    '--broker-logger[Broker logger entity]:logger:'
    '--client[Client ID]:id:'
    '--client-defaults[Client defaults entity]'
    '--client-metrics[Client metrics name]:name:'
    '--group[Group name]:group:'
    '--user[User principal]:principal:'
    '--user-defaults[User defaults entity]'
    '--ip[IP address]:ip:'
    '--ip-defaults[IP defaults entity]'
    '--all[List all configs including defaults]'
)

_arguments -s -S $arguments
