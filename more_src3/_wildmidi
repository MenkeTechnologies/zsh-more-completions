#compdef wildmidi
# _wildmidi — Chris Ison Bret Curtis WildMIDI MIDI synthesizer/renderer using GUS-format soundfont patches for MIDI to WAV/OGG/PCM conversion (mindwerks team, C); getopt
# upstream: https://github.com/Mindwerks/wildmidi

_wildmidi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-x[print MIDI file info]' \
        '-l[log volume]' \
        '-m+[master volume]:n:' \
        '--master-volume=+[master volume]:n:' \
        '-o+[output WAV]:file:_files -g "*.wav *.ogg *.mp3 *.flac"' \
        '--wavout=+[output WAV]:file:_files -g "*.wav"' \
        '-w[stdout WAV]' \
        '--stdout[stdout WAV]' \
        '-c+[config]:file:_files -g "*.cfg wildmidi.cfg timidity.cfg"' \
        '--config-file=+[config]:file:_files -g "*.cfg wildmidi.cfg timidity.cfg"' \
        '-r+[rate Hz]:n:(8000 11025 16000 22050 32000 44100 48000 96000)' \
        '--rate=+[rate Hz]:n:(8000 11025 16000 22050 32000 44100 48000 96000)' \
        '-d+[device]:str:' \
        '--device=+[device]:str:' \
        '-b[reverb]' \
        '--reverb[reverb]' \
        '-e[enhanced resampling]' \
        '--enhanced-resampling[enhanced resampling]' \
        '-k[stop on EOF]' \
        '-n[no audio]' \
        '-p[playback]' \
        '-R+[roundtempo]:n:' \
        '-s[skip silence]' \
        '-t+[test mode]:n:(0 1 2 3 4)' \
        '-T[test mode]' \
        '*:MIDI file:_files -g "*.mid *.midi *.kar *.rmi *.lds *.mus *.hmi *.hmp *.xmi"'
}

_wildmidi "$@"
