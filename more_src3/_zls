#compdef zls
# Documentation: https://github.com/zigtools/zls (src/main.zig parseArgs)
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

# Zsh completion for zls (Zig Language Server)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'help:show help'
  'version:show version'
  'env:print config paths, log path, version'
)

_arguments -s -S \
  '--config-path[path to a zls.json configuration file]:file:_files' \
  '--log-file[path to log file]:file:_files' \
  '--log-level[set log verbosity]:level:(err warn info debug)' \
  '--enable-stderr-logs[write log messages to stderr]' \
  '--disable-lsp-logs[disable LSP window/logMessage notifications]' \
  '(- *)'{-h,--help,help}'[show help]' \
  '(- *)--version[show version]' \
  '1:subcommand:->subcommand' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'zls subcommand' subcommands && ret=0
    ;;
esac

return ret
