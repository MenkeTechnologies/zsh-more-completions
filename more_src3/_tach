#compdef tach
# Documentation: https://docs.gauge.sh/usage/commands/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:interactively define module boundaries'
  'mod:interactive terminal editor for configuring module boundaries'
  'sync:sync project configuration with actual dependencies'
  'check:check boundaries and interfaces are respected'
  'check-external:validate external imports match declared dependencies'
  'report:per-module report of imports/exports'
  'show:visualize dependency graph'
  'map:emit module dependency/dependent map'
  'test:run tests respecting tach.toml constraints'
  'install:install tach check as pre-commit hook'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tach command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '--force[force re-initialization if project is already configured]' && ret=0 ;;
      (mod)
        _arguments \
          '(-d --depth)'{-d+,--depth=}'[depth of child directories from root]:n:' \
          '*'{-e+,--exclude=}'[comma-separated paths to exclude]:paths:' && ret=0 ;;
      (sync)
        _arguments \
          '--add[add existing constraints and re-sync]' \
          '*'{-e+,--exclude=}'[comma-separated paths to exclude]:paths:' && ret=0 ;;
      (check)
        _arguments \
          '--exact[raise errors if any dependencies are unused]' \
          '--dependencies[check dependency constraints]' \
          '--interfaces[check interface implementations]' \
          '*'{-e+,--exclude=}'[comma-separated paths to exclude]:paths:' && ret=0 ;;
      (check-external)
        _arguments \
          '*'{-e+,--exclude=}'[comma-separated paths to exclude]:paths:' && ret=0 ;;
      (report)
        _arguments \
          '--dependencies[generate dependency report]' \
          '--usages[generate usage report]' \
          '--external[generate external dependency report]' \
          '*'{-d+,--dependency-modules=}'[filter dependencies]:modules:' \
          '*'{-u+,--usage-modules=}'[filter usages]:modules:' \
          '--raw[group lines by module without formatting]' \
          '*'{-e+,--exclude=}'[comma-separated paths to exclude]:paths:' \
          ':path:_files' && ret=0 ;;
      (show)
        _arguments \
          '(-o --out)'{-o+,--out=}'[output path for graph file]:file:_files' \
          '--mermaid[generate mermaid.js graph]' \
          '--web[open dependency graph in remote web viewer]' \
          '*:included path:_files' && ret=0 ;;
      (map)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
          '--direction=[direction of map]:dir:(dependencies dependents)' \
          '--closure=[get closure for specific file path]:path:_files' && ret=0 ;;
      (test)
        _arguments \
          '--base=[base commit for change detection]:rev:' \
          '--head=[head commit for comparison]:rev:' \
          '--disable-cache[skip cache checks and updates]' \
          '*:pytest args:' && ret=0 ;;
      (install)
        _arguments \
          '1:hook target:(pre-commit)' && ret=0 ;;
    esac ;;
esac

return ret
