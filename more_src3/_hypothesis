#compdef hypothesis
# _hypothesis — HypothesisWorks property-based testing for Python (HypothesisWorks, Python); click
# upstream: https://github.com/HypothesisWorks/hypothesis

_hypothesis() {
    local -a sub=(
        'fuzz:run a coverage-guided fuzz target'
        'write:scaffold test for a function'
        'codemod:run codemod over project'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hypothesis subcommand' sub ;;
        args)
            case $words[1] in
                fuzz) _arguments \
                    '--corpus=+[corpus dir]:dir:_files -/' \
                    '--seed=+[seed]:n:' \
                    '--max-runs=+[max runs]:n:' \
                    '--timeout=+[timeout sec]:n:' \
                    '--no-replay[no replay]' \
                    '--processes=+[parallel processes]:n:' \
                    '*:target:' ;;
                write) _arguments \
                    '1:function-name:' \
                    '--style=+[style]:s:(pytest unittest)' \
                    '--annotate=+[annotate types]:b:(true false)' \
                    '--except=+[exception list]:list:' ;;
                codemod) _arguments \
                    '*:path:_files' ;;
            esac
            ;;
    esac
}

_hypothesis "$@"
