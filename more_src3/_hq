#compdef hq
# Documentation: https://github.com/ludovicianul/hq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# hq: command line HTML elements finder (CSS/XPath selectors)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-a --attribute)'{-a+,--attribute=}'[output value of attribute]:attribute:' \
  '(-t --text)'{-t,--text}'[output text content of matched elements]' \
  '(-p --pretty)'{-p,--pretty}'[pretty-print HTML output]' \
  '(-f --file)'{-f+,--file=}'[input file (default stdin)]:file:_files -g "*.{html,htm,xhtml}"' \
  '(-r --remove)'{-r+,--remove=}'[remove matched elements (selector)]:selector:' \
  ':CSS selector:' && ret=0

return ret
