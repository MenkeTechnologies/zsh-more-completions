#compdef w_scan w_scan2
# _w_scan — Winfried Köhler w_scan and w_scan2 channel scanner for DVB-T/T2 DVB-C DVB-S/S2 ATSC and ISDB-T without initial tuning data (linuxtv team, C); getopt
# upstream: https://github.com/stefantalpalaru/w_scan2

_w_scan() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-a+[adapter]:n:(0 1 2 3)' \
        '-A+[frontend]:n:(0 1 2 3)' \
        '-c+[country]:c:(AU AT BE BR CA CH CN CZ DE DK ES FI FR GB GR HK HR HU IE IL IN IS IT JP KR LU NL NO NZ PL PT RO RU SE SG SI SK TR TW UA US VN ZA)' \
        '-f+[type]:t:(a c s t)' \
        '-l+[LNB type]:l:(UNIVERSAL DBS STANDARD ENHANCED L10700 L11300 C-BAND C-MULTI L10750 L10600)' \
        '-s+[satellite]:s:(S0E0 S1W S2E S5E S7E S9E S11W S13E S16E S19E S20W S21E S23W S24W S25W S27W S28W S30W S31W S34W S40W S42W S45W S52E S53E S57E S62W S66E S70W S75E S78E S80E S82E S84E S88E S91W S93E S95E S96W S100E S105E S111W S115W S118W S121W S125W S133W S138W S141W S148W S172E)' \
        '-S+[sat-rotor pos]:s:' \
        '-D+[diseqc]:n:(0 1 2 3)' \
        '-i+[inversion]:i:(0 1 2)' \
        '-I+[modulation]:m:(0 1 2 3 4 5)' \
        '-o+[output format]:o:(vdr vdr2 wscan vlc xine kaffeine zap xmltv mplayer dvbv5 json)' \
        '-O[old format]' \
        '-x+[output file]:file:_files' \
        '-X[xine output]' \
        '-w[wirbel]' \
        '-W[write to terminal]' \
        '-Y+[country code]:str:' \
        '-Z[no encrypted]' \
        '-E[exclude encrypted]' \
        '-F[fast scan]' \
        '-G[guess]' \
        '-H[help]' \
        '-J[long help]' \
        '-K[short help]' \
        '-L+[list lo]:l:(0 1 2 3 4)' \
        '-M+[scan mode]:m:(0 1 2 3 4)' \
        '-N+[non-functional ATSC etc.]:n:' \
        '-P[PnP]' \
        '-Q+[bandwidth filter]:b:(6 7 8)' \
        '-R+[radio services]:r:(0 1 2 3)' \
        '-T+[tv services]:t:(0 1 2 3)' \
        '-U[user-priority output]' \
        '-d+[delsys priority]:str:' \
        '-t+[tuning timeout]:n:'
}

_w_scan "$@"
