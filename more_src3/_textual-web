#compdef textual-web
# _textual-web — serve Textual apps over the web (Textualize/textual-web)
# upstream: https://github.com/Textualize/textual-web
# Flags from src/textual_web/cli.py (click).

_textual-web() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-c --config)'{-c+,--config=}'[TOML config file]:file:_files -g "*.toml"' \
        '(-e --environment)'{-e+,--environment=}'[environment]:env:' \
        '(-a --api-key)'{-a+,--api-key=}'[API key]:key:' \
        '*'{-r+,--run=}'[command to run a Textual app (repeatable)]:cmd:' \
        '--dev[enable devtools in Textual apps]' \
        '(-t --terminal)'{-t,--terminal}'[publish a remote terminal on a random URL]' \
        '(-x --exit-on-idle)'{-x+,--exit-on-idle=}'[exit after idle WAIT seconds]:s:' \
        '(-w --web-interface)'{-w,--web-interface}'[enable web interface]' \
        '(-s --signup)'{-s,--signup}'[create a textual-web account]' \
        '--welcome[launch an example app]' \
        '--merlin[launch Merlin game]'
}

_textual-web "$@"
