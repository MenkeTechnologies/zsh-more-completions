#compdef terraform-config-inspect
# _terraform-config-inspect — inspect Terraform module configuration (hashicorp/terraform-config-inspect)
# upstream: https://github.com/hashicorp/terraform-config-inspect
# Flags from main.go (spf13/pflag).

_terraform-config-inspect() {
    _arguments \
        '--json[produce JSON-formatted output]' \
        '--stack[parse a Terraform stack]' \
        '--after-init[parse a Terraform configuration after init]' \
        '*:module dir:_files -/'
}

_terraform-config-inspect "$@"
