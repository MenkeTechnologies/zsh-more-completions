#compdef incus-cli
# _incus-cli — LinuxContainers Incus system container/VM manager CLI alias (Linux Containers, Go); spf13/cobra
# upstream: https://github.com/lxc/incus

_incus-cli() {
    local -a sub=(
        'admin:admin commands'
        'alias:command alias management'
        'auth:authentication helpers'
        'cluster:cluster management'
        'config:config'
        'console:open console'
        'copy:copy instance/volume'
        'create:create instance'
        'delete:delete instance/profile'
        'exec:execute command'
        'export:export instance'
        'file:file operations'
        'image:image management'
        'import:import instance'
        'info:show resource info'
        'launch:create and start instance'
        'list:list instances'
        'monitor:monitor events'
        'move:move instance'
        'network:network management'
        'operation:operation management'
        'pause:pause instance'
        'profile:profile management'
        'project:project management'
        'publish:publish instance as image'
        'query:raw query API'
        'rebuild:rebuild instance'
        'remote:remote server management'
        'rename:rename instance'
        'restart:restart instance'
        'restore:restore from snapshot'
        'resume:resume instance'
        'shell:open shell'
        'snapshot:take snapshot'
        'start:start instance'
        'stop:stop instance'
        'storage:storage management'
        'top:top-style instance metrics'
        'trust:trust management'
        'version:show version'
        'warning:warning management'
        'webui:open web UI'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--force-local[force using local socket]' \
        '--no-aliases[no aliases]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--sub-commands[show sub-commands tree]' \
        '--project=+[project name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'incus subcommand' sub ;;
        args)
            case $words[1] in
                launch|create) _arguments \
                    '1:image:' \
                    '2:name:' \
                    '--vm[create VM]' \
                    '--profile=+[profile]:list:' \
                    '-p+[profile]:list:' \
                    '--config=+[config key=value]:str:' \
                    '-c+[config key=value]:str:' \
                    '--device=+[device]:str:' \
                    '-d+[device]:str:' \
                    '--network=+[network]:str:' \
                    '-n+[network]:str:' \
                    '--storage=+[storage pool]:str:' \
                    '-s+[storage pool]:str:' \
                    '--type=+[instance type]:t:(container virtual-machine)' \
                    '-t+[instance type]:t:(container virtual-machine)' \
                    '--ephemeral[ephemeral]' \
                    '-e[ephemeral]' \
                    '--target=+[cluster target]:str:' ;;
                list) _arguments \
                    '--columns=+[columns]:list:' \
                    '-c+[columns]:list:' \
                    '--format=+[format]:fmt:(table csv json yaml compact)' \
                    '-f+[format]:fmt:(table csv json yaml compact)' \
                    '--fast[fast list]' \
                    '--all-projects[all projects]' \
                    '*:filter:' ;;
                exec) _arguments \
                    '1:instance:' \
                    '--env=+[env var]:str:' \
                    '-e+[env var]:str:' \
                    '--mode=+[mode]:m:(auto interactive non-interactive)' \
                    '-t[force pseudo-terminal]' \
                    '-T[disable pseudo-terminal]' \
                    '-n[disable stdin]' \
                    '--user=+[user id]:str:_users' \
                    '--group=+[group id]:str:_groups' \
                    '--cwd=+[cwd]:dir:_files -/' \
                    '*:cmd:_command_names -e' ;;
                snapshot|restore) _arguments \
                    '1:instance:' \
                    '*:name:' ;;
                copy|move|rename|publish|export|import) _arguments '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(device edit get metadata remove set show template trust unset)' \
                    '*:arg:' ;;
                profile|network|storage|project|cluster|image|remote|trust) _arguments \
                    '1:cmd:(add apply assign copy create delete device edit get list rename remove set show unset)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_incus-cli "$@"
