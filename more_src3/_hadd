#compdef hadd
# Documentation: https://github.com/root-project/root/blob/master/main/src/hadd.cxx
# Documentation: https://github.com/root-project/root/blob/master/main/src/hadd-argparse.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse stubs in hadd-argparse.py and argv loop in hadd.cxx

# hadd: merge ROOT histograms / files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,-help,--help}'[show help and exit]' \
  '-a[append to existing target file]' \
  '-f[force overwriting of output file]' \
  '-f0[no compression]' \
  '-f1[compression level 1]' \
  '-f2[compression level 2]' \
  '-f3[compression level 3]' \
  '-f4[compression level 4]' \
  '-f5[compression level 5]' \
  '-f6[compression level 6]' \
  '-f7[compression level 7]' \
  '-f8[compression level 8]' \
  '-f9[compression level 9 (maximum)]' \
  '-ff[use compression settings of first input file]' \
  '-fk[keep input baskets compression; metadata uses specified level]' \
  '-k[skip corrupt or non-existent files without exiting]' \
  '-O[re-optimize basket size when merging TTrees]' \
  '-T[do not merge Trees]' \
  '-dbg[enable verbosity and preserve partial files in multiprocess mode]' \
  '-d+[directory for partial multiprocess execution]:directory:_files -/' \
  '-j+[parallelize across N processes]:N:' \
  '-v+[verbosity level (0..99)]:level:' \
  '-n+[maximum number of concurrently open files]:N:' \
  '-cachesize+[resize prefetching cache (0 disables)]:size:' \
  '-L+[file listing objects to filter]:file:_files' \
  '-Ltype+[filter operation mode]:type:(SkipListed OnlyListed)' \
  '-experimental-io-features+[enable experimental output tree features]:features:' \
  '*:root file:_files -g "*.root"' && ret=0

return ret
