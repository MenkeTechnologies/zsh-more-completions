#compdef ynab ynab-cli
# Documentation: https://github.com/stephendolan/ynab-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'accounts:account commands (list/view/transactions)'
  'budgets:budget commands (list/view/settings/set-default)'
  'categories:category commands (list/view/update/budget/transactions)'
  'transactions:transaction commands (list/view/create/update/delete/search/split)'
  'payees:payee commands (list/view/update/locations/transactions)'
  'months:month commands (list/view)'
  'scheduled:scheduled transactions'
  'auth:auth commands (login/status/logout)'
  'api:invoke YNAB API directly'
  'mcp:run as MCP server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--compact[minified JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ynab command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (accounts)
        _arguments '*::sub:(list view transactions)' && ret=0 ;;
      (budgets)
        _arguments '*::sub:(list view settings set-default)' && ret=0 ;;
      (categories)
        _arguments \
          '*::sub:(list view update budget transactions)' \
          '--name=[set name]:name:' \
          '--note=[set note]:note:' \
          '--category-group-id=[set category group id]:id:' \
          '--goal-target=[set goal target]:amount:' \
          '--month=[budget month YYYY-MM]:month:' \
          '--amount=[budget amount]:amount:' && ret=0 ;;
      (transactions)
        _arguments \
          '*::sub:(list view create update delete search split)' \
          '--account=[account id]:account:' \
          '--since=[since date]:date:' \
          '--approved[approved only]' \
          '--min-amount=[min amount]:amount:' \
          '--fields=[fields to display]:fields:' \
          '--memo=[memo (search)]:memo:' \
          '--payee-name=[payee name (search)]:name:' \
          '--amount=[amount]:amount:' \
          '--date=[date]:date:' \
          '--splits=[splits]:splits:' && ret=0 ;;
      (payees)
        _arguments \
          '*::sub:(list view update locations transactions)' \
          '--name=[set name]:name:' && ret=0 ;;
      (months)
        _arguments '*::sub:(list view)' && ret=0 ;;
      (scheduled)
        _arguments '*::sub:(list view delete)' && ret=0 ;;
      (auth)
        _arguments '*::sub:(login status logout)' && ret=0 ;;
      (api)
        _arguments '*::sub:(GET POST)' && ret=0 ;;
    esac ;;
esac

return ret
