#compdef sfheadercut
# Documentation: http://www.ahay.org/RSF/sfheadercut.html
# Source: ahay/src system/main/headercut.c — cut an RSF dataset based on header information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'mask=[header file (integer mask)]: :_files -g "*.rsf(-.)"' \
    'n1=[size of first axis (from history if omitted)]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
