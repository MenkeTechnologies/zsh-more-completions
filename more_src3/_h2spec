#compdef h2spec
# _h2spec — HTTP/2 conformance testing tool
# upstream: https://github.com/summerwind/h2spec

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-p --port)'{-p,--port=}'[target port number]:port:' \
    '(-H --host)'{-H,--host=}'[target host]:host:_hosts' \
    '(-t --timeout)'{-t,--timeout=}'[time limit for each test in seconds]:seconds:' \
    '--max-header-length=[max header length]:length:' \
    '(-P --path)'{-P,--path=}'[target path]:path:' \
    '(-S --tls)'{-S,--tls}'[use TLS]' \
    '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification]' \
    '--strict[run all strict mode test cases]' \
    '(-j --junit-report)'{-j,--junit-report=}'[path for JUnit XML report]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[output verbose log]' \
    '(-s --section)'{-s,--section=}'[run only specified section]:section:' \
    '--dryrun[display test cases without running]' \
    '*:test section:' \
    && return 0
