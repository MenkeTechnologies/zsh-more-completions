#compdef verona
# =============================================================================
# verona — Microsoft Research's "Research programming
#          language to explore the concept of concurrent
#          ownership" — a C++-based research compiler
#          for a novel programming language where the
#          OWNERSHIP MODEL is extended from Rust's
#          single-thread aliasing-XOR-mutation to a
#          MULTI-THREAD setting via the concept of
#          "regions" + "cowns" (concurrent owners),
#          enabling safe data sharing across actor-like
#          concurrent tasks without locks, atomics, or
#          stop-the-world garbage collection.
#          Distinguishing from Rust (single-thread
#          borrow checker; Send/Sync traits + Mutex/
#          RwLock for cross-thread sharing), Pony
#          (Sylvan Clebsch's reference-capability
#          actor lang at 22 capabilities; lab-tested
#          but smaller community), Akka (Lightbend's
#          JVM actor library; type-unsafe message
#          passing), Erlang (mature actor lang but
#          dynamically typed + immutable-message
#          required), Inko (Yorick Peterse's actor
#          lang with similar ownership but smaller
#          ecosystem), and conventional shared-state-
#          plus-mutex C++/Java by:
#            - CONCURRENT OWNERSHIP — every object lives
#              in a REGION owned by a COWN (concurrent
#              owner).  Cowns can SCHEDULE THEMSELVES to
#              run; when scheduled, they have exclusive
#              access to their region's objects.  No
#              two cowns can have references into the
#              same region; ownership-based race
#              prevention extends naturally across
#              threads
#            - REGION-BASED MEMORY MANAGEMENT — instead
#              of per-object reference counting or
#              tracing GC, Verona groups related objects
#              into REGIONS managed as a unit.  Regions
#              can be allocated, transferred between
#              cowns, or freed wholesale; per-object
#              overhead is amortized across the region
#            - CO-LOCATED-EXECUTION SCHEDULER — when a
#              cown schedules itself, its region's
#              objects are guaranteed to be co-located
#              with the worker thread executing it;
#              cache-friendly compared to global heap
#              shared-pointer allocation patterns
#            - TRIESTE COMPILER INFRASTRUCTURE — Verona
#              is built atop microsoft/trieste (also
#              from MS Research), a generic term-
#              rewriting compiler framework that
#              expresses each compiler phase as an
#              AST→AST rewrite using pattern-matching
#              rules.  Trieste exposes a unified CLI
#              with `build` / `test` / `check`
#              subcommands; Verona inherits this
#              + adds `--no-std`
#            - PROPERTY-BASED FUZZ TESTING built-in —
#              `verona test` generates random ASTs +
#              runs them through each compiler pass;
#              if any pass produces ill-formed output,
#              the random seed + AST shape is reported
#              for reproduction.  Continuous-fuzzing
#              compiler design discipline
#            - PASS-DUMP INSPECTION — `verona build --
#              dump_passes <dir>` writes the AST after
#              each named compiler phase to a separate
#              file; useful for understanding how the
#              language semantics are progressively
#              refined through type-checking + lambda-
#              lifting + variable-binding + reference-
#              resolution + member-conflict-detection
#              etc.
#            - PATTERN-CHECKING via `verona check
#              <start> <end>` — verifies that the AST
#              patterns matched by each compiler pass
#              don't have overlapping or missing
#              cases; catches compiler-rule bugs
#              before they reach end-user code
#            - WELL-FORMEDNESS CHECKING — `-w` flag
#              enables per-pass well-formedness
#              checking; catches compiler-internal
#              invariant violations early in
#              development
#            - LOG LEVELS — `-l Trace|Debug|Info|
#              Warning|Output|Error|None` controls
#              compiler logging verbosity; useful for
#              compiler engineers debugging pass
#              ordering or rewrite-rule application
#            - 3,721+ STARS ON microsoft/verona —
#              backed by Microsoft Research's
#              Programming Languages + Verification
#              group (PLV); maintained continuously
#              since 2020 by researchers including
#              Tobias Wrigstad (Uppsala), Sylvan
#              Clebsch (MS Research), Matthew Parkinson
#              (MS Research), Sophia Drossopoulou
#              (Imperial College), and others
#          Used by: programming language researchers
#          exploring novel ownership models for
#          concurrent programming, PhD students at
#          Imperial / Uppsala / Cambridge studying
#          region-based memory management + actor
#          calculi, Microsoft Research engineers
#          prototyping safer C++ alternatives for
#          systems code, and the broader academic
#          community interested in formal foundations
#          of concurrent ownership.
#
# RESEARCH-STAGE CAVEAT: the project README explicitly
# states "The project is not ready to be used outside
# of research, and is under going a massive refactoring.
# The previous version can be found in the `old_version`
# branch."  Verona is NOT intended for production use;
# expect breaking changes + occasional broken builds.
#
# Author:  Microsoft Research's Programming Languages
#          and Verification (PLV) group; principal
#          contributors include Sylvan Clebsch (also
#          author of Pony lang), Matthew Parkinson,
#          Tobias Wrigstad (Uppsala), Sophia
#          Drossopoulou (Imperial College London),
#          Susan Eisenbach (Imperial), Juliana Franco,
#          Alex Potanin, and many others.  Mirrors of
#          academic papers on the project page
#          https://www.microsoft.com/en-us/research/
#          project/project-verona/
# Source:  https://github.com/microsoft/verona
#          https://github.com/microsoft/verona/blob/main/src/main.cc
#          https://github.com/microsoft/verona/blob/main/src/CMakeLists.txt
#          https://github.com/microsoft/trieste (compiler
#          framework Verona is built on)
# Manpage: No traditional manpage; `verona --help`
#          shows top-level subcommands (build/test/
#          check); `verona <sub> --help` shows per-
#          subcommand options.  `verona --help-all`
#          expands all subcommand help in one shot.
#          Full project docs at https://www.microsoft.
#          com/en-us/research/project/project-verona/
# Library: microsoft/trieste (the term-rewriting
#          compiler framework that provides the Verona
#          CLI's build/test/check subcommands +
#          AST→AST pass infrastructure); CLI11 (the
#          C++ argparse library that trieste uses
#          internally; CLI's `add_option` /
#          `add_flag` / `set_help_all_flag` calls
#          shape the Verona CLI surface; not part of
#          the cross-language CLI library taxonomy
#          which tracks Rust/Go/TS-Node libraries —
#          Verona is a STANDALONE LANGUAGE entry).
#          Implementation: C++ via CMake.
# License: MIT
# Status:  3,721+ stars on microsoft/verona; actively
#          refactored (latest commit 2026-05-29);
#          research-only release.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — 122nd LANGUAGE CLOSES 3+1 MICRO-CYCLE
# -----------------------------------------------------------------------------
# This completion is the **122nd language** entry in the
# cross-language CLI library taxonomy.  It closes the
# current 3+1 micro-cycle that began with R757 Rust=97
# (basalt/pulldown-cmark OPENS Axis 42 Markdown Parsing)
# → R758 Go=97 (tdx/yuin/goldmark continues Axis 42) →
# R759 TS-Node=97 (cleaver/markedjs/marked CLOSES Axis
# 42 at 1/1/1) → R760 THIS (122nd language).
#
# WHY VERONA IS A DISTINCTIVE 122nd-LANGUAGE ENTRY:
#
#   Verona occupies a unique position in the
#   programming-language landscape because it answers
#   the question "what would Rust's ownership model
#   look like if it were designed FROM SCRATCH for
#   concurrent rather than single-threaded execution?"
#   by introducing REGIONS + COWNS (concurrent owners)
#   as first-class language constructs rather than
#   wrapping Send/Sync + Mutex around single-thread
#   ownership.
#
#   Distinguishing features in the broader cross-
#   language landscape:
#
#     1. REGION-BASED CONCURRENT OWNERSHIP — most
#        ownership-typed languages (Rust, Pony, Hylo)
#        track ownership at the OBJECT level.  Verona
#        tracks it at the REGION level — a group of
#        objects with shared lifetime + shared
#        accessibility.  Fewer types to track, easier
#        whole-data-structure transfers
#
#     2. COWN SCHEDULING — cowns are SELF-SCHEDULING
#        units of work (similar to lightweight
#        goroutines or Erlang processes) but with
#        REGION OWNERSHIP attached.  When a cown
#        schedules itself, it gains exclusive access
#        to its region for the duration of one
#        scheduled execution; no locks needed because
#        the type system + runtime conspire to
#        serialize access
#
#     3. TRIESTE-BASED REWRITING COMPILER — the
#        compiler is implemented as a sequence of
#        TERM-REWRITING PASSES (rather than the
#        traditional lex → parse → typecheck → IR →
#        codegen pipeline of imperative compilers).
#        Each pass is a function from AST to AST;
#        composability + testability come for free
#
#     4. PROPERTY-BASED COMPILER TESTING — `verona
#        test` generates random ASTs + runs them
#        through compiler passes, catching pass-
#        soundness bugs BEFORE they appear in user
#        code.  Few other production compilers have
#        this level of automated fuzz-testing built
#        into the CLI
#
#     5. REFACTORING-IN-PROGRESS — the current main
#        branch is undergoing massive refactoring;
#        the old language semantics are preserved in
#        the `old_version` branch.  Demonstrates the
#        academic-iteration cycle openly, not just
#        the polished end product
#
#     6. CROSS-INSTITUTIONAL AUTHORSHIP — pulls
#        together researchers from MS Research,
#        Imperial College, Uppsala, Cambridge,
#        Australian National University, and others;
#        a true cross-institutional PL research
#        project rather than a single-lab effort
#
#     7. SYLVAN CLEBSCH LINEAGE — co-developed by
#        Sylvan Clebsch, who is ALSO the author of
#        Pony (the actor lang with reference
#        capabilities).  Verona represents the
#        "second generation" attempt at concurrent
#        ownership, learning from Pony's design
#        experience
#
# Cross-language CLI library taxonomy after R760:
#   * 122 languages
#   * 471 total CLI library variants (Rust 97 / Go 97 /
#     TS-Node 97)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 35 axes at 1/1/1 three-language symmetric
#
# Cross-language ECOSYSTEM context (Microsoft Research
# language family in this corpus):
#   * F* (in corpus) — Catalin Hritcu + Nikhil Swamy's
#     dependently-typed verification language
#   * Dafny (in corpus) — Rustan Leino's verification-
#     aware imperative language
#   * Bosque (R748 in corpus) — Mark Marron's
#     regularized programming with SMT-backed checker
#   * Q# (in corpus as _qsharp) — quantum DK lang
#   * Verona (R760 THIS) — Sylvan Clebsch + Matthew
#     Parkinson + collaborators' concurrent-ownership
#     research language with region-based memory
#     management
#
# Verona joins this rich Microsoft Research language
# family but differentiates by focusing on CONCURRENT
# OWNERSHIP specifically — the other MSR languages
# focus on verification (F*, Dafny, Bosque) or quantum
# computing (Q#) rather than concurrent systems
# programming.
#
# Cross-language ECOSYSTEM context (Ownership-Typed
# Concurrent Languages family in this corpus):
#   * Rust (extensive corpus coverage) — Send/Sync
#     traits + Mutex/RwLock; ownership is single-
#     thread, threads communicate via channels
#   * Pony (in corpus) — Sylvan Clebsch's reference-
#     capability actor lang with 22 capabilities
#   * Inko (in corpus) — Yorick Peterse's actor lang
#     with similar ownership ideas, smaller scope
#   * Neut (R744 in corpus) — vekatze's box-modality
#     static memory management (single-thread focus)
#   * Verona (R760 THIS) — region-based + cown-based
#     concurrent ownership, MS Research
#
# Comparison to other 122nd-language candidates:
#   * Verona (R760 THIS) — Microsoft Research, 3,721
#     stars, MIT, active, novel concurrent ownership
#     model with academic+industrial provenance
#   * Beef (BeefyTech/Beef) — Brian Fiete's
#     performance lang; 2,815 stars but already
#     represented as `_beefbuild`
#   * Granule (granule-project/granule) — Cambridge
#     graded modal types; 717 stars, niche
#   * Aiken (aiken-lang/aiken) — Cardano smart
#     contracts; 579 stars but already in corpus
#   * Plutarch (Plutonomicon/plutarch-plutus) —
#     Cardano eDSL; 133 stars, narrow scope
#   * Hylo — binary conflicts with Hieracles
#   * Cogent — 177 stars, niche
#
# Verona is the chosen 122nd-language entry because:
#   - It has a real, installable CLI compiler
#     (`verona build/test/check`) with rich
#     subcommand structure inherited from trieste
#   - The "region-based concurrent ownership" thesis
#     is structurally distinct from every prior
#     language entry in the corpus's 121 existing
#     slots
#   - Microsoft Research backing + cross-institutional
#     authorship provide academic + industrial
#     legitimacy
#   - 3,721 stars indicates substantial community
#     interest despite the explicit "not production-
#     ready" disclaimer
#   - Sylvan Clebsch's involvement creates a
#     lineage-narrative with Pony (already in
#     corpus) — the same researcher iterating on the
#     same problem space, learning from Pony's
#     experience and refining toward Verona's
#     region-based approach
#   - The trieste-based rewriting compiler
#     architecture is itself a teaching tool for
#     compiler engineering; the CLI exposes the
#     internals via --dump_passes + per-pass
#     test/check subcommands
#
# -----------------------------------------------------------------------------
#
# THE verona CLI
#
# verona is a multi-subcommand CLI (require_subcommand(1)
# enforces exactly one subcommand) built on CLI11 via
# the microsoft/trieste compiler framework.
# Invocation:
#   verona <subcommand> [options]
#
# Subcommands:
#   build <path> [options]            compile a Verona source path
#   test [start] [end] [options]      property-based fuzz test passes
#   check <start> <end> [options]     check compiler patterns for bugs
#
# Common options across subcommands:
#   -l, --log_level <level>           Trace | Debug | Info | Warning |
#                                     Output | Error | None
#
# build-specific options:
#   path                              source path (required positional)
#   -w                                check well-formedness
#   -p, --pass <pass>                 run up to this named pass
#   -o, --output <path>               output path
#   -n, --language_name <name>        language name for output file
#       --dump_passes <dir>           dump AST after each pass to dir
#       --no-std                      don't import the standard library
#                                     (Verona-specific extension)
#
# test-specific options:
#   start                             start at this pass
#   end                               end at this pass
#   -c, --seed_count <N>              iterations per pass (default 100)
#   -s, --seed <N>                    random seed (default random)
#   -d, --max_depth <N>               max AST depth (default 10)
#   -f, --failfast                    stop on first failure
#       --sequence                    test sequence of passes on
#                                     generated trees
#       --size_stats                  collect AST size statistics
#                                     (implies log level Info)
#   -r, --max_retries <N>             max retries for unique trees
#       --gen_bound <bool>            generate bound variable names
#                                     (default true)
#       debug_entropy                 sub-sub-command: test entropy
#                                     of random number generation
#
# check-specific options:
#   start                             start at this pass
#   end                               end at this pass
#   -w                                check well-formedness
#
# Global:
#       --help-all                    expand all help (verbose)
#   -h, --help                        show help
#
# Common invocations:
#   # Compile a Verona source file
#   verona build hello.verona
#
#   # Compile + dump AST after each pass for debugging
#   verona build --dump_passes ./pass-dumps hello.verona
#
#   # Compile only up to the type-validation pass
#   verona build --pass typevalid hello.verona
#
#   # Compile without importing standard library
#   verona build --no-std hello.verona
#
#   # Verbose logging
#   verona build -l Debug hello.verona
#
#   # Run property-based fuzz tests across all passes
#   verona test
#
#   # Fuzz tests with a fixed seed (reproducible)
#   verona test --seed 42 --seed_count 1000
#
#   # Fuzz tests stopping at first failure, max depth 5
#   verona test --failfast --max_depth 5
#
#   # Test entropy of the random number generator
#   verona test debug_entropy
#
#   # Check that compiler pass patterns are sound between
#   # the modules and structure phases
#   verona check modules structure
#
#   # Combine help for all subcommands in one output
#   verona --help-all
#
# OPTIONS (sourced directly from
# https://github.com/microsoft/verona/blob/main/src/main.cc +
# https://github.com/microsoft/trieste/blob/main/include/trieste/driver.h):
#
# (See subcommand documentation above for the complete
# flag set.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _verona_subcommands
_verona_subcommands=(
    'build:compile a Verona source path'
    'test:property-based fuzz testing of compiler passes'
    'check:check compiler patterns for bugs'
)

local -a _verona_log_levels
_verona_log_levels=(
    'Trace:most verbose logging'
    'Debug:debug-level logging'
    'Info:info-level logging'
    'Warning:warning-level logging'
    'Output:output-only logging'
    'Error:errors only'
    'None:no logging'
)

local -a _verona_test_subs
_verona_test_subs=(
    'debug_entropy:test entropy of the random number generation'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--help-all[expand help for all subcommands]' \
    '1:subcommand:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'verona subcommand' _verona_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            build)
                _arguments \
                    '(-l --log_level)'{-l,--log_level}'=[log verbosity]:level:->loglevel' \
                    '-w[check well-formedness]' \
                    '(-p --pass)'{-p,--pass}'=[run up to this pass]:pass: ' \
                    '(-o --output)'{-o,--output}'=[output path]:path:_files' \
                    '(-n --language_name)'{-n,--language_name}'=[language name for output file]:name: ' \
                    '--dump_passes=[dump passes to directory]:dir:_directories' \
                    '--no-std[do not import the standard library]' \
                    '1:source path:_files -g "*.verona"' \
                    && ret=0
                ;;
            test)
                if (( CURRENT == 2 )) && [[ -z $words[CURRENT] || $words[CURRENT] == d* ]]; then
                    _alternative \
                        'subcmds:test subcommand:_describe -t testsubs "test sub" _verona_test_subs' \
                        'passes:start pass: ' \
                        && ret=0
                else
                    _arguments \
                        '(-l --log_level)'{-l,--log_level}'=[log verbosity]:level:->loglevel' \
                        '(-c --seed_count)'{-c,--seed_count}'=[iterations per pass (default 100)]:N: ' \
                        '(-s --seed)'{-s,--seed}'=[random seed]:N: ' \
                        '(-d --max_depth)'{-d,--max_depth}'=[max AST depth (default 10)]:N: ' \
                        '(-f --failfast)'{-f,--failfast}'[stop on first failure]' \
                        '--sequence[test sequence of passes on generated trees]' \
                        '--size_stats[collect AST size statistics]' \
                        '(-r --max_retries)'{-r,--max_retries}'=[max retries for unique trees]:N: ' \
                        '--gen_bound=[generate bound variable names]:bool: ' \
                        '1:start pass: ' \
                        '2:end pass: ' \
                        && ret=0
                fi
                ;;
            check)
                _arguments \
                    '(-l --log_level)'{-l,--log_level}'=[log verbosity]:level:->loglevel' \
                    '-w[check well-formedness]' \
                    '1:start pass: ' \
                    '2:end pass: ' \
                    && ret=0
                ;;
        esac
        ;;
esac

case $state in
    loglevel)
        _describe -t loglevels 'log level' _verona_log_levels && ret=0
        ;;
esac

return ret
