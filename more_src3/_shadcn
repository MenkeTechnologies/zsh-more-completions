#compdef shadcn
# Documentation: https://ui.shadcn.com/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for shadcn component CLI

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--cwd=[working directory]:dir:_files -/' \
  '--silent[suppress output]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'shadcn command' \
      init add apply preset view search list build docs info migrate && ret=0
    ;;
  args)
    case $line[1] in
      (preset)
        _values 'preset subcommand' decode resolve info url open && ret=0 ;;
      (migrate)
        _values 'migration' rtl radix icons && ret=0 ;;
      (*)
        _files && ret=0 ;;
    esac
    ;;
esac

return ret
