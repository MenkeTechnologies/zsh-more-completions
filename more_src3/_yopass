#compdef yopass yopass-cli
# _yopass — Johan Haals Yopass self-destruct secrets CLI (Johan Haals / jhaals, Go); spf13/cobra
# upstream: https://github.com/jhaals/yopass

_yopass() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--api=+[yopass API URL]:url:_urls' \
        '-a+[yopass API URL]:url:_urls' \
        '--decrypt=+[URL to decrypt]:url:_urls' \
        '-d+[URL to decrypt]:url:_urls' \
        '--expiration=+[expiration]:e:(1h 1d 1w)' \
        '-e+[expiration]:e:(1h 1d 1w)' \
        '--file=+[file to encrypt]:file:_files' \
        '-f+[file to encrypt]:file:_files' \
        '--key=+[manual encryption key]:str:' \
        '-k+[manual encryption key]:str:' \
        '--url=+[yopass UI URL]:url:_urls' \
        '-u+[yopass UI URL]:url:_urls' \
        '--one-time=+[allow N reads]:n:' \
        '*:secret:'
}

_yopass "$@"
