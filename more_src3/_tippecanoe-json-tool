#compdef tippecanoe-json-tool
# Documentation: https://github.com/mapbox/tippecanoe
# Source: mapbox/tippecanoe jsontool.cpp — pre-process JSON features for tippecanoe (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w --wrap)'{-w,--wrap}'[wrap output features in a feature collection]' \
    '(-e --extract)'{-e+,--extract=}'[extract sub-feature using this property name as ID]:property:_default' \
    '(-c --csv)'{-c+,--csv=}'[join CSV by feature ID column]:file:_files -g "*.csv"' \
    '(-p --prevent)'{-p+,--prevent=}'[prevent specified feature simplification]:flag:_default' \
    '*:json file:_files' \
    && ret=0

return ret
