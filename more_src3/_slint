#compdef slint-viewer slint-lsp
# Documentation: https://github.com/slint-ui/slint
# Reference accessed: 2026-05-21
# Verified: tools/viewer/main.rs and tools/lsp/main.rs (clap parsers).

case "$service" in
  slint-viewer)
    _arguments \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '--auto-reload[automatically watch file system and reload on change]' \
      '--backend=[Slint rendering backend]:backend' \
      '*-I+[include path for imported .slint files or images]:path:_directories' \
      '*-L+[library path for @library imports]:library=path' \
      '--style=[style name (defaults to fluent)]:style' \
      '--save-data=[save public property values to JSON on exit]:file:_files' \
      '--load-data=[load public property values from JSON]:file:_files' \
      '--component=[component name to load]:component' \
      '*--on[set a callback handler]:callback:->skip' \
      '--translation-domain=[gettext translation domain]:domain' \
      '--translation-dir=[gettext translation directory]:dir:_directories' \
      '--no-default-translation-context[disable default translation context]' \
      '*:slint file:_files -g "*.slint"'
    ;;
  slint-lsp)
    local curcontext="$curcontext" state line ret=1
    _arguments -C \
      '(-h --help)'{-h,--help}'[show help]' \
      '(-V --version)'{-V,--version}'[show version]' \
      '--backend=[preview backend]:backend:(qt femtovg skia software)' \
      '*-I+[include path for import statements]:path:_directories' \
      '*-L+[library path (library=/path/to/library)]:library=path' \
      '--style=[preview style (defaults to fluent)]:style' \
      '--fullscreen[start the preview in full screen mode]' \
      '--no-toolbar[hide the preview toolbar]' \
      '1: :->cmd' \
      '*::arg:->args' && ret=0
    case $state in
      (cmd)
        local -a commands=(
          'format:format slint files'
        )
        _describe -t commands 'slint-lsp subcommand' commands && ret=0
        ;;
      (args)
        case ${words[1]} in
          (format)
            _arguments \
              '(-i --inline)'{-i,--inline}'[modify file inline instead of printing to stdout]' \
              '*:slint file:_files -g "*.slint"' && ret=0
            ;;
        esac
        ;;
    esac
    return ret
    ;;
esac
