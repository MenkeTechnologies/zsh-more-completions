#compdef impacket-tstool
# Documentation: https://github.com/fortra/impacket/blob/master/examples/tstool.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-tstool: RDP/Terminal Services management (qwinsta, tasklist, taskkill, tscon, etc.)
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (hex)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '-port[SMB port]:port:' \
  '1:target (DOMAIN/user[:password]@host):' \
  '2:action:->action' \
  '*::action args:->actargs' && ret=0

case $state in
  action)
    _values 'action' \
      'qwinsta[list sessions]' \
      'tasklist[list processes]' \
      'taskkill[kill process]' \
      'tscon[connect session to console]' \
      'tsdiscon[disconnect session]' \
      'logoff[log off session]' \
      'shutdown[shutdown/reboot]' \
      'msg[send a message]' \
      'shadow[shadow a session]' && ret=0
    ;;
  actargs)
    case $line[2] in
      qwinsta|tasklist)
        _arguments '-v[verbose output]' && ret=0
        ;;
      taskkill)
        _arguments \
          '-pid[process ID]:pid:' \
          '-name[process name]:name:' && ret=0
        ;;
      tscon)
        _arguments \
          '-source[source session ID]:id:' \
          '-dest[destination session]:dest:' \
          '-password[password]:pass:' && ret=0
        ;;
      tsdiscon|logoff)
        _arguments '-session[session ID]:id:' && ret=0
        ;;
      shutdown)
        _arguments \
          '-logoff[log off only]' \
          '-shutdown[shutdown]' \
          '-reboot[reboot]' \
          '-poweroff[power off]' && ret=0
        ;;
      msg)
        _arguments \
          '-session[session ID]:id:' \
          '-title[message title]:title:' \
          '-message[message body]:msg:' && ret=0
        ;;
      shadow)
        _arguments \
          '-session[session ID]:id:' \
          '-control[allow control]' \
          '-prompt[prompt user for consent]' \
          '-file[output capture file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
