#compdef xcodegen-cli
# _xcodegen-cli — Yonas Kolb XcodeGen YAML-based Xcode project generator CLI alias (Yonas Kolb / yonaskolb, Swift); custom argparse
# upstream: https://github.com/yonaskolb/XcodeGen

_xcodegen-cli() {
    local -a sub=(
        'generate:generate Xcode project'
        'cache:cache commands'
        'dump:dump project as JSON'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--spec=+[project spec yaml]:file:_files -g "project.yml *.yml *.yaml"' \
        '-s+[project spec yaml]:file:_files -g "project.yml *.yml *.yaml"' \
        '--project=+[project file]:file:_files -g "*.xcodeproj"' \
        '-p+[project file]:file:_files -g "*.xcodeproj"' \
        '--project-root=+[project root]:dir:_files -/' \
        '-r+[project root]:dir:_files -/' \
        '--no-env[no env interpolation]' \
        '-n[no env interpolation]' \
        '--use-cache[use cache]' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '-c+[cache path]:dir:_files -/' \
        '--only-plists[only plists]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcodegen subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '--spec=+[project spec yaml]:file:_files -g "project.yml *.yml *.yaml"' \
                    '-s+[project spec yaml]:file:_files -g "project.yml *.yml *.yaml"' \
                    '--project=+[project file]:file:_files -g "*.xcodeproj"' \
                    '-p+[project file]:file:_files -g "*.xcodeproj"' \
                    '--use-cache[use cache]' \
                    '--cache-path=+[cache path]:dir:_files -/' \
                    '-c+[cache path]:dir:_files -/' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--only-plists[only plists]' \
                    '--no-env[no env interpolation]' ;;
                cache) _arguments \
                    '1:cmd:(generate clear)' \
                    '*:arg:' ;;
                dump) _arguments \
                    '--type=+[output type]:t:(yaml json)' \
                    '-t+[output type]:t:(yaml json)' \
                    '--file=+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_xcodegen-cli "$@"
