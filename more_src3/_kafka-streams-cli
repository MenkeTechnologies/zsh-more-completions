#compdef kafka-streams-cli kstream-cli
# _kafka-streams-cli — Apache Kafka kafka-streams-cli kstream-cli CLI command-line frontend wrapping the Apache Kafka Streams reset-tool stream-processing library providing input intermediate-topics application-id bootstrap-servers commands-config dry-run by-duration force from-file from-datetime to-datetime to-earliest topic group reset-offsets (Apache Kafka team, Java); custom argparse
# upstream: https://kafka.apache.org/

_kafka-streams-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--application-id=+[name]:str:' \
        '--bootstrap-server=+[host:port]:str:' \
        '--bootstrap-servers=+[host:port]:str:' \
        '--config-file=+[file]:file:_files -g "*.properties *.conf"' \
        '--commands-config=+[file]:file:_files -g "*.properties *.conf"' \
        '--dry-run[dry run]' \
        '--force[force]' \
        '--input-topics=+[list]:str:' \
        '--intermediate-topics=+[list]:str:' \
        '--internal-topics=+[list]:str:' \
        '--by-duration=+[duration]:str:' \
        '--to-datetime=+[YYYY-MM-DDTHH:mm:ss.sssXXX]:str:' \
        '--to-earliest[seek to earliest]' \
        '--to-latest[seek to latest]' \
        '--to-offset=+[N]:n:' \
        '--from-file=+[file]:file:_files -g "*.csv"' \
        '--shift-by=+[N]:n:' \
        '--from-datetime=+[YYYY-MM-DDTHH:mm:ss.sssXXX]:str:' \
        '--zookeeper=+[host:port]:str:' \
        '--reset-offsets[reset offsets]' \
        '--all-topics[all topics]' \
        '--topic=+[name]:str:' \
        '--group=+[id]:str:' \
        '--describe[describe]' \
        '--execute[execute]' \
        '--export[export]' \
        '*::'
}

_kafka-streams-cli "$@"
