#compdef kail
# Documentation: https://github.com/boz/kail
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Kubernetes log tailer. Corrected from prior file against README:
# -c is --containers (plural), -j/--job has a shorthand, removed invented
# --ds daemonset and -V/--version flags, added --ignore-ns and --dry-run,
# fixed --output enum to (default raw json pretty zerolog).

_arguments -s -S \
  '(-l --label)'{-l,--label}'[label selector]:label:' \
  '(-p --pod)'{-p,--pod}'[pod name]:pod:' \
  '(-c --containers)'{-c,--containers}'[container name]:container:' \
  '(-n --ns --namespace)'{-n,--ns,--namespace}'[namespace]:namespace:' \
  '--svc[service name]:service:' \
  '--rc[replication controller]:rc:' \
  '--rs[replica set]:rs:' \
  '(-d --deploy)'{-d,--deploy}'[deployment name]:deployment:' \
  '--sts[stateful set]:sts:' \
  '(-j --job)'{-j,--job}'[job name]:job:' \
  '--node[node name]:node:' \
  '--ing[ingress name]:ingress:' \
  '--context[kubernetes context]:context:' \
  '--current-ns[use current namespace]' \
  '--ignore[label selector to ignore]:selector:' \
  '--ignore-ns[namespace to ignore]:namespace:' \
  '--since[show logs since duration]:duration:' \
  '--dry-run[print matched pods and exit]' \
  '(-o --output)'{-o,--output}'[output format]:format:(default raw json pretty zerolog)' \
  '--log-file[log file]:file:_files' \
  '--log-level[log level]:level:(debug info warn error)' \
  '(-h --help)'{-h,--help}'[show help]' && return 0
