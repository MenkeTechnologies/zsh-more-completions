#compdef ipfwadm
# Documentation: https://manned.org/ipfwadm.8
# Reference accessed: 2026-05-16
# Verified: ipfwadm(8) manpage on manned.org. Tool was removed from Debian
# after buster; only useful on legacy kernels (<2.4 pre-iptables era).
# Removed from prior file: fabricated --help/--version long flags (ipfwadm
# is single-letter-only) and bogus man.archlinux.org search URL.

# ipfwadm: legacy Linux 2.0/2.2 IP firewall administration tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[accounting rule]:direction:(in out both)' \
  '-I[input firewall rules]' \
  '-O[output firewall rules]' \
  '-F[forwarding firewall rules]' \
  '-M[masquerading administration]' \
  '-a[append rule]:policy:(accept deny reject masquerade)' \
  '-i[insert rule at top]:policy:(accept deny reject masquerade)' \
  '-d[delete rule]' \
  '-l[list rules]' \
  '-z[zero packet/byte counters]' \
  '-f[flush rules]' \
  '-p[set default policy]:policy:(accept deny reject)' \
  '-s[set timeout values]:tcp\:tcpfin\:udp:' \
  '-c[check packet against rules]' \
  '-h[show help]' \
  '-P[protocol]:proto:(tcp udp icmp all)' \
  '-S[source addr/mask [port ...]]:source:' \
  '-D[destination addr/mask [port ...]]:dest:' \
  '-V[address to bind to]:address:' \
  '-W[network interface]:interface:' \
  '-b[bidirectional matching]' \
  '-e[extended output]' \
  '-k[match TCP ACK packets only]' \
  '-m[masquerade matching packets]' \
  '-n[numeric output]' \
  '-o[log matching packets to syslog]' \
  '-r[redirect to local port]:port:' \
  '-t[bitmask manipulation (andmask xormask)]:masks:' \
  '-v[verbose output]' \
  '-x[expanded numbers]' \
  '-y[match only TCP SYN packets]' && ret=0
return ret
