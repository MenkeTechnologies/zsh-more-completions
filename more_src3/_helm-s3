#compdef helm-s3
# helm-s3: Helm plugin to use S3 as a chart repository
# https://github.com/hypnoglow/helm-s3

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'init:initialize an S3 chart repository'
      'push:push a chart to an S3 repository'
      'reindex:reindex the repository'
      'delete:delete a chart from the repository'
    )
    _describe -t commands 'helm-s3 command' commands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--force[force init even if index.yaml exists]' \
          '1:S3 URI' && ret=0
        ;;
      push)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--force[force push even if version exists]' \
          '--dry-run[simulate push without uploading]' \
          '--ignore-if-exists[skip push if version exists]' \
          '--relative[use relative URLs in index.yaml]' \
          '--acl=[S3 ACL]:acl:(private public-read public-read-write authenticated-read bucket-owner-read bucket-owner-full-control)' \
          '--content-type=[override content type]:content-type' \
          '1:chart:_files -g "*.tgz"' \
          '2:repository name' && ret=0
        ;;
      reindex)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--relative[use relative URLs in index.yaml]' \
          '1:repository name' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--version=[chart version to delete]:version' \
          '1:chart name' && ret=0
        ;;
    esac
    ;;
esac

return ret
