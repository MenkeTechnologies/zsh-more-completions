#compdef konsole5 konsole
# Documentation: https://docs.kde.org/trunk_kf6/en/konsole/konsole/command-line-options.html
# Reference accessed: 2026-05-16
# Verified: KDE Konsole command-line options docs.
# Removed from prior file: bogus man.archlinux.org search URL.

# konsole5: KDE terminal emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--fullscreen[start in fullscreen]' \
  '--background-mode[start in background, ready on Ctrl+Shift+F12]' \
  '(--hide-menubar)--show-menubar[show menubar]' \
  '(--show-menubar)--hide-menubar[hide menubar]' \
  '(--hide-tabbar)--show-tabbar[show tabbar]' \
  '(--show-tabbar)--hide-tabbar[hide tabbar]' \
  '--notransparency[disable transparency]' \
  '--profile=[specify profile]:profile:' \
  '--builtin-profile[use built-in profile]' \
  '--list-profiles[list profile names]' \
  '--list-profile-properties[list profile properties]' \
  '*-p[set profile property]:property=value:' \
  '--layout=[load tab layout file]:file:_files' \
  '--new-tab[open new tab]' \
  '--tabs-from-file=[load tabs from file]:file:_files' \
  '--workdir=[initial working directory]:dir:_files -/' \
  '(--noclose)--hold[do not close terminal on command exit]' \
  '(--hold)--noclose[do not close terminal on command exit]' \
  '(--nofork)--separate[run in separate process]' \
  '(--separate)--nofork[run in separate process]' \
  '-e[run command]:command:_command_names' \
  '*::args:_normal' && ret=0
return ret
