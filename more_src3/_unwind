#compdef unwind
# _unwind — OpenBSD unwind (validating recursive DNS resolver intended for workstations/laptops; listens on localhost; falls back to autoconfigured resolvers when DNS is blocked; controlled by unwindctl(8))
# upstream: https://github.com/openbsd/src (sbin/unwind)
# Flags from sbin/unwind/unwind.8 on tip.

_unwind() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '-f+[config file (default /etc/unwind.conf)]:file:_files' \
        '-s+[control socket (default /dev/unwind.sock)]:file:_files'
}

_unwind "$@"
