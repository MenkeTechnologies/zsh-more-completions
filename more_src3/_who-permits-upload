#compdef who-permits-upload
# Documentation: https://manpages.debian.org/who-permits-upload
# Source: debian/devscripts scripts/who-permits-upload.pl — query Debian DM upload permissions (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-k --keyring)'{-k+,--keyring=}'[GPG keyring file]:file:_files -g "*.{gpg,asc}"' \
    '(-d --dmfile)'{-d+,--dmfile=}'[DM upload permissions file URL]:url:_default' \
    '(-s --search)'{-s+,--search=}'[search type]:type:(package uid sponsor)' \
    '*:search term:_default' \
    && ret=0

return ret
