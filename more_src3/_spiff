#compdef spiff
# Documentation: https://github.com/mandelsoft/spiff
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'merge:merge templates with stubs into a final manifest'
      'diff:show structural differences between two manifests'
      'convert:convert input files to JSON or normalize ordering'
      'encrypt:encrypt or decrypt data'
    )
    _describe -t commands 'spiff command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      merge)
        _arguments -s -S \
          '--partial[handle incomplete expression evaluation]' \
          '--json[output JSON instead of YAML]' \
          '--path=[output a specific nested path]:path:' \
          '--split[output each list element as a separate document]' \
          '--select=[select a dedicated field for output]:field path:' \
          '--evaluate=[evaluate a dynaml expression on the processed document]:expression:' \
          '--state=[enable state support]:state path:_files' \
          '--bindings=[YAML file for additional bindings]:file:_files' \
          '--tag=[provide content for predefined global tag tag:path]:tag:' \
          {-D,--define=}'[binding value key=value]:key=value:' \
          '--preserve-escapes[preserve escaping for dynaml expressions]' \
          '--preserve-temporary[preserve fields marked as temporary]' \
          '--features=[enable specific features]:features:' \
          '*:template/stub file:_files' \
          && ret=0
        ;;
      convert)
        _arguments -s -S \
          '--json[convert to JSON]' \
          '--path=[output specific nested path]:path:' \
          '--split[output list elements separately]' \
          '--select=[select specific field]:field:' \
          '*:file:_files' && ret=0
        ;;
      encrypt)
        _arguments -s -S \
          '-d[decrypt data (otherwise encrypts)]' \
          '*:file:_files' && ret=0
        ;;
      diff)
        _arguments -s -S '*:file:_files' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
