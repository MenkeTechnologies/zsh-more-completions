#compdef xrdfs
# Documentation: https://man.archlinux.org/man/xrdfs.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrdfs: interactive xrootd filesystem client.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'ls:list directory'
  'cat:show file contents'
  'tail:show tail of file'
  'stat:stat object'
  'statvfs:stat virtual filesystem'
  'mv:rename file or directory'
  'mkdir:make a directory'
  'rm:remove a file'
  'rmdir:remove a directory'
  'truncate:truncate a file'
  'chmod:change mode (rwxr-x--x style)'
  'query:server-specific queries'
  'prepare:prepare files'
  'spaceinfo:show space info'
  'locate:locate a file'
  'xattr:get/set/del/list extended attributes'
)
_arguments -C \
  '--no-cwd[do not preset CWD in interactive mode]' \
  '1:server:_hosts' \
  '*: :->cmd' && ret=0
case $state in
  cmd) _describe -t commands 'xrdfs command' commands && ret=0 ;;
esac
return ret
