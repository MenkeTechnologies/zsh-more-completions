#compdef starknet
# _starknet — StarkWare starknet original Python CLI for compiling Cairo and interacting with StarkNet network (starkware-libs team, Python); argparse
# upstream: https://github.com/starkware-libs/cairo-lang

_starknet() {
    local -a sub=(
        'declare:declare a contract class'
        'deploy:deploy a contract instance'
        'deploy_account:deploy account contract'
        'new_account:create new account'
        'invoke:invoke a contract function'
        'call:call a view function'
        'tx_status:show tx status'
        'get_transaction:get tx info'
        'get_transaction_receipt:get tx receipt'
        'get_transaction_trace:get tx trace'
        'estimate_fee:estimate fee'
        'estimate_message_fee:estimate L1 message fee'
        'get_block:get block info'
        'get_class_by_hash:get contract class'
        'get_class_hash_at:get class hash at address'
        'get_contract_addresses:get system contract addresses'
        'get_full_contract:get full contract'
        'get_state_update:get state update'
        'get_storage_at:get storage at slot'
        'get_nonce:get account nonce'
        'get_code:get contract bytecode'
        'simulate_transaction:simulate tx'
        'compile:compile a contract'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--network=+[network]:n:(mainnet alpha alpha-mainnet alpha-goerli alpha-sepolia integration)' \
        '--network_id=+[network id]:str:' \
        '--gateway_url=+[gateway url]:url:_urls' \
        '--feeder_gateway_url=+[feeder gateway url]:url:_urls' \
        '--chain_id=+[chain id]:str:' \
        '--account=+[account name]:str:' \
        '--account_dir=+[account dir]:dir:_files -/' \
        '--wallet=+[wallet]:w:(starkware.starknet.wallets.open_zeppelin.OpenZeppelinAccount)' \
        '--no_wallet[no wallet]' \
        '--keystore=+[keystore]:file:_files' \
        '--starknet_chain_id=+[chain id]:str:' \
        '--max_fee=+[max fee]:n:' \
        '--nonce=+[nonce]:n:' \
        '--signature=+[signatures]:str:' \
        '--inputs=+[inputs]:str:' \
        '--contract=+[compiled contract]:file:_files -g "*.json"' \
        '--abi=+[abi file]:file:_files -g "*.json"' \
        '--address=+[contract address]:str:' \
        '--function=+[function name]:str:' \
        '--salt=+[salt]:str:' \
        '--block_hash=+[block hash]:str:' \
        '--block_number=+[block number]:str:' \
        '--retry_on_unavailable[retry on 503]' \
        '--token=+[deploy token]:str:' \
        '--no_pretty[no pretty print]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'starknet subcommand' sub ;;
    esac
}

_starknet "$@"
