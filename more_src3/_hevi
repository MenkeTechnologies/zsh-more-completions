#compdef hevi
# Documentation: https://codeberg.org/arnauc/hevi
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--color[enable colored output]' \
  '--no-color[disable colored output]' \
  '--uppercase[use uppercase hex]' \
  '--lowercase[use lowercase hex]' \
  '--size[show size at end]' \
  '--no-size[hide size line]' \
  '--offset[show offset column]' \
  '--no-offset[hide offset column]' \
  '--ascii[show ASCII interpretation]' \
  '--no-ascii[hide ASCII column]' \
  '--skip-lines[skip identical lines]' \
  '--no-skip-lines[do not skip identical lines]' \
  '--raw[raw format (disables most features)]' \
  '--show-palette[show current color palette]' \
  '--parser[parser to use]:parser:(elf pe qoi data)' \
  '1:file:_files' && ret=0

return ret
