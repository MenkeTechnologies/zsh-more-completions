#compdef zine
# Documentation: https://zine-ssg.io/docs/
# Reference accessed: 2026-05-21
# Verified: upstream Command enum cross-checked against kristoff-it/zine
#   src/main.zig (init, release, debug, help, version, serve, server, dev,
#   develop). Removed prior fabricated subcommands (new, build, markdown)
#   and per-subcommand flag tables (--source, --dest, --path, --port,
#   --open) not present upstream.

local curcontext="$curcontext" state line ret=1

_zine_commands() {
  local -a commands=(
    'init:initialize a new zine site'
    'release:build your website for release'
    'serve:start the development server'
    'server:alias for serve'
    'dev:alias for serve'
    'develop:alias for serve'
    'debug:debug helpers'
    'help:show full list of available commands'
    'version:show zine version'
  )
  _describe -t commands 'zine command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:_zine_commands' \
  '*:: :_files' && ret=0

return ret
