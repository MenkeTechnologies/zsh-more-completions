#compdef subjack
# Documentation: source-direct extraction from upstream
# haccer/subjack main.go `flag.StringVar/.IntVar/.BoolVar(...)`
# declarations (Go stdlib flag package).
# Reference accessed: 2026-05-30 via gh api.
# haccer subjack R144a — subdomain takeover detection tool for
# offensive security / bug-bounty workflows. Sister to the
# heavily-covered amass / subfinder / assetfinder / waybackurls /
# katana / httpx recon family.

_arguments -s -S \
  '-d+[single domain to check]:domain:_hosts' \
  '-w+[path to wordlist of subdomains]:file:_files' \
  '-t+[number of concurrent threads (default 10)]:n:' \
  '-timeout=[connection timeout in seconds (default 10)]:sec:' \
  '-ssl[force HTTPS connections (may increase accuracy)]' \
  '-a[send requests to every URL, not just those with identified CNAMEs]' \
  '-v[display more information per request]' \
  '-o+[output file (use .json extension for JSON output)]:file:_files' \
  '-r+[path to a list of DNS resolvers]:file:_files' \
  '-m[flag dead CNAME records even if domain is not available for registration]' \
  '-ns[check if nameservers are available for purchase (NS takeover)]' \
  '-ar[check for stale A records pointing to dead IPs (may require root for ICMP)]' \
  '-axfr[check for zone transfers (AXFR) including NS bruteforce]' \
  '-mail[check for SPF include and MX record takeovers]'
