#compdef kbagent
# _kbagent — KubeBlocks per-pod agent (apecloud/kubeblocks)
# upstream: https://github.com/apecloud/kubeblocks
# Flags from cmd/kbagent/main.go on tip.

_kbagent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--server=[run kb-agent in server mode]:bool:(true false)' \
        '--address=[kb-agent HTTP bind address]:ip:' \
        '--unix-socket=[Unix domain socket path]:path:_files' \
        '--port=[kb-agent HTTP bind port]:port:' \
        '--streaming-port=[streaming endpoint port]:port:' \
        '--max-concurrency=[max concurrent requests]:n:' \
        '--api-logging=[enable per-request API logging]:bool:(true false)' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)'
}

_kbagent "$@"
