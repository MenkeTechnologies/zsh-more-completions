#compdef writefreely
# Documentation: https://github.com/writefreely/writefreely
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cmd/writefreely/main.go).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'user:user management'
  'db:database operations'
  'config:configuration management'
  'keys:generate or load encryption keys'
  'serve:run the WriteFreely server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-c+[load configuration from file]:file:_files -g "*.ini"' \
  '--debug[enable debug logging]' \
  '--create-config[generate a basic configuration]' \
  '--config[interactive configuration process]' \
  '--sections=[which sections to configure (server db app)]:list:' \
  '--gen-keys[generate encryption and authentication keys]' \
  '--init-db[initialize app database]' \
  '--migrate[migrate the database]' \
  '--create-admin=[create admin (username:password)]:user\:pw:' \
  '--create-user=[create user (username:password)]:user\:pw:' \
  '--delete-user=[delete user]:user:' \
  '--reset-pass=[reset password for user]:user:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'writefreely command' commands && ret=0 ;;
esac

return ret
