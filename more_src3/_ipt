#compdef ipt

_arguments -s -S \
  '(- *)--help[show help information]' \
  '(- *)--version[show version]' \
  '--autocomplete[enable autocomplete]' \
  '--copy[copy selection to clipboard]' \
  '--decode-ansi[decode ANSI escape codes]' \
  '--extract-path[extract file paths from input]' \
  '--file-path[read input from file]:file:_files' \
  '--multiple[allow multiple selections]' \
  '--no-trim[do not trim output]' \
  '--ordered[maintain selection order]' \
  '--separator[output separator]:separator' \
  '--size[number of lines to display]:lines' \
  '--uniq[show unique results only]'
