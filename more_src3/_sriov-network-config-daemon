#compdef sriov-network-config-daemon
# _sriov-network-config-daemon — SR-IoV per-node config daemon (k8snetworkplumbingwg/sriov-network-operator)
# upstream: https://github.com/k8snetworkplumbingwg/sriov-network-operator
# Subcommands + flags from cmd/sriov-network-config-daemon/{start,service,waitforconfig}.go on tip.

_sriov-network-config-daemon() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the SR-IoV config daemon'
                service:'run a single configuration phase as a systemd service'
                wait-for-config:'wait until the SR-IoV configuration converges'
            )
            _describe -t commands 'sriov-network-config-daemon command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--kubeconfig=[kubeconfig file (testing)]:file:_files' \
                        '--node-name=[managed Kubernetes node name]:name:' \
                        '--use-systemd-service[run in systemd service mode]' \
                        '--disable-plugins=[comma-sep plugins to disable]:list:' \
                        '--parallel-nic-config[configure NICs in parallel]' \
                        '--manage-software-bridges[manage software (OVS) bridges]' \
                        '--ovs-socket-path=[OVSDB socket path]:path:_files'
                    ;;
                service)
                    _arguments \
                        '(-p --phase)'{-p,--phase=}'[configuration phase]:phase:(pre post)'
                    ;;
                wait-for-config)
                    _arguments \
                        '--pod-name=[caller pod name]:name:' \
                        '--pod-namespace=[caller pod namespace]:ns:'
                    ;;
            esac
            ;;
    esac
}

_sriov-network-config-daemon "$@"
