#compdef unrar
# Documentation: unrar (RAR archive extractor)
# Source: extract / list / test RAR archives.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args state line
local -a commands

commands=(
    'e:extract files without archived paths'
    'l:list archive content (brief)'
    'lt:list archive content (technical)'
    'lb:list archive content (bare)'
    'p:print files to stdout'
    't:test archive'
    'v:verbosely list archive content'
    'vt:verbosely list (technical)'
    'vb:verbosely list (bare)'
    'x:extract files with full path'
)

_arguments -s -C \
    '-ad[append archive name to destination path]' \
    '-ag-[generate archive name by mask]::mask:' \
    '-ai[ignore file attributes]' \
    '-ap+[set path inside archive]:path:' \
    '-c-[disable comments show]' \
    '-cl[convert names to lower case]' \
    '-cu[convert names to upper case]' \
    '-dh[open shared files]' \
    '-ep[exclude paths from names]' \
    '-ep1[exclude base dir from names]' \
    '-ep3[expand paths to full incl drive letter]' \
    '-f[freshen files]' \
    '-id-[disable messages/list/header/progress]:flag:(c d p q)' \
    '-ierr[send all messages to stderr]' \
    '-inul[disable all messages]' \
    '-kb[keep broken extracted files]' \
    '-n+[include only specified file]:filename:' \
    '-o+[set overwrite mode]:mode:(+ -)' \
    '-or[rename files automatically]' \
    '-ow[save/restore owner/group]' \
    '-p+[set password]:password:' \
    '-p-[do not query password]' \
    '-r[recurse subdirectories]' \
    '-sl+[process files smaller than size]:size:' \
    '-sm+[process files bigger than size]:size:' \
    '-ta+[process files modified after date YYYYMMDDHHMMSS]:date:' \
    '-tb+[process files modified before date YYYYMMDDHHMMSS]:date:' \
    '-tn+[process files newer than time period]:period:' \
    '-to+[process files older than time period]:period:' \
    '-ts+[save/restore file time]:mode:(c m a p)' \
    '-u[update files]' \
    '-v[volume only]' \
    '-vp[pause before each volume]' \
    '-x+[exclude specified file]:filename:' \
    '-y[assume Yes on all queries]' \
    '-@[disable file lists]' \
    '-@+[read file lists from stdin]' \
    '1:command:->cmds' \
    '2:archive:_files -g "*.(rar|cbr|RAR|CBR)"' \
    '*::files-or-listfile:_files' \
    && ret=0

case $state in
    cmds) _describe -t commands 'unrar command' commands && ret=0 ;;
esac

return ret
