#compdef iwd
# Documentation: https://man.archlinux.org/man/iwd.8
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: prior file had a #compdef iwctl collision with _iwctl and a
# block of invented flags (--passphrase, --dont-ask, --timeout, -p)
# that belong to iwctl, not the iwd daemon. iwd.8 documents only
# --version/-v and --help/-h.

# Zsh completion for iwd - iNet Wireless Daemon

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-v,--version}'[show version number and exit]'
