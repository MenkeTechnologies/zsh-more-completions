#compdef sonic-pi-tool
# ============================================================================
# _sonic-pi-tool — zsh completion for sonic-pi-tool, the OSC-based Sonic Pi CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/lpil/sonic-pi-tool
#   Author     : Louis Pilfold (lpil) — also creator of the Gleam language
#   License    : MPL-2.0
#   Stars      : 232
#   Language   : Rust
#   Crate      : sonic-pi-tool v0.1.0
#   Binary     : sonic-pi-tool  (Cargo.toml [[bin]] name)
#   Last push  : 2024-06-16
#
# WHAT IT IS
#   sonic-pi-tool is "controlling Sonic Pi from the command line" — Louis
#   Pilfold's Rust CLI for the Sonic Pi livecoding music environment by
#   Sam Aaron.  Sonic Pi listens for OSC (Open Sound Control) messages on
#   UDP port 4557 to evaluate Ruby-flavoured code that drives the
#   SuperCollider audio backend.  sonic-pi-tool sends those OSC messages
#   from a terminal so the user can drive Sonic Pi from `$EDITOR`, from
#   stdin pipes, from shell scripts, or as part of a livecoding workflow
#   without having to keep the Sonic Pi GUI focused.  Available
#   operations: probe the server, evaluate a Ruby snippet inline / from
#   stdin / from a file, start the bundled SuperCollider server, stop all
#   running synths, stream the server's log events to stdout, and record
#   the audio output to a `.wav` file via the server's recording API.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap v2 SubCommand chain)
#   sonic-pi-tool <command> [args]
#
#   Subcommands:
#     check                       Check if the Sonic Pi server is listening
#                                 on port 4557 (OSC probe)
#     eval <CODE>                 Send <CODE> string to the Sonic Pi server
#                                 for evaluation (Sonic Pi Ruby DSL)
#     eval-stdin                  Read Sonic Pi code from stdin and send
#                                 it to the server
#     eval-file <PATH>            Read Sonic Pi code from a file and send
#                                 it to the server
#     start-server                Locate and start the Sonic Pi server
#                                 (forks the bundled SuperCollider
#                                 backend)
#     stop                        Stop all currently playing music on the
#                                 server (send the OSC `/stop-all-jobs`)
#     logs                        Print log events emitted by the Sonic
#                                 Pi server (OSC log channel)
#     record <PATH>               Record the audio output of the current
#                                 session to <PATH> (absolute path)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `rosc = "~0.1"` declared in Cargo.toml — the
#   canonical Rust OSC (Open Sound Control) library by klingtnet
#   (klingtnet/rosc).  rosc handles the OSC 1.0 / 1.1 wire format —
#   address pattern matching, type-tag string parsing, bundle / message
#   serialization, time tags — that Sonic Pi's UDP-based protocol uses
#   to receive code-evaluation, transport, and recording commands.
#   Verified via:
#     gh api repos/lpil/sonic-pi-tool/contents/Cargo.toml
#       → rosc = "~0.1"
#   This entry is the Rust=119 leader bump that OPENS Axis 64
#   (OSC / Open Sound Control Library), pairing with future
#   Go=hypebeast/go-osc and TS-Node=osc-js / osc.js poles to close
#   the axis at 1/1/1.
#
#   No completion for `sonic-pi-tool` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  The
#   adjacent `more_src/_sonic-pi-cli` in this corpus is the unrelated
#   Ruby-implemented sonic-pi-cli wrapper (different binary name).
# ============================================================================

_sonic-pi-tool() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_sonic-pi-tool_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                eval)         _arguments ':sonic pi code:'                     && ret=0 ;;
                eval-file)    _arguments ':code file:_files -g "*.(rb|sp|spi)"' && ret=0 ;;
                record)       _arguments ':output wav file (absolute path):_files -g "*.wav"' && ret=0 ;;
                check|eval-stdin|start-server|stop|logs)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sonic-pi-tool_commands] )) ||
_sonic-pi-tool_commands() {
    local -a commands
    commands=(
        'check:check if the Sonic Pi server is listening on port 4557'
        'eval:send a string of Sonic Pi code to the server for evaluation'
        'eval-stdin:read Sonic Pi code from stdin and send to the server'
        'eval-file:read Sonic Pi code from a file and send to the server'
        'start-server:find and start the Sonic Pi (SuperCollider) server'
        'stop:stop all currently playing music on the server'
        'logs:print log events emitted by the Sonic Pi server'
        'record:record the audio output of the current session to a file'
    )
    _describe -t commands 'sonic-pi-tool command' commands
}

_sonic-pi-tool "$@"
