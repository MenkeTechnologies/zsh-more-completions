#compdef liftoff
# _liftoff — Alaina Shumate Steven Salzberg liftoff CLI accurate annotation lift-over tool transferring gene annotations between genome assemblies through minimap2-driven alignment of source gene sequences to target genome producing remapped GFF3 GTF annotation file mapping intron/exon structure (Alaina Shumate team, Python); argparse
# upstream: https://github.com/agshumate/Liftoff

_liftoff() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-g+[reference annotation]:file:_files -g "*.gff *.gff3 *.gtf"' \
        '-db+[reference db]:file:_files -g "*.db"' \
        '-o+[output gff]:file:_files -g "*.gff *.gff3 *.gtf"' \
        '-u+[unmapped file]:file:_files' \
        '-exclude_partial[exclude partial mappings]' \
        '-mismatch=+[N]:n:' \
        '-gap_open=+[N]:n:' \
        '-gap_extend=+[N]:n:' \
        '-p+[threads]:n:' \
        '-m+[minimap2 path]:file:_files' \
        '-dir+[intermediate dir]:dir:_files -/' \
        '-sc+[copies]:str:' \
        '-copies[include copies]' \
        '-s+[min sequence identity]:n:' \
        '-a+[min coverage]:n:' \
        '-d+[max distance ratio]:n:' \
        '-flank+[flank]:n:' \
        '-V+[verbosity]:l:(0 1 2)' \
        '-f+[feature types]:file:_files' \
        '-infer_genes[infer parent genes]' \
        '-infer_transcripts[infer transcripts]' \
        '-chroms=+[file]:file:_files' \
        '-unplaced=+[file]:file:_files' \
        '-cds[include CDS]' \
        '-polish[polish output]' \
        '-overlap+[N]:n:' \
        '*:target fasta:_files -g "*.fa *.fasta *.fna *.gz"'
}

_liftoff "$@"
