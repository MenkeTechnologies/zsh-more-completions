#compdef spi-test spidev_test
# _spi-test — Linux kernel tools spidev_test CLI for testing SPIdev character-device transfer modes bits-per-word speed read length pattern verification loopback tx-rx data dump (kernel tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git/tree/tools/spi

_spi-test() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-D+[device]:file:_files -g "/dev/spidev*"' \
        '--device=+[device]:file:_files -g "/dev/spidev*"' \
        '-s+[max speed Hz]:n:' \
        '--speed=+[max speed Hz]:n:' \
        '-d+[delay us]:n:' \
        '--delay=+[delay us]:n:' \
        '-b+[bits per word]:n:' \
        '--bpw=+[bits per word]:n:' \
        '-l[LSB first]' \
        '--lsb[LSB first]' \
        '-C[chip select high]' \
        '--cs-high[chip select high]' \
        '-3[3-wire mode]' \
        '--3wire[3-wire mode]' \
        '-N[no chip select]' \
        '--no-cs[no chip select]' \
        '-R[ready]' \
        '--ready[ready]' \
        '-2[dual]' \
        '--dual[dual]' \
        '-4[quad]' \
        '--quad[quad]' \
        '-O[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-I[input file]:file:_files' \
        '--input=+[file]:file:_files' \
        '-S+[size]:n:' \
        '--size=+[size]:n:' \
        '-p+[hex bytes pattern]:str:' \
        '--pattern=+[hex bytes pattern]:str:' \
        '-i[loop]' \
        '--iter=+[N]:n:' \
        '-r+[N]:n:'
}

_spi-test "$@"
