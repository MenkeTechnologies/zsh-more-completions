#compdef syz-fmt
# _syz-fmt — format syzkaller syscall description files (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-fmt/syz-fmt.go (flag).

_syz-fmt() {
    _arguments \
        '-dry-run[only check formatting, do not patch]' \
        '*:file or dir:_files'
}

_syz-fmt "$@"
