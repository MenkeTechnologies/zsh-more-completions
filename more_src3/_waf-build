#compdef waf-build waf2
# _waf-build — Thomas Nagy waf-build CLI command-line frontend wrapping the Waf the meta build system Python-based framework that helps to configure compile and install applications open-source written in Python originally Thomas Nagy Samba waf-style build system used by Samba KDE Inkscape GLib MozillaB2G Bzr originally born from the bksys project a Scons port for KDE Bksys waf-1.5+ python script wrapping for source builds configure build install uninstall clean distclean dist update list step msvc shutdown environment Logs Options Configure Build Errors Context dict_table fileutils gccdeps glib mongodb (Thomas Nagy team Samba Project, Python); custom argparse
# upstream: https://waf.io/

_waf-build() {
    local -a sub=(
        'configure:configure project'
        'build:build project'
        'install:install built'
        'uninstall:uninstall built'
        'clean:clean build dir'
        'distclean:remove build dir and config'
        'dist:create source tarball'
        'distcheck:check source tarball'
        'list:list build targets'
        'step:execute build step'
        'update:update tool'
        'shutdown:shutdown daemon'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[N]:n:' \
        '-k+[keep going]:n:' \
        '--keep=+[N]:n:' \
        '-p[show progress bar]' \
        '--progress[show progress bar]' \
        '-z[ignore signature changes]' \
        '--zones=+[name]:str:' \
        '--top=+[dir]:dir:_files -/' \
        '--out=+[dir]:dir:_files -/' \
        '--no-lock-in-run[no lock in run]' \
        '--no-lock-in-out[no lock in out]' \
        '--no-lock-in-top[no lock in top]' \
        '--targets=+[names]:str:' \
        '*--targets=+[name]:str:' \
        '--prefix=+[dir]:dir:_files -/' \
        '--destdir=+[dir]:dir:_files -/' \
        '--bindir=+[dir]:dir:_files -/' \
        '--libdir=+[dir]:dir:_files -/' \
        '--check-c-compiler=+[name]:str:' \
        '--check-cxx-compiler=+[name]:str:' \
        '--cflags=+[flags]:str:' \
        '--cxxflags=+[flags]:str:' \
        '--linkflags=+[flags]:str:' \
        '--libdirs=+[dirs]:str:' \
        '--includedirs=+[dirs]:str:' \
        '--force[force]' \
        '-f[force]' \
        '--nocache[no cache]' \
        '--notests[no tests]' \
        '--alltests[all tests]' \
        '--testcmd=+[cmd]:str:' \
        '--clear-failed[clear failed tests]' \
        '--exitcode=+[N]:n:' \
        '--zones-only[zones only]' \
        '-o+[out]:dir:_files -/' \
        '--diff[show diff]' \
        '--files=+[files]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'waf subcommand' sub ;;
        args)
            case $words[1] in
                step) _arguments '*:target:' ;;
                update) _arguments '*:tool:' ;;
            esac
            ;;
    esac
}

_waf-build "$@"
