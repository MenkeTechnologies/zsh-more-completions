#compdef session-desktop
# Documentation: https://github.com/oxen-io/session-desktop
# Reference accessed: 2026-05-21
# Verified: Session-Desktop main_node.ts on GitHub uses the same tray-flag
# pair as Signal-Desktop (forked from it). Electron app with standard
# Chromium flags otherwise.

# session-desktop: Session decentralized messenger desktop client (Electron)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--start-in-tray[launch minimized to system tray]' \
  '--use-tray-icon[show tray icon and hide on close]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--enable-features=[Chromium feature flags]:features:' \
  '--disable-features=[disable Chromium features]:features:' && ret=0
return ret
