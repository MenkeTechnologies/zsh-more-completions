#compdef kube-dns-sidecar
# _kube-dns-sidecar — kube-dns dnsmasq health/metrics sidecar (probes dnsmasq, exports Prometheus stats)
# upstream: https://github.com/kubernetes/dns
# Flags from cmd/sidecar/main.go on tip.

_kube-dns-sidecar() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--dnsmasq-addr=[address dnsmasq is listening on]:addr:' \
        '--dnsmasq-port=[port dnsmasq is listening on]:port:' \
        '--dnsmasq-poll-interval-ms=[interval to poll dnsmasq for stats (ms)]:ms:' \
        '*--probe=[probe definition: <label>,<server>,<dns name>[,<interval_s>][,<type>]]:spec:' \
        '--prometheus-addr=[Prometheus metrics bind address]:addr:' \
        '--prometheus-port=[Prometheus metrics port]:port:' \
        '--prometheus-path=[Prometheus metrics path]:path:' \
        '--prometheus-namespace=[Prometheus metric namespace]:ns:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_kube-dns-sidecar "$@"
