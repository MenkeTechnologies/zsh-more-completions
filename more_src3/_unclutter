#compdef unclutter
# _unclutter — unclutter X mouse-cursor hider; hides pointer after a configurable idle period
# upstream: https://github.com/Airblader/unclutter-xfixes

_unclutter() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-display+[X display]:display:' \
        '-idle+[idle seconds before hide]:n:' \
        '-keystroke[hide on keystroke too]' \
        '-jitter+[jitter px]:n:' \
        '-grab[use grab]' \
        '-noevents[do not use events]' \
        '-onescreen[only act on initial screen]' \
        '-reset[unhide cursor at start]' \
        '-root[apply to root window]' \
        '-fork[fork to background]' \
        '-not+[skip these window names]:names:' \
        '-visible[show cursor when visible cursor changes]' \
        '-timeout+[timeout]:n:'
}

_unclutter "$@"
