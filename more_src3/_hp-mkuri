#compdef hp-mkuri hp-makeuri
# Documentation: https://manpages.debian.org/bookworm/hplip/hp-makeuri.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm hp-makeuri(1) manpage. NOTE: there is no
# `hp-mkuri` binary upstream; this completion file targets the real
# `hp-makeuri` and accepts the misspelling via #compdef alias for
# backwards compatibility.
# Removed from prior file: fabricated -V/--version flag and bogus
# man.archlinux.org search URL.

# hp-makeuri: construct HPLIP device URI for a bus address
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-p --port)'{-p+,--port=}'[device port]:port:(1 2 3)' \
  '(-c --cups)'{-c,--cups}'[CUPS-compatible URI]' \
  '(-s --sane)'{-s,--sane}'[SANE-compatible URI]' \
  '(-f --fax)'{-f,--fax}'[fax URI]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '*:bus address:' && ret=0
return ret
