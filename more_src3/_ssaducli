#compdef ssaducli
# Documentation: https://techlibrary.hpe.com/docs/iss/shared/troubleshoot/233197.htm
# Reference accessed: 2026-05-21
# Verified: HPE Smart Storage Administrator Diagnostic Utility CLI reports.
# Removed fabricated controller/array/ld/pd/enclosure/show/add/create/delete
# verb structure that was copy-pasted from ssacli — ssaducli is a different
# tool that generates diagnostic report zip archives.

# ssaducli: HPE Smart Storage Administrator Diagnostic CLI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-h[show help]' \
  '-f+[output report archive filename]:file:_files -g "*.zip"' \
  '-ssd[generate SmartSSD wear gauge report]' \
  '*::ssaducli args:_files' && ret=0
return ret
