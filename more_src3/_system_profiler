#compdef system_profiler
# Documentation: https://www.unix.com/man-page/osx/8/system_profiler/
# Source: Apple macOS — System Information report CLI (System Profiler.app backend).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a datatypes=(
    SPSoftwareDataType SPHardwareDataType SPApplicationsDataType SPAudioDataType
    SPBluetoothDataType SPCameraDataType SPCardReaderDataType SPDeveloperToolsDataType
    SPDiagnosticsDataType SPDisabledSoftwareDataType SPDiscBurningDataType SPEthernetDataType
    SPExtensionsDataType SPFibreChannelDataType SPFireWireDataType SPFirewallDataType
    SPFontsDataType SPFrameworksDataType SPDisplaysDataType SPHardwareRAIDDataType
    SPInstallHistoryDataType SPInternationalDataType SPLegacySoftwareDataType SPNetworkLocationDataType
    SPLogsDataType SPManagedClientDataType SPMemoryDataType SPNVMeDataType
    SPNetworkDataType SPNetworkVolumeDataType SPParallelATADataType SPParallelSCSIDataType
    SPPowerDataType SPPrefPaneDataType SPPrintersSoftwareDataType SPPrintersDataType
    SPConfigurationProfileDataType SPRawCameraDataType SPSASDataType SPSerialATADataType
    SPSPIDataType SPSmartCardsDataType SPStartupItemDataType SPStorageDataType
    SPThunderboltDataType SPUSBDataType SPNetworkVolumeDataType SPSyncServicesDataType
    SPUniversalAccessDataType SPVoiceRecognitionDataType SPWWANDataType SPAirPortDataType
)

_arguments -s \
    '(- *)-usage[print usage and examples]' \
    '(- *)-listDataTypes[list available data types]' \
    '-xml[generate report in XML format]' \
    '-json[generate report in JSON format]' \
    '-detailLevel[report detail level]:level:(mini basic full)' \
    '-timeout[max time (seconds) to wait for results]:seconds:' \
    "*:data type:($datatypes)" \
    && ret=0

return ret
