#compdef virt-resize
# _virt-resize — libguestfs virt-resize (resize a libvirt VM disk image by laying out partitions/LVs on a larger destination; --resize old=new, --expand part, --shrink part, --LV-expand vg/lv, --output-format raw|qcow2, --output-format, --no-extra-partition, --machine-readable; positional source then destination)
# upstream: https://github.com/libguestfs/libguestfs (resize)
# Flags from libguestfs resize/resize.ml on tip.

_virt-resize() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '-d[debug]' \
        '*--resize+[old=new]:old=new:' \
        '*--resize-force+[old=new]:old=new:' \
        '*--expand+[partition or LV]:part:' \
        '*--LV-expand+[VG/LV]:lv:' \
        '*--shrink+[partition]:part:' \
        '*--delete+[partition]:part:' \
        '*--ignore+[partition]:part:' \
        '--output-format=*[output format]:fmt:(raw qcow2 vmdk vdi)' \
        '--align-first=*[align mode]:mode:(never always auto)' \
        '--no-extra-partition[no extra partition for unallocated]' \
        '--no-expand-content[do not expand FS content]' \
        '--ntfsresize-force[force ntfsresize]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--machine-readable[machine-readable output]' \
        '1:source disk:_files' \
        '2:destination disk:_files'
}

_virt-resize "$@"
