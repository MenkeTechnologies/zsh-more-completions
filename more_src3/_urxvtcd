#compdef urxvtcd
# Documentation: https://man.archlinux.org/man/urxvt.1
# Reference accessed: 2026-05-21
# Verified: urxvtcd shares urxvt(1)/urxvtc(1) options; manpage at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-help[show help]' \
  '-display+[X display]:display:' \
  '-geometry+[window geometry WxH+X+Y]:geom:' \
  '-fn+[primary font]:font:' \
  '-fb+[bold font]:font:' \
  '-fi+[italic font]:font:' \
  '-fbi+[bold italic font]:font:' \
  '-cd+[startup working directory]:dir:_files -/' \
  '-name+[application name]:name:' \
  '-title+[window title]:title:' \
  '-T+[window title]:title:' \
  '-n+[icon name]:name:' \
  '-tn+[$TERM value]:term:' \
  '-e[command to execute after options]' \
  '-bg+[background color]:color:' \
  '-fg+[foreground color]:color:' \
  '-cr+[cursor color]:color:' \
  '-pr+[pointer color]:color:' \
  '-bd+[border color]:color:' \
  '-tr[transparency]' \
  '-tint+[tint color]:color:' \
  '-sh+[tint shading]:percent:' \
  '-fade+[unfocused fade percent]:percent:' \
  '-fc+[fade color]:color:' \
  '-cm+[color modifier intensity/saturation/hue]:mod:' \
  '-pixmap+[background pixmap]:file:_files' \
  '-bl[borderless]' \
  '-ov[override-redirect]' \
  '-hold[hold window after child exits]' \
  '-ip[scroll with new lines]' \
  '-keysym.*+[key binding]:binding:' \
  '-pe+[Perl extensions]:exts:' \
  '-sb[show scrollbar]' \
  '-sr[scrollbar right]' \
  '-sl+[scrollback lines]:lines:' \
  '-si[scroll on input]' \
  '-sk[scroll on keypress]' \
  '-sw[scroll with secondary screen]' \
  '-ss[secondary screen scroll]' \
  '-vb[visual bell]' \
  '-iconic[start iconified]' \
  '*::cmd:_command_names' && ret=0

return ret
