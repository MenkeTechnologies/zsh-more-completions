#compdef holepunch hyperdht-cli holepunch-cli
# _holepunch — Hyperswarm Holepunch CLI for managing the Hyperswarm Distributed Hash Table peer-to-peer networking platform via Hyperswarm RPC NAT-traversal and DHT-based key-value storage (holepunchto team, JavaScript); commander.js
# upstream: https://github.com/holepunchto/hyperswarm

_holepunch() {
    local -a sub=(
        'init:initialize new app'
        'start:start app'
        'stage:stage release'
        'release:publish release'
        'seed:seed network'
        'sidecar:run sidecar'
        'shutdown:shutdown sidecar'
        'list:list local apps'
        'pin:pin app'
        'unpin:unpin app'
        'info:show app info'
        'doctor:run diagnostics'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--store=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'holepunch subcommand' sub ;;
        args)
            case $words[1] in
                stage|release) _arguments \
                    '--channel=+[channel]:c:(stable beta dev)' \
                    '--dry-run[dry run]' \
                    '--ignore=+[csv]:str:' \
                    '*:app dir:_files -/' ;;
                seed) _arguments \
                    '--persist[persist]' \
                    '--seeders=+[N]:n:' \
                    '*:key or app dir:' ;;
            esac
            ;;
    esac
}

_holepunch "$@"
