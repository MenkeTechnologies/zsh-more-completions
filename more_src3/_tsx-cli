#compdef tsx-cli
# _tsx-cli — Hiroki Osame tsx Node enhanced with esbuild for TypeScript CLI alias (privatenumber team, TypeScript); custom argparse
# upstream: https://github.com/privatenumber/tsx

_tsx-cli() {
    local -a sub=(
        'watch:start watching script for changes'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--tsconfig=+[tsconfig]:file:_files -g "tsconfig*.json"' \
        '--no-cache[disable cache]' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tsx subcommand' sub ;;
        args)
            case $words[1] in
                watch) _arguments \
                    '--ignore=+[pattern]:str:' \
                    '--clear-screen[clear screen]' \
                    '--no-clear-screen[no clear screen]' \
                    '--include=+[pattern]:str:' \
                    '*:script args:_files' ;;
            esac
            ;;
    esac
}

_tsx-cli "$@"
