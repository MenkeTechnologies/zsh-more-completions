#compdef syz-benchcmp
# _syz-benchcmp — compare syzkaller fuzzing bench files (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-benchcmp/benchcmp.go (flag).

_syz-benchcmp() {
    _arguments \
        '-all[draw graphs for all variables]' \
        '-out=[save graph to file instead of browser]:file:_files' \
        '-over=[X-axis variable]:var:(fuzzing exec_total cover signal)' \
        '-skip=[seconds to skip after start]:s:' \
        '*:bench file:_files'
}

_syz-benchcmp "$@"
