#compdef kubectl-apidocs
# Documentation: https://github.com/hashmap-kz/kubectl-apidocs/blob/master/cmd/cmd.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-apidocs launches an interactive tree view of API resources.
# It only registers the standard kubectl genericclioptions ConfigFlags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--user=[kubeconfig user name]:user:' \
  '--as=[username to impersonate]:user:' \
  '*--as-group=[group to impersonate]:group:' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--client-certificate=[path to a client certificate file]:file:_files' \
  '--client-key=[path to a client key file]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS certificate validity check]' \
  '--request-timeout=[length of time to wait before giving up on a request]:duration:' \
  '*:args:_default'
