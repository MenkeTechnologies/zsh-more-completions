#compdef varnishd
# Documentation: https://manpages.debian.org/testing/varnish/varnishd.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-V[display version]' \
  '(- *)-x+[dump documentation]:format:(parameter vsl cli builtin optstring)' \
  '-a+[listen address and port]:listen address\:port:' \
  '-b+[backend server]:host\:port:' \
  '-C[print compiled VCL and exit]' \
  '-d[debug mode]' \
  '-F[run in foreground]' \
  '-f+[VCL configuration file]:VCL file:_files' \
  '-h+[hash algorithm]:algorithm:(critbit simple_list classic)' \
  '-I+[CLI commands file (executed before worker starts)]:CLI file:_files' \
  '-i+[server identity for syslog and CLI banner]:identity:' \
  '-j+[jailing mechanism]:jail type:(unix linux solaris none)' \
  '-l+[VSL records space size]:size:' \
  '-M+[reverse CLI address (connect to management port)]:address\:port:' \
  '-n+[runtime/shared memory directory]:instance name:' \
  '-P+[PID file]:PID file:_files' \
  '-p+[set runtime parameter]:parameter=value:' \
  '-r+[set read-only parameters]:parameters:' \
  '-S+[secret file for CLI authentication]:secret file:_files' \
  '-s+[storage backend]:storage type:(default malloc umem file persistent)' \
  '-T+[management interface listen address]:address\:port:' \
  '-t+[default TTL for cached objects]:seconds:' \
  '-W+[waiter type]:waiter:(poll epoll kqueue ports)' && ret=0

return ret
