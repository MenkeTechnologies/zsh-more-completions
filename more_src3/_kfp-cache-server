#compdef kfp-cache-server cache-server
# _kfp-cache-server — Kubeflow Pipelines cache server / mutating webhook (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/cache/main.go on tip.

_kfp-cache-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--db_driver=[database driver]:driver:(mysql)' \
        '--db_host=[database host]:host:_hosts' \
        '--db_port=[database port]:port:' \
        '--db_name=[database name]:name:' \
        '--db_user=[database user]:user:' \
        '--db_password=[database password]:secret:' \
        '--db_group_concat_max_len=[MySQL group_concat_max_len]:n:' \
        '--db_extra_params=[extra DB connection parameters (k=v\&k=v)]:params:' \
        '--namespace_to_watch=[watched namespace]:ns:' \
        '--kube_client_qps=[Kubernetes client QPS]:f:' \
        '--kube_client_burst=[Kubernetes client burst]:n:' \
        '--tls_cert_filename=[webhook TLS cert filename]:name:' \
        '--tls_key_filename=[webhook TLS key filename]:name:' \
        '--listen_port=[webhook bind port]:port:'
}

_kfp-cache-server "$@"
