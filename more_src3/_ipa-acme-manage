#compdef ipa-acme-manage
# Documentation: https://www.mankier.com/1/ipa-acme-manage
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '1:command:(enable disable status pruning prune-config)' \
  '*:arg:' && ret=0

return ret
