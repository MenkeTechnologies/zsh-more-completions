#compdef kamctl
# Documentation: https://www.kamailio.org/docs/tools/sr-tools.html
# Source: kamailio/kamailio utils/kamctl/kamctl — Kamailio control shell script (subcommand dispatcher).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '1:subcommand:(start stop restart status monitor console online ping ps psa uptime stats srv
        add show passwd rm sets setn acl alias ul usrloc alias_db avp db domain uid_domain trusted
        address mtree rpc rpcprint lcr cr dispatcher dialog dialplan rpid speeddial acc tls
        trap pstrap)' \
    '*::args:_files' \
    && ret=0

return ret
