#compdef kubectl-ctx-tags
# Documentation: https://github.com/tgigli/kubectl-ctx-tags
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-ctx-tags (tgigli): organize kubectl contexts with tags. With no
# subcommand it launches an interactive TUI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:_default' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'add:add tags to a context'
      'remove:remove tags from a context'
      'list:list all contexts with their tags'
      'tags:list all unique tags'
    )
    _describe -t commands 'kubectl-ctx-tags command' cmds && ret=0
    ;;
esac

return ret
