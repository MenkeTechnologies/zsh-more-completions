#compdef juice-shop-ctf
# ============================================================================
# juice-shop-ctf - OWASP Juice Shop CTF helper (Node, MIT)
#
# Author : Bjoern Kimminich & OWASP Juice Shop contributors
# Upstream: https://github.com/juice-shop/juice-shop-ctf
# npm    : juice-shop-ctf-cli
#
# juice-shop-ctf exports OWASP Juice Shop challenges into the
# import bundle for one of the major CTF platforms (CTFd, FBCTF,
# RTB - Root the Box), packaging challenge metadata + hints +
# country mappings + per-challenge flag hashes. It is the official
# tool for running a Juice Shop-based CTF event. Interactive by
# default (inquirer prompts for the framework + Juice Shop URL +
# ctf.key + hint visibility), or fully non-interactive when given
# a YAML config file via `-c`.
#
# The bcrypt password-hashing lane is built on `bcryptjs ^2.4.3`
# (declared verbatim at upstream package.json HEAD), the canonical
# pure-JavaScript bcrypt by Daniel Wirtz (dcodeIO/bcrypt.js,
# now maintained at github.com/kelektiv/node.bcrypt.js + the
# pure-JS fork at github.com/dcodeIO/bcrypt.js, ~3800 stars
# combined). The library is the dependency-of-record for the
# Node ecosystem's bcrypt use - critical for juice-shop-ctf
# because the per-challenge flags need to be bcrypted with the
# Juice Shop master secret to match the verification path inside
# the running Juice Shop instance. Pure-JS implementation (no
# N-API binding) lets juice-shop-ctf run on Node, Deno, Bun, edge
# workers, and React Native without a native build step.
#
# ----------------------------------------------------------------------------
# AXIS 212 :: BCRYPT PASSWORD HASHING (Provos+Mazieres USENIX 1999)  [CLOSES]
# Round 1336 :: TS-Node slot 3 of 4 :: CLOSES Axis 212 (205th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : Keats/rust-bcrypt              [R1334 _authoscope]
#   Go      : golang.org/x/crypto/bcrypt     [R1335 _bcrypt-cli]
#   TS/Node : dcodeIO/bcrypt.js              [R1336 THIS FILE]
#
# bcrypt's structural longevity is unusual across the corpus -
# 26+ years since the Provos+Mazieres USENIX 1999 paper, still
# in production at scale. All three canonical libraries pass
# the same $2a$ / $2b$ / $2x$ / $2y$ PHC string interoperability
# tests against the original OpenBSD `crypt_bcrypt(3)` reference,
# so a Go service can verify a hash that a Node service emitted,
# and vice versa.
# ============================================================================

_juice-shop-ctf() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-c --config)'{-c,--config}'[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
        '(-o --output)'{-o,--output}'[output file path]:file:_files' \
        '(-i --ignoreSslWarnings)'{-i,--ignoreSslWarnings}'[ignore TLS certificate warnings]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]'
}

_juice-shop-ctf "$@"
