#compdef zfs-unload-key
# _zfs-unload-key — OpenZFS zfs unload-key (drop a wrapping key from kernel memory making encrypted children inaccessible until reloaded; -r recursive, -a all loaded encryption roots; positional argument is the dataset)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zfs/zfs_main.c (zfs_do_unload_key) on tip.

_zfs-unload-key() {
    _arguments \
        '-r[recursive]' \
        '-a[all loaded keys]' \
        '*:dataset:'
}

_zfs-unload-key "$@"
