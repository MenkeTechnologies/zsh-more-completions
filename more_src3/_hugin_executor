#compdef hugin_executor
# Documentation: https://hugin.sourceforge.io/docs/manual/Hugin_executor.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--assistant[run assistant on the command line]' \
  '--stitching[enable command line stitching]' \
  '--dry-run[print commands without executing them]' \
  '--threads=[number of processor threads]:n:' \
  '--user-defined-output=[user-defined executor file]:script:_files' \
  '--prefix=[output prefix for stitched files]:prefix:' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
