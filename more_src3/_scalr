#compdef scalr
# Documentation: https://github.com/Scalr/scalr-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (README.md).

# Scalr CLI completion. The Scalr CLI uses single-dash global flags
# (-help, -configure, -update, etc.) and a flat list of kebab-case
# subcommands (create-workspace, get-runs, etc.).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a subcmds=(
  'create-access-policy:create access policy'
  'delete-access-policy:delete access policy'
  'get-access-policies:list access policies'
  'get-access-policy:get access policy'
  'update-access-policy:update access policy'
  'create-access-token:create access token'
  'delete-access-token:delete access token'
  'get-access-token:get access token'
  'update-access-token:update access token'
  'create-agent-pool-token:create agent pool token'
  'list-agent-pool-access-tokens:list agent pool tokens'
  'get-account:get account'
  'update-account:update account'
  'create-agent-pool:create agent pool'
  'delete-agent-pool:delete agent pool'
  'get-agent-pool:get agent pool'
  'get-agent-pools:list agent pools'
  'update-agent-pool:update agent pool'
  'delete-agent:delete agent'
  'get-agent:get agent'
  'get-agents:list agents'
  'get-apply:get apply'
  'get-apply-log:get apply log'
  'create-configuration-version:create configuration version'
  'download-configuration-version:download configuration version'
  'get-configuration-version:get configuration version'
  'get-configuration-versions:list configuration versions'
  'get-cost-estimate:get cost estimate'
  'get-cost-estimate-breakdown:get cost estimate breakdown'
  'get-cost-estimate-log:get cost estimate log'
  'create-endpoint:create endpoint'
  'delete-endpoint:delete endpoint'
  'get-endpoint:get endpoint'
  'list-endpoints:list endpoints'
  'update-endpoint:update endpoint'
  'create-environment:create environment'
  'delete-environment:delete environment'
  'get-environment:get environment'
  'list-environments:list environments'
  'update-environment:update environment'
  'list-event-definitions:list event definitions'
  'create-module:create module'
  'delete-module:delete module'
  'get-module:get module'
  'list-modules:list modules'
  'resync-module:resync module'
  'resync-module-version:resync module version'
  'get-module-version:get module version'
  'list-module-versions:list module versions'
  'get-permission:get permission'
  'get-permissions:list permissions'
  'ping:ping the Scalr API'
  'get-json-output:get plan JSON output'
  'get-plan:get plan'
  'get-plan-log:get plan log'
  'get-sanitized-json-output:get sanitized JSON output'
  'get-policy:get policy'
  'get-policy-check:get policy check'
  'get-policy-checks-log:get policy checks log'
  'list-policy-checks:list policy checks'
  'override-policy:override policy'
  'create-policy-group:create policy group'
  'delete-policy-group:delete policy group'
  'get-policy-group:get policy group'
  'list-policy-groups:list policy groups'
  'update-policy-group:update policy group'
  'create-provider-configuration:create provider configuration'
  'delete-provider-configuration:delete provider configuration'
  'get-provider-configuration:get provider configuration'
  'list-provider-configurations:list provider configurations'
  'update-provider-configuration:update provider configuration'
  'create-role:create role'
  'delete-role:delete role'
  'get-role:get role'
  'get-roles:list roles'
  'update-role:update role'
  'cancel-run:cancel run'
  'confirm-run:confirm run'
  'create-run:create run'
  'discard-run:discard run'
  'get-run:get run'
  'get-runs:list runs'
  'get-runs-queue:get runs queue'
  'create-service-account:create service account'
  'delete-service-account:delete service account'
  'get-service-account:get service account'
  'get-service-accounts:list service accounts'
  'update-service-account:update service account'
  'get-current-state-version:get current state version'
  'get-state-version:get state version'
  'get-state-version-download:download state version'
  'list-state-versions:list state versions'
  'create-tag:create tag'
  'delete-tag:delete tag'
  'get-tag:get tag'
  'list-tags:list tags'
  'update-tag:update tag'
  'create-team:create team'
  'delete-team:delete team'
  'get-team:get team'
  'get-teams:list teams'
  'update-team:update team'
  'create-user:create user'
  'delete-user:delete user'
  'get-user:get user'
  'get-users:list users'
  'update-user:update user'
  'create-variable:create variable'
  'delete-variable:delete variable'
  'get-variable:get variable'
  'get-variables:list variables'
  'update-variable:update variable'
  'create-vcs-provider:create VCS provider'
  'delete-vcs-provider:delete VCS provider'
  'get-vcs-provider:get VCS provider'
  'list-vcs-providers:list VCS providers'
  'update-vcs-provider:update VCS provider'
  'create-webhook:create webhook'
  'delete-webhook:delete webhook'
  'get-webhook:get webhook'
  'list-webhooks:list webhooks'
  'update-webhook:update webhook'
  'create-workspace:create workspace'
  'delete-workspace:delete workspace'
  'get-workspace:get workspace'
  'get-workspaces:list workspaces'
  'lock-workspace:lock workspace'
  'unlock-workspace:unlock workspace'
  'resync-workspace:resync workspace'
  'set-schedule:set workspace schedule'
)

_arguments -C \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-verbose[display full request/response details]' \
  '-configure[interactive configuration]' \
  '-update[upgrade to latest version]' \
  '-autocomplete[enable shell tab completion]' \
  '1:subcommand:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'scalr subcommand' subcmds && ret=0 ;;
esac

return ret
