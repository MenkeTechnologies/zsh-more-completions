#compdef kubectl-spy
# kubectl-spy (krew plugin): spy on Kubernetes pods by attaching an ephemeral debug container
# https://github.com/nickolaev/kubectl-spy

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--image=[debug container image]:image' \
  '--container=[target container name]:container' \
  '--shell=[shell to use]:shell:(bash sh zsh)' \
  '1:pod name'
