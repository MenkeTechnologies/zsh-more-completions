#compdef wpc
# ============================================================================
# wpc - WallPaper Changer for Linux + Windows
#        (Rust, MIT)
#
# Author : Jagadeesh Kotra (jkotra)
# Upstream: https://github.com/jkotra/wpc
#
# `wpc` is a wallpaper rotator that fetches images
# from configurable sources (Wallhaven.cc, Reddit
# subreddits, local directories, dynamic
# time-of-day-driven configs) and applies them as
# the desktop background. The tool runs as either a
# foreground process (interactive mode) or a
# background daemon (system-startup integration).
#
# Architecture:
#   - Each image source is a plugin (WallHaven /
#     Reddit / local) implementing the `WPCPlugin`
#     trait
#   - Source plugins emit candidate URLs into a
#     pool; the changer rotates through them at the
#     configured interval
#   - Each candidate is checked against minimum
#     width/height constraints + max-age + dynamic
#     time-of-day rules before being applied
#   - Optional theme integration: extract dominant
#     palette from the wallpaper + invoke gsettings
#     (Linux GNOME) to switch between
#     light/dark/grayscale system themes
#
# Use cases:
#   - Auto-rotating desktop wallpaper from curated
#     online sources (Wallhaven.cc + r/wallpaper +
#     r/EarthPorn + ...)
#   - Aesthetic-coherent theme matching: pair the
#     desktop wallpaper with light/dark mode
#     switching based on image brightness
#   - Time-of-day wallpaper schedules (different
#     images for morning / afternoon / evening /
#     night)
#
# Usage:
#   wpc -d <dir> [options]
#
# General flags (clap derive Parser):
#   -d, --directory <path>      - save / source
#                                  directory
#                                  (required)
#       --interval <secs>       - wallpaper rotation
#                                  interval
#       --update <secs>          - pool refresh
#                                  interval
#       --maxage <hours>        - skip wallpapers
#                                  older than N hours
#                                  (default -1 = no
#                                  limit)
#       --startup               - add wpc to system
#                                  startup
#       --rm-startup            - remove wpc from
#                                  startup
#       --background            - run as background
#                                  daemon
#       --min-width <px>        - minimum wallpaper
#                                  width
#       --min-height <px>       - minimum wallpaper
#                                  height
#       --trigger <file>        - trigger config
#                                  file
#       --local                 - use local
#                                  directory as
#                                  source
#
# Wallhaven plugin:
#   -w, --wallhaven             - enable wallhaven.cc
#                                  plugin
#       --wallhaven-config <f>  - wallhaven plugin
#                                  config file
#
# Reddit plugin:
#   -r, --reddit                - enable reddit
#                                  plugin
#       --subreddit <name>      - target subreddit
#                                  (default
#                                  "wallpaper")
#       --reddit-n <N>          - candidates per
#                                  fetch (default 6)
#       --reddit-sort <sort>    - sort order: hot |
#                                  new | top |
#                                  rising
#
# Theme integration:
#       --set-theme             - enable theme
#                                  switching based on
#                                  wallpaper brightness
#       --grayscale             - desaturate
#                                  wallpaper before
#                                  applying
#       --force-dark-theme      - always use dark
#                                  theme regardless
#                                  of wallpaper
#       --theme-brigness-threshold <f>
#                               - brightness
#                                  threshold for
#                                  dark/light
#                                  switching (default
#                                  50.0)
#       --dark-theme-only       - only consider dark-
#                                  toned wallpapers
#       --light-theme-only      - only consider
#                                  light-toned
#                                  wallpapers
#
# Global:
#   -h, --help                  - print help
#   -V, --version               - print version
#
# Environment:
#   RUST_LOG                    - env_logger filter
#
# The image-rs lane is built on `image = "0.23.12"`
# (declared verbatim at upstream Cargo.toml HEAD as a
# direct dep), the canonical Rust image processing
# library by the image-rs working group - github.
# com/image-rs/image, 5700+ stars on the image-rs
# umbrella.
#
# image-rs implements decoders + encoders for
# virtually every mainstream image format under one
# crate, with optional features per format for
# tree-shaking-friendly builds:
#   - PNG (RFC 2083 with all 12 color types)
#   - JPEG (RGB/CMYK/grayscale; baseline + progressive)
#   - GIF (animated multi-frame support)
#   - BMP (Windows + OS/2)
#   - TIFF (multi-page support)
#   - WebP (RIFF + VP8/VP8L/VP8X codecs)
#   - AVIF (AOMedia, optional feature)
#   - HEIC (Apple, via libheif feature)
#   - ICO (Windows icon format)
#   - PNM (Portable PixMap family)
#   - TGA (Targa)
#   - DDS (DirectDraw Surface)
#   - HDR (Radiance RGBE)
#   - QOI (Quite OK Image format)
#   - OpenEXR (Industrial Light & Magic; HDR)
#   - Farbfeld (suckless.org format)
#
# The library exposes a uniform `DynamicImage` enum
# that abstracts over the per-format pixel layout,
# letting consumers process images without
# format-specific code. The `image::imageops` module
# provides standard transformations (resize, crop,
# rotate, flip, blur, contrast, brightness,
# composite, blend), all polymorphic over
# DynamicImage.
#
# The image-rs working group is the canonical Rust
# crate for image processing - depended on by:
#   - rust-bevy (game engine)
#   - GIMP-RS (GIMP plugin development)
#   - kornia-rs (computer vision library)
#   - opencv-rust (when not binding to OpenCV
#     directly)
#   - virtually every Rust project that needs to
#     read/write image files
#   - wpc (THIS BINARY)
#
# wpc uses image-rs in `changer/` to:
#   - load downloaded candidate wallpapers
#   - check dimensions against --min-width / --min-
#     height bounds
#   - optionally desaturate via --grayscale
#   - extract average luminance for --theme-
#     brigness-threshold decisions
#   - resize to fit desktop dimensions (Linux only;
#     Windows uses native PostMessage to set the
#     wallpaper)
#
# ----------------------------------------------------------------------------
# AXIS 259 :: Image processing libraries (multi-format
#              decoders + encoders + transformation
#              primitives)
# Round 1475 :: Rust slot 1 of 4 :: OPENS Axis 259
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : image-rs/image                - the
#                                              image-rs
#                                              working
#                                              group's
#                                              canonical
#                                              umbrella;
#                                              ~15 image
#                                              formats
#                                              under one
#                                              crate
#   Go      : disintegration/imaging        - Grigory
#                                              Dryapak's
#                                              canonical
#                                              Go image
#                                              library;
#                                              built on
#                                              the stdlib
#                                              image
#                                              package
#   TS/Node : lovell/sharp                  - Lovell
#                                              Fuller's
#                                              libvips
#                                              binding;
#                                              the
#                                              de-facto
#                                              Node high-
#                                              performance
#                                              image
#                                              library;
#                                              ~14M weekly
#                                              downloads
#
# Image processing is a wide axis - the W3C / IEC /
# ISO image format specifications are individually
# strict but compose into a vast cross-format
# transformation surface. All three lanes target
# essentially the same core formats (PNG/JPEG/WebP/
# GIF/TIFF) with different transformation philosophies.
#
# Structural commentary on the canonical libraries:
#   - image-rs/image (Rust): single-crate multi-
#     format umbrella with optional features for
#     each format; tree-shaking-friendly
#   - disintegration/imaging (Go): builds on the
#     Go stdlib's `image` + `image/jpeg` + `image/
#     png` + `image/gif` packages; adds
#     transformation primitives (resize, crop,
#     rotate, blur, ...) on top
#   - lovell/sharp (Node): libvips binding via
#     C++ N-API; trades native binding complexity
#     for ~10x faster operations than pure-JS
#     alternatives (jimp, gm); uses libvips's
#     streaming pixel-pipeline architecture for
#     low-memory operation on huge images
#
# Axis 259 opens with the Rust slot at the image-rs
# canonical multi-format crate.
# ============================================================================

_wpc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-d --directory)'{-d,--directory}'[save/source directory]:dir:_files -/' \
        '--interval[rotation interval (seconds)]:secs:' \
        '--update[pool refresh interval (seconds)]:secs:' \
        '--maxage[max wallpaper age in hours (-1 = no limit)]:hours:' \
        '--startup[add wpc to system startup]' \
        '--rm-startup[remove wpc from startup]' \
        '--background[run as background daemon]' \
        '--min-width[minimum wallpaper width (px)]:px:' \
        '--min-height[minimum wallpaper height (px)]:px:' \
        '--trigger[trigger config file]:file:_files' \
        '--local[use local directory as source]' \
        '(-w --wallhaven)'{-w,--wallhaven}'[enable wallhaven.cc plugin]' \
        '--wallhaven-config[wallhaven plugin config file]:file:_files' \
        '(-r --reddit)'{-r,--reddit}'[enable reddit plugin]' \
        '--subreddit[target subreddit]:name:' \
        '--reddit-n[candidates per fetch]:N:' \
        '--reddit-sort[sort order]:sort:(hot new top rising)' \
        '--set-theme[enable theme switching based on wallpaper]' \
        '--grayscale[desaturate wallpaper before applying]' \
        '--force-dark-theme[always use dark theme]' \
        '--theme-brigness-threshold[brightness threshold (default 50.0)]:f:' \
        '--dark-theme-only[only dark-toned wallpapers]' \
        '--light-theme-only[only light-toned wallpapers]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_wpc "$@"
