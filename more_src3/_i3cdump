#compdef i3cdump
# _i3cdump — i3c-tools i3cdump CLI memory dumper hex-dumping the address-space of an I3C device on a Linux /dev/i3c-* character device with byte word block range bank-select modes printing per-row offset and ASCII for bulk EEPROM-style or register-bank inspection (Boris Brezillon team, C); getopt
# upstream: https://github.com/i3c-tools/i3c-tools

_i3cdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-y[non-interactive]' \
        '-v[verbose]' \
        '-m+[mode]:m:(b w l s i I3C_PRIV_XFER)' \
        '-r+[range first-last]:str:' \
        '-f[force]' \
        '1:i3c-bus:_files -g "/dev/i3c-*"' \
        '2:address:' \
        '3:mode:'
}

_i3cdump "$@"
