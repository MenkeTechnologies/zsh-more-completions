#compdef ls-cli
# _ls-cli — GNU coreutils ls list directory contents CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_ls-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[show all]' \
        '--all[show all]' \
        '-A[show all except . and ..]' \
        '--almost-all[show all except . and ..]' \
        '--author[show author]' \
        '-b[escape non-printing chars]' \
        '--escape[escape non-printing chars]' \
        '--block-size=+[size]:str:' \
        '-B[ignore backup files]' \
        '--ignore-backups[ignore backup files]' \
        '-c[sort by ctime]' \
        '-C[list entries by columns]' \
        '--color=+[when]:w:(always never auto)' \
        '-d[list directories themselves]' \
        '--directory[list directories themselves]' \
        '-D[Emacs dired mode]' \
        '--dired[Emacs dired mode]' \
        '-f[no sort]' \
        '-F[append indicator]' \
        '--classify[append indicator]' \
        '--file-type[append indicator no *]' \
        '--format=+[format]:f:(across commas horizontal long single-column verbose vertical)' \
        '--full-time[long with full time]' \
        '-g[long without owner]' \
        '--group-directories-first[group dirs first]' \
        '-G[no group]' \
        '--no-group[no group]' \
        '-h[human readable]' \
        '--human-readable[human readable]' \
        '--si[powers of 1000]' \
        '-H[follow command line symlinks]' \
        '--dereference-command-line[follow command line symlinks]' \
        '--dereference-command-line-symlink-to-dir[follow command line symlinks to dirs]' \
        '--hide=+[pattern]:str:' \
        '--hyperlink=+[when]:w:(always never auto)' \
        '--indicator-style=+[style]:s:(none slash file-type classify)' \
        '-i[print inode]' \
        '--inode[print inode]' \
        '-I+[pattern]:str:' \
        '--ignore=+[pattern]:str:' \
        '-k[block size 1k]' \
        '--kibibytes[block size 1k]' \
        '-l[long listing]' \
        '-L[follow symlinks]' \
        '--dereference[follow symlinks]' \
        '-m[comma list]' \
        '-n[numeric uid/gid]' \
        '--numeric-uid-gid[numeric uid/gid]' \
        '-N[print raw entry names]' \
        '--literal[print raw entry names]' \
        '-o[long without group]' \
        '-p[append / to dirs]' \
        '--indicator-style=slash' \
        '-q[print ? for non-graphic chars]' \
        '--hide-control-chars[print ? for non-graphic chars]' \
        '--show-control-chars[show control chars]' \
        '-Q[quote names]' \
        '--quote-name[quote names]' \
        '--quoting-style=+[style]:s:(literal locale shell shell-always shell-escape shell-escape-always c c-maybe escape)' \
        '-r[reverse order]' \
        '--reverse[reverse order]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-s[size]' \
        '--size[size]' \
        '-S[sort by size]' \
        '--sort=+[key]:k:(none size time version extension)' \
        '--time=+[mode]:m:(atime access use ctime status birth)' \
        '--time-style=+[style]:str:' \
        '-t[sort by mtime]' \
        '-T+[tabsize]:n:' \
        '--tabsize=+[tabsize]:n:' \
        '-u[sort by atime]' \
        '-U[no sort]' \
        '-v[sort by version]' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-x[list entries by lines]' \
        '-X[sort by extension]' \
        '-Z[print security context]' \
        '--context[print security context]' \
        '-1[one per line]' \
        '*:files:_files'
}

_ls-cli "$@"
