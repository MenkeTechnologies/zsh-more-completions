#compdef create-solid solid-create
# _solid-create — SolidStart scaffolder (Ryan Carniato + SolidJS team); creates a SolidStart fine-grained reactive web app
# upstream: https://github.com/solidjs/solid-start

_solid-create() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--template+[starter template]:template:(basic todomvc with-mdx with-tailwindcss with-vitest with-prisma with-auth with-trpc bare experiments hackernews movies notes uploads with-websocket)' \
        '--ts[force TypeScript]' \
        '--js[force JavaScript]' \
        '--git[init git]' \
        '--no-git[skip git init]' \
        '--install[install deps]' \
        '--no-install[skip install]' \
        '--package-manager+[pkg manager]:pm:(npm yarn pnpm bun)' \
        '*:dir:_files -/'
}

_solid-create "$@"
