#compdef ypcat
# _ypcat — OpenBSD ypcat (dump all key/value pairs from a YP map (or nickname); -k prefixes the key, -t skips nickname translation, -x lists nicknames)
# upstream: https://github.com/openbsd/src (usr.bin/ypcat)
# Flags from usr.bin/ypcat/ypcat.1 on tip.

_ypcat() {
    _arguments \
        '-k[display map keys]' \
        '-t[skip nickname translation]' \
        '-d+[domain]:domain:' \
        '-x[list nickname translations]' \
        '1:mapname:(passwd group hosts services networks protocols rpc netgroup aliases)'
}

_ypcat "$@"
