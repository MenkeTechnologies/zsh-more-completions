#compdef knative-mqttsource
# _knative-mqttsource — Knative Eventing reference MQTT CloudEvent source
# upstream: https://github.com/knative/eventing
# Flags from cmd/mqttsource/main.go on tip.

_knative-mqttsource() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--sink=[destination URL to send events to]:url:_urls' \
        '--source=[MQTT broker URL to subscribe to]:url:_urls' \
        '--eventSource=[CloudEvents source attribute]:uri:' \
        '--topic=[MQTT topic to subscribe to]:topic:' \
        '--clientid=[MQTT client ID]:id:'
}

_knative-mqttsource "$@"
