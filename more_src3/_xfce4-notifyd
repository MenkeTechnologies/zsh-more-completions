#compdef xfce4-notifyd xfce4-notifyd-config
# Documentation: https://github.com/xfce-mirror/xfce4-notifyd/blob/master/xfce4-notifyd/main.c
#                https://github.com/xfce-mirror/xfce4-notifyd/blob/master/xfce4-notifyd-config/main.c
# Reference accessed: 2026-05-21
# Verified: xfce4-notifyd main.c only handles --version/-V; xfce4-notifyd-config
# main.c GOptionEntry table has --version/-V and --socket-id/-s.

local curcontext="$curcontext" ret=1

case $service in
  (xfce4-notifyd)
    _arguments -C \
      '(- *)'{-V,--version}'[display version information]' \
      '(- *)'{-h,--help}'[show help]' \
      '--display=[X display]:display:' && ret=0 ;;
  (xfce4-notifyd-config)
    _arguments -C \
      '(- *)'{-V,--version}'[display version information]' \
      '(- *)'{-h,--help}'[show help]' \
      '(-s --socket-id)'{-s+,--socket-id=}'[settings manager socket]:socket_id:' \
      '--display=[X display]:display:' && ret=0 ;;
esac

return ret
