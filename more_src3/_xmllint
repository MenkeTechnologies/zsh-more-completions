#compdef xmllint
# Documentation: https://manpages.debian.org/xmllint.1
# Source: libxml2 — XML parser / validator / formatter CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--auto[generate a small document for testing]' \
    '--catalogs[use SGML catalogs from SGML_CATALOG_FILES]' \
    '--chkregister[turn on node registration (libxml dev)]' \
    '--compress[gzip-compress output]' \
    '--copy[test internal copy implementation]' \
    '--c14n[W3C XML Canonicalization output]' \
    '--dtdvalid=[validate against DTD at URL]:url:' \
    '--dtdvalidfpi=[validate against DTD by Formal Public Identifier]:fpi:' \
    '--debug[parse + dump annotated tree]' \
    '--debugent[debug entities defined in the document]' \
    '--dropdtd[remove DTD from output]' \
    '--dtdattr[fetch external DTD; populate tree with inherited attributes]' \
    '--encode=[output encoding]:encoding:(UTF-8 UTF-16 ISO-8859-1 ISO-8859-15 ASCII)' \
    '--format[reformat and reindent output]' \
    '(- *)--help[short usage summary]' \
    '--html[use the HTML parser]' \
    '--htmlout[output results as HTML]' \
    '--insert[test for valid insertions]' \
    '--loaddtd[fetch external DTD]' \
    '--load-trace[log loaded documents to stderr]' \
    '--maxmem=[max parser memory allocation]:bytes:' \
    '--memory[parse from memory]' \
    '--noblanks[drop ignorable blank spaces]' \
    '--nocatalogs[do not use any catalogs]' \
    '--nocdata[substitute CDATA by equivalent text nodes]' \
    '--noent[substitute entity values for entity references]' \
    '--nonet[do not use the Internet to fetch DTDs/entities]' \
    '--noout[suppress output]' \
    '--nowarning[do not emit warnings]' \
    '--nowrap[no HTML doc wrapper]' \
    '--noxincludenode[XInclude without start/end nodes]' \
    '--nsclean[remove redundant namespace declarations]' \
    '--output=[save result to FILE]:file:_files' \
    '--path=[filesystem paths to load DTDs/entities]:paths:' \
    '--pattern=[run XPath subset pattern]:pattern:' \
    '--postvalid[validate after parsing]' \
    '--push[use push-mode parser]' \
    '--recover[output parsable portions of invalid document]' \
    '--relaxng=[validate against RelaxNG schema]:schema:_files' \
    '--repeat[repeat 100 times (timing/profiling)]' \
    '--schema=[validate against W3C XML Schema]:schema:_files' \
    '--shell[run navigating shell]' \
    '--xpath=[run XPath expression]:expr:' \
    '--stream[streaming validation for large files]' \
    '--testIO[test user I/O support]' \
    '--timing[report time taken for various steps]' \
    '--valid[check valid against included DTD]' \
    '(- *)--version[display libxml version]' \
    '--walker[test walker module]' \
    '--xinclude[do XInclude processing]' \
    '--xmlout[XML serializer output (with --html)]' \
    '*:XML file:_files' \
    && ret=0

return ret
