#compdef hatch-test
# _hatch-test — Hatch Python test runner (pypa/hatch)
# upstream: https://github.com/pypa/hatch

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--cover[measure code coverage]' \
  '--all[test all Python versions]' \
  '--parallel[run tests in parallel]' \
  '--randomize[randomize test order]' \
  '--python=[Python version]:version:' \
  '--include=[include matrix variables]:vars:' \
  '--exclude=[exclude matrix variables]:vars:' \
  '--retries=[retry count for flaky tests]:count:' \
  '*:pytest args:'
