#compdef tunnelto
# Documentation: https://github.com/agrinman/tunnelto
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'set-auth:save your API authentication key for future use'
  'help:display help documentation'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity (stackable)]' \
  '(-k --key)'{-k,--key}'=[API authentication key]:key:' \
  '(-s --subdomain)'{-s,--subdomain}'=[custom subdomain]:name:' \
  '(-p --port)'{-p,--port}'=[destination port for tunnel traffic]:port:' \
  '--host=[target hostname (default localhost)]:host:_hosts' \
  '--scheme=[protocol]:scheme:(http https)' \
  '--dashboard-address=[local inspection dashboard address]:address:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tunnelto subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (set-auth)
        _arguments '(-k --key)'{-k,--key}'=[API authentication key]:key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
