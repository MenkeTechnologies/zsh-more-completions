#compdef jupyter-qtconsole
# Documentation: https://github.com/jupyter/qtconsole/blob/main/qtconsole/qtconsoleapp.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jupyter-qtconsole: Qt-based Jupyter frontend. Added real --plain/
# --no-plain/--banner/--no-banner flags from JupyterQtConsoleApp.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--help-all[show all options]' \
  '--version[show version]' \
  '--plain[disable rich text support]' \
  '--no-plain[enable rich text support]' \
  '--banner[display a banner on startup]' \
  '--no-banner[do not display a banner on startup]' \
  '--confirm-exit[prompt for confirmation when exiting]' \
  '--no-confirm-exit[no confirm exit]' \
  '--existing=[connect to existing kernel]:conn_file:' \
  '--kernel=[kernel name]:name:' \
  '--style=[Pygments style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files -g "*.css"' \
  '--colors=[ANSI colors]:val:(lightbg linux nocolor)' \
  '--paging=[paging mode]:mode:(inside hsplit vsplit none)' \
  '--editor=[external editor]:cmd:_command_names' \
  '--debug[debug]' \
  '--logfile=[log file]:file:_files' \
  '--config=[config file]:file:_files -g "*.py"' \
  '*::jupyter-qtconsole args:_files' && ret=0
return ret
