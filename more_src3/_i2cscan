#compdef i2cscan
# Documentation: man i2cscan(8)
# Source: netbsd/src usr.sbin/i2cscan — scan iic(4) bus for devices (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[scan using 1-byte reads instead of quick writes]' \
    '1:iic bus device:_files' \
    && ret=0

return ret
