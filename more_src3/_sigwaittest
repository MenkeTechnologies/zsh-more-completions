#compdef sigwaittest
# Documentation: https://wiki.linuxfoundation.org/realtime/documentation/howto/tools/rt-tests
# Source: rt-tests src/sigwaittest/sigwaittest.c — measure signal wait/wakeup latency.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\?,--help}'[show help]' \
    '(-a --affinity)'{-a+,--affinity=}'[CPU affinity (NUM pins all to CPU NUM)]:cpu:_default' \
    '(-b --breaktrace)'{-b+,--breaktrace=}'[send break trace when latency > USEC]:usec:_default' \
    '(-d --distance)'{-d+,--distance=}'[thread interval distance (us, default 500)]:us:_default' \
    '(-f --fork)'{-f,--fork}'[fork processes instead of threads]' \
    '(-i --interval)'{-i+,--interval=}'[base thread interval (us, default 1000)]:us:_default' \
    '(-l --loops)'{-l+,--loops=}'[number of loops (0=endless)]:n:_default' \
    '(-p --prio)'{-p+,--prio=}'[priority]:prio:_default' \
    '(-t --threads)'{-t+,--threads=}'[threads per processor (NUM=count, default 1)]:n:_default' \
    && ret=0

return ret
