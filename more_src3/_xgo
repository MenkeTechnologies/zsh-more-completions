_xgo() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_xgo_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build|install|test|fmt|doc|get)
                    _arguments '*:XGo package or file:_files -g "*.xgo *.gox *.go"' && ret=0 ;;
                run)
                    _arguments \
                        '1:XGo package or file:_files -g "*.xgo *.gox *.go"' \
                        '*::program args:' && ret=0 ;;
                clean|watch|pack)
                    _arguments '::directory:_files -/' && ret=0 ;;
                go)
                    _arguments '*:XGo package or file to convert:_files -g "*.xgo *.gox"' && ret=0 ;;
                env)
                    _arguments '*:env var name:' && ret=0 ;;
                mod)
                    _arguments \
                        '1:mod subcommand:(init tidy download)' \
                        '*::arg:->mod_args'
                    case $state in
                        mod_args)
                            case $words[1] in
                                init)
                                    _arguments '::module path:' && ret=0 ;;
                                tidy|download)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
                serve|version|bug)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xgo_commands] )) ||
_xgo_commands() {
    local -a commands
    commands=(
        'build:build XGo files'
        'install:build XGo files and install target to GOBIN'
        'run:compile and run an XGo program'
        'test:test XGo packages'
        'fmt:format XGo packages'
        'doc:show documentation for package or symbol'
        'env:prints XGo environment information'
        'get:add dependencies to the current module and install them'
        'clean:clean all XGo auto-generated files'
        'version:print XGo version'
        'bug:start a bug report'
        'mod:module maintenance (init/tidy/download)'
        'go:convert XGo code into Go code'
        'pack:merge project config into a single index_pack file'
        'serve:serve as an XGo LangServer'
        'watch:monitor code changes and regenerate Go files'
    )
    _describe -t commands 'xgo command' commands
}

_xgo "$@"
