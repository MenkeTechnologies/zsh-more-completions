#compdef kapptemplate
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/kapptemplate.1.html
# Reference accessed: 2026-05-19
# Verified: upstream man page at the URL above. Prior file invented Qt/KF
# options (--style --stylesheet --platform --graphicssystem --reverse etc);
# the canonical kapptemplate CLI is the shell-script interface below.

# KAppTemplate: KDE application template/framework generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[display a full summary of options]' \
  '--noinit[do not run make -f Makefile.cvs]' \
  '--default[use default values instead of prompting]' \
  '(--kpart-app --kpart-plugin --existing)--full-app[create a full featured KDE application]' \
  '(--full-app --kpart-plugin --existing)--kpart-app[create a full featured KPart application]' \
  '(--full-app --kpart-app --existing)--kpart-plugin[create a KPart plugin framework]' \
  '(--full-app --kpart-app --kpart-plugin)--existing[convert existing source to automake/autoconf KDE framework]' && ret=0
return ret
