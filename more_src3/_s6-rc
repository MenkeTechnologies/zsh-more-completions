#compdef s6-rc
# Documentation: https://skarnet.org/software/s6-rc/s6-rc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-l+[live state directory]:live directory:_files -/' \
  '-a[add currently active services to the selection]' \
  '-b[use blocking lock]' \
  '-u[bring services up (default)]' \
  '-d[stop services normally]' \
  '-D[force stop, even essential services]' \
  '-e[exclude services marked as essential from output]' \
  '-E[include essential services (default)]' \
  '-v+[verbosity level]:verbosity:(0 1 2 3)' \
  '-n+[dry run with delay in ms]:dryruntimeout' \
  '-t+[timeout in milliseconds]:timeout' \
  '-p[prune to exact selection or exclude selection]' \
  '1:command:(help list listall diff start stop change)' \
  '*:service name' && ret=0

return ret
