#compdef wicd-client
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/wicd-client.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wicd-client: WICD network manager GUI/tray client (legacy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --tray)'{-t,--tray}'[run tray icon only]' \
  '(-n --no-tray)'{-n,--no-tray}'[run without tray icon]' \
  '(-a --no-animate)'{-a,--no-animate}'[disable network traffic animations]' && ret=0
return ret
