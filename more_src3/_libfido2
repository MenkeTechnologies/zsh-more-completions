#compdef fido2-cred fido2-token fido2-assert
# Documentation: https://developers.yubico.com/libfido2/Manuals/
# Reference accessed: 2026-05-19
# Verified: fido2-token(1), fido2-cred(1), fido2-assert(1) usage from installed binaries and Yubico manuals.

# libfido2 ships three CLI binaries (fido2-cred, fido2-token, fido2-assert).
# All three use uppercase mode flags (-M/-V, -G/-V, -C/-D/-G/-I/-L/-R/-S/-V)
# plus lowercase auxiliary flags. There are no long-option (--xxx) forms.
local curcontext="$curcontext" ret=1 cmd

cmd=${${(M)${(s. .)PREFIX}#fido2-*}:-${service:-${words[1]}}}
case ${service:-${words[1]}} in
  fido2-cred)
    _arguments -s \
      '-M[make credential]' \
      '-V[verify credential]' \
      '-a+[enterprise attestation mode]:mode:' \
      '-b[also produce CTAP2 largeBlobKey]' \
      '-c+[credProtect policy]:policy:(1 2 3)' \
      '-d[debug output]' \
      '(- *)-h[show help]' \
      '-i+[input file]:file:_files' \
      '-o+[output file]:file:_files' \
      '-q[quiet]' \
      '-r[output raw binary]' \
      '-u[U2F (CTAP1) mode]' \
      '-v[require user verification]' \
      '-w[wrap output / hex output]' \
      '1:device:_files -W /dev -g "hidraw*"' \
      '2:type:(es256 es384 rs256 eddsa)' && ret=0
    ;;
  fido2-token)
    _arguments -s \
      '-C[modify the PIN on device]' \
      '-D[delete credential/enrollment/blob]' \
      '-G[get largeBlob from device]' \
      '-I[get device information]' \
      '-L[list authenticators (or details)]' \
      '-R[reset the authenticator]' \
      '-S[set/configure or enroll]' \
      '-V[show version]' \
      '-a[enterprise attestation]' \
      '-b[largeBlob operation]' \
      '-c[resident credential operation]' \
      '-d[debug output]' \
      '-e[biometric enrollment]' \
      '-f[force PIN change]' \
      '-i+[credential or template id]:id:' \
      '-k+[key path or rp_id]:value:' \
      '-l+[minimum PIN length]:length:' \
      '-m+[rp_id allowlist]:rp_id:' \
      '-n+[name or rp_id]:name:' \
      '-p+[display name]:name:' \
      '-r[list resident relying parties]' \
      '-t+[ppuat path]:file:_files' \
      '-u[user verification always]' \
      '*:device or path:_files -W /dev -g "hidraw*"' && ret=0
    ;;
  fido2-assert)
    _arguments -s \
      '-G[get assertion]' \
      '-V[verify assertion]' \
      '-b[also produce CTAP2 largeBlobKey]' \
      '-d[debug output]' \
      '(- *)-h[show help]' \
      '-i+[input file]:file:_files' \
      '-o+[output file]:file:_files' \
      '-p+[hmac-secret/uv option]:option:(up uv pin)' \
      '-r[output raw binary]' \
      '-t+[per-assertion option]:option:' \
      '-u[U2F (CTAP1) mode]' \
      '-v[require user verification]' \
      '-w[hex output]' \
      '1:device_or_keyfile:_files' \
      '2:type:(es256 es384 rs256 eddsa)' && ret=0
    ;;
esac

return ret
