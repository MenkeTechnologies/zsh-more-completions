#compdef twitch-dl
# Documentation: https://twitch-dl.bezdomni.net/usage.html
# Reference accessed: 2026-05-21
# Verified: upstream twitch-dl docs (ihabunek/twitch-dl).

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'cache:view and manage cached files'
  'chat:render chat for a given video'
  'clips:list clips from a channel'
  'download:download a video or clip'
  'env:print environment information'
  'info:print info for a video or clip'
  'videos:list videos from a channel'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->command' \
  '*::arg:_default' && ret=0

case $state in
  (command)
    _describe -t commands 'twitch-dl command' commands && ret=0
    ;;
esac

return ret
