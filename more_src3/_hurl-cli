#compdef hurl-cli
# _hurl-cli — Orange Hurl plain-text HTTP request runner CLI alias (Orange-OpenSource team, Rust); clap-rs
# upstream: https://github.com/Orange-OpenSource/hurl

_hurl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--aws-sigv4=+[provider]:str:' \
        '--cacert=+[ca cert]:file:_files' \
        '-E+[client cert]:file:_files' \
        '--cert=+[client cert]:file:_files' \
        '--key=+[key file]:file:_files' \
        '-b+[cookie file]:file:_files' \
        '--cookie=+[cookie file]:file:_files' \
        '-c+[cookie jar]:file:_files' \
        '--cookie-jar=+[cookie jar]:file:_files' \
        '--compressed[allow compressed response]' \
        '--connect-timeout=+[seconds]:n:' \
        '--connect-to=+[host1:port1:host2:port2]:str:' \
        '--continue-on-error[continue on error]' \
        '-d+[delay ms]:n:' \
        '--delay=+[delay ms]:n:' \
        '--error-format=+[format]:f:(short long json)' \
        '--file-root=+[dir]:dir:_files -/' \
        '-f[fail fast]' \
        '--fail-at-end[fail at end]' \
        '--from-entry=+[n]:n:' \
        '--glob=+[pattern]:str:' \
        '-i[include response headers]' \
        '--include[include response headers]' \
        '-I+[interface]:_net_interfaces' \
        '--interface=+[interface]:_net_interfaces' \
        '--ipv4[ipv4]' \
        '--ipv6[ipv6]' \
        '-k[insecure]' \
        '--insecure[insecure]' \
        '--jobs=+[n]:n:' \
        '--json[json output]' \
        '-L[location follow]' \
        '--location[location follow]' \
        '--location-trusted[location trusted]' \
        '--max-redirs=+[n]:n:' \
        '--max-time=+[seconds]:n:' \
        '-m+[seconds]:n:' \
        '--max-filesize=+[bytes]:n:' \
        '--no-color[no color]' \
        '--no-output[no output]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--parallel[parallel]' \
        '--path-as-is[path as-is]' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--repeat=+[count]:n:' \
        '--report-html=+[dir]:dir:_files -/' \
        '--report-junit=+[file]:file:_files' \
        '--report-tap=+[file]:file:_files' \
        '--resolve=+[host:port:addr]:str:' \
        '--retry=+[count]:n:' \
        '--retry-interval=+[ms]:n:' \
        '--secret=+[name]:str:' \
        '--ssl-no-revoke[ssl no revoke]' \
        '--test[test mode]' \
        '--to-entry=+[n]:n:' \
        '--unix-socket=+[socket]:file:_files' \
        '-u+[user:password]:str:' \
        '--user=+[user:password]:str:' \
        '--variable=+[name=value]:str:' \
        '--variables-file=+[file]:file:_files' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--very-verbose[very verbose]' \
        '--workdir=+[dir]:dir:_files -/' \
        '*:hurl files:_files -g "*.hurl"'
}

_hurl-cli "$@"
