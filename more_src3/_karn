#compdef karn
# Documentation: https://github.com/prydonius/karn/blob/master/cmd/karn/karn.go
# Reference accessed: 2026-05-19
# Verified: upstream source (urfave/cli app.Commands) at the URL above.
# Prior file invented list/use/add/edit/remove subcommands and
# --alias/--name/--email/--ssh-key/--gpg-key flags; karn only has the
# two commands below (identities are configured via ~/.karn.yml).

# karn: manage multiple Git identities

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'update:check and update the Git identity for the current repo'
      'init:print shell snippet to hook karn into the git command'
    )
    _describe -t commands 'karn subcommand' subcmds && ret=0
    ;;
esac

return ret
