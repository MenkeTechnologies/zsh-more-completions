#compdef xgps
# Documentation: https://gitlab.com/gpsd/gpsd/-/raw/master/man/xgps.adoc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Added: -?, --host, --port, -device, -c/--const (documented upstream).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-D --debug)'{-D+,--debug=}'[debug level]:lvl:' \
  '(-l --llfmt)'{-l+,--llfmt=}'[lat/lon format]:fmt:(d m s)' \
  '(-u --units)'{-u+,--units=}'[display units]:units:(i n m imperial nautical metric)' \
  '(-c --const)'{-c+,--const=}'[constellation display format]:format:' \
  '(-r --rotate)'{-r+,--rotate=}'[rotate skyview counterclockwise (deg)]:deg:' \
  '--host=[server to connect to]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[port number]:port:' \
  '-device=[device to connect to]:device:_files -W /dev' \
  '*:server:_hosts' && ret=0

return ret
