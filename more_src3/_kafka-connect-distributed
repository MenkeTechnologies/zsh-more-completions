#compdef kafka-connect-distributed kafka-connect-distributed.sh connect-distributed
# _kafka-connect-distributed — Apache Kafka kafka-connect-distributed Kafka Connect distributed worker CLI for running scalable connectors source/sink REST API rebalancing and offset/config topic management (apache team, Java); JCommander
# upstream: https://kafka.apache.org/

_kafka-connect-distributed() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-daemon[run as daemon]' \
        '--daemon[run as daemon]' \
        '-loggc[enable GC log]' \
        '--loggc[enable GC log]' \
        '--name=+[name]:str:' \
        '--logging-options=+[opt]:str:' \
        '*:worker properties:_files -g "*.properties connect-distributed.properties"'
}

_kafka-connect-distributed "$@"
