#compdef ios-deploy-cli
# _ios-deploy-cli — phonegap-ios-deploy iOS app install/debug over USB/Wi-Fi CLI alias (PhoneGap / ios-control, Objective-C); custom argparse
# upstream: https://github.com/ios-control/ios-deploy

_ios-deploy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--app=+[app bundle]:dir:_files -/' \
        '-b+[app bundle]:dir:_files -/' \
        '--bundle=+[app bundle]:dir:_files -/' \
        '--bundle_id=+[bundle id]:str:' \
        '-1+[bundle id]:str:' \
        '--debug[debug mode]' \
        '-d[debug mode]' \
        '--detect[detect devices]' \
        '-c[detect devices]' \
        '--justlaunch[launch and exit]' \
        '-m[launch and exit]' \
        '--no-wifi[no wifi]' \
        '-W[no wifi]' \
        '--device-name=+[device name]:str:' \
        '-Q+[device name]:str:' \
        '--device=+[device id]:str:' \
        '-i+[device id]:str:' \
        '--id=+[device id]:str:' \
        '--no-interactive[no interactive]' \
        '-I[no interactive]' \
        '--list[list app installs]' \
        '--bundle-name=+[bundle name]:str:' \
        '-O+[bundle name]:str:' \
        '--exists=+[check exists]:str:' \
        '-e+[check exists]:str:' \
        '--list-bundle-id[list bundle ids]' \
        '-B[list bundle ids]' \
        '--list-installed[list installed apps]' \
        '-L[list installed apps]' \
        '--app-bundle-id=+[app bundle id]:str:' \
        '--upload=+[upload file]:file:_files' \
        '-o+[upload file]:file:_files' \
        '--download[download files]' \
        '-w[download files]' \
        '--list-files=+[list device files]:str:' \
        '-l+[list device files]:str:' \
        '--to=+[destination dir]:dir:_files -/' \
        '-2+[destination dir]:dir:_files -/' \
        '--rm[remove file]' \
        '-r[remove file]' \
        '--key=+[device key]:str:' \
        '-9+[device key]:str:' \
        '--timeout=+[timeout seconds]:n:' \
        '-t+[timeout seconds]:n:' \
        '--unbuffered[unbuffered]' \
        '-u[unbuffered]' \
        '--noinstall[no install]' \
        '-n[no install]' \
        '--noninteractive[no interactive]' \
        '--port=+[debug port]:port:' \
        '-x+[debug port]:port:' \
        '--xcode-test=+[xcode test]:str:' \
        '-T+[xcode test]:str:' \
        '--args=+[runtime args]:str:' \
        '-a+[runtime args]:str:' \
        '--envs=+[env vars]:str:' \
        '-s+[env vars]:str:' \
        '--exit[exit immediately after launch]' \
        '-E[exit immediately after launch]' \
        '--faster-path-search[faster path search]' \
        '-z[faster path search]' \
        '--non-recursive[non recursive]' \
        '-R[non recursive]' \
        '--app-deltas=+[app deltas]:dir:_files -/' \
        '-A+[app deltas]:dir:_files -/' \
        '--check-app[check app]' \
        '-x[check app]' \
        '*:arg:'
}

_ios-deploy-cli "$@"
