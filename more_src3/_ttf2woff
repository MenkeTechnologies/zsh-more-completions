#compdef ttf2woff
# Documentation: https://github.com/fontello/ttf2woff
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Verified usage from fontello/ttf2woff README:
#   ttf2woff input.ttf output.woff
# No flags are documented; previous -h/-v/-m/-p/-V flags were not in
# upstream documentation.

_arguments \
  '1:input TTF/OTF font:_files -g "*.(#i)(ttf|otf)"' \
  '2:output WOFF font:_files -g "*.(#i)woff"'
