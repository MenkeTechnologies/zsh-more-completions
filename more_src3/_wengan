#compdef wengan.pl wengan
# Documentation: https://github.com/adigenova/wengan
# Source: adigenova/wengan wengan.pl — hybrid genome assembler (Perl, getopts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x+[long-read preset]:preset:(ontlon ontraw pacraw ccsont ccspac)' \
    '-a+[mode (short-read assembler)]:mode:(M A D)' \
    '-s+[short-reads (fwd1.fastq.gz,rev1.fastq.gz,...)]:files:_default' \
    '-l+[long-reads.fq.gz]:file:_files -g "*.fq.gz"' \
    '-b+[HiFi reads (hifi.fq.gz,hifi2.fq.gz,...)]:files:_default' \
    '-g+[genome size in Mb]:size:_default' \
    '-p+[output prefix]:prefix:_default' \
    '(- *)-h[detail information]' \
    '-t+[CPU cores (default 1)]:n:_default' \
    '-c+[pre-assembled short-read contigs]:file:_files' \
    '-i+[insert-size list for raw long-reads]:list:_default' \
    '-I+[insert-size list for CCS reads]:list:_default' \
    '-n[show pipeline commands]' \
    '-k+[k-mer size 15-28]:n:_default' \
    '-w+[minimizer window 5-15]:n:_default' \
    '-q+[min mapping quality 20-60]:n:_default' \
    '-m+[moving window (default 150)]:n:_default' \
    '-d+[min base coverage (default 7)]:n:_default' \
    '-f+[stddev factor (default 0.1)]:n:_default' \
    '-M+[Liger minimum contig length in TR]:n:_default' \
    '-R+[Liger repeat copy number factor]:n:_default' \
    '-L+[Liger long mate-edge length (default 100000)]:n:_default' \
    '-N+[Liger long-reads to keep mate-edge (default 5)]:n:_default' \
    '-P+[Liger min reduced-path length (default 20kb)]:n:_default' \
    '-Q+[Liger min contig length in matching]:n:_default' \
    '-U+[Liger backbone repeat copy number factor]:n:_default' \
    '-T+[Liger TR iterations per edge (default 1M)]:n:_default' \
    '-D+[HiFi ploidy]:ploidy:(1 2)' \
    && ret=0

return ret
