#compdef image-automation-controller
# _image-automation-controller — Flux GitOps image-automation reconciler
# upstream: https://github.com/fluxcd/image-automation-controller
# Flags from main.go on tip.

_image-automation-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--events-addr=[fluxcd notification-controller events receiver URL]:url:' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '--concurrent=[concurrent reconciles]:n:' \
        '--default-service-account=[default impersonated ServiceAccount]:sa:' \
        '*--ssh-kex-algos=[allowed SSH KEX algorithms (repeatable)]:algo:' \
        '*--ssh-hostkey-algos=[allowed SSH host key algorithms (repeatable)]:algo:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--watch-all-namespaces=[watch all namespaces]:bool:(true false)' \
        '--log-level=[log level]:level:(debug info error)' \
        '--log-encoding=[log encoder]:fmt:(json console)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_image-automation-controller "$@"
