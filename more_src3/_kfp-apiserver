#compdef kfp-apiserver ml-pipeline-apiserver
# _kfp-apiserver — Kubeflow Pipelines API server (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/apiserver/main.go on tip.

_kfp-apiserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--logLevel=[application log level]:level:(debug info warn error fatal panic)' \
        '--rpcPortFlag=[gRPC bind host\:port]:host\:port:' \
        '--httpPortFlag=[HTTP gateway bind host\:port]:host\:port:' \
        '--webhookPortFlag=[admission webhook bind host\:port]:host\:port:' \
        '--webhookTLSCertPath=[webhook TLS cert]:file:_files' \
        '--webhookTLSKeyPath=[webhook TLS key]:file:_files' \
        '--config=[JSON config file]:file:_files -g "*.json(-.)"' \
        '--sampleconfig=[samples directory]:dir:_files -/' \
        '--tlsCertPath=[server TLS cert]:file:_files' \
        '--tlsCertKeyPath=[server TLS key]:file:_files' \
        '--collectMetricsFlag=[expose Prometheus metrics]:bool:(true false)' \
        '--pipelinesStoreKubernetes=[store/run pipeline versions in Kubernetes]:bool:(true false)' \
        '--disableWebhook=[run without the local admission webhook]:bool:(true false)' \
        '--globalKubernetesWebhookMode=[run only as the global Kubernetes webhook]:bool:(true false)'
}

_kfp-apiserver "$@"
