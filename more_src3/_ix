#compdef ix
# Documentation: https://gist.github.com/hlecuanda/418d782b711ddc7d686f73a596241a56
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (official ix.io client script).
# Note: prior file invented -L and -p and was missing -o, -x, -h.

# Zsh completion for ix - command line pastebin (ix.io)

_arguments -s -S \
  '-h[show help/usage]' \
  '-x[enable debug mode (sourcetrace, xtrace, verbose)]' \
  '-l[list the last 100 pastes]' \
  '-o+[print contents of a paste by ID]:paste ID:' \
  '-d+[delete a paste by ID]:paste ID:' \
  '-i+[replace an existing paste ID]:paste ID:' \
  '-n+[auto-delete after NUM reads]:reads:' \
  '-u+[list pastes for a specific user]:username:' \
  '*:files:_files'
