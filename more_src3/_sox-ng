#compdef sox_ng soxi_ng play_ng rec_ng
# Documentation: https://codeberg.org/sox_ng/sox_ng
# Reference accessed: 2026-05-27
# Verified: sox_ng upstream README states drop-in CLI compatibility with SoX;
#           flags mirror sox(1) — see also src/_sox in this repository.

local -a arguments

arguments=(
  {-d,--default-device}'[use the default audio device (where available)]'
  {-n,--null}'[use the null file handler; e.g. with synth effect]'
  {-p,--sox-pipe}'[alias for -t sox -]'
  '--buffer[set the size of all processing buffers (default 8192)]:bytes:'
  '--clobber[do not prompt to overwrite output file (default)]'
  '--combine[select combining method for multiple input files]:method:(concatenate sequence mix mix-power merge multiply)'
  {-D,--no-dither}'[do not dither automatically]'
  '--dft-min[minimum size (log2) for DFT processing (default 10)]:log2 size:'
  '--effects-file[file containing effects and options]:file:_files'
  {-G,--guard}'[use temporary files to guard against clipping]'
  '(- * :)'{-h,--help}'[display version number and usage information]'
  '--help-effect[show usage of effect NAME, or NAME=all for all]:effect:'
  '--help-format[show info on format NAME, or NAME=all for all]:format:'
  {--i,--info}'[behave as soxi(1)]'
  '--input-buffer[override the input buffer size (default: as --buffer)]:bytes:'
  '--no-clobber[prompt to overwrite output file]'
  '-m[mix multiple input files (instead of concatenating)]'
  '-M[merge multiple input files (instead of concatenating)]'
  '--norm[guard (see --guard) and normalise]'
  '--play-rate-arg[default rate argument for auto-resample with play]:arg:'
  '--plot[generate script to plot response of filter effect]:type:(gnuplot octave)'
  {-q,--no-show-progress}'[run in quiet mode; opposite of -S]'
  '--replay-gain[replay-gain mode]:mode:(track album off)'
  '-R[use default random numbers (same on each run of SoX)]'
  {-S,--show-progress}'[display progress while processing audio data]'
  '--single-threaded[disable parallel effects channels processing]'
  '--temp[specify the directory to use for temporary files]:dir:_files -/'
  '-T[multiply samples of corresponding channels from all inputs]'
  '(- * :)--version[display version number of SoX and exit]'
  '-V-[increment or set verbosity level (default 2)]:level:'
  {-v,--volume}'[input file volume adjustment factor (real number)]:factor:'
  '--ignore-length[ignore input file length given in header; read to EOF]'
  {-t,--type}'[file type of audio]:type:'
  {-e,--encoding}'[set encoding]:encoding:(signed-integer unsigned-integer floating-point mu-law a-law ima-adpcm ms-adpcm gsm-full-rate)'
  {-b,--bits}'[encoded sample size in bits]:bits:'
  {-N,--reverse-nibbles}'[reverse nibble-order]'
  {-X,--reverse-bits}'[reverse bit-order]'
  '--endian[encoded byte-order]:endian:(little big swap)'
  '-L[set little-endian byte-order]'
  '-B[set big-endian byte-order]'
  '-x[set opposite byte-order to default]'
  {-c,--channels}'[number of channels of audio data; e.g. 2 = stereo]:channels:'
  {-r,--rate}'[sample rate of audio]:rate:'
  {-C,--compression}'[compression factor for output format]:factor:'
  '--add-comment[append output file comment]:comment:'
  '--comment[specify comment text for the output file]:comment:'
  '--comment-file[file containing comment text for the output file]:file:_files'
  '--no-glob[do not glob wildcard match the following filename]'
  '*:filename:_files'
)

_arguments -s -S $arguments
