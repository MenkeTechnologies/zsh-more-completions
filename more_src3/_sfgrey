#compdef sfgrey
# Documentation: http://www.ahay.org/RSF/sfgrey.html
# Source: ahay/src plot/main/grey.c — greyscale / colormap image plot to vplot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'transp=[(y/n) transpose display axes]: :(y n)' \
    'yreverse=[(y/n) reverse vertical axis]: :(y n)' \
    'xreverse=[(y/n) reverse horizontal axis]: :(y n)' \
    'gpow=[raise data to gpow power for display]: :_default' \
    'phalf=[percentage for estimating gpow]: :_default' \
    'clip=[data clip]: :_default' \
    'pclip=[clip percentile (default 99)]: :_default' \
    'gainstep=[subsampling for gpow/clip estimation]: :_default' \
    'gainpanel=[gain reference (a/e or panel number)]: :_default' \
    'allpos=[(y/n) assume positive data]: :(y n)' \
    'mean=[(y/n) bias on the mean value]: :(y n)' \
    'bias=[value mapped to color-table center]: :_default' \
    'polarity=[(y/n) reverse polarity (default white=high)]: :(y n)' \
    'symcp=[(y/n) symmetric color palette of 255 colors]: :(y n)' \
    'verb=[(y/n) verbose]: :(y n)' \
    'bar=[file with scalebar data]: :_files -g "*.rsf(-.)"' \
    'wantscalebar=[(y/n) draw scalebar]: :(y n)' \
    'scalebar=[(y/n) draw scalebar (alias)]: :(y n)' \
    'minval=[scalebar minimum value]: :_default' \
    'maxval=[scalebar maximum value]: :_default' \
    'barreverse=[(y/n) reverse scalebar direction]: :(y n)' \
    'wantframenum=[(y/n) display third-axis position in corner]: :(y n)' \
    'color=[colormap (default i)]: :_default' \
    'nreserve=[reserved colors]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
