#compdef zgenom
# Documentation: https://github.com/jandamm/zgenom
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'load:load plugins and completions'
      'bin:load executables'
      'loadall:bulk load plugins'
      'ohmyzsh:load ohmyzsh base, plugins, and themes'
      'prezto:load Prezto and modules'
      'pmodule:load a repo as Prezto plugins'
      'compile:compile your .zshrc files'
      'reset:remove init script'
      'save:generate init script'
      'saved:check for an init script'
      'init:initialize zgenom (called by saved)'
      'update:update all plugins and reset'
      'clean:clean zgenom plugins'
      'selfupdate:update zgenom'
      'autoupdate:run updates automatically'
      'compdef:fix issues with compdef'
      'api:safely access internal api'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (load)
        _arguments \
          '1:repository:' \
          '2:subdirectory:' && ret=0
        ;;
      (ohmyzsh)
        _arguments \
          '1:component type:(plugins themes lib)' \
          '2:name:' && ret=0
        ;;
      (prezto)
        _arguments '1:module:' && ret=0
        ;;
      (bin)
        _arguments \
          '1:repository:' \
          '2:binary:' && ret=0
        ;;
      (compile)
        _arguments '*:file:_files -g "*.zsh"' && ret=0
        ;;
    esac
    ;;
esac

return ret
