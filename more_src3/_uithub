#compdef uithub
# Documentation: https://github.com/janwilmake/uithub
# Reference accessed: 2026-05-22
# Verified: cli/uithub-cli.js usage and help output.

# Zsh completion for uithub - fetch GitHub repos as LLM-friendly text via uithub.com

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:(logout)' \
  '*:url or owner/repo:' && ret=0

return ret
