#compdef swiftpm-cli
# _swiftpm-cli — Apple Swift Package Manager swift package CLI alias (Apple, Swift); custom argparse
# upstream: https://github.com/apple/swift-package-manager

_swiftpm-cli() {
    local -a sub=(
        'add-dependency:add a dependency'
        'add-product:add a product'
        'add-target:add a target'
        'archive-source:create a source archive'
        'clean:remove build artifacts'
        'compute-checksum:compute checksum for binary'
        'config:configure SwiftPM'
        'describe:describe package'
        'diagnose-api-breaking-changes:diagnose API breaking changes'
        'dump-package:print Package.swift JSON'
        'dump-symbol-graph:dump symbol graph'
        'edit:put package in editable mode'
        'experimental-install:install a tool'
        'experimental-uninstall:uninstall a tool'
        'experimental-snippet:experimental snippet commands'
        'generate-documentation:generate documentation'
        'init:scaffold a Swift package'
        'install:install package'
        'list-installed:list installed tools'
        'plugin:run plugin command'
        'purge-cache:purge cache'
        'reset:reset build/dependency state'
        'resolve:resolve dependencies'
        'show-dependencies:show dependencies tree'
        'show-executables:show executables'
        'tools-version:tools version'
        'unedit:remove editable mode'
        'update:update dependencies'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--package-path=+[package path]:dir:_files -/' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '--config-path=+[config path]:dir:_files -/' \
        '--build-path=+[build path]:dir:_files -/' \
        '--security-path=+[security path]:dir:_files -/' \
        '--scratch-path=+[scratch path]:dir:_files -/' \
        '--manifest-cache=+[manifest cache]:c:(none local shared)' \
        '--enable-cache[enable cache]' \
        '--disable-cache[disable cache]' \
        '--triple=+[triple]:str:' \
        '--sdk=+[SDK]:str:' \
        '--toolchain=+[toolchain]:str:' \
        '--swift-sdk=+[swift SDK]:str:' \
        '-c+[configuration]:c:(debug release)' \
        '--configuration=+[configuration]:c:(debug release)' \
        '-Xcc+[cc flag]:str:' \
        '-Xcxx+[cxx flag]:str:' \
        '-Xlinker+[linker flag]:str:' \
        '-Xswiftc+[swiftc flag]:str:' \
        '-Xbuild-tools-swiftc+[build tools swiftc flag]:str:' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--very-verbose[very verbose]' \
        '--vv[very verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--color-diagnostics[color diagnostics]' \
        '--no-color-diagnostics[no color diagnostics]' \
        '--use-integrated-swift-driver[use integrated driver]' \
        '--explicit-target-dependency-import-check[explicit target dependency import check]' \
        '--experimental-explicit-module-build[experimental explicit module build]' \
        '--print-manifest-job-graph[print manifest job graph]' \
        '--build-system=+[build system]:b:(native xcode swiftbuild)' \
        '--enable-test-discovery[enable test discovery]' \
        '--disable-test-discovery[disable test discovery]' \
        '--disable-package-manifest-caching[disable manifest caching]' \
        '--enable-package-manifest-caching[enable manifest caching]' \
        '--disable-resolved-update[disable resolved update]' \
        '--force-resolved-versions[force resolved versions]' \
        '--disable-sandbox[disable sandbox]' \
        '--allow-network-connections=+[allow network connections]:str:' \
        '--use-prebuilts[use prebuilts]' \
        '--no-use-prebuilts[no use prebuilts]' \
        '--prebuilts-download-base=+[prebuilts download base]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swiftpm subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--type=+[type]:t:(empty executable library tool macro plugin system-module)' \
                    '--name=+[name]:str:' \
                    '--enable-xctest[enable xctest]' \
                    '--enable-swift-testing[enable swift testing]' ;;
                add-dependency) _arguments \
                    '1:url-or-path:' \
                    '--exact=+[exact version]:str:' \
                    '--from=+[from version]:str:' \
                    '--branch=+[branch]:str:' \
                    '--revision=+[revision]:str:' \
                    '--up-to-next-minor-from=+[up to next minor from]:str:' \
                    '--up-to-next-major-from=+[up to next major from]:str:' \
                    '--path=+[local path]:dir:_files -/' \
                    '--package-id=+[package id]:str:' ;;
                edit|unedit|update) _arguments \
                    '--branch=+[branch]:str:' \
                    '--revision=+[revision]:str:' \
                    '*:package:' ;;
                plugin) _arguments \
                    '--list[list plugins]' \
                    '--allow-writing-to-package-directory[allow writing]' \
                    '--allow-writing-to-directory=+[allow writing to dir]:dir:_files -/' \
                    '--allow-network-connections=+[allow network connections]:str:' \
                    '--package=+[package]:str:' \
                    '*:plugin-cmd:' ;;
                generate-documentation) _arguments \
                    '--target=+[target]:str:' \
                    '--disable-indexing[disable indexing]' ;;
                experimental-install|install|experimental-uninstall) _arguments \
                    '--product=+[product]:str:' \
                    '*:url:_urls' ;;
                describe) _arguments \
                    '--type=+[type]:t:(text json yaml)' ;;
                config) _arguments \
                    '1:cmd:(set-mirror get-mirror unset-mirror)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_swiftpm-cli "$@"
