#compdef statikapi
# Documentation: https://github.com/zonayedpca/statikapi
# Reference accessed: 2026-05-22
# Verified: packages/cli/src/index.js and commands/build.js, dev.js.

# Zsh completion for statikapi - static API output generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--srcDir[source routes directory]:directory:_directories' \
  '--outDir[output directory]:directory:_directories' \
  '--pretty[pretty-print JSON output]' \
  '--minify[minify JSON output]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'statikapi command' \
      'build[build static JSON endpoints into api-out/]' \
      'dev[watch src-api and serve preview UI]' && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '1:project directory:_directories' && ret=0
        ;;
      dev)
        _arguments \
          '--host[dev server host]:host:' \
          '--port[dev server port]:port:' \
          '--no-ui[disable preview UI]' \
          '--no-open[do not open browser]' \
          '--keep-alive[keep dev server running in non-TTY]' \
          '--serve[alias for --keep-alive]' \
          '1:project directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
