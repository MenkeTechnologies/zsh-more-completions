#compdef why3
# Documentation: https://www.why3.org/doc/manpages.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:configure provers'
  'doc:produce HTML documentation'
  'execute:execute Why3 program'
  'extract:extract program to OCaml/C'
  'find:print location of theory'
  'ide:start interactive IDE'
  'pp:pretty-print Why3 file'
  'prove:try to prove goals'
  'realize:realize theory'
  'replay:replay session'
  'session:manage session'
  'wc:line counter'
  'webide:start web IDE'
  'help:show help on a sub-command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--print-libdir[print library directory]' \
  '--print-datadir[print data directory]' \
  '--list-debug-flags[list debug flags]' \
  '--list-formats[list formats]' \
  '--list-printers[list printers]' \
  '--list-provers[list provers]' \
  '--list-strategies[list strategies]' \
  '--list-transforms[list transforms]' \
  '--list-metas[list metas]' \
  '*-C+[config file]:file:_files' \
  '*--config=[config file]:file:_files' \
  '*-L+[library path]:dir:_files -/' \
  '*--library=[library path]:dir:_files -/' \
  '*-D+[debug flag]:flag:' \
  '*--debug=[debug flag]:flag:' \
  '--debug-all[enable all debug]' \
  '*: :->args' && ret=0

case $state in
  (args)
    if (( CURRENT == 1 )); then
      _describe -t cmds 'why3 command' commands && ret=0
    else
      case $line[1] in
        (prove|ide|webide)
          _arguments \
            '-P+[prover]:prover:' \
            '--prover=[prover]:prover:' \
            '-F+[input format]:fmt:(why mlw whyml smt smt2 smtv2 smtv2.6 native cnf tptp coq)' \
            '--format=[input format]:fmt:' \
            '-T+[theory]:theory:' \
            '--theory=[theory]:theory:' \
            '-G+[goal]:goal:' \
            '--goal=[goal]:goal:' \
            '*-a+[apply transform]:transform:' \
            '*--apply-transform=[transform]:transform:' \
            '-t+[time limit]:s:' \
            '--timelimit=[time limit]:s:' \
            '-s+[step limit]:n:' \
            '--stepslimit=[step limit]:n:' \
            '-m+[memory MB]:mb:' \
            '--memlimit=[memory MB]:mb:' \
            '*: :_files -g "*.why *.mlw *.smt *.smt2"' && ret=0 ;;
        (config)
          _arguments \
            '--detect[detect provers]' \
            '--detect-provers[detect provers]' \
            '--add-prover+[add prover]:prover:' \
            '--list-supported-provers[list supported]' \
            '--full-config[show full config]' \
            '*: :_files' && ret=0 ;;
        (extract)
          _arguments \
            '-D+[driver]:driver:' \
            '--driver=[driver]:driver:' \
            '-o+[output]:file:_files' \
            '--output=[output]:file:_files' \
            '*: :_files -g "*.mlw *.why"' && ret=0 ;;
        (*) _files ;;
      esac
    fi ;;
esac

return ret
