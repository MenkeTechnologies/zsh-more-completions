#compdef hfsplus-cat hfsdebug hfsplusutils
# _hfsplus-cat — hfsplusutils hfsplus-cat CLI for reading files from HFS+ Apple Mac OS X Extended file-system volumes by path or CNID node debug catalog read raw HFS+ records (hfsplusutils team, C); getopt
# upstream: https://github.com/AbstractTypeEquals/hfsplus

_hfsplus-cat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-d[debug]' \
        '-r[resource fork]' \
        '--resource[resource fork]' \
        '-D[data fork]' \
        '--data[data fork]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-n+[CNID node id]:n:' \
        '--node=+[CNID node id]:n:' \
        '*:HFS+ path:_files'
}

_hfsplus-cat "$@"
