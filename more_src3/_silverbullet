#compdef silverbullet
# _silverbullet — Zef Hemel SilverBullet end-user-programmable Markdown notebook with Lua and Space Script extensions (silverbulletmd team, TypeScript); custom argparse
# upstream: https://github.com/silverbulletmd/silverbullet

_silverbullet() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--hostname=+[bind host]:host:_hosts' \
        '-L+[bind host]:host:_hosts' \
        '--user=+[user:pass]:str:' \
        '--auth=+[auth file]:file:_files' \
        '--cert=+[tls cert]:file:_files' \
        '--key=+[tls key]:file:_files' \
        '--read-only[read only mode]' \
        '--reindex[force reindex on start]' \
        '--db=+[database path]:file:_files' \
        '--sync-only[sync mode only]' \
        '--shell-backend=+[backend]:b:(local off)' \
        '--http-prefix=+[http prefix]:str:' \
        '--token=+[bearer token]:str:' \
        '--lock-file=+[lock file]:file:_files' \
        '--data=+[data dir]:dir:_files -/' \
        '*:space:_files -/'
}

_silverbullet "$@"
