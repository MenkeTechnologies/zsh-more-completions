#compdef tempo-vulture
# Documentation: https://github.com/grafana/tempo/blob/main/cmd/tempo-vulture/main.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cmd/tempo-vulture/main.go flag definitions).

# tempo-vulture: synthetic trace generator for testing Tempo
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-prometheus-path=[prometheus metrics path]:path:' \
  '-prometheus-listen-address=[prometheus listen address]:addr:' \
  '-tempo-query-url=[Tempo query URL]:url:' \
  '-tempo-push-url=[Tempo push URL]:url:' \
  '-tempo-push-tls[use TLS for push]' \
  '-tempo-org-id=[Tempo org/tenant id]:id:' \
  '-tempo-query-livestore[query the livestore]' \
  '-tempo-write-backoff-duration=[write backoff duration]:duration:' \
  '-tempo-long-write-backoff-duration=[long write backoff duration]:duration:' \
  '-tempo-read-backoff-duration=[read backoff duration]:duration:' \
  '-tempo-search-backoff-duration=[search backoff duration]:duration:' \
  '-tempo-metrics-backoff-duration=[metrics backoff duration]:duration:' \
  '-tempo-retention-duration=[retention duration]:duration:' \
  '-tempo-recent-traces-backoff-duration=[recent traces backoff]:duration:' \
  '-validation-mode[validation-only mode]' \
  '-validation-timeout=[validation timeout]:duration:' \
  '-validation-cycles=[validation cycles]:n:' \
  '*::tempo-vulture args:_files' && ret=0
return ret
