#compdef infratoolbox
# Documentation: https://github.com/infratoolbox/cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# infratoolbox: unified CLI for terraform/terragrunt/tflint/checkov/terraform-docs.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:execute terraform apply'
  'init:run terraform init'
  'plan:generate terraform execution plan'
  'validate:verify terraform configuration syntax'
  'doc:generate documentation via terraform-docs'
  'lint:analyse code using tflint'
  'scan:security scan with checkov'
  'merge:consolidate multiple terraform files'
  'module:create a new module template'
  'env:manage terraform environments'
  'terragrunt:execute terragrunt commands'
  'license:display licensing information'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'infratoolbox command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      apply|init|plan|validate)
        _arguments \
          '*:path:_files -/' && ret=0
        ;;
      doc|lint|scan|merge|module|env|terragrunt)
        _arguments \
          '*:arg:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
