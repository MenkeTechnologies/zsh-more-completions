#compdef inject inject-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/inject.py argparse)
# Reference accessed: 2026-05-29
# inject — kernel-error injection via bpf_override_return on selected call chains (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-I,--include=}'[additional header file to include in BPF program]:header:_files -g "*.h"' \
  '(-P --probability)'{-P,--probability=}'[probability that this call chain will fail (default 1)]:p:' \
  '(-v --verbose)'{-v,--verbose}'[print BPF program]' \
  '(-c --count)'{-c,--count=}'[number of fails before bypassing the override (default -1)]:N:' \
  '1:mode (base kernel function to fail):(kmalloc bio alloc_page)' \
  '2:spec (call chain specification):' \
  && ret=0

return ret
