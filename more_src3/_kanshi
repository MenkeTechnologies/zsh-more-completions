#compdef kanshi
# Documentation: https://manpages.debian.org/testing/kanshi/kanshi.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for kanshi - dynamic display configuration for Wayland

# Corrected from prior file: man page documents -h/-c/-l only; removed
# the undocumented -v/--version and added -l/--listen-fd.
_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '(-l --listen-fd)'{-l,--listen-fd}'[listen on the specified file descriptor for IPC]:fd:'
