#compdef kubectl-pod_inspect
# Documentation: https://github.com/jpriebe/kubectl-pod-inspect
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-pod-inspect lists containers' status, recent events, and recent
# logs for non-ready containers. Documented kubectl-style global flags
# are inherited; positional argument is the pod name.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[kubernetes namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '*:pod name:_default'
