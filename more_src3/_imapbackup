#compdef imapbackup
# Documentation: (no canonical upstream)
# Reference accessed: 2026-05-16
# Verified: there are multiple competing scripts named "imapbackup" (Rui
# Carmo's original Python 2 script, various Python 3 forks, and the Go
# rewrite at github.com/jangko/imapbackup which returned 404 at lookup).
# None ships an authoritative manpage. Without a fixed upstream to verify
# against, a conservative stub is the only honest completion.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# imapbackup: download an entire IMAP account as mbox files
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
