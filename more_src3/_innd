#compdef innd
# Documentation: man innd(8)
# Source: InterNetNews/inn innd/innd.c — NNTP news server daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-4+[bind to IPv4 address]:addr:_default' \
    '-6+[bind to IPv6 address]:addr:_default' \
    '-a[allow any incoming connections]' \
    '-c+[article cutoff age in days]:days:_default' \
    '-d[debug, no fork]' \
    '-f[stay in foreground]' \
    '-H+[max incoming connections per remote host]:N:_default' \
    '-i+[max simultaneous incoming connections]:N:_default' \
    '-l+[max article size]:bytes:_default' \
    '-m+[start mode]:mode:(g p t)' \
    '-N[disable Perl/Python filter]' \
    '-n+[readers-when-stopped]:flag:(n y)' \
    '-o+[max outgoing channels]:N:_default' \
    '-P+[listen port]:port:_default' \
    '-r[renumber active file at startup]' \
    '-s[syntax-check inn.conf and exit]' \
    '-S[read incoming.conf and exit]' \
    '-t+[seconds before timeout]:secs:_default' \
    '-T+[max simultaneous remote connections]:N:_default' \
    '-u[unbuffered logs]' \
    '-X+[seconds before remote sender timeout]:secs:_default' \
    '-Z[disable streaming]' \
    && ret=0

return ret
