#compdef hivexml
# _hivexml — Red Hat libhivex hivexml CLI for converting Windows registry hive binary files SYSTEM SOFTWARE SAM SECURITY DEFAULT NTUSER.DAT into XML representation for inspection diff search programmatic processing (libguestfs team, C); getopt
# upstream: https://github.com/libguestfs/hivex

_hivexml() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-u[output Unicode strings as UTF-8]' \
        '--unsafe[unsafe mode]' \
        '-o+[output file]:file:_files -g "*.xml"' \
        '--output=+[output file]:file:_files -g "*.xml"' \
        '*:hive file:_files -g "SYSTEM SOFTWARE SAM SECURITY DEFAULT NTUSER.DAT *.hive"'
}

_hivexml "$@"
