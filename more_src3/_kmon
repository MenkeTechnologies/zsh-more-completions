#compdef kmon
# Documentation: https://github.com/orhun/kmon/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream orhun/kmon README option table.
# Corrected from prior file: removed invented -s/--sort enum option
# (sort is a SUBCOMMAND with -s/-n/-d flags); added real -E/--regex;
# fixed accent/color value descriptions.

# Zsh completion for kmon (Linux kernel manager and activity monitor)

_kmon() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S -C \
    '(-a --accent-color)'{-a+,--accent-color=}'[set accent color (hex or color name)]:color:' \
    '(-c --color)'{-c+,--color=}'[set main color (hex or color name)]:color:' \
    '(-t --tickrate)'{-t+,--tickrate=}'[set terminal refresh rate in ms]:milliseconds:' \
    '(-r --reverse)'{-r,--reverse}'[reverse the kernel module list]' \
    '(-u --unicode)'{-u,--unicode}'[show Unicode symbols for block titles]' \
    '(-E --regex)'{-E,--regex}'[interpret module search query as a regex]' \
    '(-h --help)'{-h,--help}'[display help information]' \
    '(-V --version)'{-V,--version}'[display version information]' \
    '1:command:(sort)' \
    '*::arg:->args' \
    && ret=0

  case $state in
    args)
      if [[ $line[1] == sort ]]; then
        _arguments -s -S \
          '(-s --size)'{-s,--size}'[sort modules by size]' \
          '(-n --name)'{-n,--name}'[sort modules by name]' \
          '(-d --dependent)'{-d,--dependent}'[sort modules by dependent count]' \
          '(-h --help)'{-h,--help}'[print help information]' && ret=0
      fi
      ;;
  esac

  return ret
}

_kmon "$@"
