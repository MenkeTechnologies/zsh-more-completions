#compdef vgcfgbackup
# _vgcfgbackup — backup volume group descriptor area (LVM2); save VG metadata to text file (default /etc/lvm/backup)
# upstream: https://gitlab.com/lvmteam/lvm2

_vgcfgbackup() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --file)'{-f,--file}'+[output file]:file:_files' \
        '--ignorelockingfailure[ignore lock failures]' \
        '--readonly[read-only access]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:vg:'
}

_vgcfgbackup "$@"
