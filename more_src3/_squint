#compdef squint squint-cljs
# Documentation: https://github.com/squint-cljs/squint/blob/main/src/squint/internal/cli.cljs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed fabricated --config, --imports, --copy-resources, --source-maps,
# --no-source-maps, --main flags that do not exist in upstream cli.cljs.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:compile and run a .cljs file'
  'compile:compile CLJS files to JavaScript'
  'watch:watch :paths in squint.edn and recompile on change'
  'repl:start an interactive console REPL'
  'socket-repl:start a socket-based REPL'
  'nrepl-server:start an nREPL server'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-e+[compile and run an expression]:expr' \
  '--output-dir=[output directory]:dir:_files -/' \
  '--extension=[output file extension]:ext' \
  '*--paths=[source path]:path:_files -/' \
  '--elide-imports[do not emit import statements]' \
  '--elide-exports[do not emit export statements]' \
  '--no-run[skip execution of compiled code]' \
  '--show[print compiled expression]' \
  '--repl[REPL mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'squint command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (compile|run|watch)
        _arguments '*::file:_files -g "*.{cljs,cljc}"' && ret=0 ;;
    esac ;;
esac

return ret
