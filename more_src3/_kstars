#compdef kstars
# Documentation: https://invent.kde.org/education/kstars/-/blob/master/kstars/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream kstars/main.cpp QCommandLineParser setup.
# Removed fabricated --filename/--qwindowicon/--qwindowtitle/--display/
# --platform; added real --paused/--live-stacker; --dump takes the
# output file value directly.

# kstars: KDE desktop planetarium
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--dump=[dump sky image to file]:file:_files' \
  '--script=[script to execute]:file:_files' \
  '--width=[width of sky image]:value:' \
  '--height=[height of sky image]:value:' \
  '--date=[date and time]:string:' \
  '--paused[start with clock paused]' \
  '--live-stacker[run Live Stacker standalone mode]' \
  '*:FITS file:_files' && ret=0
return ret
