#compdef js_of_ocaml
# Documentation: https://github.com/ocsigen/js_of_ocaml/blob/master/compiler/bin-js_of_ocaml/cmd_arg.ml
# Reference accessed: 2026-05-27
# Verified: upstream compiler/bin-js_of_ocaml/ (ocsigen/js_of_ocaml)

# Zsh completion for js_of_ocaml (OCaml bytecode to JavaScript compiler)

local curcontext="$curcontext" state line ret=1

local -a _jsoo_subcommands
_jsoo_subcommands=(
  'compile:compile OCaml bytecode to JavaScript (default)'
  'link:link several JavaScript files together'
  'build-fs:embed files in a js_of_ocaml pseudo filesystem'
  'build-runtime:build a standalone runtime for separate compilation'
  'check-runtime:check the runtime for missing/unused primitives'
  'print-standard-runtime:print the standard runtime to stdout'
)

# Common cmdliner flags from Jsoo_cmdline.Arg (debug/opt/warnings)
local -a _jsoo_common
_jsoo_common=(
  '*--debug=[enable debug section]:section:'
  '*--enable=[enable optimization]:opt:'
  '*--disable=[disable optimization]:opt:'
  '--pretty[pretty print the output]'
  '--debuginfo[output debug information]'
  '--debug-info[output debug information]'
  '--noinline[disable inlining]'
  '--no-inline[disable inlining]'
  '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]'
  '*-w+[enable or disable warnings]:warn:'
  '--Werror[turn all warnings into errors]'
  '--custom-header=[custom header for generated JavaScript]:header:'
  '--build-config[print build-relevant configuration and exit]'
  '--apply-build-config=[override build-relevant configuration]:config:'
  '*--set=[set compiler options (PARAM=VALUE)]:param:'
  '--help[show help]'
  '--help=[show help in format]:fmt:(auto pager groff plain)'
  '--version[print version]'
)

_arguments -C \
  $_jsoo_common \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'js_of_ocaml subcommand' _jsoo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      compile|'')
        _arguments \
          $_jsoo_common \
          '-o+[output file name]:file:_files' \
          '*--load-shape=[load shape file]:file:_files' \
          '--keep-unit-names[keep unit name]' \
          '--opt=[set optimization profile]:level:' \
          '(--noruntime --no-runtime)'{--noruntime,--no-runtime}'[do not include the standard runtime]' \
          '--include-runtime[include partial runtime when compiling cmo/cma]' \
          '(--no-sourcemap --no-source-map)'{--no-sourcemap,--no-source-map}'[do not generate source map]' \
          '(--sourcemap --source-map)'{--sourcemap,--source-map}'[generate source map]' \
          '--source-map-inline[inline sourcemap in the generated JavaScript]' \
          '--source-map-no-source[do not inline sources in source map]' \
          '(--empty-sourcemap --empty-source-map)'{--empty-sourcemap,--empty-source-map}'[always generate empty source maps]' \
          '--source-map-root=[root dir for source map]:dir:_files -/' \
          '--wrap-with-fun=[wrap output JS in a named function or IIFE]:name:' \
          '*--setenv=[set environment variable statically (PARAM=VALUE)]:env:' \
          '--target-env=[runtime compile target]:env:(isomorphic browser nodejs)' \
          '--toplevel[compile a toplevel and embed necessary cmis]' \
          '--export=[file listing units to export in toplevel]:file:_files' \
          '--dynlink[enable dynlink of bytecode files]' \
          '--linkall[link all primitives and compilation units]' \
          '(--nocmis --no-cmis)'{--nocmis,--no-cmis}'[do not include cmis when compiling toplevel]' \
          '*-I+[add directory to include path]:dir:_files -/' \
          '*--file=[register file in the pseudo filesystem]:file:_files' \
          '--extern-fs[allow registering files from outside (default)]' \
          '--no-extern-fs[disallow registering files from outside]' \
          '--ofs=[output the filesystem to file]:file:_files' \
          '--effects=[implementation of effect handlers]:kind:(cps double-translation disabled)' \
          '*:bytecode-or-js:_files' && ret=0
        ;;
      link)
        _arguments \
          $_jsoo_common \
          '-o+[output file name]:file:_files' \
          '(--no-sourcemap --no-source-map)'{--no-sourcemap,--no-source-map}'[do not generate source map]' \
          '(--sourcemap --source-map)'{--sourcemap,--source-map}'[generate source map]' \
          '--source-map-inline[inline sourcemap in the generated JavaScript]' \
          '(--empty-sourcemap --empty-source-map)'{--empty-sourcemap,--empty-source-map}'[always generate empty source maps]' \
          '--source-map-root=[root dir for source map]:dir:_files -/' \
          '--resolve-sourcemap-url=[resolve source map url]:bool:(true false)' \
          '--linkall[link all compilation units]' \
          '-a[build a .cma.js library from .cmo.js files]' \
          '(--dynlink --toplevel)'{--dynlink,--toplevel}'[enable dynlink/toplevel support]' \
          '*:js-files:_files -g "*.js"' && ret=0
        ;;
      build-fs)
        _arguments \
          '-o+[output file name]:file:_files' \
          '*-I+[add directory to include path]:dir:_files -/' \
          '*:files:_files' && ret=0
        ;;
      build-runtime)
        _arguments \
          $_jsoo_common \
          '-o+[output file name]:file:_files' \
          '--toplevel[compile a toplevel and embed necessary cmis]' \
          '(--nocmis --no-cmis)'{--nocmis,--no-cmis}'[do not include cmis when compiling toplevel]' \
          '*--setenv=[set environment variable statically (PARAM=VALUE)]:env:' \
          '--wrap-with-fun=[wrap output JS in a named function or IIFE]:name:' \
          '*--file=[register file in the pseudo filesystem]:file:_files' \
          '--extern-fs[allow registering files from outside (default)]' \
          '--no-extern-fs[disallow registering files from outside]' \
          '--ofs=[output the filesystem to file]:file:_files' \
          '*-I+[add directory to include path]:dir:_files -/' \
          '(--noruntime --no-runtime)'{--noruntime,--no-runtime}'[do not include the standard runtime]' \
          '(--no-sourcemap --no-source-map)'{--no-sourcemap,--no-source-map}'[do not generate source map]' \
          '(--sourcemap --source-map)'{--sourcemap,--source-map}'[generate source map]' \
          '--source-map-inline[inline sourcemap in the generated JavaScript]' \
          '--source-map-no-source[do not inline sources in source map]' \
          '(--empty-sourcemap --empty-source-map)'{--empty-sourcemap,--empty-source-map}'[always generate empty source maps]' \
          '--source-map-root=[root dir for source map]:dir:_files -/' \
          '--target-env=[runtime compile target]:env:(isomorphic browser nodejs)' \
          '--effects=[implementation of effect handlers]:kind:(cps double-translation disabled)' \
          '*:js-files:_files -g "*.js"' && ret=0
        ;;
      check-runtime)
        _arguments \
          '--target-env=[runtime compile target]:env:(isomorphic browser nodejs)' \
          '*:files:_files' && ret=0
        ;;
      print-standard-runtime)
        _arguments '--help[show help]' && ret=0
        ;;
      *)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
