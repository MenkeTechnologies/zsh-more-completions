#compdef upowerd
# Documentation: https://upower.freedesktop.org/docs/upowerd.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# upowerd: UPower D-Bus service for battery/power.
# Per the upstream manpage, the only documented CLI option is --help.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help options]' && ret=0
return ret
