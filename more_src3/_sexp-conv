#compdef sexp-conv
# Documentation: sexp-conv --help
# Source: convert / fingerprint s-expressions via libnettle.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--hash=-[output only the hash]::algorithm:(md5 sha1 sha224 sha256 sha384 sha512 ripemd160 sha3_256 sha3_512)' \
    '(- *)--list-hashes[list available hash algorithms]' \
    '(-s --syntax)'{-s+,--syntax=}'[output syntax]:syntax:(advanced hex transport canonical)' \
    '--once[process only first s-expression]' \
    '(-w --width)'{-w+,--width=}'[base64 line width (0 = no limit)]:width:' \
    '--lock[lock output file]' \
    && ret=0

return ret
