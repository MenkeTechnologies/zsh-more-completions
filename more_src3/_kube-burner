#compdef kube-burner
# Documentation: https://kube-burner.github.io/kube-burner/latest/cli/
# Reference accessed: 2026-05-19
# Verified: kube-burner CLI documentation - subcommands and global
# --log-level; init/index command flags. Replaced bogus
# man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[help for kube-burner]' \
  '--log-level=[logging level]:level:(debug info warn error fatal)' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands
    commands=(
      'init:launch a benchmark (create/delete resources)'
      'index:collect and index metrics for a time range'
      'measure:gather measurements without running a workload'
      'check-alerts:evaluate configured alerts for a time period'
      'destroy:remove objects declared in a config file'
      'health-check:check cluster node status and readiness'
      'import:import a metrics tarball'
      'completion:generate the completion script'
      'version:print the kube-burner version'
    )
    _describe -t commands 'kube-burner command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (init)
        _arguments -s -S \
          '--uuid=[benchmark UUID]:uuid:' \
          '(-c --config)'{-c+,--config=}'[config file path or URL]:file:_files' \
          '--configmap=[configmap name with configuration]:name:' \
          '--namespace=[namespace of the configmap]:namespace:' \
          '--metrics-endpoint=[metrics endpoint file path]:file:_files' \
          '--skip-tls-verify[skip TLS verification for Prometheus]' \
          '--timeout=[global benchmark timeout]:duration:' \
          '--kubeconfig=[kubeconfig file path]:file:_files' \
          '--kube-context=[kubeconfig context name]:context:' \
          '--user-metadata=[user metadata YAML file]:file:_files' \
          '--user-data=[input variables YAML/JSON file]:file:_files' \
          '--allow-missing[allow missing config keys]' \
          '*--set=[override a config value]:keyval:' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
