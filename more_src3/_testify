#compdef testifylint
# _testify — testifylint linter for stretchr/testify usage (Antonin Carette, Go); checks assertion/require pattern correctness
# upstream: https://github.com/Antonboom/testifylint

_testify() {
    _arguments \
        '-V[show version]' \
        '-c+[context lines]:n:' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '-debug+[debug flags]:flags:' \
        '-disable+[disable checkers]:list:(blank-import bool-compare compares contains empty error-is-as error-nil expected-actual float-compare go-require len negative-positive nil-compare require-error suite-broken-parallel suite-dont-use-pkg suite-extra-assert-call suite-method-signature suite-subtest-run suite-thelper useless-assert)' \
        '-enable+[enable checkers]:list:(blank-import bool-compare compares contains empty error-is-as error-nil expected-actual float-compare go-require len negative-positive nil-compare require-error suite-broken-parallel suite-dont-use-pkg suite-extra-assert-call suite-method-signature suite-subtest-run suite-thelper useless-assert)' \
        '-enable-all[enable all checkers]' \
        '-disable-all[disable all]' \
        '-expected-actual.pattern+[regex for expected/actual]:regex:' \
        '-fix[apply rewrites]' \
        '-flags[print analyzer flags]' \
        '-go-require.ignore-http-handlers[ignore HTTP handlers]' \
        '-json[json output]' \
        '-memprofile+[memory profile]:file:_files' \
        '-source[show source]' \
        '-suite-extra-assert-call.mode+[mode]:mode:(remove require)' \
        '-tags+[build tags]:tags:' \
        '-trace+[trace file]:file:_files' \
        '-v[verbose]' \
        '*:packages:'
}

_testify "$@"
