#compdef innbind
# Documentation: man innbind(8)
# Source: InterNetNews/inn backends/innbind.c — bind socket to privileged port for innd (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[force socket creation + descriptor passing (skip bind attempt)]' \
    '*:address (fdnum,family,address,port):_default' \
    && ret=0

return ret
