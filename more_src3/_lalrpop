#compdef lalrpop
# _lalrpop — LALRPOP: LR(1) parser generator for Rust (lalrpop/lalrpop)
# upstream: https://github.com/lalrpop/lalrpop
# Flags from lalrpop/src/main.rs (pico_args).

_lalrpop() {
    local -a args
    args=(
        '(-l --level)'{-l+,--level=}'[debug level]:level:(quiet info verbose debug)'
        '(-o --out-dir)'{-o+,--out-dir=}'[output directory for generated .rs files]:dir:_files -/'
        '--features=[comma-separated feature list for conditional compilation]:features:'
        '(-f --force)'{-f,--force}'[regenerate even when .lalrpop is older than .rs]'
        '(-c --color)'{-c,--color}'[force colored output even when stdout is not a TTY]'
        '--no-whitespace[strip redundant whitespace from the generated file]'
        '--comments[include comments in generated code]'
        '--report[emit .report files alongside generated parsers]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:LALRPOP grammar file:_files -g "*.lalrpop"'
    )
    _arguments -s -S $args
}

_lalrpop "$@"
