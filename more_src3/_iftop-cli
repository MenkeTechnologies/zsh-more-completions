#compdef iftop-cli
# _iftop-cli — Paul Warren iftop display bandwidth usage on interface CLI alias (PaulWarren team, C); custom argparse
# upstream: https://github.com/PaulWarren/iftop

_iftop-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n[no host name resolution]' \
        '-N[no port name resolution]' \
        '-p[promiscuous mode]' \
        '-P[show ports]' \
        '-l[long port display]' \
        '-L+[lines]:n:' \
        '-b[bandwidth bars off]' \
        '-B[Bytes/sec]' \
        '-i+[interface]:_net_interfaces' \
        '-f+[BPF filter]:str:' \
        '-F+[network/mask]:str:' \
        '-G+[ipv6 network/mask]:str:' \
        '-m+[max]:str:' \
        '-c+[config file]:file:_files -g "iftoprc"' \
        '-o+[sort order]:o:(2s 10s 40s source destination)' \
        '-t[text output]' \
        '-s+[seconds]:n:' \
        '-Z[hide source address]' \
        '*:arg:'
}

_iftop-cli "$@"
