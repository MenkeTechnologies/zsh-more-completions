#compdef square-cli square2
# _square-cli — Block Square square-cli CLI command-line frontend wrapping the Square commerce platform REST API managing locations customers orders payments invoices subscriptions catalog items variations inventory loyalty gift-cards refunds disputes terminals devices bookings team-members merchants webhook subscriptions sandbox (Block Square team, Go); cobra
# upstream: https://squareup.com/

_square-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'location:location operations'
        'customer:customer operations'
        'order:order operations'
        'payment:payment operations'
        'invoice:invoice operations'
        'subscription:subscription operations'
        'catalog:catalog operations'
        'item:item operations'
        'variation:variation operations'
        'inventory:inventory operations'
        'loyalty:loyalty operations'
        'gift-card:gift card operations'
        'refund:refund operations'
        'dispute:dispute operations'
        'terminal:terminal operations'
        'device:device operations'
        'booking:booking operations'
        'team:team member operations'
        'merchant:merchant operations'
        'webhook:webhook subscription operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-token=+[token]:str:' \
        '--application-id=+[id]:str:' \
        '--api-url=+[url]:str:' \
        '--environment=+[e]:e:(sandbox production)' \
        '--api-version=+[v]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'square-cli subcommand' sub ;;
        args)
            case $words[1] in
                location|customer|order|payment|invoice|subscription|catalog|item|variation|inventory|loyalty|gift-card|refund|dispute|terminal|device|booking|team|merchant|webhook) _arguments '1:op:(list get create update delete cancel publish search batch-retrieve batch-upsert search-orders calculate-order)' '*:id:' ;;
            esac
            ;;
    esac
}

_square-cli "$@"
