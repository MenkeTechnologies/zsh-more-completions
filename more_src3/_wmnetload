#compdef wmnetload
# Documentation: https://github.com/bbidulock/wmnetload
# Reference accessed: 2026-05-21
# Verified: upstream README documents only -i (interface) and -b (bytes)
# runtime options; previously listed -display/-bg/-fg/-position/-version were
# fabricated and have been removed.

# wmnetload: WMaker dockapp showing network throughput
local curcontext="$curcontext" ret=1
_arguments -C \
  '-i+[interface to monitor]:interface' \
  '-b[display throughput in bytes]' \
  '*::wmnetload args:_files' && ret=0
return ret
