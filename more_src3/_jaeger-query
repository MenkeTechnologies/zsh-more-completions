#compdef jaeger-query
# _jaeger-query — Jaeger Query distributed tracing UI/api server (Jaeger team, Go); spf13/cobra
# upstream: https://github.com/jaegertracing/jaeger

_jaeger-query() {
    local -a sub=(
        'docs:generate docs'
        'env:print environment variables'
        'features:print features'
        'help:show help'
        'status:show server status'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "*.yaml *.yml"' \
        '--span-storage.type=+[span storage type]:type:(cassandra elasticsearch opensearch kafka memory grpc badger blackhole)' \
        '--dependency-storage.type=+[dependency storage type]:type:(cassandra elasticsearch opensearch memory grpc)' \
        '--metrics-backend=+[metrics backend]:b:(prometheus none expvar)' \
        '--metrics-http-route=+[metrics http route]:str:' \
        '--admin.http.host-port=+[admin http host:port]:hostport:' \
        '--query.host-port=+[query host:port]:hostport:' \
        '--query.http.host-port=+[query http host:port]:hostport:' \
        '--query.grpc.host-port=+[query grpc host:port]:hostport:' \
        '--query.base-path=+[query base path]:str:' \
        '--query.static-files=+[static files]:dir:_files -/' \
        '--query.ui-config=+[ui config]:file:_files' \
        '--query.bearer-token-propagation[propagate bearer token]' \
        '--query.additional-headers=+[additional headers]:str:' \
        '--query.max-clock-skew-adjustment=+[max clock skew]:dur:' \
        '--query.log-static-assets-access[log static assets access]' \
        '--query.enable-tracing[enable internal tracing]' \
        '--collector.tags=+[collector process tags]:str:' \
        '--log-level=+[log level]:level:(debug info warn error fatal panic)' \
        '--log-encoding=+[log encoding]:enc:(console json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'jaeger-query subcommand' sub ;;
    esac
}

_jaeger-query "$@"
