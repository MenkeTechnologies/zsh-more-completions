#compdef systemd-quotacheck
# _systemd-quotacheck (systemd wrapper that runs quotacheck(8) at boot when forcequotacheck is set on the kernel command line or systemd-quotacheck.service is unconditionally enabled; takes no positional arguments)
# upstream: https://github.com/systemd/systemd (src/quotacheck)
# Argument shape from systemd src/quotacheck/quotacheck.c on tip.

_systemd-quotacheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-quotacheck "$@"
