#compdef psidtopgm
# Documentation: man psidtopgm (Netpbm)
# Source: convert PostScript image data (psid) to PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    '3:bits per sample:(1 2 4 8)' \
    '4:image data file:_files' \
    && ret=0

return ret
