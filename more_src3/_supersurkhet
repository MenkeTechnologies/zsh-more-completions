#compdef supersurkhet
# Documentation: https://www.npmjs.com/package/@supersurkhet/cli
# Reference accessed: 2026-05-23
# Verified: npm view @supersurkhet/cli description and bin.

# Zsh completion for supersurkhet - Supersurkhet plugin development CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args:' && ret=0

return ret
