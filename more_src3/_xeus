#compdef xeus xeus-zmq
# _xeus — QuantStack Xeus base framework C++ implementation of the Jupyter kernel protocol used by xeus-cling xeus-python (jupyter-xeus team, C++); custom argparse
# upstream: https://github.com/jupyter-xeus/xeus

_xeus() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-f+[connection file]:file:_files -g "*.json"' \
        '--file=+[connection file]:file:_files -g "*.json"' \
        '--connection-file=+[connection file]:file:_files -g "*.json"' \
        '--debug[debug mode]' \
        '--log-level=+[level]:l:(trace debug info warning error critical)' \
        '--log-file=+[log file]:file:_files' \
        '--enable-zmq-trace[enable ZMQ trace]' \
        '--ip=+[IP address]:host:_hosts' \
        '--transport=+[transport]:t:(tcp ipc inproc epgm pgm vmci)' \
        '--signature-scheme=+[scheme]:s:(hmac-sha256 hmac-sha1 hmac-md5)' \
        '--key=+[HMAC key]:str:' \
        '--protocol-version=+[version]:str:' \
        '--shell-port=+[port]:port:_ports' \
        '--control-port=+[port]:port:_ports' \
        '--iopub-port=+[port]:port:_ports' \
        '--hb-port=+[port]:port:_ports' \
        '--stdin-port=+[port]:port:_ports' \
        '--enable-control[enable control channel]' \
        '--enable-shell[enable shell channel]' \
        '--ext-args=+[args]:str:'
}

_xeus "$@"
