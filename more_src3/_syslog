#compdef syslog
# Documentation: man syslog(1) (Apple System Log utility)
# Source: macOS syslog — Apple System Log utility (send / view / control ASL).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show usage]' \
    '(- *)-s[send a log message]' \
    '-r+[remote syslog server]:host:_hosts' \
    '-l+[log level]:level:(0 1 2 3 4 5 6 7 Emergency Alert Critical Error Warning Notice Info Debug)' \
    '*-k+[key/value pair for ASL]:key val:' \
    '(- *)-C[show ASL configuration]' \
    '*-f+[log file to read]:file:_files' \
    '*-d+[log directory to read]:dir:_files -/' \
    '-B[do not buffer output]' \
    '-w+[watch (tail) mode, repeat last N]::n:' \
    '-F+[output format]:format:(raw bsd xml std msg)' \
    '-T+[time format]:format:(sec utc local jdate)' \
    '-E+[encoding format]:format:(safe vis vis-cstyle vis-nl)' \
    '-x+[copy messages to file]:file:_files' \
    '(- *)-c+[show or set per-process filter mask]:process mask:_pids' \
    '(- *)-config[show or set configuration]:option:' \
    '(- *)-module[show or set module options]:name action:' \
    '*:expression:' \
    && ret=0

return ret
