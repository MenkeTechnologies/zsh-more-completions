#compdef s6-sudod
# _s6-sudod — s6 conn-tools s6-sudod (server half of the s6-sudo IPC RPC pair; receives a command, captured env, and stdio descriptors from s6-sudoc over a UCSPI-Unix transport, then runs the command)
# upstream: https://github.com/skarnet/s6
# Flags from src/conn-tools/s6-sudod.c on tip.

_s6-sudod() {
    _arguments \
        '-0[do not pass stdin to the command]' \
        '-1[do not pass stdout to the command]' \
        '-2[do not pass stderr to the command]' \
        '-d[do not forward exit status (always exit 0)]' \
        '-t+[timeout (ms)]:ms:' \
        '*::command-and-args:_command_names -e'
}

_s6-sudod "$@"
