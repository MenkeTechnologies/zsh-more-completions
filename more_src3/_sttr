#compdef sttr
# Documentation: https://github.com/abhimanyu003/sttr
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sttr - string transformer CLI

_sttr() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'ascii85-encode:encode to ascii85'
        'ascii85-decode:decode ascii85'
        'base32-encode:encode to base32'
        'base32-decode:decode base32'
        'base64-encode:encode to base64'
        'base64-decode:decode base64'
        'base85-encode:encode to base85'
        'base85-decode:decode base85'
        'base64url-encode:encode to base64url'
        'base64url-decode:decode base64url'
        'html-encode:encode HTML entities'
        'html-decode:decode HTML entities'
        'rot13-encode:apply ROT13 cipher'
        'url-encode:URL encode'
        'url-decode:URL decode'
        'morse-encode:encode to morse code'
        'morse-decode:decode morse code'
        'bcrypt:generate bcrypt hash'
        'md5:generate MD5 hash'
        'sha1:generate SHA1 hash'
        'sha256:generate SHA256 hash'
        'sha512:generate SHA512 hash'
        'xxh32:generate xxHash 32-bit'
        'xxh64:generate xxHash 64-bit'
        'xxh128:generate xxHash 128-bit'
        'camel:convert to camelCase'
        'kebab:convert to kebab-case'
        'lower:convert to lowercase'
        'pascal:convert to PascalCase'
        'reverse:reverse the string'
        'slug:convert to URL slug'
        'snake:convert to snake_case'
        'title:convert to Title Case'
        'upper:convert to UPPERCASE'
        'count-lines:count number of lines'
        'reverse-lines:reverse line order'
        'shuffle-lines:shuffle lines randomly'
        'sort-lines:sort lines alphabetically'
        'unique-lines:remove duplicate lines'
        'number-lines:add line numbers'
        'remove-spaces:remove all spaces'
        'remove-newlines:remove newline characters'
        'count-chars:count number of characters'
        'count-words:count number of words'
        'hex-rgb:convert hex color to RGB'
        'hex-encode:encode to hex'
        'hex-decode:decode hex'
        'json:format JSON'
        'json-escape:escape JSON string'
        'json-unescape:unescape JSON string'
        'json-yaml:convert JSON to YAML'
        'yaml-json:convert YAML to JSON'
        'json-msgpack:convert JSON to msgpack'
        'msgpack-json:convert msgpack to JSON'
        'markdown-html:render markdown to HTML'
        'extract-emails:extract email addresses'
        'extract-ip:extract IP addresses'
        'extract-urls:extract URLs'
        'escape-quotes:escape quotes in string'
        'zeropad:zero-pad a number'
        'completion:generate shell completion'
        'interactive:run in interactive mode'
        'version:show version'
        'help:show help'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'sttr command' commands
            ;;
        args)
            _arguments -s -S \
                '*:input string or file:_files'
            ;;
    esac
}

_sttr "$@"
