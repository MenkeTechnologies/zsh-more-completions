#compdef ifwatchd
# Documentation: man ifwatchd(8)
# Source: netbsd/src usr.sbin/ifwatchd — interface event watcher daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[script on interface arrival]:arrival script:_files' \
    '-c+[script on carrier present]:carrier script:_files' \
    '-D+[script on interface departure]:departure script:_files' \
    '-d+[script on interface down / address delete]:down script:_files' \
    '(- *)-h[display usage synopsis]' \
    '-i[skip up-script at startup for active interfaces]' \
    '-n+[script on carrier lost]:no-carrier script:_files' \
    '-q[suppress non-error syslog messages]' \
    '-u+[script on interface up / address add]:up script:_files' \
    '-v[verbose debug mode, stay attached to terminal]' \
    '*:interface:_net_interfaces' \
    && ret=0

return ret
