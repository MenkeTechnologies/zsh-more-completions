#compdef tfprovidercheck
# Documentation: https://github.com/suzuki-shunsuke/tfprovidercheck
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,-help,--help}'[help]' \
  '(- *)'{-v,-version,--version}'[version]' \
  '(-c -config --config)'{-c,-config,--config}'+[config file path]:file:_files' && ret=0

return ret
