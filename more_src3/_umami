#compdef umami
# Documentation: https://github.com/umami-software/cli
# Reference accessed: 2026-05-21
# Verified: upstream index.js. Only one command (config) and -v/-h
# aliases exist. Prior file fabricated login/logout/websites/teams/users/
# events/stats subcommands, --server, --token, --output, --website, etc.

local curcontext="$curcontext" state line ret=1

_umami_commands() {
    local -a commands=(
        'config:configures umami'
    )
    _describe -t commands 'umami command' commands
}

_arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:_umami_commands' \
    '*::arg:->args' && ret=0

return ret
