#compdef starboard
# Documentation: https://github.com/aquasecurity/starboard
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Kubernetes-native security toolkit (Aqua). Project superseded by Trivy-Operator.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--cluster=[kubeconfig cluster]:cluster:' \
  '--user=[kubeconfig user]:user:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'version:print version info'
      'init:create custom resource definitions and RBAC'
      'scan:run security weakness identification tools'
      'generate:alias for scan'
      'get:retrieve security reports'
      'report:generate a cluster-wide HTML report'
      'cleanup:delete Kubernetes objects created by starboard'
      'config:manage starboard configuration'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (scan|generate)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:report type:(vulnerabilityreports configauditreports ciskubebenchreports kubehunterreports)' \
          '*:resource:' && ret=0
        ;;
      (get)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-o --output)'{-o,--output=}'[output format]:fmt:(yaml json)' \
          '1:report type:(vulnerabilityreports configauditreports clustercompliancereports)' \
          '*:resource:' && ret=0
        ;;
    esac
    ;;
esac

return ret
