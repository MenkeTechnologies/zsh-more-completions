#compdef system76-power
# Documentation: https://github.com/pop-os/system76-power/blob/master/src/args.rs
# Reference accessed: 2026-05-21
# Verified: upstream system76-power src/args.rs (clap Args enum and subcmds).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'daemon:run the system76-power D-Bus daemon (requires root)'
  'profile:query or set power profile'
  'graphics:graphics management'
  'charge-thresholds:set battery charge thresholds'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'system76-power command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (daemon)
        _arguments \
          '(-q --quiet)'{-q,--quiet}'[suppress logging output]' \
          '(-v --verbose)'{-v,--verbose}'[enable debug-level logging]' && ret=0 ;;
      (profile)
        _values 'profile' 'battery' 'balanced' 'performance' && ret=0 ;;
      (graphics)
        local -a gfx=(
          'compute:integrated graphics with dGPU compute availability'
          'hybrid:PRIME hybrid mode'
          'integrated:integrated graphics only'
          'nvidia:NVIDIA discrete graphics'
          'switchable:detect if system supports graphics switching'
          'power:query or set discrete GPU power state'
        )
        _describe -t gfxcmd 'graphics subcommand' gfx && ret=0 ;;
      (charge-thresholds)
        _arguments \
          '--list-profiles[list available profiles]' \
          '--profile=[set named threshold profile]:p:(full_charge balanced max_lifespan)' \
          '*: :' && ret=0 ;;
    esac ;;
esac

return ret
