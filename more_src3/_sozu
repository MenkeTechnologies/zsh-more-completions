#compdef sozu
# Documentation: https://github.com/sozu-proxy/sozu/blob/main/doc/configure_cli.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(-c --config)'{-c+,--config=}'[path to sozu TOML config]:file:_files -g "*.toml(-.)"' \
  '--help[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'start:Launch the sozu process manager'
      'worker:Run a proxy worker'
      'shutdown:Gracefully stop sozu'
      'status:Display worker and cluster statuses'
      'events:Monitor backend health status changes'
      'top:Launch interactive TUI dashboard'
      'cluster:Cluster management (add, h2 enable/disable)'
      'backend:Backend management (add)'
      'listener:Listener management (http/https add)'
      'frontend:Frontend management (http/https add)'
      'state:Save or load configuration state'
      'query:Query clusters or metrics'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
