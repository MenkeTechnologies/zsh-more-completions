#compdef xtdb-cli xt-cli
# _xtdb-cli — JUXT XTDB bitemporal SQL/Datalog database CLI alias (xtdb team, Clojure); custom argparse
# upstream: https://github.com/xtdb/xtdb

_xtdb-cli() {
    local -a sub=(
        'play:open xt-play repl'
        'shell:open xt shell'
        'sql:run sql query'
        'datalog:run datalog query'
        'tx:submit transaction'
        'submit-tx:submit transaction'
        'fetch:fetch entity'
        'put:put document'
        'delete:delete entity'
        'evict:evict document history'
        'index:index commands'
        'db:db commands'
        'db:create:create database'
        'db:drop:drop database'
        'db:list:list databases'
        'attribute-stats:show attribute stats'
        'status:show node status'
        'sync:wait until indexed'
        'await-tx:await transaction'
        'pull:pull entity tree'
        'open-q:open lazy query'
        'history:entity history'
        'completion:generate completion'
        'help:show help'
        'version:show version'
        'start-node:start xt node'
        'stop-node:stop xt node'
        'compact:compact storage'
        'tx-log:print tx log'
        'load:load edn data'
        'load-jdbc:load jdbc table'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.{yaml,yml,edn,json}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml,edn,json}"' \
        '--url=+[xt url]:url:_urls' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--user=+[user]:user:_users' \
        '-u+[user]:user:_users' \
        '--password=+[password]:str:' \
        '--db=+[database]:str:' \
        '-d+[database]:str:' \
        '--format=+[format]:f:(json edn table csv)' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xtdb subcommand' sub ;;
        args)
            case $words[1] in
                sql|datalog) _arguments \
                    '1:query:' \
                    '--file=+[query file]:file:_files' \
                    '-f+[query file]:file:_files' \
                    '--snapshot-token=+[snapshot]:str:' \
                    '--basis=+[basis]:str:' \
                    '--limit=+[limit]:n:' ;;
                tx|submit-tx|put|delete|evict) _arguments \
                    '1:tx ops or eid:' \
                    '--from=+[file]:file:_files' \
                    '-f+[file]:file:_files' ;;
                fetch|pull|history) _arguments \
                    '1:eid:' \
                    '--at=+[time]:str:' ;;
                db:create|db:drop) _arguments '1:db name:' ;;
                load|load-jdbc) _arguments '1:source:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_xtdb-cli "$@"
