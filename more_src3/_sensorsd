#compdef sensorsd
# Documentation: man sensorsd(8)
# Source: openbsd/src usr.sbin/sensorsd — hardware sensor monitoring daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[check interval in seconds (default 20)]:check:_default' \
    '-d[run in foreground]' \
    '-f+[configuration file (default /etc/sensorsd.conf)]:file:_files' \
    && ret=0

return ret
