#compdef tekton-hub-api
# _tekton-hub-api — Tekton Hub backend API server (Goa-generated REST/gRPC for the Hub catalog)
# upstream: https://github.com/tektoncd/hub
# Flags from api/cmd/api/main.go on tip; additional config via env (HUB_API_CONFIG_FILE_URL, JWT_SIGNING_KEY, GH_RATE_LIMIT, GHE_URL, GHE_TOKEN, CLEANUP_INTERVAL, RECONCILE_INTERVAL).

_tekton-hub-api() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--host=[server host (valid values: localhost)]:host:' \
        '--domain=[host domain name (overrides service design)]:domain:' \
        '--http-port=[HTTP port (overrides service design)]:port:' \
        '--secure[use secure scheme (https or grpcs)]' \
        '--debug[log request and response bodies]'
}

_tekton-hub-api "$@"
