#compdef hp-sendfax
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-sendfax.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-sendfax(1) manpage + deepin-community
# hplip sendfax.py. Note: hp-sendfax does NOT honor the standard -g
# debug flag because it conflicts with --group.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-sendfax: HPLIP fax send utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d+,--device=}'[device URI]:uri:' \
  '(-p --printer)'{-p+,--printer=}'[printer name]:printer:_printers' \
  '(-n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '(-f --faxnum --fax-num --num)'{-f+,--faxnum=,--fax-num=,--num=}'[fax number(s) (with -n)]:nums:' \
  '(-r --recipient)'{-r+,--recipient=}'[recipient(s) (with -n)]:recipients:' \
  '(--group --groups)'{--group=,--groups=}'[group(s) (with -n)]:groups:' \
  '*:file:_files' && ret=0
return ret
