#compdef zhack
# _zhack — OpenZFS zhack (low-level developer-only ZFS poker: subcommands feature stat / feature enable / feature ref / label repair-checksums / label dump bypass normal pool safety; used to fix on-disk corruption manually -d debug, -c cachefile)
# upstream: https://github.com/openzfs/zfs (cmd/zhack)
# Subcommands from openzfs cmd/zhack/zhack.c on tip.

_zhack() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-d+[search dir]:dir:_files -/' \
        '-c+[cachefile]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'zhack command' '(feature label)' ;;
        args)
            case $line[1] in
                feature) _describe -t commands 'feature subcommand' '(stat enable ref)' ;;
                label) _describe -t commands 'label subcommand' '(repair dump)' ;;
            esac
            ;;
    esac
}

_zhack "$@"
