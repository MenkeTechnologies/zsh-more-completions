#compdef lancedb
# _lancedb — LanceDB vector database CLI (LanceDB, Rust); clap-rs
# upstream: https://github.com/lancedb/lancedb

_lancedb() {
    local -a sub=(
        'create:create a table'
        'drop:drop a table'
        'list:list tables'
        'add:add records to a table'
        'query:query a table'
        'search:vector search a table'
        'index:build index'
        'compact:compact files'
        'stats:show stats'
        'optimize:optimize table'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--uri=+[lancedb URI]:uri:' \
        '--api-key=+[api key]:str:' \
        '--region=+[region]:region:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lancedb subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:table:' \
                    '--schema=+[schema file]:file:_files' \
                    '--data=+[data file]:file:_files' \
                    '--mode=+[mode]:mode:(create overwrite append)' ;;
                drop|stats|optimize|compact) _arguments '1:table:' ;;
                list) _arguments '*:arg:' ;;
                add) _arguments \
                    '1:table:' \
                    '--data=+[data file]:file:_files' \
                    '--mode=+[mode]:mode:(append overwrite)' ;;
                query|search) _arguments \
                    '1:table:' \
                    '--filter=+[filter sql]:sql:' \
                    '--limit=+[limit]:n:' \
                    '--vector=+[query vector]:vec:' \
                    '--columns=+[columns]:list:' ;;
                index) _arguments \
                    '1:table:' \
                    '--type=+[index type]:type:(IVF_PQ IVF_HNSW_PQ BTREE BITMAP LABEL_LIST)' \
                    '--num-partitions=+[num partitions]:n:' \
                    '--num-sub-vectors=+[num sub vectors]:n:' \
                    '--column=+[column]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_lancedb "$@"
