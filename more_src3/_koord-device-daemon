#compdef koord-device-daemon
# _koord-device-daemon — Koordinator per-node device-labeling daemon (KDD)
# upstream: https://github.com/koordinator-sh/koordinator
# Flags from cmd/koord-device-daemon/main.go (urfave/cli) on tip.

_koord-device-daemon() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '--oneshot[label once and exit]' \
        '--no-timestamp[do not add timestamp to labels]' \
        '--sleep-interval=[interval between labeling cycles]:dur:' \
        '--prints-output-file=[device info output file path]:file:_files' \
        '--config-file=[KDD config file]:file:_files'
}

_koord-device-daemon "$@"
