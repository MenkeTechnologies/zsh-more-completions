#compdef inset
# Documentation: https://docs.generic-mapping-tools.org/latest/inset.html
# Source: GenericMappingTools/gmt src/inset.c — manage map inset begin/end (C, modern-mode).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[clearance around inset]:clearance:_default' \
    '-N[do not clip what exceeds inset boundaries]' \
    '-D+[inset position+dimensions]:opts:_default' \
    '-F+[panel attributes]:opts:_default' \
    '-M+[inset offset margin]:margin:_default' \
    '*-V[verbose (stackable)]' \
    '1:subcommand:(begin end)' \
    && ret=0

return ret
