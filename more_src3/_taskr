#  talk-desktop (Nextcloud Talk Desktop), radashi-org/radashi (Radashi
#  utility library), cabloy/cabloy (Vona CLI), software-mansion/
#  TypeGPU (TypeGPU WebGPU CLI), kactus-io/kactus (Sketch+Git GUI),
#  jaredpalmer/razzle (Razzle React SSR — 11k stars, deprecated but
#  influential), styleguidist/react-styleguidist (5k stars), lukeed/
#  taskr (mri's own author's task runner, 2.5k stars), cacjs/cac (CAC
#  USES mri INTERNALLY — mri is a transitive dependency of every cac
#  user!), lukeed/sade (SADE ALSO USES mri INTERNALLY — mri powers
#  sade's parsing layer), danmactough/node-feedparser (RSS/Atom/RDF),
#  sheerun/prettier-standard, microlinkhq/html-get, ampproject/amp.
#  dev (Google AMP project), camunda/camunda-modeler, plone/volto
#  (Plone CMS), and HUNDREDS of other Node packages.  mri's wide
#  internal use (sade/cac depend on it) means mri's runtime footprint
#  is in essentially every modern Node CLI.
#
#  mri API:
#    const parse = require('mri')      // ESM: import parse from 'mri'
#
#    const argv = parse(process.argv.slice(2), {
#      alias: {
#        v: 'version',                  // -v aliases to --version
#        h: 'help',
#        m: 'mode',
#        d: 'cwd',
#        _: 'tasks',                    // _ alias renames positionals
#      },
#      default: {                       // default values applied if
#        cwd: '.',                      //   flag not provided
#        mode: 'serial',
#      },
#      boolean: ['help', 'version'],    // force these flags to bool
#      string: ['mode', 'cwd'],         // force these flags to string
#      unknown: key => {                // called on unrecognized flag
#        throw new Error(`Unknown: ${key}`)
#      },
#    });
#    // argv = { _: [...positionals], help: false, mode: 'serial',
#    //          cwd: '.', ... }
#
#  mri distinctive features:
#    - MINIMAL ~120 LOC — fits on one screen, zero dependencies
#    - 5-8x FASTER than minimist — measured 8M args/sec vs minimist's
#      1.5M (per lukeed's mri/bench/index.js suite)
#    - SUBSET of minimist API — drop-in compatible for COMMON usage,
#      but INTENTIONALLY DROPS minimist's expensive features
#    - alias: { short: 'long' } — short-to-long flag aliasing
#    - default: { flag: value } — default values applied when flag
#      not provided
#    - boolean: [...names] — force flags to be parsed as boolean
#      (negation `--no-name` works ONLY for these explicit boolean
#      flags)
#    - string: [...names] — force flags to be parsed as string
#      (prevents Number() coercion of numeric-looking values like
#      "0123" which should stay a string)
#    - unknown: fn(key) — error callback for unrecognized flags
#      (returns false from callback to silently ignore; returns true
#      to keep parsing; throws to abort)
#    - SHORT-CLUSTER `-abc` -> `-a -b -c` automatic
#    - `--flag=value` and `--flag value` both valid
#    - `--` separator stops option parsing (everything after goes
#      verbatim into argv._)
#    - INTENTIONALLY DROPPED from minimist:
#      * `--no-flag` automatic negation (mri requires explicit
#        boolean: list to enable per-flag)
#      * `--key.dotted.path` deep object expansion
#      * `--key=val,val2,val3` comma-split into arrays
#      * `parse-numbers` aggressive numeric coercion
#      * `stopEarly` option (use `--` separator instead)
#    - NO subcommand framework (mri is JUST a parser — sade/cac wrap
#      it for subcommand/help/version generation)
#    - NO automatic --help/--version generation (caller writes the
#      `if (argv.help) { console.log(USAGE); process.exit(0) }`
#      handler — taskr does this in lib/cli/index.js)
#    - DESIGN PHILOSOPHY: lukeed's micro-library doctrine — strip
#      to bare essentials, optimize the hot path, push the rest to
#      caller composition
#  Distinct from R236 Node commander (TJ Holowaychuk's
#  builder-with-subcommand-tree framework — Vue CLI, jest, ngx, etc.),
#  R237 Node Heroku oclif (Heroku's enterprise CLI framework with
#  plugin discovery), R--- Node yargs (Bash-style yargs-parser
#  framework — npm, jest, etc.), R398-ish Node meow (Sindre Sorhus's
#  zero-config flag parser using minimist underneath), R399-ish Node
#  substack/minimist (the ORIGINAL micro-arg-parser — 1.5M args/sec,
#  what mri replaces), R400 Node cac (Anthony Fu's CAC — full
#  command framework that USES MRI INTERNALLY), R403-ish Node
#  TypeScript clipanion (Yarn's class-based CLI framework), R406
#  Node vercel/arg (Vercel's tiny arg parser — different design
#  philosophy from mri: arg uses spec-object-as-schema with built-in
#  type coercion functions, while mri uses minimist-style flat alias
#  map).  TypeScript-Node documented libraries so far: commander,
#  oclif, yargs, meow, minimist, cac, clipanion, gluegun-ish, sade,
#  vercel/arg... mri makes 11.  mri's approach: MINIMAL MINIMIST-
#  COMPATIBLE PARSER with `parse(argv, opts)` single-call API +
#  `alias`/`default`/`boolean`/`string`/`unknown` option keys + 5-8x
#  faster than minimist + ~120 LOC + ZERO dependencies + INTENTIONAL
#  feature omissions (no auto-negation, no dotted-paths, no comma-
#  split, no numeric coercion) + DESIGN PHILOSOPHY: ruthless
#  minimalism + sade/cac/dozens of frameworks build on top of it —
#  corpus's **first documented minimal-minimist-replacement
#  TypeScript-Node CLI library**.  Brings cross-language CLI library
#  taxonomy variant count to 148; TypeScript-Node ecosystem now has
#  11 documented CLI libraries — TYING WITH RUST AND GO at the top
#  of the cross-language taxonomy in a THREE-WAY TIE.
#
#  Surface (verbatim from `packages/taskr/lib/cli/help.js`):
#
#  Usage:
#    taskr [options] [tasks...]
#
#  Options:
#    -m, --mode <MODE>              Run in 'parallel' or 'serial'.
#                                   Default: 'serial'
#    -d, --cwd <DIR>                Set Taskr's home directory.
#                                   Default: '.'
#    -l, --list                     Display all available tasks
#                                   (loads taskfile.js and prints
#                                   the export keys)
#    -v, --version                  Display Taskr's version
#    -h, --help                     Display this help text and exit
#
#  Positional:
#    TASKS...                       Task names to run (must match
#                                   exported keys in taskfile.js).
#                                   Multiple task names run
#                                   according to --mode (parallel or
#                                   serial)
#
#  Examples:
#    taskr                                  # Run default task from taskfile.js
#    taskr build                            # Run "build" task
#    taskr -m parallel test lint            # Run "test" and "lint" in parallel
#    taskr --mode=serial build deploy       # Run "build" then "deploy" serially
#    taskr -d /demo                         # Use /demo as taskr home directory
#    taskr -l                               # List all tasks defined in taskfile.js
#    taskr -v                               # Print version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also mri users):
#    - feedparser (danmactough/node-feedparser RSS/Atom/RDF, 1978
#      stars — FUTURE candidate)
#    - prettier-standard (sheerun/prettier-standard, 867 stars —
#      FUTURE candidate)
#    - db-prices (derhuerst/db-prices-cli, 12 stars — too niche)
#    - html-get (microlinkhq/html-get, 101 stars — FUTURE candidate)
#    - tailwindcss (IN CORPUS — separate completion for the broader
#      tailwindcss tool; v4 CLI uses mri internally)
#    - create-vite (IN CORPUS via _create-vite — Vite scaffolder
#      uses mri internally)
#    - razzle (jaredpalmer/razzle 11k stars — DEPRECATED, replaced by
#      vite/next)
#    - styleguidist (styleguidist/react-styleguidist, 5k stars —
#      FUTURE candidate)
# ============================================================================

_taskr() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[display help text and exit]' \
    '(-v --version)'{-v,--version}'[display Taskr version]' \
    '(-l --list)'{-l,--list}'[display all available tasks]' \
    '(-m --mode)'{-m,--mode}'[run in parallel or serial mode]:mode:(serial parallel)' \
    '(-d --cwd)'{-d,--cwd}'[set Taskr home directory]:dir:_directories' \
    '*:task:'
}

_taskr "$@"
