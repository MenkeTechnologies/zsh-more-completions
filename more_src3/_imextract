#compdef imextract
# _imextract — extract image sub-regions from FITS/IRAF images (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from imextract.c (single-letter getopt-style).

_imextract() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-d+[output directory]:dir:_files -/' \
        '-f[FITS output for IRAF input]' \
        '-h+[HISTORY line to add]:hist:' \
        '-n[echo output filename]' \
        '-o+[output filename]:file:_files' \
        '-s+[replace given character with spaces in arguments]:char:' \
        '-v[verbose output]' \
        '-x+[suffix to add before extension]:suffix:' \
        '*:FITS/IRAF file or region:_files'
}

_imextract "$@"
