#compdef tfplugindocs
# Documentation: https://github.com/hashicorp/terraform-plugin-docs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate provider documentation (default)'
  'validate:validate provider documentation'
  'migrate:migrate legacy documentation'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'tfplugindocs command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '--examples-dir=[examples directory]:dir:_files -/' \
          '--ignore-deprecated=[ignore deprecated resources]:bool:(true false)' \
          '--provider-dir=[provider root]:dir:_files -/' \
          '--provider-name=[provider name]:name' \
          '--providers-schema=[providers schema file]:file:_files' \
          '--rendered-provider-name=[rendered provider name]:name' \
          '--rendered-website-dir=[output docs directory]:dir:_files -/' \
          '--tf-version=[terraform version]:version' \
          '--website-source-dir=[website templates source]:dir:_files -/' \
          '--website-temp-dir=[temporary website dir]:dir:_files -/' && ret=0
        ;;
      (validate)
        _arguments \
          '--allowed-guide-subcategories=[allowed guide subcategories]:list' \
          '--allowed-guide-subcategories-file=[file with allowed guide subcategories]:file:_files' \
          '--allowed-resource-subcategories=[allowed resource subcategories]:list' \
          '--allowed-resource-subcategories-file=[file with allowed resource subcategories]:file:_files' \
          '--provider-dir=[provider root]:dir:_files -/' \
          '--provider-name=[provider name]:name' \
          '--providers-schema=[providers schema file]:file:_files' \
          '--tf-version=[terraform version]:version' && ret=0
        ;;
      (migrate)
        _arguments \
          '--examples-dir=[examples directory]:dir:_files -/' \
          '--provider-dir=[provider root]:dir:_files -/' \
          '--templates-dir=[templates directory]:dir:_files -/' \
          '--provider-name=[provider name]:name' && ret=0
        ;;
    esac
    ;;
esac

return ret
