#compdef libreswan-pluto pluto
# _libreswan-pluto — Libreswan pluto IKEv1 IKEv2 keying daemon CLI for establishing IPsec security associations Kerberos OE AH ESP exchange with X.509 certificate PSK XAUTH EAP NCP cryptohelpers (libreswan team, C); getopt-ish
# upstream: https://libreswan.org/

_libreswan-pluto() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.conf ipsec.conf"' \
        '-c+[file]:file:_files -g "*.conf ipsec.conf"' \
        '--secretsfile=+[file]:file:_files -g "*.secrets ipsec.secrets"' \
        '--ctlbase=+[file]:file:_files' \
        '--nofork[do not daemonize]' \
        '-d[do not daemonize]' \
        '--logfile=+[file]:file:_files' \
        '--use-syslog[use syslog]' \
        '--logappend[append to log file]' \
        '--log-no-time[no time in log]' \
        '--log-no-append[do not append to log]' \
        '--debug=+[mode]:m:(all none control parsing emitting raw cpu memory tmi base)' \
        '--debug-none[no debug]' \
        '--debug-all[all debug]' \
        '--debug-parsing[debug parsing]' \
        '--debug-emitting[debug emitting]' \
        '--debug-control[debug control]' \
        '--debug-raw[debug raw]' \
        '--debug-crypt[debug crypt]' \
        '--debug-private[debug private]' \
        '--listen=+[ip]:str:' \
        '--ikeport=+[port]:n:' \
        '--natikeport=+[port]:n:' \
        '--virtual-private=+[csv]:str:' \
        '--coredir=+[dir]:dir:_files -/' \
        '--vendorid=+[id]:str:' \
        '--pluto-restart-on-crash[restart on crash]' \
        '--seccomp=+[mode]:m:(disabled enabled tolerant)' \
        '--statsd=+[host:port]:str:' \
        '--ddos-mode=+[mode]:m:(auto busy unlimited)' \
        '--global-redirect=+[mode]:m:(yes no auto)' \
        '--ikev1-policy=+[p]:p:(accept reject drop)' \
        '--ikev2-policy=+[p]:p:(accept reject drop)' \
        '--nssdir=+[dir]:dir:_files -/'
}

_libreswan-pluto "$@"
