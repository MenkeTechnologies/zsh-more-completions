#compdef s6-linux-init s6-linux-init-echo s6-linux-init-hpr s6-linux-init-logouthookd s6-linux-init-nuke s6-linux-init-shutdown s6-linux-init-shutdownd s6-linux-init-telinit s6-linux-init-umountall
# Documentation: source-direct extraction from upstream
# skarnet/s6-linux-init src/{init,misc,shutdown}/*.c USAGE strings
# + subgetopt_r option-string specs + skalibs GOL_main gol_bool
# + gol_arg tables + case-arm decoding for the mutex what/subwhat
# action selectors (s6-linux-init-shutdown: 4-way -h/-p/-r/-k
# primary action mutex + 2-way -H/-P secondary mutex; s6-linux-init
# -hpr: 3-way -h/-p/-r action mutex + 2-way -d/-w wtmp-mode mutex).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6-linux-init R124b — 9-stem multi-binary harvest of the
# s6-linux-init pid 1 + shutdown + misc utility binaries. Sister to
# the already-covered s6-linux-init-maker (boot-image generator).
# These compose with R117-R123 s6/s6-rc tooling to form a complete
# init+supervision+shutdown stack as a sysvinit/systemd alternative.

case $service in

  s6-linux-init)
    # Stage-1 pid 1 binary: brings up the early boot environment,
    # then chain-loads the stage-2 environment.
    _arguments -s -S \
      '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level (default 1)]:level:' \
      '(-c --basedir)'{-c+,--basedir=}'[base directory for the boot tree]:basedir:_directories' \
      '(-p --initial-path)'{-p+,--initial-path=}'[initial PATH for stage-2 environment]:path:' \
      '(-s --envdumpdir)'{-s+,--envdumpdir=}'[directory to dump the boot environment into]:dir:_directories' \
      '(-m --umask)'{-m+,--umask=}'[initial umask (octal, default 022)]:umask (octal):' \
      '(-d --slashdev)'{-d+,--slashdev=}'[devtmpfs to mount on /dev (empty = skip)]:fstype:' \
      '(-D --default-runlevel)'{-D+,--default-runlevel=}'[name of the default runlevel (default "default")]:runlevel:' \
      '(-n --no-unmount-slashrun -N --hands-off-slashrun)'{-n,--no-unmount-slashrun}'[do not unmount /run on shutdown]' \
      '(-n --no-unmount-slashrun -N --hands-off-slashrun)'{-N,--hands-off-slashrun}'[do not touch /run at all (already mounted)]' \
      '(-C --container)'{-C,--container}'[run as PID 1 inside a container (skip device init)]' \
      '(-B --no-logger)'{-B,--no-logger}'[do not start the catch-all logger]' \
      '(-W --readiness-fd)'{-W+,--readiness-fd=}'[notify readiness on the given fd]:fd:'
    ;;

  s6-linux-init-telinit)
    # Switch the running s6-linux-init pid 1 to a different runlevel.
    _arguments -s -S \
      '1:runlevel name:'
    ;;

  s6-linux-init-echo)
    # Minimal echo(1) replacement for use in early-boot scripts
    # where /bin/echo may not yet be available. Avoids the
    # busybox/coreutils/bash divergence on -e and escape handling.
    _arguments -s -S \
      '-n[do not print a trailing newline]' \
      '-s+[field separator string (default single space)]:sep:' \
      '*:argument:'
    ;;

  s6-linux-init-logouthookd)
    # Daemon invoked by s6-linux-init to receive user logout
    # notifications and trigger cleanup hooks. No CLI flags.
    _arguments -s -S \
      ': :_default'
    ;;

  s6-linux-init-nuke)
    # SIGKILL every process except pid 1 and itself. Used during
    # shutdown after all services are stopped. No CLI flags.
    _arguments -s -S \
      ': :_default'
    ;;

  s6-linux-init-umountall)
    # Unmount every filesystem in /proc/mounts except devtmpfs,
    # proc, and sysfs (hardcoded MAXLINES=99 ceiling). No CLI flags.
    _arguments -s -S \
      ': :_default'
    ;;

  s6-linux-init-hpr)
    # Low-level halt/poweroff/reboot binary called by
    # s6-linux-init-shutdown after the grace period.
    _arguments -s -S \
      '(-h -p -r)-h[HALT the system]' \
      '(-h -p -r)-p[POWEROFF the system]' \
      '(-h -p -r)-r[REBOOT the system]' \
      '-f[force: skip /run/initctl FIFO write; call reboot(2) directly]' \
      '(-d -w)-d[do NOT write a wtmp/utmp shutdown record]' \
      '(-d -w)-w[ONLY write the wtmp record; do not actually halt/poweroff/reboot]' \
      '-W[do NOT broadcast a wall(1) message to logged-in users]' \
      '-n[do NOT call sync(2) before halting]' \
      '-i[interactively confirm the hostname before proceeding]'
    ;;

  s6-linux-init-shutdown)
    # User-facing shutdown(8) replacement. Schedules a halt /
    # poweroff / reboot at a given time with optional broadcast
    # message. Backwards-compatible with util-linux shutdown.
    _arguments -s -S \
      '(-h -p -r -k -c)-h[HALT the system at the scheduled time]' \
      '(-h -p -r -k -c)-p[POWEROFF the system at the scheduled time]' \
      '(-h -p -r -k -c)-r[REBOOT the system at the scheduled time]' \
      '(-h -p -r -k -c)-k[KICK only: broadcast warning then cancel; do not actually halt]' \
      '(-h -p -r -k)-c[cancel an already-scheduled shutdown]' \
      '(-H -P)-H[after halt: secondary action mode 1 (used with -h)]' \
      '(-H -P)-P[after halt: poweroff (used with -h)]' \
      '(-F)-f[skip fsck on next boot (no-op; kept for util-linux compat)]' \
      '(-f)-F[force fsck on next boot (no-op; kept for util-linux compat)]' \
      '-a[honor /etc/shutdown.allow access-control list]' \
      '-i[interactively confirm the hostname before proceeding]' \
      '-t+[grace time in seconds before sending SIGKILL]:sec:' \
      '1:time spec (now / +mins / hh:mm) or message for -c:' \
      '*:broadcast message:'
    ;;

  s6-linux-init-shutdownd)
    # Long-running daemon that listens for shutdown requests from
    # s6-linux-init-shutdown / s6-linux-init-hpr and orchestrates
    # the shutdown sequence (wall broadcasts, grace period,
    # service shutdown, then chain-load s6-linux-init-hpr).
    _arguments -s -S \
      '-d+[notification fd to write readiness on]:fd:' \
      '-c+[base directory for the boot tree (matches s6-linux-init -c)]:basedir:_directories' \
      '-g+[grace period in ms between SIGTERM and SIGKILL of stragglers]:ms:' \
      '-C[run inside a container (do NOT touch hardware reboot)]' \
      '-B[do NOT use a catch-all logger]'
    ;;

esac
