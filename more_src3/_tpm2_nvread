#compdef tpm2_nvread
# _tpm2_nvread — tpm2-software tpm2_nvread read data from a TPM2 NV index (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_nvread() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[hierarchy or index]:str:' \
        '--hierarchy=+[hierarchy or index]:str:' \
        '-P+[auth password]:str:' \
        '--auth=+[auth password]:str:' \
        '-p+[auth password]:str:' \
        '-s+[size bytes]:n:' \
        '--size=+[size bytes]:n:' \
        '--offset=+[offset]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '-Q[do not output anything]' \
        '--cphash=+[cp hash file]:file:_files' \
        '*:NV index:'
}

_tpm2_nvread "$@"
