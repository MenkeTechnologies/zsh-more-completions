#compdef kde-window-decorator kwin-decoration-test
# _kde-window-decorator — KDE compiz-style window decorator (KDE Project, C++); QCommandLineParser
# upstream: https://invent.kde.org/plasma/kdecoration

_kde-window-decorator() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-all[show all help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--replace[replace running instance]' \
        '--platform=+[Qt platform plugin]:str:' \
        '--no-fade[no fade]' \
        '--blur[enable blur]' \
        '--minimal[minimal theme]' \
        '--reduced-shadow[reduced shadow]' \
        '--shadow-radius=+[shadow radius]:n:' \
        '--shadow-opacity=+[shadow opacity]:f:' \
        '--shadow-x-offset=+[shadow x offset]:n:' \
        '--shadow-y-offset=+[shadow y offset]:n:' \
        '--shadow-color=+[shadow color]:c:' \
        '*:arg:'
}

_kde-window-decorator "$@"
