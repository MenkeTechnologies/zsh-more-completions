#compdef s6-rc-fdholder-filler
# _s6-rc-fdholder-filler — s6-rc fdholder filler (reads an autofilled-filename list from stdin and registers each as an fd-holder placeholder for a future s6-fdholder-daemon)
# upstream: https://github.com/skarnet/s6-rc
# Flags from src/s6-rc/s6-rc-fdholder-filler.c on tip.

_s6-rc-fdholder-filler() {
    _arguments \
        '-1[print to stdout when ready]' \
        '-t+[per-fd timeout (ms)]:ms:'
}

_s6-rc-fdholder-filler "$@"
