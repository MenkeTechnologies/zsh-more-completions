#compdef kgateway
# _kgateway — Kubernetes Gateway API controller (CNCF Sandbox; the Solo.io Gloo Gateway v2 lineage, now open-source under kgateway-dev)
# upstream: https://github.com/kgateway-dev/kgateway
# Flags from cmd/kgateway/main.go on tip (cobra).

_kgateway() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print the kgateway version and exit]'
}

_kgateway "$@"
