#compdef jpackager jpackage
# Documentation: https://docs.oracle.com/en/java/javase/14/docs/specs/man/jpackage.html
# Reference accessed: 2026-05-16
# Verified: Oracle JDK 14+ jpackage(1) docs. NOTE: was jpackager in
# JDK 13 (incubator); shipped as jpackage in JDK 14+. Both names
# accepted via #compdef alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# jpackager: Java native package builder (JDK 14+ name: jpackage)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-t --type)'{-t+,--type=}'[output type]:type:(app-image exe msi rpm deb pkg dmg)' \
  '--app-version=[application version]:version:' \
  '--copyright=[copyright string]:text:' \
  '--description=[application description]:text:' \
  '(-n --name)'{-n+,--name=}'[application name]:name:' \
  '(-d --dest)'{-d+,--dest=}'[destination directory]:dir:_files -/' \
  '--temp=[temporary directory]:dir:_files -/' \
  '--vendor=[vendor name]:name:' \
  '--verbose[verbose output]' \
  '--add-modules=[modules to add]:modules:' \
  '(-p --module-path)'{-p+,--module-path=}'[module path]:path:_files -/' \
  '--bind-services[bind services]' \
  '--runtime-image=[runtime image]:dir:_files -/' \
  '--icon=[icon file]:file:_files' \
  '(-i --input)'{-i+,--input=}'[input directory]:dir:_files -/' \
  '--add-launcher=[additional launcher]:spec:' \
  '--arguments=[default arguments]:args:' \
  '--java-options=[JVM options]:opts:' \
  '--main-class=[main class]:class:' \
  '--main-jar=[main JAR]:file:_files' \
  '(-m --module)'{-m+,--module=}'[main module]:module:' \
  '--app-image=[existing app-image]:dir:_files -/' \
  '--file-associations=[file association props]:file:_files' \
  '--install-dir=[install directory]:dir:' \
  '--license-file=[license file]:file:_files' \
  '--resource-dir=[resource directory]:dir:_files -/' \
  '--win-console[Windows console app]' \
  '--win-dir-chooser[Windows: show install dir chooser]' \
  '--win-menu[Windows Start menu shortcut]' \
  '--win-menu-group=[Windows menu group]:group:' \
  '--win-per-user-install[Windows per-user install]' \
  '--win-shortcut[Windows desktop shortcut]' \
  '--win-upgrade-uuid=[Windows upgrade UUID]:uuid:' \
  '--mac-package-identifier=[macOS package identifier]:id:' \
  '--mac-package-name=[macOS package name]:name:' \
  '--mac-bundle-signing-prefix=[macOS bundle signing prefix]:prefix:' \
  '--mac-sign[macOS code-sign]' \
  '--mac-signing-keychain=[macOS keychain]:path:' \
  '--mac-signing-key-user-name=[macOS signing key user]:user:' \
  '--linux-package-name=[Linux package name]:name:' \
  '--linux-deb-maintainer=[deb maintainer]:email:' \
  '--linux-menu-group=[Linux menu group]:group:' \
  '--linux-package-deps=[package dependencies]:deps:' \
  '--linux-rpm-license-type=[RPM license type]:type:' \
  '--linux-app-release=[Linux app release]:release:' \
  '--linux-app-category=[Linux app category]:category:' \
  '--linux-shortcut[Linux desktop shortcut]' && ret=0
return ret
