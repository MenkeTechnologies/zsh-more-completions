#compdef hifiasm
# Documentation: https://hifiasm.readthedocs.io/en/latest/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hifiasm: haplotype-resolved assembler for PacBio HiFi reads
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-o[output prefix]:prefix:' \
  '-t[number of threads]:n:' \
  '-k[k-mer size]:k:' \
  '-w[minimizer window size]:w:' \
  '-f[bloom filter k]:f:' \
  '-D[skip k-mers with count above N]:n:' \
  '-N[max number of overlaps for each base]:n:' \
  '-r[rounds of haplotype-aware error correction]:n:' \
  '-a[rounds of assembly cleaning]:n:' \
  '-z[length of adapter to trim]:n:' \
  '-m[max length of mash dist for purging]:n:' \
  '-p[max length of mash dist for purging]:n:' \
  '-s[similarity threshold for duplicate-haplotig purging]:val:' \
  '-O[min overlap length]:n:' \
  '-u[disable post-join step for unitig graphs]' \
  '--ul[Ultra-long ONT reads file]:file:_files' \
  '--h1[Hi-C read 1 file (for Hi-C phasing)]:file:_files' \
  '--h2[Hi-C read 2 file]:file:_files' \
  '--n-hap[number of haplotypes (default 2)]:n:' \
  '--primary[output primary/alternate instead of dual haplotypes]' \
  '--ont[Nanopore mode]' \
  '*:HiFi read files:_files -g "*.(fq|fastq|gz|fa|fasta)"' && ret=0
return ret
