#compdef walldns
# _walldns — djbdns walldns (DNS server that serves "thru" addresses: every A query returns the IPv4 encoded into the queried name and every PTR returns the queried name itself; used to publish synthetic in-addr.arpa zones)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from server.c on tip (shared with tinydns/dnscache/axfrdns/rbldns).

_walldns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '-c+[config file path]:file:_files' \
        '-d+[debug level]:n:' \
        '-D[daemonize]' \
        '-l+[log file path]:file:_files' \
        '-p+[pid file path]:file:_files' \
        '-P+[server port (default 53)]:port:'
}

_walldns "$@"
