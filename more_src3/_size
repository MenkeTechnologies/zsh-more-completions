#compdef size
# Documentation: size usage (Darwin size(1))
# Source: size — display object-file section sizes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m[display Mach-O per-section sizes]' \
    '-l[display info about Mach-O load commands]' \
    '-x[display values in hex (with -m)]' \
    '*-arch[restrict to specified architecture]:arch:(i386 x86_64 x86_64h arm64 arm64e ppc ppc64 all)' \
    '*:object file:_files' \
    && ret=0

return ret
