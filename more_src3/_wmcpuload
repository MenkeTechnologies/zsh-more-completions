#compdef wmcpuload
# Documentation: https://manpages.debian.org/bookworm/wmcpuload/wmcpuload.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian bookworm wmcpuload(1) man page OPTIONS list.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --display)'{-d,--display}'+[X display]:display' \
  '(-t --title)'{-t,--title}'+[window title]:title' \
  '(-bl --backlight)'{-bl,--backlight}'[turn on back-light]' \
  '(-lc --light-color)'{-lc,--light-color}'+[backlight color]:color' \
  '(-i --interval)'{-i,--interval}'+[update interval in seconds (default 1)]:seconds' \
  '(-c --cpu)'{-c,--cpu}'+[CPU number to monitor (GNU/Linux, IRIX)]:cpu' \
  '(-n --ignore-nice)'{-n,--ignore-nice}'[disregard nice value]' \
  '(-w --windowed)'{-w,--windowed}'[execute in windowed mode]' \
  '(-wp --windowed-withpanel)'{-wp,--windowed-withpanel}'[windowed mode with background panel]' \
  '(-bw --broken-wm)'{-bw,--broken-wm}'[fix for incompatible window managers]' \
  '(-a --alarm)'{-a,--alarm}'+[alarm threshold percent (0-100, default 90)]:percent' && ret=0

return ret
