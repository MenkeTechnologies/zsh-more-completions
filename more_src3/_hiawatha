#compdef hiawatha
# Documentation: https://www.hiawatha-webserver.org/
# Source: hiawatha.c main() argument parser (Hugo Leisink, GitLab)
# Reference accessed: 2026-05-30
# hiawatha — secure-by-default web server. Defaults: daemonize + read from
# $CONFIG_DIR. Flag set is small (7) — most behavior is driven by the
# config file in /etc/hiawatha (or whatever -c points at).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help and exit]' \
  '(- *)-v[show version and copyright, then exit]' \
  '(- *)-m[list enabled modules and exit]' \
  '(- *)-s[show sandbox information (ENABLE_SANDBOX builds only)]' \
  '(- *)-k[validate configuration and exit (does not start the server)]' \
  '-c+[configuration directory (default $CONFIG_DIR, usually /etc/hiawatha)]:dir:_files -/' \
  '-d[do not daemonize; stay in foreground]' \
  && ret=0

return ret
