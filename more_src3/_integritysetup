#compdef integritysetup
# _integritysetup — cryptsetup integritysetup (manage standalone dm-integrity volumes: format/open/close/status/dump, --integrity selects MAC (crc32c, sha256, hmac-sha256...), --tag-size, --interleave-sectors, --journal-size, --integrity-recalculate, --integrity-key-file for keyed HMACs, --no-wipe)
# upstream: https://gitlab.com/cryptsetup/cryptsetup
# Subcommands from cryptsetup src/integritysetup.c on tip.

_integritysetup() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--integrity+[MAC algorithm]:algo:(crc32 crc32c xxhash64 sha1 sha256 sha384 sha512 hmac-sha256 hmac-sha384 hmac-sha512)' \
        '--tag-size+[tag bytes]:bytes:' \
        '--integrity-key-size+[bytes]:bytes:' \
        '--integrity-key-file+[file]:file:_files' \
        '--journal-size+[bytes]:bytes:' \
        '--interleave-sectors+[bytes]:bytes:' \
        '--sector-size+[bytes]:bytes:' \
        '--allow-discards[allow discards]' \
        '--no-wipe[skip device wipe]' \
        '--integrity-recalculate[recalculate digest]' \
        '--integrity-no-journal[disable journal]' \
        '--integrity-bitmap-mode[use bitmap recovery]' \
        '--integrity-legacy-padding[legacy padding]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'integritysetup command' '(format open close status dump resize)' ;;
        args) _arguments '*:device or name:_files' ;;
    esac
}

_integritysetup "$@"
