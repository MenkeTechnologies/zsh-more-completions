#compdef tparse
# Documentation: https://github.com/mfridman/tparse
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

_arguments -s -S \
  '(-h)-h[show help and exit]' \
  '-version[show version and exit]' \
  '-json[required: run go test with JSON output]' \
  '-all[show passed tests, skipped tests, and elapsed times]' \
  '-pass[display information on passed tests]' \
  '-skip[show skipped tests]' \
  '-file=[read test output from file]:file:_files' \
  '-follow[print raw output as if running go test without -json]' \
  '-smallscreen[format long test names vertically for narrow displays]' \
  '*:packages:_files -/'
