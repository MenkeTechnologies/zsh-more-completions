#compdef watchify
# ---------------------------------------------------------------------------
# watchify — watch mode for browserify builds (Node.js, 1790★)
#
# upstream: https://github.com/browserify/watchify
# author : James Halliday (substack) + browserify-org maintainers
#          original: substack <mail@substack.net>
# license: MIT
#
# Source-direct completion: every watchify-specific flag below is verbatim
# from index.js (`opts.ignoreWatch`, `opts.poll`, `opts.delay`) and bin/cmd.js
# (`-o`, `--outfile`, `-v`, `--verbose`, `--version`) and bin/args.js
# (`--ignore-watch`, `--iw`) on the watchify master tip.  Pass-through
# browserify flags are taken from `browserify/bin/args` since watchify
# loads them via `fromArgs(args, watchify.args)`.
#
# Direct deps from package.json:
#   "chokidar": "^3.4.0"           ← canonical Node fs watcher
#   "browserify": "^17.0.0"
#   "outpipe": "^2.0.0"            (James Halliday substack's pipe-to-shell)
#   "anymatch": "^3.1.2"           (chokidar's matcher; also by paulmillr)
#   "through2": "^4.0.2"
#
# ============================================================================
# === AXIS 151 CLOSES — filesystem-watcher ecosystem ========================
# === TRIPLE-206 ROUND-NUMBER LANDMARK · 144th AXIS CLOSED ==================
# ============================================================================
# Axis position: TS-Node=206 CLOSES Axis 151 at slot 1/1/1 — quadruple-clean
# closure of the canonical filesystem-watcher ecosystem spanning the three
# major systems languages:
#
#     Rust    : notify             by Félix Saparelli (passcod)
#                 → doctave (Niklas Begley, dev docs site generator)
#                 _doctave        [Rust=206 OPENED Axis 151, slot 1/0/0]
#                 cross-platform abstraction over
#                 inotify (Linux) + FSEvents (macOS) + ReadDirectoryChangesW
#
#     Go      : fsnotify/fsnotify  by Nathan Youngman (took over from
#                                   Chris Howey's howeyc/fsnotify archive)
#                 → hotbuild (wandercn, hot recompile tool)
#                 _hotbuild       [Go=206 CONTINUED Axis 151, slot 2/0/0]
#                 cross-platform abstraction over
#                 inotify (Linux) + kqueue (BSD/macOS) + RDCW (Windows)
#
#     JS/Node : chokidar           by Paul Miller (paulmillr) — used by
#                                   Vite, Webpack-dev-server, Parcel,
#                                   Jest, Browser-Sync, Gulp, Storybook
#                 → watchify (James Halliday substack/browserify org)
#                 _watchify       [TS-Node=206 CLOSES Axis 151, slot 1/1/1]
#                                              ↑↑↑ THIS FILE ↑↑↑
#                 wraps native fs.watch/fs.watchFile + fsevents (macOS)
#
# Round-number 206 landmark fires simultaneously across all three lanes:
# Rust completion #206 + Go completion #206 + TS-Node completion #206 =
# triple-206. Axis #144 closed in the lifetime of the corpus.
# ============================================================================

_watchify() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C -s \
        '(-o --outfile)'{-o,--outfile=}'[REQUIRED. Write the browserify bundle to this file (or shell command if contains | or >)]:outfile or shell command:_files' \
        '(-v --verbose)'{-v,--verbose}'[show when a file was written and how long the bundling took (in seconds)]' \
        '--version[show the watchify and browserify versions with their module paths]' \
        '--delay=[amount of time in ms to wait before emitting an update event after a change (default 100)]:milliseconds:' \
        '(--ignore-watch --iw)--ignore-watch=[ignore monitoring files matching this glob (omit value → **/node_modules/**)]:glob pattern:' \
        '(--ignore-watch --iw)--iw=[short for --ignore-watch]:glob pattern:' \
        '--poll=[use polling to monitor for changes (default 100ms, useful on NFS)]:interval ms:' \
        \
        '(-d --debug)'{-d,--debug}'[browserify pass-through: enable source maps]' \
        '*'{-t,--transform=}'[browserify pass-through: apply transform]:transform module name:' \
        '*'{-r,--require=}'[browserify pass-through: expose module externally]:module:' \
        '*'{-x,--exclude=}'[browserify pass-through: omit module from output]:module:' \
        '*'{-i,--ignore=}'[browserify pass-through: replace module with empty module]:module:' \
        '*'{-e,--entry=}'[browserify pass-through: entry point]:entry file:_files' \
        '*'{-p,--plugin=}'[browserify pass-through: register a plugin]:plugin module name:' \
        '*'{-s,--standalone=}'[browserify pass-through: generate a UMD bundle exposing the given name]:name:' \
        '*'{-u,--external=}'[browserify pass-through: reference module from elsewhere]:module:' \
        '*--global-transform=[browserify pass-through: apply transform globally to every package]:transform module:' \
        '--node[browserify pass-through: emit a node-targeted bundle]' \
        '--insert-globals[browserify pass-through: skip global parsing and always insert]' \
        '--insert-global-vars=[browserify pass-through: comma-separated list of globals to insert]:vars:' \
        '--ignore-missing[browserify pass-through: skip ignoring missing files]' \
        '--full-paths[browserify pass-through: preserve full path comments]' \
        '--no-builtins[browserify pass-through: do not use node builtins]' \
        '--no-commondir[browserify pass-through: do not use commondir for paths]' \
        '--no-bundle-external[browserify pass-through: do not bundle external modules]' \
        '--bare[browserify pass-through: alias for --no-builtins --no-commondir]' \
        '--node-version=[browserify pass-through: target node version]:version:' \
        '--browser-field=[browserify pass-through: package.json browser field strategy]:field:(true false)' \
        \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:entry file:_files' && ret=0

    return ret
}

_watchify "$@"
