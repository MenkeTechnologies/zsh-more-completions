#compdef typeoutfileinfo
# Documentation: typeoutfileinfo (TeX Live 2026 fileinfo package)
# Source: print LaTeX \ProvidesFile / \ProvidesPackage / \ProvidesClass info for the given file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:tex file:_files -g "*.(tex|sty|cls|ltx|fd|def|cfg)"' \
    && ret=0

return ret
