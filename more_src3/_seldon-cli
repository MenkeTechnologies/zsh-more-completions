#compdef seldon-cli seldon
# _seldon-cli — Seldon seldon-cli CLI command-line frontend wrapping the Seldon Core and Seldon Core 2 MLOps Kubernetes-native ML model deployment platform managing deployments servers models pipelines experiments inference REST gRPC OpenInference Protocol explainers outlier-detection drift-detection batch infer process (Seldon team, Go); cobra
# upstream: https://www.seldon.io/

_seldon-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'model:model operations'
        'server:server operations'
        'deployment:deployment operations'
        'pipeline:pipeline operations'
        'experiment:experiment operations'
        'inference:run inference'
        'batch:batch inference'
        'explain:explain a prediction'
        'detect:detect outliers/drift'
        'graph:graph operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--scheduler-host=+[host]:_hosts' \
        '--scheduler-port=+[port]:n:' \
        '--insecure[skip TLS verify]' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'seldon-cli subcommand' sub ;;
        args)
            case $words[1] in
                model|server|deployment|pipeline|experiment) _arguments '1:op:(list get load unload start stop create delete update status)' '*:name:' ;;
                inference|explain|detect) _arguments \
                    '--model=+[name]:str:' \
                    '--data=+[json]:str:' \
                    '--data-file=+[file]:file:_files -g "*.json *.yaml *.yml"' \
                    '*:model name:' ;;
                batch) _arguments \
                    '--input-data-path=+[path]:str:' \
                    '--output-data-path=+[path]:str:' ;;
            esac
            ;;
    esac
}

_seldon-cli "$@"
