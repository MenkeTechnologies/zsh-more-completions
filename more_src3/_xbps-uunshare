#compdef xbps-uunshare
# Documentation: https://man.voidlinux.org/xbps-uunshare.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*-b+[bind mount src:dest into chroot]:bind:' \
  '1:chroot_dir:_files -/' \
  '*::command:_command_names' && ret=0

return ret
