#compdef size
# _size-bin — GNU binutils size; print size of sections in object files
# upstream: https://sourceware.org/binutils

_size-bin() {
    _arguments \
        '(-A --format=sysv)'{-A,--format=sysv}'[sysv output]' \
        '(-B --format=berkeley)'{-B,--format=berkeley}'[berkeley output]' \
        '(-G --format=gnu)'{-G,--format=gnu}'[GNU output]' \
        '--common[print common symbols too]' \
        '(-d)-d[print in decimal]' \
        '(-o)-o[print in octal]' \
        '(-x)-x[print in hex]' \
        '(-t --totals)'{-t,--totals}'[print totals]' \
        '--target+[BFD target]:target:' \
        '(-f)-f[print full file path]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:file:_files'
}

_size-bin "$@"
