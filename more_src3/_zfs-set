#compdef zfs-set
# _zfs-set — OpenZFS zfs set set property value CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-set() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-u[do not mount]' \
        '*:property=value dataset:'
}

_zfs-set "$@"
