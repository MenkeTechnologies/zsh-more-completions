#compdef httpstat
# Documentation: https://github.com/reorx/httpstat
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httpstat - visualizes curl(1) statistics in a way of beauty and clarity.
# Accepts any curl(1) flag except -w, -D, -o, -s, -S.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)--help[show help]' \
  '*-H+[add header]:header:' \
  '-d+[request body]:data:' \
  '-k[allow insecure connections]' \
  '-L[follow redirects]' \
  '-X+[request method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '*::url or curl flag:_urls' && ret=0
return ret
