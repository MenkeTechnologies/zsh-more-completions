#compdef wpa_cli wpa_supplicant_cli
# _wpa_cli — wpa_supplicant wpa_cli (interactive control client over the wpa_supplicant control socket; -i interface, -p control socket dir, -a action-script, -B background, -h help, -P pidfile, -G group, -G ifname filter; once inside: scan, scan_results, status, list_networks, add_network, set_network N, save_config, reconfigure, disconnect, reassociate, terminate)
# upstream: https://w1.fi/cgit/hostap (wpa_supplicant)
# Flags from w1.fi/hostap wpa_supplicant/wpa_cli.c on tip.

_wpa_supplicant_cli() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[interface]:interface:_net_interfaces' \
        '-p+[ctrl socket dir]:dir:_files -/' \
        '-a+[action script]:file:_files' \
        '-B[background]' \
        '-P+[pidfile]:file:_files' \
        '-G+[group]:group:_groups' \
        '*::command:_command_names -e'
}

_wpa_supplicant_cli "$@"
