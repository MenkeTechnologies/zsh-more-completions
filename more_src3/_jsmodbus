# ============================================================================
# _jsmodbus — zsh completion for jsmodbus, the canonical Node.js Modbus CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/Cloud-Automation/node-modbus
#   Author     : Stefan Poeter (Cloud-Automation GmbH)
#   License    : MIT
#   Language   : TypeScript
#   npm        : jsmodbus v4.1.0
#   Binary     : jsmodbus  (package.json bin → ./bin/jsmodbus.js)
#   Last push  : 2026-05-12
#
# WHAT IT IS
#   jsmodbus is "Modbus TCP Client/Server implementation for Node.JS" — the
#   canonical npm-published JavaScript/TypeScript Modbus library by
#   Cloud-Automation GmbH (Stefan Poeter), distributed under the package
#   name `jsmodbus` (the GitHub repo is `node-modbus`).  The package ships
#   both the library API and a small Commander-based CLI binary that
#   exposes the four "read" Modbus function codes — fc01 through fc04 —
#   over Modbus TCP.  Each subcommand opens a socket to <host>:<port>,
#   issues the read on the specified <unitId>, decodes the result over the
#   <range> address window, and optionally repeats the request at a
#   configurable interval with transfer-time benchmarking.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/jsmodbus.js Commander chain;
#                       each `program.command(...).description(...)
#                       .option(...).action(...)` block follows the same
#                       per-fc shape)
#   jsmodbus <fc01|fc02|fc03|fc04> <host> <unitId> <range> [OPTIONS]
#
#   Function-code subcommands (Modbus function codes):
#     fc01 <host> <unitId> <range>     Read Coils                  (FC 01)
#     fc02 <host> <unitId> <range>     Read Discrete Inputs        (FC 02)
#     fc03 <host> <unitId> <range>     Read Holding Registers      (FC 03)
#     fc04 <host> <unitId> <range>     Read Input Registers        (FC 04)
#
#   Positional arguments (identical across all four subcommands):
#     <host>             IP address or hostname of the Modbus TCP server
#     <unitId>           Modbus unit ID (slave address), parsed as int
#     <range>            Register address window, "start:end" format
#                        (e.g. "0:10" reads addresses 0..9)
#
#   Options (identical across all four subcommands):
#     -p, --port <port>           Modbus Port                       [default 502]
#     -r, --repeat <time>         Repeat interval in milliseconds
#     -b, --buffer                Print output as buffer (Buffer values
#                                 instead of decoded array)
#     -t, --timeout <timeout>     Connection timeout in milliseconds [default 2000]
#     -bm, --benchmark            Show timestamp benchmark information
#                                 (`transfer=Xms, cue=Yms` after each result)
#     -h, --help                  Commander auto-flag — show help
#         --version               Commander auto-flag — show version
#
# AXIS / CORPUS POSITION
#   This entry IS the canonical Node.js Modbus library + CLI — `jsmodbus`
#   on npm — packaged in the same repository (`Cloud-Automation/node-modbus`).
#   The binary at `bin/jsmodbus.js` imports the library via
#   `const modbus = require('..')` and instantiates clients with
#   `new modbus.client.TCP(socket, unitId, timeout)`.  The library itself
#   is the de-facto reference Modbus implementation across the Node.js
#   industrial-automation ecosystem.  Verified via:
#     gh api repos/Cloud-Automation/node-modbus/contents/package.json
#       → "name": "jsmodbus", "bin": { "jsmodbus": "./bin/jsmodbus.js" }
#     gh api repos/Cloud-Automation/node-modbus/contents/bin/jsmodbus.js
#       → const modbus = require('..')  // self-reference to jsmodbus library
#   This entry is the TS-Node=116 leader bump that CLOSES Axis 61
#   (Modbus Industrial Fieldbus Library) at 1/1/1 three-language symmetry:
#     Rust   = tokio-modbus 0.17 (R833, `tempcol`,         acpiccolo)
#     Go     = goburrow/modbus   (R834, `modbus_exporter`, RichiH)
#     TS-Node = jsmodbus 4.1.0   (R835, `jsmodbus`,        Cloud-Automation)
#   Reaches the triple-116 landmark Rust=Go=TS-Node=116.
#
#   No completion for `jsmodbus` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_jsmodbus() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_jsmodbus_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                fc01|fc02|fc03|fc04)
                    _jsmodbus_fc_args && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_jsmodbus_commands] )) ||
_jsmodbus_commands() {
    local -a commands
    commands=(
        'fc01:Read Coils (Modbus FC 01)'
        'fc02:Read Discrete Inputs (Modbus FC 02)'
        'fc03:Read Holding Registers (Modbus FC 03)'
        'fc04:Read Input Registers (Modbus FC 04)'
    )
    _describe -t commands 'jsmodbus function code' commands
}

(( $+functions[_jsmodbus_fc_args] )) ||
_jsmodbus_fc_args() {
    _arguments \
        '(-p --port)'{-p+,--port=}'[Modbus TCP port (default 502)]:port:' \
        '(-r --repeat)'{-r+,--repeat=}'[repeat interval in milliseconds]:ms:' \
        '(-b --buffer)'{-b,--buffer}'[print output as Buffer instead of decoded array]' \
        '(-t --timeout)'{-t+,--timeout=}'[connection timeout in milliseconds (default 2000)]:ms:' \
        '(-bm --benchmark)'{-bm,--benchmark}'[show transfer/cue timing benchmark info]' \
        '(- *)'{-h,--help}'[help for this function code]' \
        ':Modbus host (IP or hostname):_hosts' \
        ':Modbus unit ID (slave address):' \
        ':register range (start:end, e.g. 0:10):'
}

_jsmodbus "$@"
