#compdef signal-desktop
# Documentation: https://github.com/signalapp/Signal-Desktop
# Reference accessed: 2026-05-16
# Verified: Signal-Desktop GitHub issue tracker (#1965 and #2368) documents
# the only two Signal-specific CLI flags. The app is Electron-based and
# additionally honors the standard Electron/Chromium flag set.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# signal-desktop: Signal messenger desktop client (Electron)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--start-in-tray[launch minimized to system tray]' \
  '--use-tray-icon[show tray icon and hide on close]' \
  '--no-sandbox[disable Chromium sandbox]' \
  '--enable-features=[Chromium feature flags]:features:' \
  '--disable-features=[disable Chromium features]:features:' && ret=0
return ret
