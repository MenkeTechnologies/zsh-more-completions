#compdef kanata-cli
# _kanata-cli — kanata cross-platform keyboard remapper CLI alias (jtroo, Rust); clap-rs
# upstream: https://github.com/jtroo/kanata

_kanata-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cfg=+[config file]:file:_files -g "*.kbd *.lisp"' \
        '-c+[config file]:file:_files -g "*.kbd *.lisp"' \
        '--debug[debug]' \
        '-d[debug]' \
        '--check[check config syntax]' \
        '--port=+[tcp server port]:port:' \
        '-p+[tcp server port]:port:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--symlink-path=+[unix symlink path]:file:_files' \
        '-s+[unix symlink path]:file:_files' \
        '--log-layer-changes[log layer changes]' \
        '--list[list devices]' \
        '-l[list devices]' \
        '--wait[wait for input device]' \
        '-w[wait for input device]' \
        '--nodelay[no delay]' \
        '-n[no delay]' \
        '--log-file=+[log file]:file:_files' \
        '-L+[log file]:file:_files' \
        '--watch[watch config]' \
        '-W[watch config]' \
        '*:arg:'
}

_kanata-cli "$@"
