#compdef strmclip
# Documentation: https://www.klayout.de/
# Source: KLayout/klayout src/buddies/src/bd/strmclip.cc — clip a layout to a rectangle or layer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-l --clip-layer)'{-l+,--clip-layer=}'[layer to take clip regions from]:spec:' \
    '(-t --top-in)'{-t+,--top-in=}'[top cell for input]:cellname:' \
    '(-x --top-out)'{-x+,--top-out=}'[top cell for output]:cellname:' \
    '(-r --rect)'{-r+,--rect=}'[clip box "l,b,r,t"]:l,b,r,t:' \
    '*:input then output file:_files' \
    && ret=0

return ret
