#compdef ippproxy
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/ippproxy.8.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy ippproxy(8) manpage. Section 8.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# ippproxy: IPP infrastructure printer proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '-d[device URI]:uri:' \
  '-p[password]:password:' \
  '-u[username]:user:_users' \
  '*-v[verbose (repeatable)]' \
  '*:infrastructure printer URI:' && ret=0
return ret
