#compdef scrappie
# Documentation: https://github.com/nanoporetech/scrappie
# Source: nanoporetech/scrappie src/scrappie.c — Oxford Nanopore basecaller (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _scrappie_cmds
_scrappie_cmds=(
    'help:show help for scrappie or a subcommand'
    'events:basecall events with a Scrappie model'
    'raw:basecall raw signal with a Scrappie model'
    'licence:print the software licence'
    'version:print the version'
    'squiggle:render expected current signal from a sequence'
    'mappy:reference-aware basecaller (basecall + map)'
    'seqmappy:basecall using mapped fastq + reference'
    'event_table:dump event table'
)

_arguments -C \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'scrappie command' _scrappie_cmds && ret=0
        ;;
esac

return ret
