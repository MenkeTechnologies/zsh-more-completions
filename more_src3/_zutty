#compdef zutty
# _zutty — Zutty (OpenGL-ES-accelerated X11 terminal; -font/-fontsize/-geometry/-fg/-bg, -title, -name, -e command, -display, --boldcolors, --altScroll, --autoCopy, --selectBold/--selectStrong, --shell, --workdir)
# upstream: https://github.com/tomscii/zutty
# Flags from zutty src/options.cc on tip.

_zutty() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-font+[font]:font:' \
        '-fontsize+[font size pt]:size:' \
        '-fontpath+[font path]:dir:_files -/' \
        '-display+[X display]:display:' \
        '-geometry+[WxH]:geom:' \
        '-fg+[foreground color]:color:' \
        '-bg+[background color]:color:' \
        '-title+[window title]:title:' \
        '-name+[window name]:name:' \
        '-shell+[shell]:shell:_files' \
        '-workdir+[working dir]:dir:_files -/' \
        '-e+[run command]:command:_command_names -e' \
        '--boldcolors[bright colors for bold]' \
        '--altScroll[alt-screen mouse scroll]' \
        '--autoCopy[auto-copy selection]' \
        '--shell+[shell]:shell:_files' \
        '*::command:_command_names -e'
}

_zutty "$@"
