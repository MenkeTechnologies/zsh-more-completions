#           port: u16,
#           #[arg(long = "no-color", default_value_t = false)]
#           disable_colors: bool }
#
#   This entry is the Rust=175 leader bump that **OPENS Axis 120
#   (MIDI / IEEE 1639 + ALSA / CoreMIDI / WinMM cross-platform
#   MIDI I/O)** at 1/0/0 following R1057 _dcmjs (TS-Node=174
#   CLOSED Axis 119 DICOM at 1/1/1 triple-174 + 112th axis
#   closed).  Go=175 continuation on deck for R1059 via the
#   canonical Go MIDI library `gomidi/midi` (the dominant Go
#   MIDI stack maintained by Marc René Arns — provides typed
#   `gomidi/midi`, `gomidi/midi/v2`, `gomidi/midi/drivers/
#   midicatdrv`, `gomidi/midi/drivers/portmididrv`, `gomidi/
#   midi/drivers/rtmididrv`, `gomidi/midi/drivers/testdrv`
#   driver packages spanning every major MIDI platform).
#   TS-Node=175 closing pair at R1060 via the canonical
#   Node.js MIDI library `jzz` (Jazz-Soft's reference Node.js
#   MIDI implementation, used by Node-RED MIDI contributions,
#   the Open Stage Control music-control surface, dozens of
#   browser-based DAW prototypes, and the Web MIDI API
#   reference implementation in Chrome's MIDI message router
#   tests).
#
#   No completion for `harmonia` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_harmonia() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--disable-link[do not start Ableton Link connection]' \
        '--open[open UI in default browser after server starts]' \
        '(-i --ip)'{-i,--ip}'=[IP for UI HTTP server (default 0.0.0.0)]:ip:' \
        '(-p --port)'{-p,--port}'=[port for UI HTTP server (default 8080)]:port:' \
        '--no-color[disable colored log output]'
}

_harmonia "$@"
