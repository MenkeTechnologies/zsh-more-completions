#compdef xinput
# Documentation: man xinput(1)
# Source: openbsd/xenocara app/xinput/src/xinput.c (master) — XInput device configuration tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'get-feedbacks:show feedbacks for device'
    'set-ptr-feedback:set pointer feedback (threshold/num/denom)'
    'set-integer-feedback:set integer feedback'
    'get-button-map:show button map'
    'set-button-map:set button map'
    'set-pointer:set pointer (x/y indices)'
    'set-mode:set mode (ABSOLUTE|RELATIVE)'
    'list:list input devices'
    'query-state:show device state'
    'test:show events from device'
    'create-master:create new master device pair'
    'remove-master:remove master device pair'
    'reattach:reattach slave to master'
    'float:make slave floating'
    'set-cp:set client pointer'
    'test-xi2:show XI2 events'
    'map-to-output:map device to RandR output'
    'list-props:list device properties'
    'set-int-prop:set integer property'
    'set-float-prop:set float property'
    'set-atom-prop:set atom property'
    'watch-props:watch property changes'
    'delete-prop:delete property'
    'set-prop:set property (auto-typed)'
)

_arguments -s -C \
    '(--version -version)'{--version,-version}'[show version]' \
    '(--help -help)'{--help,-help}'[show help]' \
    '(--short --long --name-only --id-only)--short[short list output]' \
    '(--short --long --name-only --id-only)--long[long list output]' \
    '(--short --long --name-only --id-only)--name-only[name-only list output]' \
    '(--short --long --name-only --id-only)--id-only[id-only list output]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'xinput command' cmds && ret=0 ;;
esac

return ret
