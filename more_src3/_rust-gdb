#compdef rust-gdb
# Documentation: Rust toolchain rust-gdb (gdb wrapper with Rust pretty-printers)
# Source: Rust rust-gdb — invoke gdb with Python pretty-printers preloaded.
# Reference accessed: 2026-06-10
# NOTE: rust-gdb forwards every flag to gdb; cover only the most-used gdb flags.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show gdb version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet --silent)'{-q,--quiet,--silent}'[do not print banner]' \
    '(-nx -n)'{-nx,-n}'[do not read any .gdbinit files]' \
    '-nh[do not read ~/.gdbinit]' \
    '*-x+[execute gdb commands from file]:file:_files' \
    '*-ex+[execute given gdb command]:gdbcmd:' \
    '*-iex+[execute given gdb command (before -ex)]:gdbcmd:' \
    '-batch[run in batch mode (no prompt)]' \
    '-batch-silent[batch mode but suppress program output]' \
    '-return-child-result[exit with child process status]' \
    '-tui[start gdb in TUI mode]' \
    '(-w --write)'{-w,--write}'[set write permission on executable]' \
    '-pid=[process id to attach]:pid:_pids' \
    '-p+[process id to attach (short form)]:pid:_pids' \
    '-c+[core file to examine]:corefile:_files' \
    '-d+[directory to search for source files]:dir:_files -/' \
    '*-s+[symbol file to read]:symfile:_files' \
    '-e+[executable file]:executable:_files' \
    '-se+[symbol+exe file]:file:_files' \
    '*-ix+[init script (before .gdbinit)]:file:_files' \
    '--data-directory=[gdb data directory]:dir:_files -/' \
    '*:executable then args:_files' \
    && ret=0

return ret
