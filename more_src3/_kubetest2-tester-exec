#compdef kubetest2-tester-exec
# _kubetest2-tester-exec — kubetest2 tester that runs an arbitrary command (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Args from pkg/testers/exec/exec.go.

_kubetest2-tester-exec() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '*::command and args:_command_names -e'
}

_kubetest2-tester-exec "$@"
