#compdef kestra
# _kestra — Kestra unified orchestration platform CLI (Kestra, Java); picocli
# upstream: https://github.com/kestra-io/kestra

_kestra() {
    local -a sub=(
        'server:run server components'
        'flow:manage flows'
        'namespace:manage namespaces'
        'sys:system commands'
        'plugins:manage plugins'
        'configs:manage configs'
        'template:manage templates'
        'restore:restore from backup'
        'storage:manage storage'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--config=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kestra subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '1:component:(local standalone worker scheduler executor webserver indexer)' \
                    '--worker-thread=+[worker threads]:n:' \
                    '--port=+[port]:port:' ;;
                flow) _arguments \
                    '1:cmd:(deploy validate list test run namespace export import)' \
                    '--namespace=+[namespace]:ns:' \
                    '--server=+[server url]:url:_urls' \
                    '--user=+[user]:str:_users' \
                    '--password=+[password]:str:' \
                    '*:file:_files -g "*.yml *.yaml"' ;;
                namespace) _arguments \
                    '1:cmd:(files plugins kv)' \
                    '--namespace=+[namespace]:ns:' \
                    '*:arg:' ;;
                sys) _arguments \
                    '1:cmd:(database flowqueue logqueue triggerqueue purge)' \
                    '*:arg:' ;;
                plugins) _arguments \
                    '1:cmd:(install uninstall list doc)' \
                    '*:arg:' ;;
                configs) _arguments \
                    '1:cmd:(show)' \
                    '*:arg:' ;;
                template) _arguments \
                    '1:cmd:(deploy validate list export import)' \
                    '--namespace=+[namespace]:ns:' \
                    '*:arg:' ;;
                restore) _arguments \
                    '1:cmd:(flow template)' \
                    '*:arg:' ;;
                storage) _arguments \
                    '1:cmd:(list copy delete)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_kestra "$@"
