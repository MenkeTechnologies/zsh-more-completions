#compdef vpa-recommender
# _vpa-recommender — Vertical Pod Autoscaler recommender (kubernetes/autoscaler/vertical-pod-autoscaler)
# upstream: https://github.com/kubernetes/autoscaler/tree/master/vertical-pod-autoscaler
# Flags from pkg/recommender/{main,config/config}.go + common/flags.go on tip.

_vpa-recommender() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--recommender-name=[recommender name (matches VPAs that name it)]:name:' \
        '--recommender-interval=[metric fetch interval]:dur:' \
        '--checkpoints-gc-interval=[orphaned-checkpoint GC interval]:dur:' \
        '--checkpoints-timeout=[checkpoint-write loop timeout]:dur:' \
        '--address=[Prometheus metrics bind address]:host\:port:' \
        '--storage=[VPA storage mode]:storage:(checkpoint prometheus)' \
        '--memory-saver=[track only pods that have a VPA]:bool:(true false)' \
        '--update-worker-count=[concurrent VPA-update workers]:n:' \
        '--recommendation-margin-fraction=[safety margin on recommended request]:f:' \
        '--pod-recommendation-min-cpu-millicores=[min CPU recommendation per pod]:f:' \
        '--pod-recommendation-min-memory-mb=[min memory recommendation per pod]:f:' \
        '--target-cpu-percentile=[CPU percentile for target recommendation]:f:' \
        '--recommendation-lower-bound-cpu-percentile=[CPU lower-bound percentile]:f:' \
        '--recommendation-upper-bound-cpu-percentile=[CPU upper-bound percentile]:f:' \
        '--confidence-interval-cpu=[CPU confidence-multiplier window]:dur:' \
        '--target-memory-percentile=[memory percentile for target recommendation]:f:' \
        '--recommendation-lower-bound-memory-percentile=[memory lower-bound percentile]:f:' \
        '--recommendation-upper-bound-memory-percentile=[memory upper-bound percentile]:f:' \
        '--confidence-interval-memory=[memory confidence-multiplier window]:dur:' \
        '--round-cpu-millicores=[CPU rounding factor (millicores)]:n:' \
        '--round-memory-bytes=[memory rounding factor (bytes)]:n:' \
        '--prometheus-address=[Prometheus server URL]:url:_urls' \
        '--prometheus-insecure[skip TLS verification against Prometheus]' \
        '--prometheus-cadvisor-job-name=[Prometheus cAdvisor scrape job name]:name:' \
        '--history-length=[Prometheus history window]:dur:' \
        '--history-resolution=[Prometheus history resolution]:dur:' \
        '--history-cpu-metric=[Prometheus metric for CPU history]:metric:' \
        '--history-memory-metric=[Prometheus metric for memory history]:metric:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--profiling[expose /debug/pprof endpoints]' \
        '--vpa-object-namespace=[namespace to search VPAs in]:ns:' \
        '--ignored-vpa-object-namespaces=[comma-sep namespaces to ignore]:list:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '-v[klog verbosity level]:n:'
}

_vpa-recommender "$@"
