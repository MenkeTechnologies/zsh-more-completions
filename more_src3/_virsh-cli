#compdef virsh-cli
# _virsh-cli — libvirt virsh CLI alias (Red Hat / libvirt team, C); custom argparse
# upstream: https://github.com/libvirt/libvirt

_virsh-cli() {
    local -a sub=(
        'connect:connect to hypervisor'
        'list:list domains'
        'start:start domain'
        'shutdown:shutdown domain'
        'reboot:reboot domain'
        'destroy:force stop domain'
        'create:create transient domain from xml'
        'define:define persistent domain from xml'
        'undefine:undefine domain'
        'console:open console'
        'edit:edit domain xml'
        'autostart:set autostart'
        'dominfo:show domain info'
        'dommemstat:show memory stats'
        'domstats:show domain stats'
        'domblklist:list block devices'
        'domiflist:list interfaces'
        'snapshot-create:create snapshot'
        'snapshot-list:list snapshots'
        'snapshot-revert:revert to snapshot'
        'snapshot-delete:delete snapshot'
        'attach-device:attach device'
        'detach-device:detach device'
        'attach-disk:attach disk'
        'detach-disk:detach disk'
        'attach-interface:attach interface'
        'detach-interface:detach interface'
        'change-media:change cdrom media'
        'migrate:migrate domain'
        'save:save domain state'
        'restore:restore domain state'
        'managedsave:managed save'
        'managedsave-remove:remove managed save'
        'dump:dump core'
        'screenshot:take screenshot'
        'send-key:send key event'
        'qemu-monitor-command:send qemu monitor command'
        'pool-list:list storage pools'
        'pool-info:show pool info'
        'pool-define:define pool'
        'pool-create:create pool'
        'pool-destroy:destroy pool'
        'pool-undefine:undefine pool'
        'pool-start:start pool'
        'vol-list:list volumes'
        'vol-info:show volume info'
        'vol-create:create volume'
        'vol-delete:delete volume'
        'vol-clone:clone volume'
        'net-list:list networks'
        'net-info:show network info'
        'net-define:define network'
        'net-create:create network'
        'net-destroy:destroy network'
        'net-undefine:undefine network'
        'net-start:start network'
        'nodeinfo:show node info'
        'sysinfo:show sysinfo'
        'capabilities:show hypervisor capabilities'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[connect URI]:str:' \
        '--connect=+[connect URI]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[readonly]' \
        '--readonly[readonly]' \
        '-d+[debug level]:n:(0 1 2 3 4)' \
        '--debug=+[debug level]:n:(0 1 2 3 4)' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '-t[show timing info]' \
        '--timing[show timing info]' \
        '-e+[escape sequence]:str:' \
        '--escape=+[escape sequence]:str:' \
        '-k+[keepalive interval]:n:' \
        '--keepalive-interval=+[keepalive interval]:n:' \
        '-K+[keepalive count]:n:' \
        '--keepalive-count=+[keepalive count]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'virsh subcommand' sub ;;
    esac
}

_virsh-cli "$@"
