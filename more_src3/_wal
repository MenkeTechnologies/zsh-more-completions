#compdef wal
# Documentation: https://github.com/dylanaraps/pywal
# Source: https://github.com/dylanaraps/pywal/blob/master/pywal/__main__.py
# Reference accessed: 2026-06-01
# Binary shipped by both `pywal` and `pywal16` PyPI packages.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _wal_backends
_wal_backends=(wal colorthief colorz haishoku schemer2 modern fast colortillery)

_arguments -s -S \
    '-a+[terminal background transparency (URxvt only)]:alpha:_default' \
    '-b+[custom background color]:color:_default' \
    '--backend=[color generation backend]:backend:('"${_wal_backends[*]}"')' \
    '(--theme -f)'{--theme=,-f+}'[colorscheme file or theme name]:theme:_files' \
    '--iterative[iterate directory images in order]' \
    '--recursive[recurse into image directory]' \
    '--saturate=[color saturation 0.0-1.0]:val:_default' \
    '--preview[print the current color palette]' \
    '--vte[fix text artifacts in VTE terminals]' \
    '-c[delete all cached colorschemes]' \
    '-i+[image or directory]:image:_files' \
    '-l[generate a light colorscheme]' \
    '-n[skip setting the wallpaper]' \
    '*-o+[external script to run after wal]:script:_command_names -e' \
    '-p+[permanently save current theme]:name:_default' \
    '-q[quiet mode]' \
    '-R[restore previous colorscheme]' \
    '-s[skip changing colors in terminals]' \
    '-t[skip changing colors in tty]' \
    '-w[use last used wallpaper for color generation]' \
    '-e[skip reloading gtk/xrdb/i3/sway/polybar]' \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    && ret=0

return ret
