#compdef lrelease
# Documentation: lrelease --help (Qt Linguist)
# Source: compile XML TS translations into QM binaries.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '-idbased[deprecated; ID-based translation]' \
    '-compress[compress QM files]' \
    '-nounfinished[do not include unfinished translations]' \
    '-fail-on-unfinished[error on unfinished translations]' \
    '-fail-on-invalid[fail on validity-check failures]' \
    '-removeidentical[do not include translations identical to source text]' \
    '-markuntranslated+[prefix marker for untranslated strings]:prefix:' \
    '-project+[lupdate-style project file]:file:_files -g "*.lupdate"' \
    '-qm+[output QM file]:file:_files -g "*.qm"' \
    '-silent[silent mode]' \
    '-verbose[verbose output]' \
    '*:ts file:_files -g "*.ts"' \
    && ret=0

return ret
