#compdef yew yew-cli
# _yew — Yew Rust web-framework helper CLI (yewstack/yew)
# upstream: https://github.com/yewstack/yew

_yew() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_yew_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                new)
                    _arguments \
                        '--ssr[scaffold a server-side-rendered Yew project]' \
                        '--csr[scaffold a client-side-rendered Yew project (default)]' \
                        '--template=[starter template to use]:template:(default minimal counter todomvc)' \
                        '1:project name:' && ret=0 ;;
                build|serve|dev)
                    _arguments \
                        '--release[build in release mode]' \
                        '--public-url=[base URL for assets]:url:' \
                        '--dist=[output directory]:dir:_files -/' \
                        '--features=[cargo features (comma-separated)]:features:' \
                        '--no-default-features[disable default cargo features]' \
                        '--port=[serve port (only with serve / dev)]:port:' \
                        '--open[open the browser after starting the dev server]' && ret=0 ;;
                lint|fmt|clippy) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_yew_commands] )) ||
_yew_commands() {
    local -a commands
    commands=(
        'new:scaffold a new Yew project'
        'build:build a Yew project'
        'dev:start the Yew dev server with hot reload'
        'serve:serve a built Yew project'
        'lint:run rustfmt + clippy across the Yew project'
        'fmt:format the Yew project'
        'clippy:run clippy across the Yew project'
    )
    _describe -t commands 'yew command' commands
}

_yew "$@"
