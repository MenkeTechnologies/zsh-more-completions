#compdef lispmtopgm
# Documentation: man lispmtopgm (Netpbm)
# Source: convert a Lisp Machine bitmap file to PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:lispm file:_files' \
    && ret=0

return ret
