#compdef so-sensor so-sensor-ctl
# _so-sensor — Security Onion so-sensor sensor-management CLI for starting stopping checking deploying packet capture stenographer suricata zeek interface configuration on Security Onion sensor nodes (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-sensor() {
    local -a sub=(
        'start:start sensor services'
        'stop:stop sensor services'
        'restart:restart sensor services'
        'status:show sensor status'
        'check:check sensor configuration'
        'reload:reload sensor configuration'
        'enable:enable sensor service'
        'disable:disable sensor service'
        'configure:configure interface'
        'reset:reset sensor state'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-i+[interface]:str:' \
        '--interface=+[interface]:str:' \
        '-s+[service]:s:(suricata zeek stenographer pcap netsniff-ng strelka)' \
        '--service=+[service]:s:(suricata zeek stenographer pcap netsniff-ng strelka)' \
        '-f[force]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-sensor subcommand' sub ;;
        args)
            case $words[1] in
                configure) _arguments \
                    '--mtu=+[N]:n:' \
                    '--promisc[promiscuous]' \
                    '--lro=+[b]:b:(on off)' \
                    '--gro=+[b]:b:(on off)' \
                    '--gso=+[b]:b:(on off)' \
                    '--tso=+[b]:b:(on off)' \
                    '*:interface:' ;;
            esac
            ;;
    esac
}

_so-sensor "$@"
