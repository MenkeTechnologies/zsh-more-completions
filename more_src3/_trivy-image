#compdef trivy-image
# _trivy-image — Aqua Security Trivy container image scanner subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-image() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--insecure[insecure]' \
        '--timeout=+[timeout]:dur:' \
        '--format=+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github cosign-vuln)' \
        '-f+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github cosign-vuln)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--ignore-unfixed[ignore unfixed vulns]' \
        '--exit-code=+[exit code on vuln]:n:' \
        '--exit-on-eol=+[exit code on EOL]:n:' \
        '--ignorefile=+[ignore file]:file:_files' \
        '--skip-files=+[skip files]:list:' \
        '--skip-dirs=+[skip dirs]:list:_files -/' \
        '--include-non-failures[include non failures]' \
        '--vuln-type=+[vuln type]:list:(library os)' \
        '--scanners=+[scanners]:list:(vuln secret misconfig license)' \
        '--security-checks=+[security checks (deprecated)]:list:' \
        '--ignore-policy=+[ignore policy rego]:file:_files -g "*.rego"' \
        '--list-all-pkgs[list all packages]' \
        '--platform=+[platform]:str:' \
        '--server=+[remote scanner server URL]:url:_urls' \
        '--token=+[server token]:str:' \
        '--token-header=+[server token header]:str:' \
        '--custom-headers=+[custom headers]:str:' \
        '--input=+[image tar file]:file:_files -g "*.tar"' \
        '--registry-token=+[registry token]:str:' \
        '--username=+[registry username]:str:_users' \
        '--password=+[registry password]:str:' \
        '--registry-mirrors=+[registry mirrors]:list:' \
        '--image-config-scanners=+[image config scanners]:list:(misconfig secret)' \
        '--docker-host=+[docker host]:str:' \
        '--podman-host=+[podman host]:str:' \
        '--containerd-host=+[containerd host]:str:' \
        '--image-src=+[image source]:src:(docker containerd podman remote)' \
        '--vex=+[vex file/dir]:str:' \
        '--skip-db-update[skip db update]' \
        '--db-repository=+[db repo]:str:' \
        '--java-db-repository=+[java db repo]:str:' \
        '--skip-java-db-update[skip java db update]' \
        '--download-db-only[download db only]' \
        '--download-java-db-only[download java db only]' \
        '--no-progress[no progress]' \
        '--offline-scan[offline scan]' \
        '--compliance=+[compliance spec]:spec:(docker-cis-1.6.0 k8s-cis-1.23 k8s-cis-1.24 k8s-cis-1.7)' \
        '--report=+[report mode]:r:(all summary)' \
        '*:image:'
}

_trivy-image "$@"
