#compdef shellcheck
# _shellcheck-bin — ShellCheck static analysis for shell scripts (Vidar Holen, Haskell); catches common shell bugs
# upstream: https://github.com/koalaman/shellcheck

_shellcheck-bin() {
    _arguments \
        '(-a --check-sourced)'{-a,--check-sourced}'[also follow source statements]' \
        '(-C --color)'{-C,--color}'+[color]:when:(auto always never)' \
        '(-i --include)'{-i,--include}'+[only check codes]:codes:' \
        '(-e --exclude)'{-e,--exclude}'+[exclude codes]:codes:' \
        '(-f --format)'{-f,--format}'+[format]:fmt:(checkstyle diff gcc json json1 quiet tty)' \
        '(-l --list-optional)'{-l,--list-optional}'[list optional checks]' \
        '--norc[skip rc file]' \
        '--rcfile+[rc file]:file:_files' \
        '(-o --enable)'{-o,--enable}'+[enable optional checks]:checks:' \
        '(-P --source-path)'{-P,--source-path}'+[source path]:path:' \
        '(-s --shell)'{-s,--shell}'+[shell]:shell:(sh bash dash ksh busybox bats)' \
        '(-S --severity)'{-S,--severity}'+[min severity]:severity:(error warning info style)' \
        '(-w --wiki-link-count)'{-w,--wiki-link-count}'+[wiki link count]:n:' \
        '(-x --external-sources)'{-x,--external-sources}'[allow external sources]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:file:_files'
}

_shellcheck-bin "$@"
