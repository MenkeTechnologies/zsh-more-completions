#compdef harness-cli
# _harness-cli — Harness modern CD/CI platform CLI alias (harness team, Go); cobra
# upstream: https://github.com/harness/harness-cli

_harness-cli() {
    local -a sub=(
        'login:login'
        'logout:logout'
        'whoami:show current user'
        'account:show account info'
        'application:list:list apps'
        'application:create:create app'
        'application:get:get app'
        'application:delete:delete app'
        'service:list:list services'
        'service:create:create service'
        'service:get:get service'
        'service:delete:delete service'
        'environment:list:list envs'
        'environment:create:create env'
        'environment:get:get env'
        'environment:delete:delete env'
        'pipeline:list:list pipelines'
        'pipeline:create:create pipeline'
        'pipeline:get:get pipeline'
        'pipeline:delete:delete pipeline'
        'pipeline:execute:execute pipeline'
        'pipeline:apply:apply pipeline yaml'
        'pipeline:status:show status'
        'connector:list:list connectors'
        'connector:create:create connector'
        'connector:delete:delete connector'
        'connector:test:test connector'
        'connector:apply:apply connector yaml'
        'gitops:application:list:list apps'
        'gitops:application:get:get app'
        'gitops:application:sync:sync app'
        'gitops:cluster:list:list clusters'
        'gitops:cluster:get:get cluster'
        'secrets:list:list secrets'
        'secrets:create:create secret'
        'secrets:delete:delete secret'
        'projects:list:list projects'
        'projects:create:create project'
        'projects:delete:delete project'
        'projects:get:get project'
        'orgs:list:list organizations'
        'orgs:create:create organization'
        'feature-flag:list:list flags'
        'feature-flag:get:get flag'
        'feature-flag:create:create flag'
        'feature-flag:delete:delete flag'
        'feature-flag:patch:update flag'
        'sto:list:list scans'
        'sto:scan:create:start scan'
        'sto:scan:status:scan status'
        'cv:list:list CV monitored services'
        'cv:get:get CV service'
        'completion:generate completion'
        'help:show help'
        'version:show version'
        'update:update CLI'
        'config:set:set config option'
        'config:get:get config option'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[api key]:str:' \
        '--base-url=+[base url]:url:_urls' \
        '--account-id=+[account id]:str:' \
        '--debug[debug]' \
        '--json[json output]' \
        '--config=+[config file]:file:_files' \
        '--profile=+[profile]:str:' \
        '--no-color[no color]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'harness subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                pipeline:execute) _arguments \
                    '--pipeline-id=+[id]:str:' \
                    '--project-id=+[id]:str:' \
                    '--org-id=+[id]:str:' \
                    '--input-set-id=+[id]:str:' \
                    '--branch=+[branch]:str:' \
                    '--connector-ref=+[ref]:str:' ;;
            esac
            ;;
    esac
}

_harness-cli "$@"
