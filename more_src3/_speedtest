#compdef speedtest
# Documentation: speedtest --help (speedtest-cli 2.1.3)
# Source: command-line bandwidth tester using speedtest.net.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--no-download[do not perform download test]' \
    '--no-upload[do not perform upload test]' \
    '--single[use a single connection (simulate file transfer)]' \
    '--bytes[display values in bytes instead of bits]' \
    '--share[generate a results-image share URL]' \
    '(--simple --csv --json)--simple[only show basic information]' \
    '(--simple --csv --json)--csv[only show basic information as CSV (bit/s)]' \
    '(--simple --csv --json)--json[only show basic information as JSON (bit/s)]' \
    '--csv-delimiter=[single character CSV delimiter (default ,)]:char:' \
    '--csv-header[print CSV headers]' \
    '--list[list speedtest.net servers sorted by distance]' \
    '*--server=[specify a server ID (repeatable)]:server id:' \
    '*--exclude=[exclude a server (repeatable)]:server id:' \
    '--mini=[URL of the Speedtest Mini server]:url:' \
    '--source=[source IP address to bind to]:ip:' \
    '--timeout=[HTTP timeout in seconds (default 10)]:seconds:' \
    '--secure[use HTTPS to speedtest.net servers]' \
    '--no-pre-allocate[do not pre-allocate upload data]' \
    && ret=0

return ret
