#compdef kubectl-volsync
# Documentation: https://github.com/backube/volsync/tree/main/kubectl-volsync
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config-dir=[directory for VolSync config files]:dir:_directories' \
  '--kubeconfig=[paths to a kubeconfig (also via KUBECONFIG env)]:file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'migration:migrate data into a Kubernetes cluster'
      'replication:replicate data between PVCs'
      'help:help about any command'
      'completion:generate the autocompletion script'
    )
    _describe -t commands 'kubectl-volsync command' commands && ret=0
    ;;
  args)
    case $line[1] in
      migration)
        _arguments -s -S '1:subcommand:(create delete rsync)' && ret=0
        ;;
      replication)
        _arguments -s -S '1:subcommand:(create delete schedule set-destination set-source sync)' && ret=0
        ;;
    esac
    ;;
esac

return ret
