#compdef iwconfig
# Documentation: https://manpages.debian.org/iwconfig
# Source: HewlettPackard wireless-tools iwconfig.c — Linux 802.11 wireless extensions tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '1::interface:_net_interfaces' \
    '*:: :->params' \
    && ret=0

case $state in
    params)
        _values 'parameter' \
            'essid[set ESSID / network name]' \
            'nwid[set network ID (pre-802.11)]' \
            'mode[operating mode (Ad-Hoc Managed Master Repeater Secondary Monitor Auto)]' \
            'freq[operating frequency]' \
            'channel[radio channel]' \
            'sens[signal threshold sensitivity]' \
            'ap[force registration with specific Access Point]' \
            'nick[nickname / station name]' \
            'nickname[nickname / station name]' \
            'rate[bit rate]' \
            'bit[bit rate]' \
            'rts[RTS/CTS threshold]' \
            'frag[fragmentation threshold]' \
            'txpower[transmit power]' \
            'enc[encryption mode/key]' \
            'key[encryption key]' \
            'power[power management]' \
            'retry[retry limits/lifetime]' \
            'modu[modulation type]' \
            'commit[apply pending changes to driver]' \
            && ret=0
        ;;
esac

return ret
