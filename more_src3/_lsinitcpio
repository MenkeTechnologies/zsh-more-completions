#compdef lsinitcpio

# Zsh completion for lsinitcpio (list contents of initcpio images)

_arguments -s -S \
  '(-a --analyze)'{-a,--analyze}'[analyze the initcpio image]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-l --list)'{-l,--list}'[list files in the image]' \
  '(-n --nocolor)'{-n,--nocolor}'[disable colorized output]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '(-x --extract)'{-x,--extract}'[extract image contents to current directory]' \
  '1:image file:_files'
