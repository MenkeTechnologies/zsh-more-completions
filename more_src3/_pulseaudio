#compdef pulseaudio
# Documentation: https://manpages.debian.org/pulseaudio.1
# Source: PulseAudio sound daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(- *)--dump-conf[load and parse daemon config, then output it]' \
    '(- *)--dump-modules[list available loadable modules]' \
    '(- *)--dump-resample-methods[list available audio resamplers]' \
    '(- *)--cleanup-shm[remove stale shared-memory segments from /dev/shm]' \
    '(- *)--start[start PulseAudio if not running (implies --daemonize)]' \
    '(- *)'{-k,--kill}'[kill an already running PulseAudio daemon of the calling user]' \
    '(- *)--check[exit 0 if daemon is running for calling user, else non-zero]' \
    '--system=[run as system-wide instance instead of per-user]:bool:(true false)' \
    '(-D --daemonize)'{-D,--daemonize=}'[daemonize after startup (detach from terminal)]:bool:(true false)' \
    '--fail=[fail startup if any default.pa command fails]:bool:(true false)' \
    '--high-priority=[acquire a high Unix nice level]:bool:(true false)' \
    '--realtime=[acquire RT scheduling for IO threads]:bool:(true false)' \
    '--disallow-module-loading=[prevent module loading after startup]:bool:(true false)' \
    '--disallow-exit=[disallow user-requested exit]:bool:(true false)' \
    '--exit-idle-time=[terminate after last client + N seconds]:seconds:' \
    '--scache-idle-time=[unload cached samples after N seconds idle]:seconds:' \
    '--log-level=[verbosity level 0-4 (error..debug)]:level:(0 1 2 3 4)' \
    '*'{-v,--verbose}'[increase verbosity by one]' \
    '--log-target=[logging destination]:target:(auto syslog journal stderr file:/path newfile:/path)' \
    '--log-meta=[show source code location in log messages]:bool:(true false)' \
    '--log-time=[show timestamps in log messages]:bool:(true false)' \
    '--log-backtrace=[stack-trace frames per message]:frames:' \
    '(-p --dl-search-path)'{-p+,--dl-search-path=}'[plugin search path]:path:_directories' \
    '--resample-method=[default audio resampler]:method:(src-sinc-best-quality src-sinc-medium-quality src-sinc-fastest src-zero-order-hold src-linear trivial speex-float-0 speex-float-1 speex-float-2 speex-float-3 speex-float-4 speex-float-5 speex-float-6 speex-float-7 speex-float-8 speex-float-9 speex-float-10 speex-fixed-0 speex-fixed-1 speex-fixed-2 speex-fixed-3 speex-fixed-4 speex-fixed-5 speex-fixed-6 speex-fixed-7 speex-fixed-8 speex-fixed-9 speex-fixed-10 ffmpeg auto copy peaks)' \
    '--use-pid-file=[create a PID file]:bool:(true false)' \
    '--no-cpu-limit=[do not install CPU load limiter]:bool:(true false)' \
    '--disable-shm=[disable shared memory; sockets only]:bool:(true false)' \
    '--enable-memfd=[use memfd for audio data exchange with clients]:bool:(true false)' \
    '*'{-L,--load=}'[load plugin module with arguments]:module args:' \
    '(-F --file)'{-F+,--file=}'[run script on startup]:file:_files' \
    '-C[open command interpreter on stdin/stdout after startup]' \
    '-n[do not load default script file at startup]' \
    && ret=0

return ret
