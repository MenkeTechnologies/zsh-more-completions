#compdef shake-cli
# _shake-cli — Neil Mitchell Shake Haskell build system CLI alias (Neil Mitchell, Haskell); custom argparse
# upstream: https://github.com/ndmitchell/shake

_shake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--abbrev=+[abbreviation]:list:' \
        '--color=+[color]:c:(auto always never)' \
        '--demand=+[demand]:list:' \
        '--digest=+[digest]:m:(auto warn legacy)' \
        '--exception[exception]' \
        '--flush=+[flush ms]:n:' \
        '--keep-going[keep going on errors]' \
        '-k[keep going on errors]' \
        '--lint=+[lint]:l:(none warn errors)' \
        '--lint-fsatrace=+[lint fsatrace]:l:(none warn errors)' \
        '--lint-watch=+[lint watch]:l:(none warn errors)' \
        '--live=+[live file]:file:_files' \
        '--metadata=+[metadata dir]:dir:_files -/' \
        '-d+[metadata dir]:dir:_files -/' \
        '--never-files=+[never files]:list:' \
        '--no-build[no build]' \
        '--no-time[no time]' \
        '--numeric-version[print version]' \
        '--parallel=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--profile=+[profile file]:file:_files' \
        '--progress=+[progress mode]:m:(none simple full record replay)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--quiet-progress[quiet progress]' \
        '--rebuild[rebuild]' \
        '-B[rebuild]' \
        '--rebuild-fail=+[rebuild on failure]:list:' \
        '--report=+[report file]:file:_files' \
        '--silent[silent]' \
        '-s[silent]' \
        '--storage=+[storage db]:file:_files' \
        '--threads=+[threads]:n:' \
        '--timings[timings]' \
        '-t[timings]' \
        '--trace=+[trace categories]:list:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--write-flat=+[write flat]:file:_files' \
        '--no-rebuild[no rebuild]' \
        '*:target:'
}

_shake-cli "$@"
