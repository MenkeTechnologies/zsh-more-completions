#compdef kine
# Documentation: https://github.com/k3s-io/kine/blob/master/pkg/app/app.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: removed fabricated --datastore-endpoint,
# --datastore-cafile, --datastore-certfile, --datastore-keyfile (no
# such flags). Added real flags from app.go: --skip-verify,
# --log-format, --trusted-ca-file, slow-sql/metrics/compact flags.
# urfave/cli auto-adds --help and --version (no -h/-v shorts).

_kine() {
  _arguments \
    '--help[Show help]' \
    '--version[Print the version]' \
    '--listen-address=[etcd listen address]:address:' \
    '--endpoint=[Storage endpoint (default is sqlite)]:endpoint:' \
    '--ca-file=[CA cert for DB connection]:file:_files' \
    '--cert-file=[Certificate for DB connection]:file:_files' \
    '--key-file=[Key file for DB connection]:file:_files' \
    '--skip-verify[Whether the TLS client should verify the server certificate]' \
    "--log-format=[Log format to use ('plain' or 'json')]:format:(plain json)" \
    '--metrics-bind-address=[Address the metric endpoint binds to]:address:' \
    '--server-cert-file=[Certificate for etcd connection]:file:_files' \
    '--server-key-file=[Key file for etcd connection]:file:_files' \
    '--trusted-ca-file=[CA certificate for verifying client certificates]:file:_files' \
    '--datastore-max-idle-connections=[Maximum number of idle connections retained by datastore]:count:' \
    '--datastore-max-open-connections=[Maximum number of open connections used by datastore]:count:' \
    '--datastore-connection-max-lifetime=[Maximum amount of time a connection may be reused]:duration:' \
    '--slow-sql-threshold=[Duration over which slow SQL is logged at info]:duration:' \
    '--slow-sql-warning-threshold=[Duration over which slow SQL is logged at warn]:duration:' \
    '--metrics-enable-profiling[Enable net/http/pprof handlers on the metrics bind address]' \
    '--metrics-ignore-tls-config[Ignore TLS config for metrics server]' \
    '--watch-progress-notify-interval=[Interval between periodic watch progress notifications]:duration:' \
    '--emulated-etcd-version=[Emulated etcd version returned on the status endpoint]:version:' \
    '--compact-interval=[Interval between compaction runs]:duration:' \
    '--compact-interval-jitter=[Jitter applied to the compaction interval]:duration:' \
    '--compact-timeout=[Timeout for a compaction run]:duration:' \
    '--compact-min-retain=[Minimum number of revisions to retain]:count:' \
    '--compact-batch-size=[Compaction batch size]:count:' \
    '--poll-batch-size=[Poll batch size]:count:' \
    '--debug[Enable debug logging]'
}

_kine "$@"
