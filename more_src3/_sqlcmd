#compdef sqlcmd
# Documentation: https://learn.microsoft.com/en-us/sql/tools/sqlcmd/sqlcmd-utility
# Reference accessed: 2026-05-21
# Verified: Microsoft Learn sqlcmd utility reference (go-mssqldb modern).
# Removed: -T as "trust server certificate" (collides with -C; -T is not a
# valid sqlcmd option). Added: -F, -j, -N, -D, -J, plus long options.

# Zsh completion for sqlcmd - Microsoft SQL Server command-line utility

_arguments -s -S \
  '-a+[packet size]:packet size:' \
  '-A[dedicated administrator connection]' \
  '-b[terminate batch job on error]' \
  '-c+[batch terminator]:terminator:' \
  '-C[trust server certificate]' \
  '-d+[database to use]:database:' \
  '-D[connect via DAC (Dedicated Admin Connection)]' \
  '-e[echo input]' \
  '-E[use trusted (integrated) connection]' \
  '-f+[code page]:codepage:' \
  '-F+[hostname in certificate]:hostname:' \
  '-g[enable column encryption]' \
  '-G[use Azure Active Directory authentication]' \
  '-h+[rows between column headers]:headers:' \
  '-H+[client workstation name]:hostname:' \
  '-i+[input file]:file:_files' \
  '-I[enable quoted identifiers]' \
  '-j[print raw error messages]' \
  '-J+[server certificate file]:file:_files' \
  '-K+[application intent]:intent:(ReadOnly ReadWrite)' \
  '-l+[login timeout seconds]:seconds:' \
  '-m+[error level]:level:' \
  '-M+[multi-subnet failover]:option:' \
  '-N+[encrypt connection]:mode:(s m o)' \
  '-o+[output file]:file:_files' \
  '-p[print performance statistics]' \
  '-P+[password]:password:' \
  '-q+[startup query]:query:' \
  '-Q+[query then exit]:query:' \
  '-r+[redirect error messages]:stream:(0 1)' \
  '-R[use client regional settings]' \
  '-s+[column separator]:separator:' \
  '-S+[server (protocol:server,port)]:server:' \
  '-t+[query timeout seconds]:seconds:' \
  '-u[Unicode output]' \
  '-U+[login user]:user:' \
  '*-v+[create scripting variable]:variable:' \
  '-V+[severity level to report]:level:' \
  '-w+[screen width]:width:' \
  '-W[remove trailing spaces]' \
  '-x[disable variable substitution]' \
  '-X[disable interactive commands]' \
  '-y+[display width for variable columns]:width:' \
  '-Y+[display width for fixed columns]:width:' \
  '-z+[new password]:password:' \
  '-Z+[new password and exit]:password:' \
  '-?[show syntax summary]' \
  '--authentication-method=[Azure SQL authentication method]:method:' \
  '--driver-logging-level=[mssql driver log level]:level:' \
  '--vertical[print results in vertical format]' \
  '--sqlconfig=[configuration file path]:file:_files' \
  '--verbosity=[log level 0-4]:level:(0 1 2 3 4)' \
  '--version[print version]'
