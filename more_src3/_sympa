#compdef sympa
# _sympa — Sympa mailing-list manager admin CLI (sympa-community/sympa)
# upstream: https://github.com/sympa-community/sympa
# Subcommands from src/sbin/sympa.pl.in POD.

_sympa() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config=[path to sympa.conf]:file:_files -g "*.conf"' \
        '--robot=[mail virtual robot domain]:domain:' \
        '--lang=[interface language]:lang:' \
        '--mail[output sent through MTA]' \
        '--debug[debug output]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_sympa_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                add|del|review|set|user|review)
                    _arguments \
                        '1:list@domain:' \
                        '*:email:' && ret=0 ;;
                create|close|open|move|copy|del|review|export_list|reload_list_config|sync_list_db|restore|update|dump|rebuildarc|send_digest)
                    _arguments \
                        '1:list@domain:' \
                        '*:flag:' && ret=0 ;;
                config)
                    _arguments \
                        '1: :(show diff cast update help)' \
                        '*:config arg:' && ret=0 ;;
                upgrade)
                    _arguments \
                        '1: :(password shared sympa)' && ret=0 ;;
                help)
                    _arguments \
                        '1:topic / subcommand:' && ret=0 ;;
                check|bouncers|include|instantiate|lowercase|make_alias_file|md5_digest|show_pending_lists|test|upgrade_config_location|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_sympa_commands] )) ||
_sympa_commands() {
    local -a commands
    commands=(
        'add:subscribe one or more users to a list'
        'bouncers:show / manage bounced subscribers'
        'check:check the Sympa configuration / installation'
        'close:close (deactivate) a mailing list'
        'config:manage Sympa configuration (show / diff / cast / update)'
        'copy:copy a list (alias of move)'
        'create:create a new mailing list'
        'del:unsubscribe one or more users from a list'
        'dump:dump the list configuration / subscribers'
        'export_list:export a list (configuration + subscribers)'
        'help:show help for a subcommand'
        'include:run the data-source include / sync'
        'instantiate:instantiate a family of mailing lists'
        'lowercase:normalize subscriber email addresses to lowercase'
        'make_alias_file:regenerate the MTA aliases file'
        'md5_digest:print the MD5 token for an email'
        'move:rename / move a list'
        'open:open (re-activate) a closed list'
        'rebuildarc:rebuild the list archive index'
        'reload_list_config:reload an in-memory list configuration'
        'restore:restore a previously closed list'
        'review:print the list of subscribers'
        'send_digest:force sending of the daily digest'
        'set:change a subscriber attribute (digest, reception, etc.)'
        'show_pending_lists:list pending list creation requests'
        'sync_list_db:sync list metadata to the database'
        'test:run internal self-tests'
        'update:update list metadata in the database'
        'upgrade:run upgrade routines (password / shared / sympa)'
        'upgrade_config_location:relocate sympa.conf to the new path'
        'user:manage Sympa users (list / move / delete)'
        'version:print Sympa version'
    )
    _describe -t commands 'sympa command' commands
}

_sympa "$@"
