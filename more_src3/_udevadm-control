#compdef udevadm-control
# _udevadm-control — systemd udevadm control subcommand CLI for controlling the running udevd daemon reloading rules database start stop logging level setting max children environment hierarchy timeout (systemd team, C); getopt
# upstream: https://github.com/systemd/systemd

_udevadm-control() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-e[exit]' \
        '--exit[exit]' \
        '-l+[log level]:l:(emerg alert crit err warning notice info debug)' \
        '--log-level=+[log level]:l:(emerg alert crit err warning notice info debug)' \
        '-s[stop exec queue]' \
        '--stop-exec-queue[stop exec queue]' \
        '-S[start exec queue]' \
        '--start-exec-queue[start exec queue]' \
        '-R[reload rules]' \
        '--reload[reload rules]' \
        '--reload-rules[reload rules]' \
        '-p+[KEY=VALUE]:str:' \
        '--property=+[KEY=VALUE]:str:' \
        '-m+[max children]:n:' \
        '--children-max=+[max children]:n:' \
        '-t+[seconds]:n:' \
        '--timeout=+[seconds]:n:' \
        '--ping[ping daemon]' \
        '--load-credentials[load credentials]'
}

_udevadm-control "$@"
