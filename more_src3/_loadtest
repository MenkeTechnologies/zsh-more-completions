#compdef loadtest
# Documentation: https://github.com/alexfernandez/loadtest
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for loadtest - HTTP load testing tool

_arguments -s -S \
  '(-n --maxRequests)'{-n,--maxRequests}'[max number of requests to make]:number:' \
  '(-c --concurrency)'{-c,--concurrency}'[number of concurrent clients]:number:' \
  '(-t --maxSeconds)'{-t,--maxSeconds}'[max duration of test in seconds]:seconds:' \
  '--timeout=[timeout per request in milliseconds]:milliseconds:' \
  '(-T --contentType)'{-T,--contentType}'[MIME content type for POST data]:type:' \
  '*'{-H,--header}'[add custom header]:header:' \
  '(-P --postBody)'{-P,--postBody}'[string to send as POST body]:body:' \
  '(-p --postFile)'{-p,--postFile}'[file to send as POST body]:file:_files' \
  '(-u --putFile)'{-u,--putFile}'[file to send as PUT body]:file:_files' \
  '(-A --patchBody)'{-A,--patchBody}'[string to send as PATCH body]:body:' \
  '(-a --patchFile)'{-a,--patchFile}'[file to send as PATCH body]:file:_files' \
  '--data=[data to send in the body]:data:' \
  '(-m --method)'{-m,--method}'[HTTP method]:method:(GET POST PUT DELETE PATCH HEAD OPTIONS)' \
  '(-C --cookie)'{-C,--cookie}'[send cookie with requests]:cookie:' \
  '(-s --secureProtocol)'{-s,--secureProtocol}'[TLS/SSL method to use]:method:' \
  '--insecure[allow invalid TLS certificates]' \
  '(-r --recover)'{-r,--recover}'[recover from errors]' \
  '--rps=[rate of requests per second]:number:' \
  '--requestsPerSecond=[rate of requests per second]:number:' \
  '--cores=[run in multi-process mode on N cores]:number:' \
  '--agent[deprecated; use keep-alive agent]' \
  '(-k --keepalive)'{-k,--keepalive}'[use keep-alive connections]' \
  '--cert=[path to TLS client certificate]:file:_files' \
  '--key=[path to TLS client key]:file:_files' \
  '--quiet[suppress output]' \
  '--debug[show debug messages]' \
  '--tcp[use low-level TCP sockets]' \
  '-R[custom request generator function from file]:file:_files' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:url:' && return 0
