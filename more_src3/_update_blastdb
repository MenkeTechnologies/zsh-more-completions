#compdef update_blastdb update_blastdb.pl
# Documentation: https://www.ncbi.nlm.nih.gov/books/NBK569850/
# Documentation: https://ftp.ncbi.nlm.nih.gov/blast/executables/blast+/LATEST/ (ncbi-blast-2.17.0+-src)
# Reference accessed: 2026-05-27
# Verified: upstream c++/src/app/blast/update_blastdb.pl (BLAST+ 2.17.0)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--verbose[increase verbosity (repeatable)]' \
  '--quiet[suppress progress messages]' \
  '--force[force download even if local copy is up to date]' \
  '--passive=[use passive ftp]:passive:(1 no)' \
  '--timeout=[network timeout in seconds]:seconds:' \
  '--showall=[list available databases in chosen format]:format:(pretty tsv json)' \
  '--decompress[decompress archives after download]' \
  '--source=[source repository for downloads]:source:(ncbi gcp aws)' \
  '--gcp-project=[Google Cloud project for billing]:project:' \
  '--num_threads=[number of parallel download threads]:n:' \
  '--legacy_exit_code[use legacy exit codes]' \
  '--force_ftp[force the ftp protocol instead of https]' \
  '*:database:' && ret=0

return ret
