#compdef hypercorn
# Documentation: https://hypercorn.readthedocs.io/en/latest/how_to_guides/configuring.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hypercorn — ASGI/WSGI HTTP server (pgjones/hypercorn)

_arguments -s -S \
  '(-b --bind)'{-b,--bind}'[bind address host:port|unix:path|fd://num]:address' \
  '--insecure-bind[bind address without SSL enforcement]:address' \
  '--quic-bind[bind address for QUIC]:address' \
  '(-w --workers)'{-w,--workers}'[number of workers]:number' \
  '(-k --worker-class)'{-k,--worker-class}'[worker class]:class:(asyncio uvloop trio)' \
  '--backlog[listen backlog]:number' \
  '--ca-certs[CA certificates file]:file:_files' \
  '--certfile[SSL certificate file]:file:_files' \
  '--keyfile[SSL key file]:file:_files' \
  '--keyfile-password[password for encrypted keyfile]:password' \
  '--ciphers[SSL ciphers]:ciphers' \
  '--verify-mode[SSL peer cert verify mode]:mode' \
  '(-c --config)'{-c,--config}'[config file]:file:_files' \
  '--graceful-timeout[graceful shutdown timeout (s)]:seconds' \
  '--keep-alive[idle connection timeout (s)]:seconds' \
  '--read-timeout[TCP socket read timeout]:seconds' \
  '--max-requests[max requests before worker restart]:number' \
  '--max-requests-jitter[jitter for max-requests]:number' \
  '--access-logfile[access log target (- for stdout)]:file:_files' \
  '--access-logformat[access log format]:format' \
  '--error-logfile[error log file]:file:_files' \
  '--log-file[error log file]:file:_files' \
  '--log-level[log level]:level:(debug info warning error critical)' \
  '--log-config[log config file]:file:_files' \
  '(-p --pid)'{-p,--pid}'[PID file]:file:_files' \
  '--root-path[ASGI root path]:path' \
  '--server-name[hostnames to serve]:names' \
  '(-u --user)'{-u,--user}'[unix socket owner user]:user' \
  '(-g --group)'{-g,--group}'[unix socket owner group]:group' \
  '(-m --umask)'{-m,--umask}'[unix socket umask]:umask' \
  '--reload[enable auto-reload on code changes]' \
  '--debug[enable debug mode]' \
  '--websocket-ping-interval[ping interval to keep connections alive]:seconds' \
  '--statsd-host[statsd host]:host' \
  '--statsd-prefix[statsd metrics prefix]:prefix' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  ':application module' && return 0
