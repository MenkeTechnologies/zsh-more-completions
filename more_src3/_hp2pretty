#compdef hp2pretty
# _hp2pretty — convert GHC .hp heap profile to SVG (pepeiborra/hp2pretty)
# upstream: https://github.com/pepeiborra/hp2pretty
# Flags from src/Main.hs.

_hp2pretty() {
    _arguments \
        '--uniform-scale=[uniform scale across multiple inputs]:axis:(none time memory both)' \
        '*:hp file:_files -g "*.hp"'
}

_hp2pretty "$@"
