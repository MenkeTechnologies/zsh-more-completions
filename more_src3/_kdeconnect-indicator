#compdef kdeconnect-indicator
# _kdeconnect-indicator — KDE kdeconnect-indicator CLI system-tray applet for the KDE Connect protocol displaying paired Android iOS devices battery clipboard remote-input file-share notification SMS share menu on non-Plasma desktops GNOME XFCE LXQt MATE Cinnamon (KDE team, C++); Qt argparse
# upstream: https://invent.kde.org/network/kdeconnect-kde

_kdeconnect-indicator() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--replace[replace existing]' \
        '--device=+[device id]:str:' \
        '--name=+[indicator name]:str:' \
        '--help-all[show all options]' \
        '--help-qt[show Qt options]' \
        '--help-kde[show KDE options]' \
        '*::'
}

_kdeconnect-indicator "$@"
