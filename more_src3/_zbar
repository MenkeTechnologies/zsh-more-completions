#compdef zbarimg zbarcam
# _zbar — ZBar zbarimg / zbarcam (decode QR / EAN / UPC / Code128 / Code39 / Codabar barcodes from images (zbarimg) or live video device (zbarcam); -q quiet, --raw machine-readable, -d display window, -S<sym>.enable toggles symbology, --xml/--SGF emit structured output)
# upstream: https://github.com/mchehab/zbar
# Flags from zbar zbar/processor.c on tip.

_zbar() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--raw[raw output]' \
        '-d[display window]' \
        '-D[no display]' \
        '--xml[output as XML]' \
        '--SGF[output SGF]' \
        '--nodbus[disable D-Bus]' \
        '--prescale=*[scale image before decoding]:scale:' \
        '-S+[symbology config]:symbology.option=value:(qrcode.enable code128.enable code39.enable codabar.enable databar.enable databar-exp.enable ean13.enable ean8.enable ean5.enable ean2.enable upca.enable upce.enable isbn10.enable isbn13.enable i25.enable pdf417.enable)' \
        '*:image or video device:_files'
}

_zbar "$@"
