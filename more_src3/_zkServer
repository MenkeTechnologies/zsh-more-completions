#compdef zkServer zkServer.sh
# Documentation: https://zookeeper.apache.org/doc/r3.9.4/zookeeperTools.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a subcommands
subcommands=(
    'start:Start ZooKeeper server'
    'start-foreground:Start in foreground'
    'stop:Stop ZooKeeper server'
    'restart:Restart ZooKeeper server'
    'status:Check server status'
    'upgrade:Upgrade ZooKeeper'
    'print-cmd:Print startup command'
    'version:Print version'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:config file:_files'

case $state in
    subcmd)
        _describe -t subcommands 'zkServer subcommand' subcommands
        ;;
esac
