#compdef lxqt-trayman
# Documentation: https://github.com/lxqt/lxqt-panel
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxqt-trayman is not a top-level LXQt binary in the canonical upstream
# repositories; it appears as a helper associated with the lxqt-panel tray
# plugin in some downstream packaging. Only built-in help and version are
# exposed.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
