#compdef kruise-manager
# _kruise-manager — OpenKruise advanced-workload controller manager
# upstream: https://github.com/openkruise/kruise
# Flags from main.go on tip.

_kruise-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--rest-config-qps=[QPS for REST config]:n:' \
        '--rest-config-burst=[burst for REST config]:n:' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--health-probe-addr=[healthz/readyz bind host\:port]:host\:port:' \
        '--allow-privileged=[allow privileged containers]:bool:(true false)' \
        '--enable-leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--namespace=[restrict manager to a single namespace]:ns:' \
        '--enable-pprof=[enable pprof endpoint]:bool:(true false)' \
        '--pprof-addr=[pprof bind host\:port]:host\:port:' \
        '--sync-period=[minimum watched-resource resync interval]:dur:' \
        '--leader-election-lease-duration=[leader lease duration]:dur:' \
        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-election-resource-lock=[lease resource lock kind]:kind:(leases configmaps endpoints configmapsleases endpointsleases)' \
        '--leader-election-id=[leader-election lease ID]:id:' \
        '--leader-election-retry-period=[leader retry period]:dur:' \
        '--controller-cache-sync-timeout=[controller cache sync timeout]:dur:' \
        '--webhook-initialize-timeout=[webhook init timeout]:dur:' \
        '--default-ttlseconds-for-always-nodeimage=[default TTL (s) for finished NodeImage pull tasks]:s:' \
        '--feature-gates=[feature gates]:gates:' \
        '--logging-format=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kruise-manager "$@"
