#compdef hugin
# Documentation: https://manpages.debian.org/bookworm/hugin/hugin.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hugin - panorama photo stitcher GUI; accepts a .pto project file or images.

local curcontext="$curcontext" ret=1

_arguments -C \
  '*:project or image:_files -g "*.(pto|jpg|jpeg|JPG|JPEG|tif|tiff|TIF|TIFF|png|PNG)"' && ret=0

return ret
