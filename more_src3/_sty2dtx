#compdef sty2dtx
# Documentation: sty2dtx --help (v2.4)
# Source: Perl tool — convert a LaTeX .sty file into a documented .dtx skeleton.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print short help]' \
    '(- *)-H[print extended help]' \
    '(- *)-V[print version and copyright]' \
    '-v[be verbose]' \
    '-o[use given file as output]:output:_files' \
    '-O[overwrite existing output file(s)]' \
    '-B[use basename of single input file for output file]' \
    '-I[also create .ins (install) file]' \
    '--author=[author variable]:author:' \
    '--email=[email variable]:email:' \
    '--maintainer=[maintainer variable]:maintainer:' \
    '--year=[copyright year]:year:' \
    '--version=[package version]:version:' \
    '--date=[package date]:date:' \
    '--description=[description of package/class]:description:' \
    '--type=[package type]:type:(package class)' \
    '--filebase=[filebase variable]:base:' \
    '*:sty input or dtx output:_files -g "*.(sty|dtx)"' \
    && ret=0

return ret
