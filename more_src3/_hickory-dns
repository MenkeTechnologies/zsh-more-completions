#compdef hickory-dns
# ============================================================================
# _hickory-dns â€” zsh completion for Hickory DNS (formerly trust-dns),
#                 the safe Rust DNS server (authoritative / resolver /
#                 recursive / forwarder, DNSSEC + DoT + DoQ + DoH)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/hickory-dns/hickory-dns
#   Author     : Benjamin Fry  <benjaminfry@me.com> and the
#                hickory-dns community  (formerly bluejekyll/trust-dns)
#   License    : Apache-2.0 OR MIT
#   Language   : Rust
#   Crate      : hickory-dns  (workspace member under bin/)
#   Binary     : hickory-dns  (bin/Cargo.toml [[bin]] name = "hickory-dns",
#                              path = "src/hickory-dns.rs")
#   Last push  : active (workspace, current)
#
# WHAT IT IS
#   Hickory DNS is "a safe and secure DNS server with a variety of
#   protocol features (DNSSEC, TSIG, SIG(0), DoT, DoQ, DoH).  It can
#   be operated as an authoritative DNS server, forwarding resolver,
#   stub resolver, or a recursive resolver (experimental).  Zone
#   data can be managed in-memory, with flat files, or with an
#   SQLite database."  Hickory is the rebranded successor to
#   trust-dns;  the underlying crates (`hickory-resolver`,
#   `hickory-proto`, `hickory-server`, `hickory-client`, `hickory-
#   recursor`) are the canonical Rust implementation of every DNS
#   wire protocol, including modern encrypted transports.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/src/hickory-dns.rs
#                       module-doc Usage block + hickory_dns::
#                       DnsServer clap-derive struct)
#   hickory-dns [OPTIONS]
#   hickory-dns (-h | --help | -V | --version)
#
#   Options:
#         --validate              Test validation of configuration
#                                 files and exit
#         --workers <WORKERS>     Number of Tokio runtime workers
#                                 [default: number of CPU cores]
#     -q, --quiet                 Disable INFO messages (WARN and
#                                 ERROR still emitted)
#     -d, --debug                 Turn on DEBUG messages
#                                 (default level is INFO)
#     -c, --config <NAME>         Path to configuration file of
#                                 named server
#                                 [default: /etc/named.toml]
#     -z, --zonedir <DIR>         Path to the root directory for
#                                 all zone files (see also config
#                                 toml)
#     -p, --port <PORT>           Listening port for DNS queries
#                                 (overrides any value in config
#                                 file)
#         --disable-tcp           Disable TCP protocol (overrides
#                                 any value in config file)
#         --disable-udp           Disable UDP protocol (overrides
#                                 any value in config file)
#         --nsid <NSID>           Name server identifier (NSID)
#                                 payload for EDNS responses.
#                                 Use `0x` prefix for hex-encoded
#                                 data.  Mutually exclusive with
#                                 `--nsid-hostname`.
#         --nsid-hostname         Use the system hostname as the
#                                 NSID payload for EDNS responses.
#                                 Mutually exclusive with `--nsid`.
#     -h, --help                  Print help
#     -V, --version               Print version
#
#   Environment integration:
#     `tracing_subscriber::EnvFilter::from_env()` reads the
#     `RUST_LOG` environment variable in addition to the
#     `-q`/`-d` flags, so users can fine-tune per-module log
#     filters via `RUST_LOG=hickory_proto=trace,info`.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `hickory-resolver` and `hickory-server`
#   declared in bin/Cargo.toml workspace dependencies â€” the
#   canonical Rust DNS protocol implementation maintained by the
#   hickory-dns project (formerly Benjamin Fry's trust-dns).
#   hickory-resolver provides typed DNS bindings:  every RR type
#   (A, AAAA, NS, MX, TXT, SOA, SRV, DNSKEY, RRSIG, NSEC, NSEC3,
#   DS, TLSA, SVCB, HTTPS, etc.), DNSSEC validation, TSIG and
#   SIG(0) message authentication, DNS-over-TLS (DoT, RFC 7858),
#   DNS-over-HTTPS (DoH, RFC 8484), DNS-over-QUIC (DoQ, RFC 9250),
#   and a stub/recursive/forwarding resolver with caching.
#   hickory-server adds the authoritative side:  zone-file parsing,
#   in-memory + SQLite store backends, secondary transfers,
#   incremental zone updates, and the named-server runtime.
#   Verified via:
#     gh api repos/hickory-dns/hickory-dns/contents/bin/Cargo.toml
#       â†’ [[bin]] name = "hickory-dns" path = "src/hickory-dns.rs"
#       â†’ default = ["sqlite", "resolver", "rustls-platform-verifier"]
#     gh api repos/hickory-dns/hickory-dns/contents/bin/src/hickory-dns.rs
#       â†’ use hickory_dns::DnsServer;
#         let args = DnsServer::parse();
#   This entry is the Rust=131 leader bump that OPENS Axis 76
#   (DNS Protocol Library), pairing with future Go=miekg/dns and
#   TS-Node=dns2 (or dnspacket) poles to close the axis at 1/1/1.
#
#   No completion for `hickory-dns` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) â€” confirmed absent.
# ============================================================================

_hickory-dns() {
    _arguments -s \
        '--validate[test validation of configuration files and exit]' \
        '--workers=[number of Tokio runtime workers (default CPU cores)]:workers:' \
        '(-q --quiet)'{-q,--quiet}'[disable INFO messages]' \
        '(-d --debug)'{-d,--debug}'[turn on DEBUG messages]' \
        '(-c --config)'{-c+,--config=}'[config file path (default /etc/named.toml)]:config file:_files -g "*.{toml,conf}"' \
        '(-z --zonedir)'{-z+,--zonedir=}'[root directory for all zone files]:zone dir:_files -/' \
        '(-p --port)'{-p+,--port=}'[listening port for DNS queries]:port:' \
        '--disable-tcp[disable TCP protocol]' \
        '--disable-udp[disable UDP protocol]' \
        '(--nsid-hostname)--nsid=[NSID payload for EDNS responses (0x prefix for hex)]:nsid:' \
        '(--nsid)--nsid-hostname[use system hostname as NSID payload]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_hickory-dns "$@"
