#compdef hcitool
# _hcitool — BlueZ hcitool (legacy CLI for HCI-level Bluetooth ops: dev list, inq inquiry, scan discovery (-l/-i length/iac, -n names, -a class, -b print BD_ADDR), name BD_ADDR (peer name), info, spinq/epinq inquiry mode, cmd raw OGF OCF, rssi/link/lq link signal quality, con/cc/dc connections, sr/cpt switch role)
# upstream: https://github.com/bluez/bluez (tools/hcitool.c)
# Subcommands from bluez tools/hcitool.c on tip.

_hcitool() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX source device]:device:' \
        '1:command:(dev inq scan name info spinq epinq cmd con cc dc sr cpt rssi lq tpl afh lst auth enc key clkoff clock lescan leinfo lewladd lewlrm lewlsz lewlclr lerladd lerlrm lerlsz lerlclr lerlon lerloff lecc ledc lecup)' \
        '*::arg:'
}

_hcitool "$@"
