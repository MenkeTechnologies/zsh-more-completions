#compdef x2sys_binlist
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_binlist.html
# Source: GenericMappingTools/gmt supplements/x2sys — emit bin index file from track files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG identifying data attributes]:tag:_default' \
    '-D[append track-segment length per bin column]' \
    '-E[cylindrical equal-area projection before binning]' \
    '*-V[verbose (stackable)]' \
    '(- *)-\?[show help]' \
    '*:track file:_files' \
    && ret=0

return ret
