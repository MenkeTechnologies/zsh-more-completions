#compdef impacket-mssqlclient
# Documentation: https://github.com/fortra/impacket/blob/master/examples/mssqlclient.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-mssqlclient: MSSQL client over TDS.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-port[MSSQL port (default 1433)]:port:' \
  '-db[initial database]:db:' \
  '-windows-auth[use Windows Authentication]' \
  '-file[run SQL script from file]:file:_files' \
  '-show[show queries being executed]' \
  '*-command[execute SQL command (may repeat)]:sql:' \
  '--host-name[HostName property for MSSQLServer]:name:' \
  '--app-name[AppName property for MSSQLServer]:name:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target machine IP]:ip:' \
  '*::positional:_files' && ret=0
return ret
