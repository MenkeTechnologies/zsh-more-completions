#compdef libvirt-guests
# Documentation: https://libvirt.org/manpages/libvirt-guests.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# libvirt-guests: init/service helper to suspend/resume libvirt guests at
# host shutdown/boot. Operations are passed as the single positional arg.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:action:(start stop status restart condrestart try-restart reload force-reload gueststatus shutdown)' && ret=0

return ret
