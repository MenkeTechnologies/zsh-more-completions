#compdef seq24
# Documentation: https://manpages.debian.org/testing/seq24/seq24.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian man page for seq24.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--file[load MIDI file at startup]:file:_files -g "*.(midi|mid)"' \
  '--manual_alsa_ports[do not auto-attach ALSA ports]' \
  '--showmidi[output incoming MIDI to screen]' \
  '--priority[run with FIFO scheduler]' \
  '--pass_sysex[route sysex to all outputs]' \
  '--ignore[exclude ALSA device]:device number:' \
  '--show_keys[show key press values]' \
  '--interaction_method[mouse method]:n:(0 1)' \
  '--jack_transport[sync to JACK transport]' \
  '--jack_master[try to be JACK master]' \
  '--jack_master_cond[conditional JACK master]' \
  '--jack_start_mode[JACK start mode]:mode:(0 1)' \
  '--stats[output runtime stats]' \
  '--jack_session_uuid[JACK session UUID]:uuid:' \
  '*:midi file:_files -g "*.(midi|mid)"' && ret=0

return ret
