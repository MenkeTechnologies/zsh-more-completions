#compdef zfs-get
# _zfs-get — OpenZFS zfs get display properties CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-get() {
    _arguments \
        '--help[show help]' \
        '-h[script mode, no headers]' \
        '-H[script mode, no headers]' \
        '-p[parsable output]' \
        '-r[recursive]' \
        '-d+[depth]:n:' \
        '-o+[output cols]:o:(name property value received source)' \
        '-s+[source filter]:s:(local default inherited temporary received none)' \
        '-t+[type csv]:t:(all filesystem snap snapshot volume bookmark)' \
        '*:property dataset:'
}

_zfs-get "$@"
