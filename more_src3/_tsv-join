#compdef tsv-join
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-join.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-verbose[detailed help content]' \
  '(- *)--help-fields[help on field syntax]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --filter-file)'{-f,--filter-file}'+[filter file (required)]:file:_files' \
  '(-k --key-fields)'{-k,--key-fields}'+[key fields]:field-list' \
  '(-d --data-fields)'{-d,--data-fields}'+[data stream key fields if distinct]:field-list' \
  '(-a --append-fields)'{-a,--append-fields}'+[filter fields to append to output]:field-list' \
  '(-H --header)'{-H,--header}'[process first line as column headers]' \
  '(-p --prefix)'{-p,--prefix}'+[prefix to apply to appended field headers]:str' \
  '(-w --write-all)'{-w,--write-all}'+[retain unmatched records (left outer join)]:str' \
  '(-e --exclude)'{-e,--exclude}'[exclude matching records (anti-join)]' \
  '--delimiter=[field separator]:char' \
  '(-z --allow-duplicate-keys)'{-z,--allow-duplicate-keys}'[permit duplicate keys with differing values]' \
  '--line-buffered[flush output after each line]' \
  '*:file:_files' && return 0
