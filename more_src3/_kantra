#compdef kantra
# _kantra — Konveyor application migration analyzer CLI
# upstream: https://github.com/konveyor/kantra
# Subcommands + persistent flags from cmd/root.go + cmd/analyze/analyze.go + cmd/openrewrite/openrewrite.go on tip.

_kantra() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log verbosity (0-7)]:n:' \
        '--no-cleanup=[do not clean up temporary resources]:bool:(true false)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'analyze:run rule-based source analysis on an application'
                'openrewrite:run OpenRewrite recipes on a project'
                'rules:manage analyzer rulesets'
                'provider:manage analyzer providers'
                'discover:discover languages/frameworks in a codebase'
                'generate:generate analysis assets (Dockerfile, etc.)'
                'config:manage kantra configuration'
                'version:print kantra version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                analyze)
                    _arguments \
                        '--list-languages=[list detected application languages]:bool:(true false)' \
                        '(-l --label-selector)'{-l,--label-selector=}'[rules label selector]:expr:' \
                        '(-i --input)'{-i,--input=}'[application source or binary path]:path:_files' \
                        '(-o --output)'{-o,--output=}'[output directory]:dir:_files -/' \
                        '--skip-static-report=[do not generate static report]:bool:(true false)' \
                        '--analyze-known-libraries=[analyze open-source libraries]:bool:(true false)' \
                        '--maven-settings=[custom maven settings file]:file:_files' \
                        '(-m --mode)'{-m,--mode=}'[analysis mode]:mode:(full source-only)' \
                        '--no-dependency-rules=[disable dependency rules]:bool:(true false)' \
                        '--json-output=[emit JSON analysis + dependency output]:bool:(true false)' \
                        '--overwrite=[overwrite output directory]:bool:(true false)' \
                        '--bulk=[combine multiple analyses into one static report]:bool:(true false)' \
                        '--jaeger-endpoint=[Jaeger trace endpoint]:url:_urls' \
                        '--enable-default-rulesets=[run default rulesets]:bool:(true false)' \
                        '--http-proxy=[HTTP proxy URL]:url:_urls' \
                        '--https-proxy=[HTTPS proxy URL]:url:_urls' \
                        '--no-proxy=[csv of proxy-excluded URLs]:csv:' \
                        '--incident-selector=[incident selector expression]:expr:' \
                        '--run-local=[run Java analysis containerless]:bool:(true false)' \
                        '--disable-maven-search=[disable Maven dep search]:bool:(true false)' \
                        '--no-progress=[disable progress reporting]:bool:(true false)' \
                        '--container-runtime-flags=[extra flags for container runtime]:flags:' \
                        '--override-provider-settings=[custom provider config file]:file:_files' \
                        '--static-report-path=[override static report template path]:dir:_files -/'
                    ;;
                openrewrite)
                    _arguments \
                        '(-l --list-targets)'{-l,--list-targets}'[list available OpenRewrite recipes]' \
                        '(-t --target)'{-t,--target=}'[OpenRewrite recipe to use]:name:' \
                        '(-g --goal)'{-g,--goal=}'[Maven goal]:goal:(dryRun run)' \
                        '(-i --input)'{-i,--input=}'[application source directory]:dir:_files -/' \
                        '(-s --maven-settings)'{-s,--maven-settings=}'[custom maven settings file]:file:_files' \
                        '(-x --maven-debug-log)'{-x,--maven-debug-log}'[enable Maven debug logging]'
                    ;;
            esac
            ;;
    esac
}

_kantra "$@"
