#compdef spegel
# _spegel — in-cluster OCI registry mirror (spegel-org/spegel)
# upstream: https://github.com/spegel-org/spegel
# Subcommands + flags from main.go (go-arg).

_spegel() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--log-level=[minimum log level]:level:(DEBUG INFO WARN ERROR)' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_spegel_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                version)
                    _arguments \
                        '--format=[output format]:format:(text json)'
                    ;;
                configuration)
                    _arguments \
                        '--containerd-registry-config-path=[directory for mirror configuration]:dir:_files -/' \
                        '*--mirrored-registries=[registries to mirror]:registry:' \
                        '*--mirror-targets=[registries acting as mirrors]:registry:' \
                        '--resolve-tags=[resolve tags to digests]:bool:(true false)' \
                        '--prepend-existing=[keep existing mirror config and prepend]:bool:(true false)'
                    ;;
                registry)
                    _arguments \
                        '--metrics-addr=[metrics listen address]:addr:' \
                        '--containerd-sock=[containerd socket endpoint]:path:_files' \
                        '--containerd-namespace=[containerd namespace]:ns:' \
                        '--containerd-content-path=[containerd content store path]:dir:_files -/' \
                        '--data-dir=[persistent data directory]:dir:_files -/' \
                        '--router-addr=[router listen address]:addr:' \
                        '--registry-addr=[image registry listen address]:addr:' \
                        '*--mirrored-registries=[registries to mirror]:registry:' \
                        '*--registry-filters=[regex filters for registries/tags]:regex:' \
                        '--mirror-resolve-timeout=[max duration to find a mirror]:duration:' \
                        '--mirror-resolve-retries=[max mirror attempts]:n:' \
                        '--debug-web-enabled=[enable debug web page]:bool:(true false)' \
                        '--bootstrap-kind=[bootstrapper kind]:kind:(dns http static)' \
                        '--dns-bootstrap-domain=[DNS bootstrap domain]:domain:' \
                        '--http-bootstrap-addr=[HTTP bootstrap listen address]:addr:' \
                        '--http-bootstrap-peer=[HTTP bootstrap peer]:peer:' \
                        '*--static-bootstrap-peers=[static bootstrap peers]:peer:'
                    ;;
                cleanup)
                    _arguments \
                        '--addr=[readiness-probe listen address]:addr:' \
                        '--containerd-registry-config-path=[directory for mirror configuration]:dir:_files -/'
                    ;;
                cleanup-wait)
                    _arguments \
                        '--probe-endpoint=[endpoint to probe cleanup jobs from]:url:' \
                        '--threshold=[consecutive successful probes required]:n:' \
                        '--period=[probe interval]:duration:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_spegel_commands] )) ||
_spegel_commands() {
    local -a commands
    commands=(
        'version:print Spegel version'
        'configuration:write the containerd mirror configuration'
        'registry:run the Spegel mirror registry'
        'cleanup:run the cleanup job (remove mirror config)'
        'cleanup-wait:wait for a cleanup job to finish'
    )
    _describe -t commands 'spegel command' commands
}

_spegel "$@"
