#compdef tekton-triggers-cel-eval cel-eval
# _tekton-triggers-cel-eval — Tekton Triggers CEL interceptor offline evaluator (tektoncd/triggers)
# upstream: https://github.com/tektoncd/triggers
# Flags from cmd/cel-eval/cmd/root.go on tip.

_tekton-triggers-cel-eval() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-e --expression)'{-e,--expression=}'[CEL expression to evaluate (required)]:expr:' \
        '(-r --http-request)'{-r,--http-request=}'[path to HTTP-request fixture (required)]:file:_files'
}

_tekton-triggers-cel-eval "$@"
