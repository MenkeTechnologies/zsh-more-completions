#compdef lean4
# Documentation: https://github.com/leanprover/lean4/blob/master/src/util/shell.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lean4 - Lean 4 theorem prover (when binary named lean4)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-V,--short-version}'[show short version]' \
  '(- *)'{-g,--githash}'[show git hash]' \
  '(-r --run)'{-r,--run}'[execute the main function]' \
  '(-I --stdin)'{-I,--stdin}'[read input from stdin]' \
  '(-R --root)'{-R+,--root=}'[set package root directory]:directory:_files -/' \
  '(-j --threads)'{-j+,--threads=}'[number of threads]:count:' \
  '(-M --memory)'{-M+,--memory=}'[soft memory limit in megabytes]:megabytes:' \
  '(-t --trust)'{-t+,--trust=}'[set trust level]:level:' \
  '(-T --timeout)'{-T+,--timeout=}'[deterministic timeout]:heartbeats:' \
  '(-P --profile)'{-P,--profile}'[enable profiling]' \
  '(-a --stats)'{-a,--stats}'[display statistics]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-d --deps)'{-d,--deps}'[show dependencies]' \
  '(-N --deps-json)'{-N,--deps-json}'[output dependencies as JSON]' \
  '(-O --src-deps)'{-O,--src-deps}'[show source dependencies]' \
  '(-S --server)'{-S,--server}'[start the language server]' \
  '(-W --worker)'{-W,--worker}'[start a language server worker]' \
  '(-p --plugin)'{-p+,--plugin=}'[load plugin]:plugin:_files -g "*.so *.dylib *.dll"' \
  '(-l --load-dynlib)'{-l+,--load-dynlib=}'[load dynamic library]:library:_files -g "*.so *.dylib *.dll"' \
  '(-s --tstack)'{-s+,--tstack=}'[thread stack size]:size:' \
  '(-J --json)'{-J,--json}'[output diagnostics as JSON]' \
  '(-e --exitOnPanic)'{-e,--exitOnPanic}'[exit on panic]' \
  '(-u --setup)'{-u+,--setup=}'[setup configuration]:setup:' \
  '-o+[output olean file]:file:_files' \
  '-i+[output ilean data]:file:_files' \
  '-c+[output C file]:file:_files -g "*.c"' \
  '-b+[output bytecode]:file:_files' \
  '(-x --print-prefix)'{-x,--print-prefix}'[print install prefix]' \
  '(-L --print-libdir)'{-L,--print-libdir}'[print library directory]' \
  '(-f --features)'{-f,--features}'[list available features]' \
  '*:Lean source file:_files -g "*.lean"' && ret=0

return ret
