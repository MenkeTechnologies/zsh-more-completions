#compdef swift-container-updater
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/container/updater.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# main() calls parse_options(once=True); only standard daemon flags + CONFIG positional.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '*:CONFIG file:_files -g "*.conf"' && ret=0
return ret
