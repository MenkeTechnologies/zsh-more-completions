_letmein() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version information and exit]' \
        '(-c --config)'{-c,--config}'=[override config file path]:path:_files -g "*.conf *.toml *.yaml *.yml"' \
        '--verbose[show detailed information about what happens internally]' \
        '--dns=[DNS resolver service (comma-separated)]:list:' \
        '--dns-crypt=[DNS resolver transport encryption (comma-separated)]:list:' \
        '--seccomp=[override seccomp setting from config]:mode:(off log kill)' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _lm_cmds=(
                'knock:knock a resource on a server (opens port or adds jump rules)'
                'revoke:revoke a resource on a server (closes port or removes jump rules)'
                'gen-key:generate a new shared secret key'
            )
            _describe -t commands 'letmein command' _lm_cmds && ret=0
            ;;
        args)
            case $words[1] in
                knock|revoke)
                    _arguments \
                        '1:host (hostname, IPv4, or IPv6):' \
                        '2:port:' \
                        '(-r --resource)'{-r,--resource}'=[resource ID instead of port]:id:' \
                        '(-u --user)'{-u,--user}'=[user ID for authentication (8-digit hex)]:id:' \
                        '(-P --server-port)'{-P,--server-port}'=[letmein server port (default 5800)]:port:' \
                        '(-T --server-port-tcp)'{-T,--server-port-tcp}'[force TCP for letmein server connection]' \
                        '(-U --server-port-udp)'{-U,--server-port-udp}'[force UDP for letmein server connection]' \
                        '(-4 --ipv4)'{-4,--ipv4}'[resolve HOST to IPv4 only]' \
                        '(-6 --ipv6)'{-6,--ipv6}'[resolve HOST to IPv6 only]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_letmein "$@"
