#compdef kysely
# _kysely — Kysely DB migration/seed CLI (kysely-org/kysely-ctl)
# upstream: https://github.com/kysely-org/kysely-ctl
# Subcommands & flags from src/commands/root.mts and src/arguments/common.mts (citty).

_kysely() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(ts|js|mts|mjs)"' \
        '--cwd=[working directory for relative paths]:dir:_files -/' \
        '--debug[enable debug logging]' \
        '(-e --environment)'{-e+,--environment=}'[environment overrides]:env:(production development test)' \
        '--no-outdated-check[skip version-check notice]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize kysely config in current project'
                'migrate:run database migrations'
                'seed:run database seeds'
                'sql:execute SQL against the configured DB'
                'down:migrate down (legacy)'
                'up:migrate up (legacy)'
                'latest:migrate to latest (legacy)'
                'list:list migration status (legacy)'
                'rollback:rollback latest batch (legacy)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                migrate) _arguments '1:sub:(down latest list make rollback up)' ;;
                seed) _arguments '1:sub:(make run)' ;;
            esac
            ;;
    esac
}

_kysely "$@"
