#compdef tmux-cssh
# Documentation: https://github.com/zinic/tmux-cssh
# Reference accessed: 2026-05-21
# Verified: tmux-cssh source script flag list (zinic fork of dennishafemann).

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-u --user)'{-u,--user}'[SSH user]:user:_users' \
  '(-c --certificate -i --identity)'{-c,--certificate,-i,--identity}'[path to SSH key file]:keyfile:_files' \
  '(-sc --ssh-server-connect-string)'{-sc,--ssh-server-connect-string}'[SSH connection string (multiple allowed)]:host:_hosts' \
  '(-sa --ssh_args)'{-sa,--ssh_args}'[additional SSH arguments]:args:' \
  '(-ss -csc --ssh_command --custom-ssh-command)'{-ss,-csc,--ssh_command,--custom-ssh-command}'[custom SSH command]:command:' \
  '(-ts --tmux-session-name)'{-ts,--tmux-session-name}'[tmux session name]:name:' \
  '(-ns --new-session)'{-ns,--new-session}'[initialize new session with timestamp]' \
  '(-set --set-epoch-time)'{-set,--set-epoch-time}'[use current epoch time as session name]' \
  '(-tl --tmuxlayout)'{-tl,--tmuxlayout}'[tmux layout]:layout:(tiled even-vertical even-horizontal main-horizontal main-vertical)' \
  '(-sw --splitwindow)'{-sw,--splitwindow}'[max panes before creating new window]:n:' \
  '(-ds --dont-synchronize)'{-ds,--dont-synchronize}'[disable keyboard synchronization]' \
  '(-f --filename)'{-f,--filename}'[file with connection strings]:file:_files' \
  '(-cs --config-setting)'{-cs,--config-setting}'[config setting name]:name:' \
  '(-cf --config-file)'{-cf,--config-file}'[config file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-dc --dont-clusterize)'{-dc,--dont-clusterize}'[disable clustering]' \
  '*:host:_hosts'
