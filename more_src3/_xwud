#compdef xwud
# Documentation: https://man.archlinux.org/man/xwud.1.en
# Reference accessed: 2026-05-30
# xwud — X Window UnDumper. Display an XWD-format image previously created by xwd.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show option descriptions]' \
  '(- *)-version[show version]' \
  '-bg+[color for "0" bits in bitmap images]:color:' \
  '-display+[X server to connect to]:display:' \
  '-dumpheader[print XWD header info only (no image display)]' \
  '-fg+[color for "1" bits in bitmap images]:color:' \
  '-geometry+[window size and position]:geom:' \
  '-in+[input XWD file (default stdin)]:file:_files -g "*.(xwd|XWD)"' \
  '-new[force creation of a new colormap]' \
  '-noclick[disable window termination via mouse clicks]' \
  '-plane+[select a single bit plane to display]:N:' \
  '-raw[display image using current screen color values]' \
  '-rv[swap foreground and background colors]' \
  '-scale[enable window resizing + image scaling]' \
  '-std+[use specified Standard Colormap]:maptype:' \
  '-vis+[specify a particular visual or visual class]:vis-type-or-id:' \
  && ret=0

return ret
