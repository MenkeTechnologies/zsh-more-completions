#compdef ldapurl
# _ldapurl — OpenLDAP Foundation ldapurl LDAP URL formatting tool RFC 4516 builder and parser (openldap team, C); custom argparse
# upstream: https://www.openldap.org

_ldapurl() {
    _arguments \
        '-V[show version]' \
        '-?[show help]' \
        '-H+[LDAP URI to parse]:url:_urls' \
        '-h+[host]:host:_hosts' \
        '-p+[port]:port:_ports' \
        '-S+[scheme]:s:(ldap ldaps ldapi cldap)' \
        '-b+[search base DN]:str:' \
        '-s+[scope]:s:(base one sub children)' \
        '-f+[filter]:str:' \
        '-a+[attributes csv]:str:' \
        '-x+[extensions csv]:str:' \
        '-E+[criticality control]:str:' \
        '-c[parse URL components]'
}

_ldapurl "$@"
