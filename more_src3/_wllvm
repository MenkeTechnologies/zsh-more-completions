#compdef wllvm wllvm++ extract-bc
# Documentation: https://github.com/travitch/whole-program-llvm
# Documentation: https://github.com/travitch/whole-program-llvm/blob/master/wllvm/extraction.py
# Reference accessed: 2026-05-27
# Verified: upstream README and extraction.py argparse definitions

local curcontext="$curcontext" ret=1

case "$service" in
  extract-bc)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help message and exit]' \
      '(-l --linker)'{-l+,--linker=}'[LLVM bitcode linker to use]:linker:_command_names -e' \
      '(-a --archiver)'{-a+,--archiver=}'[LLVM bitcode archiver to use]:archiver:_command_names -e' \
      '(-v --verbose)'{-v,--verbose}'[call external procedures in verbose mode]' \
      '(-m --manifest)'{-m,--manifest}'[write a manifest file listing all .bc files used]' \
      '(-s --sort)'{-s,--sort}'[sort the list of bitcode files (for debugging)]' \
      '(-b --bitcode)'{-b,--bitcode}'[extract bitcode module rather than archive (archives only)]' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '*:binary produced by wllvm/wllvm++:_files' && ret=0
    ;;
  wllvm|wllvm++)
    # Compiler wrapper: proxy for clang/clang++ — defer to underlying compiler completion
    # WLLVM only intercepts a couple of meta-flags; everything else passes through to the compiler.
    _arguments -s -S \
      '--help[show wllvm help message and exit]' \
      '--version[show version information and exit]' \
      '*:source file or compiler flag:_files' && ret=0
    ;;
esac

return ret
