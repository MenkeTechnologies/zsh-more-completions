#compdef systemd-modules-load
# _systemd-modules-load (systemd kernel-module-load helper reading /etc/modules-load.d/*.conf, /usr/lib/modules-load.d/*.conf, /run/modules-load.d/*.conf to insmod each listed module at boot; takes no arguments — just runs once at boot via systemd-modules-load.service)
# upstream: https://github.com/systemd/systemd (src/modules-load)
# Argument shape from systemd src/modules-load/modules-load.c on tip.

_systemd-modules-load() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-modules-load "$@"
