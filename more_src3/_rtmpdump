#compdef rtmpdump
# Documentation: rtmpdump --help (v2.6)
# Source: dump RTMP streams to FLV files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(-i --url)'{-i+,--url=}'[full RTMP URL with options]:url:' \
    '(-r --rtmp)'{-r+,--rtmp=}'[RTMP URL]:url:' \
    '(-n --host)'{-n+,--host=}'[override hostname]:host:_hosts' \
    '(-c --port)'{-c+,--port=}'[override port]:port:' \
    '(-S --socks)'{-S+,--socks=}'[SOCKS proxy host\:port]:proxy:' \
    '(-l --protocol)'{-l+,--protocol=}'[protocol number]:num:(0 2)' \
    '(-y --playpath)'{-y+,--playpath=}'[override play path]:path:' \
    '(-Y --playlist)'{-Y,--playlist}'[send playlist before playing]' \
    '(-s --swfUrl)'{-s+,--swfUrl=}'[player SWF URL]:url:' \
    '(-t --tcUrl)'{-t+,--tcUrl=}'[tcUrl for connect]:url:' \
    '(-p --pageUrl)'{-p+,--pageUrl=}'[web page URL]:url:' \
    '(-a --app)'{-a+,--app=}'[target application name]:app:' \
    '(-w --swfhash)'{-w+,--swfhash=}'[SHA256 hash of SWF]:hex:' \
    '(-x --swfsize)'{-x+,--swfsize=}'[size of decompressed SWF]:num:' \
    '(-W --swfVfy)'{-W+,--swfVfy=}'[SWF URL with auto hash/size]:url:' \
    '(-X --swfAge)'{-X+,--swfAge=}'[days to cache SWF hash]:days:' \
    '(-u --auth)'{-u+,--auth=}'[auth string for connect]:string:' \
    '*'{-C+,--conn=}'[AMF connect data]:type\:data:' \
    '(-f --flashVer)'{-f+,--flashVer=}'[Flash version string]:version:' \
    '(-v --live)'{-v,--live}'[save a live stream]' \
    '(-d --subscribe)'{-d+,--subscribe=}'[subscribe stream name]:name:' \
    '(-R --realtime)'{-R,--realtime}'[do not Pause/Unpause BUFX]' \
    '(-o --flv)'{-o+,--flv=}'[FLV output file (- for stdout)]:file:_files -g "*.flv"' \
    '(-e --resume)'{-e,--resume}'[resume a partial download]' \
    '(-m --timeout)'{-m+,--timeout=}'[connection timeout seconds]:num:' \
    '(-A --start)'{-A+,--start=}'[start at N seconds]:num:' \
    '(-B --stop)'{-B+,--stop=}'[stop at N seconds]:num:' \
    '(-T --token)'{-T+,--token=}'[SecureToken key]:key:' \
    '(-j --jtv)'{-j+,--jtv=}'[Justin.tv legacy JSON auth token]:json:' \
    '(-\# --hashes)'{-\#,--hashes}'[progress hashes (not byte counter)]' \
    '(-b --buffer)'{-b+,--buffer=}'[buffer time ms]:ms:' \
    '(-k --skip)'{-k+,--skip=}'[keyframes to skip on resume]:n:' \
    '(-q --quiet -V --verbose -z --debug)'{-q,--quiet}'[no output]' \
    '(-q --quiet -V --verbose -z --debug)'{-V,--verbose}'[verbose output]' \
    '(-q --quiet -V --verbose -z --debug)'{-z,--debug}'[debug output]' \
    && ret=0

return ret
