#compdef so-strelka-update
# _so-strelka-update — Security Onion so-strelka-update CLI for updating Strelka file-scanning scanners YARA rule sources ClamAV signatures Snowman TRiD definitions and frontend/backend container images across cluster (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-strelka-update() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-c+[component]:c:(frontend backend coordinator gatekeeper yara clamav trid snowman strelka-mongodb)' \
        '--component=+[component]:c:(frontend backend coordinator gatekeeper yara clamav trid snowman strelka-mongodb)' \
        '-f[force]' \
        '--force[force]' \
        '--no-reload[no reload]' \
        '--no-restart[no restart]' \
        '--no-check[no check]' \
        '--dry-run[dry run]' \
        '--check-only[check only]' \
        '--upgrade-images[upgrade container images]' \
        '--prune[prune old images]'
}

_so-strelka-update "$@"
