#compdef tonic-cli tonic-build
# _tonic-cli — hyperium tonic gRPC over HTTP/2 Rust impl build/CLI alias (Hyperium team / Lucio Franco, Rust); custom argparse
# upstream: https://github.com/hyperium/tonic

_tonic-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--out_dir=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--include=+[include path]:list:_files -/' \
        '-I+[include path]:list:_files -/' \
        '--build_client=+[build client]:b:(true false)' \
        '--build_server=+[build server]:b:(true false)' \
        '--client_attributes=+[client attr]:list:' \
        '--server_attributes=+[server attr]:list:' \
        '--field_attribute=+[field attr]:list:' \
        '--type_attribute=+[type attr]:list:' \
        '--enum_attribute=+[enum attr]:list:' \
        '--message_attribute=+[message attr]:list:' \
        '--compile_well_known_types[compile well known types]' \
        '--extern_path=+[extern path]:list:' \
        '--protoc_arg=+[protoc arg]:list:' \
        '--use_arc_self[use Arc<Self>]' \
        '--bytes=+[fields as Bytes]:list:' \
        '--btree_map=+[BTreeMap for fields]:list:' \
        '--codec_path=+[codec path]:str:' \
        '--skip_protoc_run[skip protoc run]' \
        '--disable_comments=+[disable comments]:list:' \
        '*:proto:_files -g "*.proto"'
}

_tonic-cli "$@"
