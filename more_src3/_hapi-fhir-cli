#compdef hapi-fhir-cli
# Documentation: https://hapifhir.io/hapi-fhir/docs/tools/hapi_fhir_cli.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug[enable debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'run-server:launch a local test FHIR server'
      'upload-examples:upload HL7 FHIR example resources'
      'upload-terminology:upload external code systems (SNOMED CT, LOINC, ICD-10)'
      'migrate-database:run JPA schema migration'
      'clear-migration-lock:clear migration lock rows after failure'
      'reindex-terminology:recreate freetext indexes for terminology resources'
    )
    _describe -t commands 'hapi-fhir-cli command' cmds && ret=0
    ;;
  (args)
    _arguments \
      '-v[FHIR version]:version:(dstu2 dstu3 r4 r4b r5)' \
      '-t[target server URL]:url:' \
      '-u[code system URI]:uri:' \
      '*:args:_default' && ret=0
    ;;
esac

return ret
