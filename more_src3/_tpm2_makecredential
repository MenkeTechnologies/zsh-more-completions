#compdef tpm2_makecredential
# _tpm2_makecredential — tpm2-software tpm2_makecredential create a credential blob bound to a TPM2 endorsement key (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_makecredential() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-T+[TCTI string]:str:' \
        '--tcti=+[TCTI string]:str:' \
        '-e+[EK public file]:file:_files' \
        '--encryption-key=+[EK public file]:file:_files' \
        '-s+[secret file]:file:_files' \
        '--secret=+[secret file]:file:_files' \
        '-n+[object name]:str:' \
        '--name=+[object name]:str:' \
        '-o+[output credential blob]:file:_files' \
        '--credential-blob=+[output credential blob]:file:_files' \
        '-G+[ek algorithm]:a:(rsa rsa2048 ecc)' \
        '--key-algorithm=+[ek algorithm]:a:(rsa rsa2048 ecc)' \
        '-Q[do not output anything]'
}

_tpm2_makecredential "$@"
