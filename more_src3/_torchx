#compdef torchx
# Documentation: source-direct extraction from upstream
# pytorch/torchx torchx/cli/main.py argparse subcommand registry
# (top-level imports 10 `Cmd<Name>()` classes from
# torchx/cli/cmd_*.py, each implementing `add_arguments(self,
# subparser)` for its per-subcommand flag set). Per upstream
# pyproject.toml `[project.scripts] torchx =
# "torchx.cli.main:main"`.
# Reference accessed: 2026-05-30 via gh api.
# PyTorch torchx R153b — PyTorch job launcher: a unified CLI
# for running PyTorch jobs across local processes, Kubernetes,
# Slurm, AWS Batch, Ray, and other schedulers. Sister tool to
# torchrun/torchserve already in the corpus + torchtune (`tune`)
# also fresh this round.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--log-level)--log-level=[log verbosity (default INFO)]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '1:subcommand:((run\:run-a-component-as-a-job describe\:describe-a-running-job list\:list-jobs status\:show-job-status log\:fetch-job-logs cancel\:cancel-a-job delete\:delete-a-job configure\:configure-a-scheduler runopts\:show-runopts-for-a-scheduler tracker\:job-tracker-management builtins\:list-built-in-components))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      run)
        # Run a component (a Python function returning AppDef)
        # against a chosen scheduler.
        _arguments -s -S \
          '-s+[scheduler to run against]:scheduler:(local_cwd local_docker kubernetes slurm aws_batch ray gcp_batch)' \
          '-cfg+[scheduler config (key=value comma list)]:cfg:' \
          '--dryrun[print the app def without submitting]' \
          '--wait[block until job terminates]' \
          '--log[also stream logs after submission]' \
          '--tee_logs[interleave logs from all replicas]' \
          '--workspace=[workspace dir for component bundling]:dir:_directories' \
          '*:component spec + args:' \
          && ret=0
        ;;
      describe|status|log|cancel|delete)
        # Single-positional commands targeting a job by its
        # `<scheduler>://<session>/<app-id>` URI.
        _arguments -s -S \
          '1:job URI (scheduler\://session/app-id):' \
          && ret=0
        ;;
      list)
        _arguments -s -S \
          '-s+[scheduler to list jobs for]:scheduler:(local_cwd local_docker kubernetes slurm aws_batch ray gcp_batch)' \
          && ret=0
        ;;
      configure|runopts)
        _arguments -s -S \
          '1:scheduler:(local_cwd local_docker kubernetes slurm aws_batch ray gcp_batch)' \
          && ret=0
        ;;
      tracker|builtins)
        _arguments -s -S '*::: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
