#compdef waylandpp wayland-scanner++
# Documentation: https://github.com/NilsBrause/waylandpp
# Reference accessed: 2026-05-21
# Verified: upstream scanner/scanner.cpp at github.com/NilsBrause/waylandpp.
# Usage: wayland-scanner++ [-s on] [-x extra_header.hpp] protocol.xml ... header.hpp source.cpp

local curcontext="$curcontext" ret=1

_arguments -C \
  '-s+[strict mode]:mode:(on)' \
  '*-x+[extra header to include]:header:_files -g "*.(hpp|h)"' \
  '*:wayland protocol XML or cpp output:_files -g "*.(xml|hpp|cpp|h)"' && ret=0

return ret
