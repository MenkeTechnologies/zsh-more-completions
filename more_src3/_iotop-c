#compdef iotop-c
# Documentation: https://github.com/Tomas-M/iotop
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iotop-c (iotop reimplementation in C) completion

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-H --help-type)'{-H,--help-type=}'[interactive help type]:type:(none win inline)' \
  {-o,--only}'[show only processes with I/O activity]' \
  {-b,--batch}'[batch (non-interactive) mode]' \
  {-n,--iter=}'[number of iterations]:iterations:' \
  {-d,--delay=}'[delay between updates in seconds]:delay:' \
  {-p,--pid=}'[monitor specific PID]:PID:_pids' \
  {-u,--user=}'[monitor specific user]:user:_users' \
  {-P,--processes}'[show only processes, not threads]' \
  {-a,--accumulated}'[show accumulated I/O]' \
  {-A,--accum-bw}'[show accumulated bandwidth]' \
  {-k,--kilobytes}'[show I/O in kilobytes]' \
  {-c,--fullcmdline}'[show full command line]' \
  {-t,--time}'[add timestamp to each line in batch mode]' \
  {-q,--quiet}'[suppress header in batch mode]' \
  {-e,--hide-exited}'[hide exited processes]' \
  {-x,--dead-x}'[show exited processes with x marker]' \
  '--filter=[filter processes by TID and command (regex)]:regex:' \
  {-g,--grtype=}'[graph data source]:type:(io r w rw sw)' \
  {-l,--no-color}'[disable colorization]' \
  {-N,--inverse}'[use inverse color scheme]' \
  '--ascii[use ASCII character set]' \
  '--unicode[use Unicode character set]' \
  '--si[use SI units (1000) instead of binary (1024)]' \
  {-W,--write}'[save configuration and exit]' \
  '-1[toggle PID column]' \
  '-2[toggle PRIO column]' \
  '-3[toggle USER column]' \
  '-4[toggle READ column]' \
  '-5[toggle WRITE column]' \
  '-6[toggle SWAPIN column]' \
  '-7[toggle IO column]' \
  '-8[toggle GRAPH column]' \
  '-9[toggle COMMAND column]' \
  && ret=0

return ret
