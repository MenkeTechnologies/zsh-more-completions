#compdef lci
# Documentation: https://github.com/justinmeza/lci
# Reference accessed: 2026-05-27
# Verified: upstream main.c getopt_long longopt[] table (justinmeza/lci)

# Zsh completion for lci, a LOLCODE interpreter written in C.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[output help and exit]' \
  '(- *)'{-v,--version}'[print program version and exit]' \
  '(-i --interactive)'{-i,--interactive}'[start an interactive prompt]' \
  '*:LOLCODE source file:_files' && ret=0

return ret
