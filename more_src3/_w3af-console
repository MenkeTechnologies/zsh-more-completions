#compdef w3af_console w3af-console
# Documentation: https://github.com/andresriancho/w3af/blob/master/w3af_console
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (getopt parsing in main()).
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# --start flag (real flag is -P/--profile-run for batch mode).
# Added: -e (easter egg), -v/--version, -f/--force-update,
# -P/--profile-run, -y/--yes, -t/--target per upstream.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-e[easter egg]' \
  '(-s --script)'{-s+,--script=}'[run script file]:file:_files -g "*.w3af"' \
  '(-p --profile)'{-p+,--profile=}'[load profile]:profile:' \
  '(-P --profile-run)'{-P+,--profile-run=}'[load and run profile in batch mode]:profile:' \
  '(-n --no-update)'{-n,--no-update}'[skip update check]' \
  '(-f --force-update)'{-f,--force-update}'[force update check]' \
  '(-y --yes)'{-y,--yes}'[auto-accept disclaimer]' \
  '(-t --target)'{-t+,--target=}'[target URL]:url:' && ret=0
return ret
