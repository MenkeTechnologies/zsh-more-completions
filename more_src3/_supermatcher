#compdef supermatcher
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/supermatcher.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS supermatcher: rapidly find local alignments between large
# sequence sets using a word-match seed-and-extend heuristic.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[suppress interactive prompts]' '-stdout[write output to stdout]' \
  '-filter[read from stdin, write to stdout]' '-options[prompt for all parameters]' \
  '-debug[generate debug output file]' '-verbose[verbose output]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[show version]' \
  '-asequence=[first sequence set (seqall)]:sequence USA:_files' \
  '-bsequence=[second sequence set (seqset)]:sequence USA:_files' \
  '-datafile=[scoring matrix (default EBLOSUM62/EDNAFULL)]:matrix:_files' \
  '-gapopen=[gap opening penalty (default 10.0)]:penalty:' \
  '-gapextend=[gap extension penalty (default 0.5)]:penalty:' \
  '-minscore=[minimum alignment score threshold]:score:' \
  '-wordlen=[word length for seed matching (default 6)]:length:' \
  '-width=[alignment display width (default 16)]:cols:' \
  '-errfile=[error log file (default supermatcher.error)]:file:_files' \
  '-outfile=[alignment output file]:file:_files' \
  '*:sequence USA:_files' && ret=0

return ret
