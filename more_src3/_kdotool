#compdef kdotool
# ---------------------------------------------------------------------------
# kdotool — xdotool-like window control utility for KDE Plasma (Rust, 357★)
#
# upstream: https://github.com/jinliu/kdotool
# author : Jin Liu  <m.liu.jin@gmail.com>
# license: Apache-2.0
#
# Source-direct completion: every flag, every command, every WINDOWSTATE
# PROPERTY below is verbatim from src/help.rs `help()` text and src/main.rs
# match arms (parse loop for search/getactivewindow/getmouselocation +
# window action commands + global commands) on the kdotool tip.
#
# Direct deps from Cargo.toml:
#   chrono     = "0.4.43"        ← canonical Rust datetime library (this axis)
#   anyhow     = "1.0.100"
#   dbus       = "0.9.10"        (KWin script registration over D-Bus)
#   serde      = "1"
#   handlebars = "5"             (script-template render engine)
#   lexopt     = (cli feature)   (blyxxyz's zero-dep argv parser)
#   env_logger = (cli feature)
#
# kdotool operates by D-Bus-loading KWin scripts into the running Plasma
# session — the user-facing command syntax is identical to xdotool but the
# implementation is pure KWin JavaScript injection.
#
# === AXIS 155 OPENER — datetime / chronology library ecosystem ===
# Axis position: Rust=210 OPENS Axis 155 at slot 1/0/0 — round-number 155
# axis milestone.  Canonical Rust datetime library is `chrono` by Kang
# Seonghoon (lifthrasiir, original 2014), now maintained by Brandon W.
# Maister and the chrono-rs team — the de facto standard time library
# for the entire Rust ecosystem, used by tokio-tungstenite, hyper, AWS SDK,
# Diesel ORM, SQLx, every Rust web framework, and every CLI that logs time.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=210   ← THIS FILE              (axis 155 OPENS, slot 1/0/0)
#   Go=210     ← next round              (axis 155 continues, slot 2/0/0)
#   TS-Node=210 ← round after            (axis 155 CLOSES at triple-210, slot 1/1/1)
# ---------------------------------------------------------------------------

_kdotool() {
    local context state state_descr line ret=1
    typeset -A opt_args

    # All commands, source-direct from src/help.rs help() text on tip
    local -a cmds
    cmds=(
        # Window Query Commands
        'search:search for windows by regex pattern (title|name|class|classname|role)'
        'getactivewindow:select the currently active window'
        'getmouselocation:output mouse x y screen and window id'
        # Window Action Commands (use last query result %1 by default)
        'getwindowname:output the name (titlebar text) of a window'
        'getwindowclassname:output the class name of a window'
        'getwindowgeometry:output x y width height of a window'
        'getwindowid:output the ID of a window'
        'getwindowpid:output the PID owning a window'
        'windowactivate:activate a window (switches desktops if needed)'
        'windowraise:(KDE 6 only) raise a window to top of stack'
        'windowminimize:minimize a window'
        'windowclose:close a window'
        'windowsize:resize a window (WIDTH HEIGHT, accepts percentages, x|y unchanged)'
        'windowmove:move a window (X Y, accepts percentages, --relative)'
        'windowstate:change ABOVE|BELOW|SKIP_TASKBAR|... properties on a window'
        'get_desktop_for_window:output the desktop number a window is on'
        'set_desktop_for_window:move a window to a different desktop (or current_desktop|all)'
        'savewindowstack:save the current query stack under a name'
        'loadwindowstack:reload a previously saved window stack by name'
        # Global Commands
        'get_desktop:output the current desktop number'
        'set_desktop:change the current desktop'
        'get_num_desktops:output the number of desktops'
    )

    _arguments -s -S -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show program version]' \
        '(-q --quiet)'{-q,--quiet}'[do not print anything to stdout (for scripting)]' \
        '(-d --debug)'{-d,--debug}'[enable debug output]' \
        '(-n --dry-run)'{-n,--dry-run}'[do not actually run the script - just print it to stdout]' \
        '--shortcut=[register a global shortcut to run this command pipeline]:shortcut:' \
        '--name=[name for the registered shortcut (used with --shortcut)]:name:' \
        '--remove=[remove a previously registered shortcut by name]:name:' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'kdotool command' cmds && ret=0
            ;;
        args)
            case $line[1] in
                search)
                    _arguments \
                        '(-C --case-sensitive)'{-C,--case-sensitive}'[match window title case-sensitively]' \
                        '(-c --class)'{-c,--class}'[match against window class]' \
                        '(-n --classname)'{-n,--classname}'[match against window classname]' \
                        '(-r --role)'{-r,--role}'[match against window role]' \
                        '(-t --title --name)'{-t,--title,--name}'[match against window title (titlebar)]' \
                        '(-p --pid)'{-p,--pid=}'[match windows belonging to a PID]:pid:_pids' \
                        '(-D --desktop)'{-D,--desktop=}'[only match windows on a desktop number]:desktop:' \
                        '(-l --limit)'{-l,--limit=}'[stop after N matches (0 = unlimited)]:limit:' \
                        '(-a --all --any)'{-a,--all}'[require all conditions met]' \
                        '(-a --all --any)--any[match any condition (default)]' \
                        '*:regex pattern:' && ret=0
                    ;;
                getmouselocation)
                    _arguments \
                        '--shell[output shell data you can eval]' && ret=0
                    ;;
                windowmove)
                    _arguments \
                        '--relative[move relative to the current window position]' \
                        '*:WINDOW or X Y coordinate:' && ret=0
                    ;;
                windowstate)
                    _arguments \
                        '*--add=[add property]:property:(above below skip_taskbar skip_pager fullscreen shaded demands_attention no_border minimized maximized_horz maximized_vert maximized)' \
                        '*--remove=[remove property]:property:(above below skip_taskbar skip_pager fullscreen shaded demands_attention no_border minimized maximized_horz maximized_vert maximized)' \
                        '*--toggle=[toggle property]:property:(above below skip_taskbar skip_pager fullscreen shaded demands_attention no_border minimized maximized_horz maximized_vert maximized)' \
                        '*:WINDOW:' && ret=0
                    ;;
                set_desktop_for_window)
                    _arguments \
                        '*:WINDOW or desktop number or current_desktop or all:(current_desktop all)' && ret=0
                    ;;
                savewindowstack|loadwindowstack)
                    _arguments '1:name:' '*::next command: ' && ret=0
                    ;;
                *)
                    _arguments '*:WINDOW or arg:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_kdotool "$@"
