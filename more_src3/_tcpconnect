#compdef tcpconnect tcpconnect-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpconnect.py argparse)
# Reference accessed: 2026-05-29
# tcpconnect — trace TCP active (outbound) connect()s (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --timestamp)'{-t,--timestamp}'[include timestamp on output]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-P --port)'{-P,--port=}'[comma-separated list of destination ports to trace]:ports:' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '(-L --lport)'{-L,--lport}'[include LPORT on output]' \
  '(-U --print-uid)'{-U,--print-uid}'[include UID on output]' \
  '(-u --uid)'{-u,--uid=}'[trace this UID only]:uid:' \
  '(-c --count)'{-c,--count}'[count connects per src ip and dest ip/port]' \
  '--cgroupmap=[trace cgroups in this BPF map only]:map:' \
  '--mntnsmap=[trace mount namespaces in this BPF map only]:map:' \
  '(-d --dns)'{-d,--dns}'[include likely DNS query associated with each connect]' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
