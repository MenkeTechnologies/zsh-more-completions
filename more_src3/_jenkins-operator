#compdef jenkins-operator
# _jenkins-operator — Prow operator that runs ProwJobs on a Jenkins master (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/jenkins-operator/main.go (flag).

_jenkins-operator() {
    _arguments \
        '-label-selector=[ProwJob label selector]:selector:' \
        '-tot-url=[Tot URL]:url:_urls' \
        '-jenkins-url=[Jenkins URL]:url:_urls' \
        '-jenkins-user=[Jenkins username]:user:_users' \
        '-jenkins-token-file=[Jenkins API token file]:file:_files' \
        '-jenkins-bearer-token-file=[Jenkins API bearer token file]:file:_files' \
        '-cert-file=[PEM certificate file]:file:_files' \
        '-key-file=[PEM key file]:file:_files' \
        '-ca-cert-file=[PEM CA certificate file]:file:_files' \
        '-csrf-protect[request a Jenkins CSRF protection token]' \
        '-skip-report[do not report with the GitHub client]' \
        '-dry-run=[whether to make mutating API calls]:val:(true false)' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-github-token-path=[GitHub token file]:file:_files'
}

_jenkins-operator "$@"
