#compdef tenere
# Documentation: https://github.com/pythops/tenere
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (src/main.rs clap args).

# Zsh completion for tenere - TUI interface for LLMs (ChatGPT, llama.cpp, Ollama, etc.)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[path to custom config file]:file:_files' && ret=0

return ret
