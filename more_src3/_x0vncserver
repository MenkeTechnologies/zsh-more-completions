#compdef x0vncserver
# _x0vncserver — TigerVNC x0vncserver (export the main X server (display :0) over RFB without spawning a new X; -display source X display, -SecurityTypes/-PasswordFile auth, -rfbport listen port)
# upstream: https://github.com/TigerVNC/tigervnc
# Flags from tigervnc unix/x0vncserver/x0vncserver.cxx on tip.

_x0vncserver() {
    _arguments \
        '-display+[X display to export]:display:' \
        '-rfbport+[listen port]:port:' \
        '-SecurityTypes+[security types]:types:(None VncAuth Plain TLSNone TLSVnc TLSPlain X509None X509Vnc X509Plain)' \
        '-PasswordFile+[password file]:file:_files' \
        '-localhost[bind to localhost only]' \
        '-AlwaysShared[multiple clients]' \
        '-NeverShared[refuse extra clients]' \
        '-PollingCycle+[polling ms]:ms:' \
        '-MaxIdleTime+[idle seconds before disconnect]:seconds:'
}

_x0vncserver "$@"
