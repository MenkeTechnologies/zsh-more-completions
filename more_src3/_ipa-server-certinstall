#compdef ipa-server-certinstall
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-server-certinstall.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-server-certinstall.1.

# ipa-server-certinstall: install SSL cert into IPA server services
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --dirsrv)'{-d,--dirsrv}'[install cert on Directory Server]' \
  '(-w --http)'{-w,--http}'[install cert in Apache Web Server]' \
  '(-k --kdc)'{-k,--kdc}'[install cert in Kerberos KDC]' \
  '--pin=[password to unlock private key]:pin:' \
  '--cert-name=[cert name to install]:name:' \
  '(-p --dirman-password)'{-p,--dirman-password=}'[Directory Manager password]:password:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[output only errors]' \
  '--log-file=[log to file]:file:_files' \
  '*:cert file:_files' && ret=0
return ret
