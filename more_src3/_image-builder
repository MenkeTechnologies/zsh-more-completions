#compdef image-builder
# _image-builder — build OS images / bootc artifacts from the CLI (osbuild/image-builder-cli)
# upstream: https://github.com/osbuild/image-builder-cli
# Subcommands from cmd/image-builder/main.go (cobra).

_image-builder() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_image-builder_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                version)
                    _arguments \
                        '--format=[output format]:format:(yaml json)'
                    ;;
                bootc)
                    _arguments '1:bootc subcommand:(inspect)'
                    ;;
                build|manifest|describe)
                    _arguments \
                        '*--blueprint=[blueprint file (YAML/JSON/TOML)]:file:_files' \
                        '--distro=[distro override (rhel-9, fedora-39, ...)]:distro:' \
                        '--arch=[target architecture]:arch:(amd64 arm64 ppc64le s390x x86_64 aarch64)' \
                        '--cache-dir=[cache/store directory]:dir:_files -/' \
                        '--output-dir=[output directory]:dir:_files -/' \
                        '--output-name=[basename for the produced image]:name:' \
                        '*--with-image-types=[only include these image types]:type:' \
                        '1:image type:'
                    ;;
                upload)
                    _arguments \
                        '--to=[upload target URL or profile]:target:' \
                        '1:image path:_files'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_image-builder_commands] )) ||
_image-builder_commands() {
    local -a commands
    commands=(
        'build:build an OS image from a blueprint'
        'manifest:generate an osbuild manifest from a blueprint'
        'describe:describe an image type / blueprint'
        'list:list available image types / distros'
        'version:print image-builder version'
        'upload:upload a built image to a cloud target'
        'bootc:bootc image-builder helpers (inspect)'
    )
    _describe -t commands 'image-builder command' commands
}

_image-builder "$@"
