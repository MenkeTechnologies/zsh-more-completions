#compdef scriptisto
# _scriptisto — Igor Petruk scriptisto language-agnostic shebang interpreter that builds and caches scripts (igor-petruk team, Rust); clap-derive
# upstream: https://github.com/igor-petruk/scriptisto

_scriptisto() {
    local -a sub=(
        'new:create a new script from template'
        'template:print template content'
        'build:build a script'
        'cache:cache subcommands'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scriptisto subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '--lang=+[language]:l:(rust c cpp go python java haskell typescript javascript swift kotlin scala dart d zig nim ocaml ruby perl)' \
                    '-l+[language]:l:(rust c cpp go python java haskell typescript javascript swift kotlin scala dart d zig nim ocaml ruby perl)' \
                    '*:script name:_files' ;;
                template) _arguments '1:template:(rust c cpp go python java haskell typescript javascript swift kotlin scala dart d zig nim ocaml ruby perl)' ;;
                build) _arguments \
                    '--build-only[only build]' \
                    '-b[only build]' \
                    '*:script:_files' ;;
                cache) _arguments '1:cache cmd:(clear-target clear-all path)' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_scriptisto "$@"
