#compdef solhint
# Documentation: https://github.com/protofire/solhint
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for solhint - Solidity linter

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create configuration file for solhint'
  'list-rules:display covered rules of current .solhint.json'
  'stdin:lint source code data provided to STDIN'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[output usage information]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  '(-c --config)'{-c,--config}'[specify rules configuration file]:file:_files' \
  '(-f --formatter)'{-f,--formatter}'[report formatter]:formatter:(stylish table tap unix json compact sarif)' \
  '(-w --max-warnings)'{-w,--max-warnings}'[number of allowed warnings]:num:' \
  '(-q --quiet)'{-q,--quiet}'[report errors only]' \
  '--ignore-path[use custom ignore file]:file:_files' \
  '--fix[automatically fix problems and show report]' \
  '--cache[only lint files changed since last run]' \
  '--cache-location[path to cache file]:file:_files' \
  '--noPrompt[do not suggest file backups when using fix]' \
  '--save[save report to file in current folder]' \
  '--noPoster[remove Discord poster]' \
  '--disc[skip solhint update checks]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _alternative \
      'commands:command:_describe -t commands "command" commands' \
      'files:file:_files -g "*.sol"' && ret=0
    ;;
  args)
    case $words[1] in
      stdin)
        _arguments \
          '--filename[filename for the stdin input]:filename:' && ret=0
        ;;
      *)
        _files -g '*.sol' && ret=0
        ;;
    esac
    ;;
esac

return ret
