#compdef heif-enc heif-dec heif-info heif-thumbnailer heif-convert libheif
# _libheif — Dirk Farin libheif heif-enc heif-dec heif-info HEIF HEIC AVIF image format tools (struktur team, C++); custom argparse
# upstream: https://github.com/strukturag/libheif

_libheif() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q+[quality 0-100]:n:' \
        '--quality=+[quality 0-100]:n:' \
        '-L[lossless mode]' \
        '--lossless[lossless mode]' \
        '-t+[thumbnail size]:n:' \
        '--thumb=+[thumbnail size]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-e+[encoder]:e:(x265 aom rav1e svt-av1 avif1 jpeg uncompressed vvenc)' \
        '--encoder=+[encoder]:e:(x265 aom rav1e svt-av1 avif1 jpeg uncompressed)' \
        '-A[use AVIF compression]' \
        '--avif[use AVIF compression]' \
        '-c+[colorspace]:c:(yuv420 yuv422 yuv444 rgb monochrome)' \
        '--chroma=+[chroma]:c:(yuv420 yuv422 yuv444)' \
        '-d+[bit depth]:d:(8 10 12)' \
        '--bit-depth=+[bit depth]:d:(8 10 12)' \
        '-T+[matrix coefficients]:str:' \
        '--matrix-coefficients=+[matrix coefficients]:str:' \
        '-r+[range]:r:(limited full)' \
        '--range=+[range]:r:(limited full)' \
        '-P+[colour primaries]:str:' \
        '--colour-primaries=+[colour primaries]:str:' \
        '-X+[transfer characteristics]:str:' \
        '--transfer-characteristics=+[transfer characteristics]:str:' \
        '-p+[encoder param=value]:str:' \
        '--enc-param=+[encoder param=value]:str:' \
        '-D[output debug]' \
        '--debug[output debug]' \
        '--cicp=+[primaries:transfer:matrix:range]:str:' \
        '--no-overwrite[no overwrite]' \
        '--list-encoders[list encoders]' \
        '--list-decoders[list decoders]' \
        '--avif-tiles=+[NxM]:str:' \
        '--matrix-output[matrix output]' \
        '--with-alpha[with alpha channel]' \
        '--without-alpha[without alpha]' \
        '*:input file:_files -g "*.heic *.heif *.avif *.jpg *.jpeg *.png *.y4m *.tiff *.tif"'
}

_libheif "$@"
