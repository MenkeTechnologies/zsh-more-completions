#compdef zypper
# Documentation: https://en.opensuse.org/SDB:Zypper_manual
# Source: openSUSE/zypper src/Zypper.cc + src/Command.cc — openSUSE package manager (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    {-c+,--config=}'[config file]:file:_files' \
    '*'{-v,--verbose}'[increase verbosity]' \
    {-q,--quiet}'[suppress normal output]' \
    '--terse[terse output, machine-readable]' \
    {-A,--no-abbrev}'[do not abbreviate text in tables]' \
    {-t,--table-style=}'[table style]:n:_default' \
    '--no-color[whether to use colors]' \
    {-x,--xmlout}'[XML output]' \
    '(--non-interactive -n)'{--non-interactive,-n}'[do not ask anything; default answers]' \
    '--non-interactive-include-reboot-patches[automatically include reboot patches]' \
    '--no-cd[ignore CD/DVD repositories]' \
    '--no-remote[ignore remote repositories]' \
    '--reposd-dir=-[repo definitions directory]:dir:_files -/' \
    '--cache-dir=-[cache directory]:dir:_files -/' \
    '--raw-cache-dir=-[raw cache directory]:dir:_files -/' \
    '--solv-cache-dir=-[SOLV cache directory]:dir:_files -/' \
    '--pkg-cache-dir=-[package cache directory]:dir:_files -/' \
    '(-R --no-refresh)'{-R,--no-refresh}'[do not refresh repos before command]' \
    '--gpg-auto-import-keys[trust+import new repo signing keys automatically]' \
    '*'{-p+,--plus-repo=}'[add additional repo URI]:uri:_default' \
    '*'{-D+,--plus-content=}'[add repos providing this content]:tag:_default' \
    '--disable-repositories[do not read meta-data from repos]' \
    '--disable-system-resolvables[do not read installed packages]' \
    '--root=-[operate from this root directory]:dir:_files -/' \
    '--installroot=-[install-only root]:dir:_files -/' \
    '--userdata=-[user transaction id]:id:_default' \
    '--promptids[print known prompt IDs]' \
    '--ignore-unknown[ignore unknown packages]' \
    '1:command:(addlocale addlock addrepo addservice al as catalogs cc cl clean clean-cache dist-upgrade dup exit help if info install in install-new-recommends inr list-patches lp list-updates lu ll locales lock-add locks lr ls modifyrepo mr modifyservice ms packages pa patch patch-check pchk patches patterns pt products pd quit refresh ref refresh-services refs remove removelocale removelock removeptf removerepo removeservice rm renamerepo nr repos rl rs search se service-add service-delete service-list services source-install si shell sh targetos tos update up verify ve versioncmp vcmp what-provides wp)' \
    '*::command args:_default' \
    && ret=0

return ret
