#compdef haystack
# _haystack — deepset Haystack LLM/RAG pipelines CLI (deepset, Python); click
# upstream: https://github.com/deepset-ai/haystack

_haystack() {
    local -a sub=(
        'pipeline:work with pipelines'
        'component:work with components'
        'eval:evaluate pipelines'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'haystack subcommand' sub ;;
        args)
            case $words[1] in
                pipeline) _arguments \
                    '1:cmd:(run draw serialize deserialize validate)' \
                    '--input=+[input file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '--format=+[format]:fmt:(yaml json)' \
                    '*:arg:' ;;
                component) _arguments \
                    '1:cmd:(list show)' \
                    '*:arg:' ;;
                eval) _arguments \
                    '1:cmd:(run)' \
                    '--pipeline=+[pipeline file]:file:_files' \
                    '--data=+[eval data file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_haystack "$@"
