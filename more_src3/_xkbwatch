#compdef xkbwatch
# Documentation: man xkbwatch (X.Org)
# Source: XKB state-change monitor (mostly a -version-only stub).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-version[show version]' \
    && ret=0

return ret
