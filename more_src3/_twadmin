#compdef twadmin
# Documentation: man twadmin(8)
# Source: Tripwire/tripwire-open-source src/twadmin/twadmincl.cpp (master) — tripwire admin tool (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\\?,--help}'[show help]' \
    '(-m --mode)'{-m+,--mode=}'[admin mode]:mode:(create-cfgfile create-polfile print-cfgfile print-polfile remove-encryption encrypt examine generate-keys change-passphrases)' \
    '--create-cfgfile[create encrypted configuration file]' \
    '--create-polfile[create encrypted policy file]' \
    '--print-cfgfile[decrypt and print configuration]' \
    '--print-polfile[decrypt and print policy]' \
    '--remove-encryption[remove encryption from file]' \
    '--encrypt[encrypt file]' \
    '--examine[examine file (show signing/encryption)]' \
    '--generate-keys[generate site/local keys]' \
    '--change-passphrases[change site/local passphrases]' \
    '(-v --verbose -s --silent --quiet)'{-v,--verbose}'[verbose output]' \
    '(-v --verbose -s --silent --quiet)'{-s,--silent,--quiet}'[silent output]' \
    '(-c --cfgfile)'{-c+,--cfgfile=}'[config file]:file:_files' \
    '(-p --polfile)'{-p+,--polfile=}'[policy file]:file:_files' \
    '(-S --site-keyfile)'{-S+,--site-keyfile=}'[site keyfile]:file:_files -g "*.key"' \
    '(-L --local-keyfile)'{-L+,--local-keyfile=}'[local keyfile]:file:_files -g "*.key"' \
    '(-P --passphrase)'{-P+,--passphrase=}'[passphrase]:passphrase:_default' \
    '(-Q --site-passphrase)'{-Q+,--site-passphrase=}'[site key passphrase]:passphrase:_default' \
    '(-K --site-keysize)'{-K+,--site-keysize=}'[site key size]:bits:_default' \
    '(-Y --local-keysize)'{-Y+,--local-keysize=}'[local key size]:bits:_default' \
    '(-e --no-encryption)'{-e,--no-encryption}'[do not encrypt output file]' \
    '(-n --no-signing)'{-n,--no-signing}'[do not sign output file]' \
    '*:file:_files' \
    && ret=0

return ret
