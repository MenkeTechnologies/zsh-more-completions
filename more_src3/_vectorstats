#compdef vectorstats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/vectorstats.html
# Source: MRtrix3/mrtrix3 cmd/vectorstats.cpp — general linear model with permutation testing on vectors (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '-notest[generate design output only, no testing]' \
    '-errors+[error type to assume]:type:(ee ise both)' \
    '-exchange_within+[within-block exchangeability]:file:_files' \
    '-exchange_whole+[whole-block exchangeability]:file:_files' \
    '-strong[strong family-wise control]' \
    '-nshuffles+[number of permutations]:n:_default' \
    '-permutations+[permutations file]:file:_files' \
    '-variance+[variance group assignments]:file:_files' \
    '1:input (text file of file names):_files -g "*.txt"' \
    '2:design matrix:_files' \
    '3:contrast matrix:_files' \
    '4:output prefix:_default' \
    && ret=0

return ret
