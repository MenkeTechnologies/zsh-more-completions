#compdef xprintidle
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/xprintidle.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' && ret=0

return ret
