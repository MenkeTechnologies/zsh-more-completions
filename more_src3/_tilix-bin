#compdef tilix
# _tilix-bin — Tilix GTK3 tiling terminal (Gerald Nunn, D); GNOME terminal with split panes + session save
# upstream: https://github.com/gnunn1/tilix

_tilix-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-w --working-directory)'{-w,--working-directory}'+[cwd]:dir:_files -/' \
        '(-e --command)'{-e,--command}'+[command]:cmd:_command_names -e' \
        '(-x --execute)'{-x,--execute}'+[execute]:cmd:_command_names -e' \
        '(-t --title)'{-t,--title}'+[title]:title:' \
        '(-p --profile)'{-p,--profile}'+[profile]:profile:' \
        '(-a --action)'{-a,--action}'+[action]:action:(app-new-session app-new-window session-add-right session-add-down)' \
        '(-s --session)'{-s,--session}'+[session]:file:_files -g "*.tilix"' \
        '--maximize[maximize]' \
        '--minimize[minimize]' \
        '--full-screen[fullscreen]' \
        '--focus-window[focus window]' \
        '--new-process[force new process]' \
        '--geometry+[geometry]:geom:' \
        '--quake[quake mode]' \
        '--group+[group with window UUID]:uuid:' \
        '--terminal-uuid+[terminal UUID]:uuid:' \
        '--window-style+[window style]:style:(normal disable-csd disable-csd-hide-toolbar borderless)'
}

_tilix-bin "$@"
