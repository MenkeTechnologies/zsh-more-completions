#compdef losetup-cli
# _losetup-cli — util-linux losetup loop device setup CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_losetup-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[show all]' \
        '--all[show all]' \
        '-d[detach loop]' \
        '--detach[detach loop]' \
        '-D[detach all]' \
        '--detach-all[detach all]' \
        '-f[find unused loop]' \
        '--find[find unused loop]' \
        '-c[reread capacity]' \
        '--set-capacity[reread capacity]' \
        '-j+[file]:file:_files' \
        '--associated=+[file]:file:_files' \
        '-L[avoid possible conflicts]' \
        '--nooverlap[avoid possible conflicts]' \
        '-r[read-only]' \
        '--read-only[read-only]' \
        '--direct-io=+[bool]:b:(on off)' \
        '--ro[read-only]' \
        '--rw[read-write]' \
        '--show[show device name]' \
        '-s[show device name]' \
        '-N[no header]' \
        '--noheadings[no header]' \
        '-O+[output cols]:str:' \
        '--output=+[output cols]:str:' \
        '--output-all[output all cols]' \
        '-J[json output]' \
        '--json[json output]' \
        '-l[long listing]' \
        '--list[long listing]' \
        '-r[read-only]' \
        '-P[scan partitions]' \
        '--partscan[scan partitions]' \
        '-o+[offset bytes]:n:' \
        '--offset=+[offset bytes]:n:' \
        '--sizelimit=+[bytes]:n:' \
        '-b+[sector size]:n:' \
        '--sector-size=+[sector size]:n:' \
        '--loop-ref=+[label]:str:' \
        '*:device file:_files'
}

_losetup-cli "$@"
