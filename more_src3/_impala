#compdef impala impala-shell
# Documentation: https://impala.apache.org/docs/build/html/topics/impala_shell_options.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Apache Impala impala-shell: interactive/scriptable client for Impala daemons
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --impalad)'{-i+,--impalad=}'[connect to host[:port]]:host:_hosts' \
  '(-b --kerberos_host_fqdn)'{-b+,--kerberos_host_fqdn=}'[override Kerberos hostname]:fqdn:_hosts' \
  '(-k --kerberos)'{-k,--kerberos}'[use Kerberos auth]' \
  '(-s --kerberos_service_name)'{-s+,--kerberos_service_name=}'[Kerberos service principal name]:name:' \
  '-l[use LDAP auth]' \
  '-u+[LDAP username]:user:_users' \
  '--ldap_password_cmd=[command to retrieve LDAP password]:cmd:' \
  '-ssl[enable TLS/SSL]' \
  '--ca_cert=[CA certificate path]:file:_files' \
  '--protocol=[connection protocol]:proto:(hs2 hs2-http beeswax)' \
  '(-q --query)'{-q+,--query=}'[execute a single query]:query:' \
  '(-f --query_file)'{-f+,--query_file=}'[execute queries from file]:file:_files' \
  '(-d --database)'{-d+,--database=}'[startup database]:db:' \
  '(-Q --query_option)'*{-Q+,--query_option=}'[set query option (key=value)]:opt:' \
  '*--var=[define substitution variable name=value]:var:' \
  '(-B --delimited)'{-B,--delimited}'[output delimited text]' \
  '--output_delimiter=[output delimiter character]:char:' \
  '(-o --output_file)'{-o+,--output_file=}'[output results to file]:file:_files' \
  '(-E --vertical)'{-E,--vertical}'[print output vertically]' \
  '--print_header[print column headers]' \
  '(-p --show_profiles)'{-p,--show_profiles}'[show query profiles after execution]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '--quiet[disable verbose output]' \
  '-c[continue on query failure]' \
  '--live_progress[show progress bar]' \
  '--disable_live_progress[disable progress bar]' \
  '--live_summary[show detailed progress report]' \
  '--config_file=[config file path]:file:_files' && ret=0
return ret
