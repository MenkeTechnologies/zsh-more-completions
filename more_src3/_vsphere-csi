#compdef vsphere-csi
# _vsphere-csi — vSphere CSI driver (CSI controller + node for VMware vSphere CNS)
# upstream: https://github.com/kubernetes-sigs/vsphere-csi-driver
# Flags from cmd/vsphere-csi/main.go on tip.

_vsphere-csi() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print driver version and exit]' \
        '--supervisor-fss-name=[supervisor feature-state-switch configmap name]:name:' \
        '--supervisor-fss-namespace=[supervisor feature-state-switch configmap namespace]:ns:' \
        '--fss-name=[internal feature-state-switch configmap name]:name:' \
        '--fss-namespace=[internal feature-state-switch configmap namespace]:ns:' \
        '--enable-profile-server[enable controller profiling endpoint]' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_vsphere-csi "$@"
