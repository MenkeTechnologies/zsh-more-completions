#compdef lacheck
# Documentation: https://www.gnu.org/software/texinfo/manual/texinfo/lacheck.html
# Reference accessed: 2026-05-19
# Verified: lacheck(1) man page from TeX Live (LaCheck 1.30). Synopsis:
# `lacheck filename[.tex]` - no command-line flags.

local -a arguments

arguments=(
    '*:LaTeX file:_files -g "*.tex"'
)

_arguments -s -S $arguments
