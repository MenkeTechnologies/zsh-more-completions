#compdef siril siril-cli
# _siril — astronomical image processing tool (free-astro/siril)
# upstream: https://gitlab.com/free-astro/siril
# Flags from siril(1) man page.

_siril() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(- *)'{-c,--copyright}'[show copyright]' \
        '(-f --format)'{-f,--format}'[list supported image formats]' \
        '-i+[configuration file]:file:_files' \
        '(-o --offline)'{-o,--offline}'[start in offline mode]' \
        '-p[start headless using named pipes]' \
        '(-r --inpipe)'{-r+,--inpipe=}'[input pipe path]:path:_files' \
        '(-w --outpipe)'{-w+,--outpipe=}'[output pipe path]:path:_files' \
        '(-d --directory)'{-d+,--directory=}'[working directory]:dir:_files -/' \
        '(-s --script)'{-s+,--script=}'[script file (- for stdin)]:file:_files' \
        '*:image or sequence:_files'
}

_siril "$@"
