#compdef live-server
# Documentation: https://github.com/tapio/live-server
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for live-server - Development server with live reload

_arguments \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '--port=[specify port]:port:' \
  '--host=[specify host address]:host:' \
  '--open=[open browser to path]:path:' \
  '--no-browser[do not open browser]' \
  '--browser=[specify browser to use]:browser:' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
  '--watch=[comma-separated paths to watch]:paths:' \
  '--ignore=[comma-separated patterns to ignore]:patterns:' \
  '--ignorePattern=[regex pattern to ignore]:regex:' \
  '--no-css-inject[reload page on CSS change instead of injecting]' \
  '--entry-file=[serve this file for all 404s]:file:_files' \
  '--mount=[mount a directory to a path (path\:dir)]:path\:dir:' \
  '--spa[translate requests to /index.html for SPA]' \
  '--wait=[wait time in ms before reloading]:milliseconds:' \
  '--htpasswd=[htpasswd file for authentication]:file:_files' \
  '--cors[enable CORS]' \
  '--https=[path to HTTPS config]:config file:_files' \
  '--https-module=[HTTPS module to use (e.g. spdy)]:module:' \
  '--proxy=[proxy requests (path\:url)]:path\:url:' \
  '--middleware=[middleware file to load]:file:_files' \
  '*:directory:_directories'
