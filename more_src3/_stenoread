#compdef stenoread stenocurl
# _stenoread — Google stenographer stenoread query CLI wrapping HTTPS calls to the stenographer daemon retrieving stored pcap segments by time-range BPF filter or 5-tuple writing to tcpdump or to disk (google team, Go); flag
# upstream: https://github.com/google/stenographer

_stenoread() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output pcap]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '--output=+[output pcap]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '-w+[output pcap]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '--write=+[output pcap]:file:_files -g "*.pcap *.pcapng *.cap"' \
        '-cacert=+[file]:file:_files -g "*.crt *.pem"' \
        '-cert=+[file]:file:_files -g "*.crt *.pem"' \
        '-key=+[file]:file:_files -g "*.key *.pem"' \
        '-server=+[url]:str:' \
        '-port=+[port]:n:' \
        '-tcpdump-args=+[args]:str:' \
        '-stenocurl-args=+[args]:str:' \
        '--debug[debug]' \
        '--retries=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '*:query expression:'
}

_stenoread "$@"
