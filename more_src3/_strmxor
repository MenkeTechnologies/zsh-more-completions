#compdef strmxor
# Documentation: https://www.klayout.de/
# Source: KLayout/klayout src/buddies/src/bd/strmxor.cc — layout XOR (geometric difference) tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-ta --top-a)'{-ta,--top-a=}'[top cell for first layout]:name:' \
    '(-tb --top-b)'{-tb,--top-b=}'[top cell for second layout]:name:' \
    '(-to --top-output)'{-to,--top-output=}'[top cell for output layout]:name:' \
    '(-u --deep)'{-u,--deep}'[deep hierarchical mode]' \
    '(-s --silent)'{-s,--silent}'[silent mode]' \
    '--no-summary[do not print a summary]' \
    '(-l --layer-details)'{-l,--layer-details}'[treat missing layers as empty]' \
    '(-t --tolerances)'{-t,--tolerances=}'[tolerances for geometry compare]:values:' \
    '(-n --threads)'{-n,--threads=}'[number of threads to use]:threads:' \
    '(-p --tiles)'{-p,--tiles=}'[tiling mode size]:size:' \
    '(-m --heal)'{-m,--heal}'[heal results in tiling mode]' \
    '(-b --layer-bump)'{-b,--layer-bump=}'[layer number offset added per tolerance]:offset:' \
    '*:input layouts (A B then output):_files' \
    && ret=0

return ret
