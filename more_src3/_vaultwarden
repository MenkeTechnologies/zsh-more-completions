#             config::SKIP_CONFIG_VALIDATION.store(true, Ordering::Relaxed);
#             let web_vault_version = util::get_active_web_release();
#             println!("Vaultwarden {version}");
#             println!("Web-Vault {web_vault_version}");
#             exit(0);
#         }
#
#         if let Some(command) = pargs.subcommand().unwrap_or_default() {
#             if command == "hash" {
#                 // Generate Argon2id PHC for ADMIN_TOKEN
#                 let preset: Option<String> = pargs
#                     .opt_value_from_str(["-p", "--preset"])
#                     .unwrap_or_default();
#                 // ... process hash with preset (bitwarden|owasp)
#             } else if command == "backup" {
#                 // Backup SQLite database
#                 match db::backup_sqlite() { ... }
#             }
#         }
#     }
#
# Five-axis distinctness from every other documented Rust argv parser:
#
#   1. ZERO DEPENDENCIES + SINGLE FILE — Every other documented
#      Rust argv parser (except lexopt) has at least one crate
#      dependency.  pico-args has ZERO and lives in a single
#      ~600-line .rs file.
#
#   2. IMPERATIVE EXTRACT-AT-CALLSITE — Every other documented
#      Rust argv parser uses schema-first (clap/structopt/argh/
#      gumdrop) or combinator-first (bpaf) declaration.  pico-
#      args has no schema — call sites just ask for flags by name.
#
#   3. CONSUMING-AND-FINISH SEMANTICS — Every other documented
#      Rust argv parser maintains state and returns parsed
#      values.  pico-args CONSUMES argv as it goes and exposes
#      unconsumed args via `.finish()` — natural way to detect
#      unknown flags.
#
#   4. OsString-FIRST DESIGN — Every other documented Rust argv
#      parser converts to String/utf-8 implicitly.  pico-args
#      keeps OsString as primary type with opt-in UTF-8
#      conversion.
#
#   5. EXPLICIT COMPILE-SPEED PRIORITY — Every other documented
#      Rust argv parser uses derive macros or proc-macros that
#      add significant compile time.  pico-args has no macros
#      at all — <1 second compile time vs 5-15 seconds for
#      clap derive.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/dani-garcia/vaultwarden/blob/main/src/main.rs
# `parse_args` function + `HELP` constant.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _vw_cmds
_vw_cmds=(
    'hash:generate an Argon2id PHC string for ADMIN_TOKEN'
    'backup:create a backup of the SQLite database'
)

_arguments -C \
    '(- *)'{-h,--help}'[print help information]' \
    '(- *)'{-v,--version}'[print Vaultwarden and Web-Vault version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'vaultwarden command' _vw_cmds && ret=0
        ;;
    args)
        case $words[1] in
            hash)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    '(-p --preset)'{-p+,--preset=}'[Argon2id parameter preset]:preset:((bitwarden\:"64MiB,\ 3\ iter,\ 4\ threads\ (default)" owasp\:"19MiB,\ 2\ iter,\ 1\ thread"))' \
                    && ret=0
                ;;
            backup)
                _arguments \
                    '(- *)'{-h,--help}'[show help]' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
