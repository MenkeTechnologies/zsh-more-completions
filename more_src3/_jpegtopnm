#compdef jpegtopnm
# Documentation: man jpegtopnm (Netpbm)
# Source: convert a JPEG image to PNM (libjpeg-based).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dct=[DCT method]:method:(int fast float)' \
    '-nosmooth[no smoothing during upsampling]' \
    '-maxmemory=[max memory bytes]:N:' \
    '(-adobe -notadobe)-adobe[force Adobe-marker handling]' \
    '(-adobe -notadobe)-notadobe[ignore Adobe markers]' \
    '-comments[print JPEG comments to stderr]' \
    '-dumpexif[dump Exif data and exit]' \
    '-exif=[write Exif data to filespec]:file:_files' \
    '-multiple[treat input as multi-image stream]' \
    '-repair[repair corrupted images]' \
    '-verbose[verbose output]' \
    '-tracelevel=[libjpeg trace level]:N:' \
    '-traceexif[trace Exif processing]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:jpeg file:_files -g "*.(jpg|jpeg|jpe)"' \
    && ret=0

return ret
