#compdef huggingface-cli hf
# Documentation: https://huggingface.co/docs/huggingface_hub/main/en/guides/cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Hugging Face Hub CLI (hf / huggingface-cli).

_huggingface_subcommands() {
  local -a subcmds=(
    'auth:manage authentication (login, logout, etc.)'
    'buckets:interact with buckets'
    'cache:manage local cache directory'
    'collections:interact with collections on the Hub'
    'datasets:interact with datasets on the Hub'
    'download:download files from the Hub'
    'endpoints:manage Hugging Face Inference Endpoints'
    'extensions:manage hf CLI extensions'
    'jobs:run and manage Jobs on the Hub'
    'models:interact with models on the Hub'
    'papers:interact with papers on the Hub'
    'repo:manage repos on the Hub'
    'skills:manage skills for AI assistants'
    'spaces:interact with spaces on the Hub'
    'sync:sync files between local directory and bucket'
    'upload:upload a file or folder to the Hub'
    'upload-large-folder:upload a large folder'
    'env:print environment information'
    'version:print hf version'
    'login:log in (legacy)'
    'logout:log out (legacy)'
    'whoami:show current user info (legacy)'
    'scan-cache:scan cache directory (legacy)'
    'delete-cache:delete cache entries (legacy)'
  )
  _describe -t commands 'huggingface CLI subcommand' subcmds
}

_huggingface() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '--install-completion[install shell completion]' \
    '--show-completion[show shell completion]' \
    '1:subcommand:_huggingface_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        download)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--repo-type=[type of repository]:type:(model dataset space)' \
            '--revision=[git revision]:revision:' \
            '*--include=[glob pattern to include]:pattern:' \
            '*--exclude=[glob pattern to exclude]:pattern:' \
            '--local-dir=[local directory to download to]:directory:_directories' \
            '--cache-dir=[cache directory]:directory:_directories' \
            '--token=[access token]:token:' \
            '--quiet[suppress progress bars]' \
            '--force-download[force re-download]' \
            '1:repo_id:'
          ;;
        upload)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--repo-type=[type of repository]:type:(model dataset space)' \
            '--revision=[git revision]:revision:' \
            '--commit-message=[commit message]:message:' \
            '--commit-description=[commit description]:description:' \
            '--create-pr[create a pull request]' \
            '--token=[access token]:token:' \
            '--quiet[suppress progress bars]' \
            '1:repo_id:' \
            '2:local_path:_files'
          ;;
        login)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--token=[access token]:token:' \
            '--add-to-git-credential[save token to git credential helper]'
          ;;
        logout)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--token=[access token to revoke]:token:'
          ;;
        whoami)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--token=[access token]:token:'
          ;;
        repo)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(create)' \
            '--type=[type of repository]:type:(model dataset space)' \
            '--organization=[organization]:organization:' \
            '--token=[access token]:token:'
          ;;
        scan-cache|cache)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--dir=[cache directory to scan]:directory:_directories' \
            '--verbose[show verbose output]'
          ;;
        delete-cache)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--dir=[cache directory]:directory:_directories' \
            '--disable-tui[disable TUI mode]'
          ;;
        env|version)
          _arguments '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_huggingface "$@"
