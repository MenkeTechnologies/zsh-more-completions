# ============================================================================
# _hrp — zsh completion for httprunner/httprunner (binary `hrp`), an
#         "All-in-One Testing Framework for API, UI and Performance" —
#         Go=148 leader bump continuing Axis 93 OpenAPI / openapiv3 via
#         the canonical Go schema library github.com/getkin/kin-openapi
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/httprunner/httprunner
#   Maintainer : httprunner (debugtalk)
#   License    : Apache-2.0
#   Stars      : 4279
#   Language   : Go (compiler) / Python (legacy v3)
#   Module     : github.com/httprunner/httprunner/v5
#   Binary     : hrp  (cmd/root.go RootCmd.Use = "hrp",
#                       built from cmd/cli/main.go)
#   Last push  : 2025-12-11
#
# WHAT IT IS
#   HttpRunner is "an open source API/UI testing framework, easy
#   to use and feature-rich, with extensible plugin mechanism".
#   Test cases are authored in GoTest, YAML, JSON, or natural-
#   language form (LLM-driven) and cover:  HTTP(S) / HTTP/2 /
#   WebSocket / gRPC API testing;  Android (via adb), iOS,
#   HarmonyOS, and browser UI automation;  and load testing via
#   the bundled boomer concurrent runner.  Test results render
#   to JSON logs + HTML reports for CI consumption, and the
#   bundled `mcpserver` / `mcphost` subcommands expose the
#   whole test driver as a Model Context Protocol surface for
#   AI coding agents.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/root.go RootCmd
#                       PersistentFlags + cmd/cli/main.go
#                       addAllCommands — spf13/cobra)
#   hrp [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global persistent flags:
#     -l, --log-level <LEVEL>        Log level (TRACE | DEBUG |
#                                    INFO | WARN | ERROR |
#                                    FATAL | PANIC)
#                                    [default: INFO]
#     --log-json                     Emit JSON logs (default:
#                                    colorized console)
#     --venv <PATH>                  Python3 venv path
#                                    (for plugin Python
#                                     functions)
#
#   Subcommands:
#     build                          Build a hashicorp/go-plugin
#                                    plugin from a `.py` / `.go`
#                                    source file
#     convert                        Convert testcase formats
#                                    (har → yaml/json/gotest,
#                                     postman/openapi → yaml,
#                                     swagger → yaml, etc.)
#     pytest                         Run testcases via pytest
#                                    (HttpRunner v3 Python
#                                     driver compatibility)
#     report                         Generate HTML test reports
#                                    from JSON logs
#     run                            Execute a test case (.yml |
#                                    .json | .py | .go) or
#                                    test directory
#     scaffold                       Create a new HttpRunner
#                                    project scaffold
#     server                         Start the gRPC test-runner
#                                    server (for distributed
#                                    boomer load testing)
#     wiki                           Open the online docs in a
#                                    browser
#     mcphost                        Run as an MCP host (client
#                                    that drives other MCP
#                                    servers)
#     mcpserver                      Run as an MCP server
#                                    (exposes test runner to AI
#                                    coding agents)
#
#     ios <SUBCOMMAND>               iOS device subcommands
#                                    (list, info, install,
#                                     uninstall, screenshot,
#                                     install-ipa, launch, ...)
#     adb <SUBCOMMAND>               Android (adb) device
#                                    subcommands (list, info,
#                                     install-apk, push, pull,
#                                     screenshot, launch, ...)
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help
#     -v, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/getkin/kin-openapi v0.118.0`
#   declared in go.mod — `kin-openapi` is THE canonical Go
#   OpenAPI 3.0.x / 3.1.x typed library maintained by Kin Lane
#   et al. (getkin/kin-openapi, 2.4K+ stars, used by Snyk
#   driftctl, oapi-codegen-style projects, Datadog API
#   generators, and the broader Go OpenAPI tooling stack).
#   kin-openapi exposes the typed `openapi3.T` (a complete
#   spec tree) with `openapi3.Info`, `openapi3.Server`,
#   `openapi3.Paths`, `openapi3.PathItem`, `openapi3.Operation`,
#   `openapi3.RequestBody`, `openapi3.Responses`,
#   `openapi3.Parameter`, `openapi3.Components`,
#   `openapi3.Schema` / `openapi3.SchemaRef` with $ref
#   resolution, `openapi3.SecurityScheme`,
#   `openapi3.MediaType`, `openapi3.Encoding`, `openapi3.Header`,
#   `openapi3.Discriminator`, `openapi3filter.Validator` for
#   typed request/response payload validation against the
#   spec, and the `openapi3gen` automatic-schema-generator that
#   reflects Go structs.  HttpRunner's
#   `convert/openapi/openapi3_loader.go` parses Swagger 2.0 /
#   OpenAPI 3.0 specs into `openapi3.T` via
#   `loader.LoadFromFile(...)`, walks `t.Paths.iter()`, and
#   emits a YAML / JSON / GoTest test-case skeleton for every
#   typed operation.  Verified via:
#     gh api repos/httprunner/httprunner/contents/go.mod
#       → github.com/getkin/kin-openapi v0.118.0
#       → github.com/spf13/cobra (transitively)
#       → module github.com/httprunner/httprunner/v5
#     gh api repos/httprunner/httprunner/contents/cmd/root.go
#       → RootCmd.Use = "hrp"
#       → PersistentFlags --log-level, --log-json, --venv
#     gh api repos/httprunner/httprunner/contents/cmd/cli/
#         main.go
#       → cmd.RootCmd.AddCommand(CmdBuild|CmdConvert|CmdPytest|
#           CmdReport|CmdRun|CmdScaffold|CmdServer|CmdWiki|
#           CmdMCPHost|CmdMCPServer|CmdIOSRoot|CmdAndroidRoot)
#   This entry is the Go=148 leader bump that continues Axis
#   93 (OpenAPI / openapiv3 schema library) opened at R961 with
#   Rust=openapiv3 via holon-run/uxc.
#
#   No completion for `hrp` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_hrp() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-l --log-level)'{-l,--log-level}'=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL PANIC)' \
        '--log-json[emit JSON logs]' \
        '--venv=[Python3 venv path]:path:_files -/' \
        '1: :_hrp_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run|pytest)
                    _arguments \
                        '*:test case or directory:_files' && ret=0 ;;
                convert)
                    _arguments \
                        '*:source file:_files -g "*.{yaml,yml,json,har,py,go}"' && ret=0 ;;
                report)
                    _arguments \
                        '*:JSON log file:_files -g "*.json"' && ret=0 ;;
                scaffold)
                    _arguments \
                        ':project name:' && ret=0 ;;
                ios|adb)
                    _arguments \
                        '1:device subcommand:(list info install uninstall screenshot launch push pull)' \
                        '*::arg:' && ret=0 ;;
                build|server|wiki|mcphost|mcpserver)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_hrp_commands] )) ||
_hrp_commands() {
    local -a commands
    commands=(
        'build:build a hashicorp/go-plugin plugin from source'
        'convert:convert testcase formats (har/postman/openapi/swagger)'
        'pytest:run testcases via pytest (v3 compatibility)'
        'report:generate HTML test reports from JSON logs'
        'run:execute a test case or directory'
        'scaffold:create a new HttpRunner project scaffold'
        'server:start the gRPC test-runner server'
        'wiki:open the online docs'
        'mcphost:run as an MCP host'
        'mcpserver:run as an MCP server'
        'ios:iOS device subcommands'
        'adb:Android (adb) device subcommands'
    )
    _describe -t commands 'hrp command' commands
}

_hrp "$@"
