#compdef wbmptopbm
# Documentation: man wbmptopbm (Netpbm)
# Source: convert a WAP wireless bitmap to a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:wbmp file:_files -g "*.wbmp"' \
    && ret=0

return ret
