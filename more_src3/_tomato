autoload -U is-at-least

_tomato() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_tomato_commands" \
"*::: :->🍅 tomato" \
&& ret=0
    case $state in
    (🍅 tomato)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tomato-command-$line[1]:"
        case $line[1] in
            (get)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The key to look for. Use dots as path separators:_default' \
'::file -- The toml file to read from. Omit to read from stdin:_default' \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The key to set a value for. Use dots as path separators:_default' \
':value -- The new value:_default' \
'::file -- The toml file to read from. Omit to read from stdin. If you read from stdin, the normal output of the old value is suppressed. Instead the modified file is written to stdout in json if you requested json, toml otherwise:_default' \
&& ret=0
;;
(rm)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The key to remove from the file. Use dots as path separators:_default' \
'::file -- The toml file to read from. Omit to read from stdin. If you read from stdin, the normal output of the old value is suppressed. Instead the modified file is written to stdout in json if you requested json, toml otherwise:_default' \
&& ret=0
;;
(append)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The full key path of the array you want to append to:_default' \
':value -- The value to append to the array:_default' \
'::file -- The toml file to modify. Omit to read from stdin:_default' \
&& ret=0
;;
(exists)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The key to check the existence of:_default' \
'::file -- The toml file to read from. Omit to read from stdin:_default' \
&& ret=0
;;
(keys)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':key -- The key to list subkeys for:_default' \
'::file -- The toml file to read from. Omit to read from stdin:_default' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-f+[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'--format=[How to format the output\: json, toml, bash, or raw]:FORMAT:_default' \
'-b[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'--backup[Back up the file to <filepath>.bak if we write a new version. This option is ignored when we'\''re operating on stdin]' \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_tomato__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:tomato-help-command-$line[1]:"
        case $line[1] in
            (get)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(set)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(rm)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(append)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(exists)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(keys)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_tomato_commands] )) ||
_tomato_commands() {
    local commands; commands=(
'get:Get the value of a key from the given file' \
'set:Set a key to the given value, returning the previous value if one existed' \
'rm:Delete a key from the given file, returning the previous value if one existed' \
'append:Append the given value to an array, returning the previous array if one existed' \
'exists:Exit with status code zero if the key exists in the input file, non-zero if not' \
'keys:List all keys at a given path, if the value type has sub-keys' \
'completions:Generate completions for the named shell' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'tomato commands' commands "$@"
}
