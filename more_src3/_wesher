#compdef wesher
# Documentation: https://github.com/costela/wesher
# Source: costela/wesher — wireguard-overlay mesh manager.
# Reference accessed: 2026-06-01
# All flags support WESHER_* environment variables.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--cluster-key=[shared cluster encryption key (32 bytes, base64)]:key:_default' \
    '--join=[comma-separated existing cluster members]:hosts:_default' \
    '--init[reinitialize the cluster, forgetting previous state]' \
    '--bind-addr=[IP to bind cluster communication to]:addr:_default' \
    '--bind-iface=[network interface for cluster communication]:iface:_default' \
    '--cluster-port=[gossip port (default 7946 tcp/udp)]:port:_default' \
    '--wireguard-port=[wireguard port (default 51820 udp)]:port:_default' \
    '--overlay-net=[mesh overlay CIDR (default 10.0.0.0/8)]:cidr:_default' \
    '--interface=[wireguard interface name (default wgoverlay)]:dev:_default' \
    '--no-etc-hosts[skip automatic /etc/hosts entries]' \
    '--log-level=[verbosity]:level:(debug info warn error)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
