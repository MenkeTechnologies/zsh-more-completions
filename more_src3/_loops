#compdef loops
# Documentation: https://loops.so/docs/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Loops.so CLI (loops-so/cli)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:Log in, switch teams, manage stored API keys'
  'contacts:Create, update, find, and delete contacts'
  'events:Send events to trigger automations'
  'lists:View your mailing lists'
  'transactional:Send and manage transactional emails'
  'contact-properties:Create and list contact properties'
  'api-key:Validate your current API key'
  'version:Display CLI version'
  'agent-context:Output JSON schema of all commands and flags'
  'completion:Set up shell autocompletion'
)

_arguments -s -S \
  '(-o --output)'{-o,--output}'=[output format]:format:(text json)' \
  '(-t --team)'{-t,--team}'=[team key name to use]:team:' \
  '--debug[print API request details before sending]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'loops command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (auth)
        _arguments -s -S '1:subcommand:(login use list)' && ret=0
        ;;
      (contacts)
        _arguments -s -S '1:subcommand:(create update find delete)' && ret=0
        ;;
      (events)
        _arguments -s -S '1:event-name:' && ret=0
        ;;
      (lists)
        _arguments -s -S '1:subcommand:(list)' && ret=0
        ;;
      (transactional)
        _arguments -s -S '1:subcommand:(send list)' && ret=0
        ;;
      (contact-properties)
        _arguments -s -S '1:subcommand:(create list)' && ret=0
        ;;
      (completion)
        _arguments -s -S '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
