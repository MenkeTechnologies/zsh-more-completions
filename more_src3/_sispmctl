#compdef sispmctl
# Documentation: https://manpages.debian.org/bookworm/sispmctl/sispmctl.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm sispmctl(1) man page.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[print usage information]' \
  '-v[print version and copyright]' \
  '-s[scan for supported Gembird devices]' \
  '-o[switch outlet(s) ON]' \
  '-f[switch outlet(s) OFF]' \
  '-t[toggle outlet state]' \
  '-g[get outlet status]' \
  '-m[get power supply status]' \
  '-b+[control buzzer]:state:(on off)' \
  '-d+[select device by sequence number]:n:' \
  '-D+[select device by serial number]:serial:' \
  '-n[print 1/0 instead of ON/OFF]' \
  '-q[suppress explanatory text]' \
  '-a[retrieve schedule for outlet]' \
  '-A[set schedule for outlet]' \
  '--Aat=[event time YYYY-MM-DD HH:MM]:time:' \
  '--Aafter=[N minutes after previous event]:n:' \
  '--Ado=[event action]:action:(on off)' \
  '--Aloop=[loop back to first event after N minutes]:n:' \
  '-l[daemonize and start HTTP webserver]' \
  '-p+[network port for HTTP listener]:port:' \
  '-u+[directory of served web pages]:dir:_directories' \
  '-i+[bind IP address]:ip:' \
  '*::arguments:_default' && ret=0

return ret
