#compdef kafka-get-offsets
# Documentation: https://kafka.apache.org/documentation/ (kafka-get-offsets.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[REQUIRED. The server(s) to connect to in the form HOST1:PORT1,HOST2:PORT2]:host\:port:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--exclude-internal-topics[Exclude internal topics (included by default)]'
    '--help[Print usage information]'
    '--partitions[Comma separated list of partition ids]:partition ids:'
    '--time[Timestamp / -1 latest / -2 earliest / -3 max-timestamp / -4 earliest-local / -5 latest-tiered / -6 earliest-pending-upload]:time:'
    '--topic[The topic to get the offsets for (accepts a regular expression)]:topic:'
    '--topic-partitions[Comma separated list of topic-partition patterns]:topic-partitions:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
