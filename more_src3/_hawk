#compdef hawk
# Documentation: https://github.com/GrayCodeAI/hawk
# Reference accessed: 2026-05-22
# Verified: cmd/root.go and subcommand registrations (Cobra).

# Zsh completion for hawk - AI coding agent CLI (eyrie-powered)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-m --model)'{-m,--model}'[model from eyrie catalog]:model:' \
  '(-p --print)'{-p,--print}'[print response and exit]' \
  '--prompt[single prompt and exit]:prompt:' \
  '--output-format[print output format]:format:(text json stream-json)' \
  '--input-format[print input format]:format:(text stream-json)' \
  '--provider[LLM provider]:provider:' \
  '(-r --resume)'{-r,--resume}'[resume session by ID]:id:' \
  '(-c --continue)'{-c,--continue}'[continue most recent conversation]' \
  '--session-id[specific session ID]:id:' \
  '--permission-mode[permission mode]:mode:(default acceptEdits bypassPermissions dontAsk plan)' \
  '--dangerously-skip-permissions[bypass permission checks]' \
  '--max-turns[maximum agentic turns]:turns:' \
  '--max-budget-usd[maximum API spend in USD]:usd:' \
  '--sandbox[Bash permission profile]:profile:(strict workspace off)' \
  '--auto-commit[auto-commit Write/Edit changes]' \
  '--watch[watch working directory for changes]' \
  '--vibe[vibe mode: auto-apply without confirmations]' \
  '--power[power level 1-10]:level:' \
  '--council[consult multiple models]' \
  '--teach[explain reasoning while working]' \
  '--auto-skill[auto-detect and install skills]' \
  '--recover[scan and resume interrupted sessions]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'hawk command' \
      'version[print version]' \
      'setup[run first-time setup]' \
      'doctor[run diagnostics]' \
      'preflight[check ready to chat]' \
      'credentials[manage credentials]' \
      'config[show or update settings]' \
      'mcp[show MCP configuration]' \
      'sessions[list saved sessions]' \
      'tools[list built-in tools]' \
      'plugin[manage plugins]' \
      'completion[generate shell completion]' \
      'research[autonomous research loop]' \
      'context[export project context document]' \
      'inspect[site audit]' \
      'sight[diff-based code review]' \
      'recover[scan or resume interrupted sessions]' \
      'agent[agent subcommands]' \
      'mission[mission control]' \
      'search[search]' \
      'snapshot[snapshot]' \
      'eval[evaluation]' \
      'daemon[daemon control]' \
      'exec[execute]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        _arguments '1:action:(get set provider model keys routing-preview migrate-deployments)' \
          '*:args:' && ret=0
        ;;
      plugin)
        _arguments '1:action:(list install uninstall)' '2:plugin:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      research)
        _arguments \
          '--grep[grep pattern for metric]:pattern:' \
          '--direction[optimization direction]:dir:(lower higher)' \
          '--budget[time budget per experiment in minutes]:min:' \
          '--branch[git branch prefix]:prefix:' \
          '--results[results TSV path]:file:_files' \
          '*:metric command:' && ret=0
        ;;
      context)
        _arguments \
          '--focus[focus area]:area:' \
          '(-o --output)'{-o,--output}'[write to file]:file:_files' && ret=0
        ;;
      recover)
        _arguments '1:session-id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
