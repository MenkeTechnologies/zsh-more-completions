#compdef stoplight stoplight-cli stoplight-prism
# _stoplight — Stoplight stoplight-cli OpenAPI tooling suite incorporating Prism mock server Spectral linter Elements rendering and Studio editor automation (stoplightio team, TypeScript); yargs
# upstream: https://github.com/stoplightio/prism

_stoplight() {
    local -a sub=(
        'mock:run mock server'
        'proxy:run proxy server'
        'serve:serve documentation'
        'validate:validate OpenAPI spec'
        'lint:lint OpenAPI spec with Spectral'
        'bundle:bundle OpenAPI references'
        'generate:generate elements docs'
        'mock-from-openapi:mock from OpenAPI'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stoplight subcommand' sub ;;
        args)
            case $words[1] in
                mock|proxy) _arguments \
                    '-p+[port]:n:' \
                    '--port=+[port]:n:' \
                    '-h+[host]:str:' \
                    '--host=+[host]:str:' \
                    '-d+[dynamic mode]' \
                    '--dynamic[dynamic mode]' \
                    '-m+[multiprocess]' \
                    '--multiprocess[multiprocess]' \
                    '-e+[errors]:b:(true false)' \
                    '--errors=+[errors]:b:(true false)' \
                    '--cors=+[b]:b:(true false)' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                lint) _arguments \
                    '-r+[ruleset]:file:_files -g "*.yaml *.yml *.js"' \
                    '--ruleset=+[ruleset]:file:_files -g "*.yaml *.yml *.js"' \
                    '-f+[format]:f:(stylish json junit html text teamcity pretty github-actions sarif gitlab)' \
                    '--format=+[format]:f:(stylish json junit html text teamcity pretty github-actions sarif gitlab)' \
                    '-D+[fail-severity]:s:(error warn info hint)' \
                    '--fail-severity=+[fail-severity]:s:(error warn info hint)' \
                    '--display-only-failures[only failures]' \
                    '--encoding=+[enc]:e:(utf8 utf16le ascii utf-8)' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                bundle) _arguments \
                    '-o+[output]:file:_files' \
                    '--output=+[output]:file:_files' \
                    '*:openapi:_files -g "*.yaml *.yml *.json"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_stoplight "$@"
