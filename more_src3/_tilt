#compdef tilt
# _tilt — Tilt multi-service dev orchestrator (watches files, rebuilds container images, live-updates k8s/docker-compose deployments via a Tiltfile in starlark)
# upstream: https://github.com/tilt-dev/tilt
# Subcommands from internal/cli/cli.go on tip; per-subcommand flags can be discovered via `tilt <cmd> --help`.

_tilt() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'up:start tilt and begin watching/building/deploying resources from a Tiltfile'
                'ci:run tilt once for CI (exits after all resources reach Ready)'
                'down:stop everything tilt is managing'
                'demo:start a Tilt demo project'
                'docker:run docker commands using the Tilt build socket'
                'docker-prune:prune Tilt-managed docker images'
                'doctor:print system info for filing bug reports'
                'verify-install:verify tilt is correctly installed'
                'version:show version'
                'logs:stream resource logs'
                'args:get or set Tiltfile args'
                'trigger:trigger a manual resource update'
                'enable:enable a resource'
                'disable:disable a resource'
                'apply:apply a tilt API object from YAML'
                'create:create a tilt API object'
                'delete:delete a tilt API object'
                'describe:describe tilt API objects'
                'edit:edit a tilt API object'
                'get:list tilt API objects'
                'patch:patch a tilt API object'
                'wait:wait for tilt API objects to reach a condition'
                'explain:explain a tilt API object kind'
                'api-resources:list tilt API resources'
                'analytics:opt in/out of anonymous usage analytics'
                'dump:dump tilt internal state (debug)'
                'alpha:experimental commands'
                'lsp:start the tilt language server'
                'snapshot:create or view a snapshot of the current session'
                'help:show help for any subcommand'
            )
            _describe -t commands 'tilt command' subs
            ;;
        args)
            case $line[1] in
                up|ci)
                    _arguments \
                        '--file=[Tiltfile path]:file:_files' \
                        '--namespace=[kube namespace]:ns:' \
                        '--port=[API server port]:port:' \
                        '--host=[API server bind host]:host:' \
                        '--legacy[run in legacy terminal UI mode]' \
                        '--stream[stream resource logs to stdout]' \
                        '--no-browser[do not open the UI in a browser]' \
                        '--klog=[klog verbosity level]:n:' \
                        '*:resource:'
                    ;;
                down)
                    _arguments \
                        '--file=[Tiltfile path]:file:_files' \
                        '--delete-namespaces[delete Tiltfile-created namespaces]'
                    ;;
                logs)
                    _arguments \
                        '(-f --follow)'{-f,--follow}'[follow log output]' \
                        '*:resource:'
                    ;;
            esac
            ;;
    esac
}

_tilt "$@"
