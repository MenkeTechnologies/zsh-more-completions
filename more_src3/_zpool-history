#compdef zpool-history
# _zpool-history — OpenZFS zpool history (replay the ZFS administrative log: every modifying command (create/destroy/snapshot/set/...) is recorded with timestamp + user; -i shows internal events, -l adds long history including dataset id, -j JSON; positional pool optional)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_history) on tip.

_zpool-history() {
    _arguments \
        '-i[include internal events]' \
        '-l[long form (with internal info)]' \
        '-j[JSON output]' \
        '*:pool:'
}

_zpool-history "$@"
