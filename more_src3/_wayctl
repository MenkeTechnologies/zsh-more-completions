#compdef wayctl
# _wayctl — script-friendly CLI for Wayland compositors (Nightshade-DE/wayctl)
# upstream: https://github.com/Nightshade-DE/wayctl
# Flags from wayctl.py / wayctl_core/commands/ (argparse).

_wayctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --pretty)'{-p,--pretty}'[pretty-print JSON output]' \
        '(-c --conf)'{-c+,--conf=}'[TOML action mapping file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging level]:level:(TRACE DEBUG INFO WARNING ERROR CRITICAL)' \
        '(-l --log)'{-l,--log}'[write logs to file]::path:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'get:query toplevels / workspaces / outputs'
                'set:apply a state change (focus, fullscreen, ...)'
                'send:send an action via fallback (key, trigger)'
                'config:lint / inspect configuration'
                'render:render labwc block from TOML'
                'daemon:run / control wayctl daemon'
                'monitor:subscribe to daemon event stream'
                'version:show version info'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                get) _arguments '1:resource:(toplevels workspaces outputs)' ;;
                set|send) _arguments '1:action:(focus close fullscreen maximized minimized normalize rectangle assign_workspace create_workspace remove_workspace rename_workspace switch_workspace send_key trigger_action)' ;;
                config) _arguments '1:subcommand:(lint)' '--strict[treat warnings as errors]' ;;
                render) _arguments '1:target:(labwc)' ;;
                daemon) _arguments '1:subcommand:(start stop status)' ;;
            esac
            ;;
    esac
}

_wayctl "$@"
