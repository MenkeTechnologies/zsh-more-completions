#compdef size-limit
# Documentation: https://github.com/ai/size-limit
# Reference accessed: 2026-05-21
# Verified: upstream size-limit README (ai/size-limit).
# Removed from prior file: --clean-dir, --hide-passed, --highlight-less,
# --compare-with — these are not documented as CLI flags in upstream
# README (only as config keys). Added documented --limit and --config.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--json[output as JSON]' \
  '--why[analyze bundle contents (Statoscope HTML report)]' \
  '--save-bundle=[save analysis report to directory]:directory:_directories' \
  '--config=[path to configuration file]:file:_files' \
  '--limit=[size/time limit (e.g. "10 kB")]:limit:' \
  '--debug[enable debug output]' && ret=0

return ret
