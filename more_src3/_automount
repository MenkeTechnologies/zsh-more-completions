#compdef automount
# Documentation: https://www.unix.com/man-page/osx/8/automount/
# Source: Apple macOS — automount(8) (drives automountd from /etc/auto_master).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose information about actions]' \
    '-c[flush cached information in automountd(8)]' \
    '-u[unmount all non-busy automounts (keep top-level triggers)]' \
    '-t[unreferenced-timeout in seconds]:seconds:' \
    && ret=0

return ret
