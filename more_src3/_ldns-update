#compdef ldns-update
# Documentation: https://manpages.debian.org/bookworm/ldnsutils/ldns-update.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# ldns-update: NLnetLabs ldns Dynamic DNS Update utility (positional)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:name:' \
  '2:zone:' \
  '3:ip (or "none" to delete):' \
  '4:tsig_name:' \
  '5:tsig_alg:' \
  '6:tsig_hmac:' && ret=0
return ret
