#compdef kak
# _kak — Maxime Coste mawww Kakoune modal code editor inspired by vim (mawww team, C++); custom argparse
# upstream: https://github.com/mawww/kakoune

_kak() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-e+[execute commands on startup]:cmd:' \
        '-E+[execute commands after init]:cmd:' \
        '-n[skip kakrc]' \
        '-s+[session name]:session:' \
        '-d[daemon mode]' \
        '-p+[session name pipe]:session:' \
        '-f+[filter command]:cmd:' \
        '-i+[backup extension]:str:' \
        '-ui=+[ui type]:u:(ncurses dummy json)' \
        '-l[list sessions]' \
        '-c+[connect to session]:session:' \
        '-ro[read-only]' \
        '-clear[clear sockets]' \
        '-debug=+[debug categories]:c:(events keys commands shell profile parsing wait files faces commit)' \
        '+[line number]:line:' \
        '*:file:_files'
}

_kak "$@"
