#compdef worms
# Documentation: man worms(6)
# Source: openbsd/src games/worms/worms.c — animate worms (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-d+[delay in ms (0-1000)]:ms:_default' \
    '-f[print "WORM" as background field]' \
    '-l+[worm length (2-1024)]:N:_default' \
    '-n+[number of worms (1-100)]:N:_default' \
    '-t[leave trail of dots]' \
    && ret=0

return ret
