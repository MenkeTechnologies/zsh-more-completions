#compdef lightningd
# _lightningd — Blockstream Core Lightning lightningd daemon for the Lightning Network Bitcoin layer-2 (ElementsProject team, C); custom argparse
# upstream: https://github.com/ElementsProject/lightning

_lightningd() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--conf=+[config file]:file:_files' \
        '--lightning-dir=+[lightning dir]:dir:_files -/' \
        '--network=+[network]:n:(bitcoin testnet regtest signet liquid liquid-regtest)' \
        '--mainnet[bitcoin mainnet]' \
        '--testnet[testnet mode]' \
        '--regtest[regtest mode]' \
        '--signet[signet mode]' \
        '--bitcoin-rpcuser=+[bitcoind rpc user]:user:_users' \
        '--bitcoin-rpcpassword=+[bitcoind rpc password]:str:' \
        '--bitcoin-rpcconnect=+[bitcoind host]:host:_hosts' \
        '--bitcoin-rpcport=+[bitcoind port]:port:_ports' \
        '--bitcoin-cli=+[bitcoin-cli path]:file:_command_names' \
        '--bitcoin-datadir=+[bitcoind data dir]:dir:_files -/' \
        '--rpc-file=+[rpc socket]:file:_files' \
        '--pid-file=+[pid file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--log-level=+[level]:l:(io trace debug info unusual broken)' \
        '--log-prefix=+[prefix]:str:' \
        '--log-timestamps=+[bool]:b:(true false)' \
        '--alias=+[node alias]:str:' \
        '--rgb=+[color]:color:' \
        '--bind-addr=+[bind address]:addr:' \
        '--addr=+[external address]:addr:' \
        '--announce-addr=+[announce address]:addr:' \
        '--offline[offline mode]' \
        '--autolisten=+[bool]:b:(true false)' \
        '--proxy=+[socks proxy]:str:' \
        '--always-use-proxy=+[bool]:b:(true false)' \
        '--tor-service-password=+[password]:str:' \
        '--encrypted-hsm[encrypt hsm]' \
        '--commit-fee=+[percent]:n:' \
        '--cltv-delta=+[blocks]:n:' \
        '--cltv-final=+[blocks]:n:' \
        '--fee-base=+[msat]:n:' \
        '--fee-per-satoshi=+[ppm]:n:' \
        '--min-capacity-sat=+[sats]:n:' \
        '--htlc-minimum-msat=+[msat]:n:' \
        '--htlc-maximum-msat=+[msat]:n:' \
        '--ignore-fee-limits=+[bool]:b:(true false)' \
        '--fee-target=+[blocks]:n:' \
        '--funding-confirms=+[blocks]:n:' \
        '--accept-htlc-tlv-types=+[csv types]:str:' \
        '--max-concurrent-htlcs=+[N]:n:' \
        '--experimental-dual-fund[dual funding]' \
        '--experimental-onion-messages[onion messages]' \
        '--experimental-offers[BOLT12 offers]' \
        '--developer[developer mode]' \
        '--plugin=+[plugin path]:file:_files' \
        '--plugin-dir=+[plugin dir]:dir:_files -/' \
        '--disable-plugin=+[plugin name]:str:' \
        '--daemon[daemonize]'
}

_lightningd "$@"
