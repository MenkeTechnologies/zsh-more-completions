#compdef tesseract
# Documentation: tesseract --help-extra (Tesseract OCR)
# Source: tesseract-ocr/tesseract — open-source OCR engine.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a psm_modes oem_modes
psm_modes=(
    '0:osd_only — Orientation+script detection only'
    '1:auto_osd — Automatic page seg with OSD'
    '2:auto_only — Automatic page seg, no OSD/OCR'
    '3:auto — Fully automatic (default)'
    '4:single_column — single column variable size'
    '5:single_block_vert_text — vertical text block'
    '6:single_block — single uniform block'
    '7:single_line — single text line'
    '8:single_word — single word'
    '9:circle_word — single word in a circle'
    '10:single_char — single character'
    '11:sparse_text — sparse text'
    '12:sparse_text_osd — sparse text with OSD'
    '13:raw_line — raw single text line'
)
oem_modes=(
    '0:tesseract_only — legacy engine'
    '1:lstm_only — neural-net LSTM engine'
    '2:tesseract_lstm_combined — legacy + LSTM'
    '3:default — based on availability'
)

_arguments -s -C \
    '--tessdata-dir=[location of tessdata path]:path:_files -/' \
    '--user-words=[user words file]:path:_files' \
    '--user-patterns=[user patterns file]:path:_files' \
    '--dpi=[input image DPI]:value:' \
    '--loglevel=[logging level]:level:(ALL TRACE DEBUG INFO WARN ERROR FATAL OFF)' \
    '-l+[language(s) for OCR (eg eng+spa)]:langs:' \
    '*-c+[config var=value]:var=value:' \
    '--psm=[page segmentation mode]:psm:->psm' \
    '--oem=[OCR engine mode]:oem:->oem' \
    '(- *)'{-h,--help}'[show minimal help]' \
    '(- *)--help-extra[show extra help]' \
    '(- *)--help-psm[show page segmentation modes]' \
    '(- *)--help-oem[show OCR engine modes]' \
    '(- *)'{-v,--version}'[show version info]' \
    '(- *)--list-langs[list available languages]' \
    '(- *)--print-fonts-table[print fonts table]' \
    '(- *)--print-parameters[print parameters]' \
    '1:image or imagelist or "stdin":_files' \
    '2:outputbase or "stdout":_files' \
    '*:config file:_files' \
    && ret=0

case $state in
    psm) _describe -t psm-modes 'page segmentation mode' psm_modes && ret=0 ;;
    oem) _describe -t oem-modes 'OCR engine mode' oem_modes && ret=0 ;;
esac

return ret
