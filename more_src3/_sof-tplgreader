#compdef sof-tplgreader
# Documentation: SOF tplgreader
# Source: thesofproject/sof-test tools/sof-tplgreader.py (main) — SOF topology file reader (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --sofcard)'{-s+,--sofcard=}'[SOF card id]:card:_default' \
    '(-f --filter)'{-f+,--filter=}'[filter expression key:value]:filter:_default' \
    '(-b --block)'{-b+,--block=}'[block filter expression]:filter:_default' \
    '(-d --dump)'{-d+,--dump=}'[dump target field(s)]:fields:_default' \
    '(-e --export -c --count -i --index -v --value)'{-e,--export}'[export pipeline to bash assoc array]' \
    '(-e --export -c --count -i --index -v --value)'{-c,--count}'[print pipeline count]' \
    '(-e --export -c --count -i --index -v --value)'{-i+,--index=}'[get pipeline at index]:N:_default' \
    '(-e --export -c --count -i --index -v --value)'{-v,--value}'[print only the value]' \
    '(-t --tplgroot)'{-t+,--tplgroot=}'[tplg-root folder]:dir:_files -/' \
    '(-o --sort)'{-o,--sort}'[sort pipelines by id within tplg]' \
    '--version[show version]' \
    '1:tplg file(s):_files -g "*.tplg"' \
    && ret=0

return ret
