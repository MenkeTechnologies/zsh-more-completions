#compdef yggdrasil
# Documentation: https://github.com/yggdrasil-network/yggdrasil-go (cmd/yggdrasil/main.go)
# Reference accessed: 2026-05-29
# Yggdrasil end-to-end encrypted IPv6 mesh network.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-version[print version and exit]' \
  '-genconf[print a new config to stdout]' \
  '-useconf[read HJSON/JSON config from stdin]' \
  '-useconffile=[read HJSON/JSON config from file]:file:_files' \
  '-normaliseconf[output normalised configuration]' \
  '-exportkey[output private key in PEM format]' \
  '-json[output configuration as JSON instead of HJSON]' \
  '-autoconf[automatic mode (dynamic IP, peer with IPv6 neighbors)]' \
  '-logto=[log destination: file path, syslog, or stdout]:dest:(syslog stdout)' \
  '-address[output IPv6 address from config]' \
  '-subnet[output IPv6 subnet from config]' \
  '-publickey[output public key from config]' \
  '-loglevel=[log level to enable]:level:(error warn info debug trace)' \
  '-user=[user (and optionally group) to set UID/GID to]:user:_users' && ret=0

return ret
