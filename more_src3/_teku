#compdef teku
# Documentation: https://docs.teku.consensys.io/reference/cli
# Reference accessed: 2026-05-21
# Verified: upstream Consensys Teku CLI reference.
# Removed from prior file: fabricated 'beacon' and 'deposit' subcommands
# (teku does not expose those; the beacon node is the default invocation).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--data-base-path=[path to the Teku data directory]:directory:_directories' \
  '--data-path=[deprecated alias for --data-base-path]:directory:_directories' \
  '--network=[predefined network configuration]:network:(mainnet sepolia holesky hoodi ephemery gnosis chiado lukso minimal)' \
  '--initial-state=[SSZ-encoded state file for checkpoint sync]:file:_files' \
  '--ee-endpoint=[Engine JSON-RPC API endpoint]:url:' \
  '--ee-jwt-secret-file=[shared secret for execution client auth]:file:_files' \
  '--validator-keys=[encrypted keystore:password dir]:keys:' \
  '--validators-proposer-default-fee-recipient=[default fee recipient]:address:' \
  '--rest-api-enabled[enable REST API service]' \
  '--rest-api-port=[REST API listening port]:port:' \
  '--logging=[logging verbosity]:level:(OFF FATAL ERROR WARN INFO DEBUG TRACE ALL)' \
  '--metrics-enabled[enable Prometheus metrics exporter]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'admin:administrative operations'
      'migrate-database:database migration utilities'
      'bootnode:run a bootstrap node'
      'slashing-protection:manage slashing protection DB'
      'validator-client:run a standalone validator client (alias: vc)'
      'vc:run a standalone validator client'
      'voluntary-exit:perform a voluntary exit'
      'help:print command help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
