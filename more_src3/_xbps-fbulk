#compdef xbps-fbulk
# Documentation: https://man.voidlinux.org/xbps-fbulk.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-j --jobs)'{-j,--jobs}'+[number of parallel builds]:n:' \
  '(-l --logdir)'{-l,--logdir}'+[log directory]:dir:_directories' \
  '(-s --system)'{-s,--system}'[only process manually-installed packages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '1:void-packages path:_directories' \
  '*:package: ' && ret=0

return ret
