#compdef wasm-pack
# Documentation: https://rustwasm.github.io/docs/wasm-pack/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_wasm_pack_commands() {
  local -a commands=(
    'build:Build the project as a wasm package'
    'test:Run tests with wasm-pack'
    'pack:Create a tarball from the pkg directory'
    'publish:Publish a package to the npm registry'
    'new:Create a new wasm-pack project from a template'
    'login:Login to a registry'
    'help:Print help'
    'completions:Generate completions for a shell'
  )
  _describe -t commands 'wasm-pack command' commands
}

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[increase logging verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[no output printed to stdout]' \
  '--log-level=[set log level (info, warn, error)]:level:(info warn error)' \
  '--color=[colorize output]:when:(auto always never)' \
  '1:command:_wasm_pack_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      build)
        _arguments -s -S \
          '(-t --target)'{-t,--target}'=[target environment]:target:(bundler nodejs web no-modules deno)' \
          '(-d --out-dir)'{-d,--out-dir}'=[output directory]:directory:_directories' \
          '--out-name=[output file name prefix]:name' \
          '--scope=[npm scope]:scope' \
          '-m+[build mode]:mode:(no-install normal force)' \
          '--mode=[build mode]:mode:(no-install normal force)' \
          '--dev[create a development build]' \
          '--release[create a release build (default)]' \
          '--profiling[create a profiling build (optimized with debug info)]' \
          '--debug[deprecated; use --dev instead]' \
          '--profile=[cargo profile]:profile' \
          '--no-typescript[do not emit TypeScript bindings]' \
          '--no-pack[do not generate package.json]' \
          '--no-opt[do not run wasm-opt on output]' \
          '--reference-types[enable reference types when generating bindings]' \
          '--weak-refs[enable weak references when generating bindings]' \
          '--panic-unwind[enable panic=unwind]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:path:_directories' && ret=0
        ;;
      test)
        _arguments -s -S \
          '--node[run tests in Node.js]' \
          '--firefox[run tests in Firefox]' \
          '--chrome[run tests in Chrome]' \
          '--safari[run tests in Safari]' \
          '--headless[run browser tests in headless mode]' \
          '--release[build with release profile]' \
          '--mode=[build mode]:mode:(no-install normal)' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:path:_directories' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--template=[git template URL]:template' \
          '(-m --mode)'{-m,--mode}'=[mode]:mode:(no-install normal)' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:name' && ret=0
        ;;
      publish)
        _arguments -s -S \
          '(-a --access)'{-a,--access}'=[npm access level]:access:(public restricted)' \
          '--tag=[npm dist-tag]:tag' \
          '(-t --target)'{-t,--target}'=[target environment]:target:(bundler nodejs web no-modules deno)' \
          '(-d --pkg-dir)'{-d,--pkg-dir}'=[package directory]:dir:_directories' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:path:_directories' && ret=0
        ;;
      pack)
        _arguments -s -S \
          '(-d --pkg-dir)'{-d,--pkg-dir}'=[package directory]:dir:_directories' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:path:_directories' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-r --registry)'{-r,--registry}'=[registry URL]:url' \
          '(-s --scope)'{-s,--scope}'=[npm scope]:scope' \
          '(-t --auth-type)'{-t,--auth-type}'=[authentication type]:type:(legacy sso saml oauth)' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      completions)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
