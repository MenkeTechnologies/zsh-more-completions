#compdef subscription-manager
# _subscription-manager — Red Hat subscription-manager Red Hat subscription mgmt CLI alias (candlepin team, Python); argparse
# upstream: https://github.com/candlepin/subscription-manager

_subscription-manager() {
    local -a sub=(
        'attach:attach a subscription'
        'auto-attach:auto-attach commands'
        'clean:clean local data'
        'config:configuration'
        'environments:list environments'
        'facts:show or update facts'
        'identity:show or regen identity'
        'import:import entitlement certificate'
        'list:list subscriptions/products'
        'orgs:list orgs'
        'plugins:show plugins'
        'redeem:redeem subscription'
        'refresh:refresh entitlements'
        'register:register the system'
        'release:set or show release version'
        'remove:remove a subscription'
        'repo-override:repo override'
        'repos:show or enable/disable repos'
        'role:set or show role'
        'service-level:show or set service level'
        'status:show current status'
        'syspurpose:syspurpose commands'
        'unregister:unregister'
        'usage:show or set usage type'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'subscription-manager subcommand' sub ;;
        args)
            case $words[1] in
                register) _arguments \
                    '--username=+[user]:_users' \
                    '--password=+[password]:str:' \
                    '--type=+[type]:str:' \
                    '--name=+[name]:str:' \
                    '--consumerid=+[id]:str:' \
                    '--org=+[org]:str:' \
                    '--environments=+[envs csv]:str:' \
                    '--auto-attach[auto attach]' \
                    '--force[force]' \
                    '--release=+[release]:str:' \
                    '--servicelevel=+[level]:str:' \
                    '--activationkey=+[key]:str:' \
                    '--baseurl=+[url]:url:_urls' \
                    '--serverurl=+[url]:url:_urls' \
                    '--insecure[insecure]' ;;
                attach) _arguments \
                    '--pool=+[pool id]:str:' \
                    '--quantity=+[n]:n:' \
                    '--auto[auto]' \
                    '--servicelevel=+[level]:str:' \
                    '--file=+[file]:file:_files' ;;
                remove) _arguments \
                    '--serial=+[serial]:str:' \
                    '--pool=+[pool]:str:' \
                    '--all[all]' \
                    '--proxy=+[proxy]:str:' ;;
                repos) _arguments \
                    '--list[list repos]' \
                    '--list-enabled[list enabled]' \
                    '--list-disabled[list disabled]' \
                    '--enable=+[repo]:str:' \
                    '--disable=+[repo]:str:' ;;
                list) _arguments \
                    '--installed[installed products]' \
                    '--consumed[consumed subscriptions]' \
                    '--available[available subs]' \
                    '--all[all subs]' \
                    '--ondate=+[date]:str:' \
                    '--service-level=+[level]:str:' \
                    '--match-installed[match installed]' \
                    '--no-overlap[no overlap]' \
                    '--matches=+[pattern]:str:' \
                    '--pool-only[pool only]' \
                    '--afterdate=+[date]:str:' \
                    '--matches=+[pattern]:str:' \
                    '--utility[utility view]' \
                    '--no-progress-messages[no progress messages]' ;;
                status) _arguments '--ondate=+[date]:str:' ;;
                config) _arguments \
                    '--list[list config]' \
                    '--remove=+[option]:str:' \
                    '--remove=+[option]:str:' ;;
            esac
            ;;
    esac
}

_subscription-manager "$@"
