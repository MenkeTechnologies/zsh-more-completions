#compdef jest
# Documentation: https://jestjs.io/docs/cli
# Source: facebook/jest CLI options.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--watch[watch files; rerun tests for changed files]' \
    '--watchAll[watch files; rerun all tests on change]' \
    '(-t --testNamePattern)'{-t+,--testNamePattern=}'[run tests whose name matches regex]:regex:' \
    '(-u --updateSnapshot)'{-u,--updateSnapshot}'[re-record every failing snapshot]' \
    '--coverage[collect and report coverage]' \
    '(-o --onlyChanged)'{-o,--onlyChanged}'[run tests for files changed in repo]' \
    '(-i --runInBand)'{-i,--runInBand}'[run all tests serially (no worker pool)]' \
    '--bail=-[exit after N failing test suites (default 1)]:n:' \
    '--testPathPatterns=[regex matched against test paths]:regex:' \
    '*--testPathIgnorePatterns=[regex matched against test paths to skip]:regex:' \
    '(-c --config)'{-c+,--config=}'[Jest config file path]:file:_files' \
    '--clearCache[delete Jest cache directory and exit]' \
    '--verbose[show individual test results in suite hierarchy]' \
    '--silent[prevent tests from printing console messages]' \
    '--forceExit[force exit after all tests complete]' \
    '--detectOpenHandles[print handles preventing clean exit]' \
    '(-w --maxWorkers)'{-w+,--maxWorkers=}'[max worker-pool size (number or percent)]:n:' \
    '*:test path pattern:_files' \
    && ret=0

return ret
