#compdef strongswan ipsec
# _strongswan — strongSwan CLI (control client over /var/run/charon.ctl Vici socket; subcommands: up/down a connection, status/statusall, listconns, listsas, listcerts, listalgs, listcounters, restart, reload, rereadall, secrets, version, scepclient, pki; -h help, -d level debug, -k VICI socket override)
# upstream: https://github.com/strongswan/strongswan
# Subcommands from strongSwan src/swanctl + src/starter + src/ipsec on tip.

_strongswan() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-d+[debug level]:level:' \
        '-k+[VICI socket]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'ipsec command' '(up down status statusall listconns listsas listcerts listcacerts listacerts listocsp listcrls listpubkeys listalgs listplugins listcounters resetcounters restart reload rereadall rereadsecrets rereadcacerts rereadacerts rereadcrls rereadocsp purgeocsp purgeike purgecerts purgecrls scepclient pki secrets version help leases)' ;;
        args)
            case $line[1] in
                up|down) _arguments '*:connection:' ;;
                pki) _describe -t commands 'pki subcommand' '(--gen --pub --print --self --issue --keyid --acert --signcrl --ocsp --verify --req)' ;;
            esac
            ;;
    esac
}

_strongswan "$@"
