#compdef lid
# Documentation: man lid(1)
# Source: libuser lid (man) — display user's groups or group's users.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-g --group)'{-g,--group}'[list users in group instead of groups of user]' \
    '(-i --interactive)'{-i,--interactive}'[ask all questions when connecting to user db]' \
    '(-n --onlynames)'{-n,--onlynames}'[list only names (omit IDs)]' \
    '1::name:_users' \
    && ret=0

return ret
