#compdef lux
# Documentation: https://github.com/iawia002/lux
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-i[information only]' \
  '-d[debug mode]' \
  '-j[print extracted data in JSON]' \
  '-s[minimum outputs]' \
  '-v[show version]' \
  '-F+[URLs file path]:file:_files' \
  '-f+[select specific stream to download]:stream:' \
  '-p[download playlist]' \
  '-n+[set thread count for download]:threads:' \
  '-c+[cookie file or string]:cookie:_files' \
  '-r+[use specified referrer URL]:referrer:' \
  '-cs+[HTTP chunk size for downloading in MB]:size:' \
  '-retry+[retry count on failed download]:retries:' \
  '-start+[playlist video to start at]:n:' \
  '-end+[playlist video to end at]:n:' \
  '-items+[playlist video items to download (comma-separated)]:items:' \
  '-o+[output directory]:directory:_files -/' \
  '-O+[output filename]:filename:' \
  '-C[download subtitles]' \
  '-embed[embed subtitles into video (YouTube only)]' \
  '-aria2[use Aria2 RPC to download]' \
  '-aria2addr+[Aria2 address]:addr:' \
  '-aria2method+[Aria2 method]:method:' \
  '-aria2token+[Aria2 RPC token]:token:' \
  '-h[show help]' \
  '*:URL:_urls' && ret=0

return ret
