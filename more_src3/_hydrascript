_hydrascript() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-d --dump)'{-d,--dump}'[show interpreter dump data]' \
        ':HydraScript source file:_files -g "*.js"'
}

_hydrascript "$@"
