#compdef video2x
# Documentation: https://github.com/k4yt3x/video2x
# Reference accessed: 2026-05-27
# Verified: upstream tools/video2x/src/argparse.cpp at github.com/k4yt3x/video2x (flat boost::program_options CLI; no upscale/interpolate subcommands)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[display help page]' \
  '(-V --version)'{-V,--version}'[print program version and exit]' \
  '--log-level=[set verbosity level]:level:(trace debug info warn error critical none)' \
  '--no-progress[do not display the progress bar]' \
  '(-l --list-devices)'{-l,--list-devices}'[list available Vulkan devices (GPUs)]' \
  '(-i --input)'{-i+,--input=}'[input video file path]:input:_files' \
  '(-o --output)'{-o+,--output=}'[output video file path]:output:_files' \
  '(-p --processor)'{-p+,--processor=}'[processor to use]:processor:(libplacebo realesrgan realcugan rife)' \
  '(-a --hwaccel)'{-a+,--hwaccel=}'[hardware acceleration method for decoding]:hwaccel:(none cuda vaapi vdpau qsv drm opencl vulkan videotoolbox dxva2 d3d11va)' \
  '(-d --device)'{-d+,--device=}'[Vulkan device index (GPU ID, default 0)]:device:(0 1 2 3)' \
  '(-b --benchmark)'{-b,--benchmark}'[discard processed frames and calculate average FPS]' \
  '(-c --codec)'{-c+,--codec=}'[output codec (default libx264)]:codec:(libx264 libx265 libx264rgb libvpx-vp9 libaom-av1 libsvtav1 h264_nvenc hevc_nvenc h264_videotoolbox hevc_videotoolbox)' \
  '--no-recalculate-pts[do not recalculate presentation timestamps]' \
  '--no-copy-audio-streams[do not copy audio streams]' \
  '--no-copy-subtitle-streams[do not copy subtitle streams]' \
  '--pix-fmt=[output pixel format]:pix-fmt:(yuv420p yuv420p10le yuv422p yuv444p nv12 rgb24 bgr24)' \
  '--bit-rate=[bitrate in bits per second]:bitrate:' \
  '--rc-buffer-size=[rate control buffer size in bits]:size:' \
  '--rc-min-rate=[minimum rate control]:rate:' \
  '--rc-max-rate=[maximum rate control]:rate:' \
  '--qmin=[minimum quantizer]:qmin:' \
  '--qmax=[maximum quantizer]:qmax:' \
  '--gop-size=[group of pictures structure size]:gop:' \
  '--max-b-frames=[maximum number of B-frames]:n:' \
  '--keyint-min=[minimum interval between keyframes]:n:' \
  '--refs=[number of reference frames]:n:' \
  '--thread-count=[number of threads for encoding]:n:' \
  '--delay=[delay in milliseconds for encoder]:ms:' \
  '*'{-e+,--extra-encoder-option=}'[additional AVOption for the encoder (key=value)]:option:' \
  '(-w --width)'{-w+,--width=}'[output width]:width:' \
  '(-h --height)'{-h+,--height=}'[output height]:height:' \
  '(-s --scaling-factor)'{-s+,--scaling-factor=}'[scaling factor]:factor:(2 3 4)' \
  '(-n --noise-level)'{-n+,--noise-level=}'[noise level]:level:(-1 0 1 2 3)' \
  '(-m --frame-rate-mul)'{-m+,--frame-rate-mul=}'[frame rate multiplier]:n:(2 3 4)' \
  '(-t --scene-thresh)'{-t+,--scene-thresh=}'[scene detection threshold (0-100, default 100)]:percent:' \
  '--libplacebo-shader=[GLSL shader name/path for libplacebo]:shader:(anime4k-v4-a anime4k-v4-a+a anime4k-v4-b anime4k-v4-b+b anime4k-v4-c anime4k-v4-c+a anime4k-v4.1-gan)' \
  '--realesrgan-model=[Real-ESRGAN model name]:model:(realesr-animevideov3 realesrgan-plus-anime realesrgan-plus realesr-generalv3)' \
  '--realcugan-model=[Real-CUGAN model name]:model:(models-nose models-pro models-se)' \
  '--realcugan-threads=[threads for Real-CUGAN]:n:' \
  '--realcugan-syncgap=[sync gap mode for Real-CUGAN]:mode:(0 1 2 3)' \
  '--rife-model=[RIFE model name]:model:(rife rife-HD rife-UHD rife-anime rife-v2 rife-v2.3 rife-v2.4 rife-v3.0 rife-v3.1 rife-v4 rife-v4.6 rife-v4.25 rife-v4.25-lite rife-v4.26)' \
  '--rife-uhd[enable RIFE Ultra HD mode]' && ret=0

return ret
