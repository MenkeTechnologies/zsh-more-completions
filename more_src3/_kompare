#compdef kompare
# Documentation: https://invent.kde.org/sdk/kompare/-/blob/master/src/app/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE kompare src/app/main.cpp QCommandLineParser
# options, plus the standard KAboutData --help/--version flags.

# Kompare: KDE diff/patch viewer (frontend for diff)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '-c[compare URL1 with URL2]' \
  '-o[open URL1 as diff output (- reads from stdin)]' \
  '-b[blend URL2 (diff output) into URL1 (file or folder)]' \
  '-n[disable auto-finding original file(s) with -o and - URL]' \
  '-e+[specify the encoding]:encoding:' \
  '*:file:_files' && ret=0
return ret
