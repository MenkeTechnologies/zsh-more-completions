#compdef tiup-cluster
# _tiup-cluster — TiUP TiDB cluster lifecycle manager
# upstream: https://github.com/pingcap/tiup
# Subcommands + persistent flags from components/cluster/command/root.go on tip.

_tiup-cluster() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--ssh-timeout=[SSH connect timeout (s)]:s:' \
        '--wait-timeout=[per-operation wait timeout (s)]:s:' \
        '(-y --yes)'{-y,--yes}'[assume yes for all confirmations]' \
        '--native-ssh[EXPERIMENTAL: use system SSH client]' \
        '--ssh=[executor type]:exec:(builtin system none)' \
        '(-c --concurrency)'{-c,--concurrency=}'[max parallel tasks]:n:' \
        '--format=[output format]:fmt:(default json)' \
        '--ssh-proxy-host=[SSH bastion host]:host:' \
        '--ssh-proxy-user=[SSH bastion user]:user:' \
        '--ssh-proxy-port=[SSH bastion port]:port:' \
        '--ssh-proxy-identity-file=[SSH bastion identity file]:file:_files' \
        '--ssh-proxy-use-password=[SSH bastion login with password]:bool:(true false)' \
        '--ssh-proxy-timeout=[SSH bastion connect timeout (s)]:s:' \
        '--profile-dir=[write CPU/heap profiles here]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'deploy:deploy a new TiDB cluster'
                'start:start a cluster'
                'stop:stop a cluster'
                'restart:restart a cluster'
                'reload:reload cluster config without restart'
                'scale-in:scale out (remove) nodes'
                'scale-out:scale out (add) nodes'
                'upgrade:upgrade a cluster'
                'patch:apply a hotfix patch to nodes'
                'rolling-upgrade:rolling upgrade'
                'destroy:tear down a cluster'
                'clean:clean cluster data/logs'
                'display:show cluster topology + status'
                'list:list all clusters'
                'audit:show command audit log'
                'check:pre-flight checks against hosts'
                'edit-config:edit cluster topology'
                'show-config:print cluster topology'
                'exec:run a shell command on cluster nodes'
                'template:print a topology template'
                'enable:enable systemd unit on nodes'
                'disable:disable systemd unit on nodes'
                'prune:prune offline nodes from topology'
                'replay:replay a previous audit-logged operation'
                'rename:rename a cluster'
                'rotate-ssh:rotate SSH keys on nodes'
                'tls:enable/disable cluster TLS'
                'transfer:transfer files to/from cluster nodes'
                'meta:metadata utilities'
                'test:test/diagnose helpers'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_tiup-cluster "$@"
