#compdef webtorrent
# Documentation: https://github.com/webtorrent/webtorrent-cli
# Reference accessed: 2026-05-21
# Verified: upstream bin/cmd.js command and option definitions.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'download:download a torrent (default)'
  'downloadmeta:download metadata of torrent'
  'seed:seed a file or folder'
  'create:create a .torrent file'
  'info:show torrent information'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--airplay[stream to Apple TV]' \
  '--chromecast[stream to Chromecast]' \
  '--dlna[stream via DLNA]' \
  '--mplayer[stream to MPlayer]' \
  '--mpv[stream to mpv]' \
  '--omx[stream to OMX]' \
  '--vlc[stream to VLC]' \
  '--iina[stream to IINA]' \
  '--smplayer[stream to SMPlayer]' \
  '--xbmc[stream to XBMC]' \
  '--stdout[stream to stdout (implies quiet)]' \
  '(-o --out)'{-o+,--out=}'[download destination]:dir:_files -/' \
  '(-s --select)'{-s+,--select=}'[select specific file index]:index:' \
  '(-i --interactive-select)'{-i,--interactive-select}'[interactively select file]' \
  '(-t --subtitles)'{-t+,--subtitles=}'[subtitles file]:file:_files' \
  '(-p --port)'{-p+,--port=}'[HTTP server port]:port:' \
  '(-b --blocklist)'{-b+,--blocklist=}'[blocklist file or URL]:blocklist:' \
  '*'{-a,--announce=}'[tracker URL]:url:' \
  '(-q --quiet)'{-q,--quiet}'[suppress UI output]' \
  '(-d --download-limit)'{-d+,--download-limit=}'[max download speed kB/s]:kBps:' \
  '(-u --upload-limit)'{-u+,--upload-limit=}'[max upload speed kB/s]:kBps:' \
  '--pip[picture-in-picture mode]' \
  '--verbose[show torrent protocol details]' \
  '--playlist[open files in playlist]' \
  '--player-args=[extra player arguments]:args:' \
  '--torrent-port=[torrent seeding port]:port:' \
  '--dht-port=[DHT port]:port:' \
  '--not-on-top[do not set always-on-top]' \
  '--keep-seeding[continue seeding after download]' \
  '--no-quit[do not quit when player exits]' \
  '--on-done=[script to run after download]:script:_files' \
  '--on-exit=[script to run before program exit]:script:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'webtorrent command' commands && ret=0 ;;
  (args) _files && ret=0 ;;
esac

return ret
