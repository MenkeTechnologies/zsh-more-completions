#compdef swipl
# Documentation: swipl --help
# Source: SWI-Prolog — Prolog runtime + compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(- *)--abi-version[show ABI version key]' \
    '(- *)--arch[show architecture]' \
    '(- *)--dump-runtime-variables=-[dump link info]::format:(sh make cmake)' \
    '-x+[start from saved state]:state:_files' \
    '*-g+[run Prolog goal]:goal:' \
    '-t+[toplevel goal]:goal:' \
    '-f+[user initialisation file]:file:_files -g "*.pl"' \
    '-F+[site initialisation file]:file:_files -g "*.pl"' \
    '*-l+[load script source file]:file:_files -g "*.{pl,prolog}"' \
    '*-s+[script source file]:file:_files -g "*.{pl,prolog}"' \
    '*-p+[file search alias]:alias=path:' \
    '*-D-[set Prolog flag]:NAME[=VALUE]:' \
    '-O[optimised compilation]' \
    '-o+[output executable file (with -c)]:file:_files' \
    '-c[compile to executable and exit]' \
    '--on-error=[error policy]:style:(print halt status)' \
    '--on-warning=[warning policy]:style:(print halt status)' \
    '--tty=[allow tty control]:bool:(true false)' \
    '--packs=[attach add-ons]:bool:(true false)' \
    '--signals=[modify signal handling]:bool:(true false)' \
    '--sigalert=[thread alert signal number]:num:' \
    '--threads=[allow threads]:bool:(true false)' \
    '--debug=[generate debug info]:bool:(true false)' \
    '--debug-on-interrupt=[trap debugger on interrupt]:bool:(true false)' \
    '(-q --quiet)'{-q,--quiet=-}'[suppress informational messages]::bool:(true false)' \
    '--traditional[disable version-7 extensions]' \
    '--home=-[print or use SWI-Prolog home]::dir:_files -/' \
    '--stack-limit=[max Prolog stack size]:size:' \
    '--table-space=[max SLG table size]:size:' \
    '--shared-table-space=[max shared SLG table size]:size:' \
    '--pce=[enable xpce GUI]:bool:(true false)' \
    '--pldoc=-[start PlDoc server]::port:' \
    '*:Prolog file:_files -g "*.{pl,prolog,plp}"' \
    && ret=0

return ret
