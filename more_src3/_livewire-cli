#compdef livewire-cli
# _livewire-cli — Caleb Porzio Livewire dynamic Laravel UI CLI alias (livewire team, PHP); artisan-based
# upstream: https://github.com/livewire/livewire

_livewire-cli() {
    local -a sub=(
        'livewire:configure-s3-upload-cleanup:configure s3 upload cleanup'
        'livewire:copy:copy component'
        'livewire:cp:copy component'
        'livewire:delete:delete component'
        'livewire:rm:delete component'
        'livewire:discover:discover components'
        'livewire:make:create component'
        'livewire:form:create form object'
        'livewire:layout:publish layout'
        'livewire:move:move component'
        'livewire:mv:move component'
        'livewire:publish:publish files'
        'livewire:stubs:publish stubs'
        'livewire:touch:create component (alias)'
        'livewire:upgrade:run upgrade helper'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'livewire subcommand' sub ;;
        args)
            case $words[1] in
                livewire:make|livewire:touch) _arguments \
                    '1:component name:' \
                    '--force[force overwrite]' \
                    '--inline[inline component]' \
                    '--test[also create test]' \
                    '--pest[use pest]' \
                    '--stub=+[stub]:str:' \
                    '--view=+[view]:str:' ;;
                livewire:copy|livewire:cp|livewire:move|livewire:mv) _arguments \
                    '1:from:' \
                    '2:to:' \
                    '--force[force overwrite]' \
                    '--inline[inline]' ;;
                livewire:delete|livewire:rm) _arguments \
                    '1:component:' \
                    '--force[force]' \
                    '--inline[inline]' ;;
                livewire:publish) _arguments \
                    '--config[publish config]' \
                    '--assets[publish assets]' \
                    '--pagination[publish pagination views]' ;;
            esac
            ;;
    esac
}

_livewire-cli "$@"
