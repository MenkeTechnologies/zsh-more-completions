#compdef jsii
# Documentation: https://github.com/aws/jsii-compiler/blob/main/src/main.ts
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (yargs option definitions).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase the verbosity of output]' \
  '(-w --watch)'{-w,--watch}'[watch for file changes and recompile automatically]' \
  '(-r --project-references)'{-r,--project-references}'[generate TypeScript project references]' \
  '--fix-peer-dependencies[no longer has any effect]' \
  '(-Werr --fail-on-warnings)'{-Werr,--fail-on-warnings}'[treat warnings as errors]' \
  '*'{-Wno,--silence-warnings}'+[silence a warning (JSII code, number, or name)]:warning:' \
  '--strip-deprecated=-[hide @deprecated members; optional FQN file]::file:_files' \
  '--add-deprecation-warnings[inject runtime warnings for deprecated elements]' \
  '--generate-tsconfig=[name of tsconfig file to generate]:file:_files' \
  '(-c --tsconfig)'{-c,--tsconfig}'=[use this tsconfig file to compile]:file:_files' \
  '--validate-tsconfig=[validate the tsconfig against a rule set]:ruleset:(strict generated minimal off)' \
  '--compress-assembly[emit a compressed version of the assembly]' \
  '*:TypeScript project root:_directories'
