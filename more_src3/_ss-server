#compdef ss-server sslocal ss-local ss-redir ss-tunnel sstunnel ssmanager
# _ss-server — shadowsocks-rust ss-server Rust port of Shadowsocks fast secure socks5 proxy (shadowsocks team, Rust); clap-derive
# upstream: https://github.com/shadowsocks/shadowsocks-rust

_ss-server() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.json"' \
        '--config=+[config file]:file:_files -g "*.json"' \
        '-s+[server addr]:str:' \
        '--server-addr=+[server addr]:str:' \
        '-m+[encrypt method]:m:(none plain table rc4 rc4-md5 aes-128-cfb aes-192-cfb aes-256-cfb aes-128-ctr aes-192-ctr aes-256-ctr aes-128-gcm aes-256-gcm chacha20-ietf-poly1305 xchacha20-ietf-poly1305 2022-blake3-aes-128-gcm 2022-blake3-aes-256-gcm 2022-blake3-chacha20-poly1305 2022-blake3-chacha8-poly1305)' \
        '--encrypt-method=+[encrypt method]:m:(aes-128-gcm aes-256-gcm chacha20-ietf-poly1305 2022-blake3-aes-128-gcm 2022-blake3-aes-256-gcm 2022-blake3-chacha20-poly1305)' \
        '-k+[password]:str:' \
        '--password=+[password]:str:' \
        '-u[enable udp]' \
        '-U[udp only]' \
        '--udp-bind-addr=+[udp bind]:str:' \
        '--udp-max-associations=+[N]:n:' \
        '--udp-timeout=+[seconds]:n:' \
        '--tcp-keepalive=+[seconds]:n:' \
        '--tcp-no-delay[tcp no delay]' \
        '--tcp-fast-open[tcp fast open]' \
        '--tcp-mptcp[multipath tcp]' \
        '--mptcp[multipath tcp]' \
        '--server-host=+[host]:host:_hosts' \
        '--server-port=+[port]:port:_ports' \
        '--manager-addr=+[manager addr]:str:' \
        '--no-delay[disable Nagle]' \
        '--nofile=+[ulimit nofile]:n:' \
        '--acl=+[acl file]:file:_files' \
        '--dns=+[dns server]:str:' \
        '--ipv6-first[prefer ipv6]' \
        '--ipv6-only[ipv6 only]' \
        '--outbound-bind-addr=+[bind addr]:str:' \
        '--outbound-bind-interface=+[iface]:str:' \
        '--outbound-fwmark=+[mark]:n:' \
        '--log-without-time[no time in logs]' \
        '--log-config=+[log config file]:file:_files' \
        '-v[verbose]' \
        '--vvv[very verbose]' \
        '-d[daemon mode]' \
        '--daemonize[daemon mode]' \
        '--pid-file=+[pid file]:file:_files' \
        '--protocol=+[protocol]:p:(http socks tunnel redir)'
}

_ss-server "$@"
