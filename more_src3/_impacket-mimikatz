#compdef impacket-mimikatz
# Documentation: https://github.com/fortra/impacket/blob/master/examples/mimikatz.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-mimikatz: mini shell driving a mimikatz instance over RPC.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-file[input file with mini shell commands]:file:_files' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target machine IP]:ip:' \
  '*::positional:_files' && ret=0
return ret
