#compdef webpack-bundle-analyzer
# Documentation: https://github.com/webpack-contrib/webpack-bundle-analyzer
# Reference accessed: 2026-05-21
# Verified: upstream src/bin/analyzer.js commander option definitions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m+,--mode=}'[analyzer mode]:mode:(server static json)' \
  '(-h --host)'{-h+,--host=}'[HTTP server host]:host' \
  '(-p --port)'{-p+,--port=}'[HTTP server port or "auto"]:port' \
  '(-r --report)'{-r+,--report=}'[output file for static mode]:file:_files' \
  '(-t --title)'{-t+,--title=}'[HTML report title]:title' \
  '(-s --default-sizes)'{-s+,--default-sizes=}'[module sizes to show]:size type:(stat parsed gzip brotli zstd)' \
  '--compression-algorithm=[compression algorithm]:algo:(gzip brotli zstd)' \
  '(-O --no-open)'{-O,--no-open}'[do not open report in browser]' \
  '*'{-e+,--exclude=}'[modules to exclude (regexp)]:pattern' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(debug info warn error silent)' \
  '1:stats JSON file:_files -g "*.json"' && ret=0

return ret
