        case $line[1] in
            (module)
_arguments "${_arguments_options[@]}" : \
'--scope=[Module scope (comma-separated, default\: "*")]:SCOPE:_default' \
'--depends-on=[Module dependencies (comma-separated module ids)]:DEPENDS_ON:_default' \
'--description=[Description (writes module purpose)]:DESCRIPTION:_default' \
