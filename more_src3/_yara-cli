#compdef yara yarac yara-cli
# Documentation: https://yara.readthedocs.io/en/stable/commandline.html
# Reference accessed: 2026-05-21
# Verified: upstream YARA command-line docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (yara|yara-cli)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-C --compiled-rules)'{-C,--compiled-rules}'[RULES_FILE contains pre-compiled rules]' \
      '(-c --count)'{-c,--count}'[print number of matches only]' \
      '(-d --define)*'{-d+,--define=}'[define external variable VAR=VAL]:def:' \
      '(-q --disable-console-logs)'{-q,--disable-console-logs}'[disable console log messages]' \
      '--fail-on-warnings[treat warnings as errors]' \
      '(-f --fast-scan)'{-f,--fast-scan}'[fast matching mode]' \
      '(-i --identifier)*'{-i+,--identifier=}'[only matching identifier]:id:' \
      '--max-process-memory-chunk=[chunk size for reading process memory]:bytes:' \
      '(-l --max-rules)'{-l+,--max-rules=}'[abort after N rules matched]:n:' \
      '--max-strings-per-rule=[max strings per rule (default 10000)]:n:' \
      '(-x --module-data)*'{-x+,--module-data=}'[MODULE=FILE data]:MODULE=FILE:' \
      '(-n --negate)'{-n,--negate}'[print non-matching files]' \
      '(-N --no-follow-symlinks)'{-N,--no-follow-symlinks}'[do not follow symlinks]' \
      '(-w --no-warnings)'{-w,--no-warnings}'[disable warnings]' \
      '(-m --print-meta)'{-m,--print-meta}'[print metadata]' \
      '(-D --print-module-data)'{-D,--print-module-data}'[print module data]' \
      '(-e --print-namespace)'{-e,--print-namespace}'[print namespace]' \
      '(-S --print-stats)'{-S,--print-stats}'[print rule statistics]' \
      '(-s --print-strings)'{-s,--print-strings}'[print matching strings]' \
      '(-L --print-string-length)'{-L,--print-string-length}'[print length of matching strings]' \
      '(-g --print-tags)'{-g,--print-tags}'[print tags]' \
      '(-r --recursive)'{-r,--recursive}'[recursive]' \
      '--scan-list[scan files listed in a file]' \
      '(-z --skip-larger)'{-z+,--skip-larger=}'[skip files larger than N bytes]:size:' \
      '(-k --stack-size)'{-k+,--stack-size=}'[stack size slots]:slots:' \
      '(-t --tag)*'{-t+,--tag=}'[only matching tag]:tag:' \
      '(-p --threads)'{-p+,--threads=}'[threads for directory scanning]:n:' \
      '(-a --timeout)'{-a+,--timeout=}'[abort after seconds]:s:' \
      '*: :_files -g "*.(yar|yara)"' && ret=0 ;;
  (yarac)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-d --define)*'{-d+,--define=}'[define var=val]:def:' \
      '(-w --no-warnings)'{-w,--no-warnings}'[no warnings]' \
      '--fail-on-warnings[fail on warnings]' \
      '*: :_files -g "*.(yar|yara)"' && ret=0 ;;
esac

return ret
