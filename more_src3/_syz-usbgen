#compdef syz-usbgen
# _syz-usbgen — generate syzkaller USB/HID ID tables from a syslog (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Args from tools/syz-usbgen/usbgen.go.

_syz-usbgen() {
    _arguments \
        '1:input syslog file:_files' \
        '2:output go file:_files -g "*.go"'
}

_syz-usbgen "$@"
