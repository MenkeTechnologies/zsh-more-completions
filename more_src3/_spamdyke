#compdef spamdyke spamdyke-qrv
# Documentation: https://www.spamdyke.org/documentation/README.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# spamdyke: drop-in connection-time spam filter for qmail
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display brief option list]' \
  '(- *)--more-help[detailed options and defaults]' \
  '(- *)'{-v,--version}'[display version and copyright]' \
  '--config-test[verify configuration without accepting mail]' \
  '--config-test-smtpauth-username=[test auth with username]:user:' \
  '--config-test-smtpauth-password=[test auth with password]:password:' \
  '(-f --config-file)'{-f+,--config-file=}'[read configuration from file]:file:_files' \
  '--config-dir=[search directory tree for config files]:dir:_files -/' \
  '--config-dir-search=[directory matching rules]:rule:' \
  '(-L --full-log-dir)'{-L+,--full-log-dir=}'[log all SMTP data to directory]:dir:_files -/' \
  '(-g --graylist-dir)'{-g+,--graylist-dir=}'[create graylist files in directory]:dir:_files -/' \
  '--filter-level=[filter strictness]:level:(allow-all normal require-auth reject-all)' \
  '(-a --max-recipients)'{-a+,--max-recipients=}'[max recipients per connection]:n:' \
  '(-l --log-level)'{-l+,--log-level=}'[log verbosity level]:level:' \
  '--log-target=[log destination]:target:(syslog stderr)' \
  '(-B --ip-blacklist-file)'{-B+,--ip-blacklist-file=}'[IP blacklist file]:file:_files' \
  '(-b --rdns-blacklist-dir)'{-b+,--rdns-blacklist-dir=}'[rDNS blacklist directory]:dir:_files -/' \
  '(-s --sender-blacklist-file)'{-s+,--sender-blacklist-file=}'[sender blacklist file]:file:_files' \
  '(-W --ip-whitelist-file)'{-W+,--ip-whitelist-file=}'[IP whitelist file]:file:_files' \
  '(-x --dns-blacklist-entry)*'{-x+,--dns-blacklist-entry=}'[RBL to check]:rbl:' \
  '*--dns-whitelist-entry=[DNS whitelist entry]:entry:' \
  '(-u --policy-url)'{-u+,--policy-url=}'[append URL to rejection messages]:url:' \
  '*::qmail-smtpd args:_command_names' && ret=0

return ret
