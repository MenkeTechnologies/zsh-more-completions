#compdef initdb
# Documentation: https://www.postgresql.org/docs/current/app-initdb.html
# Source: postgres/postgres src/bin/initdb/initdb.c — initialize a new PostgreSQL cluster (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-D+,--pgdata=}'[data directory]:dir:_files -/' \
    {-E+,--encoding=}'[default encoding]:encoding:_default' \
    '--locale=-[default locale]:locale:_default' \
    '--lc-collate=-[LC_COLLATE]:locale:_default' \
    '--lc-ctype=-[LC_CTYPE]:locale:_default' \
    '--lc-monetary=-[LC_MONETARY]:locale:_default' \
    '--lc-numeric=-[LC_NUMERIC]:locale:_default' \
    '--lc-time=-[LC_TIME]:locale:_default' \
    '--lc-messages=-[LC_MESSAGES]:locale:_default' \
    '--no-locale[same as --locale=C]' \
    {-T+,--text-search-config=}'[text search config]:config:_default' \
    {-A+,--auth=}'[default auth method for both]:method:(trust reject md5 password scram-sha-256 gss sspi ident peer pam ldap radius cert)' \
    '--auth-local=-[local auth method]:method:(trust reject md5 password scram-sha-256 ident peer pam ldap radius)' \
    '--auth-host=-[host auth method]:method:(trust reject md5 password scram-sha-256 gss sspi ident pam ldap radius cert)' \
    {-W,--pwprompt}'[prompt for superuser password]' \
    '--pwfile=-[file with superuser password]:file:_files' \
    {-U+,--username=}'[superuser name]:user:_users' \
    {-d,--debug}'[debug output]' \
    {-s,--show}'[show internal settings]' \
    {-n,--no-clean}'[do not clean up after errors]' \
    {-N,--no-sync}'[do not wait for changes to be written safely]' \
    '--no-instructions[suppress post-init instructions]' \
    {-c+,--set=}'[set GUC NAME=VALUE]:setting:_default' \
    {-S,--sync-only}'[only sync data directory]' \
    {-X+,--waldir=}'[WAL directory]:dir:_files -/' \
    '--wal-segsize=-[WAL segment size in MB]:size:_default' \
    && ret=0

return ret
