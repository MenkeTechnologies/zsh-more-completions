#compdef unarchive
# Documentation: https://github.com/sorin-ionescu/prezto/blob/master/modules/archive/functions/unarchive
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
#autoload

#
# Completes unarchive.
#
# Authors:
#   Sorin Ionescu <sorin.ionescu@gmail.com>
#

_arguments \
  '(-r --remove)'{-r,--remove}'[remove archive]' \
  "*::archive file:_files -g '(#i)*.(tar|tgz|tbz|tbz2|txz|tlz|gz|bz2|xz|lzma|Z|zip|zst|jar|rar|7z|deb)(-.)'" && return 0
