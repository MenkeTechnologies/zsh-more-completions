#compdef wmr wmr-cli
# _wmr — Preact WMR ESM development tool CLI (Preact team, JavaScript); sade
# upstream: https://github.com/preactjs/wmr

_wmr() {
    local -a sub=(
        'start:start dev server (default)'
        'build:production build'
        'serve:serve production build'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wmr subcommand' sub ;;
        args)
            case $words[1] in
                start|serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--http2[http2]' \
                    '--compress=+[compress]:b:(true false)' \
                    '--no-optimize[no optimize]' \
                    '--reload[reload]' \
                    '--public=+[public dir]:dir:_files -/' \
                    '--out=+[out dir]:dir:_files -/' ;;
                build) _arguments \
                    '--public=+[public dir]:dir:_files -/' \
                    '--out=+[out dir]:dir:_files -/' \
                    '--prerender[prerender]' \
                    '--no-prerender[no prerender]' \
                    '--minify[minify]' \
                    '--no-minify[no minify]' \
                    '--sourcemap[sourcemap]' \
                    '--public-path=+[public path]:str:' ;;
            esac
            ;;
    esac
}

_wmr "$@"
