#compdef syz-imagegen
# _syz-imagegen — generate kernel filesystem images for syzkaller fuzzing (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-imagegen/imagegen.go (flag).

_syz-imagegen() {
    _arguments \
        '-list[list supported filesystems and exit]' \
        '-v[print successfully created images]' \
        '-debug[print lots of debugging output]' \
        '-populate=[populate specified image with files (internal use)]:file:_files' \
        '-keep[save disk images as .img files]' \
        '-fs=[comma-separated filesystems to generate (all if empty)]:list:' \
        '-from_json=[load filesystem config from file]:file:_files'
}

_syz-imagegen "$@"
