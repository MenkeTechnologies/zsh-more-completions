#compdef kafka-replica-verification
# Documentation: https://kafka.apache.org/documentation/ (kafka-replica-verification.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Note: tool is deprecated upstream and may be removed in a future major release.

local -a arguments

arguments=(
    '--broker-list[REQUIRED: The list of hostname and port of the server to connect to]:host\:port:'
    '--fetch-size[The fetch size of each request]:bytes:'
    '--help[Print usage information]'
    '--max-wait-ms[The max amount of time each fetch request waits]:ms:'
    '--report-interval-ms[The reporting interval]:ms:'
    '--time[Timestamp for getting the initial offsets / -1 latest / -2 earliest]:time:'
    '--topics-include[List of topics to verify replica consistency (Java regex)]:regex:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
