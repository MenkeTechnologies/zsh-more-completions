#compdef hp2ps-ghc-9.14.1
# Documentation: https://downloads.haskell.org/ghc/latest/docs/users_guide/profiling.html
# Reference accessed: 2026-05-17
# Verified: GHC users guide profiling section (hp2ps reference).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -ef- (real is -e<float>[in|mm|pt]); fabricated -i sort
# flag, -M multi-page, -p percentages, -s shorten labels, -tf threshold
# (none in upstream). Real flags are -d/-b/-e/-g/-l/-m/-p/-s/-t/-c/-y/-?.

# hp2ps: GHC heap profile to PostScript converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[sort bands by roughness]' \
  '-b[large title box]' \
  '-g[gs portrait]' \
  '-l[remove 20-band limit]' \
  '-p[use .aux from previous run]' \
  '-s[small title box]' \
  '-c[color output]' \
  '-y[ignore marks]' \
  '-\?[usage]' \
  '*:hp file:_files -g "*.hp(-.)"' && ret=0
return ret
