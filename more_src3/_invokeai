#compdef invokeai invokeai-cli invokeai-web
# _invokeai — Lincoln Stein InvokeAI Stable Diffusion creative engine CLI alias (Invoke Inc. / lstein, Python); custom argparse
# upstream: https://github.com/invoke-ai/InvokeAI

_invokeai() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--root=+[root path]:dir:_files -/' \
        '-r+[root path]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--host=+[host]:host:_hosts' \
        '-H+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--cert-file=+[ssl cert file]:file:_files' \
        '--key-file=+[ssl key file]:file:_files' \
        '--allow-origins=+[allow origins]:list:' \
        '--allow-credentials=+[allow credentials]:b:(true false)' \
        '--allow-methods=+[allow methods]:list:' \
        '--allow-headers=+[allow headers]:list:' \
        '--enable-cors[enable CORS]' \
        '--log-tokenization[log tokenization]' \
        '--log-format=+[log format]:fmt:(plain color syslog legacy)' \
        '--log-level=+[log level]:level:(debug info warning error critical)' \
        '--log-sql[log SQL]' \
        '--log-handlers=+[log handlers]:list:' \
        '--log-handler-prefix=+[log handler prefix]:str:' \
        '--scan-models-on-startup[scan models on startup]' \
        '--enable-partial-loading[enable partial loading]' \
        '--device=+[device]:d:(auto cpu cuda cuda:1 mps)' \
        '--precision=+[precision]:p:(auto float32 float16 bfloat16 autocast)' \
        '--ram=+[ram cache GB]:f:' \
        '--vram=+[vram cache GB]:f:' \
        '--lazy-offload[lazy offload]' \
        '--no-lazy-offload[no lazy offload]' \
        '--always-use-cpu[always use CPU]' \
        '--xformers[use xformers]' \
        '--no-xformers[no xformers]' \
        '--internet-available=+[internet available]:b:(true false)' \
        '--invisible-watermark[invisible watermark]' \
        '--no-invisible-watermark[no invisible watermark]' \
        '--disable-update-check[disable update check]' \
        '--update-channel=+[update channel]:c:(stable beta)' \
        '--node-cache-size=+[node cache size]:n:' \
        '--no-progress[no progress]' \
        '--profile=+[profile name]:str:' \
        '--profile-prefix=+[profile prefix]:str:' \
        '--profile-dir=+[profile dir]:dir:_files -/' \
        '--workflow-thumbnails-cache-size=+[workflow thumbnails cache size]:n:' \
        '--ignore-missing-core-models[ignore missing core models]' \
        '--legacy-models-yaml-path=+[legacy models yaml path]:file:_files' \
        '--invisible[invisible]' \
        '--browser=+[browser]:str:' \
        '*:arg:'
}

_invokeai "$@"
