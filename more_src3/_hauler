#compdef hauler
# _hauler — Rancher Federal hauler airgap content management binary for moving artifacts container images and charts (rancherfederal team, Go); cobra
# upstream: https://github.com/rancherfederal/hauler

_hauler() {
    local -a sub=(
        'store:store subcommands'
        'login:login to registry'
        'logout:logout from registry'
        'completion:generate completion'
        'docs:generate docs'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--store=+[store dir]:dir:_files -/' \
        '-s+[store dir]:dir:_files -/' \
        '--cache=+[cache dir]:dir:_files -/' \
        '--ignore-errors[continue on errors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hauler subcommand' sub ;;
        args)
            case $words[1] in
                store) _arguments '1:store cmd:(add copy extract info inspect load save sync serve)' ;;
                login) _arguments \
                    '--username=+[user]:user:_users' \
                    '-u+[user]:user:_users' \
                    '--password=+[password]:str:' \
                    '-p+[password]:str:' \
                    '--password-stdin[read password from stdin]' \
                    '*:registry:_hosts' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hauler "$@"
