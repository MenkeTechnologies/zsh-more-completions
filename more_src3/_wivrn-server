#compdef wivrn-server wivrn-dashboard
# Documentation: https://github.com/WiVRn/WiVRn
# Reference accessed: 2026-05-27
# Verified: upstream server/main.cpp CLI11 add_option/add_flag calls.
# Note: wivrn-dashboard (Qt app) does not parse custom CLI flags beyond what
# Qt itself recognizes; only --help is exposed via the Qt framework.

local curcontext="$curcontext" state line ret=1

case ${service} in
  wivrn-dashboard)
    _arguments -C \
      '--help[show help]' \
      '*: :_files' && ret=0
    ;;
  wivrn-server|*)
    _arguments -C \
      '(- *)--help[show help and exit]' \
      '(- *)--version[print version and exit]' \
      '-f+[configuration file path]:file:_files' \
      '--no-manage-active-runtime[do not set the active OpenXR runtime on connection]' \
      '--early-active-runtime[set active runtime management even without a headset]' \
      '--no-instructions[suppress startup instruction messages]' \
      '--no-fork[do not fork to serve connections (debug)]' \
      '--no-publish-service[do not publish service via Avahi]' \
      '--no-encrypt[disable encryption (debug)]' \
      '--debug-gui[enable debug GUI if compiled in]' && ret=0
    ;;
esac

return ret
