#compdef triangle
# Documentation: https://www.cs.cmu.edu/~quake/triangle.switch.html
# Source: Jonathan Shewchuk's Triangle 2D quality mesh generator and Delaunay triangulator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[triangulate a Planar Straight Line Graph (.poly)]' \
    '-r[refine a previously generated mesh]' \
    '-q[quality mesh generation (no angles < 20 degrees)]' \
    '-a[max triangle area constraint]' \
    '-u[user-defined constraint on triangle size]' \
    '-A[assign regional attribute per triangle (segment-bounded region)]' \
    '-c[enclose the convex hull with segments]' \
    '-D[conforming Delaunay (all triangles Delaunay)]' \
    '-j[jettison vertices not part of final triangulation]' \
    '-e[output edges to .edge file]' \
    '-v[output Voronoi diagram of triangulation]' \
    '-n[output triangles neighboring each triangle to .neigh]' \
    '-g[output mesh as Object File Format (.off)]' \
    '-B[suppress boundary markers in output files]' \
    '-P[suppress output .poly file]' \
    '-N[suppress output .node file]' \
    '-E[suppress output .ele file]' \
    '-I[suppress mesh iteration numbers]' \
    '-O[suppress holes (ignore holes in .poly)]' \
    '-X[suppress exact arithmetic]' \
    '-z[number all items starting from zero]' \
    '-o2[generate second-order subparametric (6-node) elements]' \
    '-Y[prohibit Steiner points on mesh boundary]' \
    '-S[max number of added Steiner points]' \
    '-i[incremental Delaunay algorithm]' \
    '-F[Fortune sweepline Delaunay algorithm]' \
    '-l[divide-and-conquer with only vertical cuts]' \
    '-s[force segments by recursively splitting at midpoints]' \
    '-C[check consistency of final mesh]' \
    '-Q[quiet (suppress all explanation)]' \
    '-V[verbose (detailed progress info)]' \
    '-h[help (complete instructions)]' \
    '*:input .poly/.node:_files' \
    && ret=0

return ret
