#compdef hgview
# Documentation: https://foss.heptapod.net/mercurial/hgview
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hgview: Qt-based Mercurial repository history viewer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --rev)'{-r,--rev=}'[start at this revision]:rev:' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-N --navigate)'{-N,--navigate}'[navigation mode (manifest browser)]' \
  '(-f --file)'{-f,--file=}'[diff against named file]:file:_files' \
  '(-u --user)'{-u,--user=}'[filter by user]:user:' \
  '(-b --branch)'{-b,--branch=}'[filter by branch]:branch:' \
  '(-k --keywords)'{-k,--keywords=}'[filter by keywords]:words:' \
  '(-I --interface)'{-I,--interface=}'[user interface]:ui:(qt curses raw)' \
  '*:Mercurial repository:_files -/' && ret=0
return ret
