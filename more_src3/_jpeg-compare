#compdef jpeg-compare
# _jpeg-compare — compute similarity metrics between two JPEG/PPM images (danielgtaylor/jpeg-archive)
# upstream: https://github.com/danielgtaylor/jpeg-archive
# Flags from jpeg-compare.c (getopt_long).

_jpeg-compare() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-S --size)'{-S+,--size=}'[hash size for fast comparison]:n:' \
        '(-m --method)'{-m+,--method=}'[comparison method]:method:(fast ssim ms-ssim smallfry mpe)' \
        '(-r --ppm)'{-r,--ppm}'[treat input as PPM]' \
        '(-T --input-filetype)'{-T+,--input-filetype=}'[type of file 1]:type:(jpeg ppm auto)' \
        '(-U --second-filetype)'{-U+,--second-filetype=}'[type of file 2]:type:(jpeg ppm auto)' \
        '--short[short output (single number)]' \
        ':file 1:_files -g "*.(jpg|jpeg|ppm)"' \
        ':file 2:_files -g "*.(jpg|jpeg|ppm)"'
}

_jpeg-compare "$@"
