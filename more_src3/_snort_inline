#compdef snort_inline
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/snort.8.html
# Reference accessed: 2026-05-21
# Verified: snort_inline is the legacy Snort 2 IDS engine with -Q (inline
# via libipq/iptables ip_queue). Flag set is the Snort 2 subset relevant
# to inline mode. See snort(8) manpage for full reference.

# snort_inline: legacy inline-mode Snort 2 (drop/replace inside iptables)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[rules file]:file:_files -g "*.(conf|rules)"' \
  '-l[log dir]:dir:_files -/' \
  '-Q[run in inline mode (libipq)]' \
  '-D[run as daemon]' \
  '-d[dump application layer]' \
  '-e[show 2nd layer headers]' \
  '-i[interface]:iface:' \
  '-N[disable packet logging]' \
  '-q[quiet]' \
  '-v[verbose]' \
  '-V[show version]' \
  '-T[test config and exit]' \
  '-u[run as user]:user:_users' \
  '-g[run as group]:group:_groups' \
  '*::snort_inline args:_files' && ret=0
return ret
