#compdef heartbeat2
# _heartbeat2 — Elastic heartbeat2 CLI command-line frontend wrapping the Heartbeat lightweight uptime monitor from the Elastic Beats family providing run setup test export keystore version completion synthetic-monitor browser-monitor http-monitor tcp-monitor icmp-monitor schedule-cron monitor-id name tags fields hosts ipv4-ipv6 sock-check-port-ssl-tls-payload (Elastic Beats team, Go); cobra
# upstream: https://www.elastic.co/beats/heartbeat

_heartbeat2() {
    local -a sub=(
        'run:run heartbeat'
        'setup:setup index pipelines templates'
        'test:test config or output'
        'export:export config or template'
        'keystore:keystore operations'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "heartbeat.yml *.yml *.yaml"' \
        '-d+[selectors]:str:' \
        '-e[log to stderr]' \
        '-E+[k=v]:str:' \
        '-N[disable publishing]' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '--strict.perms[strict perms]' \
        '--system.hostfs=+[dir]:dir:_files -/' \
        '--once[run once]' \
        '--httpprof=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'heartbeat subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments '1:target:(--index-management --pipelines --dashboards --machine-learning --policy)' '*:arg:' ;;
                test) _arguments '1:target:(config output)' ;;
                export) _arguments '1:target:(config ilm-policy index-pattern template dashboard)' ;;
                keystore) _arguments '1:op:(add create list remove)' '*:key:' ;;
            esac
            ;;
    esac
}

_heartbeat2 "$@"
