#compdef llvm-ranlib
# _llvm-ranlib — LLVM ranlib (LLVM project, C++); generate ar archive index, GNU ranlib-compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-ranlib() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-D[deterministic mode]' \
        '-U[non-deterministic mode]' \
        '-v[verbose]' \
        '*:archive:_files -g "*.a"'
}

_llvm-ranlib "$@"
