#compdef strongswan-status ipsec-status statusall
# _strongswan-status — strongSwan strongswan-status statusall CLI for displaying live status of charon IKE security associations IPsec tunnels child SAs proposals lifetimes throughput peer information and DPD state (strongswan team, C); getopt
# upstream: https://github.com/strongswan/strongswan

_strongswan-status() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-a[show all conns]' \
        '--all[show all conns]' \
        '-c[show counters]' \
        '--counters[show counters]' \
        '-d[show detailed info]' \
        '--detail[show detailed info]' \
        '-i+[ike sa name]:str:' \
        '--ike=+[ike sa name]:str:' \
        '-s+[connection name]:str:' \
        '--name=+[connection name]:str:' \
        '-r[show only routed]' \
        '--routed[show only routed]' \
        '-p+[interval]:n:' \
        '--poll=+[interval]:n:' \
        '-l+[log level]:l:(debug info warn error)' \
        '--loglevel=+[log level]:l:(debug info warn error)' \
        '--json[json output]' \
        '*:connection name:'
}

_strongswan-status "$@"
