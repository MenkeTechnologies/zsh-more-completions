#compdef konveyor-dep
# _konveyor-dep — Konveyor analyzer-lsp dependency analyzer
# upstream: https://github.com/konveyor/analyzer-lsp
# Flags from cmd/dep/main.go on tip.

_konveyor-dep() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--provider-settings=[provider settings file]:file:_files' \
        '--tree=[output dependencies as a tree]:bool:(true false)' \
        '--output-file=[dependency output file]:file:_files' \
        '--dep-label-selector=[label selector for dependencies]:expr:' \
        '-v[verbosity level]:n:'
}

_konveyor-dep "$@"
