#compdef systemstats
# Documentation: systemstats --help (macOS)
# Source: macOS systemstats(8) — summarize system power-usage stats.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds
cmds=(
    --create-archive --list-files --list-files-with-null --show-events --dump
    --dashboard --concise-dashboard --analytics-sharing-status
    --checkpoint-immediate --checkpoint-wait --logger-helper
)

_arguments -s \
    "(${cmds[*]})--create-archive[archive all stats files]" \
    "(${cmds[*]})--list-files[print stats-file paths]" \
    "(${cmds[*]})--list-files-with-null[NUL-separated stats-file paths]" \
    "(${cmds[*]})--show-events[pretty single-line records]" \
    "(${cmds[*]})--dump[dump all records to stdout]" \
    "(${cmds[*]})--dashboard[deprecated power-stats summary]" \
    "(${cmds[*]})--concise-dashboard[less verbose dashboard]:format:(csv tsv json plist pretty)" \
    "(${cmds[*]})--analytics-sharing-status[show analytics-sharing history]" \
    "(${cmds[*]})--checkpoint-immediate[checkpoint all sampled values now]" \
    "(${cmds[*]})--checkpoint-wait[wait for next autonomous checkpoint]" \
    "(${cmds[*]})--logger-helper[internal helper invocation]:archive:_files" \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-f --from)'{-f,--from=}'[stats archive path]:path:_files' \
    '(-d --day)'{-d,--day=}'[calendar day (YYYYMMDD / today / yesterday)]:day:' \
    '(-s --start-time)'{-s,--start-time=}'[start time (YYYY-MM-DD hh\:mm\:ss)]:time:' \
    '(-e --end-time)'{-e,--end-time=}'[end time (YYYY-MM-DD hh\:mm\:ss)]:time:' \
    '--file-size-limit=[per-file size cap for archives]:bytes:' \
    && ret=0

return ret
