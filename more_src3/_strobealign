#compdef strobealign
# Documentation: https://github.com/ksahlin/strobealign
# Source: ksahlin/strobealign cpp/cmdline.cpp — short-read aligner using strobemers (C++, args.hxx).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-t --threads)'{-t+,--threads=}'[number of threads]:n:_default' \
    '--ithreads=[indexing threads]:n:_default' \
    '--chunk-size=[nt per worker chunk]:n:_default' \
    '-o+[output file (default stdout)]:file:_files' \
    '-v[verbose output]' \
    '--trace[highly verbose debug output]' \
    '--no-progress[disable progress report]' \
    '-x[only map reads, emit PAF]' \
    '--aemb[estimate contig abundance values]' \
    '--interleaved[interleaved input]' \
    '--index-statistics=[print index stats to file]:file:_files' \
    '(-i --create-index)'{-i,--create-index}'[generate strobemer index only]' \
    '--use-index[use a pre-generated index]' \
    '--eqx[emit =/X instead of M CIGAR ops]' \
    '--no-PG[do not output PG header line]' \
    '-U[do not output unmapped reads]' \
    '--rg-id=[read group ID]:id:_default' \
    '*--rg=[read group metadata TAG:VALUE]:tag:_default' \
    '--details[add debug details to SAM records]' \
    '-C[append FASTQ comment to SAM record]' \
    '-N+[max secondary alignments]:n:_default' \
    '-A+[matching score (default 2)]:n:_default' \
    '-B+[mismatch penalty (default 8)]:n:_default' \
    '-O+[gap open penalty (default 12)]:n:_default' \
    '-E+[gap extension penalty (default 1)]:n:_default' \
    '-L+[soft clipping penalty (default 10)]:n:_default' \
    '--nams[use NAMs instead of collinear chaining]' \
    '-H+[chaining lookback (default 50)]:n:_default' \
    '--gd=[chaining diagonal gap cost (default 0.1)]:n:_default' \
    '--gl=[chaining gap length cost (default 0.05)]:n:_default' \
    '--vp=[chaining best score threshold (default 0.7)]:n:_default' \
    '--sg=[chaining ref skip distance (default 10000)]:n:_default' \
    '--mw=[anchor count weight (default 0.01)]:n:_default' \
    '--mcs=[multi-context seed strategy]:strategy:(always rescue off first-strobe)' \
    '-f+[top repetitive strobemer fraction to filter (default 0.0002)]:n:_default' \
    '-S+[mapping score threshold (default 0.5)]:n:_default' \
    '-M+[max mapping sites to try (default 20)]:n:_default' \
    '-R+[max nt distance for filtered seeds (default 100, 0 disables rescue)]:n:_default' \
    '1:reference (FASTA):_files -g "*.{fa,fasta,fna,fa.gz,fasta.gz,fna.gz}"' \
    '2::reads 1 (FASTA/FASTQ):_files' \
    '3::reads 2 (FASTA/FASTQ):_files' \
    && ret=0

return ret
