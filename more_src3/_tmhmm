#compdef tmhmm tmhmm2 deeptmhmm
# _tmhmm — DTU Krogh Sonnhammer TMHMM transmembrane helix prediction Hidden Markov Model (DTU team, Perl); custom argparse
# upstream: https://services.healthtech.dtu.dk/services/TMHMM-2.0/

_tmhmm() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-f+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
        '--fasta=+[input fasta]:file:_files -g "*.fa *.fasta *.faa"' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--short[short output format]' \
        '--plot[generate plot]' \
        '--noplot[no plot]' \
        '--workdir=+[work dir]:dir:_files -/' \
        '--keep[keep temp files]' \
        '--html[HTML output]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '*:input fasta:_files -g "*.fa *.fasta *.faa"'
}

_tmhmm "$@"
