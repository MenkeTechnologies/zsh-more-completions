#compdef StackSlices
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/StackSlices.cxx — stack 2D slices into a 3D volume (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:outputvolume:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:x (use -1 to skip):_default' \
    '3:y (use -1 to skip):_default' \
    '4:z (use -1 to skip):_default' \
    '*:input volume(s) or directory:_files' \
    && ret=0

return ret
