#compdef kubectl-ns
# kubectl-ns (krew plugin): switch between Kubernetes namespaces
# https://github.com/ahmetb/kubectx (kubens)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --current)'{-c,--current}'[show current namespace]' \
  '(-u --unset)'{-u,--unset}'[unset current namespace]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '1:namespace:_guard "^-*" namespace'
