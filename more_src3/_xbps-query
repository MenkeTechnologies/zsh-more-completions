#compdef xbps-query
# Documentation: https://man.voidlinux.org/xbps-query.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --config)'{-C,--config}'+[path to XBPS configuration directory]:dir:_directories' \
  '(-c --cachedir)'{-c,--cachedir}'+[path to cache directory]:dir:_directories' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '(-i --ignore-conf-repos)'{-i,--ignore-conf-repos}'[ignore repos in configuration files]' \
  '(-M --memory-sync)'{-M,--memory-sync}'[fetch repository data into memory]' \
  '(-p --property)'{-p,--property}'+[only match this package property]:prop:' \
  '-R[enable repository mode (query repos instead of rootdir)]' \
  '*--repository=[append repository URL to top of list]:url:' \
  '--regex[use Extended Regular Expression patterns]' \
  '--fulldeptree[print full dependency tree]' \
  '--staging[enable staged packages from remote repositories]' \
  '(-r --rootdir)'{-r,--rootdir}'+[target root directory]:dir:_directories' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '-l[list all installed packages]' \
  '-L[list registered repositories]' \
  '-H[list packages on hold]' \
  '-m[list manually installed packages]' \
  '-O[list orphan packages]' \
  '--list-repolock-pkgs[list packages with repolock]' \
  '-o+[search for package owning file]:pattern:' \
  '-S[show package information]' \
  '-s+[search for packages by pattern]:pattern:' \
  '-f[show package file list]' \
  '-x[show package dependencies]' \
  '-X[show reverse dependencies]' \
  '--cat=[print file contents from installed package]:file:' \
  '*:package: ' && ret=0

return ret
