#compdef jiratui
# Documentation: https://github.com/whyisdifficult/jiratui
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above (Click-based; jiratui [OPTIONS] COMMAND).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'comments:add, list or delete comments on work items'
  'config:show the location of the configuration file'
  'issues:search, update or delete work items'
  'ui:launch the Jira TUI application'
  'users:search users and user groups'
  'version:show the version of the tool'
  'themes:list the available built-in themes'
)

_arguments -C \
  '--help[show help and exit]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'jiratui command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (issues)
        _arguments \
          '--help[show help]' \
          '--project-key=[project key]:key:' \
          '--key=[work item key]:key:' && ret=0
        ;;
      (*)
        _arguments '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
