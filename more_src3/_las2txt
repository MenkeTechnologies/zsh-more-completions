#compdef las2txt
# Zsh completion for las2txt - convert LAS to text
# https://github.com/LAStools/LAStools

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  {-i,--input=}'[specify input LAS/LAZ file]:input file:_files' \
  {-o,--output=}'[specify output text file]:output file:_files' \
  '--parse=[specify fields to output (x y z i r n s c t p e d u)]:parse string:' \
  '--sep=[set field separator character]:separator:' \
  '--header[include header line in output]' \
  '--verbose[verbose output]' \
  '*:file:_files'
