#compdef sgx-epc
# _sgx-epc — containers/nri-plugins NRI plugin that exposes Intel SGX EPC pages as an extended k8s resource (sgx.intel.com/epc)
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/plugins/sgx-epc/sgx-epc.go on tip.

_sgx-epc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--name=[plugin name to register to NRI]:name:' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--verbose[enable verbose logging]'
}

_sgx-epc "$@"
