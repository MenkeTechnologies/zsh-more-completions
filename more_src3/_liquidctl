#compdef liquidctl
# Documentation: https://github.com/liquidctl/liquidctl/blob/main/liquidctl/cli.py
# Reference accessed: 2026-05-19
# Verified: liquidctl/liquidctl liquidctl/cli.py docopt block.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --single (real flag is --single-12v-ocp); --export-format;
# `--device` is deprecated (kept as `-d/--device` for back-compat).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list compatible devices'
  'initialize:initialize device(s)'
  'status:show device status'
  'set:set channel value'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[output additional information]' \
  '(-g --debug)'{-g,--debug}'[show debug information on stderr]' \
  '(-m --match)'{-m,--match}'=[filter devices by description substring]:str:' \
  '(-n --pick)'{-n,--pick}'=[pick among many results for a filter]:n:' \
  '--vendor=[USB vendor ID (hex)]:vid:' \
  '--product=[USB product ID (hex)]:pid:' \
  '--release=[USB release (hex)]:rel:' \
  '--serial=[device serial]:serial:' \
  '--bus=[bus type]:bus:' \
  '--address=[device address on bus]:addr:' \
  '--usb-port=[USB port on bus]:port:' \
  '(-d --device)'{-d,--device}'=[select device by listing index (deprecated)]:n:' \
  '--speed=[abstract animation speed]:value:' \
  '--time-per-color=[time per color (seconds)]:n:' \
  '--time-off=[time with LED off (seconds)]:n:' \
  '--alert-threshold=[high-temp visual alert threshold (degC)]:n:' \
  '--alert-color=[high-temp visual alert color]:color:' \
  '--direction=[pattern movement direction]:dir:(forward backward)' \
  '--start-led=[first LED to start effect at]:n:' \
  '--maximum-leds=[number of LEDs the effect applies to]:n:' \
  '--pump-mode=[pump mode (certain Corsair coolers)]:mode:(quiet balanced extreme)' \
  '--fan-mode=[channel:mode pairs]:pairs:' \
  '--temperature-sensor=[temperature sensor number]:n:' \
  '--single-12v-ocp[enable single rail +12V OCP]' \
  '--legacy-690lc[treat as Asetek 690LC legacy]' \
  '--non-volatile[persist to non-volatile storage]' \
  '--direct-access[bypass kernel driver]' \
  '--unsafe=[comma-separated unsafe features]:list:' \
  '--json[JSON output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'liquidctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (set)
        _arguments \
          '1:channel:(fan fan1 fan2 fan3 pump led led1 led2 sync)' \
          '2:property:(speed color)' \
          '*:value or args:' && ret=0 ;;
      (initialize) _values 'arg' 'all' && ret=0 ;;
    esac ;;
esac

return ret
