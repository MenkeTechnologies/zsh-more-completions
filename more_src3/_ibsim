#compdef ibsim
# Documentation: https://github.com/linux-rdma/ibsim
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ibsim: InfiniBand fabric simulator.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-u[show usage]' \
  '(- *)-V[show version]' \
  '(-f --file)'{-f+,--file=}'[output file]:file:_files' \
  '(-d --debug)*'{-d,--debug}'[increase debug level]' \
  '(-p --parsedebug)*'{-p,--parsedebug}'[increase parse-debug level]' \
  '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
  '(-s --start)'{-s,--start}'[start the IB network immediately]' \
  '(-I --Ignoredups)'{-I,--Ignoredups}'[ignore duplicate node descriptions]' \
  '(-N --Nodes)'{-N+,--Nodes=}'[max network nodes]:n:' \
  '(-S --Switches)'{-S+,--Switches=}'[max network switches]:n:' \
  '(-P --Ports)'{-P+,--Ports=}'[max network ports]:n:' \
  '(-L --Linearcap)'{-L+,--Linearcap=}'[linear forwarding table capacity]:n:' \
  '(-M --Mcastcap)'{-M+,--Mcastcap=}'[multicast forwarding table capacity]:n:' \
  '(-r --remote)'{-r,--remote}'[remote mode]' \
  '(-l --listen)'{-l+,--listen=}'[port to listen on]:port:' \
  '(-n --no-console)'{-n,--no-console}'[disable console]' \
  '*:netfile:_files' && ret=0
return ret
