#compdef aomenc aomdec aom libaom
# _libaom — Alliance for Open Media libaom aomenc and aomdec reference AV1 video encoder decoder implementation (av1 team, C); getopt
# upstream: https://aomedia.googlesource.com/aom

_libaom() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--codec=+[codec]:c:(av1)' \
        '--passes=+[N]:n:' \
        '--pass=+[N]:n:' \
        '--fpf=+[stats file]:file:_files' \
        '--limit=+[N frames]:n:' \
        '--good[good quality]' \
        '--allintra[all intra]' \
        '--rt[realtime]' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-h+[height]:n:' \
        '--height=+[height]:n:' \
        '--fps=+[num/denom]:str:' \
        '--target-bitrate=+[kbps]:n:' \
        '--cpu-used=+[N]:n:' \
        '--auto-alt-ref=+[bool]:b:(0 1)' \
        '--lag-in-frames=+[N]:n:' \
        '--threads=+[N]:n:' \
        '-t+[N]:n:' \
        '--end-usage=+[mode]:m:(vbr cbr cq q)' \
        '--cq-level=+[N]:n:' \
        '--min-q=+[N]:n:' \
        '--max-q=+[N]:n:' \
        '--profile=+[N]:n:' \
        '--tile-columns=+[N]:n:' \
        '--tile-rows=+[N]:n:' \
        '--row-mt=+[bool]:b:(0 1)' \
        '--enable-tpl-model=+[bool]:b:(0 1)' \
        '--aq-mode=+[mode]:m:(0 1 2 3)' \
        '--deltaq-mode=+[mode]:m:(0 1 2 3 4 5)' \
        '--enable-tpl=+[bool]:b:(0 1)' \
        '--bit-depth=+[N]:n:(8 10 12)' \
        '--input-bit-depth=+[N]:n:' \
        '--matrix-coefficients=+[mode]:str:' \
        '--color-primaries=+[mode]:str:' \
        '--transfer-characteristics=+[mode]:str:' \
        '--color-range=+[range]:r:(0 1)' \
        '--enable-cdef=+[bool]:b:(0 1)' \
        '--enable-restoration=+[bool]:b:(0 1)' \
        '--enable-superres=+[bool]:b:(0 1)' \
        '--superres-mode=+[N]:n:' \
        '--superres-denominator=+[N]:n:' \
        '--ivf[IVF output]' \
        '--webm[WebM output]' \
        '--obu[OBU output]' \
        '-o+[output file]:file:_files -g "*.ivf *.webm *.obu *.av1 *.yuv *.y4m *.mkv"' \
        '*:input yuv:_files -g "*.yuv *.y4m"'
}

_libaom "$@"
