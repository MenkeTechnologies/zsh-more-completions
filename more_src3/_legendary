#compdef legendary
# Documentation: https://github.com/derrod/legendary/blob/master/legendary/cli.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Legendary (open source game launcher for Epic Games)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'activate:activate games on third party launchers'
  'alias:manage aliases'
  'auth:authenticate with the Epic Games Store'
  'clean-saves:clean cloud saves'
  'cleanup:remove old temporary, metadata, and manifest files'
  'crossover:setup CrossOver for launching games (macOS only)'
  'download-saves:download all cloud saves'
  'egl-sync:setup or run Epic Games Launcher sync'
  'eos-overlay:manage EOS Overlay install'
  'import:import an already installed game'
  'info:print info about specified app name or manifest'
  'install:install/download/update/repair a game'
  'download:alias for install'
  'update:alias for install'
  'repair:alias for install (with --repair)'
  'launch:launch a game'
  'list:list available installable games'
  'list-files:list files in manifest'
  'list-installed:list installed games'
  'list-saves:list available cloud saves'
  'move:move specified app to a new location'
  'status:show legendary status information'
  'sync-saves:sync cloud saves'
  'uninstall:uninstall (delete) a game'
  'verify:verify a game'\''s local files'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-H,--full-help}'[show full help including individual command help]' \
  '(- *)'{-V,--version}'[print version and exit]' \
  '(-v --debug)'{-v,--debug}'[set loglevel to debug]' \
  '(-y --yes)'{-y,--yes}'[default to yes for all prompts]' \
  '(-J --pretty-json)'{-J,--pretty-json}'[pretty-print JSON]' \
  '(-A --api-timeout)'{-A+,--api-timeout=}'[API HTTP request timeout in seconds]:seconds:' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (install|download|update|repair)
        _arguments -s -S \
          '--base-path=[base installation path]:path:_files -/' \
          '--game-folder=[game folder name]:folder:' \
          '--max-shared-memory=[max shared memory MiB]:memory:' \
          '--max-workers=[max number of download workers]:workers:' \
          '--manifest=[manifest URL or path]:manifest:' \
          '--old-manifest=[old manifest URL or path]:manifest:' \
          '--delta-manifest=[delta manifest URL or path]:manifest:' \
          '--platform=[platform to install for]:platform:(Windows Mac Win32)' \
          '--prefix=[only fetch paths starting with prefix]:prefix:' \
          '--exclude=[exclude paths starting with prefix]:prefix:' \
          '--install-tag=[only download files with install tag]:tag:' \
          '--enable-reordering[enable reordering to reduce RAM]' \
          '--dl-timeout=[download timeout (seconds)]:timeout:' \
          '--save-path=[override save game path]:path:_files -/' \
          '--repair[repair game files]' \
          '--repair-and-update[repair and update game]' \
          '--ignore-free-space[skip free space check]' \
          '--disable-patching[disable delta patching]' \
          '--force[redownload all files]' \
          '--no-install[do not install, only download]' \
          '--with-dlcs[install DLCs]' \
          '--skip-dlcs[do not install DLCs]' \
          '*:app name:' && ret=0
        ;;
      (launch)
        _arguments -s -S \
          '--offline[skip login and run game offline]' \
          '--skip-version-check[skip version check]' \
          '--override-username=[override username]:username:' \
          '--dry-run[print launch command without running]' \
          '--language=[override game language]:language:' \
          '--wrapper=[wrapper command for launch]:command:' \
          '--set-defaults[set current arguments as default]' \
          '--reset-defaults[reset default arguments]' \
          '--wine=[path to wine binary]:wine binary:_files' \
          '--wine-prefix=[path to wine prefix]:wine prefix:_files -/' \
          '--no-wine[do not use wine]' \
          '*:app name:' && ret=0
        ;;
      (list|list-games|list-installed)
        _arguments -s -S \
          '--platform=[platform]:platform:(Windows Mac Win32)' \
          '--include-ue[include Unreal Engine]' \
          '-T[include non-installable items]' \
          '--csv[output as CSV]' \
          '--tsv[output as TSV]' \
          '--json[output as JSON]' && ret=0
        ;;
      (uninstall)
        _arguments -s -S \
          '--keep-files[do not delete game files]' \
          '*:app name:' && ret=0
        ;;
      (auth)
        _arguments -s -S \
          '--import[import from Epic Games Launcher]' \
          '--code=[authorization code]:code:' \
          '--token=[exchange token]:token:' \
          '--sid=[SID from browser]:sid:' \
          '--delete[remove existing credentials]' \
          '--disable-webview[disable embedded browser]' && ret=0
        ;;
      (*)
        _arguments -s -S \
          '*:app name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
