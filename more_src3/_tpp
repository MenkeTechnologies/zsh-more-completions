#compdef tpp
# Documentation: https://github.com/cbbrowne/tpp
# Reference accessed: 2026-05-21
# Verified: upstream tpp.rb ARGV parsing at the URL above.

# Zsh completion for tpp (text presentation program)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-t+[output format type]:type:(ncurses autoplay latex txt)' \
  '-o+[output file]:file:_files' \
  '-s+[delay seconds between slides in autoplay mode]:seconds' \
  '1:presentation file:_files -g "*.tpp(N)"' && ret=0

return ret
