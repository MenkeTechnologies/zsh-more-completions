#compdef agdbinfo
# _libagdb — libyal Windows SuperFetch (.db, agdb) parser; dumps prefetch context, volume info, file references used by Win Vista+ memory manager
# upstream: https://github.com/libyal/libagdb

_libagdb() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-X[exclusive]' \
        '*:SuperFetch db:_files -g "*.db"'
}

_libagdb "$@"
