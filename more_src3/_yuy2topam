#compdef yuy2topam
# Documentation: man yuy2topam (Netpbm)
# Source: convert YUY2 4:2:2 packed bytes to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[image width pixels]:pixels:' \
    '-height=[image height pixels]:pixels:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:yuy2 data file:_files' \
    && ret=0

return ret
