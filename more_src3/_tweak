#compdef tweak
# Documentation: https://www.chiark.greenend.org.uk/~sgtatham/tweak/manpage-3.02.html
# Reference accessed: 2026-05-21
# Verified: upstream tweak manpage section 1.4 OPTIONS.

# tweak: simple binary file editor for terminal
local curcontext="$curcontext" ret=1
_arguments -C \
  '-f[fix mode: insert function disabled]' \
  '-l[look mode: read-only, no modifications]' \
  '-e[eager mode: read entire input at startup]' \
  '-w[bytes per line]:width:' \
  '-o[ensure file offset at start of line]:offset:' \
  '-D[print default .tweakrc to stdout, do not edit]' \
  '*:file:_files' && ret=0
return ret
