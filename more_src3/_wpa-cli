#compdef wpa-cli wpa_cli
# _wpa-cli — wpa_supplicant Wi-Fi protected access control CLI (Jouni Malinen, C); custom argparse
# upstream: https://w1.fi/wpa_supplicant/

_wpa-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-p+[control socket path]:dir:_files -/' \
        '-i+[interface]:iface:_net_interfaces' \
        '-g+[global control socket path]:file:_files' \
        '-G+[ping interval]:n:' \
        '-B[run as daemon]' \
        '-a+[action script]:file:_files' \
        '-P+[pid file]:file:_files' \
        '-T[trace function calls]' \
        '-s[silent mode]' \
        '*:arg:'
}

_wpa-cli "$@"
