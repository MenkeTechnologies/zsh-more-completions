#compdef synthv1 synthv1_jack synthv1_lv2
# _synthv1 — Rui Nuno Capela synthv1 polyphonic dual-oscillator subtractive synthesizer with LV2 plugin and standalone JACK app for analog-style synth voices (rncbc team, C++/Qt); Qt argparse
# upstream: https://synthv1.sourceforge.io/

_synthv1() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[client name]:str:' \
        '--client-name=+[client name]:str:' \
        '-J+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[no auto connect]' \
        '--no-auto-connect[no auto connect]' \
        '-G[no GUI]' \
        '--no-gui[no GUI]' \
        '-p+[preset]:str:' \
        '--preset=+[preset]:str:' \
        '--style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '--platform=+[platform]:p:(xcb wayland cocoa windows direct2d)' \
        '*:synthv1 preset file:_files -g "*.synthv1 *.lv2"'
}

_synthv1 "$@"
