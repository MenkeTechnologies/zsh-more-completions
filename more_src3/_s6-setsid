#compdef s6-setsid
# _s6-setsid — s6 daemontools-extras s6-setsid (setsid/setpgrp wrapper that can detach from controlling terminal, optionally grab a new ctty, and run a child in a session/pgrp; richer than util-linux setsid)
# upstream: https://github.com/skarnet/s6
# Flags from src/daemontools-extras/s6-setsid.c on tip.

_s6-setsid() {
    _arguments \
        '(-s -b -f -g)-s[setsid (new session, default)]' \
        '(-s -b -f -g)-b[start a new process group]' \
        '(-s -b -f -g)-f[foreground (do not setsid, just setpgrp)]' \
        '(-s -b -f -g)-g[run child in current process group]' \
        '(-i -I -q)-i[ignore failures (do not exit on error)]' \
        '(-i -I -q)-I[fail on error (strict)]' \
        '(-i -I -q)-q[silent]' \
        '-d+[ctty path to grab]:tty:_files' \
        '*::program:_command_names -e'
}

_s6-setsid "$@"
