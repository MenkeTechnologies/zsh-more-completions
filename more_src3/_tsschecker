#compdef tsschecker
# _tsschecker — check TSS signing status for iOS firmware (1Conan/tsschecker, fork of tihmstar/tsschecker)
# upstream: https://github.com/tihmstar/tsschecker
# Flags from tsschecker/main.c.

_tsschecker() {
    local -a args
    args=(
        '(-d --device)'{-d+,--device=}'[device model (e.g. iPhone10,3)]:model:'
        '(-i --ios)'{-i+,--ios=}'[firmware version (e.g. 14.7.1)]:version:'
        '(-o --ota)'{-o,--ota}'[check OTA signing status instead of normal restore]'
        '(-b --no-baseband)'{-b,--no-baseband}'[do not check baseband signing; request tickets without baseband]'
        '(-m --build-manifest)'{-m+,--build-manifest=}'[explicit BuildManifest (can be combined with -d)]:file:_files -g "*.plist"'
        '(-s --save)'{-s,--save}'[save fetched SHSH blobs (most useful with -e)]'
        '(-u --update-install)'{-u,--update-install}'[only request tickets for InstallType=Update]'
        '(-l --latest)'{-l,--latest}'[use the latest public firmware version]'
        '(-e --ecid)'{-e+,--ecid=}'[ECID to use for fetching blobs (instead of random)]:ecid:'
        '(-g --generator)'{-g+,--generator=}'[generator in 16-char hex (e.g. 0x1111111111111111)]:generator:'
        '(-x --cryptexseed)'{-x+,--cryptexseed=}'[Cryptex1 seed in 32-char hex]:seed:'
        '(-t --cryptexnonce)'{-t+,--cryptexnonce=}'[Cryptex1 Nonce (required for cryptex blobs)]:nonce:'
        '(-c --bbsnum)'{-c+,--bbsnum=}'[BbSNUM in hex (for saving BBTickets)]:snum:'
        '(-p --bplist)'{-p,--bplist}'[save SHSH blob as binary plist (use with --save)]'
        '(-r --raw)'{-r,--raw}'[send raw file to Apple TSS server (debug)]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_tsschecker "$@"
