#compdef helm-git
# Documentation: https://github.com/aslafy-z/helm-git
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# helm-git is invoked via Git URL query parameters (ref, sparse, depupdate,
# package), not as a standalone command with traditional flags.
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:helm repo URL (git+https://... with ?ref=...&sparse=...):'
