#compdef kubectl-who-can
# kubectl-who-can (krew plugin): show who has RBAC permissions for actions
# https://github.com/aquasecurity/kubectl-who-can

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[check all namespaces]' \
  '--as=[username to impersonate]:user' \
  '--as-group=[group to impersonate]:group' \
  '--as-uid=[UID to impersonate]:uid' \
  '--cluster=[cluster to use]:cluster' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--subresource=[sub-resource]:subresource' \
  '1:verb:(get list create update patch delete deletecollection watch)' \
  '2:resource' \
  '3:resource name'
