#compdef knative-kafka-webhook
# _knative-kafka-webhook — Knative Eventing Kafka Broker admission webhook (sharedmain)
# upstream: https://github.com/knative-extensions/eventing-kafka-broker
# Flags from control-plane/cmd/webhook-kafka/main.go + knative.dev/pkg sharedmain on tip.

_knative-kafka-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-kafka-webhook "$@"
