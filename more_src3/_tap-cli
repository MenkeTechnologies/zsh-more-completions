#compdef tap-cli
# _tap-cli — Isaac Z. Schlueter node-tap test framework CLI alias (tapjs team, TypeScript); custom argparse
# upstream: https://github.com/tapjs/tapjs

_tap-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--coverage[enable coverage]' \
        '--no-coverage[disable coverage]' \
        '--coverage-report=+[reporter]:r:(text text-summary html json lcov clover cobertura)' \
        '--check-coverage[fail on low coverage]' \
        '--branches=+[pct]:n:' \
        '--functions=+[pct]:n:' \
        '--lines=+[pct]:n:' \
        '--statements=+[pct]:n:' \
        '--100[require 100 pct coverage]' \
        '--reporter=+[reporter]:r:' \
        '-R+[reporter]:r:' \
        '--no-color[no color]' \
        '--color[color]' \
        '--bail[bail on first fail]' \
        '--no-bail[no bail]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--jobs-auto[auto jobs]' \
        '--timeout=+[seconds]:n:' \
        '-t+[seconds]:n:' \
        '--save=+[save file]:file:_files' \
        '--changed[only changed]' \
        '-n[only changed]' \
        '--watch[watch mode]' \
        '-w[watch mode]' \
        '--only[only flagged tests]' \
        '-O[only flagged tests]' \
        '--grep=+[pattern]:str:' \
        '-g+[pattern]:str:' \
        '--invert[invert grep]' \
        '-i[invert grep]' \
        '--node-arg=+[node arg]:str:' \
        '--ts[enable typescript]' \
        '--no-ts[disable typescript]' \
        '--jsx[enable jsx]' \
        '--no-jsx[disable jsx]' \
        '--debug[debug mode]' \
        '--snapshot[snapshot mode]' \
        '--snapshot-update[update snapshots]' \
        '-s[update snapshots]' \
        '--rcfile=+[rcfile]:file:_files' \
        '--show-full-coverage[show full coverage]' \
        '--include=+[glob]:str:' \
        '--exclude=+[glob]:str:' \
        '--test-regex=+[regex]:str:' \
        '--test-ignore=+[ignore]:str:' \
        '--passes[print passing tests]' \
        '--no-passes[hide passing tests]' \
        '*:test files:_files'
}

_tap-cli "$@"
