#compdef waybackurls-cli waybackurls
# _waybackurls-cli — TomNomNom Tom Hudson waybackurls-cli CLI command-line frontend wrapping the waybackurls accept line-delimited domains on stdin fetch known URLs from the Wayback Machine for *.domain and output them on stdout open-source written in Go AlienVault-OTX Common-Crawl WaybackMachine-Internet-Archive Virus-Total-Public-Search-Wayback-Endpoint historical-URL-list historical-URL-archive subdomain-flag dates-flag (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/waybackurls

_waybackurls-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-dates[show dates]' \
        '-no-subs[no subdomains]' \
        '-get-versions[get all versions]' \
        '*:domain:'
}

_waybackurls-cli "$@"
