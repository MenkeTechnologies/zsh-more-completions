#compdef up
# Documentation: https://github.com/apex/up (apex/up CLI)
# Reference accessed: 2026-05-21
# Verified: upstream apex/up internal/cli subcommand directories.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'app:application management'
  'build:build deployment archive'
  'config:show effective configuration'
  'deploy:deploy the project'
  'disable-stats:disable anonymous statistics'
  'docs:open documentation'
  'domains:manage domains'
  'logs:show log output'
  'metrics:show project metrics'
  'prune:prune old deployments'
  'run:run a hook (build, etc.)'
  'stack:manage CloudFormation stack'
  'start:start the dev server locally'
  'team:manage team / billing / subscription'
  'upgrade:upgrade up CLI'
  'url:show / open / copy stage endpoint URL'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-C --chdir)'{-C+,--chdir=}'[change working directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose log output]' \
  '--format=[output format]:format:(text json)' \
  '--region=[target region]:region:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'up command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (stack)
        _arguments \
          '*::sub:(plan apply delete status)' && ret=0 ;;
      (logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '(-s --since)'{-s+,--since=}'[show logs since duration]:duration:' \
          '(-q --query)'{-q+,--query=}'[log query]:query:' \
          '--region=[region]:region:' && ret=0 ;;
      (url)
        _arguments \
          '(-o --open)'{-o,--open}'[open in browser]' \
          '(-c --copy)'{-c,--copy}'[copy to clipboard]' \
          '*::stage:(staging production development)' && ret=0 ;;
      (team)
        _arguments '*::sub:(status switch login logout members subscribe unsubscribe card ci add)' && ret=0 ;;
      (run)
        _arguments \
          '*::hook:(build clean preinstall postinstall predeploy postdeploy)' && ret=0 ;;
      (start)
        _arguments \
          '--port=[local port]:port:' \
          '--command=[start command]:cmd:' && ret=0 ;;
      (deploy)
        _arguments \
          '--stage=[target stage]:stage:(staging production development)' \
          '--region=[region]:region:' && ret=0 ;;
    esac ;;
esac

return ret
