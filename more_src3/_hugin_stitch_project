#compdef hugin_stitch_project
# Documentation: https://wiki.panotools.org/Hugin_stitch_project
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--batch[run as batch job]' \
  '--delete[delete project file when done]' \
  '--overwrite[overwrite existing files without prompting]' \
  '/w[overwrite existing files without prompting]' \
  '--output=[output filename / prefix]:file:_files' \
  '--user-defined-output=[user defined script]:script:_files' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
