#compdef smartpy SmartPy
# _smartpy — SmartPy team smartpy intuitive smart-contract development platform for Tezos with Python embedded DSL (smartpy team, Python); argparse
# upstream: https://gitlab.com/SmartPy/smartpy

_smartpy() {
    local -a sub=(
        'compile:compile a contract'
        'test:test a contract'
        'doc:generate documentation'
        'kind:show contract kind'
        'originate:originate a contract'
        'export:export contract'
        'install:install templates'
        'list:list templates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--protocol=+[protocol]:p:(ithaca jakarta kathmandu lima mumbai nairobi oxford paris quebec rio)' \
        '--purge[purge build]' \
        '--no-cache[no cache]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[disable color]' \
        '--out=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'smartpy subcommand' sub ;;
        args)
            case $words[1] in
                compile|test|kind) _arguments \
                    '--protocol=+[protocol]:p:(ithaca jakarta kathmandu lima mumbai nairobi oxford paris quebec rio)' \
                    '--out=+[output dir]:dir:_files -/' \
                    '*:file:_files -g "*.py"' ;;
                originate) _arguments \
                    '--endpoint=+[node URL]:url:_urls' \
                    '--protocol=+[protocol]:p:(ithaca jakarta kathmandu lima mumbai nairobi oxford paris quebec rio)' \
                    '--private-key=+[signer key]:str:' \
                    '--storage=+[initial storage]:str:' \
                    '--public-key-hash=+[manager pkh]:str:' \
                    '*:file:_files -g "*.tz *.py"' ;;
                doc|export) _arguments '*:file:_files -g "*.py"' ;;
            esac
            ;;
    esac
}

_smartpy "$@"
