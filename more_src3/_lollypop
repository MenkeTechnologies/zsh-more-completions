#compdef lollypop
# _lollypop — GNOME music player (gnome/lollypop)
# upstream: https://gitlab.gnome.org/World/lollypop
# Options from lollypop/application_cmdline.py (Gtk.Application.add_main_option).

_lollypop() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-a --play-ids)'{-a+,--play-ids=}'[play tracks by ID list]:ids:' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-r --set-rating)'{-r+,--set-rating=}'[rate the current track]:rating:(1 2 3 4 5)' \
        '(-t --play-pause)'{-t,--play-pause}'[toggle playback]' \
        '(-s --stop)'{-s,--stop}'[stop playback]' \
        '(-n --next)'{-n,--next}'[skip to next track]' \
        '(-p --prev)'{-p,--prev}'[skip to previous track]' \
        '(-e --emulate-phone)'{-e,--emulate-phone}'[emulate a Librem phone UI]' \
        '*:audio file/dir:_files'
}

_lollypop "$@"
