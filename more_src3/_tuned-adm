#compdef tuned-adm
# Documentation: man tuned-adm(8)
# Source: redhat-performance/tuned tuned-adm.py (master) — Tuned daemon CLI (Python argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-d --debug)'{-d,--debug}'[show debug messages]' \
    '(-a --async)'{-a,--async}'[do not wait for completion (dbus)]' \
    '(-t --timeout)'{-t+,--timeout=}'[sync operation timeout in seconds]:seconds:_default' \
    '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:(critical error warn info debug)' \
    '1:command:(list active off profile profile_info recommend verify auto_profile profile_mode instance_acquire_devices get_instances instance_get_devices)' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            list)
                _arguments '1:list choice:(profiles plugins)' '(-v --verbose)'{-v,--verbose}'[show plugin configuration]' ;;
            profile)
                _arguments '*:profile:_default' ;;
            profile_info)
                _arguments '1::profile:_default' ;;
            verify)
                _arguments '(-i --ignore-missing)'{-i,--ignore-missing}'[ignore missing/unsupported tunings]' ;;
            instance_acquire_devices)
                _arguments '1:devices (comma list):_default' '2:instance:_default' ;;
            get_instances)
                _arguments '1::plugin name:_default' ;;
            instance_get_devices)
                _arguments '1:instance:_default' ;;
        esac
        ;;
esac

return ret
