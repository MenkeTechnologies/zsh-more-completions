#compdef ueberzug ueberzugpp
# Documentation: https://pypi.org/project/ueberzug/ ; https://github.com/jstkdng/ueberzugpp
# Reference accessed: 2026-05-21
# Verified: upstream ueberzug 18.3.1 __main__.py docopt usage and ueberzugpp README.

local curcontext="$curcontext" state line ret=1

local -a commands
if [[ ${words[1]} == ueberzugpp ]]; then
  commands=(
    'layer:send commands to ueberzugpp for displaying images'
    'tmux:internal tmux integration'
  )
else
  commands=(
    'layer:display images in terminal'
    'library:print path to the bash library'
    'version:print project version'
    'query_windows:internal — search for windows'
  )
fi

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ueberzug command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (layer)
        if [[ ${words[1]} == ueberzugpp ]]; then
          _arguments \
            '(-h --help)'{-h,--help}'[show help]' \
            '(-s --silent)'{-s,--silent}'[print stderr to /dev/null]' \
            '--use-escape-codes[detect terminal capabilities via escape codes]' \
            '--pid-file=[output file for daemon PID]:file:_files' \
            '--no-stdin[do not listen on stdin]' \
            '--no-cache[disable resized-image cache]' \
            '--no-opencv[use Libvips instead of OpenCV]' \
            '(-o --output)'{-o,--output}'[image output method]:output:(x11 wayland sixel kitty iterm2 chafa)' \
            '(-p --parser)'{-p,--parser}'[unused (backwards compat)]:parser:' \
            '(-l --loader)'{-l,--loader}'[unused (backwards compat)]:loader:' && ret=0
        else
          _arguments \
            '(-p --parser)'{-p,--parser}'[input parser]:parser:(json simple bash)' \
            '(-l --loader)'{-l,--loader}'[image loader]:loader:(synchronous thread process)' \
            '(-s --silent)'{-s,--silent}'[print stderr to /dev/null]' && ret=0
        fi
        ;;
      (query_windows)
        _arguments '*:PID:_pids' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
