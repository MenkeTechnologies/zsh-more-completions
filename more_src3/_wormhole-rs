#compdef wormhole-rs
# _wormhole-rs — Rust port of magic-wormhole (magic-wormhole/magic-wormhole.rs)
# upstream: https://github.com/magic-wormhole/magic-wormhole.rs
# Subcommands & flags from cli/src/main.rs (clap).

_wormhole-rs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose --log)'{-v,--verbose,--log}'[enable logging to stdout]' \
        '--no-color[disable color output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'send:send a file or a folder'
                'tx:alias for send'
                'receive:receive a file or a folder'
                'rx:alias for receive'
                'send-many:send a file to many recipients'
                'forward:forward TCP ports between machines'
                'completion:generate shell completion scripts'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                send|tx)
                    _arguments \
                        '--rename=[suggest a different filename to receiver]:name:' \
                        '--name=[alias for --rename]:name:' \
                        '*:file/dir:_files'
                    ;;
                send-many)
                    _arguments \
                        '(-n --tries)'{-n+,--tries=}'[limit number of receivers]:n:' \
                        '--timeout=[stop after N minutes]:mins:' \
                        '*:file/dir:_files'
                    ;;
                receive|rx)
                    _arguments \
                        '--noconfirm[accept without confirmation]' \
                        '--yes[alias for --noconfirm]'
                    ;;
                forward)
                    _arguments '1:subcommand:(serve connect)' '*::args:'
                    ;;
                completion)
                    _arguments '1:shell:(bash elvish fish powershell zsh)'
                    ;;
            esac
            ;;
    esac
}

_wormhole-rs "$@"
