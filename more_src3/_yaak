#compdef yaak yaak-cli
# _yaak — Yaak yaak-cli CLI for the Yaak desktop API testing tool managing workspaces environments requests folders responses with HTTP REST GraphQL gRPC WebSocket and OAuth (mountain-loop team, TypeScript); commander.js
# upstream: https://github.com/mountain-loop/yaak

_yaak() {
    local -a sub=(
        'workspace:workspace operations'
        'environment:environment operations'
        'folder:folder operations'
        'request:request operations'
        'response:response operations'
        'run:run request or folder'
        'export:export workspace'
        'import:import workspace'
        'sync:sync workspace'
        'settings:show settings'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--workspace=+[name or id]:str:' \
        '--environment=+[name or id]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yaak subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--data=+[json]:str:' \
                    '--header=+[csv]:str:' \
                    '--query=+[csv]:str:' \
                    '--insecure[insecure TLS]' \
                    '--output=+[file]:file:_files' \
                    '--format=+[fmt]:f:(json text raw markdown)' \
                    '*:request id or name:' ;;
                export) _arguments \
                    '--output=+[file]:file:_files -g "*.json *.yaml *.yml"' \
                    '--include-environments[include environments]' \
                    '--include-history[include history]' ;;
                import) _arguments \
                    '--format=+[f]:f:(yaak postman insomnia openapi har curl)' \
                    '*:input file:_files -g "*.json *.yaml *.yml *.har"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_yaak "$@"
