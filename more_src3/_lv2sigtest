#compdef lv2sigtest lv2_sig_test
# _lv2sigtest — Filipe Coelho LV2 lv2sigtest plugin signal-flow validator running automated NULL silence sine impulse tests across plugin inputs for regression testing (lv2 team, C); getopt
# upstream: https://gitlab.com/lv2/lv2

_lv2sigtest() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[sample rate]:n:(22050 44100 48000 88200 96000 192000)' \
        '--rate=+[sample rate]:n:(22050 44100 48000 88200 96000 192000)' \
        '-b+[block size]:n:' \
        '--block-size=+[block size]:n:' \
        '-n+[N runs]:n:' \
        '--num-runs=+[N runs]:n:' \
        '-t+[test type]:t:(null silence sine impulse noise dc dc-blocked pink white sweep)' \
        '--test=+[test type]:t:(null silence sine impulse noise dc dc-blocked pink white sweep)' \
        '-f+[frequency Hz]:n:' \
        '--frequency=+[frequency Hz]:n:' \
        '-a+[amplitude]:f:' \
        '--amplitude=+[amplitude]:f:' \
        '-o+[output wav]:file:_files -g "*.wav *.flac *.aiff"' \
        '--output=+[output wav]:file:_files -g "*.wav *.flac *.aiff"' \
        '-c[csv summary]' \
        '--csv[csv summary]' \
        '*:plugin uri:'
}

_lv2sigtest "$@"
