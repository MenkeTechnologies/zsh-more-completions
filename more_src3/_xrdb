#compdef xrdb
# Documentation: xrdb -help
# Source: X.Org xrdb — X resource database utility.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '-display+[X display]:host\:dpy:' \
    '(-all -global -screen -screens)-all[do all resources (default)]' \
    '(-all -global -screen -screens)-global[screen-independent resources]' \
    '(-all -global -screen -screens)-screen[per-screen resources for one screen]' \
    '(-all -global -screen -screens)-screens[per-screen resources for all screens]' \
    '-n[show but do not commit]' \
    '(-cpp -nocpp)-cpp+[preprocessor]:filename:_command_names -e' \
    '(-cpp -nocpp)-nocpp[do not use a preprocessor]' \
    '-E[show preprocessor command + processed input]' \
    '(-query -get)-query[query resources]' \
    '(-query -get)-get+[get content of a single resource]:name:' \
    '(-load -override -merge)-load[load resources from file (default)]' \
    '(-load -override -merge)-override[merge file into existing]' \
    '(-load -override -merge)-merge[merge resources from file and sort]' \
    '-edit+[edit resources into file]:filename:_files' \
    '-backup+[backup suffix for -edit (default .bak)]:string:' \
    '-symbols[show preprocessor symbols]' \
    '-remove[remove resources]' \
    '-retain[avoid server reset]' \
    '-quiet[suppress duplicate warnings]' \
    '*-D-[preprocessor define]:NAME[=VALUE]:' \
    '*-U-[preprocessor undefine]:NAME:' \
    '*-I-[preprocessor include directory]:dir:_files -/' \
    '*:input filename (or - for stdin):_files' \
    && ret=0

return ret
