#compdef rawtopgm
# Documentation: man rawtopgm (Netpbm)
# Source: convert raw grayscale byte data to PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-bpp+[bytes per pixel]:bytes:(1 2)' \
    '-littleendian[input is little-endian]' \
    '-maxval+[max sample value]:N:' \
    '-headerskip+[header bytes to skip]:N:' \
    '-rowskip+[bytes to skip after each row]:N:' \
    '(-tb -topbottom)'{-tb,-topbottom}'[read top-to-bottom]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    '3:image data file:_files' \
    && ret=0

return ret
