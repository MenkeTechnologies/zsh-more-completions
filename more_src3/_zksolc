#compdef zksolc
# _zksolc — Matter Labs zksolc Solidity compiler frontend producing zkSync Era LLVM-backed bytecode for zkEVM contracts with combined-json and standard-json modes (matter-labs team, Rust); clap
# upstream: https://github.com/matter-labs/era-compiler-solidity

_zksolc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--standard-json[standard JSON IO]' \
        '--combined-json=+[items]:items:(abi hashes bin metadata srcmap srcmap-runtime asm function-debug function-debug-runtime)' \
        '--yul[Yul input]' \
        '--llvm-ir[LLVM IR input]' \
        '--eravm-assembly[EraVM assembly input]' \
        '--zkasm[EraVM assembly input]' \
        '--solc=+[path]:file:_files' \
        '-O+[opt level]:l:(0 1 2 3 s z)' \
        '--optimization=+[opt level]:l:(0 1 2 3 s z)' \
        '--fallback-Oz[fallback to Oz]' \
        '--debug-output-directory=+[dir]:dir:_files -/' \
        '--llvm-options=+[opts]:str:' \
        '--llvm-verify-each[LLVM verify each]' \
        '--disable-system-request-memoization[disable system request memo]' \
        '--enable-eravm-extensions[enable EraVM extensions]' \
        '--force-evmla[force EVMLA codegen]' \
        '--allow-paths=+[paths csv]:str:' \
        '--base-path=+[path]:dir:_files -/' \
        '--include-path=+[path]:dir:_files -/' \
        '--metadata-hash=+[hash]:h:(none ipfs keccak256)' \
        '--metadata-literal[metadata literal]' \
        '--remappings=+[remappings]:str:' \
        '--libraries=+[libs]:str:' \
        '--output-dir=+[dir]:dir:_files -/' \
        '-o+[dir]:dir:_files -/' \
        '--bin[bin output]' \
        '--asm[asm output]' \
        '--bytecode[bytecode output]' \
        '--metadata[metadata output]' \
        '--overwrite[overwrite output]' \
        '--codegen=+[mode]:m:(evmla yul)' \
        '--evm-version=+[v]:v:(homestead tangerineWhistle spuriousDragon byzantium constantinople petersburg istanbul berlin london paris shanghai cancun prague osaka)' \
        '*:source file:_files -g "*.sol *.yul *.ll *.eravm *.zkasm"'
}

_zksolc "$@"
