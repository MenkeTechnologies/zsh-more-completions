#compdef toot
# Documentation: https://github.com/ihabunek/toot/tree/master/toot/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'login:log into a Mastodon instance'
      'logout:log out'
      'auth:show auth info'
      'whoami:display current user'
      'whois:display user info'
      'instance:display instance info'
      'search:search for content'
      'thread:show thread for status'
      'post:post a status'
      'upload:upload media'
      'delete:delete a status'
      'favourite:favourite a status'
      'unfavourite:unfavourite a status'
      'reblog:reblog a status'
      'unreblog:unreblog a status'
      'pin:pin a status'
      'unpin:unpin a status'
      'bookmarks:list bookmarks'
      'bookmark:bookmark a status'
      'unbookmark:unbookmark a status'
      'follow:follow an account'
      'unfollow:unfollow an account'
      'mute:mute an account'
      'unmute:unmute an account'
      'block:block an account'
      'unblock:unblock an account'
      'notifications:show notifications'
      'timeline:show timeline'
      'tui:launch TUI'
      'env:show environment info'
      'activate:activate an account'
    )
    _describe -t commands 'toot command' commands && ret=0
    ;;
  args)
    case $words[1] in
      post)
        _arguments -s -S \
          '*'{-m,--media}'=[media file]:media:_files' \
          '*'{-d,--description}'=[media description]:description' \
          '*--thumbnail=[thumbnail file]:file:_files' \
          {-v,--visibility}'=[visibility]:visibility:(public unlisted private direct)' \
          {-s,--sensitive}'[mark as sensitive]' \
          {-p,--spoiler-text}'=[spoiler text]:spoiler' \
          {-l,--language}'=[language]:language' \
          '--scheduled-at=[ISO 8601 schedule time]:time' \
          '--scheduled-in=[schedule duration]:duration' \
          {-r,--reply-to}'=[reply to status ID]:status id' \
          {-R,--reply-last}'[reply to last posted status]' \
          {-e,--editor}'=[editor]:editor' \
          {-t,--content-type}'=[MIME type]:mime' \
          '*--poll-option=[poll option]:option' \
          '--poll-expires-in=[poll duration]:duration' \
          '--poll-multiple[allow multiple poll answers]' \
          '--poll-hide-totals[hide poll totals]' \
          {-u,--using}'=[account to use]:account' \
          '--json[output as JSON]' \
          '1:text' \
          && ret=0
        ;;
      timeline)
        _arguments -s -S \
          {-i,--instance}'=[instance domain or URL]:instance' \
          {-a,--account}'=[show account timeline]:account' \
          '--list=[show list timeline]:list' \
          {-t,--tag}'=[show hashtag timeline]:tag' \
          {-p,--public}'[show public timeline]' \
          {-l,--local}'[show only local statuses]' \
          {-r,--reverse}'[reverse order]' \
          {-1,--once}'[only first count toots]' \
          {-c,--count}'=[number of posts per page]:count' \
          && ret=0
        ;;
      upload)
        _arguments -s -S \
          {-d,--description}'=[media description]:description' \
          '1:file:_files' \
          && ret=0
        ;;
      whois)
        _arguments -s -S \
          '1:account' \
          && ret=0
        ;;
      search)
        _arguments -s -S \
          '--json[output as JSON]' \
          '1:query' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
