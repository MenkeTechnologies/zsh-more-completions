#compdef xcfview
# Documentation: https://manpages.debian.org/xcfview
# Source: xcftools xcfview.in — view XCF images via mailcap-discovered viewer (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:xcf file:_files -g "*.{xcf,xcf.gz,xcf.bz2}"' \
    && ret=0

return ret
