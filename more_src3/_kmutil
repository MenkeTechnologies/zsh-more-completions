#compdef kmutil
# Documentation: https://keith.github.io/xcode-man-pages/kmutil.8.html
# Source: Apple macOS — kernel-extension management (replacement for kextcache/kextstat/kextload/kextunload on Catalina+).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a global=(
    '(-h)-h[show help]'
    '(-a --arch)'{-a+,--arch=}'[target architecture]:arch:(x86_64 arm64 arm64e)'
    '(-V --variant-suffix)'{-V+,--variant-suffix=}'[prefer variant (development / debug / kasan)]:variant:(development debug kasan release)'
    '(-z --no-authentication)'{-z,--no-authentication}'[disable staging + validation]'
    '(-v --verbose)'{-v,--verbose}'[verbose output]'
    '*'{-r,--repository=}'[extension directory]:dir:_directories'
    '(-R --volume-root)'{-R+,--volume-root=}'[target volume (default /)]:path:_directories'
    '(-B --boot-path)'{-B+,--boot-path=}'[path to boot kext collection]:path:_files'
    '(-S --system-path)'{-S+,--system-path=}'[path to system kext collection]:path:_files'
    '(-A --aux-path)'{-A+,--aux-path=}'[path to auxiliary kext collection]:path:_files'
    '(-M --allow-missing-collections)'{-M,--allow-missing-collections}'[recover if collection missing]'
    '--kdk=[KDK path for kext discovery]:path:_directories'
    '--build=[build version for collections]:build:'
)

_arguments -C -s \
    "$global[@]" \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'create:create a new kext collection'
            'inspect:inspect / display kext collection contents'
            'load:load kexts from collections (or rebuild aux dynamically)'
            'unload:unload extension(s) by -b or -p'
            'libraries:find library kexts defining needed symbols'
            'showloaded:list loaded kexts'
            'dumpstate:diagnostic state of kernelmanagerd(8)'
            'find:locate paths of kexts matching filter'
            'check:verify load info + collection consistency'
            'log:kext-management subsystem logging'
            'print-diagnostics:test kexts for build-into-collection viability'
            'clear-staging:remove kernelmanagerd staging directory'
            'migrate:software-update migration step'
            'install:update boot + system collections'
            'rebuild:rebuild auxiliary collection'
            'trigger-panic-medic:recovery: clear aux collection + approvals'
            'configure-boot:recovery: install custom boot objects'
        )
        _describe -t subcmds 'kmutil command' subcmds && ret=0
        ;;
    args)
        _arguments \
            "$global[@]" \
            '*'{-b,--bundle-id=}'[kext bundle id]:bundle id:' \
            '*'{-p,--path=}'[kext path]:path:_files' \
            && ret=0
        ;;
esac

return ret
