#       LDAP_NO_SUCH_OBJECT=32, LDAP_INVALID_CREDENTIALS=49,
#       LDAP_INSUFFICIENT_ACCESS=50, LDAP_BUSY=51,
#       LDAP_UNAVAILABLE=52, LDAP_UNWILLING_TO_PERFORM=53,
#       LDAP_LOOP_DETECT=54, LDAP_NAMING_VIOLATION=64,
