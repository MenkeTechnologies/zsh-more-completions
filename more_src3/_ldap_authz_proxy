_ldap_authz_proxy() {
    _arguments -s \
        '(- *)'{-h,--help}'[show usage screen]' \
        '(- *)'{-H,--help-config}'[show help for the configuration file format]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-b --bind)'{-b,--bind}'=[bind address (default 127.0.0.1)]:address:' \
        '(-p --port)'{-p,--port}'=[port to listen on (default 10567)]:port:' \
        '(-l --log)'{-l,--log}'=[log file]:path:_files -g "*.log"' \
        '(-j --json)'{-j,--json}'[log in structured JSON format]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '--dump-config[check configuration file, dump parsed values and exit]' \
        '(-t --test)'{-t,--test}'[test mode: query LDAP and exit with HTTP-equivalent status]' \
        '1:config file:_files -g "*.conf *.ini"' \
        '2:username (test mode):' \
        '3:URI path (test mode):'
}

_ldap_authz_proxy "$@"
