#compdef wcs-rd2xy
# Documentation: https://astrometry.net/
# Source: dstndstn/astrometry.net util/wcs-rd2xy-main.c — convert (RA,Dec) → (x,y) pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-w+[WCS input file]:file:_files -g "*.(wcs|fits|fit|fts)(-.)"' \
    '-i+[RDLS input file]:file:_files' \
    '-o+[XYlist output file]:file:_files' \
    '-f+[field index from RDLS]:n:_default' \
    '-e+[FITS HDU number]:n:_default' \
    '-t[use TAN projection only (ignore SIP)]' \
    '-r+[RA value (degrees)]:value:_default' \
    '-d+[Dec value (degrees)]:value:_default' \
    '-R+[RA column name]:name:_default' \
    '-D+[Dec column name]:name:_default' \
    '-L[force WCSlib]' \
    '-v[verbose]' \
    && ret=0

return ret
