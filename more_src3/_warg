#compdef warg
# _warg — Warg WebAssembly component registry client (bytecodealliance/registry)
# upstream: https://github.com/bytecodealliance/registry
# Subcommands + flags from src/commands.rs + src/commands/*.rs (clap).

_warg() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a common
    common=(
        '--registry=[registry URL]:url:'
        '--config=[warg client config file]:file:_files -g "*.json"'
    )

    _arguments -C $common \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_warg_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                publish)
                    _arguments '1: :_warg_publish_subs'
                    ;;
                key)
                    _arguments '1:key subcommand:(new info delete set)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_warg_commands] )) ||
_warg_commands() {
    local -a commands
    commands=(
        'config:read or update the warg client config file'
        'info:print info about the registry / a package'
        'key:manage signing keys'
        'lock:create / update a warg-lock.toml'
        'bundle:bundle a component with its deps from the registry'
        'dependencies:print resolved package dependencies'
        'download:download package contents from the registry'
        'update:fetch the latest package logs from the registry'
        'publish:publish, yank, grant, revoke (subcommands)'
        'reset:reset client state for a registry'
        'clear:clear local registry caches'
        'login:authenticate to the registry'
        'logout:remove cached registry credentials'
    )
    _describe -t commands 'warg command' commands
}

(( $+functions[_warg_publish_subs] )) ||
_warg_publish_subs() {
    local -a sub
    sub=(
        'init:initialize a new package'
        'release:release a package version'
        'yank:yank a package version'
        'grant:grant permissions for the package'
        'revoke:revoke permissions for the package'
        'start:start a new pending publish'
        'list:list records in a pending publish'
        'abort:abort a pending publish'
        'submit:submit a pending publish'
    )
    _describe -t publish-subcommands 'publish subcommand' sub
}

_warg "$@"
