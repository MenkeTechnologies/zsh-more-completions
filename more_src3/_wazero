#compdef wazero
# Documentation: https://github.com/tetratelabs/wazero/blob/main/cmd/wazero/wazero.go
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. wazero uses Go-style
# single-dash flags only (no GNU `--long` aliases).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'run:run a WebAssembly binary'
      'compile:pre-compile a WebAssembly binary'
      'version:show version'
    )
    _describe -t commands 'wazero command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      run)
        _arguments -s -S \
          '-h[show help]' \
          '-interpreter[interpret instead of compiling]' \
          '*-env[key=value env var exposed to binary]:env:' \
          '-env-inherit[inherit env vars from calling process]' \
          '*-mount[host:guest filesystem path]:mount:' \
          '-listen[open TCP socket host:port]:addr:' \
          '-timeout[abort after duration]:duration:' \
          '-hostlogging[host function log categories]:category:(proc filesystem memory poll clock random sock)' \
          '-cpuprofile[CPU profile output path]:file:_files' \
          '-memprofile[memory profile output path]:file:_files' \
          '-cachedir[directory for compiled native code]:directory:_directories' \
          '-workers[number of compilation workers]:n:' \
          '1:wasm file:_files -g "*.wasm"' \
          '*:arguments:' && ret=0
        ;;
      compile)
        _arguments -s -S \
          '-h[show help]' \
          '-count[number of compilations (benchmark)]:n:' \
          '-cpuprofile[CPU profile output path]:file:_files' \
          '-memprofile[memory profile output path]:file:_files' \
          '-cachedir[directory for compiled native code]:directory:_directories' \
          '-workers[number of compilation workers]:n:' \
          '1:wasm file:_files -g "*.wasm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
