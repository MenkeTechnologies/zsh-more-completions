#compdef kadmin-cli
# _kadmin-cli — MIT Kerberos kadmin Kerberos admin client CLI alias (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kadmin-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-r+[realm]:str:' \
        '-p+[principal]:str:' \
        '-q+[query]:str:' \
        '-c+[credentials cache]:file:_files' \
        '-k[use keytab]' \
        '-t+[keytab file]:file:_files' \
        '-s+[admin server[:port]]:str:' \
        '-w+[password]:str:' \
        '-x+[db args]:str:' \
        '-O[old auth]' \
        '-N[no auth]' \
        '*:command:'
}

_kadmin-cli "$@"
