#compdef uptime-cli
# _uptime-cli — procps uptime show how long system has been running CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_uptime-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-p[show in pretty format]' \
        '--pretty[show in pretty format]' \
        '-r[raw seconds output]' \
        '--raw[raw seconds output]' \
        '-s[show since when up]' \
        '--since[show since when up]' \
        '-c[show in container format]' \
        '--container[show in container format]' \
        '*:arg:'
}

_uptime-cli "$@"
