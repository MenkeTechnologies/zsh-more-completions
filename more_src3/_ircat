#compdef ircat
# Documentation: https://manpages.debian.org/bookworm/lirc/ircat.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ircat(1) manpage OPTIONS section.

# ircat: print configured key names triggered by IR events
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '1:program name:' && ret=0
return ret
