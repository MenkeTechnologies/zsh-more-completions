#compdef taxonkit
# Documentation: https://github.com/shenwei356/taxonkit
# Source: shenwei356/taxonkit taxonkit/cmd/ — NCBI taxonomy toolkit (Go, spf13/cobra).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _taxonkit_cmds
_taxonkit_cmds=(
    'list:list subtree of given taxids'
    'lineage:query taxonomic lineage of given taxids'
    'reformat:reformat lineage in canonical ranks'
    'reformat2:reformat lineage to arbitrary ranks'
    'name2taxid:convert taxonomy names to taxids'
    'filter:filter taxids by taxonomic rank range'
    'lca:compute lowest common ancestor for taxids'
    'taxid-changelog:create taxid change log from dump files'
    'create-taxdump:create NCBI-style taxdump for custom taxonomies'
    'profile2cami:convert metagenomic profile to CAMI format'
    'cami-filter:filter CAMI-format profile'
    'genautocomplete:generate shell autocompletion script'
    'version:print version information'
)

_arguments -C \
    '--data-dir=[directory of NCBI taxonomy dump files]:dir:_files -/' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--threads=[number of CPUs]:n:_default' \
    '--verbose[print verbose information]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'taxonkit command' _taxonkit_cmds && ret=0
        ;;
esac

return ret
