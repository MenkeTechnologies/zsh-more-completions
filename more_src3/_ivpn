#compdef ivpn
# IVPN - Command-line interface for IVPN client

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'connect:connect to VPN'
  'disconnect:disconnect from VPN'
  'status:show connection status'
  'servers:show available servers'
  'firewall:manage IVPN firewall'
  'wgkeys:manage WireGuard keys'
  'dns:manage DNS settings'
  'antitracker:manage AntiTracker'
  'logs:show logs'
  'login:log in to IVPN account'
  'logout:log out of IVPN account'
  'account:show account info'
  'wifi:manage WiFi control settings'
  'exclude:manage split tunnel exclusions'
  'splittun:manage split tunneling'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ivpn command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      connect)
        _arguments \
          '(-p --protocol)'{-p+,--protocol=}'[protocol to use]:protocol:(wireguard openvpn)' \
          '--obfsproxy[use obfsproxy for OpenVPN]' \
          '--any[connect to any available server]' \
          '--fastest[connect to fastest server]' \
          '--last[reconnect to last used server]' \
          '--gateway[server gateway to connect to]:gateway:' \
          '--city[server city to connect to]:city:' \
          '--country[server country to connect to]:country code:' \
          '--multihop-exit[multi-hop exit server]:exit server:' \
          '--dns[DNS server to use when connected]:dns:' \
          '--antitracker[enable AntiTracker]' \
          '--firewall[enable firewall on connect]' \
          '--fw[enable firewall on connect]' \
          && ret=0
        ;;
      disconnect)
        _arguments && ret=0
        ;;
      status)
        _arguments && ret=0
        ;;
      servers)
        _arguments \
          '(-p --protocol)'{-p+,--protocol=}'[filter by protocol]:protocol:(wireguard openvpn)' \
          '--country[filter by country]:country code:' \
          '--city[filter by city]:city:' \
          '--ping[show ping times]' \
          '--sort[sort servers]:sort by:(name country city ping)' \
          && ret=0
        ;;
      firewall)
        _arguments \
          '1:action:(on off status)' \
          '--persistent[make firewall persistent across reboots]' \
          '--allow-lan[allow LAN traffic when firewall is enabled]' \
          '--allow-multicast[allow multicast when firewall is enabled]' \
          && ret=0
        ;;
      dns)
        _arguments \
          '1:dns server or action:' \
          && ret=0
        ;;
      login)
        _arguments \
          '1:account ID:' \
          '--force[force login]' \
          && ret=0
        ;;
      exclude)
        _arguments \
          '1:action:(add remove list)' \
          '*:app or IP:' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
