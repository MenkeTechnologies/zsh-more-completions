#compdef transmission-create
# Documentation: https://manpages.debian.org/testing/transmission-cli/transmission-create.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --private)'{-p,--private}'[mark the torrent as private]' \
  '(-o --outfile)'{-o,--outfile}'[save the generated torrent to this file]:file:_files -g "*.torrent"' \
  '(-s --piecesize)'{-s,--piecesize}'[set the piece size in KiB]:size (KiB)' \
  '(-c --comment)'{-c,--comment}'[add a comment]:comment' \
  '*'{-t,--tracker}'[add a tracker announce URL]:URL' \
  '(-r --source)'{-r,--source}'[set source tag for private trackers]:source' \
  '--anonymize[omit created-by and created-date keys]' \
  '(-V --version)'{-V,--version}'[show version number]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:file or directory:_files' && ret=0

return ret
