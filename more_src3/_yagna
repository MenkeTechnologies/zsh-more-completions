#compdef yagna
# _yagna — Golem Network yagna daemon for the decentralized computation marketplace (golemfactory team, Rust); clap-derive
# upstream: https://github.com/golemfactory/yagna

_yagna() {
    local -a sub=(
        'service:service subcommands'
        'id:identity subcommands'
        'app-key:app key subcommands'
        'payment:payment subcommands'
        'me:show daemon info'
        'net:net subcommands'
        'settings:settings subcommands'
        'status:show daemon status'
        'version:version subcommands'
        'complete:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--accept-terms[accept terms]' \
        '--json[json output]' \
        '-j[json output]' \
        '--datadir=+[data dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '--api-url=+[REST URL]:url:_urls' \
        '--gsb-url=+[GSB URL]:url:_urls' \
        '--app-key=+[app key]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yagna subcommand' sub ;;
        args)
            case $words[1] in
                service) _arguments '1:service cmd:(run shutdown status)' ;;
                id) _arguments '1:id cmd:(create drop list lock unlock update show export)' ;;
                app-key) _arguments '1:app-key cmd:(create drop list show)' ;;
                payment) _arguments '1:payment cmd:(accounts driver-list fund init invoice release-allocations status)' ;;
                net) _arguments '1:net cmd:(connect disconnect status ping find session sessions block unblock)' ;;
                settings) _arguments '1:settings cmd:(show set get)' ;;
                version) _arguments '1:version cmd:(show check release upgrade)' ;;
                complete) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_yagna "$@"
