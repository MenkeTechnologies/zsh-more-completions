#compdef sparse
# Documentation: https://manpages.debian.org/testing/sparse/sparse.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian sparse(1) manpage. Accepts gcc-style preprocessor
# (-D, -U, -I, -nostdinc), sparse warnings (-Wsparse-all,
# -Wsparse-error, -Waddress-space, ...) and -f options
# (-fmem-report, -ftabstop, -fmax-errors, -fmax-warnings,
# -fdiagnostic-prefix). --arch=ARCH and --os=OS use the long form.
# Trimmed: -m32/-m64 are not in the documented sparse option list;
# kept only documented flags.

# Zsh completion for sparse (Linux kernel semantic checker for C)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-W+[enable warning]:warning:(
    address-space bitwise bitwise-pointer cast-from-as cast-to-as
    cast-truncate constant-suffix constexpr-not-const context
    decl declaration-after-statement default-bitfield-sign
    designated-init do-while enum-mismatch
    external-function-has-definition flexible-array-array
    flexible-array-nested flexible-array-sizeof flexible-array-union
    init-cstring memcpy-max-count newline-eof non-pointer-null
    old-initializer one-bit-signed-bitfield paren-string
    past-deep-designator pointer-arith ptr-subtraction-blows
    return-void shadow shift-count-negative shift-count-overflow
    sizeof-bool sparse-all sparse-error transparent-union typesign
    undef universal-initializer union-cast
  )' \
  '-Wno-+[disable warning]:warning' \
  '*-D+[define preprocessor macro]:macro definition' \
  '*-U+[undefine preprocessor macro]:macro name' \
  '*-I+[add include path]:directory:_files -/' \
  '--arch=[target architecture]:architecture:' \
  '--os=[target operating system]:os:' \
  '-gcc-base-dir[GCC base directory]:directory:_files -/' \
  '-multiarch-dir[multiarch directory name]:directory' \
  '-fmem-report[report memory usage]' \
  '-ftabstop=[set tab stop width]:size' \
  '-fmax-errors=[limit displayed errors]:count' \
  '-fmax-warnings=[limit displayed warnings]:count' \
  '-fmemcpy-max-count=[set memcpy warning limit]:count' \
  '-fdiagnostic-prefix=[prefix diagnostics]:prefix' \
  '-Wsparse-all[enable all sparse warnings]' \
  '-Wsparse-error[treat sparse warnings as errors]' \
  '*:C source file:_files -g "*.c(N)"' && ret=0

return ret
