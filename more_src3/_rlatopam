#compdef rlatopam
# Documentation: man rlatopam (Netpbm)
# Source: convert a Wavefront RLA image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:rla file:_files -g "*.rla"' \
    && ret=0

return ret
