#compdef jubaanomaly jubaclassifier jubagraph jubarecommender jubaregression jubastat
# Documentation: https://github.com/jubatus/jubatus/blob/master/man/en/jubatus_server.8
# Reference accessed: 2026-05-19
# Verified: upstream jubatus_server(8) man page at the URL above.

typeset -A opt_args
local context state line

_arguments -s -S \
    "(-\? --help)"{-\?,--help}"[print the brief usage of the command]" \
    "(-v --version)"{-v,--version}"[print the version of Jubatus server]" \
    "(-p --rpc-port)"{-p,--rpc-port}"[port number to listen for RPC requests \[9199\]]:port:" \
    "(-b --listen_addr)"{-b,--listen_addr}"[IPv4 address to listen for RPC requests]:ipaddr:" \
    "(-B --listen_if)"{-B,--listen_if}"[network interface to listen for RPC requests]:interface:" \
    "(-c --thread)"{-c,--thread}"[number of threads to accept RPC connection \[2\]]:number:" \
    "(-t --timeout)"{-t,--timeout}"[session timeout of RPC in seconds \[10\]]:timeout:" \
    "(-d --datadir)"{-d,--datadir}"[directory to save and load training models \[/tmp\]]:directory:_directories" \
    "(-l --logdir)"{-l,--logdir}"[directory to output ZooKeeper log files]:directory:_directories" \
    "(-g --log_config)"{-g,--log_config}"[path of log4cxx (XML) logging configuration file]:file:_files" \
    "(-f --configpath)"{-f,--configpath}"[path of the server configuration file]:file:_files" \
    "(-m --model_file)"{-m,--model_file}"[path of the model file to load at startup]:file:_files" \
    "(-D --daemon)"{-D,--daemon}"[launch in daemon mode (detach from console)]" \
    "(-T --config_test)"{-T,--config_test}"[validate the configuration file and exit]" \
    "(-z --zookeeper)"{-z,--zookeeper}"[list of ZooKeeper server(s)]:zookeeper list:" \
    "(-n --name)"{-n,--name}"[instance name to uniquely identify a task in the ZK cluster]:name:" \
    "(-x --mixer)"{-x,--mixer}"[MIX strategy used when choosing MIX node \[linear_mixer\]]:mixer:" \
    "(-s --interval_sec)"{-s,--interval_sec}"[invoke mix in every <seconds> second \[16\]]:seconds:" \
    "(-i --interval_count)"{-i,--interval_count}"[invoke mix in every <count> updates \[512\]]:count:" \
    "(-Z --zookeeper_timeout)"{-Z,--zookeeper_timeout}"[session timeout between ZooKeeper and server in seconds \[10\]]:seconds:" \
    "(-I --interconnect_timeout)"{-I,--interconnect_timeout}"[timeout of RPC between Jubatus servers in seconds \[10\]]:seconds:" \
    "*::args:_gnu_generic"
