#compdef z80asm z80nm z80dasm
# Documentation: https://manpages.debian.org/bookworm/z80asm/z80asm.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm z80asm(1) manpage.

local curcontext="$curcontext" state line ret=1

case $service in
  (z80asm)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '*'{-v,--verbose}'[verbose (repeatable)]' \
      '(-l --list)'{-l-,--list=-}'[generate list file]:file:_files' \
      '(-L --label)'{-L-,--label=-}'[generate label file]:file:_files' \
      '(-p --label-prefix)'{-p+,--label-prefix=}'[prefix all labels]:prefix:' \
      '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
      '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
      '*'{-I+,--includepath=}'[include path]:dir:_files -/' \
      '(-f --force)'{-f,--force}'[produce output even on errors]' \
      '*: :_files -g "*.asm *.z80 *.s"' && ret=0 ;;
  (z80nm)
    _arguments -C \
      '-h[help]' \
      '-V[version]' \
      '-l[print list]' \
      '*: :_files -g "*.o *.lib"' && ret=0 ;;
  (z80dasm)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '(-a --address)'{-a+,--address=}'[start address hex]:n:' \
      '(-l --length)'{-l+,--length=}'[length]:n:' \
      '(-o --offset)'{-o+,--offset=}'[file offset]:n:' \
      '(-S --sym-output)'{-S+,--sym-output=}'[symbol output]:file:_files' \
      '(-s --sym-input)'{-s+,--sym-input=}'[symbol input]:file:_files' \
      '(-t --sym-output)'{-t,--sym-output}'[symbol output]' \
      '(-g --origin)'{-g+,--origin=}'[origin]:n:' \
      '(-O --output-name)'{-O+,--output-name=}'[output]:file:_files' \
      '*: :_files -g "*.bin *.rom *.com"' && ret=0 ;;
esac

return ret
