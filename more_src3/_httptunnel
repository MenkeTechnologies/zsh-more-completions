#compdef htc hts
# Documentation: https://www.gnu.org/software/httptunnel/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# GNU httptunnel - htc (client) and hts (server).

local curcontext="$curcontext" state line ret=1

case $service in
  (htc)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-c --content-length)'{-c+,--content-length=}'[HTTP PUT request size in bytes]:bytes:' \
      '(-d --device)'{-d+,--device=}'[device for I/O]:device:_files' \
      '(-F --forward-port)'{-F+,--forward-port=}'[TCP port for I/O]:port:' \
      '(-k --keep-alive)'{-k+,--keep-alive=}'[keepalive interval in seconds]:seconds:' \
      '(-M --max-connection-age)'{-M+,--max-connection-age=}'[max connection age in seconds]:seconds:' \
      '(-S --strict-content-length)'{-S,--strict-content-length}'[always write Content-Length bytes]' \
      '(-A --proxy-authorization)'{-A+,--proxy-authorization=}'[proxy auth user:password]:user\:password:' \
      '(-z --proxy-authorization-file)'{-z+,--proxy-authorization-file=}'[load proxy credentials from file]:file:_files' \
      '(-B --proxy-buffer-size)'{-B+,--proxy-buffer-size=}'[proxy buffer size in bytes]:bytes:' \
      '(-P --proxy)'{-P+,--proxy=}'[HTTP proxy hostname[:port]]:proxy:' \
      '(-T --timeout)'{-T+,--timeout=}'[timeout in ms before sending padding]:ms:' \
      '(-U --user-agent)'{-U+,--user-agent=}'[User-Agent string]:string:' \
      '(-w --no-daemon)'{-w,--no-daemon}'[prevent background fork]' \
      '*:host\:port:' && ret=0
    ;;
  (hts)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '(-c --content-length)'{-c+,--content-length=}'[HTTP PUT request size in bytes]:bytes:' \
      '(-d --device)'{-d+,--device=}'[device for I/O]:device:_files' \
      '(-F --forward-port)'{-F+,--forward-port=}'[forward to host:port]:host\:port:' \
      '(-k --keep-alive)'{-k+,--keep-alive=}'[keepalive interval in seconds]:seconds:' \
      '(-M --max-connection-age)'{-M+,--max-connection-age=}'[max connection age in seconds]:seconds:' \
      '(-S --strict-content-length)'{-S,--strict-content-length}'[always write Content-Length bytes]' \
      '(-s --stdin-stdout)'{-s,--stdin-stdout}'[use stdin/stdout (disables daemon)]' \
      '(-w --no-daemon)'{-w,--no-daemon}'[prevent background fork]' \
      '(-p --pid-file)'{-p+,--pid-file=}'[pid file location]:file:_files' \
      '(-C --chroot)'{-C+,--chroot=}'[chroot location]:dir:_files -/' \
      '(-u --user)'{-u+,--user=}'[switch user before serving]:user:_users' \
      '*:port:' && ret=0
    ;;
esac

return ret
