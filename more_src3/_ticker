#compdef ticker
# Documentation: https://github.com/achannarasappa/ticker
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config=[config file location with watchlist and positions]:config:_files -g "*.{yml,yaml}(-.)"' \
  '(-w --watchlist)'{-w,--watchlist}'=[comma-separated list of symbols to watch]:symbols:' \
  '(-i --interval)'{-i,--interval}'=[refresh interval in seconds (default 5)]:seconds:' \
  '--show-tags[display currency, exchange name, and quote delay]' \
  '--show-fundamentals[display open price, previous close, and day range]' \
  '--show-separator[layout with separators between each quote]' \
  '--show-summary[show total day change, total value, and value change]' \
  '--show-positions[show positions with weight, average cost, quantity]' \
  '--sort=[sort order]:order:(alpha value user change)' \
  '--debug[enable debug logging]' \
  '--version[print current version number]' \
  '1::subcommand:(print)' && ret=0

return ret
