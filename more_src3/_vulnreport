#compdef vulnreport
# _vulnreport — vulnreport vulnerability report tracker (Salesforce engineering, Ruby on Rails); manage pentest findings + reports
# upstream: https://github.com/salesforce/vulnreport

_vulnreport() {
    local -a sub=(
        'server:run web server'
        'console:rails console'
        'db:db tasks'
        'migrate:run migrations'
        'seed:seed db'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vulnreport subcommand' sub ;;
    esac
}

_vulnreport "$@"
