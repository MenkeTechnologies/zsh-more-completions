#compdef tcpkill
# Documentation: man tcpkill(8)
# Source: hackerschoice/dsniff tcpkill.c (master) — kill TCP connections via RST injection (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[network interface]:interface:_net_interfaces' \
    '-1[severity 1 (one RST per packet)]' \
    '-2[severity 2]' \
    '-3[severity 3]' \
    '-4[severity 4]' \
    '-5[severity 5]' \
    '-6[severity 6]' \
    '-7[severity 7]' \
    '-8[severity 8]' \
    '-9[severity 9 (most aggressive)]' \
    '-V[show version]' \
    '(-h -?)'{-h,-\\?}'[show help]' \
    '*:pcap expression:_default' \
    && ret=0

return ret
