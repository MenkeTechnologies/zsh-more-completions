#compdef vacuumlo
# Documentation: vacuumlo --help (PostgreSQL)
# Source: remove unreferenced large objects from PostgreSQL databases.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-l+,--limit=}'[commit after removing each LIMIT LOs]:n:' \
    {-n,--dry-run}'[do not remove, just show]' \
    {-v,--verbose}'[verbose progress messages]' \
    {-h+,--host=}'[server host/socket]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_ports' \
    {-U+,--username=}'[user name]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    '*:dbname:' \
    && ret=0

return ret
