#compdef socialite-cli
# _socialite-cli — Laravel Socialite OAuth provider auth CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/socialite

_socialite-cli() {
    local -a sub=(
        'socialite:install:install socialite'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'socialite subcommand' sub ;;
        args)
            case $words[1] in
                socialite:install) _arguments \
                    '--provider=+[provider]:p:(google github facebook twitter linkedin bitbucket gitlab discord apple slack microsoft)' ;;
            esac
            ;;
    esac
}

_socialite-cli "$@"
