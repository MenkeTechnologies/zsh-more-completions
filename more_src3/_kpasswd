#compdef kpasswd
# Documentation: https://web.mit.edu/kerberos/krb5-latest/doc/user/user_commands/kpasswd.html
# Reference accessed: 2026-05-19
# Verified: MIT krb5 kpasswd(1) docs + local Heimdal kpasswd(1) man page.

# MIT kpasswd takes only [principal]. Heimdal kpasswd adds
# --admin-principal= and -c/--cache=. Removed invented MIT flags
# (-?, --usage, --admin-server) not present in either source.
local -a arguments

arguments=(
    '--help[display help]'
    '(-c --cache)'{-c+,--cache=}'[use the named credential cache]:cache:_files'
    '--admin-principal=[administrator principal used to change the password]:principal:'
    '*:principal:'
)

_arguments -s -S $arguments
