#compdef hass-cli
# Documentation: https://github.com/home-assistant-ecosystem/home-assistant-cli
# Reference accessed: 2026-05-27
# Verified: upstream homeassistant_cli/cli.py global click options and the
# plugin files area.py, config.py, device.py, entity.py, event.py, service.py,
# state.py, system.py, template.py. Subcommand list matches the plugins/
# directory contents.

local curcontext="$curcontext" state line ret=1

local -a _hass_subcommands
_hass_subcommands=(
  'area:manage Home Assistant areas'
  'config:retrieve configuration'
  'device:operate on registered devices'
  'discover:find Home Assistant instances on the local network'
  'entity:get and manage entities'
  'event:fire and watch events'
  'ha:Home Assistant OS operations'
  'info:CLI information'
  'integration:manage integrations / config entries'
  'map:display locations on a map'
  'raw:call the raw Home Assistant API'
  'service:list and call services'
  'state:query and modify entity states'
  'system:system log and health'
  'template:render Jinja2 templates'
  'completion:generate shell completion'
)

_arguments -s -S -C \
  '(- *)--version[show version and exit]' \
  '(-l --loglevel)'{-l+,--loglevel=}'[logging level]:level:(CRITICAL ERROR WARNING INFO DEBUG)' \
  '(-s --server)'{-s+,--server=}'[Home Assistant server URL]:url:' \
  '--token=[bearer token]:token:' \
  '--supervisor-token=[supervisor bearer token]:token:' \
  '--password=[API password]:password:' \
  '--timeout=[network timeout in seconds]:seconds:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml table auto ndjson)' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-x)-x[show exception backtraces]' \
  '--cert=[client certificate (.pem)]:file:_files -g "*.pem"' \
  '--insecure[disable SSL certificate verification]' \
  '--debug[enable debug mode]' \
  '--columns=[customize displayed columns (key=value pairs)]:cols:' \
  '--no-headers[suppress table headers]' \
  '--table-format=[table format style]:fmt:(plain simple github grid fancy_grid pipe orgtbl jira presto pretty psql rst mediawiki moinmoin youtrack html latex latex_raw latex_booktabs textile)' \
  '--sort-by=[sort by JSONPath expression]:path:' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'hass-cli subcommand' _hass_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      area)
        local -a _area_sub
        _area_sub=(
          'list:list all areas (optional regex filter)'
          'create:create one or more areas'
          'delete:delete an area (supports --confirm)'
          'rename:rename an area'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'area subcommand' _area_sub && ret=0 ;;
          rest)
            case $line[1] in
              delete) _arguments '--confirm[skip confirmation prompt]' '*:area:' && ret=0 ;;
              *) _message 'area arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      config)
        local -a _config_sub
        _config_sub=(
          'full:get full configuration'
          'integrations:list loaded integrations'
          'whitelist_dirs:list whitelisted directories'
          'release:print Home Assistant release version'
        )
        _describe -t commands 'config subcommand' _config_sub && ret=0
        ;;
      device)
        local -a _device_sub
        _device_sub=(
          'list:list all devices (optional regex filter)'
          'assign:assign devices to an area'
          'rename:rename a device'
          'list-by-area:list devices in an area'
          'delete:delete a device'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'device subcommand' _device_sub && ret=0 ;;
          rest)
            case $line[1] in
              assign) _arguments '--match=[regex pattern for matching device names]:pattern:' '*:device:' && ret=0 ;;
              delete) _arguments '--confirm[skip confirmation prompt]' '*:device:' && ret=0 ;;
              *) _message 'device arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      entity)
        local -a _entity_sub
        _entity_sub=(
          'list:list entities (optional regex filter)'
          'assign:assign entities to an area'
          'rename:rename an entity'
          'delete:delete an entity'
          'enable:enable a disabled entity'
          'disable:disable an entity'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'entity subcommand' _entity_sub && ret=0 ;;
          rest)
            case $line[1] in
              assign) _arguments '--match=[regex pattern for matching entity names]:pattern:' '*:entity:' && ret=0 ;;
              rename) _arguments '--name=[new display name]:name:' '*:entity:' && ret=0 ;;
              delete) _arguments '--confirm[skip confirmation prompt]' '*:entity:' && ret=0 ;;
              *) _message 'entity arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      event)
        local -a _event_sub
        _event_sub=(
          'fire:fire an event'
          'watch:subscribe to events (optional event_type filter)'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'event subcommand' _event_sub && ret=0 ;;
          rest)
            case $line[1] in
              fire) _arguments '--json=[raw JSON event data]:json:' '*:event:' && ret=0 ;;
              *) _message 'event arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      service)
        local -a _service_sub
        _service_sub=(
          'list:list services (optional regex filter)'
          'call:call a service (format: domain.service)'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'service subcommand' _service_sub && ret=0 ;;
          rest)
            case $line[1] in
              call) _arguments '--arguments=[comma-separated key=value pairs]:args:' '*:service:' && ret=0 ;;
              *) _message 'service arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      state)
        local -a _state_sub
        _state_sub=(
          'get:get an entity state'
          'delete:delete an entity state'
          'list:list entity states (optional regex filter)'
          'edit:set state and attributes for an entity'
          'toggle:toggle one or more entities'
          'turn_off:turn off one or more entities'
          'turn_on:turn on one or more entities'
          'history:get history for entities'
        )
        _arguments -C \
          '1: :->sub' \
          '*:: :->rest' && ret=0
        case $state in
          sub) _describe -t commands 'state subcommand' _state_sub && ret=0 ;;
          rest)
            case $line[1] in
              edit)
                _arguments \
                  '--attributes=[comma-separated key/value attributes]:attrs:' \
                  '--json=[raw JSON state]:json:' \
                  '--merge[merge with existing state instead of overwriting]' \
                  '*:entity:' && ret=0
                ;;
              history)
                _arguments \
                  '--since=[start of period (timestamp or relative)]:since:' \
                  '--end=[end of period (timestamp or relative)]:end:' \
                  '*:entity:' && ret=0
                ;;
              *) _message 'state arguments' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      system)
        local -a _system_sub
        _system_sub=(
          'log:get error log from Home Assistant'
          'health:get system health'
        )
        _describe -t commands 'system subcommand' _system_sub && ret=0
        ;;
      template)
        _arguments \
          '--local[render template locally instead of on the server]' \
          '1:template:_files' \
          '2:datafile:_files' && ret=0
        ;;
      info|discover|ha|integration|map|raw|completion)
        _message "${line[1]} arguments" && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
