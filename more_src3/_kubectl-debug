#compdef kubectl-debug
# Documentation: https://github.com/aylei/kubectl-debug/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-debug (aylei): launch a debug container in a running pod.
# Positional argument is the target pod name.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--image=[debug container image]:image:' \
  '--container=[target container within the pod]:container:' \
  '--fork[create a forked copy of the pod for debugging]' \
  '--fork-pod-retain-labels=[comma-separated labels to retain on forked pods]:labels:' \
  '--port-forward[enable port-forwarding mode]' \
  '--agentless[run in agentless mode]' \
  '(-a --agent-port)'{-a+,--agent-port=}'[debug agent listening port]:port:' \
  '--daemonset-ns=[namespace of debug-agent daemonset]:namespace:' \
  '--daemonset-name=[name of debug-agent daemonset]:name:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--registry-secret-name=[secret for private registries]:name:' \
  '--registry-secret-namespace=[namespace containing registry secret]:namespace:' \
  '--agent-pod-cpu-requests=[CPU requests for agent pod]:cpu:' \
  '--agent-pod-cpu-limits=[CPU limits for agent pod]:cpu:' \
  '--agent-pod-memory-requests=[memory requests for agent pod]:mem:' \
  '--agent-pod-memory-limits=[memory limits for agent pod]:mem:' \
  '1:pod name:' && ret=0

return ret
