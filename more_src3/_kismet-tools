#compdef kismetdb_dump_devices kismetdb_dump_packets kismetdb_to_kml kismetdb_to_pcap kismetdb_to_pcapng kismetdb_to_wigle
# _kismet-tools — Kismet conversion utilities (modern Kismet ships a family of kismetdb_* helpers that read SQLite-backed .kismet logs and emit JSON device dumps, raw pcap captures, KML overlays, WiGLE CSV uploads; --in input.kismet, --out output, --skip-clean skip vacuum, --skip-compression, --verbose, --help)
# upstream: https://github.com/kismetwireless/kismet (tools)
# Flags from kismet kismetdb_* utilities on tip.

_kismet-tools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--in+[input .kismet file]:file:_files -g "*.kismet"' \
        '--out+[output file]:file:_files' \
        '--skip-clean[skip vacuum]' \
        '--skip-compression[skip compression]' \
        '--verbose[verbose]'
}

_kismet-tools "$@"
