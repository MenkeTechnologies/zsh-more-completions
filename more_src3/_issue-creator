#compdef issue-creator
# _issue-creator — create GitHub issues from various sources (kubernetes/test-infra)
# upstream: https://github.com/kubernetes/test-infra
# Flags from robots/issue-creator/creator/creator.go (flag).

_issue-creator() {
    _arguments \
        '-test-owners-csv=[CSV file containing test-owners spreadsheet]:file:_files -g "*.csv"' \
        '-maxSIGs=[max number of SIG labels per issue]:n:' \
        '-maxAssignees=[max number of users to assign per issue]:n:' \
        '-token-file=[GitHub authentication token file]:file:_files' \
        '-project=[GitHub repo to create issues in]:repo:' \
        '-org=[GitHub org owning the repo]:org:' \
        '-dry-run=[dry run (read only)]:val:(true false)'
}

_issue-creator "$@"
