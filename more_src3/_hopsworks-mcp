#compdef hopsworks-mcp
# Documentation: https://github.com/logicalclocks/hopsworks
# Reference accessed: 2026-05-23
# Verified: hopsworks/mcp/run_server.py Click options (hopsworks PyPI).

# Zsh completion for hopsworks-mcp - Hopsworks MCP server

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--host[host to bind]:host:' \
  '--port[port to listen on]:port:' \
  '--transport[transport method]:(stdio http sse streamable-http)' \
  '--create_session[create Hopsworks session]' \
  '--hopsworks_host[Hopsworks host URL]:url:' \
  '--hopsworks_port[Hopsworks port]:port:' \
  '--project[default project name]:project:' \
  '--api_key_value[API key value]:key:' \
  '--api_key_file[API key file path]:file:_files' \
  '--hostname_verification[enable hostname verification]' \
  '--trust_store_path[trust store path]:file:_files' \
  '--engine[Hopsworks engine]:(spark python training spark-no-metastore spark-delta)' && ret=0

return ret
