#compdef wl-gammarelay-rs
# Documentation: https://github.com/MaxVerevkin/wl-gammarelay-rs
# Reference accessed: 2026-05-21
# Verified: clap Cli struct in upstream src/main.rs (subcommands Run, Watch).

# Zsh completion for wl-gammarelay-rs (Wayland gamma/brightness DBus daemon)

local curcontext="$curcontext" state line ret=1
local -a subcommands=(
  'run:run the server (default if no subcommand)'
  'watch:watch property updates with format string'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t subcommands 'wl-gammarelay-rs subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (watch)
        _arguments -s -S \
          '1:format (placeholders: {t} {b} {bp} {g}):' && ret=0 ;;
    esac
    ;;
esac

return ret
