#compdef wat2wasm
# Documentation: https://github.com/WebAssembly/wabt (src/tools/wat2wasm.cc, include/wabt/feature.def)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)*'{-v,--verbose}'[use multiple times for more info]' \
  '(-d --dump-module)'{-d,--dump-module}'[print a hexdump of the module to stdout]' \
  '(-o --output)'{-o+,--output=}'[output wasm binary file]:file:_files' \
  '(-r --relocatable)'{-r,--relocatable}'[create a relocatable wasm binary]' \
  '--no-canonicalize-leb128s[write LEB128 sizes as 5-bytes instead of minimal]' \
  '--debug-names[write debug names to the generated binary]' \
  '--no-check[do not check for invalid modules]' \
  '--enable-exceptions[enable exceptions feature]' \
  '--enable-mutable-globals[enable mutable globals feature]' \
  '--enable-saturating-float-to-int[enable saturating float-to-int feature]' \
  '--enable-sign-extension[enable sign extension feature]' \
  '--enable-simd[enable SIMD feature]' \
  '--enable-threads[enable threads feature]' \
  '--enable-function-references[enable function references feature]' \
  '--enable-multi-value[enable multi-value feature]' \
  '--enable-tail-call[enable tail call feature]' \
  '--enable-bulk-memory[enable bulk memory feature]' \
  '--enable-reference-types[enable reference types feature]' \
  '--enable-annotations[enable annotations feature]' \
  '--enable-code-metadata[enable code metadata feature]' \
  '--enable-gc[enable GC feature]' \
  '--enable-memory64[enable memory64 feature]' \
  '--enable-multi-memory[enable multi-memory feature]' \
  '--enable-extended-const[enable extended const feature]' \
  '--enable-relaxed-simd[enable relaxed SIMD feature]' \
  '--enable-custom-page-sizes[enable custom page sizes feature]' \
  '--enable-compact-imports[enable compact imports feature]' \
  '--enable-wide-arithmetic[enable wide arithmetic feature]' \
  '--enable-all[enable all features]' \
  '1:wat file:_files -g "*.wat"'
