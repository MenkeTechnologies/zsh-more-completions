#compdef tcpcong tcpcong-bpfcc
# _tcpcong — TCP socket congestion-control state distribution (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/tcpcong.py (argparse).

_tcpcong() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-L --localport)'{-L+,--localport=}'[only this local port]:port:'
        '(-R --remoteport)'{-R+,--remoteport=}'[only this remote port]:port:'
        '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]'
        '(-d --dist)'{-d,--dist}'[show distribution per state]'
        '(-u --microseconds)'{-u,--microseconds}'[output in microseconds]'
        '1:interval (seconds):'
        '2:output count:'
    )
    _arguments $args
}

_tcpcong "$@"
