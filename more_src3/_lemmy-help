#compdef lemmy-help
# Documentation: https://github.com/numToStr/lemmy-help
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lemmy-help - emmylua → vimdoc markdown generator.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-M --no-modeline)'{-M,--no-modeline}'[omit modeline at end of document]' \
  '(-f --prefix-func)'{-f,--prefix-func}'[prefix function names with module name]' \
  '(-a --prefix-alias)'{-a,--prefix-alias}'[prefix alias tags]' \
  '(-c --prefix-class)'{-c,--prefix-class}'[prefix class tags]' \
  '(-t --prefix-type)'{-t,--prefix-type}'[prefix type tags]' \
  '--expand-opt[expand optional notation to explicit nil typing]' \
  '(-i --indent)'{-i,--indent}'=[indentation width]:width:' \
  '(-l --layout)'{-l,--layout}'=[vimdoc formatting style]:layout:(default compact mini)' \
  '*:Lua file:_files -g "*.lua"' && ret=0

return ret
