#compdef tink-controller-v1alpha2
# _tink-controller-v1alpha2 — Tinkerbell v1alpha2 Tink controller (next-gen Hardware/Template/Workflow CR reconciler)
# upstream: https://github.com/tinkerbell/tink
# Flags from cmd/tink-controller-v1alpha2/main.go Config.AddFlags on tip + controller-runtime + viper env binding.

_tink-controller-v1alpha2() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubernetes=[Kubernetes API URL]:url:_urls' \
        '--kubeconfig=[absolute path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--enable-leader-election[enable leader election]' \
        '-v[klog verbosity level]:n:'
}

_tink-controller-v1alpha2 "$@"
