#compdef sc-im
# Documentation: https://raw.githubusercontent.com/andmarti1424/sc-im/master/src/sc-im.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--help[show help]' \
  '--version[show version and compiled features]' \
  '--sheet=[sheet name or number to open]:sheet' \
  '--nocurses[run without ncurses interface]' \
  '--output=[save results to file]:file:_files' \
  '--quit_afterload[exit after loading files]' \
  '--quiet[suppress messages]' \
  '--autocalc[enable automatic recalculation]' \
  '--numeric[treat digits as numeric values]' \
  '--half_page_scroll[scroll half page with Ctrl+F/B]' \
  '--newline_action=[cursor movement after entry]:action:(j l)' \
  '--external_functions[enable external functions]' \
  '--xlsx_readformulas[import formulas from xlsx]' \
  '*:file:_files -g "*.{sc,csv,tsv,xls,xlsx,ods,tab,txt}"'
