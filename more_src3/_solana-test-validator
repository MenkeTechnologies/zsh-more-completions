#compdef solana-test-validator
# _solana-test-validator — Solana Labs solana-test-validator local single-node Solana cluster for development with mainnet program clone airdrop and faucet (solana-labs team, Rust); clap
# upstream: https://github.com/solana-labs/solana

_solana-test-validator() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[reset ledger]' \
        '--reset[reset ledger]' \
        '--ledger=+[dir]:dir:_files -/' \
        '--accounts=+[dir]:dir:_files -/' \
        '--rpc-port=+[port]:n:' \
        '--rpc-bind-address=+[addr]:str:' \
        '--gossip-port=+[port]:n:' \
        '--gossip-host=+[host]:h:_hosts' \
        '--mint=+[pubkey]:str:' \
        '--faucet-port=+[port]:n:' \
        '--faucet-sol=+[sol]:n:' \
        '--bind-address=+[addr]:str:' \
        '--bpf-program=+[address bpf-program.so]:str:' \
        '--upgradeable-program=+[address bpf-program.so authority]:str:' \
        '--clone=+[pubkey]:str:' \
        '--clone-upgradeable-program=+[pubkey]:str:' \
        '--clone-feature-set[clone feature set]' \
        '--maybe-clone=+[pubkey]:str:' \
        '--warp-slot=+[slot]:n:' \
        '--slots-per-epoch=+[N]:n:' \
        '--ticks-per-slot=+[N]:n:' \
        '--url=+[url]:str:' \
        '-u+[url]:str:' \
        '--limit-ledger-size=+[N shreds]:n:' \
        '--no-bpf-jit[no BPF JIT]' \
        '--deactivate-feature=+[pubkey]:str:' \
        '--compute-unit-limit=+[CU]:n:' \
        '--transaction-account-lock-limit=+[N]:n:' \
        '--log[verbose logging]' \
        '--account=+[pubkey file.json]:str:' \
        '--account-dir=+[dir]:dir:_files -/' \
        '--ticks-per-slot=+[N]:n:' \
        '--no-snapshot-fetch[no snapshot fetch]'
}

_solana-test-validator "$@"
