#compdef wasmtime-cli
# Documentation: https://github.com/bytecodealliance/wasmtime (src/bin/wasmtime.rs)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: primary wasmtime completion lives in _wasmtime. This handles the
# legacy wasmtime-cli binary name (shares the same flags).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:Run a WebAssembly module'
  'compile:Compile a WebAssembly module ahead-of-time'
  'serve:Run a WebAssembly component via HTTP'
  'config:Manage Wasmtime configuration'
  'explore:Generate HTML visualization of compilation'
  'wast:Run a WAST script'
  'objdump:Dump compiled .cwasm contents'
  'settings:Show Cranelift settings'
  'completion:Generate shell completion'
  'hot-blocks:Profile hot blocks (Linux only)'
  'wizer:Pre-initialize a WebAssembly module'
  'help:Show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wasmtime command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--invoke=[function]:fn' \
          '--allow-precompiled[allow precompiled]' \
          '*--dir=[mapped dir]:d:_directories' \
          '*--env=[env var]:e' \
          '*-S+[WASI option]:s' \
          '*-W+[Wasm option]:w' \
          '*-O+[optimization option]:o' \
          '*-D+[debug option]:d' \
          '*-C+[codegen option]:c' \
          '--profile=[profile]:p:(perfmap jitdump vtune)' \
          '--allow-unknown-exports[allow unknown exports]' \
          '--module-name=[module name]:n' \
          '*--preload=[preload module]:m' \
          '*: :_files -g "*.(wasm|wat|cwasm)"' && ret=0 ;;
      (compile)
        _arguments \
          '-o+[output]:file:_files' \
          '--target=[target triple]:t' \
          '*: :_files -g "*.(wasm|wat)"' && ret=0 ;;
      (serve)
        _arguments \
          '--addr=[address]:addr' \
          '*--env=[env]:e' \
          '*--dir=[dir]:m:_directories' \
          '*: :_files -g "*.(wasm|wat|cwasm)"' && ret=0 ;;
      (objdump)
        _arguments \
          '--all[all]' \
          '--dwarf-dump[dwarf dump]' \
          '*: :_files' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(new)' \
          '*: :_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
