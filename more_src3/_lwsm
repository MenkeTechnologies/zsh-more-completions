#compdef lwsm
# Documentation: man lwsm(8)
# Source: josephholsten/pbis lwsm/client/main.c (master) — BeyondTrust Likewise service manager (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'list:list all known services and their status'
    'autostart:start all autostart services'
    'start-only:start a service (no deps)'
    'start:start a service and all dependencies'
    'stop-only:stop a service (no deps)'
    'stop:stop a service and all running dependents'
    'restart:restart a service and dependents'
    'refresh:refresh service configuration'
    'proxy:act as proxy process for a service'
    'info:get information about a service'
    'status:get the status of a service'
    'get-log:show logging state for a service'
    'set-log-target:set log target for a service/facility'
    'set-log-level:set log level for a service/facility'
    'reset-log-defaults:clear saved log defaults'
    'tap-log:redirect log to stdout temporarily'
    'gdb:attach gdb to a running service'
    'shutdown:shutdown service manager'
    'settings:list global settings'
    'set:change global setting'
)

_arguments -s -C \
    '(-q --quiet)'{-q,--quiet}'[suppress console output]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'lwsm command' cmds && ret=0 ;;
esac

return ret
