#compdef syz-showprio
# _syz-showprio — show syscall priorities used by syzkaller fuzzer (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-showprio/showprio.go (flag).

_syz-showprio() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-enable=[comma-separated enabled syscalls]:list:' \
        '-corpus=[corpus file]:file:_files'
}

_syz-showprio "$@"
