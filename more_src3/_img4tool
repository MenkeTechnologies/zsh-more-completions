#compdef img4tool
# _img4tool — manipulate IMG4 / IM4M / IM4P files (tihmstar/img4tool)
# upstream: https://github.com/tihmstar/img4tool
# Flags from img4tool/main.cpp.

_img4tool() {
    local -a args
    args=(
        '(-a --print-all)'{-a,--print-all}'[print everything from im4m]'
        '(-e --extract)'{-e,--extract}'[extract im4m / im4p payload]'
        '(-i --im4p-only)'{-i,--im4p-only}'[print only im4p]'
        '(-m --im4m)'{-m+,--im4m=}'[file path for im4m (depends on -e)]:file:_files'
        '(-p --im4p)'{-p+,--im4p=}'[file path for im4p (depends on -e)]:file:_files'
        '(-c --create)'{-c+,--create=}'[create an img4 / im4p (uses last positional as raw file)]:file:_files'
        '(-o --outfile)'{-o+,--outfile=}'[output path for extracted payload (-e) or renamed im4p (-n)]:file:_files'
        '(-t --type)'{-t+,--type=}'[set type when creating IM4P from raw]:type:'
        '(-d --desc)'{-d+,--desc=}'[set desc when creating IM4P from raw]:desc:'
        '(-n --rename-payload)'{-n+,--rename-payload=}'[rename im4p payload (NAME must be exactly 4 bytes)]:name:'
        '(-g --generator)'{-g+,--generator=}'[add generator to img4 (e.g. 0x726174736d686974)]:generator:'
        '(-f --fetch)'{-f,--fetch}'[try to get IV / KEY based on KBAG from fwkeydb]'
        '(-s --shsh)'{-s+,--shsh=}'[file path for SHSH (read / write im4m)]:file:_files'
        '(-v --verify)'{-v+,--verify=}'[verify img4 / im4m against BUILDMANIFEST]:file:_files -g "*.plist"'
        '(- *)'{-h,--help}'[show help]'
        '1:input file:_files'
    )
    _arguments -s -S $args
}

_img4tool "$@"
