#compdef wazuh-analysisd
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-analysisd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version and license info]' \
  '-c[config file]:file:_files' \
  '*-d[debug mode (repeatable)]' \
  '-f[run in foreground]' \
  '-t[test configuration]' \
  '-u[run as user]:user:_users' \
  '-g[run as group]:group:_groups' \
  '-D[chroot directory]:dir:_files -/' && ret=0
return ret
