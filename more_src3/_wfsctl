#compdef wfsctl
# Documentation: man wfsctl (macOS, wfsctl(8))
# Reference accessed: 2026-05-21
# Verified: upstream macOS wfsctl(8) manpage.

# wfsctl: WebDAV File Sharing control utility (macOS)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:(start stop status shares share unshare diagnose)' \
  '*::arg:->args' && ret=0

case $state in
  (args)
    case ${line[1]} in
      (share|unshare)
        _arguments '1:path or share name:_files' && ret=0 ;;
    esac ;;
esac

return ret
