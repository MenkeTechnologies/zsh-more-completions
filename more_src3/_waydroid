#compdef waydroid
# Documentation: https://docs.waydro.id/usage/waydroid-command-line-options
# Reference accessed: 2026-05-21
# Verified: upstream tools/helpers/arguments.py at github.com/waydroid/waydroid.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'status:quick check for the waydroid'
  'log:follow the waydroid logfile'
  'init:set up waydroid-specific configs and install images'
  'upgrade:upgrade images'
  'session:session controller'
  'container:container controller'
  'app:applications controller'
  'prop:android properties controller'
  'show-full-ui:show android full screen in window'
  'first-launch:start waydroid, prompting to initialize first if necessary'
  'shell:run remote shell command'
  'logcat:show android logcat'
  'adb:manage adb connection'
  'bugreport:create a bugreport archive interactively'
)

_arguments -s -S \
  '1:command:->command' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --log)'{-l,--log}'+[path to log file]:file:_files' \
  '--details-to-stdout[print details to stdout instead of log]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-q --quiet)'{-q,--quiet}'[suppress log messages]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'waydroid command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (init)
        _arguments -s -S \
          '(-i --images_path)'{-i,--images_path}'+[custom path for images]:dir:_files -/' \
          '(-f --force)'{-f,--force}'[re-initialize even if already done]' \
          '(-c --system_channel)'{-c,--system_channel}'+[system OTA channel]:channel' \
          '(-v --vendor_channel)'{-v,--vendor_channel}'+[vendor OTA channel]:channel' \
          '(-r --rom_type)'{-r,--rom_type}'+[ROM type]:type:(lineage bliss)' \
          '(-s --system_type)'{-s,--system_type}'+[system type]:type:(VANILLA FOSS GAPPS)' \
          '--client[run as user mode connecting to remote initializer]' && ret=0
        ;;
      (upgrade)
        _arguments -s -S \
          '(-o --offline)'{-o,--offline}'[just update configs]' && ret=0
        ;;
      (log)
        _arguments -s -S \
          '(-n --lines)'{-n,--lines}'+[count of initial output lines]:lines' \
          '(-c --clear)'{-c,--clear}'[clear the log]' && ret=0
        ;;
      (session)
        local -a session_commands=(
          'start:start session'
          'stop:stop session'
        )
        _arguments -s -S \
          '1:subaction:->session_cmd' && ret=0
        if [[ $state == session_cmd ]]; then
          _describe -t commands 'session subaction' session_commands && ret=0
        fi
        ;;
      (container)
        local -a container_commands=(
          'start:start the waydroid container'
          'stop:stop the waydroid container'
          'restart:restart the waydroid container'
          'freeze:freeze the waydroid container'
          'unfreeze:unfreeze the waydroid container'
        )
        _arguments -s -S \
          '1:subaction:->container_cmd' && ret=0
        if [[ $state == container_cmd ]]; then
          _describe -t commands 'container subaction' container_commands && ret=0
        fi
        ;;
      (app)
        local -a app_commands=(
          'install:install an APK'
          'remove:remove an app'
          'launch:launch an app'
          'list:list installed apps'
          'intent:start single application via intent'
        )
        _arguments -s -S \
          '1:subaction:->app_cmd' \
          '*:: :->app_args' && ret=0
        case $state in
          (app_cmd)
            _describe -t commands 'app subaction' app_commands && ret=0
            ;;
          (app_args)
            case $words[1] in
              (install) _arguments '1:APK file:_files -g "*.apk"' && ret=0 ;;
              (remove|launch) _arguments '1:package name' && ret=0 ;;
              (intent) _arguments '1:action' '2:URI' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      (prop)
        local -a prop_commands=(
          'get:get a property'
          'set:set a property'
        )
        _arguments -s -S \
          '1:subaction:->prop_cmd' \
          '*:: :->prop_args' && ret=0
        case $state in
          (prop_cmd) _describe -t commands 'prop subaction' prop_commands && ret=0 ;;
          (prop_args)
            case $words[1] in
              (get) _arguments '1:property name' && ret=0 ;;
              (set) _arguments '1:property name' '2:value' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      (shell)
        _arguments \
          '(-u --uid)'{-u,--uid}'+[UID to run as]:uid' \
          '(-g --gid)'{-g,--gid}'+[GID to run as]:gid' \
          '(-s --context)'{-s,--context}'+[SELinux/AppArmor context]:context' \
          '(-L --nolsm)'{-L,--nolsm}'[skip LSM transitions (dangerous)]' \
          '(-C --allcaps)'{-C,--allcaps}'[do not drop capabilities (dangerous)]' \
          '(-G --nocgroup)'{-G,--nocgroup}'[skip container cgroup (dangerous)]' \
          '*:command' && ret=0
        ;;
      (logcat)
        _arguments '*:logcat arg' && ret=0
        ;;
      (adb)
        local -a adb_commands=(
          'connect:connect adb to the Android container'
          'disconnect:disconnect adb from the Android container'
        )
        _arguments -s -S \
          '1:subaction:->adb_cmd' && ret=0
        if [[ $state == adb_cmd ]]; then
          _describe -t commands 'adb subaction' adb_commands && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
