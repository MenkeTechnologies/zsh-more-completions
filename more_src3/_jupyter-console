#compdef jupyter-console
# Documentation: https://github.com/jupyter/jupyter_client/blob/main/jupyter_client/consoleapp.py
# Reference accessed: 2026-05-19
# Verified: app_aliases/app_flags in consoleapp.py + jupyter_console app.py
# (simple-prompt) and jupyter_core base flags (--debug, --generate-config).

# jupyter-console: terminal-based Jupyter frontend
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all options]' \
  '--version[show version]' \
  '--debug[set log level to DEBUG]' \
  '--generate-config[generate default config file]' \
  '(-y)-y[answer yes to any prompts]' \
  '--confirm-exit[prompt for confirmation on exit]' \
  '--no-confirm-exit[do not prompt for confirmation on exit]' \
  '--simple-prompt[use simple prompt (no prompt_toolkit)]' \
  '--config=[config file]:file:_files -g "*.py"' \
  '--existing=[connect to an existing kernel]:conn_file:' \
  '--f=[connection file]:file:_files' \
  '--kernel=[kernel name]:name:' \
  '--ssh=[SSH server for tunneled connection]:user@host:' \
  '--sshkey=[path to SSH key]:file:_files' \
  '--ip=[kernel IP address]:ip:' \
  '--transport=[connection transport]:transport:(tcp ipc)' \
  '--hb=[heartbeat port]:port:' \
  '--shell=[shell port]:port:' \
  '--iopub=[iopub port]:port:' \
  '--stdin=[stdin port]:port:' \
  '--control=[control port]:port:' \
  '*::jupyter-console args:_files' && ret=0
return ret
