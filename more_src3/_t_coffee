#compdef t_coffee t-coffee tcoffee
# _t_coffee — Cedric Notredame t_coffee CLI multiple sequence alignment program for protein DNA RNA combining structural sequence-based and HMM information into consistency-based progressive alignment with M-Coffee Expresso 3D-Coffee R-Coffee plugin-driven external method aggregation FASTA ClustalW PIR output (Cedric Notredame team, C); custom argparse
# upstream: http://www.tcoffee.org/

_t_coffee() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-other_pg=+[program]:str:' \
        '-mode=+[m]:m:(regular expresso 3dcoffee mcoffee rcoffee accurate quickaln procoffee proba_pair)' \
        '-method=+[methods]:str:' \
        '-template_file=+[file]:file:_files' \
        '-blast=+[server]:s:(LOCAL NCBI EBI UNIPROT)' \
        '-pdb_type=+[t]:str:' \
        '-output=+[fmt]:f:(clustalw clustalw_aln fasta_aln msf_aln phylip score_html score_pdf score_ps score_ascii html_aln)' \
        '-outfile=+[file]:file:_files' \
        '-newtree=+[file]:file:_files' \
        '-usetree=+[file]:file:_files' \
        '-seq=+[file]:file:_files -g "*.fa *.fasta *.tfa *.tfasta *.aln"' \
        '-aln=+[alignment]:file:_files -g "*.aln *.fasta_aln"' \
        '-pdb=+[file]:file:_files -g "*.pdb"' \
        '-profile=+[file]:file:_files' \
        '-thread=+[N]:n:' \
        '-special_mode=+[m]:m:(suite)' \
        '-quiet=+[mode]:m:(stderr stdout nothing)' \
        '-no_warning[no warnings]' \
        '-evaluate[evaluate alignment]' \
        '-convert[convert alignment]' \
        '-distance_matrix_mode=+[m]:str:' \
        '-cluster_method=+[m]:m:(upgma nj single complete average)' \
        '*:sequence file:_files -g "*.fa *.fasta *.tfa *.aln"'
}

_t_coffee "$@"
