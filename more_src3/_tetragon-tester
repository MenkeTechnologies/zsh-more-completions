#compdef tetragon-tester
# _tetragon-tester — VM-test harness binary embedded in tetragon vmtests (cilium/tetragon)
# upstream: https://github.com/cilium/tetragon
# Args from cmd/tetragon-tester/init.go (no flags; reads config file).

_tetragon-tester() {
    _arguments \
        '1::config file:_files -g "*.json"'
}

_tetragon-tester "$@"
