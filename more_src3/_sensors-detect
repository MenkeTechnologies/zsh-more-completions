#compdef sensors-detect
# Documentation: man sensors-detect(8)
# Source: lm-sensors/lm-sensors prog/detect/sensors-detect (master) — interactive lm-sensors detection (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--stat[show statistics only]' \
    '--auto[auto-accept defaults]' \
    && ret=0

return ret
