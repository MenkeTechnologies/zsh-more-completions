#compdef sentinelone sentinelone-cli s1cli
# _sentinelone — SentinelOne XDR platform CLI (SentinelOne, Python); click
# upstream: https://github.com/Sentinel-One

_sentinelone() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'config:manage cli config'
        'sites:manage sites'
        'accounts:manage accounts'
        'groups:manage groups'
        'agents:manage agents (endpoints)'
        'threats:manage threats'
        'incidents:manage incidents'
        'policies:manage policies'
        'exclusions:manage exclusions'
        'blocklist:manage blocklist'
        'singularity:singularity data lake search'
        'users:manage users'
        'tokens:manage tokens'
        'roles:manage roles'
        'tasks:manage tasks'
        'reports:manage reports'
        'dv:deep visibility queries'
        'remote-shell:remote shell session'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[mgmt console url]:url:_urls' \
        '--api-token=+[API token]:str:' \
        '--account-id=+[account id]:id:' \
        '--site-id=+[site id]:id:' \
        '--insecure[skip tls verify]' \
        '--profile=+[profile]:profile:' \
        '--output=+[output format]:fmt:(table json yaml csv)' \
        '-o+[output format]:fmt:(table json yaml csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sentinelone subcommand' sub ;;
        args)
            case $words[1] in
                sites|accounts|groups|agents|threats|incidents|policies|exclusions|blocklist|users|tokens|roles|tasks|reports) _arguments \
                    '1:cmd:(list get create update delete enable disable mitigate isolate unisolate)' \
                    '--id=+[resource id]:id:' \
                    '--ids=+[csv ids]:list:' \
                    '*:arg:' ;;
                singularity|dv) _arguments \
                    '--query=+[query]:str:' \
                    '-q+[query]:str:' \
                    '--from=+[from]:str:' \
                    '--to=+[to]:str:' \
                    '--limit=+[limit]:n:' ;;
                remote-shell) _arguments \
                    '--agent-id=+[agent id]:id:' \
                    '--interactive[interactive]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_sentinelone "$@"
