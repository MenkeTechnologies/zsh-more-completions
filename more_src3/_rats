#compdef rats
# Documentation: man rats(1)
# Source: Secure Software RATS (Rough Auditing Tool for Security) — C/Perl/PHP/Python scanner (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '-a+[report any occurrence of function]:funcname:_default' \
    '*'{-d+,--database=,--db=}'[vulnerability database file]:file:_files' \
    '(-i --input)'{-i,--input}'[print list of external-input function calls]' \
    '(-l --language)'{-l+,--language=}'[force input language]:lang:(c perl php python)' \
    '(-r --references)'{-r,--references}'[report references too]' \
    '(-w --warning)'{-w+,--warning=}'[warning level]:level:(1 2 3)' \
    '-x[do not load default vuln databases]' \
    '(-R --no-recurssion)'{-R,--no-recurssion}'[do not recurse subdirectories]' \
    '--xml[output XML]' \
    '--html[output HTML]' \
    '--follow-symlinks[follow symlinks to files/directories]' \
    '*:file or directory:_files' \
    && ret=0

return ret
