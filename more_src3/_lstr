#compdef lstr
# Documentation: https://github.com/bgreenwell/lstr
# Reference accessed: 2026-05-19
# Verified: bgreenwell/lstr README (classic mode + interactive mode flags).

# Zsh completion for lstr directory tree (bgreenwell/lstr)
local curcontext="$curcontext" ret=1

_lstr_first() {
  local -a expl
  compadd interactive i
  _files -/
}

_arguments -s -S \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--color=[when to colorize]:when:(always auto never)' \
  '(-L --level)'{-L+,--level=}'[max tree depth]:n:' \
  '(-d --dirs-only)'{-d,--dirs-only}'[directories only]' \
  '(-s --size)'{-s,--size}'[show file sizes]' \
  '(-p --permissions)'{-p,--permissions}'[show permission bits]' \
  '(-a --all)'{-a,--all}'[include hidden files]' \
  '(-g --gitignore)'{-g,--gitignore}'[respect ignore rules]' \
  '(-G --git-status)'{-G,--git-status}'[show git status markers]' \
  '--icons[nerd font icons]' \
  '--hyperlinks[render paths as clickable hyperlinks]' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '--sort=[sort by]:type:(name size modified extension)' \
  '--dirs-first[directories before files]' \
  '--dotfiles-first[dotfiles first]' \
  '--case-sensitive[case-sensitive sort]' \
  '--natural-sort[natural/version sort]' \
  '--expand-level=[TUI initial depth]:level:' \
  '1:path or interactive:_lstr_first' \
  '*:path:_files -/' && ret=0

return ret
