#compdef imtest pop3test lmtptest smtptest mupdatetest sivtest nntptest
# Documentation: man imtest(1)
# Source: cyrusimap/cyrus-imapd imtest/imtest.c — test client for IMAP/POP3/LMTP/SMTP/Sieve (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-P+,--protocol=}'[protocol name to test]:protocol:(imap pop3 nntp lmtp smtp mupdate sieve csync http)' \
    {-H+,--haproxy-clientip=}'[HAProxy v1 client IP]:ip:_default' \
    {-I+,--pidfile=}'[pid file]:file:_files' \
    '-q[require compression (zlib)]' \
    '-s[require STARTTLS/SSL]' \
    {-c,--do-challenge}'[do SASL challenge]' \
    {-i,--no-initial-response}'[no SASL initial response]' \
    {-z,--run-stress-test}'[run stress test]' \
    {-v,--verbose}'[verbose]' \
    {-k+,--minssf=}'[minimum SSF]:ssf:_default' \
    {-l+,--maxssf=}'[maximum SSF]:ssf:_default' \
    {-p+,--port=}'[port number]:port:_default' \
    {-u+,--username=}'[SASL username]:user:_users' \
    {-a+,--authname=}'[SASL authname]:user:_users' \
    {-w+,--password=}'[password]:pass:_default' \
    {-m+,--mechanism=}'[SASL mechanism]:mech:(PLAIN LOGIN CRAM-MD5 DIGEST-MD5 SCRAM-SHA-1 SCRAM-SHA-256 GSSAPI EXTERNAL)' \
    {-f+,--input-filename=}'[pipe input file]:file:_files' \
    {-r+,--realm=}'[SASL realm]:realm:_default' \
    {-t+,--keyfile=}'[TLS keyfile]:file:_files' \
    {-n+,--reauth-attempts=}'[reauth attempts]:N:_default' \
    '-X+[output socket]:socket:_files' \
    '-x+[output socket, foreground]:socket:_files' \
    '*'{-o+,--sasl-option=}'[SASL opt=val]:opt=val:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '1:host:_hosts' \
    && ret=0

return ret
