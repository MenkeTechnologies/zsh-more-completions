#compdef hydra-cli
# _hydra-cli — Ory Hydra OAuth2 and OpenID Connect provider CLI alias (ory team, Go); cobra
# upstream: https://github.com/ory/hydra

_hydra-cli() {
    local -a sub=(
        'serve:run hydra server'
        'serve:all:run all servers'
        'serve:admin:run admin endpoint'
        'serve:public:run public endpoint'
        'migrate:run migrations'
        'migrate:status:show migration status'
        'migrate:sql:run sql migrations'
        'migrate:up:run pending migrations'
        'migrate:down:rollback migrations'
        'create:client:create OAuth2 client'
        'create:jwks:create jwks key'
        'delete:client:delete OAuth2 client'
        'delete:jwks:delete jwks'
        'get:client:get client'
        'get:jwks:get jwks'
        'import:client:import clients'
        'import:jwks:import jwks'
        'list:clients:list clients'
        'list:grants:list jwt grants'
        'list:jwks:list jwks'
        'list:trusted-issuers:list trusted issuers'
        'update:client:update client'
        'introspect:token:introspect token'
        'perform:authorization-code:perform auth code flow'
        'perform:client-credentials:perform client credentials'
        'perform:device-code:perform device code'
        'revoke:revoke token'
        'revoke:token:revoke token'
        'janitor:cleanup expired data'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.{yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml}"' \
        '--endpoint=+[admin api endpoint]:url:_urls' \
        '-e+[admin api endpoint]:url:_urls' \
        '--access-token=+[access token]:str:' \
        '--format=+[output format]:f:(default json json-pretty yaml table)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--skip-tls-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hydra subcommand' sub ;;
        args)
            case $words[1] in
                create:client) _arguments \
                    '--name=+[client name]:str:' \
                    '--secret=+[client secret]:str:' \
                    '--grant-type=+[grant types csv]:str:' \
                    '--response-type=+[response types csv]:str:' \
                    '--scope=+[scopes csv]:str:' \
                    '--redirect-uri=+[redirect URI]:url:_urls' \
                    '--audience=+[audience]:str:' \
                    '--owner=+[owner]:str:' \
                    '--policy-uri=+[policy URI]:url:_urls' \
                    '--tos-uri=+[tos URI]:url:_urls' \
                    '--client-uri=+[client URI]:url:_urls' \
                    '--logo-uri=+[logo URI]:url:_urls' \
                    '--metadata=+[metadata json]:str:' \
                    '--token-endpoint-auth-method=+[method]:m:(client_secret_basic client_secret_post private_key_jwt none)' \
                    '--jwks=+[jwks json]:str:' \
                    '--jwks-uri=+[jwks URI]:url:_urls' \
                    '--id-token-signed-response-alg=+[alg]:str:' \
                    '--access-token-strategy=+[strategy]:s:(opaque jwt)' \
                    '--lifespan-access-token=+[duration]:str:' \
                    '--lifespan-refresh-token=+[duration]:str:' ;;
                migrate:status|migrate:sql|migrate:up|migrate:down) _arguments \
                    '--yes[skip confirmation]' \
                    '-y[skip confirmation]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hydra-cli "$@"
