#compdef herbe
# Documentation: https://github.com/dudik/herbe
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for herbe (minimal daemonless X11 notification).
# herbe is configured at compile-time via config.h and accepts only positional
# arguments (each argument becomes a new line in the notification).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:notification body text:' && ret=0

return ret
