#compdef listblocks
# _listblocks — Grafana Mimir TSDB block lister (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/listblocks/main.go + pkg/storage/bucket on tip.

_listblocks() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-user=[tenant whose blocks to list]:id:' \
        '-format=[output format]:fmt:(tabbed json yaml)' \
        '-show-deleted[include blocks marked for deletion]' \
        '-show-labels[show block labels]' \
        '-show-ulid-time[show wall-clock time encoded in ULID]' \
        '-show-sources[show compaction sources]' \
        '-show-parents[show parent blocks]' \
        '-show-hints[show compaction hints]' \
        '-show-compaction-level[show compaction level]' \
        '-show-block-size[show block size from meta.json]' \
        '-show-stats[show series/chunks/samples stats]' \
        '-split-count=[split number for split-compaction grouping]:n:' \
        '-min-time=[only print blocks with MinTime >= value]:t:' \
        '-max-time=[only print blocks with MaxTime <= value]:t:' \
        '-use-ulid-time-for-min-time-check[skip loading meta.json with ULID before min-time]' \
        '-backend=[object store backend]:backend:(s3 gcs azure swift filesystem)' \
        '-blocks-storage.backend=[blocks storage backend]:backend:(s3 gcs azure swift filesystem)' \
        '-blocks-storage.s3.bucket-name=[S3 bucket name]:bucket:' \
        '-blocks-storage.s3.endpoint=[S3 endpoint]:url:_urls' \
        '-blocks-storage.s3.region=[S3 region]:region:' \
        '-blocks-storage.gcs.bucket-name=[GCS bucket name]:bucket:' \
        '-blocks-storage.azure.account-name=[Azure storage account]:name:' \
        '-blocks-storage.azure.container-name=[Azure container name]:name:' \
        '-blocks-storage.filesystem.dir=[local blocks directory]:dir:_files -/'
}

_listblocks "$@"
