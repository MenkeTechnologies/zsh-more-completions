#compdef hp-faxsetup
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-faxsetup.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-faxsetup(1) manpage. Qt4 GUI only.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-faxsetup: HPLIP fax setup GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --device)'{-d+,--device=}'[device URI]:uri:' \
  '(-p --printer)'{-p+,--printer=}'[printer name]:printer:_printers' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' && ret=0
return ret
