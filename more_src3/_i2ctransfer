#compdef i2ctransfer
# _i2ctransfer — Linux i2c-tools i2ctransfer CLI for performing low-level user-level I2C message transfers concatenating write and read messages of variable lengths with flags ten-bit addressing repeated-start no-stop (i2c-tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/utils/i2c-tools/i2c-tools.git

_i2ctransfer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-y[disable interactive confirm]' \
        '-f[force]' \
        '-a[allow addresses 0x00-0x07 and 0x78-0x7f]' \
        '*:i2cbus desc:'
}

_i2ctransfer "$@"
