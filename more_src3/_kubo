#compdef kubo
# Documentation: https://github.com/ipfs/kubo (core/commands/root.go)
# Reference accessed: 2026-05-29
# Kubo IPFS implementation (Go). Note: binary is usually `ipfs`; this completion
# is provided for setups that rename it `kubo`. For `ipfs` binary see man_src/_ipfs
# (IPFilter legacy) — modern Kubo users should prefer `kubo` alias.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'add:add a file or directory to IPFS'
  'cat:show IPFS object data'
  'get:download IPFS objects'
  'ls:list directory contents for Unix filesystem objects'
  'refs:list links (references) from an object'
  'dag:interact with IPLD DAG objects'
  'files:interact with unixfs files'
  'block:manipulate raw IPFS blocks'
  'pin:pin (and unpin) objects to local storage'
  'repo:manipulate the IPFS repo'
  'cid:convert and discover CID properties'
  'multibase:encode and decode files or stdin with multibase format'
  'id:show IPFS node id info'
  'bootstrap:show or edit the list of bootstrap peers'
  'swarm:interact with the swarm'
  'dht:issue commands directly through the DHT'
  'routing:issue routing commands'
  'ping:send echo request packets to IPFS hosts'
  'bitswap:interact with the bitswap agent'
  'pubsub:experimental pubsub commands'
  'name:publish and resolve IPNS names'
  'key:create and manipulate keypairs'
  'daemon:run a network-connected IPFS node'
  'shutdown:shut down the IPFS daemon'
  'config:get and set IPFS config values'
  'version:show IPFS version information'
  'diag:generate diagnostic reports'
  'update:download and apply Kubo updates'
  'commands:list all available commands'
  'log:interact with the daemon log output'
  'p2p:libp2p stream mounting'
  'filestore:interact with filestore objects'
  'mount:mount an IPFS read-only mount point'
  'provide:manually announce CIDs to the routing system'
  'completion:generate shell completions'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--api=[API endpoint multiaddr]:multiaddr:' \
  '--cid-base=[multibase encoding for output CIDs]:base:(base32 base32upper base32hex base32hexupper base32hexpad base32hexpadupper base36 base36upper base58btc base58flickr base64 base64pad base64url base64urlpad)' \
  '-c=-[run the command with a different IPFS_PATH (config dir)]:dir:_directories' \
  '--config=[run the command with a different IPFS_PATH (config dir)]:dir:_directories' \
  '--enc=[output encoding]:enc:(json xml text)' \
  '--encoding=[output encoding]:enc:(json xml text)' \
  '(-L --upgrade-cidv0-in-output)'{-L,--upgrade-cidv0-in-output}'[upgrade v0 CIDs to v1 in output]' \
  '--offline[run the command offline]' \
  '--timeout=[command timeout]:duration:' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'kubo subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      daemon)
        _arguments \
          '--init[initialize ipfs with default settings if not already initialized]' \
          '--init-config=[path to existing configuration file for initialization]:file:_files' \
          '--init-profile=[apply profile settings to config]:profile:' \
          '--routing=[overrides config.Routing.Type]:type:(dht dhtclient none auto autoclient)' \
          '--mount[mount IPFS and IPNS using FUSE]' \
          '--writable[enable writing through HTTP API]' \
          '--mount-ipfs=[path to IPFS mount]:dir:_directories' \
          '--mount-ipns=[path to IPNS mount]:dir:_directories' \
          '--unrestricted-api[allow API access to unlisted hashnames]' \
          '--disable-transport-encryption[disable connection-level encryption]' \
          '--enable-gc[enable automatic repo garbage collection]' \
          '--manage-fdlimit[manage file descriptor limit]' \
          '--migrate[if true, assume yes at the migrate prompt]' \
          '--agent-version-suffix=[append suffix to user agent]:suffix:' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
