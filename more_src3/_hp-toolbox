#compdef hp-toolbox
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-toolbox.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-toolbox(1) manpage. HPLIP GUI device manager;
# was removed from Debian bookworm hplip package.
# Removed from prior file: fabricated -V/--version flag and bogus
# man.archlinux.org search URL.

# hp-toolbox: HPLIP device manager GUI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '(-x --disable-dbus)'{-x,--disable-dbus}'[disable D-Bus (Qt3 only)]' && ret=0
return ret
