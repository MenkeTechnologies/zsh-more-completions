#compdef injectived
# _injectived — Injective Labs injectived Cosmos-SDK node daemon for the Injective Layer-1 finance blockchain (injective team, Go); cobra
# upstream: https://github.com/InjectiveLabs/injective-core

_injectived() {
    local -a sub=(
        'start:start the node'
        'status:show node status'
        'init:initialize node config'
        'add-genesis-account:add genesis account'
        'gentx:create gentx'
        'collect-gentxs:collect gentxs'
        'validate-genesis:validate genesis'
        'comet:comet subcommands'
        'export:export state to JSON'
        'tx:transaction subcommands'
        'query:query subcommands'
        'q:query alias'
        'keys:keys subcommands'
        'config:config subcommands'
        'snapshots:snapshot subcommands'
        'genesis:genesis subcommands'
        'rollback:rollback state'
        'prune:prune state'
        'debug:debug subcommands'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--chain-id=+[chain id]:str:' \
        '--home=+[node home]:dir:_files -/' \
        '--keyring-backend=+[backend]:b:(os file kwallet pass test memory)' \
        '--keyring-dir=+[keyring dir]:dir:_files -/' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '--log-format=+[format]:f:(plain json)' \
        '--trace[trace stack]' \
        '--node=+[tendermint rpc]:url:_urls' \
        '--output=+[format]:f:(text json)' \
        '-o+[format]:f:(text json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'injectived subcommand' sub ;;
        args)
            case $words[1] in
                tx) _arguments '1:tx module:(bank staking exchange auction insurance oracle peggy ocr wasm wasmx tokenfactory gov authz feegrant ibc-transfer slashing crisis vesting distribution evm permissions)' ;;
                query|q) _arguments '1:query module:(bank staking exchange auction insurance oracle peggy ocr wasm tokenfactory gov ibc params block tx auth slashing distribution evm permissions)' ;;
                keys) _arguments '1:keys cmd:(add delete export import list mnemonic parse rename show migrate unsafe-export-eth-key unsafe-import-eth-key)' ;;
                comet) _arguments '1:comet cmd:(reset-state show-node-id show-validator show-address version unsafe-reset-all)' ;;
                snapshots) _arguments '1:snap cmd:(list load restore export delete dump)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_injectived "$@"
