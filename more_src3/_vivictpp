#compdef vivictpp
# _vivictpp — side-by-side subjective video quality comparison tool (vivictorg/vivictpp)
# upstream: https://github.com/vivictorg/vivictpp
# Flags from src/OptParser.cc (CLI11).

_vivictpp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--left-filter=[video filters for left video]:filter:' \
        '--right-filter=[video filters for right video]:filter:' \
        '--left-format=[format options for left input]:opts:' \
        '--right-format=[format options for right input]:opts:' \
        '--hwaccel=[hardware accelerated decoding type]:type:(auto none cuda vaapi videotoolbox d3d11va dxva2 qsv vdpau)' \
        '--preferred-decoders=[comma-separated preferred decoders]:list:' \
        '1:left video:_files -g "*.{mp4,mkv,webm,mov,avi,y4m,ts,m4v}"' \
        '2:right video:_files -g "*.{mp4,mkv,webm,mov,avi,y4m,ts,m4v}"'
}

_vivictpp "$@"
