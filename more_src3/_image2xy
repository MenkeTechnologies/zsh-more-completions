#compdef image2xy
# Documentation: https://manpages.debian.org/bookworm/astrometry.net/image2xy.1.en.html
# Source: dstndstn/astrometry.net util/image2xy.c — extract a sources list from a FITS image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-e+[FITS extension to read]:ext:_default' \
    '-O[overwrite existing output]' \
    '-o+[XYlist output file]:file:_files' \
    '-L+[Lanczos interpolation order]:order:_default' \
    '-8[skip byte (u8) image optimization]' \
    '-H[reduce resolution by factor 2 before processing]' \
    '-d+[reduce by integer factor]:factor:_default' \
    '-D+[reduce by this many factors of two if needed]:n:_default' \
    '-s+[median-filter box size (default 100 px)]:n:_default' \
    '-w+[Gaussian PSF sigma (default 1 px)]:value:_default' \
    '-g+[image noise level]:sigma:_default' \
    '-p+[peak significance (sigmas, default 8)]:value:_default' \
    '-a+[saddle level joining peaks (sigmas, default 5)]:value:_default' \
    '-P+[plane index for multi-color images]:n:_default' \
    '-b[skip background subtraction]' \
    '-G+[subtract global background value]:value:_default' \
    '-m+[max extended object size for deblending (default 2000 px)]:n:_default' \
    '-S+[save background-subtracted FITS image]:file:_files' \
    '-B+[save background image]:file:_files' \
    '-U+[save smoothed background-subtracted image]:file:_files' \
    '-M+[save mask image]:file:_files' \
    '-C+[save connected-components image]:file:_files' \
    '*-v[verbose (stackable)]' \
    '*:FITS image:_files -g "*.(fits|fit|fts|FITS|fits.gz)(-.)"' \
    && ret=0

return ret
