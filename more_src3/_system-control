#compdef system-control system-manager
# Documentation: source-direct extraction from upstream jdebp/nosh
# source/system-control.cpp + source/builtins-system-control.cpp +
# source/builtins-system-manager.cpp `extern void <subcmd> ( ... )`
# declaration tables (each entry corresponds to one available
# subcommand string literal; the same binary is used for both
# system-control + system-manager via argv[0] multicall dispatch
# but the visible subcommand set differs because each builds its
# own builtins table).
# Reference accessed: 2026-05-30 via gh api.
# jdebp/nosh master CLIs R132a — 2-stem multi-binary harvest of
# the two top-level nosh service-management entrypoints. nosh is
# Jonathan de Boyne Pollard's clean-room reimplementation of an
# entire init/supervision/service-management stack across Linux
# and BSDs - the source repo has 668 .cpp files producing ~200
# binaries (most as multicall aliases to a single `exec` binary).

# popt-style compatibility flags shared by both binaries (these
# are no-ops kept for systemctl(1) command-line parity per upstream
# popt::bool_definition declarations with description string
# "Compatibility option.  Ignored.").
local -a _nosh_systemctl_compat
_nosh_systemctl_compat=(
  '--full[(systemctl compat; no-op)]'
  '--no-legend[(systemctl compat; no-op)]'
  '--no-pager[(systemctl compat; no-op)]'
  '--no-reload[(systemctl compat; no-op)]'
  '--quite[(systemctl compat; no-op; note typo per upstream)]'
)

case $service in

  system-control)
    # The main nosh service-management binary, equivalent to
    # systemctl(1) in scope. 76 subcommands extracted source-direct
    # from builtins-system-control.cpp `extern void <subcmd> (...)`
    # forward-declaration table.
    _arguments -s -S \
      '(-u --user)'{-u,--user}'[communicate with the per-user manager, not the system one]' \
      "${_nosh_systemctl_compat[@]}" \
      '1:subcommand:(activate builtins cat chkservice condrestart convert-fstab-services convert-systemd-units deactivate default disable emergency enable escape fastboot fasthalt fastpowercycle fastpoweroff fastreboot find force-reload get-mount-what get-mount-where halt hangup init is-active is-enabled is-loaded is-service-manager-client isolate list-process-table load-kernel-module move-to-control-group nagios-check-service normal per-user-manager pipe powercycle poweroff preset print-service-env print-service-scripts procstat ps reboot reenable rescue reset service-control service-dt-scanner service-is-enabled service-is-ok service-is-up service-manager service-show service-status set-service-env show show-json single start status stop svc svok svscan svshow svstat svup system-control systemctl systemd-escape try-reload-or-restart try-restart unload-kernel-module unload-when-stopped version write-volume-service-bundles)' \
      '*:: :_default'
    ;;

  system-manager)
    # The nosh pid 1 binary. Same physical binary as system-control
    # but uses argv[0] multicall dispatch to select a different
    # builtin command table. The 17-command set extracted from
    # builtins-system-manager.cpp matches what is meaningful for a
    # pid-1 process (no enable/disable; primary verbs are init /
    # activate / isolate / start + the runlevel aliases emergency /
    # rescue / normal / systemd).
    _arguments -s -S \
      '1:subcommand:(activate builtins cyclog emergency foreground init isolate move-to-control-group normal rescue service-manager set-control-group-knob start system-control system-manager systemd version)' \
      '*:: :_default'
    ;;

esac
