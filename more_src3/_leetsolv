#compdef leetsolv
# Documentation: https://github.com/eannchen/leetsolv
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# eannchen/leetsolv — spaced-repetition for LeetCode (Go)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list problems'
  'ls:list problems (alias)'
  'search:search problems'
  's:search problems (alias)'
  'detail:show problem detail'
  'get:show problem detail (alias)'
  'status:show review status'
  'stat:show review status (alias)'
  'upsert:add or update a problem'
  'add:add a problem (alias)'
  'remove:remove a problem'
  'rm:remove a problem (alias)'
  'undo:undo last action'
  'back:undo last action (alias)'
  'history:show history'
  'hist:show history (alias)'
  'log:show history (alias)'
  'setting:show configuration'
  'config:show configuration (alias)'
  'cfg:show configuration (alias)'
  'help:show help'
  'h:show help (alias)'
  'version:show version'
  'ver:show version (alias)'
  'v:show version (alias)'
  'migrate:migrate data store'
  'reset:reset data'
  'clear:clear screen'
  'cls:clear screen (alias)'
  'quit:exit'
  'q:exit (alias)'
  'exit:exit'
)

_arguments -s -S -C \
  '1:command:->cmd' \
  '*::arguments:_default' && ret=0

case $state in
  cmd) _describe -t commands 'leetsolv command' commands && ret=0 ;;
esac

return ret
