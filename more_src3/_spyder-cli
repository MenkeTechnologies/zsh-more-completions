#compdef spyder-cli spyder2
# _spyder-cli — Spyder IDE spyder-cli CLI command-line frontend wrapping the Spyder Scientific Python Development Environment Python IDE for data analysis providing project editor IPython console variable explorer help debugger profiler navigator outline workspace open close reset windows-style multi-monitor environment registration-defaults (Spyder IDE team, Python); custom argparse
# upstream: https://www.spyder-ide.org/

_spyder-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--new-instance[new instance]' \
        '--defaults[reset to defaults]' \
        '--reset[reset preferences]' \
        '--optimize[run optimization]' \
        '--no-web-widgets[no web widgets]' \
        '--show-console[show console]' \
        '--multithread[multi-threaded console]' \
        '--profile[run with cProfile]' \
        '--workdir=+[dir]:dir:_files -/' \
        '-w+[workdir]:dir:_files -/' \
        '--paths=+[paths]:str:' \
        '-p+[paths]:str:' \
        '--window-title=+[title]:str:' \
        '--register[register file association]' \
        '--language=+[lang]:str:' \
        '-l+[language]:str:' \
        '--init-cell-only[init cell only]' \
        '--report-segfault[report segfault]' \
        '--restart-process[restart process]' \
        '--repl-tab=+[name]:str:' \
        '--safe-mode[safe mode]' \
        '--no-window[no window]' \
        '--conf-dir=+[dir]:dir:_files -/' \
        '*:file:_files -g "*.py *.pyw *.ipynb"'
}

_spyder-cli "$@"
