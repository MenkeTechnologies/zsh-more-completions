#compdef ldap-delete
# _ldap-delete — distro-shipped LDAP delete wrapper (alias of ldapdelete(1); -H URI, -D bind DN, -w password, -y password file, -r recursive (subtree delete), -c continue on error, -x simple bind, -Z TLS, -n dry run, -v verbose, -h help, -V version; positional argument is the DN to remove)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapdelete)
# Flags from OpenLDAP clients/tools/ldapdelete.c on tip.

_ldap-delete() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-r[subtree delete]' \
        '-c[continue on error]' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-n[dry run]' \
        '-v[verbose]' \
        '*-o+[option=value]:opt:' \
        '*:DN:'
}

_ldap-delete "$@"
