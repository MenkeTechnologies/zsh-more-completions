#compdef v010-adapter
# _v010-adapter — containerd NRI bridge that exposes legacy v0.1.0 OCI-hook-style plugins to the v2 NRI socket
# upstream: https://github.com/containerd/nri
# Flags from plugins/v010-adapter/v010-adapter.go on tip.

_v010-adapter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket=[path to NRI socket]:socket:_files'
}

_v010-adapter "$@"
