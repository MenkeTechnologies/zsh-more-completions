#compdef trivy-config
# _trivy-config — Aqua Trivy IaC misconfig scanner subcommand alias (Aqua Security, Go); spf13/cobra
# upstream: https://github.com/aquasecurity/trivy

_trivy-config() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--timeout=+[timeout]:dur:' \
        '--format=+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github)' \
        '-f+[format]:fmt:(table json sarif template cyclonedx spdx spdx-json github)' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--severity=+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '-s+[severity]:list:(UNKNOWN LOW MEDIUM HIGH CRITICAL)' \
        '--exit-code=+[exit code on misconfig]:n:' \
        '--ignorefile=+[ignore file]:file:_files' \
        '--skip-files=+[skip files]:list:' \
        '--skip-dirs=+[skip dirs]:list:_files -/' \
        '--include-non-failures[include non failures]' \
        '--file-patterns=+[file patterns]:list:' \
        '--config-policy=+[rego policy paths]:list:_files -g "*.rego"' \
        '--policy=+[rego policy paths]:list:_files -g "*.rego"' \
        '--policy-namespaces=+[rego policy namespaces]:list:' \
        '--config-data=+[data file/dir]:list:' \
        '--data=+[data file/dir]:list:' \
        '--tf-vars=+[terraform vars file]:file:_files -g "*.tfvars"' \
        '--cf-params=+[cloudformation params file]:file:_files' \
        '--helm-values=+[helm values file]:file:_files' \
        '--helm-set=+[helm set values]:str:' \
        '--helm-set-file=+[helm set files]:str:' \
        '--helm-set-string=+[helm set string]:str:' \
        '--helm-api-versions=+[helm api versions]:list:' \
        '--helm-kube-version=+[helm kube version]:str:' \
        '--render-cause=+[render cause]:list:(misconfig)' \
        '--compliance=+[compliance spec]:spec:(docker-cis-1.6.0)' \
        '--report=+[report mode]:r:(all summary)' \
        '*:path:_files'
}

_trivy-config "$@"
