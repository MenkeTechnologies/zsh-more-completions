#compdef strapi-cli
# _strapi-cli — Strapi headless CMS CLI alias (Strapi team, JavaScript); commander
# upstream: https://github.com/strapi/strapi

_strapi-cli() {
    local -a sub=(
        'new:scaffold project'
        'start:start strapi app'
        'develop:start in development mode'
        'build:build admin panel'
        'console:start admin console'
        'generate:generate component'
        'plugin:plugin commands'
        'admin:admin commands'
        'install:install plugin'
        'uninstall:uninstall plugin'
        'configuration:dump/restore configuration'
        'config:configuration alias'
        'ts:typescript helpers'
        'webhooks:manage webhooks'
        'transfer:transfer data between environments'
        'export:export project data'
        'import:import project data'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'strapi subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:name:' \
                    '--quickstart[quickstart]' \
                    '--ts[typescript]' \
                    '--use-npm[use npm]' \
                    '--use-yarn[use yarn]' \
                    '--use-pnpm[use pnpm]' \
                    '--no-run[no run]' \
                    '--debug[debug]' \
                    '--template=+[template]:str:' \
                    '--no-example[no example data]' \
                    '--example[include example data]' \
                    '--db-client=+[db client]:c:(sqlite postgres mysql)' \
                    '--db-host=+[db host]:host:_hosts' \
                    '--db-port=+[db port]:port:' \
                    '--db-name=+[db name]:str:' \
                    '--db-username=+[db username]:str:_users' \
                    '--db-password=+[db password]:str:' \
                    '--db-ssl=+[db ssl]:b:(true false)' \
                    '--db-file=+[sqlite file]:file:_files' \
                    '--git-init[git init]' \
                    '--no-git-init[no git init]' ;;
                start|develop) _arguments \
                    '--watch-admin[watch admin]' \
                    '--polling[use polling]' \
                    '--browser=+[browser]:str:' \
                    '--debug[debug]' \
                    '--silent[silent]' \
                    '--ignore-prompts[ignore prompts]' ;;
                build) _arguments \
                    '--clean[clean]' \
                    '--no-optimization[no optimization]' \
                    '--debug[debug]' \
                    '--minify=+[minify]:b:(true false)' \
                    '--sourcemaps=+[sourcemaps]:b:(true false)' \
                    '--stats[print stats]' ;;
                generate) _arguments \
                    '1:thing:(controller service model api content-type plugin policy migration)' \
                    '*:name:' ;;
                plugin) _arguments \
                    '1:cmd:(install build watch)' \
                    '*:arg:' ;;
                admin) _arguments \
                    '1:cmd:(create-user reset-user-password)' \
                    '*:arg:' ;;
                transfer) _arguments \
                    '--from=+[from URL]:url:_urls' \
                    '--from-token=+[from token]:str:' \
                    '--to=+[to URL]:url:_urls' \
                    '--to-token=+[to token]:str:' \
                    '--force[force]' \
                    '--only=+[only types]:list:(assets entities files-tables links configuration)' \
                    '--exclude=+[exclude types]:list:' ;;
                export|import) _arguments \
                    '-f+[file]:file:_files' \
                    '--file=+[file]:file:_files' \
                    '--key=+[encryption key]:str:' \
                    '--no-encrypt[no encrypt]' \
                    '--compress=+[compress]:b:(true false)' \
                    '--exclude=+[exclude types]:list:' \
                    '--only=+[only types]:list:' ;;
                webhooks) _arguments \
                    '1:cmd:(list import export trigger delete)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_strapi-cli "$@"
