#compdef wkg
# Documentation: https://github.com/bytecodealliance/wasm-pkg-tools
# Reference accessed: 2026-05-21
# Verified: clap argument definitions in crates/wkg/src/main.rs,
# crates/wkg/src/oci.rs, and crates/wkg/src/wit.rs.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:set registry configuration'
  'get:download a package from a registry'
  'publish:publish a package to a registry'
  'oci:commands for interacting with OCI registries'
  'wit:commands for interacting with WIT files and dependencies'
)

local -a common=(
  '--config=[path to configuration file]:config file:_files'
  '--cache=[cache directory]:directory:_files -/'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'wkg command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--default-registry=[set default registry domain]:registry:' \
          '(-e --edit)'{-e,--edit}'[open config file in $EDITOR]' \
          $common && ret=0 ;;
      (get)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o+,--output=}'[output path or directory ending with /]:path:_files' \
          '--format=[output format]:format:(auto wasm wit)' \
          '--check[exit nonzero if output differs from package]' \
          '--overwrite[overwrite existing output file]' \
          '--registry=[override registry]:registry:' \
          $common \
          '1:package spec (namespace\:name\[@version\]):package:' && ret=0 ;;
      (publish)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--registry=[override registry]:registry:' \
          '--package=[package id override <ns>:<name>@<ver>]:package spec:' \
          $common \
          '1:wasm file to publish:_files -g "*.wasm"' && ret=0 ;;
      (oci)
        local -a ocisub
        ocisub=(
          'pull:pull a component from an OCI registry'
          'push:push a component to an OCI registry'
        )
        if (( CURRENT == 3 )); then
          _describe -t commands 'oci command' ocisub && ret=0
        else
          case $words[3] in
            (pull)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '-u+[registry username]:user:' \
                '-p+[registry password]:password:' \
                '--insecure=[comma delimited http allowed registries]:hosts:' \
                '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
                '1:OCI image reference:reference:' && ret=0 ;;
            (push)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '-u+[registry username]:user:' \
                '-p+[registry password]:password:' \
                '--insecure=[comma delimited http allowed registries]:hosts:' \
                '(-a --author)'{-a+,--author=}'[optional OCI author string]:author:' \
                '*--annotation=[OCI manifest annotation KEY=value]:annotation:' \
                '1:OCI image reference:reference:' \
                '2:component wasm file path:_files -g "*.wasm"' && ret=0 ;;
          esac
        fi ;;
      (wit)
        local -a witsub
        witsub=(
          'build:build a WIT package and resolve dependencies'
          'fetch:fetch WIT dependencies into deps directory'
          'update:update lock file with latest dependencies'
        )
        if (( CURRENT == 3 )); then
          _describe -t commands 'wit command' witsub && ret=0
        else
          case $words[3] in
            (build)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-d --wit-dir)'{-d+,--wit-dir=}'[WIT sources directory (default wit)]:directory:_files -/' \
                '(-o --output)'{-o+,--output=}'[output .wasm path]:file:_files' \
                $common && ret=0 ;;
            (fetch|update)
              _arguments -s -S \
                '(- *)'{-h,--help}'[show help]' \
                '(-d --wit-dir)'{-d+,--wit-dir=}'[WIT sources directory (default wit)]:directory:_files -/' \
                '(-t --type)'{-t+,--type=}'[dependency output type]:type:(wit wasm)' \
                $common && ret=0 ;;
          esac
        fi ;;
    esac ;;
esac

return ret
