#compdef xfs_restore
# Documentation: https://man7.org/linux/man-pages/man8/xfsrestore.8.html
# Reference accessed: 2026-05-29

_arguments -s \
  '-a[apply to entire dump in archive]' \
  '-b[specify blocksize]:blocksize (bytes)' \
  '-c[media change alert program]:program:_command_names' \
  '-e[set ownership and permissions of restored root directory]' \
  '-f[source of dump to restore]:source:_files' \
  '-i[interactive restore]' \
  '-m[use miniroot protocol for tape media]' \
  '-n[do not restore, just list contents]' \
  '-o[restore owner and group even if not root]' \
  '-p[report progress interval]:interval (seconds)' \
  '-q[quiet, no status messages]' \
  '-r[cumulative restore]' \
  '-s[restrict restore to pathname]:pathname:_files' \
  '-t[list contents of dump]' \
  '-v[verbosity level]:verbosity:(silent verbose trace)' \
  '-A[do not restore extended file attributes]' \
  '-B[base session id for incremental restore]:session id' \
  '-D[restore directory entries only]' \
  '-E[do not display error dialogs]' \
  '-F[do not prompt about anything]' \
  '-I[display dump inventory]' \
  '-J[inhibit inventory update]' \
  '-K[verify per-file checksums]' \
  '-L[session label to restore]:label' \
  '-O[options file]:options file:_files' \
  '-Q[force quota information restore]' \
  '-R[resume an interrupted restore]' \
  '-S[session id to restore]:session id' \
  '-T[inhibit file-by-file interactive dialogs]' \
  '-Y[max I/O buffer ring length]:length' \
  '*:destination directory:_files -/' \
  && return 0
