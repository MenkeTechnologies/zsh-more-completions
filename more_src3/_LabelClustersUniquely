local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:clustersin.hdr:_files -g "*.{nii,nii.gz,hdr,mha,nrrd}"' \
    '3:labeledclustersout.hdr:_files' \
    '4:sizethresh:_default' \
    '5::optionalBoolFullyConnected (default 0):(0 1)' \
    && ret=0

return ret
