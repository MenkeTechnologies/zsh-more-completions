#compdef wpprobe
# _wpprobe — wpprobe CLI WordPress fingerprinting and version detection tool probing /readme.html /wp-includes /wp-content /xmlrpc.php /wp-json endpoints to identify installed WordPress version active plugins themes vulnerability mapping for the pen-test reconnaissance pre-attack phase (wpprobe authors team, Go); pflag
# upstream: https://github.com/Chocapikk/wpprobe

_wpprobe() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-u+[target URL]:str:' \
        '--url=+[url]:str:' \
        '-l+[list file]:file:_files' \
        '--list=+[file]:file:_files' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-r+[retries]:n:' \
        '--retries=+[N]:n:' \
        '--user-agent=+[ua]:str:' \
        '--cookies=+[cookies]:str:' \
        '--proxy=+[url]:str:' \
        '--no-redirect[disable redirect following]' \
        '--no-vulns[disable vulnerability matching]' \
        '--ignore-ssl[ignore SSL errors]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-f+[format]:f:(text json yaml csv markdown table)' \
        '--format=+[format]:f:(text json yaml csv markdown table)' \
        '-s+[severity]:s:(low medium high critical)' \
        '--severity=+[s]:s:(low medium high critical)' \
        '*::'
}

_wpprobe "$@"
