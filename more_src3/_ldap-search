#compdef ldap-search ldap-find
# _ldap-search — distro-shipped LDAP search wrapper (small helper around OpenLDAP ldapsearch(1) that pre-fills sane defaults for the local SLAPD instance; -H URI override, -D bind DN, -w password, -y password file, -b base DN, -s scope (base|one|sub|children), -x simple bind, -ZZ start TLS, -LLL ldif-only output, -h help, -V version; positional filter then attribute list)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapsearch)
# Flags from OpenLDAP clients/tools/ldapsearch.c on tip.

_ldap-search() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-b+[base DN]:dn:' \
        '-s+[scope]:scope:(base one sub children)' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-L[LDIF output]' \
        '-LL[LDIF v1]' \
        '-LLL[LDIF only]' \
        '-z+[size limit]:n:' \
        '-l+[time limit]:seconds:' \
        '-o+[option=value]:opt:' \
        '*:filter and attrs:'
}

_ldap-search "$@"
