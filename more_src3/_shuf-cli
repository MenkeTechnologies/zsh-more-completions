#compdef shuf-cli
# _shuf-cli — GNU coreutils shuf generate random permutations CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_shuf-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-e[treat args as input lines]' \
        '--echo[treat args as input lines]' \
        '-i+[lo-hi range]:str:' \
        '--input-range=+[lo-hi range]:str:' \
        '-n+[count]:n:' \
        '--head-count=+[count]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--random-source=+[file]:file:_files' \
        '-r[output lines with repetition]' \
        '--repeat[output lines with repetition]' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_shuf-cli "$@"
