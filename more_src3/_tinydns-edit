#compdef tinydns-edit
# _tinydns-edit — djbdns tinydns-edit (sequence editor for the tinydns `data` file; safely add/remove zone records that follow the standard prefixes: =/+/@/&/^/.)
# upstream: https://github.com/dterweij/ndjbdns
# Source: tinydns-edit.c on tip; positional args are: data data.new add|del LINESPEC

_tinydns-edit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '1:data-file:_files' \
        '2:data-new-file:_files' \
        '3:action:(add)' \
        '4:type:(host alias mx ns childns)' \
        '*:spec:'
}

_tinydns-edit "$@"
