#compdef stap-merge
# Documentation: man stap-merge(1)
# Source: SystemTap stap-merge — merge per-cpu binary trace files (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose (3 extra fields per data set)]' \
    '-o+[output file]:file:_files' \
    '*:stpd_cpu input files:_files -g "stpd_cpu*"' \
    && ret=0

return ret
