#compdef simg2img
# Documentation: https://android.googlesource.com/platform/system/core/+/refs/heads/main/libsparse/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# simg2img: convert Android sparse images to raw images. Upstream
# documents only positional args (input sparse images ... output).
# No documented flags beyond implicit -h.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input sparse images then output:_files' && ret=0
return ret
