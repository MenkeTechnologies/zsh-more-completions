#compdef xattr
# Documentation: https://ss64.com/mac/xattr.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-h[show help]' \
  '(-p -w -d -c)-p[print attribute value]' \
  '(-p -w -d -c)-w[write attribute value]' \
  '(-p -w -d -c)-d[delete attribute]' \
  '(-p -w -d -c)-c[clear all attributes]' \
  '-l[long format (names and values)]' \
  '-r[recurse into directories]' \
  '-s[act on the symlink itself]' \
  '-v[force filename in output]' \
  '-x[hex representation]' \
  '*:file:_files'
