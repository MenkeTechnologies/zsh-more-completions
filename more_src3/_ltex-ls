#compdef ltex-ls ltex-cli
# Documentation: https://valentjn.github.io/ltex/ltex-ls/server-usage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--endless[keep server alive after client disconnects]' \
  '--no-endless[exit after client disconnects (default)]' \
  '--server-type=[transport mode]:type:(standardStream tcpSocket)' \
  '--host=[TCP server host]:host:_hosts' \
  '--port=[TCP server port]:port:' \
  '--client-process-id=[client PID to watch]:pid:' \
  '--log-file=[log file path]:file:_files' \
  '*::path:_files' && ret=0

return ret
