#compdef hugin_hdrmerge
# Documentation: https://manpages.ubuntu.com/manpages/questing/man1/hugin_hdrmerge.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-o+[output file]:file:_files' \
  '-m+[merge mode]:mode:(avg avg_slow khan)' \
  '-i+[iterations]:n:' \
  '-c+[Khan c parameter]:val:' \
  '-s+[Khan sigma]:val:' \
  '-a[average]' \
  '-v[verbose]' \
  '*:image_files:_files -g "*.{tif,tiff,hdr,exr}"' && ret=0

return ret
