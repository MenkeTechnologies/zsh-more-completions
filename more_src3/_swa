#compdef swa
# Documentation: https://azure.github.io/static-web-apps-cli/docs/cli/swa
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (per-subcommand pages: swa-init, swa-start, swa-build, swa-deploy, swa-login).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new Azure Static Web Apps project'
  'start:run the local emulator (or bind to a dev server)'
  'build:build the project (front + API)'
  'deploy:deploy the project to Azure Static Web Apps'
  'login:authenticate with Azure'
  'db:Static Web Apps database commands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'swa command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*::name:' && ret=0 ;;
      (start)
        _arguments \
          '(-a --app-location)'{-a+,--app-location=}'[front-end app folder]:dir:_files -/' \
          '(-O --output-location)'{-O+,--output-location=}'[built front-end folder]:dir:_files -/' \
          '(-D --app-devserver-url)'{-D+,--app-devserver-url=}'[connect to app dev server URL]:url' \
          '(-i --api-location)'{-i+,--api-location=}'[API folder]:dir:_files -/' \
          '--api-devserver-url=[connect to API server URL]:url' \
          '(-j --api-port)'{-j+,--api-port=}'[API server port]:port' \
          '(-q --host)'{-q+,--host=}'[CLI dev server host]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[CLI dev server port]:port' \
          '(-s --ssl)'{-s,--ssl}'[enable HTTPS]' \
          '(-e --ssl-cert)'{-e+,--ssl-cert=}'[SSL cert path]:file:_files' \
          '(-k --ssl-key)'{-k+,--ssl-key=}'[SSL key path]:file:_files' \
          '(-r --run)'{-r+,--run=}'[startup script/command]:cmd' \
          '(-w --swa-config-location)'{-w+,--swa-config-location=}'[directory containing staticwebapp.config.json]:dir:_files -/' \
          '(-f --func-args)'{-f+,--func-args=}'[args passed to func start]:args' \
          '(-t --devserver-timeout)'{-t+,--devserver-timeout=}'[devserver timeout (seconds)]:seconds' \
          '(-o --open)'{-o,--open}'[open browser]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '*::path_or_url:' && ret=0 ;;
      (build)
        _arguments \
          '(-a --app-location)'{-a+,--app-location=}'[front-end app folder]:dir:_files -/' \
          '(-i --api-location)'{-i+,--api-location=}'[API folder]:dir:_files -/' \
          '(-O --output-location)'{-O+,--output-location=}'[built source output folder]:dir:_files -/' \
          '(-A --app-build-command)'{-A+,--app-build-command=}'[front-end build command]:cmd' \
          '(-I --api-build-command)'{-I+,--api-build-command=}'[API build command]:cmd' \
          '--auto[automatically detect how to build]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
      (deploy)
        _arguments \
          '(-a --app-location)'{-a+,--app-location=}'[front-end app folder]:dir:_files -/' \
          '(-i --api-location)'{-i+,--api-location=}'[API folder]:dir:_files -/' \
          '(-O --output-location)'{-O+,--output-location=}'[built front-end output folder]:dir:_files -/' \
          '--api-language=[runtime language of the function]:language' \
          '--api-version=[function runtime language version]:version' \
          '(-w --swa-config-location)'{-w+,--swa-config-location=}'[directory containing staticwebapp.config.json]:dir:_files -/' \
          '(-d --deployment-token)'{-d+,--deployment-token=}'[deployment token]:token' \
          '(-dr --dry-run)'{-dr,--dry-run}'[simulate deploy]' \
          '(-pt --print-token)'{-pt,--print-token}'[print deploy token]' \
          '--env=[deployment environment]:env' \
          '(-S --subscription-id)'{-S+,--subscription-id=}'[Azure subscription id]:id' \
          '(-R --resource-group)'{-R+,--resource-group=}'[Azure resource group]:group' \
          '(-T --tenant-id)'{-T+,--tenant-id=}'[Azure tenant id]:id' \
          '(-C --client-id)'{-C+,--client-id=}'[Azure client id]:id' \
          '(-CS --client-secret)'{-CS+,--client-secret=}'[Azure client secret]:secret' \
          '(-n --app-name)'{-n+,--app-name=}'[Azure Static Web App name]:name' \
          '(-CC --clear-credentials)'{-CC,--clear-credentials}'[clear stored credentials before login]' \
          '(-u --use-keychain)'{-u,--use-keychain}'[enable OS keychain]' \
          '(-nu --no-use-keychain)'{-nu,--no-use-keychain}'[disable OS keychain]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
      (login)
        _arguments \
          '(-S --subscription-id)'{-S+,--subscription-id=}'[Azure subscription id]:id' \
          '(-R --resource-group)'{-R+,--resource-group=}'[Azure resource group]:group' \
          '(-T --tenant-id)'{-T+,--tenant-id=}'[Azure tenant id]:id' \
          '(-C --client-id)'{-C+,--client-id=}'[Azure client id]:id' \
          '(-CS --client-secret)'{-CS+,--client-secret=}'[Azure client secret]:secret' \
          '(-n --app-name)'{-n+,--app-name=}'[Azure Static Web App name]:name' \
          '(-CC --clear-credentials)'{-CC,--clear-credentials}'[clear stored credentials before login]' \
          '(-u --use-keychain)'{-u,--use-keychain}'[enable OS keychain]' \
          '--no-use-keychain[disable OS keychain]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0 ;;
      (db)
        _arguments '*::sub:(init start)' && ret=0 ;;
    esac ;;
esac

return ret
