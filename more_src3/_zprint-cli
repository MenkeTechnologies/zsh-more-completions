#compdef zprint-cli
# _zprint-cli — Kim Kinnear zprint Clojure/EDN formatter CLI alias (kkinnear team, Clojure); custom argparse
# upstream: https://github.com/kkinnear/zprint

_zprint-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--zprint=+[zprint config edn]:str:' \
        '-c+[config file]:file:_files -g ".zprintrc*"' \
        '--cfg=+[config file]:file:_files -g ".zprintrc*"' \
        '--style=+[style]:s:(community indent-only respect-bl respect-nl how-to-ns sort-dependencies require-justify quote-wrap rules-of-use-ns hiccup respect-bl-blank justified backtranslate)' \
        '-s+[style]:s:(community indent-only respect-bl respect-nl how-to-ns sort-dependencies require-justify quote-wrap rules-of-use-ns hiccup respect-bl-blank justified backtranslate)' \
        '-w[width]' \
        '--width=+[width]:n:' \
        '-l[list options]' \
        '--list-options[list options]' \
        '--list-styles[list styles]' \
        '--list-set[list set options]' \
        '--list-reset[list reset]' \
        '--list-actual[list actual]' \
        '--explain[explain config]' \
        '--explain-all[explain all]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--check[check formatting]' \
        '--diff[show diff]' \
        '--diff-only[show diff only]' \
        '--url=+[url config]:url:_urls' \
        '--url-only=+[url config (only)]:url:_urls' \
        '--validate[validate config]' \
        '*:files:_files -g "*.{clj,cljs,cljc,edn}"'
}

_zprint-cli "$@"
