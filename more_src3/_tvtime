#compdef tvtime tvtime-configure tvtime-scanner tvtime-command
# Documentation: https://manpages.debian.org/bookworm/tvtime/tvtime.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm tvtime(1) manpage.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--verbose}'[verbose output]' \
  '(-a --widescreen)'{-a,--widescreen}'[16:9 widescreen mode]' \
  '(-A --nowidescreen)'{-A,--nowidescreen}'[disable widescreen mode]' \
  '(-b --vbidevice)'{-b,--vbidevice}'+[VBI device]:device:_files -g "/dev/vbi*"' \
  '(-c --channel)'{-c,--channel}'+[start channel]:channel:' \
  '(-d --device)'{-d,--device}'+[video device]:device:_files -g "/dev/video*"' \
  '(-f --frequencies)'{-f,--frequencies}'+[frequency table]:freq:(us-cable us-broadcast japan-bcast japan-cable europe france russia australia china-bcast southafrica argentina-cable canada-cable australia-optus)' \
  '(-F --configfile)'{-F,--configfile}'+[config file]:file:_files' \
  '(-g --geometry)'{-g,--geometry}'+[window geometry]:WxH:' \
  '(-i --input)'{-i,--input}'+[input number]:n:' \
  '(-I --inputwidth)'{-I,--inputwidth}'+[input width]:px:' \
  '(-k --slave)'{-k,--slave}'[slave mode]' \
  '(-l --xmltvlanguage)'{-l,--xmltvlanguage}'+[XMLTV language]:lang:' \
  '(-m --fullscreen)'{-m,--fullscreen}'[fullscreen]' \
  '(-M --window)'{-M,--window}'[windowed]' \
  '(-n --norm)'{-n,--norm}'+[TV norm]:norm:(NTSC PAL PAL-Nc PAL-M PAL-N NTSC-JP SECAM)' \
  '(-s --showdrops)'{-s,--showdrops}'[show drop frames]' \
  '(-S --saveoptions)'{-S,--saveoptions}'[save options on exit]' \
  '(-t --xmltv)'{-t,--xmltv}'+[XMLTV file]:file:_files' \
  '(-x --mixer)'{-x,--mixer}'+[mixer device:channel]:device:' \
  '(-X --display)'{-X,--display}'+[X display]:display:' && ret=0

return ret
