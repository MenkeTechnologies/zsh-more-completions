#compdef tetragon-vmtests-run vmtest-run
# _tetragon-vmtests-run — run Tetragon unit tests in VMs (cilium/tetragon)
# upstream: https://github.com/cilium/tetragon
# Flags from cmd/tetragon-vmtests-run/main.go (cobra).

_tetragon-vmtests-run() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--base=[base image filename]:file:_files' \
        '--name=[new VM name]:name:' \
        '--kernel=[kernel filename]:file:_files' \
        '--dont-rebuild-image[skip rebuilding the VM image]' \
        '--use-tetragon-init[use tetragon-vmtests-init as init]' \
        '--qemu-cmd-print[print qemu command, do not run]' \
        '--qemu-disable-kvm[skip KVM acceleration]' \
        '--just-boot[boot the VM without running tests]' \
        '--just-build-image[only build the image]' \
        '--no-poweroff[skip VM poweroff at end]' \
        '--testsfile=[file listing tests to run]:file:_files' \
        '--btf-file=[BTF file]:file:_files' \
        '--fail-fast[exit on first error]' \
        '--keep-all-logs[keep logs for passing tests too]' \
        '--disable-unified-cgroups[boot with cgroup v1]' \
        '*'{-p+,--port=}'[forward host\:vm[:proto]]:spec:' \
        '--kernel-ver=[kernel version label]:ver:' \
        '--enable-detailed-results[produce detailed test results]' \
        '--root-dev=[root device type]:dev:(hda vda)'
}

_tetragon-vmtests-run "$@"
