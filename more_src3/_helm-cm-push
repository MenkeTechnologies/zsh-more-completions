#compdef helm-cm-push
# _helm-cm-push — Helm plugin to push chart packages to ChartMuseum (chartmuseum/helm-push)
# upstream: https://github.com/chartmuseum/helm-push
# Flags from cmd/helm-cm-push/main.go (cobra/pflag).

_helm-cm-push() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --version)'{-v+,--version=}'[override chart version pre-push]:ver:' \
        '(-a --app-version)'{-a+,--app-version=}'[override app version pre-push]:ver:' \
        '(-u --username)'{-u+,--username=}'[HTTP basic auth username]:user:' \
        '(-p --password)'{-p+,--password=}'[HTTP basic auth password]:pass:' \
        '--access-token=[token sent in Authorization header]:token:' \
        '--auth-header=[alternative header for token auth]:hdr:' \
        '--context-path=[ChartMuseum context path]:path:' \
        '--ca-file=[CA bundle file]:file:_files -g "*.(pem|crt)"' \
        '--cert-file=[HTTPS client cert]:file:_files -g "*.(pem|crt)"' \
        '--key-file=[HTTPS client key]:file:_files -g "*.(pem|key)"' \
        '--keyring=[public keyring file]:file:_files' \
        '--insecure[skip TLS verification]' \
        '(-f --force)'{-f,--force}'[force upload even if version exists]' \
        '(-d --dependency-update)'{-d,--dependency-update}'[update chart dependencies before package]' \
        '--check-helm-version[print current Helm major version]' \
        '(-t --timeout)'{-t+,--timeout=}'[seconds to wait for ChartMuseum response]:secs:' \
        '1:chart path or name:_files -g "*.tgz"' \
        '2:chart repo name or URL:'
}

_helm-cm-push "$@"
