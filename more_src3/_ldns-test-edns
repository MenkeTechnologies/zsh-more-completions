#compdef ldns-test-edns
# _ldns-test-edns — NLnet Labs ldns-test-edns (probe a DNS cache to see whether it supports EDNS0 + DO + caching of RRSIG records — useful for validating a fresh DHCP-supplied resolver)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-test-edns.c usage on tip.

_ldns-test-edns() {
    _arguments \
        '-h[show help]' \
        '-i[info mode — print "off" if no IP works]' \
        '*:ip-address:'
}

_ldns-test-edns "$@"
