#compdef sendfiles
# Documentation: man sendfiles(1)
# Source: nmh etc/sendfiles (master) — send files/directories in a MIME message (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-compress[compression method]:method:(bzip2 compress gzip lzma none)' \
    '-from+[sender address]:from:_default' \
    '-to+[recipient address]:to:_email_addresses' \
    '-subject+[subject]:subject:_default' \
    '-delay+[delay seconds]:seconds:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '*:file or directory:_files' \
    && ret=0

return ret
