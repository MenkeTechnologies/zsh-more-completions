#compdef zpool-export
# _zpool-export — OpenZFS zpool export (cleanly export one or all pools so they can be imported on another host; -a exports all, -f forces (unmounts busy datasets), -F flushes cache; positional argument(s) are the pool names to export)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_export) on tip.

_zpool-export() {
    _arguments \
        '-a[export all pools]' \
        '-f[force]' \
        '-F[flush cache]' \
        '*:pool:'
}

_zpool-export "$@"
