#compdef intelmetool
# _intelmetool — coreboot intelmetool dump Intel Management Engine MEI status firmware version flash region info (coreboot team, C); custom argparse
# upstream: https://github.com/coreboot/coreboot

_intelmetool() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-m[show MEI device version]' \
        '--mei[show MEI device version]' \
        '-i[show ME info]' \
        '--info[show ME info]' \
        '-s[scan PCI devices]' \
        '--scan[scan PCI devices]' \
        '-b[show ME boot guard]' \
        '--bootguard[show ME boot guard]' \
        '-l[show ME flash layout]' \
        '--layout[show ME flash layout]' \
        '-r[unlock ME region]' \
        '--unlockme[unlock ME region]' \
        '-d[dump ME flash]' \
        '--dump[dump ME flash]' \
        '-c+[ME command]:str:' \
        '--cmd=+[ME command]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]'
}

_intelmetool "$@"
