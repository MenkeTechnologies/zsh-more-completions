#compdef xnLinkFinder xnlinkfinder
# _xnLinkFinder — Xnl-h4ck3r xnLinkFinder discover endpoints parameters URLs in scripts files JS source code (xnl-h4ck3r team, Python); argparse
# upstream: https://github.com/xnl-h4ck3r/xnLinkFinder

_xnLinkFinder() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-i+[input target]:str:' \
        '--input=+[input target]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-op+[output parameters file]:file:_files' \
        '--output-params=+[output parameters file]:file:_files' \
        '-ow+[output words file]:file:_files' \
        '--output-words=+[output words file]:file:_files' \
        '-d+[scope domain]:str:' \
        '--scope=+[scope domain]:str:' \
        '-sp+[scope path]:str:' \
        '--scope-prefix=+[scope path]:str:' \
        '-c+[cookies]:str:' \
        '--cookies=+[cookies]:str:' \
        '-H+[extra header]:str:' \
        '--headers=+[extra header]:str:' \
        '-x+[exclusions csv]:str:' \
        '--exclude=+[exclusions csv]:str:' \
        '-r+[regex file]:file:_files' \
        '--regex=+[regex file]:file:_files' \
        '-m+[max depth]:n:' \
        '--depth=+[max depth]:n:' \
        '-mfs+[max file size kb]:n:' \
        '--max-file-size=+[max file size kb]:n:' \
        '-t+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-T+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '-p+[proxy url]:url:_urls' \
        '--proxy=+[proxy url]:url:_urls' \
        '-u+[user agent]:str:' \
        '--user-agent=+[user agent]:str:' \
        '-orig[include all originals]' \
        '--origin[include all originals]' \
        '-inc[include js scripts]' \
        '--include-scripts[include js scripts]' \
        '-vh[verify https]' \
        '--verify-https[verify https]' \
        '-sf[scope filter]' \
        '-stq+[scope tracker query]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--no-banner[no banner]'
}

_xnLinkFinder "$@"
