#compdef scsynth supernova
# _scsynth — James McCartney SuperCollider scsynth and supernova real-time audio synthesis engines OSC controlled (supercollider team, C++); custom argparse
# upstream: https://github.com/supercollider/supercollider

_scsynth() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-u+[udp port]:port:_ports' \
        '-t+[tcp port]:port:_ports' \
        '-B+[bind address]:host:_hosts' \
        '-c+[max audio bus channels]:n:' \
        '-a+[max audio bus channels]:n:' \
        '-i+[input channels]:n:' \
        '-o+[output channels]:n:' \
        '-d+[default group]:n:' \
        '-D+[load synthdefs]:b:(0 1)' \
        '-R+[publish to rendezvous]:b:(0 1)' \
        '-l+[max logins]:n:' \
        '-p+[password]:str:' \
        '-N+[NRT cmd file]:file:_files' \
        '-H+[hardware device]:str:' \
        '-S+[hw sample rate]:n:' \
        '-b+[block size]:n:' \
        '-z+[hw block size]:n:' \
        '-Z+[hw buffer size]:n:' \
        '-w+[wire buffers]:n:' \
        '-r+[random number generators]:n:' \
        '-n+[max nodes]:n:' \
        '-s+[max synths]:n:' \
        '-m+[real time memory]:n:' \
        '-V+[verbosity]:n:' \
        '-v+[verbose mode]:n:' \
        '-T+[thread count]:n:' \
        '-C+[server control bus channels]:n:' \
        '-U+[ugen plugins path]:dir:_files -/' \
        '-P+[restricted dir]:dir:_files -/' \
        '-M+[memory pools]:n:' \
        '-G+[max gpu textures]:n:'
}

_scsynth "$@"
