#compdef langfuse-cli
# Documentation: https://github.com/langfuse/langfuse-cli
# Reference accessed: 2026-05-23
# Verified: langfuse-cli package (see also _langfuse).

# Zsh completion for langfuse-cli - Langfuse OpenAPI agent CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:invoke any Langfuse API endpoint'
  'get-skill:print agent skill file'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--public-key[Langfuse public key]:key:' \
  '--secret-key[Langfuse secret key]:key:' \
  '--host[Langfuse host URL]:url:' \
  '--env[load env from file]:file:_files' \
  '--profile[named config profile]:profile:' \
  '--json[output JSON]' \
  '--curl[print curl command]' \
  '--limit[pagination limit]:n:' \
  '--refetch-api-spec[refetch OpenAPI spec]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'langfuse command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      api)
        if (( CURRENT == 3 )); then
          _values 'api resource' \
            '__schema' traces observations sessions prompts datasets \
            'dataset-items' 'score-v2s' projects members organizations && ret=0
        elif (( CURRENT == 4 )); then
          _values 'api action' list get create update delete && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
