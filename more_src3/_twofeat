#compdef twofeat
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/twofeat.html
# Reference accessed: 2026-05-21
# Verified: EMBOSS 6.6 twofeat application qualifier reference.

# EMBOSS twofeat: find neighbouring pairs of features in sequence(s)
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output report]:file:_files' \
  '-sequence=[sequence(s) with features]:file:_files' \
  '-atype=[type of first feature]:type:' \
  '-btype=[type of second feature]:type:' \
  '-minrange=[minimum distance between features]:n:' \
  '-maxrange=[maximum distance between features]:n:' \
  '-asource=[source of first feature]:source:' \
  '-asense=[sense of first feature]:sense:(0 + -)' \
  '-aminscore=[min score for feature A]:score:' \
  '-amaxscore=[max score for feature A]:score:' \
  '-atag=[tag for feature A]:tag:' \
  '-avalue=[tag value for feature A]:value:' \
  '-bsource=[source of second feature]:source:' \
  '-bsense=[sense of second feature]:sense:(0 + -)' \
  '-bminscore=[min score for feature B]:score:' \
  '-bmaxscore=[max score for feature B]:score:' \
  '-btag=[tag for feature B]:tag:' \
  '-bvalue=[tag value for feature B]:value:' \
  '-twoout[write two output features per pair]' \
  '-typeout=[output feature type]:type:' \
  '-overlap=[allowed overlap]:overlap:(A O NO NW AW BW)' \
  '-rangetype=[range type]:rangetype:(N L R F)' \
  '-sense=[required sense relationship]:sense:(A S O)' \
  '-order=[feature order]:order:(A AB BA)' \
  '*:sequence:_files' && ret=0

return ret
