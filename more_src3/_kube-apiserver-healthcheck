#compdef kube-apiserver-healthcheck
# _kube-apiserver-healthcheck — kOps healthcheck sidecar that probes /healthz on the local kube-apiserver using a control-plane client cert
# upstream: https://github.com/kubernetes/kops
# Flags from cmd/kube-apiserver-healthcheck/main.go on tip.

_kube-apiserver-healthcheck() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--client-cert=[path to client certificate]:file:_files' \
        '--client-key=[path to client key]:file:_files' \
        '--ca-cert=[path to CA certificate]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_kube-apiserver-healthcheck "$@"
