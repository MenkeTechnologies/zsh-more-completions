#compdef s6-sudo s6-sudoc s6-sudod
# Documentation: source-direct extraction from upstream skarnet/s6
# src/conn-tools/s6-sudo{,c,d}.c USAGE strings + subgetopt_r
# option-string specs + case-arm decoding for -e (no-env transmit),
# -0/-1/-2/-d (per-fd null-redirect bitmask in s6-sudod) via gh
# api.
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 ucspi-sudo R122a — 3-stem multi-binary harvest of the
# s6 UCSPI-sudo privilege-escalation framework. s6-sudo (client),
# s6-sudoc (UCSPI-client half — internal, invoked by s6-sudo),
# s6-sudod (server-side prog runner — invoked under s6-ipcserver).
# Sister tools to R121's _s6-ipcclient family.

case $service in

  s6-sudo)
    # Client: connect to an s6-sudod server via UNIX socket and ask
    # it to run a privileged command on the client's behalf.
    _arguments -s -S \
      '(-q -Q -v)-q[quiet; suppress informational messages]' \
      '(-q -Q -v)-Q[very quiet; suppress error messages too]' \
      '(-q -Q -v)-v[verbose; print connection info to stderr]' \
      '-p+[local socket path to bind from before connecting]:bindpath:_files' \
      '-l+[local name to set in PROTO_LOCAL]:localname:_hosts' \
      '-e[do NOT transmit the environment to the remote prog]' \
      '-t+[connection setup timeout in ms]:ms:' \
      '-T+[total run timeout in ms (until prog exits)]:ms:' \
      '1:s6-sudod socket path:_files' \
      '*:remote program and arguments:_command_names -e'
    ;;

  s6-sudoc)
    # UCSPI-client half of s6-sudo: typically not invoked directly.
    # s6-sudo execs s6-sudoc after the UCSPI client handshake. Reads
    # the protocol fds from the env (UCSPI conventions).
    _arguments -s -S \
      '-e[do NOT transmit the environment to the remote prog]' \
      '-t+[connection setup timeout in ms (timeoutconn)]:ms:' \
      '-T+[total run timeout in ms (until prog exits)]:ms:' \
      '*:remote program and arguments:_command_names -e'
    ;;

  s6-sudod)
    # Server-side runner: invoked under s6-ipcserver to actually run
    # the requested program with the server's privileges.
    # -0/-1/-2 are independent null-redirect bits; -d sets all four
    # at once (stdin + stdout + stderr + stdin2 control fd).
    _arguments -s -S \
      '-0[null-redirect stdin (do not proxy to client)]' \
      '-1[null-redirect stdout (do not proxy to client)]' \
      '-2[null-redirect stderr (do not proxy to client)]' \
      '-d[null-redirect all four proxied fds (equivalent to -0 -1 -2 + control)]' \
      '-t+[client inactivity timeout in ms]:ms:' \
      '*:program and arguments:_command_names -e'
    ;;

esac
