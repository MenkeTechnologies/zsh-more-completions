#compdef i2prouter
# Documentation: https://manpages.debian.org/buster/i2p/i2prouter.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# i2prouter — start and stop the I2P router (Java I2P, i2p/i2p.i2p)

local curcontext="$curcontext" ret=1
_arguments -C \
  '1:action:(console start stop restart graceful condrestart status dump install remove)' && ret=0
return ret
