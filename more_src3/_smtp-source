#compdef smtp-source
# Documentation: man smtp-source(1)
# Source: vdukhovni/postfix smtpstone/smtp-source.c (master) — Postfix SMTP/LMTP load generator (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[allow REJECT responses without aborting]' \
    '-c[show counter every second]' \
    '-C+[connection count (parallel connections)]:N:_default' \
    '-d[disable disconnect after each session]' \
    '-f+[sender address]:from:_default' \
    '-F+[message file (raw RFC822)]:file:_files' \
    '-l+[message length in bytes]:bytes:_default' \
    '-L[talk LMTP instead of SMTP]' \
    '-m+[message count per session]:N:_default' \
    '-M+[HELO name (myhostname)]:hostname:_hosts' \
    '-N[append global recipient suffix]' \
    '-o[no HELO; no headers]' \
    '-r+[recipients per message]:N:_default' \
    '-R+[random delay between sessions (sec)]:seconds:_default' \
    '-s+[number of sessions]:N:_default' \
    '-S+[message Subject]:subject:_default' \
    '-t+[recipient address]:to:_default' \
    '-T+[TCP window size]:bytes:_default' \
    '*-v[verbose (stackable)]' \
    '-w+[fixed delay between sessions (sec)]:seconds:_default' \
    '1:host[\:port]:_hosts' \
    && ret=0

return ret
