#compdef sshs
# Documentation: https://github.com/quantumsheep/sshs/blob/main/src/main.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sshs - SSH connection manager TUI.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-c,--config}'[path to SSH configuration file]:config file:_files' \
  '--show-proxy-command[show ProxyCommand]' \
  '(-s --search)'{-s,--search}'[host search filter]:filter:' \
  '--sort[sort hosts by hostname]' \
  '--sort-fancy[fancy Levenshtein sort by edit distance]' \
  '(-t --template)'{-t,--template}'[handlebars template of command to execute]:template:' \
  '--on-session-start-template=[template to run when SSH session starts]:template:' \
  '--on-session-end-template=[template to run when SSH session ends]:template:' \
  '(-e --exit)'{-e,--exit}'[exit after ending SSH session]'
