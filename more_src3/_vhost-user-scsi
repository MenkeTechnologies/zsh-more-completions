#compdef vhost-user-scsi
# Documentation: https://github.com/qemu/qemu/blob/master/contrib/vhost-user-scsi/vhost-user-scsi.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (QEMU contrib vhost-user-scsi daemon).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --print-capabilities)'{-c,--print-capabilities}'[print capabilities in JSON]' \
  '(-f --fd)'{-f+,--fd=}'[inherited file descriptor number for the socket]:fd:' \
  '(-i --iscsi-uri)'{-i+,--iscsi-uri=}'[iSCSI URI to connect to]:uri:' \
  '(-s --socket-path)'{-s+,--socket-path=}'[UNIX socket path]:file:_files' && ret=0
return ret
