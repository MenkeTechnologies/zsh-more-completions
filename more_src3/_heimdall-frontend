#compdef heimdall-frontend
# Documentation: https://github.com/Benjamin-Dobell/Heimdall
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# heimdall-frontend: Qt GUI for Heimdall (Samsung Odin replacement)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' \
  '*::heimdall-frontend args:_files' && ret=0
return ret
