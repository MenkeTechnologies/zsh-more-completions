#compdef webots
# Documentation: https://cyberbotics.com/doc/guide/starting-webots
# Documentation: https://github.com/cyberbotics/webots/blob/master/docs/guide/starting-webots.md
# Reference accessed: 2026-05-27
# Verified: upstream Webots User Guide "Starting Webots" command-line options

local -a arguments

arguments=(
  '(- *)--help[display help message and exit]'
  '(- *)--version[display version information and exit]'
  '(- *)--sysinfo[display information about the system and exit]'
  '--mode=[choose startup mode]:mode:(pause realtime run fast)'
  '--no-rendering[disable rendering in the main 3D view]'
  '--fullscreen[start Webots in fullscreen]'
  '--minimize[minimize the Webots window on startup]'
  '--batch[prevent Webots from creating blocking pop-up windows]'
  '--clear-cache[clear the cache of Webots on startup]'
  '--stdout[redirect the stdout of the controllers to the terminal]'
  '--stderr[redirect the stderr of the controllers to the terminal]'
  '--port=[change the TCP port used by Webots (default 1234)]:port:'
  '--stream=-[enable streaming server]:mode:(w3d mjpeg)'
  '--extern-urls[print URLs of extern controllers to stdout]'
  '--heartbeat=-[print periodic dots to stdout at given interval]:ms:'
  '--log-performance=[log Webots performance metrics to file]:spec:'
  '*:world file:_files -g "*.wbt"'
)

_arguments -s -S $arguments
