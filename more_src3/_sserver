#compdef sserver
# Documentation: https://web.mit.edu/kerberos/krb5-1.19/doc/admin/admin_commands/sserver.html
# Reference accessed: 2026-05-21
# Verified: upstream MIT Kerberos docs at the URL above.
# Removed fabricated -h/-l flags (sserver only documents -p, -S, and an
# optional positional server_port).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-p+[port to listen on]:port' \
  '-S+[alternate keytab file]:keytab:_files' \
  '*:server_port:' && ret=0

return ret
