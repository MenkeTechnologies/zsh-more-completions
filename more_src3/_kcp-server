#compdef kcp-server
# _kcp-server — kcp Kubernetes-like Control Plane (kcp-dev/kcp)
# upstream: https://github.com/kcp-dev/kcp
# Subcommands + flags from cmd/kcp/{kcp,options}/ on tip.

_kcp-server() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the control-plane process'
            )
            _describe -t commands 'kcp command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--root-directory=[root directory for state/certs (empty disables on-disk gen)]:dir:_files -/' \
                        '--miniproxy-mapping-file=[DEV-ONLY mini-front-proxy mapping file]:file:_files' \
                        '--secure-port=[HTTPS bind port (0 disables)]:port:' \
                        '--bind-address=[HTTPS bind address]:ip:' \
                        '--tls-cert-file=[TLS server certificate]:file:_files' \
                        '--tls-private-key-file=[TLS server private key]:file:_files' \
                        '--client-ca-file=[client-cert CA bundle]:file:_files' \
                        '--audit-log-path=[audit log file path]:file:_files' \
                        '--audit-policy-file=[audit policy YAML file]:file:_files' \
                        '*--etcd-servers=[etcd endpoint URLs]:url:_urls' \
                        '--etcd-cafile=[etcd CA cert]:file:_files' \
                        '--etcd-certfile=[etcd client cert]:file:_files' \
                        '--etcd-keyfile=[etcd client key]:file:_files' \
                        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
                        '-v[klog verbosity level]:n:' \
                        '--logtostderr[log to stderr]'
                    ;;
            esac
            ;;
    esac
}

_kcp-server "$@"
