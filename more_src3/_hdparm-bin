#compdef hdparm
# _hdparm-bin — hdparm ATA/SATA disk parameter set/get tool (Mark Lord, C); SMART, security erase, power management, identify
# upstream: https://sourceforge.net/projects/hdparm

_hdparm-bin() {
    _arguments \
        '-a+[set/get readahead sectors]:n:' \
        '-A+[disable/enable read-lookahead]:bool:(0 1)' \
        '-b+[set/get bus state]:bool:(0 1)' \
        '-B+[set APM level]:n:' \
        '-c+[set/get 32-bit IO]:str:' \
        '-C[show drive power mode status]' \
        '-d+[set/get DMA]:bool:(0 1)' \
        '-D+[enable/disable drive defect mgmt]:bool:(0 1)' \
        '-E+[set CD-ROM speed]:n:' \
        '-f[flush buffer cache]' \
        '-F[flush write cache]' \
        '-g[print drive geometry]' \
        '-h[show help]' \
        '-H[read temperature]' \
        '-i[show drive identification]' \
        '-I[show extended drive identification]' \
        '-k+[set keep_settings on reset]:bool:(0 1)' \
        '-K+[set keep features on reset]:bool:(0 1)' \
        '-L+[lock door]:bool:(0 1)' \
        '-M+[acoustic management]:n:' \
        '-N+[max addressable sectors]:n:' \
        '-p+[set PIO mode]:mode:' \
        '-P+[set sector count for multi-sector reads]:n:' \
        '-Q+[set NCQ depth]:n:' \
        '-r+[set/get read-only]:bool:(0 1)' \
        '-R+[register access]:str:' \
        '-s+[set power-up in standby]:bool:(0 1)' \
        '-S+[set standby timer]:n:' \
        '-t[perform device read timing]' \
        '-T[perform cache read timing]' \
        '-u+[set unmaskirq]:bool:(0 1)' \
        '-U+[unregister access]:str:' \
        '-v[show /proc/ide/X/settings]' \
        '-V[show version]' \
        '-W+[set write-caching]:bool:(0 1)' \
        '-X+[set DMA mode]:mode:' \
        '-y[place drive in standby mode]' \
        '-Y[place drive in sleep mode]' \
        '-Z[disable Seagate auto powersave]' \
        '-z[reread partition table]' \
        '--direct[use O_DIRECT for read timings]' \
        '--drq-hsm-error[reset HSM error]' \
        '--fwdownload+[firmware file]:file:_files' \
        '--Istdin[read identify from stdin]' \
        '--Istdout[write identify to stdout]' \
        '--idle-immediate[place drive in idle state]' \
        '--make-bad-sector+[bad sector]:n:' \
        '--prefer-ata12[force ATA-12]' \
        '--read-sector+[read sector]:n:' \
        '--repair-sector+[repair sector]:n:' \
        '--security-disable+[password]:pw:' \
        '--security-erase+[password]:pw:' \
        '--security-erase-enhanced+[password]:pw:' \
        '--security-freeze[freeze security]' \
        '--security-help[print security help]' \
        '--security-master[use master password]' \
        '--security-mode+[mode]:mode:(high maximum)' \
        '--security-set-pass+[password]:pw:' \
        '--security-unlock+[password]:pw:' \
        '--sleep[set sleep mode]' \
        '--trim-sector-ranges+[trim ranges]:str:' \
        '--verbose[verbose]' \
        '--write-sector+[write sector]:n:' \
        '*:device:_files'
}

_hdparm-bin "$@"
