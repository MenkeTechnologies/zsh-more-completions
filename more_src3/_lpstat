#compdef lpstat lpq lprm lpoptions lpadmin
# Documentation: https://www.cups.org/doc/man-{lpstat,lpq,lprm,lpoptions,lpadmin}.html
# Reference accessed: 2026-05-30
# CUPS print-management family. Multi-stem covers 5 client/admin binaries
# that share `-E` (force encryption), `-h server[:port]`, and `-U username`
# CUPS-server flags, but otherwise diverge in their job vs printer focus.

local curcontext="$curcontext" state line ret=1

# Helper: complete printer/queue names from `lpstat -p` output.
_lp_printers() {
  local -a names
  names=( ${(f)"$(lpstat -p 2>/dev/null | awk '/^printer/ {print $2}')"} )
  _describe -t printers 'printer' names
}

case $service in

  lpstat)
    _arguments -s -S \
      '-E[force encryption to the CUPS server]' \
      '-H[show server hostname + port]' \
      '-R[show ranking of print jobs]' \
      '-U+[alternate CUPS username]:user:_users' \
      '-W+[job filter]:which:(completed not-completed)' \
      '-a+[show accepting state of queues]:printer:_lp_printers' \
      '-c+[show classes + member printers]:class:' \
      '-d[show current default destination]' \
      '-e[show all destinations on local network]' \
      '-h+[alternate CUPS server (host:port)]:server:_hosts' \
      '-l[long listing]' \
      '-o+[show jobs queued on destination(s)]:destination:_lp_printers' \
      '-p+[show printers + status]:printer:_lp_printers' \
      '-r[show whether CUPS server is running]' \
      '-s[summary (-d + -c + -v)]' \
      '-t[all status info]' \
      '-u+[jobs queued by user(s)]:user:_users' \
      '-v+[show printers + device URIs]:printer:_lp_printers' \
      && ret=0
    ;;

  lpq)
    _arguments -s -S \
      '-E[force encryption to the CUPS server]' \
      '-P+[printer/class name]:printer:_lp_printers' \
      '-U+[alternate CUPS username]:user:_users' \
      '-a[report jobs on all printers]' \
      '-h+[alternate CUPS server]:server:_hosts' \
      '-l[long-format report]' \
      '+:continuous polling interval:' \
      '*:job-id:' \
      && ret=0
    ;;

  lprm)
    _arguments -s -S \
      '-E[force encryption to the CUPS server]' \
      '-P+[printer/class name]:printer:_lp_printers' \
      '-U+[alternate CUPS username]:user:_users' \
      '-h+[alternate CUPS server]:server:_hosts' \
      '-[cancel all queued jobs]' \
      '*:job-id:' \
      && ret=0
    ;;

  lpoptions)
    _arguments -s -S \
      '-E[enable encryption with CUPS server]' \
      '-d+[set user default destination (printer[/instance])]:destination:_lp_printers' \
      '-h+[alternate CUPS server]:server:_hosts' \
      '-l[list printer-specific options + current settings]' \
      '*-o+[set option (name[=value])]:option:' \
      '-p+[target destination[/instance] for following options]:destination:_lp_printers' \
      '-r+[remove named option]:option:' \
      '-x+[remove all options for destination[/instance]]:destination:_lp_printers' \
      && ret=0
    ;;

  lpadmin)
    _arguments -s -S \
      '-c+[add printer to class]:class:' \
      '-d+[set default destination]:destination:_lp_printers' \
      '-p+[configure named printer/class]:destination:' \
      '-x+[delete printer/class]:destination:_lp_printers' \
      '-r+[remove printer from class]:class:' \
      '-m+[PPD model file]:model:' \
      '*-o+[set option (name=value)]:option:' \
      '*-R+[delete named option (use `-default` suffix)]:option:' \
      '-u+[user-level access control]:expr:' \
      '-v+[device URI]:uri:' \
      '-D+[textual description]:info:' \
      '-E[enable encryption / enable destination]' \
      '-L+[textual location]:loc:' \
      '-U+[alternate CUPS username]:user:_users' \
      '-h+[alternate CUPS server]:server:_hosts' \
      '-i+[(deprecated) interface script or PPD file]:file:_files' \
      '-P+[(deprecated) PPD file]:file:_files -g "*.ppd"' \
      && ret=0
    ;;

esac

return ret
