#compdef hookdeck
# Documentation: https://hookdeck.com/docs/cli

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'listen:forward webhooks to local server'
  'login:authenticate with Hookdeck'
  'logout:remove stored credentials'
  'whoami:show current user info'
  'ci:manage CI integrations'
  'completion:generate shell completion scripts'
  'version:print version'
)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--api-key=[Hookdeck API key]:key:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'hookdeck command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (listen)
        _arguments -s -S \
          '--help[show help]' \
          '--api-key=[API key]:key:' \
          '--cli-path=[path to CLI binary]:path:_files' \
          '1:port:' \
          '2:source label:' && ret=0
        ;;
      (login)
        _arguments -s -S \
          '--help[show help]' \
          '--api-key=[API key to use for login]:key:' && ret=0
        ;;
      (completion)
        _arguments -s -S \
          '--help[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
