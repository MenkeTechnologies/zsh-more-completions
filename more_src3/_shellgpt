#compdef shellgpt shell-gpt
# _shellgpt — Farkhod Sadykov shell-gpt sgpt long-form CLI for ChatGPT and local LLMs role-based prompt management (TheR1D team, Python); typer
# upstream: https://github.com/TheR1D/shell_gpt

_shellgpt() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--model=+[model]:m:(gpt-4o gpt-4o-mini gpt-4-turbo gpt-4 gpt-3.5-turbo claude-3-opus claude-3-sonnet claude-3-haiku claude-3.5-sonnet llama3 llama2 mistral codellama)' \
        '-m+[model]:m:(gpt-4o gpt-4o-mini gpt-4-turbo gpt-4 gpt-3.5-turbo)' \
        '--temperature=+[F]:f:' \
        '-t+[F]:f:' \
        '--top-probability=+[F]:f:' \
        '-p+[F]:f:' \
        '--md[markdown render]' \
        '--no-md[no markdown render]' \
        '--editor[open in editor]' \
        '-e[open in editor]' \
        '--cache[use cache]' \
        '--no-cache[disable cache]' \
        '--shell[shell command output]' \
        '-s[shell command output]' \
        '--interaction[interactive shell mode]' \
        '--no-interaction[no interactive]' \
        '--describe-shell[describe shell command]' \
        '-d[describe shell command]' \
        '--code[code output mode]' \
        '-c[code output mode]' \
        '--functions[enable function calling]' \
        '--no-functions[disable function calling]' \
        '--repl=+[session name]:str:' \
        '--repl-id=+[repl id]:str:' \
        '--chat=+[session name]:str:' \
        '--list-chats[list chat sessions]' \
        '-lc[list chat sessions]' \
        '--show-chat=+[session name]:str:' \
        '--role=+[role name]:str:' \
        '--create-role=+[role name]:str:' \
        '--show-role=+[role name]:str:' \
        '--list-roles[list roles]' \
        '-lr[list roles]' \
        '--install-completion=+[shell]:s:(bash zsh fish)' \
        '--show-completion=+[shell]:s:(bash zsh fish)' \
        '--install-integration[install shell integration]' \
        '*:prompt:'
}

_shellgpt "$@"
