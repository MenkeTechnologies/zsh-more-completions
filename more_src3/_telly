local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _telly_log_levels
_telly_log_levels=(
    'debug:debug-level logging'
    'info:info-level logging (default)'
    'warn:warn-level logging'
    'error:error-level logging'
    'fatal:fatal-level logging'
)

_arguments -C \
    '--discovery.device-id=[8 alpha-numeric chars to uniquely identify device]:id:_default' \
    '--discovery.device-friendly-name=[name exposed via discovery]:name:_default' \
    '--discovery.device-auth=[auth token (do not change unless you know what)]:token:_default' \
    '--discovery.device-manufacturer=[manufacturer exposed via discovery]:manufacturer:_default' \
    '--discovery.device-model-number=[model number exposed via discovery]:model:_default' \
    '--discovery.device-firmware-name=[firmware name exposed via discovery]:firmware:_default' \
    '--discovery.device-firmware-version=[firmware version exposed via discovery]:version:_default' \
    '--discovery.ssdp[enable SSDP announcement on local network (default true)]' \
    '--filter.regex-inclusive[regex is inclusive (whitelist) vs exclusive (blacklist)]' \
    '--filter.regex=[regex pattern for channel filtering (default .*)]:pattern:_default' \
    '(-l --web.listen-address)'{-l+,--web.listen-address=}'[address to listen on (default localhost:6077)]:host\:port:_default' \
    '(-b --web.base-address)'{-b+,--web.base-address=}'[address to expose via discovery (for reverse proxy)]:host\:port:_default' \
    '--log.level=[log severity (debug/info/warn/error/fatal)]:level:(debug info warn error fatal)' \
    '--log.requests[log HTTP requests]' \
    '--iptv.playlist=[path to M3U file or URL]:m3u path or URL:_files -g "*.{m3u,m3u8}"' \
    '--iptv.streams=[number of concurrent streams (default 1)]:n:_default' \
    '--iptv.starting-channel=[starting channel number (default 10000)]:n:_default' \
    '--iptv.xmltv-channels[use channel numbers from XMLTV (default true)]' \
    '(-c --config.file)'{-c+,--config.file=}'[config file path (overrides all flags + env)]:config file:_files -g "*.{conf,toml,yaml,yml,json}"' \
    '(- *)--version[show application version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
