# -----------------------------------------------------------------------------
#
# WHAT IS spf13/viper AND WHY IS IT THE 65TH GO CLI LIBRARY?
#
# viper (https://github.com/spf13/viper, 30,276+ stars, top-25 Go
# GitHub project) is **Steve Francia's "Go configuration with fangs"**
# — the dominant Go library for layered application configuration.
# Where simpler tools handle one file or one source, viper is
# purpose-built for the production case of layering multiple config
# sources with deterministic priority semantics + REMOTE KEY-VALUE
# STORE backends + HOT-RELOAD on file changes.
#
# viper's distinguishing characteristics:
#
#   1. GLOBAL SINGLETON + NewViper() — viper exposes both a global
#      configuration singleton (via viper.SetConfigName, viper.
#      ReadInConfig, viper.GetString) AND a per-instance NewViper()
#      constructor for isolated configurations:
#
#          import "github.com/spf13/viper"
#
#          // Global usage (most common):
#          viper.SetConfigName("config")        // file name (no ext)
#          viper.SetConfigType("yaml")           // optional: explicit format
#          viper.AddConfigPath("/etc/myapp/")
#          viper.AddConfigPath("$HOME/.myapp")
#          viper.AddConfigPath(".")
#          viper.SetEnvPrefix("MYAPP")           // env-var prefix
#          viper.AutomaticEnv()                  // auto-bind env vars
#
#          if err := viper.ReadInConfig(); err != nil {
#              if _, ok := err.(viper.ConfigFileNotFoundError); !ok {
#                  panic(err)
#              }
#          }
#
#          // Access config values:
#          dbURL := viper.GetString("database.url")
#          port := viper.GetInt("server.port")
#          debug := viper.GetBool("debug")
#
#          // Per-instance (for libraries):
#          v := viper.New()
#          v.SetConfigName("lib-config")
#          ...
#
#      Compare:
#         * Rust config-rs (R629): builder pattern only
#         * Go knadh/koanf: per-instance only
#         * Go kelseyhightower/envconfig: env-vars only
#         * Node cosmiconfig: file discovery only
#         * viper: GLOBAL SINGLETON + per-instance NewViper()
#      FIRST documented Go Axis 13 library with global-singleton
#      pattern as primary API.
#
#   2. 7+ FILE FORMAT BACKENDS — viper supports more formats than
#      most config libraries via auto-detected file extensions:
#         * TOML (.toml)
#         * YAML (.yaml, .yml)
#         * JSON (.json)
#         * HCL — HashiCorp Configuration Language (.hcl, .tfvars)
#         * INI (.ini)
#         * envfile (.env) — dotenv-style files
#         * Java Properties (.properties)
#         * Custom via SetConfigType + RegisterFormat
#
#      The HCL backend is unique among config libraries — directly
#      supports HashiCorp's config language used by Terraform / Nomad
#      / Vault / Consul configs.
#      Compare:
#         * Rust config-rs (R629): 7 formats (TOML/YAML/JSON/JSON5/
#                                    INI/RON/custom)
#         * Go knadh/koanf: 7+ formats via providers
#         * Go envconfig: env-vars only
#         * Node cosmiconfig: TOML/YAML/JSON/JS/CJS/MJS
#         * viper: 7+ formats including HCL + Java Properties
#      FIRST documented Go Axis 13 library with HCL + Java
#      Properties file format support.
#
#   3. PFLAG/COBRA INTEGRATION via BindPFlags — viper has first-
#      class integration with spf13/pflag (cobra's flag library):
#
#          import (
#              "github.com/spf13/cobra"
#              "github.com/spf13/pflag"
#              "github.com/spf13/viper"
#          )
#
#          var rootCmd = &cobra.Command{ Use: "myapp" }
#
#          func init() {
#              rootCmd.PersistentFlags().String("config", "",
#                  "config file path")
#              rootCmd.PersistentFlags().StringP("log-level", "l",
#                  "info", "log level")
#              rootCmd.PersistentFlags().Int("port", 8080, "server port")
#
#              // Bind ALL pflags to viper config keys:
#              viper.BindPFlags(rootCmd.PersistentFlags())
#
#              // Now `viper.GetString("log-level")` returns CLI value
#              // OR env var OR config file OR default, in that priority
#          }
#
#      This integration is unique to the spf13 trinity (pflag/cobra/
#      viper) and is why viper has the dominant adoption in Go CLI
#      tooling.  Compare:
#         * Rust config-rs (R629): no clap integration (manual)
#         * Go envconfig: env-vars only
#         * Node cosmiconfig: no CLI integration
#         * viper: BindPFlags + BindPFlag + Cobra integration
#      FIRST documented Go Axis 13 library with first-class pflag/
#      cobra CLI-flag integration via BindPFlags.
#
#   4. REMOTE KEY-VALUE STORE BACKENDS — viper supports loading
#      config from REMOTE etcd/consul/Firestore via viper.
#      AddRemoteProvider:
#
#          import "github.com/spf13/viper"
#          import _ "github.com/spf13/viper/remote"
#
#          viper.AddRemoteProvider("consul",
#              "http://consul.local:8500", "/config/myapp")
#          viper.SetConfigType("yaml")
#
#          if err := viper.ReadRemoteConfig(); err != nil {
#              panic(err)
#          }
#
#          // Watch for changes:
#          viper.WatchRemoteConfig()
#
#      This lets distributed services load configuration from a
#      central KV store with hot-reload on changes.  Compare:
#         * Rust config-rs (R629): no remote KV stores
#         * Go knadh/koanf: remote via separate providers
#         * Node cosmiconfig: local-only file discovery
#         * viper: BUILT-IN remote KV store support
#      FIRST documented Go Axis 13 library with built-in remote
#      key-value store (etcd/consul/Firestore) backends.
#
#   5. STEVE FRANCIA TRINITY PROVENANCE — viper is by Steve Francia
#      (spf13 on GitHub, also author of cobra, hugo, pflag, fork-
#      cleaner).  The spf13 TRINITY:
#         * pflag — POSIX/GNU-style argument parsing
#         * cobra — CLI subcommand framework
#         * viper — layered configuration
#      together form the foundation of the dominant Go CLI tooling
#      ecosystem.  Major projects built on the trinity:
#         * Hugo — static site generator (75k+ stars)
#         * kubectl — Kubernetes CLI
#         * Helm — Kubernetes package manager (27k+ stars)
#         * Istio — service mesh
#         * etcd — distributed KV store
#         * OpenShift — Kubernetes distribution
#         * GitHub CLI (gh) — official GitHub command line
#         * Cobra-based CLIs across the entire Go ecosystem
#         * tellytv/telly (THIS — IPTV proxy)
#         * digitalocean/doctl (DO CLI)
#         * konstructio/kubefirst (K8s installer)
#         * irccloud/irccat (IRC bot)
#         * 50,000+ Go applications use cobra+viper combined
#      Steve Francia is at Google as the Go ecosystem lead since
#      ~2018.  FIRST documented Go Axis 13 library with this
#      specific Steve-Francia + spf13-trinity provenance.
#
# viper's relationship to other Axis 13 libraries:
#
#   * Unlike config-rs (R629, Rust) — config-rs is builder pattern
#                                       with serde deserialization;
#                                       viper is global-singleton +
#                                       per-instance with type-
#                                       coerced GetString/GetInt/
#                                       GetBool getters
#   * Closest analogs:
#         * Go knadh/koanf — modern alternative (different design)
#         * Go kelseyhightower/envconfig — env-vars only (narrower)
#         * Node cosmiconfig — file discovery only
#         * Node conf — Sindre Sorhus's simple persistent config
#         * Node node-config — similar layered approach
#         * Python dynaconf — similar layered approach
#         * Python hydra-core — Facebook's complex configs
#     viper is the FIRST documented Go Axis 13 library providing
#     7+ file formats (including HCL/Java Properties) + pflag/
#     cobra integration via BindPFlags + remote key-value store
#     backends + spf13-trinity ecosystem provenance.
#
# -----------------------------------------------------------------------------
#
# THE telly CLI — spf13/pflag + viper + ssdp + xmltv + m3u
#
# telly's CLI is in main.go.  Uses spf13/pflag flag definitions
# bound to viper:
#
#     import (
#         "github.com/sirupsen/logrus"
#         "github.com/spf13/viper"
#         flag "github.com/spf13/pflag"
#     )
#
#     func init() {
#         flag.String("discovery.device-id", "12345678", "...")
#         flag.String("discovery.device-friendly-name", "telly", "...")
#         flag.String("discovery.device-auth", "telly123", "...")
#         flag.String("discovery.device-manufacturer", "Silicondust", "...")
#         flag.String("discovery.device-model-number", "HDTC-2US", "...")
#         flag.String("discovery.device-firmware-name", "hdhomeruntc_atsc", "...")
#         flag.String("discovery.device-firmware-version", "20150826", "...")
#         flag.Bool("discovery.ssdp", true, "...")
#
#         flag.Bool("filter.regex-inclusive", false, "...")
#         flag.String("filter.regex", ".*", "...")
#
#         flag.StringP("web.listen-address", "l", "localhost:6077", "...")
#         flag.StringP("web.base-address", "b", "localhost:6077", "...")
#
#         flag.String("log.level", logrus.InfoLevel.String(), "...")
#         flag.Bool("log.requests", false, "...")
#
#         flag.String("iptv.playlist", "", "...")
#         flag.Int("iptv.streams", 1, "...")
#         flag.Int("iptv.starting-channel", 10000, "...")
#         flag.Bool("iptv.xmltv-channels", true, "...")
#
#         flag.StringP("config.file", "c", "", "...")
#         flag.Bool("version", false, "...")
#
#         flag.Parse()
#         viper.BindPFlags(flag.CommandLine)
#     }
#
# viper.AutomaticEnv() + viper.SetEnvPrefix("telly") binds env-
# vars TELLY_* to flags (TELLY_LOG_LEVEL → log.level).  viper.
# SetConfigName("telly.config") + AddConfigPath searches /etc/
# telly/ + $HOME/.telly/ + . for telly.config.{toml,yaml,json}.
#
# Five-axis distinctness from config-rs (R629):
#
#   1. GLOBAL SINGLETON + NewViper() — viper has both APIs;
#      config-rs is builder-only.
#
#   2. 7+ FILE FORMATS INCLUDING HCL + JAVA PROPERTIES — viper
#      supports HashiCorp Configuration Language; config-rs uses
#      RON instead.
#
#   3. PFLAG/COBRA INTEGRATION via BindPFlags — viper's first-
#      class spf13-trinity integration is unmatched.
#
#   4. REMOTE KEY-VALUE STORE BACKENDS — viper supports etcd/
#      consul/Firestore; config-rs is file+env only.
#
#   5. STEVE-FRANCIA + SPF13-TRINITY PROVENANCE — cobra/pflag/
#      viper foundational role across the Go ecosystem.
#
