#compdef nfacct_test
# _libnetfilter_acct — libnetfilter_acct example helper (nfacct_test from the libnetfilter_acct examples; subscribes to a NETLINK_NETFILTER NFNL_SUBSYS_ACCT socket and prints account-object counter updates; -n name, -d daemonize, -v verbose, -V version, -h help)
# upstream: https://git.netfilter.org/libnetfilter_acct
# Flags from netfilter/libnetfilter_acct examples/nfacct_test.c on tip.

_libnetfilter_acct() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-n+[name]:name:' \
        '-d[daemonize]' \
        '-v[verbose]'
}

_libnetfilter_acct "$@"
