#compdef scriv
# Documentation: https://scriv.readthedocs.io/en/latest/commands.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[set log verbosity]:level:' \
  '--config=[path to config file]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'create:create a new changelog fragment'
      'collect:collect changelog fragments into the changelog'
      'github-release:create or update GitHub releases from the changelog'
      'print:print changelog entries or fragments'
    )
    _describe -t commands 'scriv command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--add[git add the new fragment]' \
          '--no-add[do not git add the new fragment]' \
          '--edit[open the fragment in editor]' \
          '--no-edit[do not open in editor]' \
          '(-v --verbosity)'{-v+,--verbosity=}'[set log verbosity]:level:' \
          '--config=[path to config file]:file:_files' && ret=0
        ;;
      (collect)
        _arguments \
          '--add[git add the changelog]' \
          '--no-add[do not git add]' \
          '--edit[open changelog in editor after collecting]' \
          '--no-edit[do not open in editor]' \
          '--title=[set the entry title]:title:' \
          '--keep[keep fragment files after collecting]' \
          '--version=[version to collect for]:version:' \
          '(-v --verbosity)'{-v+,--verbosity=}'[set log verbosity]:level:' \
          '--config=[path to config file]:file:_files' && ret=0
        ;;
      (github-release)
        _arguments \
          '--all[process every changelog entry]' \
          '--check-links[verify links in entries]' \
          '--draft[create draft releases]' \
          '--dry-run[show what would be done without doing it]' \
          '--fail-if-warn[exit non-zero if warnings occur]' \
          '--repo=[GitHub repository]:repo:' \
          '(-v --verbosity)'{-v+,--verbosity=}'[set log verbosity]:level:' \
          '--config=[path to config file]:file:_files' && ret=0
        ;;
      (print)
        _arguments \
          '--version=[version to print]:version:' \
          '--output=[output file]:file:_files' \
          '(-v --verbosity)'{-v+,--verbosity=}'[set log verbosity]:level:' \
          '--config=[path to config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
