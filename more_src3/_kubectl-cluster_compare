#compdef kubectl-cluster_compare
# Documentation: https://github.com/openshift/kube-compare
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (pkg/compare/compare.go flags).

# cluster-compare (openshift/kube-compare), binary kubectl-cluster_compare:
# diff cluster resources against reference manifests.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-r --reference)'{-r+,--reference=}'[path to reference config file]:file:_files' \
  '(-f --filename)*'{-f+,--filename=}'[file or directory containing CRs to diff]:file:_files' \
  '(-R --recursive)'{-R,--recursive}'[process directory recursively]' \
  '(-c --diff-config)'{-c+,--diff-config=}'[path to the user config file]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml generate-patches junit)' \
  '(-p --overrides)'{-p+,--overrides=}'[path to user overrides]:file:_files' \
  '(-A --all-resources)'{-A,--all-resources}'[match all resources from types in reference]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--concurrency=[number of objects to process in parallel]:n:' \
  '--show-managed-fields[include managed fields in the diff]' \
  '*--generate-override-for=[template file to generate override for]:file:_files' \
  '--override-reason=[reason for generating the override]:reason:' \
  '--show-template-functions[show all available template functions]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '*:arg:_default'
