#compdef langroid
# _langroid — Prasad Chalasani Langroid multi-agent LLM framework CLI for creating ChatAgent ChatAgentConfig Task tool-use vector-store RAG with OpenAI Anthropic local LLMs (langroid team, Python); typer
# upstream: https://github.com/langroid/langroid

_langroid() {
    local -a sub=(
        'chat:interactive chat'
        'task:run a task'
        'agent:agent operations'
        'tools:tool operations'
        'vecdb:vector DB operations'
        'embed:compute embedding'
        'rag:run RAG query'
        'eval:run evals'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '-c+[file]:file:_files -g "*.yaml *.yml *.json *.toml"' \
        '--model=+[m]:m:(gpt-4o gpt-4-turbo gpt-3.5-turbo o1 o3 claude-opus-4-7 claude-sonnet-4-6 claude-haiku-4-5 gemini-2.5-pro gemini-2.5-flash llama3 mistral mixtral)' \
        '--provider=+[p]:p:(openai anthropic google azure cohere mistral groq fireworks together perplexity vertex bedrock ollama lmstudio litellm)' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--system=+[prompt]:str:' \
        '--no-stream[no stream]' \
        '--no-cache[no cache]' \
        '--cache-type=+[t]:t:(redis momento none)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'langroid subcommand' sub ;;
        args)
            case $words[1] in
                vecdb) _arguments \
                    '1:action:(create insert query delete list)' \
                    '--type=+[t]:t:(chroma qdrant lancedb meilisearch postgres pinecone weaviate)' \
                    '--collection=+[name]:str:' \
                    '*:doc:_files' ;;
                rag) _arguments \
                    '--query=+[query]:str:' \
                    '--top-k=+[N]:n:' \
                    '--collection=+[name]:str:' \
                    '*:question:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_langroid "$@"
