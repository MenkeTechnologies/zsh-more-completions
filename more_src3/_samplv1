#compdef samplv1 samplv1_jack samplv1_lv2
# _samplv1 — Rui Nuno Capela samplv1 polyphonic sampler synth with LV2 plugin and standalone JACK app for one-shot sampling with envelope LFO filter (rncbc team, C++/Qt); Qt argparse
# upstream: https://samplv1.sourceforge.io/

_samplv1() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[client name]:str:' \
        '--client-name=+[client name]:str:' \
        '-J+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[no auto connect]' \
        '--no-auto-connect[no auto connect]' \
        '-G[no GUI]' \
        '--no-gui[no GUI]' \
        '-p+[preset]:str:' \
        '--preset=+[preset]:str:' \
        '--style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '--platform=+[platform]:p:(xcb wayland cocoa windows direct2d)' \
        '*:samplv1 preset file:_files -g "*.samplv1 *.lv2 *.sf2 *.sfz *.wav *.flac *.aiff *.ogg *.aif"'
}

_samplv1 "$@"
