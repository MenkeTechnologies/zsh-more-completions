#compdef synergys
# Documentation: https://sources.debian.org/data/main/s/synergy/1.4.16-2/doc/synergys.man
# Reference accessed: 2026-05-21
# Verified: upstream Synergy 1.4.16 synergys(1) man source from Debian.
# Removed: --display, --enable-crypto, --disable-crypto, --profile-dir,
# --plugin-dir (not in upstream manpage).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --address)'{-a,--address}'+[listen address[:port]]:addr:' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '(-d --debug)'{-d,--debug}'+[log filter level]:level:(FATAL ERROR WARNING NOTE INFO DEBUG DEBUG1 DEBUG2 DEBUG3 DEBUG4 DEBUG5)' \
  '(-n --name)'{-n,--name}'+[screen name]:name:' \
  '(-1 --no-restart)'{-1,--no-restart}'[do not restart on failure]' \
  '--restart[restart on failure (default)]' \
  '(-l --log)'{-l,--log}'+[log file]:file:_files' \
  '(-f --no-daemon)'{-f,--no-daemon}'[do not daemonize]' \
  '--daemon[daemonize (default)]' && ret=0

return ret
