#compdef ultralist
# Documentation: https://github.com/ultralist/ultralist
# Reference accessed: 2026-05-21
# Verified: upstream Cobra command definitions in cmd/*.go
# (add, agenda, archive, auth, complete, delete, edit, expand, init,
#  list, prioritize, sync, version, web, root).
# Removed from prior file: fabricated uncomplete/unarchive/unprioritize/
# notes/status subcommands and made-up list filter flags
# (--completed/--archived/--due/--status/--project/--context/--priority/
# --notes). Real ultralist takes positional filter arguments to list,
# not Cobra flags.

_ultralist_commands() {
  local -a commands=(
    'add:add a new todo (alias: a)'
    'agenda:list todos due today or in the past'
    'archive:archive todos (alias: ar)'
    'auth:authenticate against ultralist.io'
    'complete:complete a todo (alias: c)'
    'delete:delete a todo (alias: d, rm)'
    'edit:edit a todo (alias: e)'
    'expand:expand a project todo (alias: ex)'
    'init:initialize a new todolist'
    'list:list todos (alias: l)'
    'prioritize:prioritize a todo (alias: p)'
    'sync:sync with ultralist.io'
    'version:print version'
    'web:open in web browser'
  )
  _describe 'command' commands
}

_ultralist() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[Show help]' \
    '1:command:_ultralist_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        add|a)
          _arguments \
            '--done[mark the todo as done]' \
            '*:todo text:'
          ;;
        complete|c)
          _arguments \
            '--archive[archive a completed todo automatically]' \
            '--revert[uncomplete a completed todo]' \
            '1:todo id:'
          ;;
        archive|ar)
          _arguments \
            '--revert[unarchive an archived todo]' \
            '1:todo id:'
          ;;
        prioritize|p)
          _arguments \
            '--revert[unprioritize a prioritized todo]' \
            '1:todo id:'
          ;;
        delete|d|rm|edit|e|expand|ex)
          _arguments '*:args:'
          ;;
        list|l|agenda)
          _arguments \
            '--unicode[allow unicode in output]' \
            '--color[allow color in output]' \
            '*:filter:'
          ;;
        auth)
          local -a auth_cmds=(
            'check:verify current authentication status'
          )
          _describe 'auth command' auth_cmds
          ;;
      esac
      ;;
  esac
}

_ultralist "$@"
