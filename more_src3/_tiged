#compdef tiged
# Documentation: https://github.com/tiged/tiged
# Reference accessed: 2026-05-21
# Verified: upstream src/bin.ts (mri) + src/types.ts (ValidModes) at the URL above.

# Zsh completion for tiged - community fork of degit

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-m --mode)'{-m,--mode}'=[clone mode (default tar)]:mode:(tar git)' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-f --force)'{-f,--force}'[force overwrite of existing files]' \
  '(-D --disable-cache)'{-D,--disable-cache}'[disable caching]' \
  '(-o --offline-mode)'{-o,--offline-mode}'[operate offline using cached data only]' \
  '(-s --subgroup)'{-s,--subgroup}'[enable GitLab subgroup support]' \
  '(-d --sub-directory)'{-d,--sub-directory}'=[subdirectory within repo]:subdirectory:' \
  '(-p --proxy)'{-p,--proxy}'=[HTTPS proxy URL]:proxy:' \
  '1:repo path (user/repo):' \
  '2:destination:_directories'
