#compdef x11docker
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--desktop[run desktop environment]' \
  '--gpu[enable GPU acceleration]' \
  '--pulseaudio[enable PulseAudio sound]' \
  '--alsa[enable ALSA sound]' \
  '--webcam[enable webcam access]' \
  '--printer[enable printer access]' \
  '--clipboard[enable clipboard sharing]' \
  '--lang[set locale]:locale' \
  '--wayland[use Wayland]' \
  '--xephyr[use Xephyr]' \
  '--xpra[use Xpra]' \
  '--nxagent[use nxagent]' \
  '--xorg[use Xorg --setuid]' \
  '--hostdisplay[use host display]' \
  '--wm[window manager]:window manager' \
  '--xc[extra X11 commands]:command' \
  '--sudouser[create sudo user in container]' \
  '--user[run as user]:user' \
  '--home[mount home directory]:directory:_directories' \
  '--share[share directory]:directory:_directories' \
  '--cap-default[use default capabilities]' \
  '--hostipc[share host IPC]' \
  '--hostnet[share host network]' \
  '--hostdbus[share host D-Bus]' \
  '--init[init system]:init system:(systemd sysvinit runit openrc s6)' \
  '--name[container name]:name' \
  '--pull[pull policy]:policy:(always missing never)' \
  '--cleanup[cleanup on exit]' \
  '--border[window border]' \
  '--size[window size]:size (WxH)' \
  '--dpi[DPI setting]:DPI' \
  '--keymap[keyboard layout]:layout' \
  '--verbose[verbose output]' \
  '--debug[debug mode]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:Docker image:_docker_images' \
  '*:command' && ret=0
return ret
