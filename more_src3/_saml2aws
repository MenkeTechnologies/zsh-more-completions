#compdef saml2aws
# Documentation: https://github.com/Versent/saml2aws
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for saml2aws (SAML to AWS STS)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:configure a new IDP account'
  'login:log in to the SAML IDP and retrieve AWS credentials'
  'exec:execute a command with AWS credentials in environment'
  'console:open the AWS console in a browser'
  'list-roles:list available AWS roles'
  'script:emit a shell script that exports AWS credentials'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(--version)--version[show version]' \
  '--verbose[enable verbose logging]' \
  '--quiet[suppress log messages]' \
  '(-i --provider)'{-i,--provider}'[(obsolete) identity provider]:provider:(ADFS Ping JumpCloud Okta OneLogin KeyCloak GoogleApps Shibboleth AzureAD Browser)' \
  '(-a --idp-account)'{-a,--idp-account}'[IDP account name]:account:' \
  '--idp-provider=[IDP provider]:provider:' \
  '--config=[path to saml2aws config file]:file:_files' \
  '--url=[IDP entry URL]:url:_urls' \
  '--username=[login username]:username:' \
  '--password=[login password]:password:' \
  '--mfa=[MFA method]:method:' \
  '--mfa-token=[MFA token]:token:' \
  '--role=[ARN of role to assume]:arn:' \
  '--aws-urn=[SAML URN for AWS login]:urn:' \
  '--skip-verify[skip TLS certificate verification]' \
  '--skip-prompt[bypass parameter prompts]' \
  '--session-duration=[session duration in seconds]:seconds:' \
  '--disable-keychain[disable keychain storage]' \
  '--region=[AWS region]:region:' \
  '--prompter=[input prompter]:prompter:(default pinentry)' \
  '(-p --profile)'{-p,--profile}'[AWS credentials profile]:profile:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'saml2aws command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (exec)
        _arguments \
          '--exec-profile=[AWS profile to source credentials from]:profile:' \
          '*:command:_command_names -e' && ret=0
        ;;
      (login)
        _arguments \
          '--force[force login]' \
          '--credential-process[output credential process JSON]' \
          '--cache-saml[cache SAML response]' \
          '--cache-file=[SAML cache file]:file:_files' && ret=0
        ;;
      (script)
        _arguments \
          '--shell=[shell type]:shell:(bash powershell fish env)' && ret=0
        ;;
    esac
    ;;
esac

return ret
