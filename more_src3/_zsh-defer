#compdef zsh-defer
# Documentation: https://github.com/romkatv/zsh-defer
# Reference accessed: 2026-05-21
# Verified: README SYNOPSIS — toggle flags 1/2/d/m/s/z/p/r/a plus
# -t delay and -c list. All match upstream documented option table.

_zsh-defer() {
    local -a args
    args=(
        '-t[Delay execution by specified seconds]:delay'
        '-c[Execute command as eval list]'
        '*:command:_command_names -e'
    )

    # Options like +1, -1, +a, -a etc.
    if [[ $words[CURRENT] == [+-][12dmszpra] ]]; then
        _values 'options' \
            '1[Redirect stdout to /dev/null]' \
            '2[Redirect stderr to /dev/null]' \
            'd[Call chpwd hooks]' \
            'm[Call precmd hooks]' \
            's[Invalidate suggestions]' \
            'z[Invalidate highlighting]' \
            'p[Reset prompt]' \
            'r[Call zle -R]' \
            'a[All options]'
        return
    fi

    _arguments -s -S $args
}

_zsh-defer "$@"
