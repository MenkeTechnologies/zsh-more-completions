#compdef verus
# _verus — Verus: SMT-backed verifier for Rust (verus-lang/verus)
# upstream: https://github.com/verus-lang/verus
# Flags pulled from source/rust_verify/src/config.rs (getopts builder).

_verus() {
    local -a args
    args=(
        '--export=[export Verus metadata for library crate (CRATENAME=PATH)]:metadata:'
        '--import=[import Verus metadata from another crate (CRATENAME=PATH)]:metadata:'
        '--verify-root[verify just the root module of crate]'
        '--verify-module=[verify only the listed module]:module:'
        '--verify-function=[verify only the listed function (with --verify-only-module or --verify-root)]:function:'
        '--no-verify[do not run verification]'
        '--no-lifetime[do not run lifetime checking on proofs]'
        '--no-erasure-check[do not run the final erasure check]'
        '--no-vstd[do not load or link against the vstd library]'
        '--is-vstd[indicate the crate being verified is vstd]'
        '--time[measure and report time taken]'
        '--time-expanded[measure and report time taken with module breakdown]'
        '--output-json[emit verification results and timing as JSON]'
        '--rlimit=[per-query resource limit in seconds (default 10)]:seconds:'
        '--multiple-errors=[errors per function (0 = stop at first, default 2)]:count:'
        '--triggers[show automatically chosen triggers for verified modules]'
        '--triggers-silent[chosen triggers only when no manual triggers given]'
        '--triggers-mode=[trigger verbosity]:mode:(silent selective module all-modules verbose verbose-all-modules)'
        '--profile[collect and report prover performance data for failed queries]'
        '--profile-all[always collect and report prover performance data]'
        '--capture-profiles[capture solver profile traces]'
        '--compile[run rustc compiler after verification]'
        '--trace[print progress information]'
        '--log-all[log everything (VIR, AIR, SMT, triggers, ...)]'
        '--log-dir=[directory for log output (default .verus-log)]:dir:_files -/'
        '--solver-log-dir=[directory for solver log output (default .verus-solver-log)]:dir:_files -/'
        '(- *)'{-h,--help}'[print help menu]'
        '(- *)--version[print version]'
        '*:Rust source file:_files -g "*.rs"'
    )
    _arguments -s -S $args
}

_verus "$@"
