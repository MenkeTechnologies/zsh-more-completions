#compdef tattoy
# Documentation: https://github.com/tattoy-org/tattoy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/tattoy-org/tattoy — crates/tattoy/src/cli_args.rs

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*--use=[enable tattoy layer]:tattoy:' \
  '--disable-indicator[hide status indicator]' \
  '--command=[override shell command]:command:_command_names -e' \
  '--capture-palette[capture terminal palette]' \
  '--parse-palette=[palette screenshot path]:file:_files' \
  '--config-dir=[config directory]:directory:_files -/' \
  '--main-config=[main config file]:file:_files' \
  '--log-path=[log file]:file:_files' \
  '--log-level=[tracing level]:level:(error warn info debug trace)' && ret=0

return ret
