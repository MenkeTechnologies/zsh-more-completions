#compdef xfs_info
# _xfs_info — xfsprogs xfs_info (display the geometry of a mounted XFS filesystem (also reachable as xfs_growfs -i); -V show version; positional argument is the mountpoint or device)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs growfs/xfs_growfs.c on tip.

_xfs_info() {
    _arguments \
        '-V[show version]' \
        '1:mountpoint or device:_files'
}

_xfs_info "$@"
