#compdef list-unreleased
# Documentation: https://manpages.debian.org/list-unreleased
# Source: debian/devscripts scripts/list-unreleased.sh — find UNRELEASED Debian source trees (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '-c[display pending changelog entry]' \
    '-R[do not recurse]' \
    '*:path:_files -/' \
    && ret=0

return ret
