#compdef xdpyinfo
# Documentation: xdpyinfo usage (X.Org)
# Source: display information about an X server.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-version[print program version]' \
    '-display+[X display name]:display:' \
    '-queryExtensions[print XQueryExtension info]' \
    '-ext+[print detailed info for extension]:extension:(all MIT-SHM XKEYBOARD Multi-Buffering SHAPE SYNC XFree86-VidModeExtension XTEST DOUBLE-BUFFER RECORD XInputExtension RENDER Composite XINERAMA DAMAGE XFIXES Generic\ Event\ Extension MIT-SCREEN-SAVER Present DPMS DRI3 BIG-REQUESTS GLX X-Resource Selection-Notifier-Extension XKEYBOARD)' \
    && ret=0

return ret
