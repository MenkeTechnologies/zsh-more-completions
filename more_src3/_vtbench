#compdef vtbench
# _vtbench — Vitess load-generation benchmark client
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtbench/cli/vtbench.go on tip.

_vtbench() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--host=[VTGate host(s), comma-separated]:hosts:' \
        '--port=[VTGate port]:port:' \
        '--unix-socket=[VTGate unix socket path]:path:_files' \
        '--protocol=[client protocol]:protocol:(mysql grpc-vtgate grpc-vttablet)' \
        '--user=[username (mysql protocol)]:user:' \
        '--db=[database (e.g. @replica, keyspace, keyspace/shard)]:db:' \
        '--deadline=[max test duration]:dur:' \
        '--sql=[SQL statement to execute]:sql:' \
        '--threads=[parallel worker threads]:n:' \
        '--count=[queries per thread]:n:' \
        '--continue-on-error=[continue on query errors]:bool:(true false)' \
        '-v[verbosity level]:n:'
}

_vtbench "$@"
