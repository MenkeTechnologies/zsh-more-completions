#compdef ijq
# Documentation: https://github.com/gpanders/ijq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for ijq - interactive jq (gpanders/ijq).
# Flags from ijq.1.scd: ijq [-cnsrjaRMCSV] [-f file] [filter] [files...]

_arguments -s -S \
  '-c[use compact instead of pretty-printed output]' \
  '-n[do not read any input]' \
  '-s[read all input into a single array]' \
  '-r[output raw strings rather than JSON]' \
  '-j[implies -r and outputs without trailing newline]' \
  '-a[output strings using only ASCII]' \
  '-R[read input as raw strings instead of JSON]' \
  '-M[disable colored output]' \
  '-C[force colored output]' \
  '-S[output object fields in sorted order]' \
  '-f[read the filter from file]:file:_files' \
  '(- *)-V[show version]' \
  '*:input file:_files'
