#compdef update-mime-database
# Documentation: update-mime-database -h (shared-mime-info)
# Source: freedesktop shared-mime-info — rebuild the MIME database cache for MIME-DIR.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-v[verbose output]' \
    '(- *)-V[print version and exit]' \
    '-n[no-op (parse but do not write)]' \
    '*:MIME directory:_files -/' \
    && ret=0

return ret
