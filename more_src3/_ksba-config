#compdef ksba-config
# Documentation: https://manpages.debian.org/testing/libksba-dev/ksba-config.1.en.html
# Reference accessed: 2026-05-19
# Verified: man page above + local `ksba-config --help` (libksba),
# which additionally lists --api-version and --host.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--api-version[show API version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '--host[show host triplet]' && ret=0

return ret
