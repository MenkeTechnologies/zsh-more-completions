#compdef hp-systray
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/hp-systray.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy hp-systray(1) manpage.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# hp-systray: HPLIP system tray status applet
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-l --logging)'{-l+,--logging=}'[log level]:level:(none info warn error debug)' \
  '-g[shortcut for -ldebug]' \
  '(-x --force-startup)'{-x,--force-startup}'[start even if no HPLIP CUPS queues]' && ret=0
return ret
