#compdef h2o-cli
# _h2o-cli — Kazuho Oku H2O optimized HTTP server CLI alias (h2o team, C); custom argparse
# upstream: https://github.com/h2o/h2o

_h2o-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "h2o.{conf,yaml,yml}"' \
        '--conf=+[config file]:file:_files -g "h2o.{conf,yaml,yml}"' \
        '-m+[run mode]:m:(worker daemon master test)' \
        '--mode=+[run mode]:m:(worker daemon master test)' \
        '-t+[test config syntax]:str:' \
        '--test=+[test config syntax]:str:' \
        '*:arg:'
}

_h2o-cli "$@"
