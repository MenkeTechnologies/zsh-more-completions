#compdef xsoar-cli demisto-sdk
# _xsoar-cli — Palo Alto Networks Cortex XSOAR xsoar-cli CLI command-line frontend wrapping the Cortex XSOAR formerly Demisto SOAR Security Orchestration Automation and Response platform demisto-sdk CLI providing init validate format secrets lint test create-content-artifacts upload download run create-id-set find-dependencies update-release-notes generate-docs convert merge openapi-codegen postman-codegen split unify zip integration script playbook incident layout indicator field type widget dashboard subplaybook (Palo Alto Networks Cortex XSOAR team, Python); click
# upstream: https://www.paloaltonetworks.com/cortex/cortex-xsoar

_xsoar-cli() {
    local -a sub=(
        'init:scaffold pack/integration'
        'validate:validate content'
        'format:auto-format content'
        'secrets:check secrets'
        'lint:run lint'
        'test:run unit tests'
        'create-content-artifacts:create content artifacts'
        'upload:upload to XSOAR'
        'download:download from XSOAR'
        'run:run command on XSOAR'
        'create-id-set:create id_set.json'
        'find-dependencies:find pack dependencies'
        'update-release-notes:update release notes'
        'generate-docs:generate README/docs'
        'convert:convert content version'
        'merge:merge content packs'
        'openapi-codegen:generate from OpenAPI'
        'postman-codegen:generate from Postman'
        'split:split YML'
        'unify:unify YML'
        'zip:zip packs'
        'integration:integration ops'
        'script:script ops'
        'playbook:playbook ops'
        'incident:incident ops'
        'layout:layout ops'
        'indicator:indicator ops'
        'field:field ops'
        'type:type ops'
        'widget:widget ops'
        'dashboard:dashboard ops'
        'subplaybook:subplaybook ops'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--insecure[skip TLS verify]' \
        '-i+[input]:_files' \
        '--input=+[file]:_files' \
        '-o+[output]:_files' \
        '--output=+[file]:_files' \
        '--id-set-path=+[file]:file:_files -g "id_set.json"' \
        '--prev-ver=+[v]:str:' \
        '--use-git[use git]' \
        '--all-files[all files]' \
        '--no-conf-json[no conf.json]' \
        '--skip-pack-dependencies[skip pack deps]' \
        '--cpu[CPU only]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xsoar subcommand' sub ;;
        args)
            case $words[1] in
                integration|script|playbook|incident|layout|indicator|field|type|widget|dashboard|subplaybook) _arguments '1:op:(list get create update delete run upload download)' '*:id:' ;;
            esac
            ;;
    esac
}

_xsoar-cli "$@"
