#compdef zev
# Documentation: https://github.com/dtnewman/zev
# Reference accessed: 2026-05-22
# Verified: README usage and CLI options.

# Zsh completion for zev - natural-language terminal command lookup

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--setup[configure API keys and settings]' \
  '*:query:' && ret=0

return ret
