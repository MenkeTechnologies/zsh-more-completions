#compdef vc-agent-scheduler volcano-agent-scheduler
# _vc-agent-scheduler — Volcano agent-side per-node scheduler (volcano-sh/volcano)
# upstream: https://github.com/volcano-sh/volcano
# Flags from cmd/agent-scheduler/app/options/options.go on tip.

_vc-agent-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--ca-cert-file=[CA cert file for HTTPS]:file:_files' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '--scheduler-name=[handled scheduler name]:name:' \
        '--scheduler-conf=[agent-scheduler configuration file]:file:_files' \
        '--resync-period=[informer resync period]:dur:' \
        '--listen-address=[HTTP server bind host\:port]:host\:port:' \
        '--healthz-address=[health-check bind host\:port]:host\:port:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--minimum-feasible-nodes=[minimum feasible nodes to score]:n:' \
        '--minimum-percentage-nodes-to-find=[minimum % nodes to score]:n:' \
        '--percentage-nodes-to-find=[% nodes to score (<=0 auto)]:n:' \
        '--csi-storage[enable CSI storage support]' \
        '--enable-healthz=[enable health check]:bool:(true false)' \
        '--leader-elect-resource-namespace=[leader election namespace]:ns:' \
        '-v[klog verbosity level]:n:'
}

_vc-agent-scheduler "$@"
