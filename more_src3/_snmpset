#compdef snmpset
# _snmpset — net-snmp snmpset (SNMPv1/2c/3 SET request helper; -v 1|2c|3, -c community, -u user (v3), -l noAuthNoPriv|authNoPriv|authPriv, -a auth alg, -A auth pw, -x priv alg, -X priv pw, -m MIBs, -M MIB dir, -r retries, -t timeout; positional: agent OID type value where type is i (integer), u (unsigned), s (string), x (hex), d (decimal string), n (null), o (object id), t (timeticks), a (IP), b (bits))
# upstream: https://www.net-snmp.org/
# Flags from net-snmp apps/snmpset.c on tip.

_snmpset() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v+[version]:version:(1 2c 3)' \
        '-c+[community]:community:' \
        '-u+[v3 user]:user:_users' \
        '-l+[v3 security level]:level:(noAuthNoPriv authNoPriv authPriv)' \
        '-a+[auth alg]:alg:(MD5 SHA SHA-224 SHA-256 SHA-384 SHA-512)' \
        '-A+[auth password]:password:' \
        '-x+[priv alg]:alg:(DES AES AES-192 AES-256)' \
        '-X+[priv password]:password:' \
        '-m+[MIBs]:mibs:' \
        '-M+[MIB dirs]:dir:_files -/' \
        '-r+[retries]:n:' \
        '-t+[timeout]:seconds:' \
        '1:agent:_hosts' \
        '*:OID type value:'
}

_snmpset "$@"
