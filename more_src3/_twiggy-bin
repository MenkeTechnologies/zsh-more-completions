#compdef twiggy
# _twiggy-bin — Twiggy code-size profiler for wasm binaries (Nick Fitzgerald, Rust); attribute Wasm binary bloat
# upstream: https://github.com/rustwasm/twiggy

_twiggy-bin() {
    local -a sub=(
        'top:show top heaviest items'
        'paths:show retaining paths'
        'monos:show monomorphizations'
        'dominators:show dominator tree'
        'diff:diff two binaries'
        'garbage:show garbage symbols'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'twiggy subcommand' sub ;;
        args)
            case $words[1] in
                top|paths|dominators|monos|garbage) _arguments \
                    '(-o --output)'{-o,--output}'+[output file]:file:_files' \
                    '(-f --format)'{-f,--format}'+[format]:fmt:(csv json text)' \
                    '(-n --max-items)'{-n,--max-items}'+[max items]:n:' \
                    '(-d --max-depth)'{-d,--max-depth}'+[max depth]:n:' \
                    '(-r --retaining-paths)'{-r,--retaining-paths}'[show retaining paths]' \
                    '*:wasm file:_files -g "*.wasm"' ;;
                diff) _arguments \
                    '(-o --output)'{-o,--output}'+[output file]:file:_files' \
                    '(-f --format)'{-f,--format}'+[format]:fmt:(csv json text)' \
                    '(-n --max-items)'{-n,--max-items}'+[max items]:n:' \
                    '1:old wasm:_files -g "*.wasm"' \
                    '2:new wasm:_files -g "*.wasm"' ;;
            esac
            ;;
    esac
}

_twiggy-bin "$@"
