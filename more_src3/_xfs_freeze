#compdef xfs_freeze
# _xfs_freeze — xfsprogs xfs_freeze (freeze/thaw a mounted filesystem via the FIFREEZE/FITHAW ioctls; -f freezes (suspends writes after flushing), -u thaws; works on any FIFREEZE-supporting filesystem (ext4/btrfs/xfs/etc.))
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs freeze/xfs_freeze.c on tip.

_xfs_freeze() {
    _arguments \
        '-V[show version]' \
        '(-u)-f[freeze]' \
        '(-f)-u[unfreeze]' \
        '1:mountpoint:_files -/'
}

_xfs_freeze "$@"
