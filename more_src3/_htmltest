#compdef htmltest
# Documentation: https://github.com/wjdp/htmltest
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# htmltest - rigorously test your generated HTML.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version and build time]' \
  '(-c --conf)'{-c+,--conf=}'[path to config file]:config:_files -g "*.yml(-.)"' \
  '(-l --log-level)'{-l+,--log-level=}'[logging level 0-3 (debug,info,warning,error)]:level:(0 1 2 3)' \
  '(-s --skip-external)'{-s,--skip-external}'[skip external link checks]' \
  '1:path:_files' && return 0
