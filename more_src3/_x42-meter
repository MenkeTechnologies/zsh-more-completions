#compdef x42-meter x42-dpm x42-meters
# _x42-meter — Robin Gareus x42 meters JACK standalone studio metering suite including K-meter EBU R128 phasescope BBC-style PPM goniometer surround analyzer (x42 team, C++); GOption
# upstream: https://github.com/x42/meters.lv2

_x42-meter() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-J+[jack client name]:str:' \
        '--jack-name=+[jack client name]:str:' \
        '-S+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[autoconnect]' \
        '--autoconnect[autoconnect]' \
        '-N[no autoconnect]' \
        '--no-autoconnect[no autoconnect]' \
        '-t+[meter type]:m:(dBTP K12 K14 K20 BBC EBU IEC60268-18 VU PPM-DIN PPM-EBU PPM-BBC PPM-DIN_4 stereo-scope phase-rotator phase-wheel spectrogram bitmeter loudness phasescope goniometer surround dpm)' \
        '--type=+[meter type]:m:(dBTP K12 K14 K20 BBC EBU IEC60268-18 VU PPM-DIN PPM-EBU PPM-BBC PPM-DIN_4 stereo-scope phase-rotator phase-wheel spectrogram bitmeter loudness phasescope goniometer surround dpm)' \
        '-i+[input port]:str:' \
        '--input=+[input port]:str:' \
        '-G+[grid color]:c:(green amber red dark light)' \
        '--grid=+[grid color]:c:(green amber red dark light)' \
        '-r+[reference dB]:f:' \
        '--reference=+[reference dB]:f:' \
        '-f+[falltime ms]:n:' \
        '--falltime=+[falltime ms]:n:' \
        '-p+[peak hold ms]:n:' \
        '--peak-hold=+[peak hold ms]:n:' \
        '-w+[window width]:n:' \
        '--width=+[window width]:n:' \
        '-d+[window height]:n:' \
        '--height=+[window height]:n:' \
        '--no-decorations[no decorations]' \
        '--no-gui[no GUI]' \
        '--osc-port=+[port]:n:'
}

_x42-meter "$@"
