#compdef impacket-ping
# Documentation: https://github.com/fortra/impacket/blob/master/examples/ping.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-ping: ICMP echo using Impacket; takes raw <src ip> <dst ip> via sys.argv (no flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:source ip:_hosts' \
  '2:destination ip:_hosts' && ret=0
return ret
