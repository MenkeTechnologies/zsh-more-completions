#compdef systemd-journal-gatewayd
# Documentation: https://man7.org/linux/man-pages/man8/systemd-journal-gatewayd.service.8.html
# Reference accessed: 2026-05-21
# Verified: upstream systemd-journal-gatewayd.service(8) manpage.
# Removed: --namespace (not documented for gatewayd).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cert=[server certificate file (PEM)]:file:_files' \
  '--key=[server secret key file (PEM)]:file:_files' \
  '--trust=[CA certificate file (PEM)]:file:_files' \
  '--system[restrict to system services and kernel messages]' \
  '--user[restrict to current user services]' \
  '(-m --merge)'{-m,--merge}'[serve interleaved entries from all journals]' \
  '(-D --directory)'{-D,--directory}'=[journal directory to serve]:dir:_files -/' \
  '--file=[journal files matching glob pattern]:glob:' && ret=0

return ret
