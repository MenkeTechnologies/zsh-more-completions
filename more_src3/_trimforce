#compdef trimforce
# Documentation: https://ss64.com/mac/trimforce.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Only 'enable', 'disable', 'help' verbs documented by Apple.
# Removed prior fabricated 'status' subcommand.

local -a subcommands

subcommands=(
    'enable:Enable TRIM on third-party SSDs (requires reboot)'
    'disable:Disable TRIM on third-party SSDs (requires reboot)'
    'help:Display brief usage syntax'
)

_arguments -s -S \
    '1:subcommand:->subcmd' && return

case $state in
    subcmd)
        _describe 'trimforce subcommand' subcommands
        ;;
esac
