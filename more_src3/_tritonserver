#compdef tritonserver
# Documentation: https://github.com/triton-inference-server/server/blob/main/docs/customization_guide/inference_protocols.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cross-checked with `tritonserver --help`).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '--model-repository=[model repository path]:dir:_files -/' \
  '--model-control-mode=[model control mode]:mode:(none poll explicit)' \
  '--strict-model-config=[require model config]:bool:(true false)' \
  '--strict-readiness=[strict readiness reporting]:bool:(true false)' \
  '--rate-limit=[rate limit mode]:mode:(off execution_count)' \
  '--rate-limit-resource=[rate limit resource]:resource:' \
  '--pinned-memory-pool-byte-size=[pinned memory pool size]:bytes:' \
  '--cuda-memory-pool-byte-size=[CUDA memory pool size]:device\:bytes:' \
  '--response-cache-byte-size=[response cache size]:bytes:' \
  '--min-supported-compute-capability=[min compute capability]:capability:' \
  '--exit-on-error=[exit on error]:bool:(true false)' \
  '--exit-timeout-secs=[exit timeout]:seconds:' \
  '--backend-directory=[backend directory]:dir:_files -/' \
  '--repoagent-directory=[repo agent directory]:dir:_files -/' \
  '--buffer-manager-thread-count=[buffer manager threads]:count:' \
  '--host-policy=[host policy]:policy:' \
  '--allow-http=[allow HTTP]:bool:(true false)' \
  '--http-port=[HTTP port]:port:' \
  '--http-address=[HTTP address]:address:' \
  '--http-thread-count=[HTTP threads]:count:' \
  '--allow-grpc=[allow gRPC]:bool:(true false)' \
  '--grpc-port=[gRPC port]:port:' \
  '--grpc-address=[gRPC address]:address:' \
  '--grpc-infer-allocation-pool-size=[gRPC pool size]:size:' \
  '--grpc-use-ssl=[use SSL for gRPC]:bool:(true false)' \
  '--grpc-server-cert=[gRPC server cert]:file:_files' \
  '--grpc-server-key=[gRPC server key]:file:_files' \
  '--grpc-root-cert=[gRPC root cert]:file:_files' \
  '--allow-metrics=[allow metrics]:bool:(true false)' \
  '--metrics-port=[metrics port]:port:' \
  '--metrics-address=[metrics address]:address:' \
  '--allow-gpu-metrics=[allow GPU metrics]:bool:(true false)' \
  '--allow-cpu-metrics=[allow CPU metrics]:bool:(true false)' \
  '--metrics-interval-ms=[metrics interval]:milliseconds:' \
  '--log-verbose=[verbose log level]:level:(0 1 2 3)' \
  '--log-info=[enable info logging]:bool:(true false)' \
  '--log-warning=[enable warning logging]:bool:(true false)' \
  '--log-error=[enable error logging]:bool:(true false)' \
  '--log-format=[log format]:format:(default ISO8601)' \
  '--log-file=[log file]:file:_files' \
  '--trace-config=[trace config]:config:' \
  '--id=[server ID]:id:' \
  '*:file:_files' && ret=0

return ret
