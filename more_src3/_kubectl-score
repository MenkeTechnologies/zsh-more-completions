#compdef kubectl-score
# kubectl-score (krew plugin): Kubernetes object analysis with recommendations
# https://github.com/zegl/kube-score

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--output-format=[output format]:format:(human ci json sarif)' \
  '--output-version=[output version for sarif]:version' \
  '--ignore-test=[ignore specific tests]:test' \
  '--enable-optional-test=[enable optional tests]:test' \
  '--ignore-container-cpu-limit[ignore container CPU limit test]' \
  '--ignore-container-memory-limit[ignore container memory limit test]' \
  '--kubernetes-version=[target Kubernetes version]:version' \
  '--verbose[verbose output]' \
  '*:file:_files -g "*.{yaml,yml,json}"'
