#compdef las2las
# Zsh completion for las2las - convert/filter/transform LAS files
# https://github.com/LAStools/LAStools

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  {-i,--input=}'[specify input LAS/LAZ file]:input file:_files' \
  {-o,--output=}'[specify output LAS/LAZ file]:output file:_files' \
  '--parse=[specify parse string for fields]:fields:' \
  '--keep-class=[keep only points of specified classification]:classification:' \
  '--drop-class=[drop points of specified classification]:classification:' \
  '--keep-return=[keep only points with specified return number]:return number:' \
  '--drop-return=[drop points with specified return number]:return number:' \
  '--keep-xy=[keep only points within XY bounding box (minX minY maxX maxY)]:bounding box:' \
  '--keep-z=[keep only points within Z range (minZ maxZ)]:z range:' \
  '--keep-intensity=[keep only points within intensity range (min max)]:intensity range:' \
  '--keep-time=[keep only points within time range (min max)]:time range:' \
  '--keep-scan-angle=[keep only points within scan angle range (min max)]:scan angle range:' \
  '--thin-with-grid=[thin points using grid of specified size]:grid size:' \
  '--thin-with-time=[thin points using time interval]:time interval:' \
  '--first-only[keep first returns only]' \
  '--last-only[keep last returns only]' \
  '--drop-first[drop first returns]' \
  '--drop-last[drop last returns]' \
  '--set-classification=[set classification for all points]:classification:' \
  '--set-return-number=[set return number for all points]:return number:' \
  '--set-number-of-returns=[set number of returns for all points]:number of returns:' \
  '--set-user-data=[set user data for all points]:user data:' \
  '--set-point-source=[set point source ID for all points]:point source ID:' \
  '--translate-xyz=[translate XYZ coordinates (X Y Z)]:translation X Y Z:' \
  '--scale-xyz=[scale XYZ coordinates (X Y Z)]:scale X Y Z:' \
  '--clamp-z=[clamp Z values to range (min max)]:z clamp range:' \
  '--clip-to-bounding-box[clip points to bounding box in header]' \
  '--merged[merge input files]' \
  '--verbose[verbose output]' \
  '*:file:_files'
