#compdef texdef latexdef contextdef lualatexdef xelatexdef
# Documentation: texdef --help (1.10)
# Source: TeX texdef — show definitions of (La)TeX commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --tex)'{-t,--tex=}'[TeX format]:format:(tex latex context luatex lualatex xetex xelatex luatex-dev lualatex-dev xetex-dev xelatex-dev latex-dev)' \
    '--texoptions=[options passed to (La)TeX]:opts:' \
    '(-s --source)'{-s,--source}'[show original source code]' \
    '(-v --value)'{-v,--value}'[show value (\\the\\command)]' \
    '(-E --Environment)'{-E,--Environment}'[treat names as environments]' \
    '(-P --preamble)'{-P,--preamble}'[show inside the preamble]' \
    '(-B --beforeclass)'{-B,--beforeclass}'[show before \\documentclass]' \
    '*'{-p,--package=}'[load package/file/module]:pkg:' \
    '*'{-c,--class=}'[load class (LaTeX only)]:class:' \
    '*'{-e,--environment=}'[show inside environment]:env:' \
    '*'{-o,--othercode=}'[preamble code added before show]:code:' \
    '*'{-b,--before=}'[code placed before definition]:code:' \
    '*'{-a,--after=}'[code placed after definition]:code:' \
    '(-f --find -F --Find)'{-f,--find}'[find file where command defined]' \
    '(-f --find -F --Find)'{-F,--Find}'[show full filepath]' \
    '(-l --list)'{-l,--list}'[list user-level commands of packages]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*:TeX command name:' \
    && ret=0

return ret
