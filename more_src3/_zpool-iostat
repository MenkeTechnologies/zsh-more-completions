#compdef zpool-iostat
# _zpool-iostat — OpenZFS zpool iostat (iostat(1)-style I/O statistics for pools/vdevs; -v breaks down by vdev, -l latency, -q queue depths, -r request sizes, -w latency histograms, -p parsable, -H scriptable, -T timestamp; trailing INTERVAL [COUNT] arguments run continuously)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_iostat) on tip.

_zpool-iostat() {
    _arguments \
        '-v[per-vdev]' \
        '-l[latency]' \
        '-q[queue depths]' \
        '-r[request size histograms]' \
        '-w[latency histograms]' \
        '-p[parsable]' \
        '-H[scriptable]' \
        '-y[exclude prefix summary]' \
        '-L[resolve symlinks]' \
        '-g[show GUIDs]' \
        '-P[full paths]' \
        '-c+[command (output augment)]:cmd:' \
        '-T+[timestamp format]:format:(u d)' \
        '*:pool [interval count]:'
}

_zpool-iostat "$@"
