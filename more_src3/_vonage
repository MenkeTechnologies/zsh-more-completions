#compdef vonage
# Documentation: https://github.com/Vonage/vonage-cli
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apps:manage applications'
  'auth:manage authentication information'
  'balance:check your account balance'
  'conversations:manage conversations'
  'jwt:manage JWT tokens'
  'members:manage applications'
  'mock:launch a mock server for Vonage APIs using Prism'
  'numbers:manage numbers'
  'users:manage users'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--verbose[print more information]' \
  '--debug[print debug information]' \
  '--no-color[toggle color output off]' \
  '--api-key=[Vonage API key]:key:' \
  '--api-secret=[Vonage API secret]:secret:' \
  '--app-id=[Vonage application id]:id:' \
  '--private-key=[path or contents of private key]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vonage command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments '*::sub:(set check show)' \
          '--local[local auth]' \
          '--show-all[show all]' \
          '--yaml[YAML output]' \
          '--json[JSON output]' && ret=0 ;;
      (mock)
        _arguments \
          '--port=[mock server port]:port:' \
          '--host=[mock server host]:host:' \
          '--download-only[only download]' \
          '--latest[use latest API spec]' \
          '*::api:(sms)' && ret=0 ;;
    esac ;;
esac

return ret
