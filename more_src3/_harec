#compdef harec
# Documentation: https://git.sr.ht/~sircmpwn/harec/tree/master/item/src/main.c
# Reference accessed: 2026-05-27
# Verified: upstream harec src/main.c getopt string "a:D:hM:m:N:o:Tt:v" and usage()

# harec: Hare bootstrap compiler. Flags are short-only (POSIX getopt, no long opts).
local curcontext="$curcontext" ret=1
_arguments -s \
  '-a+[set target architecture]:arch:' \
  '*-D+[define a constant (ident[:type]=value)]:define:' \
  '-h[print help text and exit]' \
  '-M+[set module path prefix to strip from error messages]:path:_files -/' \
  '-m+[set symbol of hosted main function]:symbol:' \
  '-N+[override namespace for module]:namespace:' \
  '-o+[set output file name]:output:_files' \
  '-T[emit tests]' \
  '-t+[emit typedefs to file]:file:_files' \
  '-v[print version and exit]' \
  '*:input:_files -g "*.ha"' && ret=0
return ret
