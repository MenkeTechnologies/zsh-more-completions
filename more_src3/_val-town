#compdef val-town vt vt-cli
# _val-town — Val Town vt CLI for the Val Town serverless TypeScript runtime managing vals projects HTTP triggers cron and shared environment secrets (val-town team, TypeScript); commander.js
# upstream: https://github.com/val-town/vt

_val-town() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'whoami:show current user'
        'create:create new val'
        'clone:clone val to local'
        'pull:pull val updates'
        'push:push local val'
        'list:list vals'
        'open:open val in browser'
        'delete:delete val'
        'rename:rename val'
        'fork:fork val'
        'run:run val'
        'logs:show val logs'
        'watch:watch val'
        'secrets:secrets operations'
        'env:env operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '--api-token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'val-town subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--type=+[t]:t:(http script email cron interval)' \
                    '--privacy=+[p]:p:(public private unlisted)' \
                    '--template=+[name]:str:' \
                    '*:name:' ;;
                run) _arguments \
                    '--input=+[file]:file:_files' \
                    '--output=+[file]:file:_files' \
                    '*:val name:' ;;
                secrets|env) _arguments \
                    '1:action:(list set get unset import export)' \
                    '*:key:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_val-town "$@"
