#compdef identify-cli
# _identify-cli — ImageMagick identify describes format/characteristics of image files CLI alias (ImageMagick team, C); custom argparse
# upstream: https://github.com/ImageMagick/ImageMagick

_identify-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-list+[list type]:str:' \
        '-format=+[output format]:str:' \
        '-verbose[verbose]' \
        '-ping[fast read]' \
        '-quiet[quiet]' \
        '-regard-warnings[treat warnings as errors]' \
        '-respect-parentheses[respect parentheses]' \
        '-set+[attr value]:str:' \
        '-strip[strip metadata]' \
        '-define=+[name=value]:str:' \
        '-debug=+[events]:str:' \
        '-precision=+[digits]:n:' \
        '-channel=+[type]:t:(Red Green Blue Cyan Magenta Yellow Black Alpha Opacity Index Default All Gray Sync)' \
        '-colorspace=+[colorspace]:c:(RGB sRGB CMYK Gray HSL HSB Lab YIQ YUV YCbCr XYZ HCL HCLp HSI HSV HWB LCH LCHab LCHuv Log scRGB)' \
        '-density=+[dpi]:str:' \
        '-depth=+[bits]:n:' \
        '-units=+[unit]:u:(PixelsPerInch PixelsPerCentimeter Undefined)' \
        '-extract=+[geometry]:str:' \
        '-features=+[distance]:n:' \
        '-fuzz=+[distance]:str:' \
        '-monitor[monitor progress]' \
        '-moments[print image moments]' \
        '-resolution=+[dpi]:str:' \
        '-size=+[geometry]:str:' \
        '-unique[print number of unique colors]' \
        '-cache=+[size]:str:' \
        '-concurrent[run in parallel]' \
        '-list+[type]:t:(Color Configure Coder Complex Compose Compress Configure Dash Debug Decoration Delegate Direction Dispose Distort Dither Endian Evaluate FillRule Filter Font Format Function Gravity Intensity Interlace Interpolate Kernel LayerMethod LineCap LineJoin List Locale LogEvent Log Magic Method Metric Mime Module Morphology NoiseType Orientation PixelChannel PixelIntensity PixelMask PixelTrait Policy PolicyDomain PolicyRights Primitive QuantumFormat Resource SparseColor Statistic Storage Stretch Style Threshold Tool TransmitType Type Units Validate VirtualPixel Weight)' \
        '*:files:_files'
}

_identify-cli "$@"
