#compdef s6-fdholder-list s6-fdholder-store s6-fdholder-retrieve
# Documentation: upstream skarnet.org/software/s6/
# s6-fdholder-{list,store,retrieve}.html
# Reference accessed: 2026-05-30 via WebFetch.
# Skarnet s6 fdholder R117 — 3-stem multi-binary harvest covering
# the s6 file-descriptor holder client utilities (each communicates
# with an s6-fdholderd daemon via UNIX socket). Sister tools to the
# already-covered s6-svc / s6-svstat / s6-svok / s6-svscan etc. svc
# manager family.

case $service in

  s6-fdholder-store)
    # Store a file descriptor in the fd-holder daemon under a given id.
    _arguments -s -S \
      '-d+[descriptor number to store (default 0)]:fd:' \
      '-T+[descriptor expiration time in ms]:ms:' \
      '-t+[operation timeout in ms]:ms:' \
      '1:fdholder socket path:_files' \
      '2:descriptor identifier:'
    ;;

  s6-fdholder-list)
    # List all descriptors currently held by the fd-holder daemon.
    _arguments -s -S \
      '-t+[operation timeout in ms]:ms:' \
      '1:fdholder socket path:_files'
    ;;

  s6-fdholder-retrieve)
    # Retrieve a held file descriptor and execute a program with it
    # connected to stdin.
    _arguments -s -S \
      '-D[delete the descriptor from server storage after retrieval]' \
      '-t+[operation timeout in ms]:ms:' \
      '1:fdholder socket path:_files' \
      '2:descriptor identifier:' \
      '*:program and arguments:_command_names -e'
    ;;

esac
