#compdef hco hco-cli
# _hco — KubeVirt Authors hco CLI command-line frontend to the HCO HyperConverged Cluster Operator for OpenShift OKD bundling KubeVirt CNAO CDI SSP HostPath-Provisioner CIS-image-provider Topology-Aware-Hubble-cluster-network-addons-aaq-network-policy MTQ kubernetes-NMState operator-deployment lifecycle (KubeVirt team, Go); cobra
# upstream: https://github.com/kubevirt/hyperconverged-cluster-operator

_hco() {
    local -a sub=(
        'apply:apply HCO CR'
        'delete:delete HCO CR'
        'status:show status'
        'wait:wait until ready'
        'upgrade:upgrade HCO'
        'reset:reset HCO'
        'config:edit configuration'
        'list-operators:list bundled operators'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--cr-file=+[file]:file:_files -g "*.yaml *.yml"' \
        '--cr-name=+[name]:str:' \
        '--phase=+[p]:p:(Available Degraded Progressing Reconciling Upgradeable)' \
        '-o+[output]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hco subcommand' sub ;;
    esac
}

_hco "$@"
