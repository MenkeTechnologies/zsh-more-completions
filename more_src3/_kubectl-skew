#compdef kubectl-skew
# kubectl-skew (krew plugin): show version skew between nodes and control plane
# https://github.com/dty1er/kubecolor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)'
