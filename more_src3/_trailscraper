#compdef trailscraper
# Documentation: https://github.com/flosell/trailscraper
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# trailscraper: get usable information out of AWS CloudTrail
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'download:downloads CloudTrail logs from S3'
  'select:loads CloudTrail records and prints them as JSON'
  'generate:generates IAM policy from CloudTrail events (stdin)'
  'guess:extends an IAM policy by guessing related actions'
  'last-event-timestamp:print the most recent timestamp seen in logs'
  'find-cloudtrail-events:find CloudTrail events for a resource'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[suppress output]' \
  '--verbose[verbose output]' \
  '--log-file=[log file path]:file:_files' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'trailscraper command' commands && ret=0
    ;;
  args)
    case $line[1] in
      download)
        _arguments \
          '--bucket=[S3 bucket containing CloudTrail logs]:bucket' \
          '*--account-id=[AWS account ID(s)]:id' \
          '*--region=[AWS region(s)]:region' \
          '--org-id=[organization ID for organizational trails]:id' \
          '--from=[start time]:time' \
          '--to=[end time]:time' \
          '--profile=[AWS profile]:profile' \
          '--no-parallel[disable parallel downloads]' && ret=0
        ;;
      select)
        _arguments \
          '--use-cloudtrail-api[use CloudTrail API directly]' \
          '--filter-assumed-role-arn=[filter by assumed role ARN]:arn' \
          '--from=[start time]:time' \
          '--to=[end time]:time' \
          '*:log file:_files' && ret=0
        ;;
      generate)
        _arguments \
          '*:file:_files' && ret=0
        ;;
      guess)
        _arguments \
          '--only=[filter by verb prefix (e.g. Get)]:prefix' \
          '*:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
