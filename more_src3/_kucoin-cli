#compdef kucoin-cli kucoin
# _kucoin-cli — KuCoin kucoin-cli CLI command-line frontend wrapping the KuCoin cryptocurrency exchange Spot Margin Futures REST WebSocket API managing accounts wallets orders trades positions market kline tickers depth funding deposit withdrawal transfer sub-account stop-limit market trade-fee currency symbol stats (KuCoin team, Go); cobra
# upstream: https://www.kucoin.com/

_kucoin-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'wallet:wallet operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'kline:kline candlestick data'
        'ticker:ticker operations'
        'depth:order book depth'
        'funding:funding operations'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'transfer:transfer operations'
        'subaccount:sub-account management'
        'symbol:symbol operations'
        'currency:currency operations'
        'futures:futures operations'
        'margin:margin operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-passphrase=+[phrase]:str:' \
        '--api-url=+[url]:str:' \
        '--api-version=+[v]:str:' \
        '--sandbox[use sandbox]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kucoin-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all history)' \
                    '--symbol=+[sym]:str:' \
                    '--side=+[s]:s:(buy sell)' \
                    '--type=+[t]:t:(limit market stop_limit market_stop limit_stop)' \
                    '--size=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '--time-in-force=+[t]:t:(GTC GTT IOC FOK)' \
                    '*:order id:' ;;
                account|wallet|trade|position|funding|deposit|withdrawal|transfer|subaccount|symbol|currency|futures|margin) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                kline|ticker|depth) _arguments \
                    '--symbol=+[sym]:str:' \
                    '--type=+[i]:i:(1min 3min 5min 15min 30min 1hour 2hour 4hour 6hour 8hour 12hour 1day 1week)' \
                    '--limit=+[N]:n:' ;;
            esac
            ;;
    esac
}

_kucoin-cli "$@"
