#compdef timeshift-cli
# Documentation: https://github.com/linuxmint/timeshift/blob/master/src/AppConsole.vala
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: timeshift-cli is a symlink to timeshift on most distributions; flags
# match the timeshift CLI exactly.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--check[create snapshot if scheduled]' \
  '--create[create snapshot now]' \
  '--list[list snapshots]' \
  '--list-snapshots[list snapshots]' \
  '--list-devices[list devices]' \
  '--restore[restore snapshot]' \
  '--delete[delete snapshot]' \
  '--delete-all[delete all snapshots]' \
  '--clone[clone current system]' \
  '--snapshot=[snapshot name]:name:' \
  '--snapshot-name=[snapshot name]:name:' \
  '--snapshot-device=[backup device]:device:_files -g "/dev/*"' \
  '--backup-device=[backup device]:device:_files -g "/dev/*"' \
  '--target=[target device]:device:_files -g "/dev/*"' \
  '--target-device=[target device]:device:_files -g "/dev/*"' \
  '--grub=[GRUB2 device]:device:_files -g "/dev/*"' \
  '--grub-device=[GRUB2 device]:device:_files -g "/dev/*"' \
  '--skip-grub[skip GRUB2 reinstall]' \
  '--btrfs[BTRFS mode]' \
  '--rsync[rsync mode]' \
  '--scripted[non-interactive mode]' \
  '--yes[answer yes to all prompts]' \
  '--comment=[snapshot description]:comment:' \
  '--comments=[snapshot description]:comment:' \
  '--tags=[snapshot tags]:tag:(O B H D W M)' \
  '--debug[show debug messages]' \
  '--verbose[show rsync output]' \
  '--quiet[hide rsync output]' && ret=0

return ret
