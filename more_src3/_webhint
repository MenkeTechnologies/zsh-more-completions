#compdef webhint hint
# Documentation: https://github.com/webhintio/hint
# Reference accessed: 2026-05-16
# Verified: webhintio/hint packages/hint/src/lib/cli/options.ts.
# Removed from prior file: bogus man.archlinux.org search URL.

_arguments -s \
  '(-c --config)'{-c,--config=}'[config file or shareable config]:config:_files' \
  '--debug[debug output]' \
  '--analytics-debug[analytics debug]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-w --watch)'{-w,--watch}'[connector watcher]' \
  '*'{-f,--formatters=}'[formatter(s)]:formatter:' \
  '*'{-r,--hints=}'[hint(s) to use]:hint:' \
  '(-t --telemetry)'{-t,--telemetry=}'[telemetry on/off]:value:(on off)' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '(-l --language)'{-l,--language=}'[language code]:lang:' \
  '*:url-or-file:_files'
