#compdef uu-echo
# Documentation: https://uutils.github.io/coreutils/docs/utils/echo.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

autoload -U is-at-least

_uu-echo() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-n[do not output the trailing newline]' \
'-e[enable interpretation of backslash escapes]' \
'-E[disable interpretation of backslash escapes (default)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::STRING:_default' \
&& ret=0
}

(( $+functions[_uu-echo_commands] )) ||
_uu-echo_commands() {
    local commands; commands=()
    _describe -t commands 'uu-echo commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-echo" ]; then
    _uu-echo "$@"
else
    compdef _uu-echo uu-echo
fi
