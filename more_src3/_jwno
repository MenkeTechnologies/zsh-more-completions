#compdef jwno
# ============================================================================
#  _jwno — Jwno: A Tiling Window Manager for Windows 10/11, written in Janet
#
#  Source-direct extraction from
#    https://github.com/agent-kilo/jwno/blob/master/src/config.janet
#
#  Authored by agent-kilo.  466 GH stars (production tiling WM deployed on
#  Windows 10/11 via Janet runtime + Win32 FFI).
#
#  CLI library taxonomy update: first documented Janet entry.  jwno uses
#  bakpakin/spork's `argparse` module — `(use spork/argparse)` brings the
#  `argparse` macro into scope.  spork is the de-facto Janet "extras"
#  library distributed alongside Calvin Rose's Janet language, providing
#  argparse + path + json + sh + fmt + http modules.  Spec-as-VARARGS-LIST
#  declarative API: `(argparse "description" "flag-name" {:kind :flag
#  :short "f" :help "..." :default ... :map fn} ...)` returns a dictionary
#  keyed by flag name.  Brings cross-language CLI library taxonomy variant
#  count to 75.
#
#  Surface (verbatim from src/config.janet `parse-command-line`):
#    --client      -C  flag        Start in REPL client mode
#    --config      -c  accumulate  Config file path (default jwno-config.janet)
#    --eval        -e  accumulate  Evaluate Janet code through REPL
#    --execute     -x  accumulate  Execute command through REPL
#    --export-all  -E  flag        Export REPL symbols after --eval processing
#    --log-file        option      Log file destination
#    --log-level       option      quiet/error/warning/info/debug (default quiet)
#    --mod-path    -m  accumulate  Custom module load path
#    --no-console      flag        Suppress console output
#    --repl        -r  option      REPL listen address (validated against PEG
#                                  for IPv4:PORT — `IP.IP.IP.IP:PORT` with
#                                  port range 1-65535, octet range 0-255)
#    --version     -v  flag        Show version info and exit
#    (default)         accumulate  Positional args treated as config files
#
#  Dup-skipped neighbors during hunt (already in corpus or unfit):
#    - jeff (tionis/jeff Janet fuzzy finder, AVAILABLE but smaller surface)
#    - x43bot (bakpakin/x43bot demo bot, smaller surface)
#    - beancraft (alexalemi register-machine compiler, smaller)
#    - judge (ianthehenry/judge Janet test framework — uses cmd library
#      not spork/argparse, would be SISTER demo)
# ============================================================================

_jwno() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-C --client)'{-C,--client}'[start in REPL client mode]' \
    '*'{-c,--config}'[config file path (accumulates)]:config file:_files -g "*.janet"' \
    '*'{-e,--eval}'[evaluate Janet code through REPL (accumulates)]:janet code' \
    '*'{-x,--execute}'[execute command through REPL (accumulates)]:command' \
    '(-E --export-all)'{-E,--export-all}'[export all REPL symbols after --eval processing]' \
    '--log-file=[log file destination]:log file:_files' \
    '--log-level=[log level]:level:(quiet error warning info debug)' \
    '*'{-m,--mod-path}'[custom module load path (accumulates)]:module path:_directories' \
    '--no-console[suppress console output]' \
    '(-r --repl)'{-r,--repl}'[REPL listen address (IPv4:PORT)]:address (e.g. 127.0.0.1:9001)' \
    '(-v --version)'{-v,--version}'[show version info and exit]' \
    '*:config file:_files -g "*.janet"'
}

_jwno "$@"
