#compdef kea-shell
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/kea-shell.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kea-shell: Kea control agent JSON shell. Corrected from prior file:
# removed invented --auth, --auth-password, --auth-passwordfile, --key
# joins; --service enum is dhcp4|dhcp6|d2|ca per upstream; only -h/-v
# are short flags (no --help long form documented).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[display help regarding command-line parameters]' \
  '-v[display the Kea version]' \
  '--host=[host to connect to]:host:_hosts' \
  '--port=[TCP port to connect to]:port:' \
  '--path=[path in the URL to connect to]:path:' \
  '--ca=[file or directory name of the Certification Authority]:file:_files' \
  '--cert=[user end-entity public key certificate file]:file:_files' \
  '--key=[user key file]:file:_files' \
  '--auth-user=[user ID for basic HTTP authentication]:user:_users' \
  '--auth-password=[password for basic HTTP authentication]:pass:' \
  '--timeout=[connection timeout, in seconds]:s:' \
  '*--service=[service that is the target of a command]:service:(dhcp4 dhcp6 d2 ca)' \
  '*:command:' && ret=0
return ret
