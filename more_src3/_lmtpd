#compdef lmtpd
# Documentation: lmtpd --help (GNU Mailutils)
# Source: GNU Mailutils Local Mail Transfer Protocol daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)--usage[short usage]' \
    '(- *)'{-V,--version}'[show version]' \
    {-d+,--daemon=-}'[daemon mode (max NUMBER children)]::n:' \
    '--foreground[remain in foreground]' \
    '--no-foreground[do not remain in foreground]' \
    {-i,--inetd}'[run in inetd mode]' \
    '--no-inetd[do not run in inetd mode]' \
    '--stderr[log to standard error]' \
    '--transcript[enable session transcript]' \
    '--no-transcript[disable session transcript]' \
    '--debug-level=[Mailutils debug level]:level:' \
    '--debug-line-info[show source info with debug messages]' \
    '--no-debug-line-info[do not show source info]' \
    '--log-facility=[syslog facility]:facility:(auth authpriv cron daemon ftp kern lpr mail news syslog user uucp local0 local1 local2 local3 local4 local5 local6 local7)' \
    {-M+,--mailer=}'[default mailer URL]:url:' \
    '--clear-include-path[clear Sieve include path]' \
    '--clear-library-path[clear Sieve library path]' \
    '--clearpath[clear Sieve library path]' \
    '*'{-I+,--includedir=}'[append DIR to Sieve include dirs]:dir:_files -/' \
    '*'{-L+,--libdir=}'[append DIR to Sieve library dirs]:dir:_files -/' \
    '*--libdir-prefix=[prepend DIR to Sieve library dirs]:dir:_files -/' \
    '--config-file=[load configuration file]:file:_files' \
    '--config-lint[check config syntax and exit]' \
    '--config-verbose[verbosely log config parsing]' \
    '--no-site-config[do not load site-wide config]' \
    '--no-config[do not load site-wide config]' \
    '*--set=[set configuration parameter PARAM=VALUE]:assignment:' \
    '--config-help[show config file summary]' \
    '--show-config-options[show compilation options]' \
    && ret=0

return ret
