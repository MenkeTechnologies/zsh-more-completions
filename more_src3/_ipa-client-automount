#compdef ipa-client-automount
# Documentation: https://github.com/freeipa/freeipa/blob/master/client/man/ipa-client-automount.1
# Reference accessed: 2026-05-16
# Verified: upstream client/man/ipa-client-automount.1.

# ipa-client-automount: configure NFS/automount on IPA client
local curcontext="$curcontext" ret=1
_arguments -C \
  '--server=[IPA server FQDN]:host:_hosts' \
  '--domain=[primary DNS domain]:domain:' \
  '--location=[automount location]:location:' \
  '--idmap-domain=[NFS domain for idmapd.conf]:domain:' \
  '(-d --debug)'{-d,--debug}'[print debugging info]' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' \
  '--uninstall[restore automount configuration files]' && ret=0
return ret
