#compdef valhalla_add_predicted_traffic
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/mjolnir/valhalla_add_predicted_traffic.cc — overlay predicted speed tiles onto graph.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[JSON config file]:file:_files -g "*.json(-.)"' \
    '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' \
    '(-j --concurrency)'{-j+,--concurrency=}'[number of threads]:n:_default' \
    '(-s --summary)'{-s,--summary}'[output traffic-coverage summary]' \
    '(-t --traffic-tile-dir)'{-t+,--traffic-tile-dir=}'[traffic tile directory]:dir:_directories' \
    '*:traffic tile dir:_directories' \
    && ret=0

return ret
