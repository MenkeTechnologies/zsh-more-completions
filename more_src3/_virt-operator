#compdef virt-operator
# _virt-operator — KubeVirt cluster operator (kubevirt/kubevirt)
# upstream: https://github.com/kubevirt/kubevirt
# Flags from pkg/virt-operator/application.go + pkg/service/service.go on tip.

_virt-operator() {
    _arguments \
        '--listen=[bind address]:ip:' \
        '--port=[bind port]:port:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--dump-install-strategy[dump install strategy to configmap and exit]' \
        '--client-qps=[Kubernetes client QPS]:f:' \
        '--client-burst=[Kubernetes client burst]:n:'
}

_virt-operator "$@"
