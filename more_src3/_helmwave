#compdef helmwave
# Documentation: https://github.com/helmwave/helmwave
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build a plan'
  'diff:show differences'
  'vs:alias for diff'
  'up:apply your plan'
  'list:list deployed releases'
  'ls:alias for list'
  'rollback:rollback your plan'
  'status:status of deployed releases'
  'down:delete all releases'
  'validate:validate your plan'
  'yml:render helmwave.yml.tpl'
  'version:show version'
  'ver:alias for version'
  'completion:generate shell completion'
  'help:show help'
  'h:alias for help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--log-format=[log format]:fmt:(text json pad emoji)' \
  '--log-level=[log level]:lvl:(debug info warn fatal panic trace)' \
  '--log-color[force color output]' \
  '--no-log-color[disable color]' \
  '--kubedog-log-width=[max kubedog log width]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'helmwave command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '--file=[helmwave plan tpl]:file:_files -g "*.yml *.tpl *.yaml"' \
          '--plandir=[plan output dir]:dir:_files -/' \
          '--tags=[tags csv]:list:' \
          '--match-all-tags[match all tags]' \
          '--diff-mode=[diff mode]:mode:(none live local)' \
          '--diff-show-secret[show secret diff]' \
          '--diff-three-way-merge[three-way merge diff]' \
          '--graph-width=[graph width]:n:' \
          '--graph-mode=[graph mode]:mode:(text png)' \
          '--remote-source[fetch remote source]' \
          '--skip-unchanged[skip unchanged releases]' \
          '--templater=[templater]:t:(sprig copy)' \
          '--yml=[output yml file]:file:_files -g "*.yml *.yaml"' && ret=0 ;;
      (up|rollback|down|status|list|ls|validate|diff|vs)
        _arguments \
          '--build[auto build before action]' \
          '--plandir=[plan dir]:dir:_files -/' \
          '--tags=[tags csv]:list:' \
          '--match-all-tags[match all tags]' \
          '--kubedog[enable kubedog]' \
          '--no-kubedog[disable kubedog]' \
          '--kubedog-status-interval=[interval]:dur:' \
          '--kubedog-start-delay=[delay]:dur:' \
          '--kubedog-timeout=[timeout]:dur:' \
          '--progress[enable progress logs]' \
          '--max-history=[max history]:n:' \
          '--parallel-limit=[parallel limit]:n:' \
          '--revision=[rollback revision]:n:' \
          '--remove-no-tags[remove releases without tags]' && ret=0 ;;
      (yml)
        _arguments \
          '--file=[input tpl file]:file:_files -g "*.yml *.tpl *.yaml"' \
          '--templater=[templater]:t:(sprig copy)' && ret=0 ;;
    esac ;;
esac

return ret
