#compdef xclipboard
# _xclipboard — xclipboard X clipboard manager (X.Org); maintains the CLIPBOARD selection across selections
# upstream: https://gitlab.freedesktop.org/xorg/app/xclipboard

_xclipboard() {
    _arguments \
        '-help[show help]' \
        '-display+[X display]:display:' \
        '-geometry+[geometry]:geom:' \
        '-background+[bg color]:color:' \
        '-foreground+[fg color]:color:' \
        '-bg+[bg color]:color:' \
        '-fg+[fg color]:color:' \
        '-bw+[border width]:n:' \
        '-bd+[border color]:color:' \
        '-bordercolor+[border color]:color:' \
        '-fn+[font]:font:' \
        '-font+[font]:font:' \
        '-iconic[start iconified]' \
        '-name+[window name]:name:' \
        '-rv[reverse video]' \
        '-reverse[reverse video]' \
        '-selectionFormat+[selection format]:format:(CHARS LINES)' \
        '-title+[window title]:title:' \
        '-xrm+[xrm resource]:resource:' \
        '-w[disable word wrap]' \
        '-nw[enable word wrap]' \
        '-nostdin[do not read stdin]'
}

_xclipboard "$@"
