#compdef vagga
# Documentation: https://github.com/tailhook/vagga/blob/master/docs/commandline.rst
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-E,--env,--environ}'=[NAME=VALUE]:env:' \
  '*'{-e,--use-env}'=[propagate var]:var:' \
  '--no-build[do not rebuild]' \
  '--no-version-check[skip version check]' \
  '-m[multi-command mode]' \
  '*:command:'
