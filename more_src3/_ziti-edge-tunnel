#compdef ziti-edge-tunnel
# _ziti-edge-tunnel — OpenZiti edge tunneler (openziti/ziti-tunnel-sdk-c)
# upstream: https://github.com/openziti/ziti-tunnel-sdk-c
# Flags from programs/ziti-edge-tunnel/ziti-edge-tunnel.c (getopt_long).

_ziti-edge-tunnel() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)*'{-v,--verbose}'[verbose logging level]:level:' \
        '*'{-i+,--identity=}'[identity JWT or JSON file]:file:_files' \
        '(-I --identity-dir)'{-I+,--identity-dir=}'[identity directory]:dir:_files -/' \
        '(-r --refresh)'{-r+,--refresh=}'[refresh interval (seconds)]:seconds:' \
        '(-d --dns-ip-range)'{-d+,--dns-ip-range=}'[DNS IP range]:cidr:' \
        '(-u --dns-upstream)'{-u+,--dns-upstream=}'[upstream DNS server]:server:' \
        '(-x --proxy)'{-x+,--proxy=}'[HTTP/SOCKS proxy URL]:url:' \
        '(-p --pcap-iface)'{-p+,--pcap-iface=}'[capture interface for pcap output]:iface:_net_interfaces' \
        '--diverter=[Linux diverter spec]:spec:' \
        '--diverter-fw=[Linux diverter firewall spec]:spec:' \
        '(-K --use-keychain)'{-K,--use-keychain}'[store identity in OS keychain]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run the edge tunneler'
                'run-host:run in host-only mode'
                'add:enroll a new identity'
                'enroll:enroll an identity from JWT'
                'on-off:set tunnel on/off'
                'tunnel_status:show current tunnel status'
                'dump:dump runtime state'
                'controller_status:show controller status'
                'service:install / uninstall as a service'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                enroll|add)
                    _arguments \
                        '--url=[controller URL]:url:' \
                        '--jwt=[JWT file]:file:_files' \
                        '--identity=[identity output file]:file:_files' \
                        '--use-keychain[store identity in OS keychain]'
                    ;;
            esac
            ;;
    esac
}

_ziti-edge-tunnel "$@"
