#compdef sh2response
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/sh2response.html
# Source: MRtrix3/mrtrix3 cmd/sh2response.cpp — estimate axially-symmetric response from SH (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-lmax+[max harmonic degree to estimate]:value:_default' \
    '-dump+[dump m=0 coefficients from all voxels]:file:_files' \
    '1:SH image:_files -g "*.{nii,nii.gz,mif}"' \
    '2:mask:_files -g "*.{nii,nii.gz,mif}"' \
    '3:directions (4D direction image):_files -g "*.{nii,nii.gz,mif}"' \
    '4:response (output coefficients):_files -g "*.txt"' \
    && ret=0

return ret
