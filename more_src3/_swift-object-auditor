#compdef swift-object-auditor
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/obj/auditor.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '(-z --zero_byte_fps)'{-z+,--zero_byte_fps=}'[audit only zero byte files at specified files/sec]:fps:' \
  '(-d --devices)'{-d+,--devices=}'[audit only given devices, comma-separated]:devices:' \
  '*:CONFIG file:_files -g "*.conf"' && ret=0
return ret
