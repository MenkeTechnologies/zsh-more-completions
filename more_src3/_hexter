#compdef hexter hexter_gtk
# Documentation: https://smbolton.com/hexter.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hexter is a Yamaha DX7 modeling DSSI soft synth. The plugin loads inside a
# DSSI host; the GUI binary (hexter_gtk) supports a single -test flag to run
# standalone for testing.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-test[run GUI standalone without a DSSI host]' \
  '*:hexter plugin .so:_files -g "*.so"' && ret=0
return ret
