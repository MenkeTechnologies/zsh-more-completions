#compdef karmada-scheduler-estimator
# _karmada-scheduler-estimator — Karmada per-cluster scheduling estimator gRPC server (karmada-io/karmada)
# upstream: https://github.com/karmada-io/karmada
# Flags from cmd/scheduler-estimator/app/options/options.go (pflag).

_karmada-scheduler-estimator() {
    _arguments \
        '--kubeconfig=[member cluster kubeconfig file]:file:_files' \
        '--master=[member cluster API server address]:url:_urls' \
        '--cluster-name=[member cluster name served]:name:' \
        '--server-port=[secure gRPC port]:port:' \
        '--grpc-auth-cert-file=[gRPC SSL certificate]:file:_files' \
        '--grpc-auth-key-file=[gRPC SSL key]:file:_files' \
        '--insecure-skip-grpc-client-verify[do not verify gRPC client certs]' \
        '--grpc-client-ca-file=[CA for verifying gRPC client certificates]:file:_files' \
        '--kube-api-burst=[burst for kube clients]:n:' \
        '--parallelism=[parallelism for estimating algorithm]:n:' \
        '--metrics-bind-address=[metrics bind address]:host\:port:' \
        '--health-probe-bind-address=[health probe bind address]:host\:port:'
}

_karmada-scheduler-estimator "$@"
