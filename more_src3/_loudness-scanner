#compdef loudness loudness-scanner loudness-drop
# _loudness-scanner — Jan Kokemüller libebur128 loudness-scanner CLI for EBU R128 loudness scanning and tagging (jiixyj team, C); getopt-ish
# upstream: https://github.com/jiixyj/loudness-scanner

_loudness-scanner() {
    local -a sub=(
        'scan:scan files for loudness'
        'tag:tag files with loudness metadata'
        'dump:dump loudness samples'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-d[print decoded info]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--decode-only[decode only]' \
        '-i+[input plugin]:p:(sndfile mpg123 ffmpeg gstreamer libavformat)' \
        '--input=+[input plugin]:p:(sndfile mpg123 ffmpeg gstreamer libavformat)' \
        '--lra[print LRA]' \
        '--max-true-peak[print max true peak]' \
        '--max-momentary[print max momentary]' \
        '--max-shortterm[print max shortterm]' \
        '--peak=+[mode]:p:(sample true dbtp all none)' \
        '--force-plg[force plugin]' \
        '--no-sort[no sort]' \
        '--csv[CSV output]' \
        '-t+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'loudness-scanner subcommand' sub ;;
        args)
            case $words[1] in
                scan|tag|dump) _arguments \
                    '*:audio file:_files -g "*.wav *.flac *.mp3 *.ogg *.opus *.aac *.m4a *.aiff *.au *.snd"' ;;
            esac
            ;;
    esac
}

_loudness-scanner "$@"
