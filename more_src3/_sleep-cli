#compdef sleep-cli
# _sleep-cli — GNU coreutils sleep delay for specified amount of time CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_sleep-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '*:duration:'
}

_sleep-cli "$@"
