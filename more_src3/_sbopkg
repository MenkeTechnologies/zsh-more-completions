#compdef sbopkg
# Documentation: https://raw.githubusercontent.com/sbopkg/sbopkg/master/src/usr/man/man8/sbopkg.8
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-b+[build packages or queues]:packages:' \
  '-B[process without prompting for confirmation]' \
  '-c[display installed SBo packages and potential updates]' \
  '-d+[download source archives]:packages:' \
  '-D+[path to local SBo repository]:directory:_files -/' \
  '-e+[error handling]:mode:(ask continue stop)' \
  '-f+[config file]:file:_files' \
  '-g+[case-insensitive glob search]:query:' \
  '(- *)-h[show help]' \
  '-i+[download, build, and install packages]:packages:' \
  '-k[skip already-installed packages]' \
  '-l[display SBo ChangeLog and quit]' \
  '-n[download rename file and quit]' \
  '-o[list and optionally delete obsolete cached sources]' \
  '-P[list and optionally delete uninstalled cached packages]' \
  '-p[list installed SBo packages]' \
  '-q[quiet mode]' \
  '-R[view README files before processing]' \
  '-r[rsync local repository with SBo and quit]' \
  '-S[sandbox mode]' \
  '-s+[case-sensitive glob search]:query:' \
  '-u[check for sbopkg updates and quit]' \
  '-V+[set repository and branch]:version:' \
  '(- *)-v[print version]' \
  '-W+[search installed packages by file or path]:query:' && ret=0

return ret
