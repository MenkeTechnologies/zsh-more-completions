#compdef zswapctl
# _zswapctl — Linux kernel zswap CLI helper around /sys/module/zswap/parameters tunables enable disable compressor lz4 lzo zstd zstd-fast pool zsmalloc z3fold zbud max_pool_percent same_filled_pages_enabled accept_threshold_percent live runtime tuning for compressed swap cache (Linux team, shell); custom argparse
# upstream: https://www.kernel.org/doc/html/latest/admin-guide/mm/zswap.html

_zswapctl() {
    local -a sub=(
        'status:show current settings'
        'enable:enable zswap'
        'disable:disable zswap'
        'compressor:get or set compressor'
        'pool:get or set zpool backend'
        'max-pool:get or set max_pool_percent'
        'same-filled:enable same_filled_pages compression'
        'accept-threshold:set accept_threshold_percent'
        'stats:show per-counter stats'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zswapctl subcommand' sub ;;
        args)
            case $words[1] in
                compressor) _arguments '1:compressor:(lzo lz4 lz4hc zstd zstd-fast deflate 842)' ;;
                pool) _arguments '1:pool:(zbud z3fold zsmalloc)' ;;
                max-pool|accept-threshold) _arguments '1:percent:' ;;
                same-filled) _arguments '1:value:(on off)' ;;
            esac
            ;;
    esac
}

_zswapctl "$@"
