#compdef sfwindow
# Documentation: http://www.ahay.org/RSF/sfwindow.html
# Source: ahay/src system/main/window.c — extract a windowed subset of an RSF dataset.
# Reference accessed: 2026-06-10
#
# Per-axis params use # = 1, 2, 3, ... (e.g. n1=, f1=, j1=, d1=, min1=, max1=).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'verb=[(y/n) verbose]: :(y n)' \
    'squeeze=[(y/n) drop singleton dims to end]: :(y n)' \
    'n1=[window size, 1st axis]: :_default' \
    'f1=[window start, 1st axis]: :_default' \
    'j1=[jump (step) in 1st axis]: :_default' \
    'd1=[sampling, 1st axis]: :_default' \
    'min1=[min coord, 1st axis]: :_default' \
    'max1=[max coord, 1st axis]: :_default' \
    'n2=[window size, 2nd axis]: :_default' \
    'f2=[window start, 2nd axis]: :_default' \
    'j2=[jump (step) in 2nd axis]: :_default' \
    'd2=[sampling, 2nd axis]: :_default' \
    'min2=[min coord, 2nd axis]: :_default' \
    'max2=[max coord, 2nd axis]: :_default' \
    'n3=[window size, 3rd axis]: :_default' \
    'f3=[window start, 3rd axis]: :_default' \
    'j3=[jump (step) in 3rd axis]: :_default' \
    'd3=[sampling, 3rd axis]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
