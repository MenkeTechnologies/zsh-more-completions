#compdef jsonnetfmt
# Documentation: https://github.com/google/jsonnet/blob/master/cmd/jsonnetfmt.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jsonnetfmt (Jsonnet code formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --exec)'{-e,--exec}'[treat filename as code]' \
  '(-o --output-file)'{-o+,--output-file=}'[write to the output file rather than stdout]:file:_files' \
  '(-i --in-place)'{-i,--in-place}'[update the Jsonnet file(s) in place]' \
  '--test[exit with failure if reformatting changed the file]' \
  '(-n --indent)'{-n+,--indent=}'[number of spaces to indent]:n:' \
  '--max-blank-lines=[max number of consecutive blank lines]:n:' \
  '--string-style=[string quoting style]:style:((d\:"double quotes" s\:"single quotes" l\:"leave as-is"))' \
  '--comment-style=[comment style]:style:((h\:"hash comments" s\:"slash comments" l\:"leave as-is"))' \
  '--pretty-field-names[use syntax sugar for fields and indexing]' \
  '--no-pretty-field-names[do not use syntax sugar for fields and indexing]' \
  '--pad-arrays[put spaces inside array brackets]' \
  '--no-pad-arrays[do not put spaces inside array brackets]' \
  '--pad-objects[put spaces inside object braces]' \
  '--no-pad-objects[do not put spaces inside object braces]' \
  '--sort-imports[sort top-level imports in alphabetical order]' \
  '--no-sort-imports[do not sort top-level imports]' \
  '--debug-desugaring[unparse the desugared AST without executing it]' \
  '*:jsonnet file:_files -g "*.jsonnet(|lib)(N)"' && ret=0

return ret
