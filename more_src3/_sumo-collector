#compdef sumo-collector
# Documentation: https://www.sumologic.com/help/docs/send-data/installed-collectors/collector-installation-reference/parameters-command-line-installer/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# sumo-collector: Sumo Logic Installed Collector installer
local curcontext="$curcontext" ret=1
_arguments -C \
  '-console[send progress messages to console (use with -q)]' \
  '-dir+[installation directory]:dir:_directories' \
  '-q[run installer silently without prompts]' \
  '-varfile+[read parameters from configuration file]:file:_files' \
  '-Vcollector.secureFiles=[control enhanced filesystem security]:bool:(true false)' \
  '-VrunAs.username=[user account running the collector]:user:_users' \
  '-VwinRunAs.password=[Windows password for RunAs user]:password:' \
  '-VskipRegistration=[skip registration during installation]:bool:(true false)' \
  '-Vsumo.accessid=[Sumo access ID]:id:' \
  '-Vsumo.accesskey=[Sumo access key]:key:' \
  '-Vsumo.token_and_url=[installation token]:token:' \
  '*::sumo-collector args:_files' && ret=0
return ret
