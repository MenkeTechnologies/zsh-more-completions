#compdef watchman
# Documentation: watchman --help (Meta watchman)
# Source: file-watching service for triggering builds/actions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'clock:return server clock for a watch root'
    'debug-ageout:age out unused watch state'
    'debug-status:show internal status'
    'debug-watcher-info:print watcher info'
    'find:find files matching watchman pattern'
    'flush-subscriptions:flush pending subscription events'
    'get-config:print effective config'
    'get-log:get recent log events'
    'get-pid:show watchman server PID'
    'get-sockname:print server socket path'
    'global-log-level:set global log verbosity'
    'list-capabilities:list server capabilities'
    'log:emit a log event'
    'log-level:set log level for this session'
    'query:run a watchman query'
    'shutdown-server:shut down the server'
    'since:list files changed since clockspec'
    'state-enter:enter a named state'
    'state-leave:leave a named state'
    'subscribe:subscribe to changes'
    'trigger:install a trigger'
    'trigger-del:delete a trigger'
    'trigger-list:list triggers'
    'unsubscribe:remove a subscription'
    'version:print server version'
    'watch:add a watch'
    'watch-del:remove a watch'
    'watch-del-all:remove every watch'
    'watch-list:list watches'
    'watch-project:add a project watch'
)

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--inetd[spawned from an inetd supervisor]' \
    '(-S --no-site-spawner)'{-S,--no-site-spawner}'[do not use site/system spawner]' \
    '(-U --sockname)'{-U+,--sockname=}'[alternate sockname (deprecated)]:path:_files' \
    '--named-pipe-path=[alternate named pipe path]:path:_files' \
    '(-u --unix-listener-path)'{-u+,--unix-listener-path=}'[unix domain socket path]:path:_files' \
    '(-o --logfile)'{-o+,--logfile=}'[log file path (- for stdout/stderr)]:path:_files' \
    '--log-level=[log level (0=off, 1=default, 2=verbose)]:n:(0 1 2)' \
    '--pidfile=[pid file path]:path:_files' \
    '(-p --persistent)'{-p,--persistent}'[persist and await further responses]' \
    '(-n --no-save-state)'{-n,--no-save-state}'[do not save state between invocations]' \
    '--statefile=[state file path]:path:_files' \
    '(-j --json-command)'{-j,--json-command}'[read JSON command from stdin]' \
    '--output-encoding=[CLI output encoding]:enc:(json bser)' \
    '--server-encoding=[CLI<->server encoding]:enc:(bser json)' \
    '(-f --foreground)'{-f,--foreground}'[run service in foreground]' \
    '(--pretty --no-pretty)--pretty[force pretty JSON]' \
    '(--pretty --no-pretty)--no-pretty[do not pretty-print JSON]' \
    '--no-spawn[do not start the service if not available]' \
    '--no-local[do not handle request in client mode if no service]' \
    '1:command:->verbs' \
    '*::args:_files' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
