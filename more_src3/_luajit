#compdef luajit
# Documentation: luajit -h
# Source: LuaJIT — Just-In-Time compiler for Lua 5.1.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    '*-e+[execute string chunk]:chunk:' \
    '*-l+[require library]:library:' \
    '*-b[save or list bytecode]' \
    '*-j+[LuaJIT control command]:cmd:(on off flush v=1 v=2 v=3 v=4 dump)' \
    '*-O+[control optimizations]:opt:(0 1 2 3 fold cse dce narrow loop fwd dse abc sink fuse)' \
    '-i[enter interactive mode after script]' \
    '-E[ignore environment variables]' \
    '*:script and args:_files -g "*.lua"' \
    && ret=0

return ret
