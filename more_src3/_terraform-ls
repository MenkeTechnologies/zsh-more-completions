#compdef terraform-ls
# Documentation: https://github.com/hashicorp/terraform-ls/blob/main/internal/cmd/serve_command.go
# Reference accessed: 2026-05-21
# Verified: upstream serve_command.go.
# Real serve flags: -port, -log-file, -cpuprofile, -memprofile,
# -req-concurrency. No -tcp flag (TCP mode enabled by non-zero -port).
# No -req-forwarding flag in upstream serve_command.go.
# Removed from prior file: -tcp, -req-forwarding (not in upstream source),
# -reqconcurrency (real flag is -req-concurrency with a dash).

_terraform-ls() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:command:_terraform-ls_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                serve)
                    _arguments \
                        '-port[port to listen on (enables TCP mode when non-zero)]:port:' \
                        '-log-file[log file path (supports template variables)]:file:_files' \
                        '-cpuprofile[CPU profile output path]:file:_files' \
                        '-memprofile[memory profile output path]:file:_files' \
                        '-req-concurrency[number of concurrent RPC requests]:number:'
                    ;;
                completion)
                    _arguments \
                        '1:shell:(bash zsh fish)'
                    ;;
                inspect-module)
                    _arguments \
                        '*:path:_directories'
                    ;;
            esac
            ;;
    esac
}

_terraform-ls_commands() {
    local -a commands
    commands=(
        'serve:start the language server'
        'completion:generate shell completion script'
        'inspect-module:list available information about a module'
        'version:show version information'
    )
    _describe -t commands 'terraform-ls command' commands
}

_terraform-ls "$@"
