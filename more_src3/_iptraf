#compdef iptraf
# _iptraf — Gerard Paul Java iptraf classic interactive ncurses IP network monitor CLI showing real-time TCP UDP ICMP NetBIOS ARP traffic statistics per-interface counts protocol breakdown LAN station monitor (riouxsi team, C); getopt
# upstream: http://iptraf.seul.org/

_iptraf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[interface]:str:' \
        '--iface=+[interface]:str:' \
        '-g[general interface statistics]' \
        '--general[general interface statistics]' \
        '-d+[interface]:str:' \
        '--detailed=+[interface]:str:' \
        '-s+[interface]:str:' \
        '--service=+[interface]:str:' \
        '-z+[interface]:str:' \
        '--packetsize=+[interface]:str:' \
        '-l+[interface]:str:' \
        '--lan=+[interface]:str:' \
        '-B[run in background]' \
        '--background[run in background]' \
        '-L+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-t+[timeout minutes]:n:' \
        '--timeout=+[timeout minutes]:n:' \
        '-f[no flush log]' \
        '--no-flush[no flush log]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-w[force enable promisc]' \
        '--promisc[force enable promisc]'
}

_iptraf "$@"
