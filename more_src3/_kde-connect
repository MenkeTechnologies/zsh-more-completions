#compdef kdeconnect-cli
# Documentation: https://github.com/KDE/kdeconnect-kde/blob/master/cli/kdeconnect-cli.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (QCommandLineParser defs).

# Zsh completion for kdeconnect-cli - KDE Connect CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --list-devices)'{-l,--list-devices}'[list all devices]' \
  '(-a --list-available)'{-a,--list-available}'[list available (paired and reachable) devices]' \
  '(-b --list-backends)'{-b,--list-backends}'[list all backends and status]' \
  '--enable-backend=[enable the specified backend]:backend:' \
  '--disable-backend=[disable the specified backend]:backend:' \
  '--id-only[print only the device id (eases scripting)]' \
  '--name-only[print only the device name (eases scripting)]' \
  '--id-name-only[print only the device id and name (eases scripting)]' \
  '--refresh[search the network and re-establish connections]' \
  '--pair[request pairing with device]' \
  '--ring[find device by ringing it]' \
  '--unpair[unpair from device]' \
  '--ping[send ping to device]' \
  '--ping-msg=[send ping with a custom message]:message:' \
  '--send-clipboard[send clipboard to device]' \
  '--share=[share file/URL to device]:path or URL:_files' \
  '--share-text=[share text to device]:text:' \
  '--list-notifications[display notifications on device]' \
  '--lock[lock the specified device]' \
  '--unlock[unlock the specified device]' \
  '--send-sms=[send an SMS (requires --destination)]:message:' \
  '--destination=[phone number to send the message]:phone number:' \
  '--attachment=[file path to attach to the SMS]:file:_files' \
  '(-d --device)'{-d,--device}'=[device ID]:device id:' \
  '(-n --name)'{-n,--name}'=[device name]:device name:' \
  '--encryption-info[get encryption info about device]' \
  '--list-commands[list remote commands and their ids]' \
  '--execute-command=[execute remote command by id]:command id:' \
  '(-k --send-keys)'{-k,--send-keys}'=[send keys to device]:keys:' \
  '--my-id[display this device'\''s id and exit]' \
  '--mount[mount filesystem of the said device]' \
  '--get-mount-point[print mount point for the filesystem of the said device]' \
  && ret=0

return ret
