#compdef shx
# Documentation: https://github.com/shelljs/shx
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Zsh completion for shx - portable Unix shell commands for Node.js
# Upstream notes shx wraps ShellJS; commands below are the documented
# subset (cd/pushd/popd/dirs/set/exit/exec are explicitly unsupported
# upstream — removed from prior file).

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '1:command:(cat chmod cp echo find grep head ln ls mkdir mv pwd rm sed sort tail tempdir test touch uniq which)' \
  '*:args:_files'
