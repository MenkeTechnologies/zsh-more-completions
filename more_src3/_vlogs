#compdef vlogs
# Documentation: https://docs.victoriametrics.com/victorialogs/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# vlogs: VictoriaLogs single-node binary
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-storageDataPath=[storage data path]:dir:_files -/' \
  '-retentionPeriod=[retention period]:duration:' \
  '-retention.maxDiskSpaceUsageBytes=[max disk space usage]:bytes:' \
  '-retention.maxDiskUsagePercent=[max disk usage percent]:pct:' \
  '-httpListenAddr=[HTTP listen addr]:addr:' \
  '-loggerLevel=[logger level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[logger format]:fmt:(default json)' \
  '-loggerOutput=[logger output]:out:(stderr stdout)' \
  '-pprofAuthKey=[pprof auth key]:key:' \
  '-metricsAuthKey=[metrics auth key]:key:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert file]:file:_files' \
  '-tlsKeyFile=[TLS key file]:file:_files' \
  '-tlsCipherSuites=[TLS cipher suites]:list:' \
  '-tlsMinVersion=[TLS min version]:ver:(TLS10 TLS11 TLS12 TLS13)' \
  '-insert.maxLineSizeBytes=[max single line size]:bytes:' \
  '-maxConcurrentInserts=[max concurrent inserts]:n:' \
  '-defaultParallelReaders=[parallel readers per query]:n:' \
  '-maxBackfillAge=[reject logs older than]:age:' \
  '-futureRetention=[accept logs up to this far in future]:age:' \
  '-httpAuth.username=[basic auth username]:user:' \
  '-httpAuth.password=[basic auth password]:pass:' \
  '-search.maxQueryDuration=[max query duration]:duration:' \
  '*::vlogs args:_files' && ret=0
return ret
