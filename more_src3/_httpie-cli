#compdef httpie-cli
# _httpie-cli — HTTPie CLI subcommand wrapper used by Homebrew's `httpie` command alias; thin shim with plugins/config/sessions subcommands
# upstream: https://github.com/httpie/cli

_httpie-cli() {
    local -a sub=(
        'plugins:manage installed plugins'
        'cli:invoke nested CLI utilities (sessions, config, completion)'
        'sessions:manage saved sessions'
        'config:edit config file'
        'completion:print shell completion script'
        'self-check:run httpie self-diagnostic'
    )
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'httpie-cli subcommand' sub ;;
        args)
            case $words[1] in
                plugins) _arguments \
                    '1:plugin action:(install upgrade uninstall list)' \
                    '*:plugin:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
                sessions) _arguments '1:session action:(list show edit delete export)' '*:session name:' ;;
            esac
            ;;
    esac
}

_httpie-cli "$@"
