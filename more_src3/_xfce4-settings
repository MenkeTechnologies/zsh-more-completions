#compdef xfce4-settings-manager
# Documentation: https://github.com/xfce-mirror/xfce4-settings/blob/master/xfce4-settings-manager/main.c
# Reference accessed: 2026-05-21
# Verified: xfce4-settings-manager/main.c GOptionEntry table (--version, --dialog)
# plus gtk_init_with_args. Note: `xfce4-settings` is not a binary name in upstream.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(- *)'{-V,--version}'[version information]' \
  '(-d --dialog)'{-d+,--dialog=}'[settings dialog to show]:dialog:(xfce4-accessibility-settings xfce4-appearance-settings xfce4-color-settings xfce4-display-settings xfce4-keyboard-settings xfce4-mime-settings xfce4-mouse-settings)' \
  '--display=[X display]:display:' && ret=0
return ret
