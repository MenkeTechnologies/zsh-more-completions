#compdef watchgnupg
# Documentation: watchgnupg --help on watchgnupg (GnuPG) 2.5.20
# Source: GnuPG watchgnupg — listen on socket / TCP port and display log messages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--tcp[listen on a TCP port (and optionally local socket)]' \
    '--force[delete already-existing socket file]' \
    '--verbose[extra informational output]' \
    '(--time-only --clock)--time-only[print only time (not full timestamp)]' \
    '(--time-only --clock)--clock[print only millisecond timestamp]' \
    '--homedir=[use DIR for gpgconfs --homedir option]:dir:_files -/' \
    '(- *)--version[print version and exit]' \
    '(- *)--help[display help and exit]' \
    '1:port or socketname:' \
    '2:socketname (only with --tcp PORT SOCKETNAME):_files' \
    && ret=0

return ret
