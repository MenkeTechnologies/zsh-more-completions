#compdef learn-ocaml learn-ocaml-client learn-ocaml-server
# Documentation: https://github.com/ocaml-sf/learn-ocaml/blob/master/src/main/learnocaml_main.ml
# Reference accessed: 2026-05-27
# Verified: upstream src/main/learnocaml_main.ml, learnocaml_client.ml, learnocaml_server_args.ml (ocaml-sf/learn-ocaml)

# Zsh completion for learn-ocaml (learn-ocaml exercise platform)

local curcontext="$curcontext" state line ret=1

case "$service" in
  learn-ocaml-client)
    local -a _loc_client_subs
    _loc_client_subs=(
      'init:initialize the configuration file'
      'grade:learn-ocaml grading client (default)'
      'print-token:print the configured user token'
      'print-server:print the configured server URL'
      'server-version:print the version of the server'
      'set-options:overwrite configuration file with command-line options'
      'fetch:fetch the user solutions on the server to the current directory'
      'template:get the template of a given exercise'
      'create-token:create a token on the server with a desired nickname'
      'exercise-list:get a structured JSON list of exercises on the server'
    )

    local -a _loc_client_global
    _loc_client_global=(
      '--server=[server URL]:url:'
      '--token=[user token]:token:'
      '--local[use a local config file]'
      '--config-file=[path to a config file]:file:_files'
      '--version[print version]'
      '--help[show help]'
      '--help=[show help in format]:fmt:(auto pager groff plain)'
    )

    _arguments -C \
      $_loc_client_global \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd)
        _describe -t commands 'learn-ocaml-client subcommand' _loc_client_subs && ret=0
        ;;
      args)
        case $line[1] in
          init)
            _arguments \
              $_loc_client_global \
              '--nickname=[nickname when creating a new token]:name:' \
              '--secret=[server secret]:secret:' && ret=0
            ;;
          grade|'')
            _arguments \
              $_loc_client_global \
              '--id=[exercise identifier]:id:' \
              '--dont-submit[do not submit solution to the server]' \
              '--output-format=[result output format]:fmt:(console json html raw)' \
              '(--color)--color=[colorize the output]:when:(auto always never)' \
              '*-v[increase verbosity]' \
              '--verbose[increase verbosity]' \
              '1:solution-file:_files -g "*.ml"' && ret=0
            ;;
          create-token)
            _arguments \
              $_loc_client_global \
              '--nickname=[nickname for the new token]:name:' \
              '--secret=[server secret]:secret:' && ret=0
            ;;
          template)
            _arguments \
              $_loc_client_global \
              '--id=[exercise identifier]:id:' && ret=0
            ;;
          fetch)
            _arguments \
              $_loc_client_global \
              '*:exercise-id:' && ret=0
            ;;
          server-version)
            _arguments \
              $_loc_client_global \
              '--min[return min of server and client versions]' && ret=0
            ;;
          *)
            _arguments $_loc_client_global && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  *)
    # learn-ocaml binary: positional COMMAND can be one or more of build, serve, grade
    local -a _loc_commands
    _loc_commands=(
      'build:generate the application from a repository'
      'serve:run a web-server providing access to the learn-ocaml app'
      'grade:run the automatic grader on exercise solutions'
    )

    _arguments -C \
      '--repo=[path to the repository with exercises/lessons/tutorials]:dir:_files -/' \
      '--build-dir=[directory where exercises are copied and precompiled]:dir:_files -/' \
      '(--app-dir -o)'{--app-dir=,-o+}'[directory where the app is generated]:dir:_files -/' \
      '--base-url=[base URL of the website]:url:' \
      '--serve-during-build[serve old build during a new build]' \
      '*--exercises=[comma-separated directories of exercises to grade]:dirs:' \
      '*-e+[comma-separated directories of exercises to grade]:dirs:' \
      '--output-json=[save processed exercises as JSON in directory]:dir:_files -/' \
      '(--grade-student -s)'{--grade-student=,-s+}'[grade given student file instead of solution.ml]:file:_files -g "*.ml"' \
      '--display-outcomes[display the toplevel outcomes]' \
      '(--quiet -q)'{--quiet,-q}'[do not display grading progression messages]' \
      '--display-stdouts[display the toplevel standard outputs]' \
      '--dump-outputs=[save outputs in files with given prefix]:prefix:' \
      '--dump-reports=[save reports in files with given prefix]:prefix:' \
      '--timeout=[limit every test to the given timeout (seconds)]:seconds:' \
      '(--verbose -v)'{--verbose,-v}'[display detailed grading reports to stdout]' \
      '--dump-dot=[dump dependency graph of the repository]:file:_files' \
      '--contents-dir=[directory containing the base learn-ocaml app contents]:dir:_files -/' \
      '--enable-tutorials[enable the Tutorials tab]' \
      '--disable-tutorials[disable the Tutorials tab]' \
      '--enable-tryocaml[enable the Tutorials tab (legacy name)]' \
      '--disable-tryocaml[disable the Tutorials tab (legacy name)]' \
      '--enable-playground[enable the Playground tab]' \
      '--disable-playground[disable the Playground tab]' \
      '--enable-lessons[enable the Lessons tab]' \
      '--disable-lessons[disable the Lessons tab]' \
      '--enable-exercises[enable the Exercises tab]' \
      '--disable-exercises[disable the Exercises tab]' \
      '--enable-toplevel[enable the Toplevel tab]' \
      '--disable-toplevel[disable the Toplevel tab]' \
      '*--exercises-filtered=[comma-separated exercises to build]:dirs:' \
      '*-f+[comma-separated exercises to build]:dirs:' \
      '(-j --jobs)'{-j+,--jobs=}'[number of parallel building jobs]:n:' \
      '--sync-dir=[directory where to store user sync tokens]:dir:_files -/' \
      '--cert=[HTTPS certificate basename]:basename:_files' \
      '(-p --port)'{-p+,--port=}'[TCP port for the server]:port:' \
      '--replace[replace a previously running instance on the same port]' \
      '--version[print version]' \
      '--help[show help]' \
      '--help=[show help in format]:fmt:(auto pager groff plain)' \
      '*: :->cmds' && ret=0

    case $state in
      cmds)
        _describe -t commands 'learn-ocaml command' _loc_commands && ret=0
        ;;
    esac
    ;;
esac

return ret
