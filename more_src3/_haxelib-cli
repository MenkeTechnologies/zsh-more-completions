#compdef haxelib-cli
# _haxelib-cli — Haxe haxelib package manager CLI alias (Haxe Foundation, Haxe); custom argparse
# upstream: https://github.com/HaxeFoundation/haxelib

_haxelib-cli() {
    local -a sub=(
        'install:install a library'
        'update:update libraries'
        'remove:remove library'
        'list:list installed libraries'
        'set:set current library version'
        'search:search haxelib'
        'info:show package info'
        'user:show user info'
        'config:show config dir'
        'path:show classpath info'
        'libpath:show library path'
        'version:show version'
        'help:show help'
        'submit:submit package'
        'register:register user'
        'dev:install development library'
        'git:install git library'
        'hg:install mercurial library'
        'setup:setup haxelib'
        'fixrepo:fix repo path'
        'selfupdate:update haxelib'
        'newrepo:create local repo'
        'deleterepo:delete local repo'
        'convertxml:convert haxelib.xml to haxelib.json'
        'run:run library script'
        'proxy:configure proxy'
        'state:show state'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--global[global lib]' \
        '-G[global lib]' \
        '--always[always answer yes]' \
        '-A[always answer yes]' \
        '--debug[debug]' \
        '-D[debug]' \
        '--quiet[quiet]' \
        '-Q[quiet]' \
        '--never[never answer yes]' \
        '-N[never answer yes]' \
        '--system[system]' \
        '-S[system]' \
        '--remote=+[remote URL]:url:_urls' \
        '-R+[remote URL]:url:_urls' \
        '--no-timeout[no timeout]' \
        '--cwd=+[cwd]:dir:_files -/' \
        '-C+[cwd]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'haxelib subcommand' sub ;;
        args)
            case $words[1] in
                install|update|remove|info|set|list) _arguments '*:library:' ;;
                dev) _arguments \
                    '1:library:' \
                    '2:path:_files -/' ;;
                git|hg) _arguments \
                    '1:library:' \
                    '2:url:_urls' \
                    '*:ref:' ;;
                run) _arguments \
                    '1:library:' \
                    '*:arg:' ;;
                search) _arguments '*:keyword:' ;;
                user) _arguments '*:user:_users' ;;
                submit) _arguments '*:zip-file:_files -g "*.zip"' ;;
                proxy) _arguments \
                    '1:host:_hosts' \
                    '2:port:' ;;
            esac
            ;;
    esac
}

_haxelib-cli "$@"
