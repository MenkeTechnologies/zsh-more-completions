#compdef scons
# _scons-bin — SCons Software Construction Tool (SCons Foundation, Python); Python-based build system
# upstream: https://github.com/SCons/scons

_scons-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-H --help-options)'{-H,--help-options}'[show all options]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-Q --quiet)'{-Q,--quiet}'[quiet]' \
        '(-q --question)'{-q,--question}'[do not run, check if up to date]' \
        '-c[clean]' \
        '--clean[clean]' \
        '-D[depends on cwd]' \
        '-n[no exec]' \
        '--no-exec[no exec]' \
        '--dry-run[dry run]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-j+[jobs]:n:' \
        '--jobs+[jobs]:n:' \
        '-C+[change to dir]:dir:_files -/' \
        '--directory+[change to dir]:dir:_files -/' \
        '-f+[SConstruct file]:file:_files' \
        '--file+[SConstruct file]:file:_files' \
        '--sconstruct+[SConstruct file]:file:_files' \
        '--debug+[debug type]:type:(action-timestamps count duplicate dtree explain findlibs includes memoizer memory nomemoizer objects pdb prepare presub stacktrace stree time tree)' \
        '--cache-debug+[cache debug]:file:_files' \
        '--cache-disable[disable cache]' \
        '--cache-force[cache force]' \
        '--cache-readonly[cache readonly]' \
        '--cache-show[cache show]' \
        '--config+[config]:type:(auto cache force)' \
        '--diskcheck+[disk check]:type:(none match rcs sccs)' \
        '--duplicate+[duplicate]:type:(hard hard-soft-copy hard-copy soft soft-copy)' \
        '--implicit-cache[implicit cache]' \
        '--implicit-deps-changed[implicit deps changed]' \
        '--implicit-deps-unchanged[implicit deps unchanged]' \
        '--interactive[interactive mode]' \
        '--max-drift+[max drift]:n:' \
        '--md5-chunksize+[md5 chunk size]:n:' \
        '--no-cache[no cache]' \
        '--no-site-dir[no site dir]' \
        '--profile+[profile output]:file:_files' \
        '--random[random build order]' \
        '--site-dir+[site dir]:dir:_files -/' \
        '--stack-size+[stack size kb]:n:' \
        '--taskmastertrace+[taskmaster trace]:file:_files' \
        '--tree+[print tree]:options:' \
        '--warn+[warning]:warning:' \
        '*:target:'
}

_scons-bin "$@"
