#compdef tl toolong
# Documentation: https://github.com/Textualize/toolong/blob/main/src/toolong/cli.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-m --merge)'{-m,--merge}'[merge files]' \
  '(-o --output-merge)'{-o,--output-merge}'[path to save merged file (requires -m)]:path:_files' \
  '*:log file:_files' && ret=0

return ret
