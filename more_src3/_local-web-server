#compdef local-web-server ws
# Documentation: https://github.com/lwsjs/local-web-server/wiki/CLI-usage
# Reference accessed: 2026-05-19
# Verified: upstream wiki at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage instructions]' \
  '--version[print the version number]' \
  '(-p --port)'{-p,--port}'=[port number to listen on]:port:' \
  '--hostname=[hostname or IP address to bind to]:host:_hosts' \
  '--max-connections=[maximum concurrent connections]:n:' \
  '--keep-alive-timeout=[inactive connection timeout (ms)]:ms:' \
  '--https[enable HTTPS using built-in TLS cert]' \
  '--http2[enable HTTP/2 using built-in TLS cert]' \
  '--key=[TLS private key path]:file:_files' \
  '--cert=[TLS certificate chain path]:file:_files' \
  '--pfx=[PFX/PKCS12 encoded key and cert chain]:file:_files' \
  '--ciphers=[cipher suite specification]:ciphers:' \
  '--secure-protocol=[SSL method]:method:' \
  '--stack=[middleware stack modules]:modules:' \
  '--view=[path to custom view module]:file:_files' \
  '--auth.user=[basic auth username]:user:' \
  '--auth.pass=[basic auth password]:password:' \
  '(-f --log.format)'{-f,--log.format}'=[log format]:format:(stats logstalgia common combined dev short tiny)' \
  '--cors.origin=[Access-Control-Allow-Origin value]:origin:' \
  '--cors.allow-methods=[Access-Control-Allow-Methods value]:methods:' \
  '--cors.credentials[add Access-Control-Allow-Credentials header]' \
  '--cors.opener-policy=[Cross-Origin-Opener-Policy value]:policy:' \
  '--cors.embedder-policy=[Cross-Origin-Embedder-Policy value]:policy:' \
  '(-z --compress)'{-z,--compress}'[serve gzip-compressed resources]' \
  '--compress.threshold=[minimum size in bytes to compress]:bytes:' \
  '(-r --rewrite)'{-r,--rewrite}'=[URL rewrite rules (from->to)]:rule:' \
  '--rewrite.keep-secure-attr[keep secure attribute on rewritten cookies]' \
  '--blacklist=[routes to forbid]:routes:' \
  '(-n --no-conditional-get)'{-n,--no-conditional-get}'[disable Conditional-GET caching]' \
  '(-s --spa)'{-s,--spa}'=[path to SPA file]:file:_files' \
  '--spa.asset-test=[regex to identify asset files]:regex:' \
  '--spa.asset-test-fs[use filesystem to identify asset files]' \
  '(-d --directory)'{-d,--directory}'=[root directory]:dir:_directories' \
  '--static.maxage=[cache max-age in seconds]:seconds:' \
  '--static.defer[serve after downstream middleware]' \
  '--static.index=[default index filename]:file:' \
  '--static.extensions=[default filename extensions]:ext:' \
  '--index.root=[index root directory]:dir:_directories' \
  '--index.hidden[show hidden files in directory listings]' \
  '--index.view=[display mode]:mode:(tiles details)' \
  '--qr[show QR code for mobile browser]' \
  '(-v --verbose)'{-v,--verbose}'[output verbose JSON debug stream]' \
  '--verbose.include=[regex of event keys to include]:regex:' \
  '--verbose.exclude=[regex of event keys to exclude]:regex:' \
  '(-c --config-file)'{-c,--config-file}'=[config file name]:file:_files' \
  '--config[print the active configuration]' \
  '(-o --open)'{-o,--open}'[open default system browser]' \
  '--list-network-interfaces[print available network interfaces]' \
  '--default-stack[print the default middleware stack]' \
  '*::args: _default' && ret=0

return ret
