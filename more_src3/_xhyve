#compdef xhyve
# _xhyve — xhyve (Hypervisor.framework-backed FreeBSD bhyve port for macOS; runs a VM directly with -m memory, -c vcpus, -A ACPI tables, -H halts on shutdown, -P pause on debug, -s slot:dev[,opts] PCI device chain, -l com[12]:stdio LPC chardev, -f firmware:kernel,initrd,cmdline)
# upstream: https://github.com/machyve/xhyve
# Flags from xhyve src/xhyve.c on tip.

_xhyve() {
    _arguments \
        '-h[show help]' \
        '-A[ACPI tables]' \
        '-c+[vcpus]:n:' \
        '-m+[memory size]:size:' \
        '-H[halt on shutdown]' \
        '-P[pause on debug]' \
        '-w[ignore unimplemented MSR access]' \
        '-W[force virtio-MMIO]' \
        '-u[utc rtc]' \
        '-U+[uuid]:uuid:' \
        '*-s+[PCI slot device]:slot:dev[,opts]:' \
        '*-l+[LPC dev e.g. com1,stdio]:dev:' \
        '-f+[firmware spec kexec/multiboot/fbsd]:spec:' \
        '-Y[disable MPTable]' \
        '-x[x2APIC enabled]' \
        '-X[x2APIC disabled]'
}

_xhyve "$@"
