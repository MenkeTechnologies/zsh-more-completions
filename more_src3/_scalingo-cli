#compdef scalingo-cli
# _scalingo-cli — Scalingo European PaaS CLI alias (Scalingo team, Go); custom argparse
# upstream: https://github.com/Scalingo/cli

_scalingo-cli() {
    local -a sub=(
        'addons:list addons'
        'addons-add:add addon'
        'addons-remove:remove addon'
        'addons-upgrade:upgrade addon'
        'addons-info:addon info'
        'addons-logs:addon logs'
        'addons-plans:list plans'
        'apps:list apps'
        'create:create app'
        'destroy:destroy app'
        'rename:rename app'
        'transfer:transfer app'
        'autoscalers:list autoscalers'
        'autoscalers-add:add autoscaler'
        'autoscalers-remove:remove autoscaler'
        'autoscalers-update:update autoscaler'
        'autoscalers-disable:disable'
        'autoscalers-enable:enable'
        'cgroups:show cgroups'
        'collaborators:list collaborators'
        'collaborators-add:add collaborator'
        'collaborators-remove:remove collaborator'
        'config:show config'
        'console:open console'
        'container-types:list container types'
        'container-sizes:list container sizes'
        'cron-tasks:list cron tasks'
        'db:postgres:start:start postgres tunnel'
        'db:postgres:stop:stop postgres tunnel'
        'db:upgrade:upgrade db'
        'db:console:open db console'
        'db:tunnel:open db tunnel'
        'db:backups:list:list backups'
        'db:backups:download:download backup'
        'db:backups:create:create backup'
        'deploy:deploy from archive'
        'deploy-cache:reset:reset deploy cache'
        'deployments:list deployments'
        'deployments-follow:follow deployment'
        'deployments-info:deployment info'
        'deployments-output:deployment output'
        'domains:list domains'
        'domains-add:add domain'
        'domains-remove:remove domain'
        'domains-ssl:show SSL'
        'env:show env'
        'env-set:set env vars'
        'env-unset:unset env vars'
        'event-types:list event types'
        'events:list events'
        'github:link:link to github'
        'github:unlink:unlink github'
        'help:show help'
        'integrations:list integrations'
        'integrations-add:add integration'
        'integrations-remove:remove integration'
        'invitations:list invitations'
        'keys:list keys'
        'keys-add:add key'
        'keys-remove:remove key'
        'login:login'
        'logout:logout'
        'logs:show logs'
        'logs-archives:show log archives'
        'maintenance:on/off:maintenance mode'
        'notifiers:list notifiers'
        'notifiers-add:add notifier'
        'notifiers-remove:remove notifier'
        'one-off:run one-off'
        'permissions:list permissions'
        'pgsql-tunnel:open postgres tunnel'
        'ps:show running processes'
        'ps-info:process info'
        'process-stats:show process stats'
        'ps-stop:stop process'
        'redirections:list redirections'
        'redirections-add:add redirection'
        'redirections-remove:remove redirection'
        'regions:list regions'
        'review-apps:list:list review apps'
        'rolling-restart:rolling restart'
        'router-logs:show router logs'
        'run:run command'
        'scale:scale app'
        'sni:add:add SNI cert'
        'sni:remove:remove SNI cert'
        'sni:show:show SNI cert'
        'stacks:list stacks'
        'stacks-set:set stack'
        'tokens:list tokens'
        'tokens-create:create token'
        'tokens-delete:delete token'
        'two-factor-auth:enable:enable 2fa'
        'two-factor-auth:disable:disable 2fa'
        'update:update CLI'
        'user:current:show current user'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--app=+[app]:str:' \
        '-a+[app]:str:' \
        '--region=+[region]:str:' \
        '--remote=+[git remote]:str:' \
        '-r+[git remote]:str:' \
        '--api-url=+[api url]:url:_urls' \
        '--auth-url=+[auth url]:url:_urls' \
        '--db-url=+[db url]:url:_urls' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scalingo subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:name:' \
                    '--region=+[region]:str:' \
                    '--remote=+[git remote]:str:' \
                    '--no-remote[no remote]' \
                    '--buildpack=+[url]:url:_urls' \
                    '--stack=+[stack]:str:' \
                    '--parent-app=+[parent app]:str:' \
                    '--force-2fa[force 2fa]' \
                    '--auto-scale[auto scale]' ;;
                deploy) _arguments \
                    '1:archive:_files -g "*.{tar.gz,tgz}"' \
                    '2:git-ref:' \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--source-url=+[url]:url:_urls' ;;
                run) _arguments \
                    '--app=+[app]:str:' \
                    '-a+[app]:str:' \
                    '--detached[detached]' \
                    '-d[detached]' \
                    '--size=+[size]:str:' \
                    '--type=+[type]:str:' \
                    '--file=+[file]:file:_files' \
                    '-f+[file]:file:_files' \
                    '*:command:' ;;
            esac
            ;;
    esac
}

_scalingo-cli "$@"
