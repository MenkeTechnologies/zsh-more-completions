#compdef terminix tilix
# Documentation: https://manpages.debian.org/bookworm/tilix/tilix.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm tilix(1) manpage. NOTE: terminix was
# renamed to tilix in 2017 - same binary, both names accepted via
# #compdef alias.
# Removed from prior file: bogus man.archlinux.org search URL.

# terminix/tilix: GTK tiling terminal emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --working-directory)'{-w+,--working-directory=}'[working directory]:dir:_files -/' \
  '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' \
  '(-t --title)'{-t+,--title=}'[window title]:title:' \
  '(-s --session)'{-s+,--session=}'[session name]:session:' \
  '(-a --action)'{-a+,--action=}'[action to perform]:action:' \
  '(-e --command)'{-e+,--command=}'[command to execute]:cmd:_command_names' \
  '--maximize[maximize window]' \
  '--minimize[minimize window]' \
  '--full-screen[fullscreen window]' \
  '--focus-window[focus existing window]' \
  '--window-style=[window style]:style:(normal disable-csd disable-csd-hide-toolbar borderless)' \
  '--new-process[start in new process]' \
  '--geometry=[window geometry]:geom:' \
  '(-q --quake)'{-q,--quake}'[quake mode (drop-down)]' \
  '--preferences[open preferences]' \
  '--display=[X display]:display:' && ret=0
return ret
