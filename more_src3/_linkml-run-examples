#compdef linkml-run-examples
# _linkml-run-examples — run positive / counter examples through a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from src/linkml/workspaces/example_runner.py (click).

_linkml-run-examples() {
    local -a args
    args=(
        '(-s --schema)'{-s+,--schema=}'[LinkML schema YAML]:file:_files -g "*.(yaml|yml)"'
        '(-P --prefixes)'{-P+,--prefixes=}'[YAML file of prefix base=URI pairs]:file:_files -g "*.(yaml|yml)"'
        '(-e --input-directory)'{-e+,--input-directory=}'[directory of positive examples that MUST validate]:dir:_files -/'
        '--counter-example-input-directory=[directory of counter-examples that MUST fail validation]:dir:_files -/'
        '--output-directory=[output directory for converted example artifacts]:dir:_files -/'
        '*--input-formats=[accepted input formats]:format:(yaml json csv tsv rdf ttl jsonld)'
        '*--output-formats=[emit examples in these formats]:format:(yaml json csv tsv rdf ttl jsonld)'
        '(-o --output)'{-o+,--output=}'[summary report output file]:file:_files'
        '--use-type-designators[honor schema-level type designators when loading]'
        '--no-use-type-designators[ignore type designators]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
    )
    _arguments -s -S $args
}

_linkml-run-examples "$@"
