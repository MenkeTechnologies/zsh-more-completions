#compdef halmos
# Documentation: https://github.com/a16z/halmos
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_halmos() {
    _arguments -S \
        '(- *)'{-h,--help}'[display help for command]' \
        '--version[show currently installed version]' \
        '--root=[project root directory]:dir:_files -/' \
        '--config=[path to config file]:file:_files' \
        '--contract=[run tests in a specific contract]:contract:' \
        '(-mc --match-contract)'{-mc+,--match-contract=}'[only run tests in contracts matching regex]:regex:' \
        '--function=[run tests matching a function prefix]:prefix:' \
        '(-mt --match-test)'{-mt+,--match-test=}'[only run tests matching regex]:regex:' \
        '*--panic-error-codes=[panic error codes treated as failures]:codes:' \
        '--invariant-depth=[depth for invariant testing]:depth:' \
        '--loop=[set loop unrolling bound]:number:' \
        '--width=[max number of execution paths]:n:' \
        '--depth=[maximum path length in steps]:n:' \
        '*--array-lengths=[lengths for dynamic-sized arrays]:spec:' \
        '*--default-array-lengths=[default lengths for dynamic arrays]:spec:' \
        '*--default-bytes-lengths=[default lengths for bytes and strings]:spec:' \
        '--storage-layout=[storage layout model]:layout:(solidity generic)' \
        '--ffi[allow FFI for external function calls]' \
        '--coverage-output=[generate coverage report]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
        '(-st --statistics)'{-st,--statistics}'[print statistics]' \
        '--no-status[disable progress display]' \
        '--debug[run in debug mode]' \
        '--debug-config[debug config parsing]' \
        '--profile-instructions[profile instruction frequencies]' \
        '--json-output=[output results as JSON]:file:_files' \
        '--print-steps[print every execution step]' \
        '--print-states[print all final execution states]' \
        '--early-exit[stop after first counterexample]' \
        '--dump-smt-queries[dump SMT queries for violations]' \
        '*--trace-events=[include specific events in traces]:events:' \
        '--solver=[SMT solver]:solver:(yices z3 bitwuzla cvc5)' \
        '--solver-command=[custom solver invocation]:cmd:' \
        '--solver-timeout-branching=[timeout for branch conditions]:ms:' \
        '--solver-timeout-assertion=[timeout for assertion violations]:ms:' \
        '--solver-max-memory=[memory limit for solver]:mb:' \
        '--solver-threads=[parallel solver threads]:n:' \
        '--cache-solver[cache unsat queries]' \
        '--forge-build-out=[forge build artifacts directory]:dir:_files -/' \
        '--symbolic-jump[support symbolic jump destinations]' \
        '--flamegraph[generate execution flamegraph]' \
        '--revert-as-failure[treat any EVM revert as a test failure]'
}

_halmos "$@"
