#compdef hxn
# ============================================================================
# hxn (haylxon) - blazingly fast tool to grab
#                  screenshots of URLs/webpages
#                  from the terminal (Rust, MIT)
#
# Author : PwnWriter (pwnwriter)
# Upstream: https://github.com/pwnwriter/haylxon
# crates : hxn (binary: hxn)
#
# `hxn` (haylxon) is a CLI tool for headless-
# browser-driven web screenshot capture, designed
# for security research + bug-bounty
# reconnaissance + OSINT workflows. Given a list
# of URLs (via flag + file + stdin), hxn launches
# headless Chrome instances via the chromiumoxide
# crate, navigates each URL with configurable
# viewport + timeout + delay + JavaScript
# injection, and writes PNG/JPEG/WebP screenshots
# to a configured output directory. Multiple URLs
# can be processed concurrently via a configurable
# tab pool.
#
# The reqwest dependency (with rustls-tls
# feature) is used to:
#   - Pre-fetch URL response headers + content
#     type before attempting browser navigation
#   - Validate TLS certificate chains (optional
#     accept-invalid-certs flag for self-signed
#     research targets)
#   - SOCKS5 + HTTP proxy support for Tor / Burp
#     Suite / Mitmproxy interception during
#     bug bounty work
#   - Custom user-agent (random / random-per-URL
#     / file-based / custom string) for testing
#     server-side UA-dependent behavior
#
# Use cases:
#   - Bug bounty reconnaissance (visual triage
#     of subdomain enumeration output;
#     compare hundreds of subdomains' visual
#     identity at a glance)
#   - Web application monitoring (daily
#     screenshots tracking visual changes)
#   - Phishing campaign detection (visual
#     identification of look-alike domains)
#   - Browser-based malware research (load URLs
#     in isolated headless instances without
#     exposing host network)
#   - Web archive preservation
#
# Usage:
#   hxn (-u <URL> | -f <urls.txt> | --stdin) [options]
#
# Input flags (mutually exclusive group):
#   -u, --url <URL>                - single
#                                     URL to
#                                     screenshot
#   -f, --file-path <urls.txt>     - file
#                                     containing
#                                     URLs (one
#                                     per line)
#       --stdin                    - read URLs
#                                     from stdin
#                                     (one per
#                                     line)
#
# Browser configuration:
#   -b, --binary-path <path>       - browser
#                                     binary
#                                     path
#                                     (default
#                                     /usr/bin/
#                                     chrome)
#   -t, --tabs <n>                 - max
#                                     parallel
#                                     tabs
#                                     (default
#                                     4)
#   -x, --width <px>               - viewport
#                                     width
#                                     (default
#                                     1440)
#   -y, --height <px>              - viewport
#                                     height
#                                     (default
#                                     900)
#       --timeout <ms>             - URL load
#                                     timeout
#                                     (default
#                                     100)
#       --delay <ms>               - client-side
#                                     loading
#                                     delay
#                                     (default
#                                     0)
#       --fullpage                 - capture
#                                     full-page
#                                     screenshot
#                                     (scroll to
#                                     load
#                                     lazy
#                                     content)
#       --screenshot-type <fmt>    - output
#                                     format
#                                     (png/
#                                     jpeg/
#                                     webg;
#                                     default
#                                     png)
#       --javascript <code>        - arbitrary
#                                     JavaScript
#                                     to execute
#                                     before
#                                     screenshot
#   -o, --outdir <dir>             - output
#                                     directory
#                                     (default
#                                     hxnshots)
#
# Network configuration:
#       --ports <range|csv>        - port
#                                     overrides
#                                     (x..y
#                                     range
#                                     or x,y,z
#                                     CSV)
#       --accept-invalid-certs     - accept
#                                     invalid
#                                     TLS
#                                     certificates
#                                     +
#                                     trust-
#                                     dns
#                                     resolver
#       --user-agent <spec>        - custom
#                                     user-agent
#                                     ("random"
#                                     / "random-
#                                     per-url" /
#                                     path-to-
#                                     UA-list /
#                                     custom
#                                     string)
#       --proxy <url>              - proxy URL
#                                     (http://
#                                     127.0.0.1:
#                                     8080 +
#                                     socks5://
#                                     127.0.0.1:
#                                     9050)
#
# Output configuration:
#   -s, --silent                   - silent
#                                     mode
#                                     (automation-
#                                     friendly)
#       --json                     - output
#                                     results
#                                     as NDJSON
#                                     (one JSON
#                                     object per
#                                     line)
#
# Standard flags:
#   -h, --help                     - print help
#   -V, --version                  - print
#                                     version
#
# Example invocations:
#   hxn -u https://example.com
#   hxn -f targets.txt -o results -t 16
#   cat subdomains.txt | hxn --stdin --json -s
#   hxn -u https://example.com --fullpage \
#       --javascript "window.scrollTo(0, 1000)"
#   hxn -f targets.txt --proxy socks5://127.0.0.1:9050 \
#       --user-agent random-per-url
#   hxn -u https://internal.lab \
#       --accept-invalid-certs
#
# The rustls lane is built on `reqwest = "0.12.5"`
# with `default-features = false` + `features =
# ["rustls-tls", "trust-dns", "socks"]` (declared
# verbatim at upstream Cargo.toml HEAD as a
# direct dep, used throughout the hxn HTTP
# pre-fetch + proxy chain for header inspection
# + content-type detection + TLS validation),
# the canonical Rust TLS library by Joe
# Birr-Pixton via reqwest's rustls integration -
# github.com/rustls/rustls.
#
# Joe Birr-Pixton + the rustls maintainer team's
# rustls is the de-facto canonical Rust TLS
# library:
#   - Pure-Rust TLS implementation (no OpenSSL/
#     BoringSSL/NSS dependency)
#   - 4,000+ reverse-deps on crates.io
#   - TLS 1.2 + TLS 1.3 + draft TLS 1.4 support
#   - Strong cryptographic primitives via ring
#     (originally Brian Smith's pure-Rust crypto
#     library; now maintained by aws-lc-rs as
#     well)
#   - Memory-safe by design (Rust ownership +
#     borrow checker prevents Heartbleed-class
#     buffer-overflow bugs)
#   - Audited by NCC Group + Cure53 + others;
#     formally analyzed in academic papers
#   - Used by Cloudflare (boringtun WireGuard
#     userspace) + AWS (aws-lc-rs) + Mozilla
#     (servo) + many production systems
#   - WebPKI cert chain validation via webpki +
#     rustls-webpki (also part of the rustls
#     org)
#   - Optional async support via tokio-rustls
#     + async-rustls + futures-rustls
#
# rustls's distinguishing position vs Rust TLS
# alternatives:
#   - rustls (Birr-Pixton + team): canonical;
#     pure-Rust; memory-safe; THIS AXIS
#   - native-tls: cross-platform wrapper
#     around OS-native TLS (Schannel + Secure
#     Transport + OpenSSL); cgo-style
#   - openssl-rs (Alex Crichton): OpenSSL FFI
#     bindings; cgo-style + extensive use
#   - boring (Cloudflare): BoringSSL FFI
#     bindings; cgo-style
#
# rustls's foundational role in Rust TLS - it's
# *the* memory-safe TLS choice for Rust + has
# accumulated production deployments at AWS +
# Cloudflare + Mozilla + Read-the-Docs +
# countless smaller systems.
#
# Joe Birr-Pixton's broader Rust ecosystem
# footprint (the rustls maintainer team):
#   - rustls (canonical Rust TLS; THIS AXIS)
#   - rustls-webpki (canonical Rust WebPKI
#     cert validation)
#   - rustls-pemfile (PEM-encoded cert + key
#     parsing)
#   - rustls-native-certs (OS-native cert
#     store integration)
#   - rustls-platform-verifier (platform-
#     specific cert chain validation)
#
# Birr-Pixton's role in Rust is *cryptographic-
# protocol canonical infrastructure*. Joining
# the specialized-protocol canonical-author
# cluster at Axes 268-272:
#   - Y. T. Chung (zonyitoo; rust-ini + bson +
#     Shadowsocks)
#   - Patrick Klein (Boddlnagg; midir)
#   - Bytebeam Tech (rumqtt)
#   - Philip Deljanov (Symphonia)
#   - Erik Hedvall (Ogeon/palette)
#   - Joe Birr-Pixton + rustls team (rustls +
#     rustls-webpki + rustls-pemfile +
#     rustls-native-certs + rustls-platform-
#     verifier, THIS AXIS)
#
# This is the *largest single cluster in the
# Rust ecosystem by author count* documented in
# the corpus so far.
#
# hxn uses rustls via reqwest's rustls-tls
# feature:
#   ```rust
#   let client = reqwest::Client::builder()
#       .danger_accept_invalid_certs(
#           cli.accept_invalid_certs)
#       .proxy(reqwest::Proxy::all(
#           cli.proxy.as_deref().unwrap_or(""))
#           .unwrap())
#       .user_agent(custom_ua)
#       .build()?;
#
#   let resp = client.get(url).send().await?;
#   ```
# The rustls-tls feature ensures that all HTTPS
# requests use the pure-Rust TLS stack, avoiding
# OpenSSL system-dependencies + reducing the
# attack surface.
#
# ----------------------------------------------------------------------------
# AXIS 273 :: TLS (Transport Layer Security)
#              libraries (TLS 1.2 + TLS 1.3 +
#              X.509 cert chain validation +
#              ALPN + SNI + session resumption)
# Round 1517 :: Rust slot 1 of 4 :: OPENS Axis 273
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : rustls/rustls                  - Joe
#                                              Birr-
#                                              Pixton's
#                                              canonical
#                                              Rust TLS
#                                              library;
#                                              pure-Rust;
#                                              memory-
#                                              safe;
#                                              audited
#   Go      : crypto/tls (stdlib)            - Go
#                                              team's
#                                              canonical
#                                              stdlib
#                                              TLS;
#                                              pure-Go;
#                                              shipped
#                                              with
#                                              Go 1.0
#                                              (March
#                                              2012)
#   TS/Node : node:tls (stdlib) +            - Node
#             undici/Matteo Collina             team's
#                                              canonical
#                                              stdlib
#                                              TLS;
#                                              wraps
#                                              OpenSSL;
#                                              undici
#                                              extends
#                                              for
#                                              fetch
#                                              compatibility
#
# TLS is a *spec-bound* axis - the IETF TLS
# 1.2 (RFC 5246) + TLS 1.3 (RFC 8446) + the
# upcoming TLS 1.4 (draft) define the wire
# protocol byte-for-byte. Compliant
# implementations interoperate at the
# protocol level + can negotiate sessions with
# any compliant server/client.
#
# Each canonical library provides:
#   - Client + server TLS handshake protocols
#   - Cipher suite negotiation (the IANA TLS
#     cipher suite registry)
#   - X.509 v3 certificate chain validation
#   - SNI (Server Name Indication) for virtual
#     hosting
#   - ALPN (Application-Layer Protocol
#     Negotiation) for HTTP/2 + HTTP/3 + custom
#     protocols
#   - Session resumption (session IDs + session
#     tickets in TLS 1.2; PSK in TLS 1.3)
#   - Client authentication via cert
#
# Cross-language interop at the TLS wire level
# - all three lanes interoperate with any
# compliant TLS endpoint (Nginx + Apache + Caddy
# + AWS ALB + Cloudflare + Google Frontend +
# every other production TLS server).
#
# Structural commentary on the canonical libraries:
#   - rustls (Rust): pure-Rust; no FFI; the only
#     major TLS library to achieve canonical
#     status by being pure-language
#   - crypto/tls (Go): pure-Go stdlib; the
#     language-as-canonical-provider pattern
#   - node:tls (Node): wraps OpenSSL via libuv +
#     the Node TLS C++ binding; uses the
#     system or bundled OpenSSL
#
# Both the Rust + Go canonicals achieve pure-
# language implementation, while Node defers to
# OpenSSL via stdlib bindings. This reflects
# each ecosystem's typical FFI tolerance + the
# maturity of pure-language cryptography in
# each ecosystem.
#
# Axis 273 opens with the Rust slot at
# Birr-Pixton's rustls, anchoring his
# specialized-protocol canonical position +
# extending the rustls organization's
# influence into the canonical-library corpus.
# ============================================================================

_hxn() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-u --url)'{-u,--url}'[single URL to screenshot]:url:' \
        '(-f --file-path)'{-f,--file-path}'[file containing URLs (one per line)]:file:_files' \
        '--stdin[read URLs from stdin]' \
        '(-b --binary-path)'{-b,--binary-path}'[browser binary path]:path:_files' \
        '(-t --tabs)'{-t,--tabs}'[max parallel tabs]:n:' \
        '(-x --width)'{-x,--width}'[viewport width in px]:px:' \
        '(-y --height)'{-y,--height}'[viewport height in px]:px:' \
        '--timeout=[URL load timeout in ms]:ms:' \
        '--delay=[client-side loading delay in ms]:ms:' \
        '--fullpage[capture full-page screenshot]' \
        '--screenshot-type=[output format]:fmt:(png jpeg webg)' \
        '--javascript=[arbitrary JavaScript to execute before screenshot]:code:' \
        '(-o --outdir)'{-o,--outdir}'[output directory]:dir:_files -/' \
        '--ports=[port overrides (range x..y or x,y,z)]:spec:' \
        '--accept-invalid-certs[accept invalid TLS certificates + trust-dns]' \
        '--user-agent=[user-agent (random / random-per-url / file / custom)]:ua:' \
        '--proxy=[proxy URL]:url:' \
        '(-s --silent)'{-s,--silent}'[silent mode (automation-friendly)]' \
        '--json[output results as NDJSON]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_hxn "$@"
