#compdef typesense-server
# Documentation: https://typesense.org/docs/latest/api/server-configuration.html
# Reference accessed: 2026-05-21
# Verified: upstream Typesense server-configuration docs (v29.0).

# Zsh completion for Typesense search server

_arguments -s -S \
  '--data-dir=[data directory]:directory:_files -/' \
  '--api-key=[bootstrap admin API key]:key:' \
  '--api-address=[API listen address]:address:' \
  '--api-port=[API listen port]:port:' \
  '--peering-address=[peering address]:address:' \
  '--peering-port=[peering port]:port:' \
  '--nodes=[path to nodes file for clustering]:file:_files' \
  '--ssl-certificate=[SSL certificate]:file:_files' \
  '--ssl-certificate-key=[SSL key]:file:_files' \
  '--ssl-refresh-interval-seconds=[SSL refresh interval]:seconds:' \
  '--enable-cors[enable CORS]' \
  '--cors-domains=[CORS allowed domains]:domains:' \
  '--thread-pool-size=[thread pool size]:size:' \
  '--num-collections-parallel-load=[parallel collection loading]:count:' \
  '--num-documents-parallel-load=[parallel document loading]:count:' \
  '--log-dir=[log directory]:directory:_files -/' \
  '--config=[config file]:file:_files' \
  '--snapshot-interval-seconds=[snapshot interval]:seconds:' \
  '--healthy-read-lag=[max healthy read lag]:lag:' \
  '--healthy-write-lag=[max healthy write lag]:lag:' \
  '--reset-peers-on-error[reset peers on error]' \
  '--analytics-dir=[analytics data directory]:directory:_files -/' \
  '--analytics-flush-interval=[analytics flush interval]:seconds:'
