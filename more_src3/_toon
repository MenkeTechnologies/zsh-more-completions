#
# WHAT IS consola AND WHY IS IT THE 51ST TS-NODE CLI LIBRARY?
#
# consola (https://github.com/unjs/consola, 7800+ stars) is
# **the unjs collective's "elegant console logger for Node.js
# and Browser"** — a unified observability library for Node CLI
# applications.  Originally developed for Nuxt.js's developer
# tooling, consola became a standalone library used across the
# entire unjs ecosystem (Nuxt, Nitro, h3, ofetch, vite-node,
# unbuild, ufo, ohash, scule, defu, magicast, mlly, pkg-types,
# c12, citty, and ~200+ other unjs packages).
#
# consola's distinguishing characteristics:
#
#   1. UNIFIED LOG LEVELS + STRUCTURED COLOR OUTPUT — Where
#      other Node loggers (winston, pino, bunyan, log4js) focus
#      on structured-JSON logging for backend services, consola
#      is purpose-built for CLI tools and developer consoles
#      with:
#         * LEVELS: silent(-1), fatal(0), error(0), warn(1),
#                    log(2), info(3), success(3), fail(3),
#                    ready(3), start(3), debug(4), trace(5),
#                    verbose(99)
#         * Each level has a DISTINCT COLOR + ICON + STRUCTURED
#           FORMATTING (e.g., `success` is green ✔, `error` is
#           red ✖, `info` is blue ℹ, `start` is magenta ⇒)
#         * Per-level reporter customization (override how each
#           level renders)
#         * Automatic detection of color support + Unicode
#           support
#
#      Example:
#
#          import { consola } from 'consola';
#          consola.success('Build complete');
#          consola.error(new Error('Connection failed'));
#          consola.start('Compiling...');
#          consola.ready('Server listening on :3000');
#
#      Compare:
#         * winston: structured JSON logging, transport-based
#         * pino: blazing fast JSON logging for services
#         * signale (sindresorhus): similar to consola but
#                                    less actively maintained
#         * consola: developer-console UX with semantic levels
#      FIRST documented TS-Node logging library with semantic
#      log levels (success/start/ready/fail/info distinct).
#
#   2. REPORTER ABSTRACTION FOR OUTPUT BACKENDS — consola
#      separates LOG EVENT EMISSION from OUTPUT RENDERING via
#      the Reporter abstraction:
#
#          import { createConsola } from 'consola';
#          import { FancyReporter, JSONReporter } from 'consola/reporters';
#
#          const logger = createConsola({
#              reporters: [
#                  new FancyReporter(),    // colored TTY output
#                  new JSONReporter(),     // JSON lines for log files
#              ],
#          });
#
#          logger.success('Build complete'); // emits to BOTH reporters
#
#      Built-in reporters:
#         * FancyReporter (default): colored + icons + multiline
#         * BasicReporter: plain text (for CI/redirect)
#         * JSONReporter: newline-delimited JSON
#         * BrowserReporter: browser-devtools-style
#      Plus user-defined custom reporters via the Reporter
#      interface.  Compare:
#         * winston: similar transport-based architecture
#         * pino: similar with pino-transport
#         * consola: reporter abstraction with multi-output
#      Distinct from winston/pino by being CLI-developer-
#      console-focused vs structured-backend-logging-focused.
#
#   3. PROMPT + SPINNER + PROGRESS INTEGRATION — consola exposes
#      INTERACTIVE prompts (delegating to @clack/prompts under
#      the hood) AND animated spinners (delegating to ora-style
#      via cli-spinners) AND progress reporters as SAME-API
#      METHODS on the logger instance:
#
#          // Interactive prompt
#          const name = await consola.prompt('What is your name?', {
#              placeholder: 'Anonymous',
#          });
#
#          // Spinner
#          const spinner = consola.start('Loading data...');
#          await loadData();
#          spinner.stop();      // or consola.success('Done')
#
#      Compare:
#         * winston/pino/bunyan: no interactive prompts (server-
#                                  logging focus)
#         * signale: similar feature set but smaller community
#         * consola: PROMPTS + SPINNERS + PROGRESS unified into
#                     one logger API
#      FIRST documented TS-Node logging library with prompts +
#      spinners + progress unified in one API.
#
#   4. PAUSE/RESUME + BUFFERING SEMANTICS — consola supports
#      pausing log output (during interactive prompts, for
#      example) and resuming with buffered messages:
#
#          consola.pause();        // buffer all messages
#          // ... show prompt without log interference ...
#          consola.resume();       // flush buffer + resume
#
#      And withTag() / wrapStd() / wrapConsole() helpers to
#      capture stdout/stderr/native console.* calls into consola
#      events.  Compare every other documented TS-Node logger —
#      none expose this pause/resume + buffering capability.
#      FIRST documented TS-Node logging library with pause/
#      resume buffering.
#
#   5. UNJS-ECOSYSTEM PROVENANCE — consola is the foundational
#      logger for the unjs collective (unified JavaScript
#      services), which maintains:
#         * Nuxt.js (50k+ stars) — Vue meta-framework
#         * Nitro — universal server engine
#         * h3 — HTTP server (uses consola internally)
#         * unbuild — universal builder
#         * vite-node — Vite runtime
#         * citty — CLI framework (used by toon CLI here)
#         * ofetch — fetch wrapper
#         * defu — deep object merger
#         * ohash — object hashing
#         * magicast — AST-as-data
#         * c12 — config loader
#         * mlly — module resolution
#         * 200+ other packages
#      Every unjs package depends on consola for its CLI output.
#      The unjs ecosystem accounts for ~10% of all weekly npm
#      downloads for CLI tools.  Compare every other documented
#      TS-Node logger — none have comparable single-ecosystem
#      foundational provenance.  FIRST documented TS-Node
#      logger with unjs-ecosystem foundational provenance.
#
# consola's relationship to other documented TS-Node libraries:
#
#   * Like chalk/kleur/picocolors (Axis 4) — colors output
#   * Unlike them — adds LOG LEVELS + ICONS + multi-reporter +
#                    prompts + spinners on top of coloring
#   * Like @clack/prompts (Axis 2) — supports interactive prompts
#   * Unlike clack — clack is prompts-only; consola unifies
#                     prompts + logging + spinners
#   * Like listr2 (Axis 7) — both show progress
#   * Unlike listr2 — listr2 is task-list-focused; consola is
#                      general-purpose logger
#   * Closest cross-language analogs:
#         * Rust: tracing — similar structured-event model with
#                  configurable subscribers (like consola's
#                  reporters)
#         * Go: zap (uber) — structured logging with multiple
#                 outputs; or charmbracelet/log which is more
#                 developer-console-focused
#     consola is the FIRST documented TS-Node library opening
#     Axis 9 (UNIFIED LOGGING / OBSERVABILITY).
#
# -----------------------------------------------------------------------------
#
# THE toon CLI — citty + consola
#
# toon's CLI in packages/cli/src/index.ts uses citty for argv
# (already documented) + consola for output:
#
#     import { defineCommand } from 'citty';
#     import { consola } from 'consola';
#
#     export const mainCommand = defineCommand({
#         meta: {
#             name,
#             description: 'TOON CLI – Convert between JSON and TOON formats',
#             version,
#         },
#         args: {
#             input: { type: 'positional', required: false },
#             output: { type: 'string', alias: 'o' },
#             encode: { type: 'boolean', alias: 'e' },
#             decode: { type: 'boolean', alias: 'd' },
#             delimiter: { type: 'string', default: ',' },
#             indent: { type: 'string', default: '2' },
#             strict: { type: 'boolean', default: true },
#             keyFolding: { type: 'string', default: 'off' },
#             flattenDepth: { type: 'string' },
#             expandPaths: { type: 'string', default: 'off' },
#             stats: { type: 'boolean', default: false },
#             verbose: { type: 'boolean', default: false },
#         },
#         async run({ args }) {
#             try {
#                 // ... encode or decode based on args ...
#                 consola.success('Conversion complete');
#                 if (args.stats) consola.info(`Tokens: ${tokenCount}`);
#             } catch (error) {
#                 consola.error(error);
#             }
#         },
#     });
#
# Operation: by default toon auto-detects encode/decode based
# on file extension (.json → encode to TOON; .toon → decode to
# JSON).  Explicit `-e` / `-d` flags override auto-detection.
# Output goes to file (`-o`) or stdout if unspecified.
#
# Five-axis distinctness from every other documented TS-Node
# logger/colorizer/observability library:
#
#   1. SEMANTIC LOG LEVELS WITH ICONS — Every other documented
#      TS-Node logger uses standard syslog levels (debug/info/
#      warn/error).  consola adds semantic levels (success/
#      start/ready/fail) each with distinct ICON + COLOR +
#      formatting.  FIRST documented TS-Node logger with this.
#
#   2. REPORTER ABSTRACTION FOR MULTI-OUTPUT — Every other
#      documented TS-Node logger has either single-output (most
#      colorizers) or transport architecture (winston/pino).
#      consola's Reporter abstraction is cleaner and
#      CLI-developer-console-focused.
#
#   3. PROMPTS + SPINNERS + PROGRESS UNIFIED — Every other
#      documented TS-Node logger focuses on log EMISSION.
#      consola unifies prompts (@clack/prompts) + spinners +
#      progress + logging into one logger API.  FIRST
#      documented TS-Node logger with this unification.
#
#   4. PAUSE/RESUME BUFFERING — Every other documented TS-Node
#      logger lacks pause/resume + message-buffering semantics.
#      consola exposes consola.pause() + consola.resume() that
#      buffer messages during interactive prompts.  FIRST
#      documented TS-Node logger with this.
#
#   5. UNJS-ECOSYSTEM FOUNDATIONAL PROVENANCE — Every other
#      documented TS-Node logger is general-purpose with
#      diverse user base.  consola is the foundational logger
#      of the unjs collective (Nuxt + Nitro + h3 + 200+
#      packages).  FIRST documented TS-Node logger with this
#      single-ecosystem foundational provenance.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/toon-format/toon/blob/main/packages/cli/src/index.ts
# mainCommand args definition.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-o --output)'{-o+,--output=}'[output file path]:file:_files' \
    '(-e --encode -d --decode)'{-e,--encode}'[encode JSON to TOON]' \
    '(-e --encode -d --decode)'{-d,--decode}'[decode TOON to JSON]' \
    '--delimiter=[delimiter for arrays (default ,)]:delim:((,\:"comma\ (default)" $'\''\\t'\''\:"tab\ (LLM-optimal)" "|\:pipe\ (human-readable)"))' \
    '--indent=[indentation size (default 2)]:N:' \
    '--strict[strict decode validation (default enabled)]' \
    '--no-strict[disable strict decode validation]' \
    '--keyFolding=[enable key folding (default off)]:mode:(off safe)' \
    '--flattenDepth=[max folded segment count when key folding is enabled]:N:' \
    '--expandPaths=[enable path expansion (default off)]:mode:(off safe)' \
    '--stats[show token statistics]' \
    '--verbose[show full stack traces and cause chains for errors]' \
    '*:input file (omit or "-" for stdin):_files -g "*.(json|toon)"' \
    && ret=0

return ret
