#compdef scanimage
# Documentation: https://manpages.debian.org/scanimage
# Source: sane-project/backends frontend/scanimage.c — command-line scanner front-end (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-v,--verbose}'[verbose output]' \
    {-d+,--device-name=}'[scanner device name]:device:_default' \
    {-L,--list-devices}'[list available devices]' \
    {-f+,--formatted-device-list=}'[list devices in printf format]:format:_default' \
    {-p,--progress}'[show scan progress]' \
    {-o+,--output-file=}'[output file]:file:_files' \
    {-T,--test}'[test backend reliability]' \
    {-A,--all-options}'[list backend-specific options]' \
    {-B+,--buffer-size=}'[buffer size in KiB]:KiB:_default' \
    {-b-,--batch=-}'[batch scan with optional output format]::format:_default' \
    '--batch-count=-[number of images]:n:_default' \
    '--batch-start=-[starting page number]:n:_default' \
    '--batch-double[scan double-sided]' \
    '--batch-increment=-[page increment]:n:_default' \
    '--batch-print[print result to stdout]' \
    '--batch-prompt[prompt before each scan]' \
    '--format=-[output image format]:format:(pnm tiff png jpeg)' \
    '--accept-md5-only[accept only MD5 auth]' \
    {-i+,--icc-profile=}'[ICC colour profile]:file:_files -g "*.icc"' \
    {-n,--dont-scan}'[do not actually scan]' \
    && ret=0

return ret
