#compdef likec4
# Documentation: https://likec4.dev/tooling/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# likec4 ships a yargs-generated dynamic completer; this static fallback
# lists the documented top-level subcommands when the yargs script is not
# available.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'serve:preview diagrams with hot-reload'
  'start:preview diagrams with hot-reload'
  'dev:preview diagrams with hot-reload'
  'build:build a static website for diagrams'
  'preview:preview a built project'
  'export:export diagrams (png/json/drawio)'
  'gen:generate diagrams (mmd/mermaid/dot/d2/plantuml)'
  'validate:check for syntax errors and layout drift'
  'format:format source files'
  'fmt:format source files'
  'lsp:launch language server'
  'completion:print shell completion script'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'likec4 command' commands && ret=0 ;;
  args)
    _arguments \
      '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
      '--project=[project name]:project:' \
      '--theme=[color theme]:theme:(light dark)' \
      '(-f --filter)'{-f+,--filter=}'[include views matching pattern]:pattern:' \
      '(-i --ignore)'{-i,--ignore}'[continue on failures]' \
      '--base-url=[deployment base path]:url:' \
      '--use-dot[use local Graphviz instead of bundled WASM]' \
      '--check[validate without modifying]' \
      '--files=[target specific source files]:files:_files' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
