#compdef kpack-build-waiter
# _kpack-build-waiter — kpack init/wait helper (block on a file, then exec)
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/build-waiter/main.go on tip.

_kpack-build-waiter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--mode=[operation mode]:mode:(wait copy)' \
        '--to=[where to copy this binary (copy mode)]:dest:_files' \
        '--wait-file=[file to wait on (wait mode)]:file:_files' \
        '--done-file=[file to write on completion]:file:_files' \
        '--execute=[command to run after waiting]:cmd:' \
        '--error-file=[shared error file]:file:_files'
}

_kpack-build-waiter "$@"
