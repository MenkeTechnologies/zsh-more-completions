#compdef virt-filesystems
# _virt-filesystems — libguestfs virt-filesystems (enumerate the partitions/filesystems/LVs/disks present inside a libvirt VM image; -a disk, -d domain, -c URI, --all everything, --filesystems show filesystems, --partitions, --logical-volumes, --volume-groups, --physical-volumes, --block-devices, -l long output, --csv, -h human sizes, --uuid show UUID column)
# upstream: https://github.com/libguestfs/libguestfs (filesystems)
# Flags from libguestfs filesystems/filesystems.ml on tip.

_virt-filesystems() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '-l[long output]' \
        '--all[everything]' \
        '--filesystems[show filesystems]' \
        '--partitions[show partitions]' \
        '--logical-volumes[show LVs]' \
        '--volume-groups[show VGs]' \
        '--physical-volumes[show PVs]' \
        '--block-devices[show block devices]' \
        '-h[human readable sizes]' \
        '--csv[CSV output]' \
        '--uuid[include UUID]' \
        '--no-title[omit title row]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)'
}

_virt-filesystems "$@"
