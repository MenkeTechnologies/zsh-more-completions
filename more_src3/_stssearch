#compdef stssearch
# Documentation: https://emboss.bioinformatics.nl/cgi-bin/emboss/help/stssearch
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS stssearch: search a DNA sequence for sequence-tagged-site (STS)
# primer pairs.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying]' \
  '-version[version]' \
  '-seqall=[nucleotide sequence(s) USA]:DNA USA:_files' \
  '-infile=[primer pairs input file]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '-sbegin1=[start position of each sequence]:n:' \
  '-send1=[end position of each sequence]:n:' \
  '-sreverse1[reverse sequence]' \
  '-sask1[ask for begin/end/reverse]' \
  '-snucleotide1[sequence is nucleotide]' \
  '-sprotein1[sequence is protein]' \
  '-slower1[make lower case]' \
  '-supper1[make upper case]' \
  '-scircular1[sequence is circular]' \
  '-squick1[read id and sequence only]' \
  '-sformat1=[input sequence format]:fmt:' \
  '-sdbname1=[database name]:db:' \
  '-sid1=[entryname]:id:' \
  '-ufo1=[UFO features]:ufo:' \
  '-fformat1=[features format]:fmt:' \
  '-fopenfile1=[features file name]:file:_files' \
  '-odirectory3=[output directory]:dir:_directories' \
  '*:DNA USA:_files' && ret=0

return ret
