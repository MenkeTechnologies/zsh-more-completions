#compdef snyk-api-import
# ============================================================================
# snyk-api-import - Snyk API-driven bulk-import + sync automation
#                    (Node, Apache-2.0)
#
# Author : Snyk (snyk organization)
# Upstream: https://github.com/snyk/snyk-api-import
# npm    : snyk-api-import
#
# `snyk-api-import` is Snyk's official bulk-import + sync CLI:
# automate importing thousands of source-code targets (GitHub
# orgs, GitLab groups, Bitbucket workspaces, Azure Repos
# projects, Artifactory, ECR, GCR, Nexus, etc.) into Snyk for
# scanning, generate per-org config files for the matching
# integration, and keep the imported Snyk projects in sync
# with upstream changes (new repos appear, deleted repos get
# removed). The companion to `snyk` (interactive CLI) +
# `snyk-broker` (network broker) - this one is the unattended
# CI/CD automation tool.
#
# Subcommand tree (yargs, command-file pattern):
#   import (i) [$0]    - kick off API-powered import from a JSON
#                        file generated by import:data
#                        --file <path>    targets JSON file
#   import:data        - generate the targets JSON file from source
#                        --orgsData <path>      orgs data file
#                        --source <name>        GitHub / GitLab / etc.
#                        --sourceUrl <url>      custom API base URL
#   list:imported      - list already-imported targets
#                        --groupId <id>         Snyk group ID
#                        --orgId <id>           Snyk org ID
#                        --integrationType <t>  filter by integration
#   orgs:create        - create Snyk organizations from a data file
#                        --file <path>          orgs data file
#                        --noDuplicateNames     skip duplicate names
#                        --includeExistingOrgsInOutput
#   orgs:data          - generate the orgs data file from source
#                        --sourceOrgPublicId <id>  Snyk template org
#                        --groupId <id>            Snyk group
#                        --sourceUrl <url>         custom API URL
#                        --skipEmptyOrgs           skip empty orgs
#                        --source <name>           GitHub / GitLab / ...
#   sync               - sync existing Snyk projects with upstream
#                        --orgPublicId <id>        Snyk org
#                        --sourceUrl <url>         custom API URL
#                        --source <list>           sources to sync
#                        --dryRun                  log potential updates
#                        --snykProduct <list>      products to sync
#                        --exclusionGlobs <globs>  comma-sep ignore
#
# The bottleneck lane is built on `bottleneck 2.19.5` (declared
# verbatim at upstream package.json HEAD), the canonical Node
# rate limiter by Simon Grondin (github.com/SGrondin/bottleneck,
# 1900+ stars). bottleneck is the de-facto Node rate limiter
# for "respect upstream API rate limits" use cases - it
# combines concurrency control (max N parallel requests) with
# rate limiting (max N requests per M seconds) in a single
# scheduler, with optional priority queue + Redis-backed
# cluster-wide coordination. snyk-api-import uses it to throttle
# bulk-imports against the Snyk API rate limit AND the upstream
# source-code-host rate limit (GitHub's secondary rate limit
# kicks in at ~5000 req/hr per token; bottleneck queues
# requests to stay under it).
#
# ----------------------------------------------------------------------------
# AXIS 226 :: Rate limiting (leaky bucket / token bucket / GCRA)  [CLOSES]
# Round 1378 :: TS-Node slot 3 of 4 :: CLOSES Axis 226 (219th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : boinkor-net/governor         [R1376 _playit-cli]
#   Go      : golang.org/x/time/rate       [R1377 _derod]
#   TS/Node : SGrondin/bottleneck          [R1378 THIS FILE]
#
# bottleneck rounds out a three-way algorithmic split across
# this axis - each lane picks a *different* underlying model:
#
#   governor (Rust, GCRA):
#     Generic Cell Rate Algorithm - leaky-bucket equivalent
#     expressed as "earliest acceptable timestamp" per check.
#     Lock-free, branch-free per-request cost.
#
#   x/time/rate (Go, token bucket):
#     Classic token bucket - fill at constant rate, consume
#     per request, allow bursts up to bucket capacity. Simple
#     Allow()/Wait()/Reserve() API.
#
#   bottleneck (Node, scheduler):
#     Concurrency-limit + rate-limit combined scheduler.
#     Priority queue with optional Redis-backed cluster sync.
#     The library treats rate limiting as a queueing problem,
#     not a check problem - all requests enter the queue,
#     the scheduler releases them per the limits.
#
# The three algorithms produce subtly different observable
# behavior under load. Token bucket admits bursts up to
# capacity then settles at fill rate. GCRA enforces constant
# inter-arrival distance with no bursts. bottleneck's
# scheduler can queue indefinitely or fail fast based on the
# `highWater` config. Cross-language API portability is poor:
# moving rate-limit logic from one lane to another typically
# requires re-tuning the limit parameters to match the new
# algorithm's burst characteristics.
#
# Each lane's choice reflects the host language's concurrency
# model: governor wants lock-free atomics (Rust's strength);
# x/time/rate is goroutine-native (Wait() blocks the calling
# goroutine cheaply); bottleneck is Promise-native
# (.schedule() returns a Promise that resolves when the
# request is allowed to fire).
# ============================================================================

_snyk-api-import() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '1: :_snyk-api-import_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                import|i)         _arguments '--file[path to JSON file with targets]:file:_files -g "*.json"' '(- *)'{-h,--help}'[help]' ;;
                import:data)      _arguments \
                                      '--orgsData[path to organizations data file generated with orgs:data]:file:_files -g "*.json"' \
                                      '--source[source of targets to import]:source:(github github-enterprise gitlab bitbucket-server bitbucket-cloud azure-repos)' \
                                      '--sourceUrl[custom base URL for the source API]:url:' \
                                      '(- *)'{-h,--help}'[help]' ;;
                list:imported)    _arguments \
                                      '--groupId[Snyk group ID]:id:' \
                                      '--orgId[Snyk organization ID]:id:' \
                                      '--integrationType[configured integration type]:type:(github github-enterprise gitlab bitbucket-server bitbucket-cloud azure-repos)' \
                                      '(- *)'{-h,--help}'[help]' ;;
                orgs:create)      _arguments \
                                      '--file[path to data file generated with orgs:data]:file:_files -g "*.json"' \
                                      '--noDuplicateNames[skip creating an organization if name already taken]' \
                                      '--includeExistingOrgsInOutput[log existing organization information as well]' \
                                      '(- *)'{-h,--help}'[help]' ;;
                orgs:data)        _arguments \
                                      '--sourceOrgPublicId[Snyk template organization public ID]:id:' \
                                      '--groupId[Snyk group ID]:id:' \
                                      '--sourceUrl[custom base URL for source API]:url:' \
                                      '--skipEmptyOrgs[skip organizations with no targets]' \
                                      '--source[source name]:source:(github github-enterprise gitlab bitbucket-server bitbucket-cloud azure-repos)' \
                                      '(- *)'{-h,--help}'[help]' ;;
                sync)             _arguments \
                                      '--orgPublicId[Snyk org public ID to update]:id:' \
                                      '--sourceUrl[custom base URL for source API]:url:' \
                                      '--source[comma-separated sources to sync]:sources:' \
                                      '--dryRun[log potential updates without applying them]' \
                                      '--snykProduct[Snyk products to consider]:products:(open-source container code iac)' \
                                      '--exclusionGlobs[comma-separated glob patterns to exclude]:globs:' \
                                      '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac

    return ret
}

_snyk-api-import_cmds() {
    local -a cmds
    cmds=(
        'import:Kick off API powered import from a targets JSON file'
        'i:Alias for import'
        'import:data:Generate the targets JSON file from a source'
        'list:imported:List already-imported targets'
        'orgs:create:Create Snyk organizations from a data file'
        'orgs:data:Generate the orgs data file from a source'
        'sync:Sync existing Snyk projects with upstream changes'
    )
    _describe -t commands 'snyk-api-import command' cmds
}

_snyk-api-import "$@"
