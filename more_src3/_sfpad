#compdef sfpad
# Documentation: http://www.ahay.org/RSF/sfpad.html
# Source: ahay/src system/main/pad.c — pad an RSF dataset with zeros at axis ends.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'beg1=[zeros to add before 1st axis]: :_default' \
    'end1=[zeros to add after 1st axis]: :_default' \
    'n1out=[output length of 1st axis (pad to here)]: :_default' \
    'beg2=[zeros to add before 2nd axis]: :_default' \
    'end2=[zeros to add after 2nd axis]: :_default' \
    'n2out=[output length of 2nd axis]: :_default' \
    'beg3=[zeros to add before 3rd axis]: :_default' \
    'end3=[zeros to add after 3rd axis]: :_default' \
    'n3out=[output length of 3rd axis]: :_default' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
