#compdef way-displays
# Documentation: https://github.com/alex-courtis/way-displays
# Reference accessed: 2026-05-21
# Verified: upstream man page doc/way-displays.1 in the repository.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print usage and exit]' \
  '(- *)'{-v,--version}'[display version and exit]' \
  '-L+[log threshold]:level:(debug info warning error fatal)' \
  '--log-threshold=[log threshold]:level:(debug info warning error fatal)' \
  '(-c --config)'{-c,--config}'+[config file path]:file:_files' \
  '(-y --yaml)'{-y,--yaml}'[print client output as raw YAML]' \
  '(- *)'{-l,--list}'[show state of connected displays]' \
  '(- *)'{-g,--get}'[show active configuration, commands, display state]' \
  '(- *)'{-s,--set}'[add a new setting or modify an existing one]' \
  '(- *)'{-d,--delete}'[remove an existing setting]' \
  '(- *)'{-t,--toggle}'[toggle a setting]' \
  '(- *)'{-w,--write}'[write active configuration to cfg.yaml]' \
  '*:setting:(ARRANGE_ALIGN ORDER SCALING AUTO_SCALE SCALE MODE TRANSFORM VRR_OFF DISABLED CALLBACK_CMD)' && ret=0

return ret
