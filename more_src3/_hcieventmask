#compdef hcieventmask
# Documentation: https://github.com/bluez/bluez/blob/master/tools/hcieventmask.c
# Source: BlueZ tools/hcieventmask.c — print HCI event mask bits for a controller.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --device)'{-i+,--device=}'[HCI device]:hciN:' \
    && ret=0

return ret
