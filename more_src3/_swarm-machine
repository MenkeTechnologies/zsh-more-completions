#compdef swarm-machine
# _swarm-machine — docker-machine swarm provisioning frontend (composes docker-machine create with --swarm/--swarm-master/--swarm-discovery flags so a cluster gets a built-in Swarm master and worker; same driver vocabulary as docker-machine plus --swarm-image, --swarm-strategy, --swarm-host, --swarm-addr, --swarm-experimental)
# upstream: https://github.com/docker/machine (legacy)
# Flags from docker-machine drivers + create command on tip.

_swarm-machine() {
    _arguments \
        '--help[show help]' \
        '--driver=*[driver]:driver:(virtualbox vmwarefusion hyperv hyperkit kvm openstack google amazonec2 azure digitalocean exoscale generic rackspace softlayer)' \
        '-d+[driver]:driver:' \
        '--swarm[enable swarm]' \
        '--swarm-master[mark this node swarm master]' \
        '--swarm-discovery+[discovery URL]:url:' \
        '--swarm-image+[swarm image]:image:' \
        '--swarm-strategy+[strategy]:strategy:(spread binpack random)' \
        '*--swarm-opt+[swarm option]:option:' \
        '--swarm-host+[advertise host:port]:host:' \
        '--swarm-addr+[swarm addr]:addr:' \
        '--swarm-experimental[enable experimental swarm features]' \
        '--engine-install-url+[engine install script]:url:' \
        '*--engine-opt+[engine option]:option:' \
        '*--engine-label+[label]:label:' \
        '*--engine-env+[env var]:env:' \
        '1:machine name:'
}

_swarm-machine "$@"
