# WHAT IT IS
#   weron is "Lean, fast & secure overlay networks based on WebRTC" — a Go
#   cobra CLI that runs a WebRTC signaling server, joins communities of
#   peers over WebSocket signaling, then negotiates direct peer-to-peer
#   data channels for layered services:  chat over data channels, latency
#   and throughput utility probes, full Layer-3 (TUN) and Layer-2 (TAP)
#   VPN tunnels, and a management API for the signaling server.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/weron/cmd/*.go cobra+pflag setup)
#   weron [persistent flags] <command> [subcommand] [flags]
#
#   Persistent flags (apply to every subcommand):
#     -v, --verbose <int>      verbosity 0-7 (default 5 info; 6 debug; 7 trace)
#
#   Commands & aliases (alias list verbatim from each *Cmd.Aliases slice):
#     signaler (sgl, s)        Start a signaling server
#     chat (cht, c)            Chat in a community via WebRTC data channels
#     manager (mgr, m)         Manage communities on the signaling server
#       create (ctr, c, mk)      Create a new community
#       delete (del, d, rm)      Delete a community
#       list (lis, l, ls)        List communities
#     utility (uti, u, util)   Utility probes over WebRTC
#       latency (ltc, l)         Measure latency between peers
#       throughput (thr, t)      Measure throughput between peers
#     vpn (v)                  Overlay-network VPN modes
#       ip (i)                   Layer-3 TUN VPN (IPv4/IPv6)
#       ethernet (eth, e)        Layer-2 TAP VPN (Ethernet frames)
#
#   Shared peer-side flags (chat / utility / vpn subcommands):
#     --raddr <url>            signaler WS URL  (default wss://weron.up.railway.app/)
#     --timeout <duration>     connection timeout (default 10s)
#     --community <id>         community to join
#     --password <pw>          community password
#     --key <key>              symmetric encryption key
#     --ice <list>             STUN/TURN comma-list
#                                (default stun:stun.l.google.com:19302)
#     --force-relay            force TURN relay
#
#   signaler-specific:
#     --laddr <addr>           listen addr (default :1337; env PORT)
#     --heartbeat <duration>   heartbeat interval (default 10s)
#     --postgres-url <url>     DATABASE_URL fallback; empty = in-memory
#     --redis-url <url>        REDIS_URL fallback; empty = in-process
#     --cleanup                purge ephemeral communities on start
#     --ephemeral-communities  allow ephemeral community creation (def true)
#     --api-username <user>    management API user (default admin)
#     --api-password <pw>      management API password
#     --oidc-issuer <url>      OIDC issuer URL
#     --oidc-client-id <id>    OIDC client id
#
#   chat-specific:
#     --names <list>           desired display-name candidates
#     --channels <list>        data-channels to join (default chat primary)
#     --id-channel <ch>        ID-negotiation channel
#     --kicks <duration>       kick timeout (default 5s)
#
#   utility latency-specific:
#     --server                 act as latency server
#     --packet-length <int>    bytes per ping packet (default 128)
#     --pause <duration>       pause between packets (default 1s)
#
#   utility throughput-specific:
#     --server                 act as throughput server
#     --packet-length <int>    bytes per packet (default 50000)
#     --packet-count <int>     packets per ack (default 1000)
#
#   vpn ip-specific:
#     --dev <name>             TUN device name (auto; Linux only)
#     --ips <cidr-list>        claim from these IP networks
#     --static                 try exact-IP static claim
#     --parallel <int>         frame-decode threads (default NumCPU)
#     --id-channel <ch>        ID-negotiation channel
#     --kicks <duration>       kick timeout (default 5s)
#     --max-retries <int>      IP-claim retries (default 200)
#
#   vpn ethernet-specific:
#     --dev <name>             TAP device name (auto; Linux/macOS)
#     --mac <mac>              MAC address (auto; Linux only)
#     --parallel <int>         frame-decode threads (default NumCPU)
#
#   manager create / delete:
#     --community <id>         community to create or delete
#     --password <pw>          community password (create only)
#     + management API flags (--raddr, --api-username, --api-password)
#
# AXIS / CORPUS POSITION
#   Direct dependency on github.com/pion/webrtc/v3 v3.3.5 (the pure-Go
#   reference WebRTC implementation maintained by the Pion project) declared
#   in go.mod — the data channel under every weron service runs through
#   pion/webrtc PeerConnections.  Verified via:
#     gh api repos/pojntfx/weron/contents/go.mod
#       → github.com/pion/webrtc/v3 v3.3.5
#   This entry is the Go=111 leader bump that continues Axis 56
#   (WebRTC Media Library) opened at R813 with Rust=webrtc-rs (whipinto).
#
#   No completion for `weron` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_weron() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --verbose)'{-v+,--verbose=}'[verbosity level (0=disabled..5=info..7=trace)]:level:(0 1 2 3 4 5 6 7)' \
        '(- *)'{-h,--help}'[help for weron]' \
        '1: :_weron_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                signaler|sgl|s)         _weron_signaler   && ret=0 ;;
                chat|cht|c)             _weron_chat       && ret=0 ;;
                manager|mgr|m)          _weron_manager    && ret=0 ;;
                utility|uti|u|util)     _weron_utility    && ret=0 ;;
                vpn|v)                  _weron_vpn        && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_weron_commands] )) ||
_weron_commands() {
    local -a commands
    commands=(
        'signaler:start a signaling server'
        'sgl:start a signaling server'
        's:start a signaling server'
        'chat:chat in a community via WebRTC data channels'
        'cht:chat in a community via WebRTC data channels'
        'manager:manage communities on the signaling server'
        'mgr:manage communities on the signaling server'
        'm:manage communities on the signaling server'
        'utility:utility probes (latency, throughput) over WebRTC'
        'uti:utility probes over WebRTC'
        'util:utility probes over WebRTC'
        'vpn:overlay-network VPN (ip / ethernet)'
        'v:overlay-network VPN'
    )
    _describe -t commands 'weron command' commands
}

# Shared peer-side connection flags used by chat / utility / vpn subcmds
_weron_peer_flags() {
    _arguments -s \
        '--raddr=[signaler WebSocket URL]:URL:_urls' \
        '--timeout=[time to wait for connections]:duration (e.g. 10s, 1m):' \
        '--community=[ID of community to join]:community id:' \
        '--password=[password for community]:password:' \
        '--key=[encryption key for community]:key:' \
        '--ice=[comma-separated STUN/TURN server list]:ice servers:' \
        '--force-relay[force usage of TURN servers]' \
        '(-v --verbose)'{-v+,--verbose=}'[verbosity level]:level:(0 1 2 3 4 5 6 7)' \
        '(- *)'{-h,--help}'[help]'
}

