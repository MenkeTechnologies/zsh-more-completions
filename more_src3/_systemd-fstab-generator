#compdef systemd-fstab-generator
# _systemd-fstab-generator (systemd unit generator that converts /etc/fstab into .mount/.swap units and synthesizes them at boot; generators are invoked by systemd with three positional directories (normal_dir, early_dir, late_dir) and never directly by the user)
# upstream: https://github.com/systemd/systemd (src/fstab-generator)
# Argument shape from systemd src/fstab-generator/fstab-generator.c on tip.

_systemd-fstab-generator() {
    _arguments \
        '1:normal dir:_files -/' \
        '2:early dir:_files -/' \
        '3:late dir:_files -/'
}

_systemd-fstab-generator "$@"
