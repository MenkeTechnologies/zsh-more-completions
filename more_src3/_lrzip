#compdef lrzip
# Documentation: https://manpages.debian.org/bookworm/lrzip/lrzip.1.en.html
# Reference accessed: 2026-05-19
# Verified: Debian bookworm lrzip(1) manpage.

# Zsh completion for lrzip
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-z --zpaq)'{-z,--zpaq}'[use zpaq compression (best)]' \
  '(-l --lzo)'{-l,--lzo}'[use lzo compression (fastest)]' \
  '(-b --bzip2)'{-b,--bzip2}'[use bzip2 compression]' \
  '(-g --gzip)'{-g,--gzip}'[use gzip compression]' \
  '(-n --no-compress)'{-n,--no-compress}'[no backend compression]' \
  '(-L --level)'{-L+,--level=}'[compression level 1-9]:level:(1 2 3 4 5 6 7 8 9)' \
  '(-o --outfile)'{-o+,--outfile=}'[output file]:file:_files' \
  '(-O --outdir)'{-O+,--outdir=}'[output directory]:dir:_files -/' \
  '(-S --suffix)'{-S+,--suffix=}'[output file suffix]:suffix:' \
  '(-f --force)'{-f,--force}'[force overwrite of existing files]' \
  '(-d --decompress)'{-d,--decompress}'[decompress]' \
  '(-t --test)'{-t,--test}'[test compressed file integrity]' \
  '(-c --check)'{-c,--check}'[verify after extraction]' \
  '(-k --keep-broken)'{-k,--keep-broken}'[keep broken or damaged output files]' \
  '(-D --delete)'{-D,--delete}'[delete source after compress/decompress]' \
  '(-p --threads)'{-p+,--threads=}'[number of processor threads]:n:' \
  '(-N --nice-level)'{-N+,--nice-level=}'[nice level]:n:' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --window)'{-w+,--window=}'[max compression window (in 100 MB)]:n:' \
  '(-e --encrypt)'{-e,--encrypt}'[encrypt file]' \
  '(-h --help -\\?)'{-h,-\?,--help}'[show help]' \
  '(-H --hash)'{-H,--hash}'[display md5 hash integrity info]' \
  '(-i --info)'{-i,--info}'[show archive info only]' \
  '(-T --threshold)'{-T,--threshold}'[disable compression threshold check]' \
  '(-U --unlimited)'{-U,--unlimited}'[use unlimited window size]' \
  '(-m --maxram)'{-m+,--maxram=}'[max ram percentage]:n:' \
  '*:file:_files' && ret=0
return ret
