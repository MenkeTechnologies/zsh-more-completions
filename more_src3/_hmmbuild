#compdef hmmbuild
# Documentation: http://eddylab.org/software/hmmer3/3.1b2/Userguide.pdf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# HMMER hmmbuild: build profile HMM from a multiple-sequence alignment
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-n[name the HMM]:name:' \
  '-o[output summary to file]:file:_files' \
  '-O[save annotated alignment to file]:file:_files' \
  '--amino[assert amino acid alignment]' \
  '--dna[assert DNA alignment]' \
  '--rna[assert RNA alignment]' \
  '--fast[use fast/heuristic build (default)]' \
  '--hand[use match column assignments from alignment]' \
  '--symfrac[non-gap symbol fraction for match-col definition]:frac:' \
  '--fragthresh[treat sequences shorter than this fraction as fragments]:frac:' \
  '--wpb[Henikoff position-based relative weights]' \
  '--wgsc[Gerstein/Sonnhammer/Chothia weighting]' \
  '--wblosum[BLOSUM filter weighting]' \
  '--wnone[no relative weighting]' \
  '--wgiven[weights given in MSA]' \
  '--wid[identity threshold for BLOSUM weights]:frac:' \
  '--eent[Karplus method effective seq#]' \
  '--eclust[clustering effective seq#]' \
  '--enone[no effective seq# - use #seqs]' \
  '--eset[set effective seq# directly]:n:' \
  '--ere[entropy target in bits/col]:bits:' \
  '--esigma[entropy sigma]:val:' \
  '--eid[identity threshold for clustering eff#]:frac:' \
  '--pnone[no prior]' \
  '--plaplace[Laplace prior]' \
  '--EmL[ML stochastic max length]:n:' \
  '--EmN[ML stochastic test count]:n:' \
  '--EvL[Viterbi max length]:n:' \
  '--EvN[Viterbi test count]:n:' \
  '--EfL[Forward max length]:n:' \
  '--EfN[Forward test count]:n:' \
  '--Eft[Forward tail mass]:val:' \
  '--seed[random seed]:n:' \
  '--w_beta[tail mass for window length]:val:' \
  '--w_length[fixed window length]:n:' \
  '--maxinsertlen[maximum length of inserts]:n:' \
  '--cpu[CPU threads]:n:' \
  '--informat[input alignment format]:fmt:(stockholm pfam a2m afa clustal phylip phylips selex)' \
  '*:output HMM and input alignment file:_files' && ret=0
return ret
