#compdef screenblank
# Documentation: man screenblank(1)
# Source: netbsd/src usr.sbin/screenblank — framebuffer screen saver daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-b[blank the framebuffer once and exit]' \
    '(- *)-u[unblank the framebuffer once and exit]' \
    '-d+[inactivity timeout in seconds (default 600)]:timeout:_default' \
    '-e+[wakeup delay in seconds (default 0.25)]:delay:_default' \
    '-f+[framebuffer device (default /dev/fb)]:framebuffer:_files' \
    '*-i+[add input device to monitor]:input device:_files' \
    '(-m)-k[do not monitor keyboard]' \
    '(-k)-m[do not monitor mouse]' \
    && ret=0

return ret
