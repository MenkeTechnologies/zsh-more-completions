#compdef ldapexop
# _ldapexop — OpenLDAP Foundation ldapexop LDAP extended operation request tool whoami refresh cancel passmod (openldap team, C); custom argparse
# upstream: https://www.openldap.org

_ldapexop() {
    _arguments \
        '-h+[LDAP server]:host:_hosts' \
        '-H+[LDAP URI]:url:_urls' \
        '-p+[LDAP port]:port:_ports' \
        '-V[show version]' \
        '-?[show help]' \
        '-d+[debug level]:n:' \
        '-n[show what would be done]' \
        '-v[verbose mode]' \
        '-x[simple authentication]' \
        '-D+[bind DN]:str:' \
        '-w+[bind password]:str:' \
        '-W[prompt for bind password]' \
        '-y+[password file]:file:_files' \
        '-Y+[SASL mechanism]:str:' \
        '-U+[SASL authcid]:str:' \
        '-X+[SASL authzid]:str:' \
        '-R+[SASL realm]:str:' \
        '-O+[SASL security properties]:str:' \
        '-I[SASL prompt mode]' \
        '-N[no reverse DNS]' \
        '-Q[SASL quiet]' \
        '-Z[StartTLS]' \
        '-ZZ[require StartTLS]' \
        '-o+[option=value]:str:' \
        '-e+[criticality]:str:' \
        '-t+[time limit secs]:n:' \
        '*:oid or operation:(whoami refresh cancel passmod 1.3.6.1.4.1.4203.1.11.3 1.3.6.1.4.1.1466.20037 1.3.6.1.4.1.4203.1.11.1)'
}

_ldapexop "$@"
