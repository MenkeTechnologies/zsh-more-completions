#compdef httperf
# Documentation: https://manpages.debian.org/bookworm/httperf/httperf.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httperf - HTTP performance measurement tool.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose mode]' \
  {-d+,--debug=}'[debug level]:level:' \
  '--server=[target server hostname]:hostname:_hosts' \
  '--server-name=[server name for Host header]:name:' \
  '--port=[server port (default 80)]:port:' \
  '--uri=[target URI]:URI:' \
  '--http-version=[HTTP version]:version:(1.0 1.1)' \
  '--method=[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS TRACE PATCH)' \
  '--no-host-hdr[omit Host header]' \
  '--ssl[use SSL/TLS]' \
  '--ssl-ciphers=[colon-separated cipher list]:ciphers:' \
  '--ssl-no-reuse[disable SSL session ID reuse]' \
  '--num-conns=[total connections to create]:number:' \
  '--num-calls=[number of calls per connection]:number:' \
  '--rate=[connection creation rate]:rate:' \
  '--timeout=[overall timeout in seconds]:seconds:' \
  '--think-timeout=[server response initiation timeout]:seconds:' \
  '--burst-length=[burst length]:length:' \
  '--hog[use all available TCP ports]' \
  '--client=[client id/N]:I/N:' \
  '--close-with-reset[close connections with RST]' \
  '--add-header=[add header]:header:' \
  '--print-reply=[print server replies]:mode:(header body)' \
  '--print-request=[print requests]:mode:(header body)' \
  '--max-connections=[max connections per session]:number:' \
  '--max-piped-calls=[max pipelined calls per connection]:number:' \
  '--period=[interarrival period]:period:' \
  '--recv-buffer=[receive buffer size in bytes]:bytes:' \
  '--send-buffer=[send buffer size in bytes]:bytes:' \
  '--session-cookie[enable session cookies]' \
  '--retry-on-failure[retry failed requests in sessions]' \
  '--failure-status=[treat status as failure]:status:' \
  '--wlog=[generate URI sequence from file]:B,F:' \
  '--wsess=[generate sessions N1,N2,X]:N1,N2,X:' \
  '--wsesslog=[session log N,X,F]:N,X,F:' \
  '--wset=[walk through N distinct URIs at rate X]:N,X:'
