#compdef heaptrack-print heaptrack_print
# Documentation: https://invent.kde.org/sdk/heaptrack
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# heaptrack_print: analyze a heaptrack.* file (src/analyze/print/heaptrack_print.cpp)

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'=[heaptrack data file]:file:_files' \
  '(-d --diff)'{-d,--diff}'=[diff against base file]:file:_files' \
  '(-t --shorten-templates)'{-t,--shorten-templates}'=[shorten C++ template names]:bool:(true false)' \
  '(-m --merge-backtraces)'{-m,--merge-backtraces}'=[merge similar backtraces]:bool:(true false)' \
  '(-p --print-peaks)'{-p,--print-peaks}'=[print peak allocation backtraces]:bool:(true false)' \
  '(-a --print-allocators)'{-a,--print-allocators}'=[print top allocators]:bool:(true false)' \
  '(-T --print-temporary)'{-T,--print-temporary}'=[print temporary allocations]:bool:(true false)' \
  '(-l --print-leaks)'{-l,--print-leaks}'=[print leaks]:bool:(true false)' \
  '(-n --peak-limit)'{-n,--peak-limit}'=[max number of peaks to show]:n:' \
  '(-s --sub-peak-limit)'{-s,--sub-peak-limit}'=[max sub-peaks per peak]:n:' \
  '(-H --print-histogram)'{-H,--print-histogram}'=[write histogram to file]:file:_files' \
  '--flamegraph-cost-type=[flamegraph cost type]:type:(allocations temporary leaked peak)' \
  '(-F --print-flamegraph)'{-F,--print-flamegraph}'=[write flamegraph data to file]:file:_files' \
  '(-M --print-massif)'{-M,--print-massif}'=[write massif-format output]:file:_files' \
  '--massif-threshold=[massif allocation threshold]:pct:' \
  '--massif-detailed-freq=[massif detailed snapshot frequency]:n:' \
  '--filter-bt-function=[only show backtraces containing function]:fn:' \
  '--suppressions=[suppression file]:file:_files' \
  '--disable-embedded-suppressions[ignore embedded suppressions]' \
  '--disable-builtin-suppressions[ignore built-in suppressions]' \
  '--print-suppressions[print matched suppressions]' \
  '*:heaptrack file:_files -g "*.(gz|zst)"' && ret=0

return ret
