#compdef kaskade
# Documentation: https://github.com/sauljabin/kaskade/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kaskade: text user interface (TUI) for Apache Kafka

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'admin:admin view for managing topics, partitions and groups'
  'consumer:consumer view for reading topic messages'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kaskade command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (admin)
        _arguments \
          '(-b)-b+[Kafka bootstrap servers]:servers:' \
          '*-c+[configuration property (key=value)]:property:' \
          '--help[show help]' && ret=0
        ;;
      (consumer)
        _arguments \
          '(-b)-b+[Kafka bootstrap servers]:servers:' \
          '*-c+[configuration property (key=value)]:property:' \
          '(-t)-t+[topic to consume]:topic:' \
          '-k+[key deserializer]:deserializer:(bytes boolean string long integer double float json avro protobuf registry)' \
          '-v+[value deserializer]:deserializer:(bytes boolean string long integer double float json avro protobuf registry)' \
          '--from-beginning[consume from the beginning of the topic]' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
