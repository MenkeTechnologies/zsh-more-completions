#compdef himitsu hiq hims
# _himitsu — SourceHut Himitsu secrets manager CLI (Drew DeVault / SourceHut, C); custom argparse
# upstream: https://git.sr.ht/~sircmpwn/himitsu

_himitsu() {
    local -a sub=(
        'add:add a secret'
        'del:delete a secret'
        'lookup:lookup a secret'
        'query:query secrets'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--show-secrets[show secret values]' \
        '-s[show secret values]' \
        '--strict[strict matching]' \
        '-c[strict matching]' \
        '--no-key[do not require key]' \
        '-K[do not require key]' \
        '1:subcommand-or-query:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'himitsu subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments '*:key=value:' ;;
                del|lookup|query) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_himitsu "$@"
