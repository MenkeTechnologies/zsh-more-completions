#compdef restorecond
# Documentation: man restorecond(8)
# Source: SELinuxProject/selinux restorecond/restorecond.c (main) — watch and restore SELinux file contexts (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug mode (do not daemonize)]' \
    '-f+[watch file with paths to monitor]:file:_files' \
    '-F[take file as input (no watching)]' \
    '-u[run as user daemon (per-user)]' \
    '-v[verbose]' \
    '-h[show help]' \
    && ret=0

return ret
