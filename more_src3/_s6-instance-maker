#compdef s6-instance-maker
# _s6-instance-maker — s6 instance s6-instance-maker (generate the run/finish/log scaffolding for a new instance-template service from a template + parameters; output goes to a fresh service directory)
# upstream: https://github.com/skarnet/s6
# Flags from src/instance/s6-instance-maker.c on tip.

_s6-instance-maker() {
    _arguments \
        '-c+[max simultaneous instances]:n:' \
        '-u+[run instances as user]:user:_users' \
        '-l+[run logger as user]:user:_users' \
        '-L+[log directory]:dir:_files -/' \
        '-t+[timestamp type for logger]:type:(0 1 2 3)' \
        '-n+[number of rotated logfiles]:n:' \
        '-s+[per-logfile size limit]:bytes:' \
        '-S+[total log size limit]:bytes:' \
        '-P+[instance-name prefix]:prefix:' \
        '-r+[restart spec service[/logger[/pipeline]]]:spec:' \
        '1:template:_files -/' \
        '2:output-dir:_files -/'
}

_s6-instance-maker "$@"
