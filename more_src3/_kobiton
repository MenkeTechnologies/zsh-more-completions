#compdef kobiton kobiton-cli
# _kobiton — Kobiton mobile device cloud CLI (Kobiton, Node.js); commander
# upstream: https://github.com/kobiton

_kobiton() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'profile:show profile'
        'devices:list available devices'
        'apps:manage uploaded apps'
        'sessions:manage sessions'
        'tests:trigger / view tests'
        'reports:download session reports'
        'tunnels:manage local tunnels'
        'config:manage CLI config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--username=+[username]:str:_users' \
        '-u+[username]:str:_users' \
        '--api-key=+[api key]:str:' \
        '-k+[api key]:str:' \
        '--region=+[region]:r:(us eu)' \
        '--output=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kobiton subcommand' sub ;;
        args)
            case $words[1] in
                devices) _arguments \
                    '1:cmd:(list groups status reserve release)' \
                    '--platform=+[platform]:p:(android ios)' \
                    '--available[available only]' ;;
                apps) _arguments \
                    '1:cmd:(upload list delete get)' \
                    '--app-id=+[app id]:id:' \
                    '*:file:_files -g "*.(apk|ipa|aab|app|zip)"' ;;
                sessions) _arguments \
                    '1:cmd:(list get end)' \
                    '--session-id=+[session id]:id:' \
                    '--status=+[status]:s:(online offline finished)' \
                    '--limit=+[limit]:n:' ;;
                tests) _arguments \
                    '1:cmd:(run list get cancel)' \
                    '--script=+[script]:file:_files' \
                    '--config=+[config file]:file:_files' ;;
                reports) _arguments \
                    '1:cmd:(download list)' \
                    '--session-id=+[session id]:id:' \
                    '--output-dir=+[output dir]:dir:_files -/' ;;
                tunnels) _arguments \
                    '1:cmd:(start stop list)' \
                    '--name=+[tunnel name]:str:' \
                    '--port=+[port]:port:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kobiton "$@"
