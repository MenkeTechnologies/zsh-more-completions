#compdef kroki
# Documentation: https://github.com/yuzutech/kroki-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'convert:convert a diagram file'
      'encode:encode a diagram file'
      'decode:decode an encoded diagram'
      'version:show version information'
    )
    _describe -t commands 'kroki command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      convert)
        _arguments -s -S \
          '(-f --format)'{-f,--format}'[output format]:format:(svg png pdf jpeg base64)' \
          '(-t --type)'{-t,--type}'[diagram type]:type:(actdiag blockdiag bpmn bytefield c4plantuml d2 dbml ditaa erd excalidraw graphviz mermaid nomnoml nwdiag packetdiag pikchr plantuml rackdiag seqdiag structurizr svgbob symbolator tikz umlet vega vegalite wavedrom wireviz)' \
          '(-o --out-file)'{-o,--out-file}'[output file (- for STDOUT)]:output file:_files' \
          '(-c --config)'{-c,--config}'[alternate config file]:config file:_files' \
          '*:input file:_files' && ret=0
        ;;
      encode|decode)
        _arguments '*:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
