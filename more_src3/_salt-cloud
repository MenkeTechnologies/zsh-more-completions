#compdef salt-cloud
# _salt-cloud — SaltStack salt-cloud (provision/manage VMs on cloud providers (AWS/GCE/Azure/OpenStack/etc.) and bootstrap salt minions onto them; -p profile -P parallel, -m map file, -d destroy, -Q/-F query providers, -a action)
# upstream: https://github.com/saltstack/salt (salt/cli/cloud.py)
# Flags from salt cli/cloud.py on tip.

_salt-cloud() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-p+[profile]:profile:' \
        '-P[parallel]' \
        '-y[assume yes]' \
        '-d[destroy]' \
        '--destroy[destroy]' \
        '-m+[map file]:file:_files' \
        '-Q[query running VMs]' \
        '-F[full query]' \
        '-S[select query]' \
        '--list-providers[list configured providers]' \
        '--list-images+[list images]:provider:' \
        '--list-sizes+[list sizes]:provider:' \
        '--list-locations+[list locations]:provider:' \
        '-a+[action]:action:(start stop reboot destroy create show_instance enable_term_protect disable_term_protect)' \
        '-f+[function]:function:' \
        '--keep-tmp[keep bootstrap tmp]' \
        '--no-deploy[do not deploy minion]' \
        '-l+[log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--output+[output format]:format:(yaml json nested pprint txt)' \
        '*:name:'
}

_salt-cloud "$@"
