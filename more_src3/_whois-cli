#compdef whois-cli
# _whois-cli — Marco d'Itri whois Internet domain name lookup CLI alias (whois team, C); custom argparse
# upstream: https://github.com/rfc1036/whois

_whois-cli() {
    _arguments \
        '--help[show help]' \
        '-h+[server]:host:_hosts' \
        '--version[show version]' \
        '-V[show version]' \
        '-p+[port]:port:' \
        '-I[query IANA before regular server]' \
        '-H[hide legal disclaimers]' \
        '--verbose[verbose]' \
        '--no-recursion[no recursion]' \
        '-a[search all RIPE-like databases]' \
        '-b[brief output (IP allocations)]' \
        '-B[disable object filter (RIPE)]' \
        '-c+[country]:str:' \
        '-d[return DNS reverse delegation (RIPE)]' \
        '-i+[attribute]:str:' \
        '-K[only primary keys]' \
        '-l[one level less specific]' \
        '-L[all less specific]' \
        '-m[all 1-level more specific]' \
        '-M[all more specific]' \
        '-q+[query]:str:' \
        '-r[no recursion (RIPE)]' \
        '-R[force display from local copy]' \
        '-s+[source]:str:' \
        '-t+[type]:str:' \
        '-T+[types csv]:str:' \
        '-v+[type]:str:' \
        '-x[exact match]' \
        '*:object:'
}

_whois-cli "$@"
