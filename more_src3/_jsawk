#compdef jsawk
# Documentation: https://github.com/micha/jsawk
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jsawk (micha/jsawk)

local ret=1

_arguments -s -S \
  '(- *)-h[print help information and exit]' \
  '-i+[read JSON input from file instead of stdin]:file:_files' \
  '-s+[use string as JSON input instead of stdin]:json string:' \
  '-n[suppress printing of JSON result set]' \
  '-j+[path to the SpiderMonkey JavaScript binary]:command:_command_names' \
  '*-f+[load and run JavaScript file before processing]:file:_files' \
  '*-q+[filter JSON through a JSONQuery query]:query:' \
  '*-b+[script run before processing JSON (this = whole input)]:js:' \
  '*-a+[script run after processing JSON (this = whole input)]:js:' \
  '*-v+[assign a global variable (NAME=VALUE) in the script env]:name=value:' \
  '1::script:' && ret=0

return ret
