#compdef linkerd-policy-controller linkerd-policy
# Documentation: https://github.com/linkerd/linkerd2/blob/main/policy-controller/runtime/src/args.rs
# Reference accessed: 2026-05-19
# Verified: linkerd/linkerd2 policy-controller/runtime/src/args.rs (clap Args struct).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --addr/--metrics-addr/--controller-namespace/--kubeconfig/
# --trace-collector/--enable-h2-upgrade/--default-opaque-ports (not in this
# binary's clap parser).

# linkerd-policy-controller: control plane policy controller (Linkerd 2.x)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--log-level=[log filter directives (default linkerd=info,warn)]:filter:' \
  '--log-format=[log format]:fmt:(plain json)' \
  '--grpc-addr=[gRPC listen address (default 0.0.0.0:8090)]:addr:' \
  '--cluster-networks=[cluster CIDR networks]:cidrs:' \
  '--identity-domain=[identity trust domain (default cluster.local)]:domain:' \
  '--cluster-domain=[cluster domain (default cluster.local)]:domain:' \
  '--default-policy=[default policy]:policy:(all-unauthenticated all-authenticated deny cluster-authenticated cluster-unauthenticated audit)' \
  '--policy-deployment-name=[name of the policy deployment]:name:' \
  '--control-plane-namespace=[control plane namespace (default linkerd)]:ns:' \
  '--probe-networks=[networks from which probes originate]:cidrs:' \
  '--default-opaque-ports=[default opaque ports list]:list:' \
  '--patch-timeout-ms=[admission patch timeout in ms]:ms:' \
  '--allow-l5d-request-headers[allow l5d-* request headers]' \
  '--global-egress-network-namespace=[global egress network namespace]:ns:' \
  '--admission-controller-disabled[disable the admission controller]' && ret=0
return ret
