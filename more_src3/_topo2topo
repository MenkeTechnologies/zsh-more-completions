#compdef topo2topo
# _topo2topo — Vitess topology service migrator
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/topo2topo/cli/topo2topo.go on tip.

_topo2topo() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--from-implementation=[source topology implementation]:impl:(zk2 etcd2 consul k8s)' \
        '--from-server=[source topology server address]:host\:port:' \
        '--from-root=[source topology server root]:path:' \
        '--to-implementation=[target topology implementation]:impl:(zk2 etcd2 consul k8s)' \
        '--to-server=[target topology server address]:host\:port:' \
        '--to-root=[target topology server root]:path:' \
        '--compare=[compare data between source and target topologies]:bool:(true false)' \
        '--do-keyspaces=[copy keyspace data]:bool:(true false)' \
        '--do-shards=[copy shard data]:bool:(true false)' \
        '--do-shard-replications=[copy ShardReplication data]:bool:(true false)' \
        '--do-tablets=[copy tablet data]:bool:(true false)' \
        '--do-routing-rules=[copy routing rules]:bool:(true false)' \
        '-v[verbosity level]:n:'
}

_topo2topo "$@"
