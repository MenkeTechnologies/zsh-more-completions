#compdef longhorn-share-manager
# _longhorn-share-manager — Longhorn RWX NFS share manager (longhorn/longhorn-share-manager)
# upstream: https://github.com/longhorn/longhorn-share-manager
# Flags from main.go + app/cmd/server.go (urfave/cli v1) on tip.

_longhorn-share-manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--debug[enable debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the share-manager NFS server'
            )
            _describe -t commands 'longhorn-share-manager command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments \
                        '--volume=[Longhorn volume name to export]:name:' \
                        '--data-engine=[data engine type]:engine:(v1 v2)' \
                        '--encrypted[volume is encrypted]' \
                        '--passphrase=[encryption passphrase]:secret:' \
                        '--cryptokeycipher=[crypto key cipher]:cipher:' \
                        '--cryptokeyhash=[crypto key hash]:hash:' \
                        '--cryptokeysize=[crypto key size (bits)]:n:' \
                        '--cryptopbkdf=[PBKDF function]:pbkdf:'
                    ;;
            esac
            ;;
    esac
}

_longhorn-share-manager "$@"
