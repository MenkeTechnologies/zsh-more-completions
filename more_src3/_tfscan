#compdef tfscan
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/tfscan.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS tfscan: scan DNA for transcription factor binding sites
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' '-outfile=[output]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-menu=[TRANSFAC taxonomic class]:menu:(F I P V O C)' \
  '-custom=[Transfac database data file]:file:_files' \
  '-mismatch=[allowed mismatches]:n:' \
  '-minlength=[minimum motif length]:n:' \
  '*:DNA sequence:_files' && ret=0

return ret
