#compdef kubecolor
# Documentation: https://github.com/kubecolor/kubecolor/blob/main/command/config.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubecolor (colorized kubectl).
# kubecolor-specific flags are parsed by kubecolor; remaining args pass to kubectl.

_arguments -s -S \
  '--plain[disable colored output]' \
  '--light-background[switch to light theme (or dark with =false)]' \
  '--force-colors=[override automatic color support detection]:value:(true false auto)' \
  '(- *)--kubecolor-version[print the kubecolor version and exit]' \
  '--kubecolor-stdin=[read command input from stdin or file]:file:_files' \
  '--kubecolor-theme=[set kubecolor theme preset]:theme:' \
  '--pager=[set kubecolor pager]:pager:' \
  '--paging=[pipe kubecolor output into pager]:when:(auto never)' \
  '--no-paging[disable paging (alias to --paging=never)]' \
  '*::kubectl args:_kubectl' && return 0
