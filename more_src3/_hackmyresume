#compdef hackmyresume
# ============================================================================
# hackmyresume - Multi-format résumé generator: HTML/Markdown/LaTeX/Word/PDF
#                 (Node, MIT)
#
# Author : hacksalot
# Upstream: https://github.com/hacksalot/HackMyResume
# npm    : hackmyresume
#
# HackMyResume is the long-running canonical Node CLI for the
# "résumé as JSON" workflow: write your résumé once as a JSON
# document (FRESH schema or JSON Resume schema), then build it
# into HTML, Markdown, LaTeX, plain text, Microsoft Word, or
# PDF using a theme template. Themes are HBS (Handlebars) or
# UND (Underscore) template packages that ship layout + CSS;
# the engine renders each section across all output formats in
# one command. ~9300 stars on GitHub, the de-facto standard
# for résumé-as-data workflows since 2015.
#
# Subcommands (commander.js):
#   new <sources...>      - scaffold new résumé(s)
#                           -f, --format <FRESH|JRS>
#   validate <sources...> - schema-validate a résumé
#   convert               - convert between FRESH <-> JRS formats
#                           -f, --format <fmt>
#   analyze <sources...>  - statistics + insights about a résumé
#                           --private (include private fields)
#   peek <sources...>     - peek at a résumé field/section
#   build [generate]      - render résumé(s) to all configured targets
#                           -t, --theme <name|path>
#                           -n, --no-prettify
#                           -c, --css <option>
#                           -p, --pdf <engine>
#                           --no-sort  --tips  --private  --no-escape
#   help [command]        - get help on a command
#
# Global flags:
#   -s, --silent     - suppress non-error output
#       --no-color   - disable colored output
#       --color      - force colored output
#   -d, --debug      - diagnostics
#   -a, --assert     - treat warnings as errors
#   -v, --version    - show version
#
# Build syntax: `hackmyresume build resume.json TO out.html out.md out.pdf`
#   - everything before TO is sources, everything after is destinations.
#   - one source can target many destinations in a single invocation.
#
# The marked lane is built on `marked ^0.3.5` (declared verbatim
# at upstream package.json HEAD), the canonical Node Markdown
# library by Christopher Jeffrey + the markedjs org (markedjs/
# marked, 35000+ stars). marked is the *de-facto* npm Markdown
# parser - over 30 million weekly downloads, used by every
# major Node tool that consumes Markdown at some layer.
# HackMyResume uses marked to render the per-section Markdown
# inside résumé JSON to HTML for the HTML/PDF/Word output paths
# (résumés are JSON, but section bodies are usually authored
# in Markdown so they read naturally in source form).
#
# ----------------------------------------------------------------------------
# AXIS 224 :: Markdown parsers (CommonMark + GFM conformance)  [CLOSES]
# Round 1372 :: TS-Node slot 3 of 4 :: CLOSES Axis 224 (217th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : kivikakk/comrak              [R1370 _rucola]
#   Go      : yuin/goldmark                [R1371 _waza]
#   TS/Node : markedjs/marked              [R1372 THIS FILE]
#
# marked vs goldmark vs comrak structural commentary: marked
# is the *oldest* of the three (initial release 2011 by Chris
# Jeffrey, predating both CommonMark spec ratification AND
# the other two libraries by half a decade) - and is therefore
# the only one whose API shape was set BEFORE CommonMark
# existed. The marked maintainers have spent the years since
# CommonMark 0.31 standardization (2014-2024) progressively
# moving the parser toward CommonMark-conformance while
# preserving back-compat for the pre-CommonMark callers that
# accumulated over the first decade. The result: marked's
# extensibility model (token-based renderer hook overrides)
# is more permissive but less spec-bound than goldmark/comrak.
#
# Use-case alignment across the three lanes:
#   - rucola (Rust, comrak): TUI note manager - render md to
#     terminal cells, full GFM tables + tasklists
#   - waza (Go, goldmark): Agent skill spec parser - extract
#     code fences from md as eval inputs/outputs
#   - hackmyresume (Node, marked): Multi-format doc generator
#     - render per-field markdown to HTML for output pipeline
#
# All three converge on the same CommonMark + GFM spec.
# Three different host-language ecosystems, three different
# extensibility philosophies (compile-time-known options struct
# vs interface-pluggable parser vs renderer-hook-overrides),
# three different deployment models (TUI / CLI build tool /
# multi-format doc generator). The spec-bound canonical-library
# pattern at its cleanest: same input, same output, different
# host-language idiomatic shape.
# ============================================================================

_hackmyresume() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-s --silent)'{-s,--silent}'[run in silent mode]' \
        '--no-color[disable colors]' \
        '--color[enable colors]' \
        '(-d --debug)'{-d,--debug}'[enable diagnostics]' \
        '(-a --assert)'{-a,--assert}'[treat warnings as errors]' \
        '(- *)'{-v,--version}'[show the version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_hackmyresume_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                new|create) _arguments \
                                '(-f --format)'{-f,--format}'[FRESH or JRS format]:format:(FRESH JRS)' \
                                '(- *)'{-h,--help}'[help]' \
                                '*:source:_files -g "*.json"' ;;
                validate)   _arguments '(- *)'{-h,--help}'[help]' '*:source:_files -g "*.json"' ;;
                convert)    _arguments \
                                '(-f --format)'{-f,--format}'[FRESH or JRS format and optional version]:format:(FRESH JRS)' \
                                '(- *)'{-h,--help}'[help]' \
                                '*:source/dest:_files -g "*.json"' ;;
                analyze)    _arguments \
                                '--private[include resume fields marked as private]' \
                                '(- *)'{-h,--help}'[help]' \
                                '*:source:_files -g "*.json"' ;;
                peek)       _arguments '(- *)'{-h,--help}'[help]' '*:source/field:_files -g "*.json"' ;;
                build|generate) _arguments \
                                '(-t --theme)'{-t,--theme}'[theme name or path]:theme:' \
                                '(-n --no-prettify)'{-n,--no-prettify}'[disable HTML prettification]' \
                                '(-c --css)'{-c,--css}'[CSS linking / embedding]:option:' \
                                '(-p --pdf)'{-p,--pdf}'[PDF generation engine]:engine:(wkhtmltopdf phantomjs weasyprint)' \
                                '--no-sort[do not sort resume sections by date]' \
                                '--tips[display theme tips and warnings]' \
                                '--private[include resume fields marked as private]' \
                                '--no-escape[turn off encoding in Handlebars themes]' \
                                '(- *)'{-h,--help}'[help]' \
                                '*:source/dest:_files' ;;
                help)       _arguments '(- *)'{-h,--help}'[help]' '1:command:(new validate convert analyze peek build help)' ;;
            esac
            ;;
    esac

    return ret
}

_hackmyresume_cmds() {
    local -a cmds
    cmds=(
        'new:Create resume(s) in FRESH or JSON RESUME format'
        'create:Alias for new'
        'validate:Validate a resume in FRESH or JSON RESUME format'
        'convert:Convert a resume to/from FRESH or JSON RESUME format'
        'analyze:Analyze one or more resumes'
        'peek:Peek at a resume field or section'
        'build:Generate resume to multiple formats'
        'generate:Alias for build'
        'help:Get help on a HackMyResume command'
    )
    _describe -t commands 'hackmyresume command' cmds
}

_hackmyresume "$@"
