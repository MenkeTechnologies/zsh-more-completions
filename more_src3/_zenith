#compdef zenith
# Documentation: https://github.com/bvaisvil/zenith
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for zenith - System monitor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-c,--cpu-height}'[minimum height of CPU chart]:height:' \
  {-d,--disk-height}'[minimum height of disk chart]:height:' \
  {-n,--net-height}'[minimum height of network chart]:height:' \
  {-p,--process-height}'[minimum height of process chart]:height:' \
  {-g,--graphics-height}'[minimum height of GPU chart]:height:' \
  '--db[path to database file]:file:_files' \
  {-r,--refresh-rate}'[refresh rate in milliseconds]:rate:' \
  '--disable-history[disable history recording]' \
  && return 0
