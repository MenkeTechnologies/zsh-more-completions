#compdef sgitopnm
# Documentation: man sgitopnm (Netpbm)
# Source: convert an SGI image file to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-channel+[output only channel C]:c:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:sgi file:_files -g "*.(sgi|rgb|rgba|bw)"' \
    && ret=0

return ret
