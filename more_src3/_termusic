#compdef termusic
# Documentation: https://github.com/tramhao/termusic/blob/master/tui/src/cli.rs
# Reference accessed: 2026-05-21
# Verified: upstream cli.rs (v0.13.x).
# Flags: -c/--hide-cover, --disable-cover, -d/--disable-discord,
# -m/--max-depth, -b/--backend (rusty/mpv/gstreamer),
# --log-to-file, --log-file, --log-filecolor.
# Subcommands: export, import (OPML feeds).
# Removed from prior file: -C/--disable-discord (real short is -d),
# -c/--disable-album-art-from-cli (real long is --hide-cover),
# --music-directory flag (music_directory is a positional argument),
# backend choice "gst" (real is "gstreamer").

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'export:export podcast feeds to OPML file'
  'import:import podcast feeds from OPML file'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --hide-cover)'{-c,--hide-cover}'[disable album cover display]' \
  '--disable-cover[completely disable cover support]' \
  '(-d --disable-discord)'{-d,--disable-discord}'[disable Discord presence]' \
  '(-m --max-depth)'{-m+,--max-depth=}'[max folder scan depth (default 4)]:depth' \
  '(-b --backend)'{-b+,--backend=}'[audio backend]:backend:(rusty mpv gstreamer)' \
  '--log-to-file[enable file logging]' \
  '--log-file=[log file path]:file:_files' \
  '--log-filecolor[colored output in log file]' \
  '1: :->cmd_or_dir' \
  '*:: :->args' && ret=0

case $state in
  cmd_or_dir)
    _alternative \
      'subcommands:subcommand:(($subcommands))' \
      'dirs:music directory:_directories' && ret=0
    ;;
  args)
    case $line[1] in
      export|import) _arguments ':opml file:_files -g "*.opml"' && ret=0 ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac

return ret
