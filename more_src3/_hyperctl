#compdef hyperctl
# _hyperctl — hyperctl (hyperhq/hyperd HyperContainer engine CLI; subcommands: pod, run, list, info, version, stop, start, kill, exec, attach, logs, rm, image (pull/push/list/rm), pull, network (create/inspect/rm/connect/disconnect))
# upstream: https://github.com/hyperhq/hyperctl (legacy)
# Subcommands from hyperctl cmd/hyperctl on tip.

_hyperctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--host+[hyperd address]:host:_hosts' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'hyperctl command' '(pod run list info version stop start kill exec attach logs rm image pull network help)' ;;
        args)
            case $line[1] in
                image) _describe -t commands 'image subcommand' '(pull push list rm)' ;;
                network) _describe -t commands 'network subcommand' '(create inspect rm connect disconnect)' ;;
                run|exec|attach|logs|stop|start|kill|rm) _arguments '*:container or pod:' ;;
            esac
            ;;
    esac
}

_hyperctl "$@"
