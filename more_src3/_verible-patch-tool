#compdef verible-patch-tool
# Documentation: https://chipsalliance.github.io/verible/
# Source: chipsalliance/verible verible/common/tools/patch-tool.cc — unified-diff helper for line-range extraction and interactive hunk apply.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '--flagfile=[load flags from comma-separated files]:files:_files' \
    '--fromenv=[set flags from env (comma-separated)]:flags:' \
    '--tryfromenv=[try to set flags from env if present]:flags:' \
    '--undefok=[flag names ok to specify on CLI]:flags:' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'changed-lines:process unified-diff and emit filenames + changed line ranges'
            'apply-pick:interactively select hunks from a patch and apply them in-place'
            'stdin-test:interactive test util — prompts for input, separates with EOF'
            'cat-test:UNIX cat clone with banner lines (test utility)'
        )
        _describe -t subcmds 'subcommand' subcmds && ret=0
        ;;
    args)
        _files && ret=0
        ;;
esac

return ret
