#compdef lmnr
# Documentation: https://github.com/lmnr-ai/lmnr
# Reference accessed: 2026-05-23
# Verified: lmnr --help (Laminar observability CLI on PyPI).

# Zsh completion for lmnr - Laminar (Lmnr) eval and dataset CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'lmnr command' \
      'eval[run an evaluation]' \
      'dev[start debugger session]' \
      'discover[discover entrypoint metadata]' \
      'add-cursor-rules[add laminar.mdc to .cursor/rules]' \
      'datasets[manage datasets]' && ret=0
    ;;
  args)
    case $line[1] in
      eval)
        _arguments -C \
          '--continue-on-error[continue on errors]' \
          '--output-file[write JSON results]:file:_files' \
          '--frontend-port[local frontend port]:port:' \
          '*:eval file:_files -g "*_eval.py eval_*.py"' && ret=0
        ;;
    esac
    ;;
esac

return ret
