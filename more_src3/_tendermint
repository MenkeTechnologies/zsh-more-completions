#compdef tendermint
# Documentation: https://docs.tendermint.com/v0.34/tendermint-core/using-tendermint.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cmd/tendermint/main.go subcommands).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--home=[Node home directory]:directory:_directories' \
  '--log_level=[Log level filter]:level:' \
  '--log_format=[Log format]:format:(plain json)' \
  '--trace[Dump INFO logs to STDERR]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:Initialize configuration files'
      'node:Run the Tendermint node'
      'gen_validator:Generate a new validator key'
      'gen_node_key:Generate a new node key'
      'show_validator:Show this node validator info'
      'show_node_id:Show this node ID'
      'testnet:Initialize files for a testnet'
      'unsafe_reset_all:Reset blockchain and validator state'
      'unsafe_reset_priv_validator:Reset private validator state'
      'replay:Replay messages from WAL'
      'replay_console:Replay messages from WAL in console mode'
      'light:Run light client'
      'reindex-event:Reindex events to event sinks'
      'rollback:Rollback to previous state'
      'version:Print version'
      'completion:Generate shell completion'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
