#compdef sndfile-mix-to-mono
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/sndfile-mix-to-mono.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu trusty sndfile-mix-to-mono(1) manpage. No CLI
# flags; usage is `sndfile-mix-to-mono <input> <mono-output>`.
# Format determined by output extension.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# sndfile-mix-to-mono: mix multi-channel audio down to mono
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:input file:_files' \
  '2:mono output file:_files' && ret=0
return ret
