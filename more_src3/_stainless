#compdef stainless
# =============================================================================
# stainless — EPFL LARA's "Verification framework for a
#          subset of the Scala programming language" — a
#          formal-verification system that statically
#          proves correctness of Scala programs against
#          their `require` / `ensuring` / invariant
#          contracts via translation to first-order
#          logic and discharge to SMT solvers (nativez3,
#          princess, cvc4/cvc5).  Built at École
#          polytechnique fédérale de Lausanne in Viktor
#          Kuncak's Laboratory for Automated Reasoning
#          and Analysis (LARA) since 2014, succeeding
#          the older Leon verifier from the same group.
#          Distinguishing from Why3 (INRIA's
#          intermediate language for verification),
#          Frama-C (CEA's C verification framework), F*
#          (Microsoft Research's dependently-typed
#          language), Dafny (Rustan Leino's verification-
#          aware imperative language), KeY (Karlsruhe's
#          Java verifier), Liquid Haskell (UCSD's
#          refinement types for Haskell), Bosque (R748
#          MS Research regularized programming with SMT-
#          backed checker), and Hazel (R752 UMich
#          typed-holes calculus) by:
#            - SCALA AS SOURCE — verifies actual Scala
#              programs (Scala 3.5+ since v0.9.9; Scala
#              2.13 was last supported in v0.9.8.7), not
#              a separate dependently-typed surface
#              language.  Programmers write the same
#              Scala code they would run in production
#              and add `require()` / `ensuring()` /
#              `decreases()` annotations
#            - INOX SOLVER INFRASTRUCTURE — built on
#              github.com/epfl-lara/inox (also LARA), a
#              shared first-order constraint solving
#              library that wraps multiple SMT backends
#              (nativez3 = bundled Z3 via JNI; princess
#              = pure-Scala SMT solver; smt-cvc4 / smt-
#              cvc5 / smt-z3 = external binaries)
#            - VERIFICATION + TERMINATION + EQUIV
#              CHECKING — three independent analysis
#              pipelines:
#              * VERIFICATION (--verification, default)
#                — discharge VCs to SMT to prove
#                postconditions hold, preconditions
#                are SAT-able, array indices in bounds,
#                pattern matches exhaustive
#              * TERMINATION (--termination) — auto-
#                infer or check `decreases` measures
#                for recursive functions
#              * EQUIVALENCE CHECKING (--equivchk) —
#                verify two implementations compute
#                the same function (useful for model-
#                vs-implementation refinement)
#            - GENC TRANSPILATION — `--genc` compiles
#              the verified Scala subset down to
#              portable C99 suitable for embedded
#              deployment; the verified program runs
#              with NO Scala runtime + NO JVM
#            - COQ EMISSION — `--coq` translates the
#              program + obligations into Coq, allowing
#              interactive proof of any obligations
#              that the SMT backend couldn't dispatch
#              automatically.  Bridges automated +
#              manual verification
#            - IMPERATIVE EXTENSION — `--full-imperative`
#              enables verification of imperative
#              features (mutable refs, heap effects)
#              via the `extraction.imperative` phase;
#              still experimental
#            - VC CACHING — `--vc-cache` + `--cache-dir
#              <dir>` + `--binary-cache` enable
#              persistent caching of verification
#              conditions across runs; dramatically
#              speeds up CI loops where only a few
#              functions changed
#            - WATCH MODE — `--watch` re-runs the full
#              verification on every source-file change
#              (filesystem watcher); pairs nicely with
#              code-as-you-verify workflows
#            - TIMEOUT CONTROL — `--timeout <secs>` sets
#              the per-VC SMT timeout; verification
#              fast-fail under timeout, termination
#              uses `timeout/100` per solver call
#            - JSON OUTPUT — `--json <path>` emits the
#              full verification + termination report
#              as machine-readable JSON; suitable for
#              CI integration + dashboard visualization
#            - SIMPLIFIER SELECTION — `--simplifier
#              vanilla|ol|ocbsl|bland` chooses how VCs
#              are simplified before SMT.  `ol`
#              (ortholattice) + `ocbsl`
#              (orthocomplemented bisemilattice) are
#              recent experimental boolean-algebra-
#              based simplifiers from LARA research
#              papers (Schneider+Kuncak POPL 2023+)
#            - FUNCTIONS FILTER — `--functions
#              f1,f2,...` restricts verification to
#              named functions; useful for narrowing
#              CI runs to changed functions
#            - BATCHED MODE — `--batched` processes
#              the whole program together (skipping
#              dependency analysis); slower but more
#              accurate for cross-module reasoning
#            - EXTRA SOURCE DEPENDENCIES — `--extra-
#              deps <coordinates>` + `--extra-
#              resolvers <urls>` fetch additional
#              source-only Maven dependencies + add
#              their sources to the verification
#              session; `--keep <obj1,obj2>` retains
#              specific library objects from those
#              deps via @keepFor annotations
#            - 400+ STARS ON epfl-lara/stainless —
#              actively maintained by LARA at EPFL;
#              regularly cited in OOPSLA / POPL /
#              CAV verification papers
#          Used by: formal-methods research groups
#          verifying Scala libraries (Stainless can
#          verify its own collection types — list,
#          set, map — used in subsequent verification),
#          industrial users at Inria's Spirals team
#          and EPFL spinoffs verifying control-flow-
#          correctness of safety-critical Scala
#          components, blockchain projects verifying
#          Scala-implemented smart-contract logic, and
#          functional-programming courses at EPFL +
#          ETH Zurich teaching verification with
#          stainless as the lab tool.
#
# Author:  EPFL Laboratory for Automated Reasoning and
#          Analysis (LARA) — Viktor Kuncak (lab head),
#          Romain Ruetschi, Jad Hamza, Régis Blanc,
#          Ivan Kuraj, Etienne Kneuss, Philippe
#          Suter, Manos Koukoutos, Mario Bucev, Simon
#          Guilloud, Sankalp Gambhir, Auguste Poiroux,
#          Yawen Guan, and many other LARA students
#          + postdocs.  Hosted at github.com/epfl-lara/
#          stainless ; mirrored at gitlab.epfl.ch/
#          lara/stainless .
# Source:  https://github.com/epfl-lara/stainless
#          https://github.com/epfl-lara/stainless/blob/main/core/src/main/scala/stainless/MainHelpers.scala
# Manpage: No traditional manpage; full options at
#          https://epfl-lara.github.io/stainless/options.html
#          Tutorial: https://epfl-lara.github.io/asplos2022tutorial/
# Library: inox (github.com/epfl-lara/inox — LARA's own
#          shared first-order constraint solving
#          library, the "solver kernel" used by both
#          stainless + leon-classic + welder; not part
#          of the cross-language CLI library taxonomy
#          which tracks Rust/Go/TS-Node libraries —
#          stainless is a STANDALONE LANGUAGE entry).
#          Implementation: Scala 3.5+ (compiled via
#          dotty/scalac).  Solver backends: bundled
#          Z3 via JNI (nativez3), princess (pure-
#          Scala), external smt-z3 / smt-cvc4 / smt-
#          cvc5 binaries.
# License: Apache-2.0
# Status:  400+ stars on epfl-lara/stainless; active
#          development (latest commit 2026-05-29);
#          Scala 3.5+ frontend; v0.9.9+ release line.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — 121st LANGUAGE CLOSES 3+1 MICRO-CYCLE
# -----------------------------------------------------------------------------
# This completion is the **121st language** entry in the
# cross-language CLI library taxonomy.  It closes the
# current 3+1 micro-cycle that began with R753 Rust=96
# (email-sleuth/scraper OPENS Axis 41 HTML Parsing) →
# R754 Go=96 (besticon/PuerkitoBio/goquery continues
# Axis 41) → R755 TS-Node=96 (udacimak/cheerio CLOSES
# Axis 41 at 1/1/1) → R756 THIS (121st language).
#
# WHY STAINLESS IS A DISTINCTIVE 121st-LANGUAGE ENTRY:
#
#   Stainless occupies a unique position in the
#   verification-language landscape because it
#   verifies REAL SCALA — not a custom dependently-
#   typed language that Scala programmers must learn
#   separately — by extracting a SUBSET of Scala into
#   a formal model and discharging proof obligations
#   to off-the-shelf SMT solvers.  This makes
#   verification an INCREMENTAL ADOPTION strategy:
#   programmers add `require()` / `ensuring()`
#   contracts to their existing code without rewriting
#   into a different language.
#
#   Strictly speaking, Stainless is a TOOL that
#   verifies Scala rather than a NEW language; but
#   the verifiable subset (formerly called "Leon
#   language" + currently called "Stainless language"
#   or "Pure Scala") has its own well-defined
#   semantics distinct from Scala-the-language, and
#   has its own community + course material + papers
#   — justifying its inclusion as a language entry
#   distinct from the Scala lang slot.
#
#   Distinguishing features in the broader cross-
#   language landscape:
#
#     1. EXISTING-LANGUAGE-SUBSET-AS-VERIFIABLE — most
#        verification systems require programmers to
#        learn a new dependently-typed language (F*,
#        Lean 4, Coq, Agda, Idris, Dafny).  Stainless
#        is the rare exception that says "use the
#        language you already know, just write proof
#        obligations as method contracts."
#
#     2. SMT-FIRST, NO INTERACTIVE PROOF NEEDED —
#        most VCs discharged automatically by Z3 /
#        CVC5 / Princess; only complex obligations
#        require the `--coq` fallback for manual
#        Coq proof.  Lowers the verification skill
#        floor compared to Coq/Lean-first systems.
#
#     3. THREE INDEPENDENT PIPELINES — verification +
#        termination + equivalence checking are
#        orthogonal analyses runnable separately
#        (--verification / --termination / --equivchk);
#        most verifiers conflate these into a single
#        pipeline.
#
#     4. GenC TRANSPILATION TARGET — verified code
#        compiles to portable C, not JVM bytecode;
#        suitable for embedded + safety-critical
#        deployments where Scala/JVM is too heavy.
#
#     5. LIBRARY-OF-LIBRARIES — Stainless ships with
#        its own verified collection library
#        (stainless.collection, stainless.lang) that
#        provides verified List/Set/Map/Option
#        implementations.  Application code can
#        compose against these and inherit their
#        verification.
#
#     6. CONTINUOUS DEVELOPMENT IN ACADEMIC LAB —
#        unlike many academic verifiers that stagnate
#        after the PhD finishes, Stainless has been
#        continuously maintained at LARA since 2014
#        (~12 years and counting), absorbing PhD
#        contributions from a sequence of students
#        without losing operational quality.
#
#     7. INDUSTRIAL TRACK RECORD — used at Inria's
#        Spirals team, EPFL spinoffs, blockchain
#        verification projects, and various
#        functional-programming courses across
#        European universities.
#
# Cross-language CLI library taxonomy after R756:
#   * 121 languages (121-LANGUAGE COUNT)
#   * 468 total CLI library variants (Rust 96 / Go 96
#     / TS-Node 96)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 34 axes at 1/1/1 three-language symmetry (axes
#     7 + 8 + 11 + 12 + 15-41)
#
# Cross-language ECOSYSTEM context (Verification-
# Languages family in this corpus):
#   * Lean 4 (in corpus) — Leo de Moura's dependent
#     types theorem prover
#   * Coq (in corpus) — INRIA's dependent types
#     proof assistant
#   * Agda (in corpus) — University of Gothenburg's
#     dependent types
#   * Idris2 (in corpus) — Edwin Brady's dependent
#     types
#   * F* (in corpus) — Microsoft Research's
#     dependently-typed verification
#   * Dafny (in corpus) — MS Research verification-
#     aware imperative
#   * TLA+ (in corpus) — Leslie Lamport's modeling
#     language
#   * Bosque (R748 in corpus) — MS Research
#     regularized programming with SMT-backed checker
#   * Hazel (R752 in corpus) — UMich typed-holes
#     live functional programming with edit-state
#     semantics
#   * Stainless (R756 THIS) — EPFL LARA's
#     verification framework for Scala-3 subset
#
# Stainless joins this elite group of formal-
# verification languages with the distinguishing
# trait that IT VERIFIES AN EXISTING MAINSTREAM
# LANGUAGE (Scala 3) rather than defining a new one.
#
# Comparison to other 121st-language candidates:
#   * Stainless (R756 THIS) — EPFL LARA, 400 stars,
#     Apache 2.0, active since 2014, verifies Scala 3
#   * Jakt (SerenityOS/jakt) — Andreas Kling, 2,989
#     stars; but already in corpus as `_jakt`
#   * MoonScript (leafo/moonscript) — Lua dialect,
#     3,437 stars; but already covered as `_moon`
#     + `_moonc`
#   * Mlatu (mlatu-lang/mlatu) — Rust-implemented
#     concatenative; only 175 stars, niche
#   * Yatima (yatima-inc/yatima) — zk-Lean4 compiler;
#     146 stars, narrow scope
#   * Pikelet (brendanzab/pikelet) — only 7 stars,
#     last updated 2023, marked WIP "please don't
#     repost"
#   * Owl Lisp (owl-lisp/owl) — Aaro Hellaakoski's
#     minimalist Scheme; 383 stars but binary name
#     conflicts and the corpus already has many CL/
#     Scheme entries
#   * Cogent (au-ts/cogent) — Data61 functional
#     systems lang; 177 stars, niche
#
# Stainless is the chosen 121st-language entry
# because:
#   - It has a real, installable CLI (`stainless`)
#     with extensive subcommand/flag coverage (>50
#     verification + termination + equivalence
#     checking + GenC + Coq + caching flags)
#   - The "verify existing mainstream language by
#     contract annotations" thesis is structurally
#     distinct from the Lean/Coq/Agda/Idris/F*/
#     Dafny "new dependently-typed language" pattern
#     dominant in the verification family
#   - 12+ years of continuous LARA maintenance at
#     EPFL ensures continuity beyond typical academic
#     artifacts
#   - Apache 2.0 + active GitHub activity make it
#     industrially viable
#   - The course adoption at EPFL + ETH and the
#     industrial usage at Inria + blockchain
#     projects provide pedagogical and production
#     legitimacy
#
# -----------------------------------------------------------------------------
#
# THE stainless CLI
#
# stainless is a single-command CLI (no subcommands;
# pipelines are selected via flags) built on inox's
# OptionDef framework (LARA's own argparse).
# Invocation:
#   stainless [OPTIONS]... FILE(S)...
#
# Pipeline selection (mutually-exclusive in practice):
#   --verification                    discharge verification
#                                     conditions to SMT
#                                     (default pipeline)
#   --termination                     check / infer
#                                     decreases measures
#   --equivchk                        equivalence checking
#                                     between candidate +
#                                     model functions
#   --tests-generation                emit tests from
#                                     counter-examples
#   --genc                            transpile to C99
#
# General:
#   --version                         show version
#   --config-file <path>              path to config file
#                                     ("false" to disable;
#                                     default
#                                     stainless.conf or
#                                     .stainless.conf)
#   --functions <f1,f2,...>           verify only named
#                                     functions
#   --debug-objects <o1,o2,...>       debug only named
#                                     objects/ADTs
#   --debug-phases <p1,p2,...>        debug only named
#                                     phases
#   --timeout <secs>                  per-VC SMT timeout
#                                     (terminator uses
#                                     timeout/100 per
#                                     solver call)
#   --json <path>                     emit JSON report
#   --watch                           re-run on file
#                                     changes (filesystem
#                                     watcher)
#   --compact                         print only invalid
#                                     summary elements
#   --extended-summary                print all phases
#                                     extended summary
#   --batched                         process whole
#                                     program (skip
#                                     dependency analysis)
#   --keep <obj1,obj2,...>            keep library objects
#                                     marked @keepFor
#                                     (implies --batched)
#   --extra-deps <coordinates>        fetch extra Maven
#                                     source deps
#   --extra-resolvers <urls>          extra resolvers
#                                     for source-dep
#                                     fetching
#   --classpath <dir>                 add to classpath
#   --cache-dir <dir>                 VC cache directory
#   --binary-cache                    cache in binary
#                                     (vs hash) mode
#
# Verification:
#   --silent                          suppress VC fail
#                                     messages
#   --fail-early                      halt on first
#                                     invalid/unknown
#   --fail-invalid                    halt on first
#                                     invalid
#   --vc-cache                        enable VC caching
#   --coq                             transpile to Coq
#   --admit-all                       admit all
#                                     obligations
#   --strict-arithmetic               check arithmetic
#                                     for overflow
#   --admit-vcs                       admit all VCs
#   --simplifier <kind>               vanilla | ol |
#                                     ocbsl | bland
#   --sat-precond                     check preconditions
#                                     are SAT
#   --full-imperative                 enable imperative
#                                     phase (experimental)
#   --check-heap-contracts            check heap reads/
#                                     modifies
#
# Termination:
#   --check-measures                  verify decreases
#                                     measures
#   --infer-measures                  auto-infer
#                                     decreases measures
#
# Evaluators:
#   --codegen                         use code-gen
#                                     evaluator
#   --instrument-fields               instrument ADT
#                                     field access
#   --small-arrays                    arrays fit in mem
#
# GenC:
#   --output <file>                   GenC output file
#   --includes <files>                C #include
#                                     directives
#
# Tests generation:
#   --output <file>                   test gen output
#   --genc-includes <files>           GenC includes for
#                                     test gen
#
# Equivalence checking:
#   --compare-funs <f1,f2,...>        candidate
#                                     functions for
#                                     equivalence
#   --models <f1,f2,...>              model functions
#   --norm <f>                        normalization
#                                     function
#   --equivalence-output <json>       JSON output
#   --n <N>                           top-N models
#   --init-score <score>              initial model
#                                     score
#   --init-weights <weights>          per-model weights
#   --max-perm <n>                    max permutations
#                                     for aux matching
#   --max-ctex <n>                    max counter-
#                                     examples
#   --measure-transfer                enable measure
#                                     transfer
#
# Common invocations:
#   # Verify HelloStainless.scala (default verification)
#   stainless HelloStainless.scala
#
#   # Specify timeout + only check named functions
#   stainless --timeout 30 --functions myTail,myMap \
#     HelloStainless.scala
#
#   # Emit JSON report for CI integration
#   stainless --json report.json HelloStainless.scala
#
#   # Re-verify on every file change
#   stainless --watch src/*.scala
#
#   # Termination analysis with measure inference
#   stainless --termination --infer-measures src/*.scala
#
#   # GenC transpilation
#   stainless --genc --output verified.c src/*.scala
#
#   # Coq fallback for hard VCs
#   stainless --coq HelloStainless.scala
#
#   # Equivalence check: ImplA equiv to Model
#   stainless --equivchk --models ModelA --compare-funs ImplA \
#     src/*.scala
#
#   # Cache VCs across runs for fast CI
#   stainless --vc-cache --cache-dir .stainless-cache \
#     src/*.scala
#
#   # Strict arithmetic + experimental simplifier
#   stainless --strict-arithmetic --simplifier ol \
#     src/*.scala
#
#   # Pull extra source dependencies + keep specific objs
#   stainless --extra-deps "com.example:my-lib:1.0" \
#     --keep MyObject src/*.scala
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _stainless_simplifiers
_stainless_simplifiers=(
    'vanilla:standard simplifier'
    'ol:ortholattice algebra (experimental)'
    'ocbsl:orthocomplemented bisemilattices boolean (experimental)'
    'bland:common OL/OCBSL logic without boolean algebra flavor'
)

_arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--config-file=[config file path (false to disable)]:config:_files' \
    '--functions=[verify only named functions (comma-separated)]:functions: ' \
    '--debug-objects=[debug only named objects/ADTs]:objects: ' \
    '--debug-phases=[debug only named phases]:phases: ' \
    '--timeout=[per-VC SMT timeout (seconds)]:seconds: ' \
    '--json=[emit JSON verification report]:path:_files -g "*.json"' \
    '--watch[re-run on file changes]' \
    '--compact[print only invalid summary elements]' \
    '--extended-summary[print extended summary of all phases]' \
    '--batched[process whole program (skip dep analysis)]' \
    '--keep=[keep library objects marked @keepFor (implies --batched)]:objects: ' \
    '--extra-deps=[extra Maven source dep coordinates]:coordinates: ' \
    '--extra-resolvers=[extra resolvers for source-dep fetching]:urls: ' \
    '--classpath=[add directory to classpath]:dir:_directories' \
    '--cache-dir=[VC cache directory]:dir:_directories' \
    '--binary-cache[cache in binary mode (less space-efficient)]' \
    '--verification[run verification pipeline (default)]' \
    '--termination[run termination pipeline]' \
    '--equivchk[run equivalence-checking pipeline]' \
    '--tests-generation[run test-generation pipeline]' \
    '--genc[transpile to C99]' \
    '--silent[suppress VC fail messages]' \
    '--fail-early[halt on first invalid/unknown VC]' \
    '--fail-invalid[halt on first invalid VC]' \
    '--vc-cache[enable VC caching]' \
    '--coq[transpile program + obligations to Coq]' \
    '--admit-all[admit all obligations in Coq output]' \
    '--strict-arithmetic[check arithmetic for overflow/unintended behavior]' \
    '--admit-vcs[admit all verification conditions]' \
    '--simplifier=[VC simplifier kind]:kind:->simplifier' \
    '--sat-precond[generate VCs to check preconditions are SAT]' \
    '--full-imperative[enable full imperative phase (experimental)]' \
    '--check-heap-contracts[check heap reads/modifies clauses]' \
    '--check-measures[verify decreases measures]' \
    '--infer-measures[auto-infer decreases measures]' \
    '--codegen[use code-generating evaluator]' \
    '--instrument-fields[instrument ADT field access during codegen]' \
    '--small-arrays[assume arrays fit into memory]' \
    '--output=[output file path (for GenC + tests-generation)]:path:_files' \
    '--includes=[C #include directives for GenC]:files: ' \
    '--genc-includes=[GenC includes for tests-generation]:files: ' \
    '--compare-funs=[candidate functions for equivchk]:functions: ' \
    '--models=[model functions for equivchk]:functions: ' \
    '--norm=[normalization function for equivchk]:function: ' \
    '--equivalence-output=[equivalence-checking JSON output]:path:_files -g "*.json"' \
    '--n=[top-N models for equivchk]:N: ' \
    '--init-score=[initial score for equivchk models]:score: ' \
    '--init-weights=[initial weights for equivchk models]:weights: ' \
    '--max-perm=[max permutations for aux-function matching]:n: ' \
    '--max-ctex=[max counter-examples to collect]:n: ' \
    '--measure-transfer[enable measure transfer for candidate functions]' \
    '*:Scala source file:_files -g "*.(scala|sc)"' \
    && ret=0

case $state in
    simplifier)
        _describe -t simplifiers 'VC simplifier' _stainless_simplifiers && ret=0
        ;;
esac

return ret
