#compdef lazbuild
# Documentation: https://wiki.freepascal.org/lazbuild
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-q,--quiet}'[reduce verbosity (repeatable)]' \
  '*--verbose[increase verbosity (repeatable)]' \
  '--verbose-pkgsearch[display package file search details]' \
  '(-B --build-all)'{-B,--build-all}'[build all files of project/package]' \
  '(-r --recursive)'{-r,--recursive}'[apply build flags to dependencies]' \
  '(-d --skip-dependencies)'{-d,--skip-dependencies}'[do not compile dependencies]' \
  '--add-package[add packages to IDE installation list]' \
  '--add-package-link=+[register a Lazarus package link]:file:_files -g "*.lpk"' \
  '--build-mode=+[override project build mode]:mode:' \
  '--bm=+[override project build mode]:mode:' \
  '--build-ide=+[compile the Lazarus IDE with options]:flags:' \
  '--compiler=+[override default compiler (ppcXXX)]:file:_command_names' \
  '--cpu=+[override target CPU]:cpu:(i386 x86_64 arm aarch64 powerpc powerpc64 sparc mips)' \
  '--subtarget=+[override project subtarget]:subtarget:' \
  '--create-makefile[generate makefile instead of compiling]' \
  '--language=+[override language]:lang:' \
  '--lazarusdir=+[base directory for Lazarus]:dir:_files -/' \
  '--max-process-count=+[max parallel compilation threads]:n:' \
  '--no-write-project[skip updating project info file]' \
  '--operating-system=+[override target OS]:os:(linux win32 win64 darwin freebsd netbsd openbsd haiku)' \
  '--os=+[override target OS]:os:' \
  '--primary-config-path=+[primary config dir]:dir:_files -/' \
  '--pcp=+[primary config dir]:dir:_files -/' \
  '--secondary-config-path=+[secondary config dir]:dir:_files -/' \
  '--scp=+[secondary config dir]:dir:_files -/' \
  '--ws=+[override widget set]:ws:(gtk gtk2 gtk3 qt qt5 qt6 win32 carbon cocoa fpgui customdrawn)' \
  '--widgetset=+[override widget set]:ws:' \
  '*:project:_files -g "*.{lpi,lpk}"' && ret=0

return ret
