#compdef inkview
# Documentation: https://inkscape.org/doc/inkscape-man.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen mode]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
  '(-t --timer)'{-t,--timer}'+[slide timer sec]:sec:' \
  '(-s --scale)'{-s,--scale}'+[zoom scale]:scale:' \
  '(-p --preload)'{-p,--preload}'[preload all images]' \
  '*:svg file:_files -g "*.{svg,svgz}"' && ret=0

return ret
