#compdef vtexplain
# _vtexplain — Vitess query plan explainer
# upstream: https://github.com/vitessio/vitess
# Flags from go/cmd/vtexplain/cli/vtexplain.go on tip.

_vtexplain() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--sql=[semicolon-delimited SQL to analyze]:sql:' \
        '--sql-file=[file containing SQL commands]:file:_files' \
        '--schema=[SQL table schema]:schema:' \
        '--schema-file=[file containing SQL schema]:file:_files' \
        '--vschema=[VTGate routing schema]:vschema:' \
        '--vschema-file=[VTGate routing schema file]:file:_files' \
        '--ks-shard-map=[JSON keyspace->shard map]:json:' \
        '--ks-shard-map-file=[file with keyspace->shard map JSON]:file:_files' \
        '--replication-mode=[replication mode to simulate]:mode:(ROW STATEMENT)' \
        '--normalize=[enable VTGate normalization]:bool:(true false)' \
        '--dbname=[optional database routing override]:name:' \
        '--planner-version=[default planner]:planner:(Gen4 Gen4Greedy Gen4Left2Right)' \
        '--shards=[number of shards per keyspace]:n:' \
        '--execution-mode=[execution mode]:mode:(multi legacy-autocommit twopc)' \
        '--output-mode=[output format]:mode:(text json)' \
        '-v[verbosity level]:n:'
}

_vtexplain "$@"
