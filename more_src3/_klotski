#compdef klotski
# Documentation: https://apps.kde.org/klotski/
# Reference accessed: 2026-05-19
# Verified: invent.kde.org/games/klotski source is behind a login wall;
# the canonical project page (URL above) and verified sibling KDE games
# use only KAboutData::setupCommandLine + QCommandLineParser standard
# set. Conservatively listing the documented Qt+KAboutData standard flags.
# Removed from prior file: --help-qt, --help-kde (KDE3/4-era, not KF6).
# STUB: KDE/Qt standard options only.

# Klotski: KDE sliding-block puzzle
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[load specified desktop file]:file:_files -g "*.desktop"' && ret=0
return ret
