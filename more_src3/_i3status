#compdef i3status
# Documentation: https://i3wm.org/i3status/manpage.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# i3status: status bar generator for i3bar, dzen2, xmobar, lemonbar.

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-c+[specify config file]:config file:_files'
