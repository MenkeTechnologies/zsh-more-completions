#compdef jupyter-labextension
# Documentation: https://github.com/jupyterlab/jupyterlab/blob/main/jupyterlab/labextensions.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: added real link/unlink/watch subcommands;
# replaced fabricated --development/--source-map/--debug flags with the
# real --dev-build/--no-minimize/--clean/--splice-source/--app-dir/
# --debug-log-path; added --installed (check) and --verbose (list).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
    'install:Install labextension(s)'
    'update:Update labextension(s)'
    'uninstall:Uninstall labextension(s)'
    'list:List labextensions'
    'link:Link labextension(s)'
    'unlink:Unlink labextension(s)'
    'enable:Enable labextension(s)'
    'disable:Disable labextension(s)'
    'lock:Lock labextension(s)'
    'unlock:Unlock labextension(s)'
    'check:Check labextension(s)'
    'build:(deprecated) Build labextension'
    'develop:(deprecated) Develop labextension'
    'watch:(deprecated) Watch labextension'
)

_arguments -s -S \
    '1:subcommand:->subcmd' \
    '*::options:->options' && ret=0

case $state in
    subcmd)
        _describe -t commands 'jupyter-labextension subcommand' subcmds && ret=0
        ;;
    options)
        case $words[1] in
            install)
                _arguments \
                    '--no-build[Defer building the application after the action]' \
                    '--dev-build[Build in development mode]' \
                    '--no-minimize[Do not minimize a production build]' \
                    '--clean[Cleanup intermediate files after the action]' \
                    '--splice-source[Splice source packages into app directory]' \
                    '--pin-version-as=[Pin this version with a certain alias]:alias' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '--debug-log-path=[Path to use for the debug log]:file:_files' \
                    '*:extension'
                ;;
            develop)
                _arguments \
                    '--overwrite[Overwrite files if they exist]' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '*:extension'
                ;;
            build)
                _arguments \
                    '--no-minimize[Do not minimize a production build]' \
                    '--dev-build[Build in development mode]' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '--debug-log-path=[Path to use for the debug log]:file:_files'
                ;;
            uninstall)
                _arguments \
                    '--no-build[Defer building the application after the action]' \
                    '--all[Uninstall all extensions]' \
                    '--clean[Cleanup intermediate files after the action]' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '*:extension'
                ;;
            list)
                _arguments \
                    '--verbose[Verbose output]' \
                    '--app-dir=[The app directory to target]:directory:_directories'
                ;;
            enable|disable|lock|unlock|link|unlink)
                _arguments \
                    '--level=[The level to enable/disable at]:level:(user sys_prefix system)' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '*:extension'
                ;;
            update)
                _arguments \
                    '--all[Update all extensions]' \
                    '--no-build[Defer building the application after the action]' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '*:extension'
                ;;
            check)
                _arguments \
                    '--installed[Check if an extension is installed]' \
                    '--app-dir=[The app directory to target]:directory:_directories' \
                    '*:extension'
                ;;
            watch)
                _arguments \
                    '--app-dir=[The app directory to target]:directory:_directories'
                ;;
        esac
        ;;
esac

return ret
