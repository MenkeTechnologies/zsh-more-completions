#compdef html-minifier html-minifier-terser
# Documentation: https://github.com/kangax/html-minifier
# Source: kangax/html-minifier — HTML minifier CLI (shares config with html-minifier-terser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files' \
    '(-c --config-file)'{-c+,--config-file=}'[JSON config file]:file:_files' \
    '(--input-dir --output-dir)--input-dir=[input directory]:dir:_directories' \
    '(--input-dir --output-dir)--output-dir=[output directory]:dir:_directories' \
    '*--file-ext=[file extensions to process]:ext:' \
    '--case-sensitive[case-sensitive attribute names]' \
    '--collapse-boolean-attributes[omit boolean attribute values]' \
    '--collapse-inline-tag-whitespace[no spaces between inline elements when collapsing]' \
    '--collapse-whitespace[collapse text-node whitespace]' \
    '--conservative-collapse[always collapse to 1 space, never remove]' \
    '--continue-on-parse-error[handle parse errors instead of aborting]' \
    '*--custom-attr-assign=[regex for custom attribute assignment]:regex:' \
    '--custom-attr-collapse=[regex for custom attributes to strip newlines from]:regex:' \
    '*--custom-attr-surround=[regex for custom attribute surround]:regex:' \
    '--decode-entities[use direct Unicode characters where possible]' \
    '--html5[parse input per HTML5 spec]' \
    '*--ignore-custom-comments=[regex for comments to ignore]:regex:' \
    '*--ignore-custom-fragments=[regex for fragments to ignore]:regex:' \
    '--include-auto-generated-tags[insert tags generated by parser]' \
    '--keep-closing-slash[keep trailing slash on void elements]' \
    '--max-line-length=[max line length for output]:n:' \
    '--minify-css=-[minify CSS in <style>/style="..."]:opts:' \
    '--minify-js=-[minify JS in <script>/event attrs]:opts:' \
    '--minify-urls=-[minify URLs in various attrs]:opts:' \
    '--preserve-line-breaks[collapse to 1 line break when whitespace has one]' \
    '--prevent-attributes-escaping[do not escape attribute values]' \
    '--process-conditional-comments[process IE conditional comments]' \
    '*--process-scripts=[script types to process]:type:' \
    "--quote-character=[attribute quote character]:char:(' \")" \
    '--remove-attribute-quotes[remove attribute quotes when possible]' \
    '--remove-comments[strip HTML comments]' \
    '--remove-empty-attributes[remove whitespace-only attributes]' \
    '--remove-empty-elements[remove empty elements]' \
    '--remove-optional-tags[remove optional tags]' \
    '--remove-redundant-attributes[remove attrs whose value matches default]' \
    '--remove-script-type-attributes[remove type="text/javascript"]' \
    '--remove-style-link-type-attributes[remove type="text/css"]' \
    '--remove-tag-whitespace[remove space between attributes]' \
    '--sort-attributes[sort attributes by frequency]' \
    '--sort-class-name[sort style classes by frequency]' \
    '--trim-custom-fragments[trim whitespace around ignoreCustomFragments]' \
    '--use-short-doctype[use HTML5 short doctype]' \
    '*:HTML file:_files -g "*.(html|htm|xhtml)"' \
    && ret=0

return ret
