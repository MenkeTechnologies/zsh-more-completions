#compdef typstfmt
# Documentation: https://github.com/astrale-sharp/typstfmt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (main.rs argument parser).
# Removed from prior file: -V (real short version is -v); --column,
# --config (not in upstream main.rs argument parser).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--check[verify formatting without modifying files]' \
  '(-o --output)'{-o+,--output=}'[output path (use - for stdout)]:path:_files' \
  '--stdout[write to stdout (deprecated; use --output -)]' \
  '(-C --make-default-config)'{-C,--make-default-config}'[generate default config file]' \
  '--get-global-config-path[print global configuration file path]' \
  '--verbose[increase verbosity]' \
  '*:file:_files -g "*.typ"' && ret=0

return ret
