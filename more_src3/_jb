#compdef jb jsonnet-bundler
# Documentation: https://github.com/jsonnet-bundler/jsonnet-bundler/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: jsonnet-bundler upstream README — subcommands
# (init, install, update, rewrite) and flags (-h/--help,
# --version, --jsonnetpkg-home, -q/--quiet). Removed
# unverified i/u aliases and --single (not in upstream README).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new empty jsonnetfile'
  'install:install new dependencies (existing ones silently skipped)'
  'update:update all or specific dependencies'
  'rewrite:automatically rewrite legacy imports to absolute ones'
  'help:show context-sensitive help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--jsonnetpkg-home=[directory to cache packages]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[suppress git output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (install|update)
        _arguments \
          '*:URI:' && ret=0 ;;
    esac ;;
esac

return ret
