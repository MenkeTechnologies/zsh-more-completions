#compdef suitesparse_mongoose mongoose
# Documentation: https://github.com/DrTimothyAldenDavis/SuiteSparse
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Usage: mongoose <MM-input-file.mtx> [output-file]

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:Matrix Market file:_files -g "*.mtx"' \
  '2:output file:_files' && ret=0

return ret
