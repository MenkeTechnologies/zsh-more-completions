#compdef iroh-cli iroh-doctor
# _iroh-cli — distributed sync/blob CLI on top of QUIC + IPFS-style content addressing (n0-computer/iroh)
# upstream: https://github.com/n0-computer/iroh
# Subcommands follow the iroh / iroh-doctor binaries shipped from the iroh workspace.

_iroh-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--rpc-addr=[address of the iroh node RPC endpoint]:addr:' \
        '--start[start the iroh node if it is not already running]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_iroh-cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--rpc-addr=[address to bind the RPC server to]:addr:' \
                        '--metrics-addr=[address to bind the metrics server to]:addr:' \
                        '--add[automatically add hashes to the node]' && ret=0 ;;
                add)
                    _arguments \
                        '--in-place[add files without copying them into the node]' \
                        '--tag=[name a tag for the added blobs]:tag:' \
                        '*:file or directory:_files' && ret=0 ;;
                get)
                    _arguments \
                        '(-o --out)'{-o+,--out=}'[output file or directory]:path:_files -/' \
                        '--collection[treat the hash as a collection]' \
                        '1:hash or ticket:' && ret=0 ;;
                blob)
                    _arguments \
                        '1: :(add get list delete share)' \
                        '*:blob arg:_files' && ret=0 ;;
                tag)
                    _arguments \
                        '1: :(list delete set)' \
                        '*:tag arg:' && ret=0 ;;
                doc)
                    _arguments \
                        '1: :(create switch import export list join leave drop close keys get set del watch)' \
                        '*:doc arg:' && ret=0 ;;
                author)
                    _arguments \
                        '1: :(new list default delete)' \
                        '*:author arg:' && ret=0 ;;
                net)
                    _arguments \
                        '1: :(node-id node-addrs remote-info connections endpoints)' \
                        '*:net arg:' && ret=0 ;;
                rpc)
                    _arguments \
                        '1: :(status shutdown stats)' && ret=0 ;;
                console) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_iroh-cli_commands] )) ||
_iroh-cli_commands() {
    local -a commands
    commands=(
        'start:start the iroh node'
        'add:add files to the iroh blob store'
        'get:fetch content by hash or ticket'
        'blob:low-level blob commands (add / get / list / delete / share)'
        'tag:manage blob tags'
        'doc:manage iroh docs (key-value documents)'
        'author:manage iroh authors'
        'net:network info (node id, addrs, remote info, connections)'
        'rpc:RPC management (status, shutdown, stats)'
        'console:open the iroh interactive console'
    )
    _describe -t commands 'iroh command' commands
}

_iroh-cli "$@"
