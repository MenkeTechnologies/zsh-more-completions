#compdef img_stat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/img_stat.html
# Source: sleuthkit/sleuthkit man/img_stat.1 — display details about an image file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-t[print image type only]' \
    '-v[verbose output of debugging statements to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
