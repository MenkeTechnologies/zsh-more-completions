#compdef import-linter

_import-linter() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '--config=[path to config file]:config file:_files' \
        '--show-timings[show timings for each contract check]' \
        '--verbose[increase output verbosity]' \
        '--debug[enable debug output]' \
        '--cache[enable caching]' \
        '--no-cache[disable caching]' \
        '--contract=[check only the specified contract]:contract name:' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'lint:check import rules against the codebase'
            )
            _describe -t commands 'import-linter subcommand' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                lint)
                    _arguments \
                        '--config=[path to config file]:config file:_files' \
                        '--show-timings[show timings for each contract check]' \
                        '--verbose[increase output verbosity]' \
                        '--debug[enable debug output]' \
                        '--cache[enable caching]' \
                        '--no-cache[disable caching]' \
                        '--contract=[check only the specified contract]:contract name:' \
                        '*:package name:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_import-linter "$@"
