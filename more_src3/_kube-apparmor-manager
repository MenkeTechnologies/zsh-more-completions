#compdef kube-apparmor-manager
# Documentation: https://github.com/sysdiglabs/kube-apparmor-manager
# Reference accessed: 2026-05-19
# Verified: upstream main.go kingpin definitions - global --level and
# -i/--internal-ip; subcommands init/sync/enforced/enabled (no
# per-subcommand flags). Replaced bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--level=[log level]:level:(panic fatal error warning info debug trace)' \
  '(-i --internal-ip)'{-i,--internal-ip}'[connect to nodes via internal address]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(init:'install CRD and node agents' sync:'sync profiles from API to nodes' enforced:'print enforcement status' enabled:'print AppArmor availability')
    _describe -t commands command commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '*: :' && ret=0
    ;;
esac

return ret
