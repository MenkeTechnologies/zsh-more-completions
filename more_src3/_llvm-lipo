#compdef llvm-lipo
# _llvm-lipo — LLVM Mach-O fat binary tool (LLVM project, C++); thin/create/replace/info on universal binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-lipo() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-create[create universal binary]' \
        '--create[create universal binary]' \
        '-thin+[thin to arch]:arch:' \
        '--thin+[thin to arch]:arch:' \
        '-extract+[extract arch]:arch:' \
        '--extract+[extract arch]:arch:' \
        '-extract_family+[extract family]:arch:' \
        '--extract_family+[extract family]:arch:' \
        '-remove+[remove arch]:arch:' \
        '--remove+[remove arch]:arch:' \
        '-replace+[replace arch and file]:arch:_files:' \
        '--replace+[replace arch and file]:arch:_files:' \
        '-archs[print arch list]' \
        '--archs[print arch list]' \
        '-info[print info]' \
        '--info[print info]' \
        '-verify_arch+[verify arch]:arch:' \
        '--verify_arch+[verify arch]:arch:' \
        '-detailed_info[print detailed info]' \
        '--detailed_info[print detailed info]' \
        '-segalign+[seg align]:arch:hex:' \
        '--segalign+[seg align]:arch:hex:' \
        '-output+[output file]:file:_files' \
        '--output+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '*:file:_files'
}

_llvm-lipo "$@"
