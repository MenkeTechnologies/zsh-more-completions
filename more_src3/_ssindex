#compdef ssindex ssgrep ssdiff
# Documentation: source-direct extraction from upstream
# GNOME/gnumeric
#   src/ssindex.c:ssindex_options[]  -> 4 GOptionEntry rows.
#   src/ssgrep.c:ssgrep_options[]    -> 17 GOptionEntry rows.
#   src/ssdiff.c:ssdiff_options[]    -> 4 GOptionEntry rows.
# Each row decoded as
#   { "long-name", 'short-char', flags, type, dest, help, arg-desc }
# Sub-flag G_OPTION_FLAG_REVERSE on ssgrep -h/--without-filename
# indicates that flag inverts the value bound to the same
# `&ssgrep_print_filenames` dest as -H/--with-filename - i.e.
# -h and -H form an explicit XOR pair, not just two flags.
# Reference accessed: 2026-05-30 via gh api.
# GNOME gnumeric R175 — 3-stem multi-binary harvest of the
# Gnumeric spreadsheet-driver command-line companions shipped
# alongside the already-covered `ssconvert` binary in the
# corpus.  ssindex extracts text+metadata for desktop search
# indexers; ssgrep is the spreadsheet-aware grep; ssdiff is
# the cell-by-cell-diff with copy-highlighting + XML output.

case $service in

  ssindex)
    _arguments -s -S \
      '(-v --version)'{-v,--version}'[display program version]' \
      '(-m --list-mime-types)'{-m,--list-mime-types}'[list MIME types ssindex is able to read]' \
      '(-i --index)'{-i,--index}'[index the given files]' \
      '(-E --encoding)'{-E+,--encoding=}'[specify an encoding for imported content]:encoding:' \
      '*:spreadsheet file:_files -g "*.(gnumeric|xlsx|xls|ods|csv)"'
    ;;

  ssgrep)
    # -h and -H form an explicit XOR pair via G_OPTION_FLAG_REVERSE
    # on -h binding to the same &ssgrep_print_filenames dest -
    # listed under mutex group (-H -h --with-filename
    # --without-filename).
    _arguments -s -S \
      '(-c --count)'{-c,--count}'[only print a count of matches per file]' \
      '(-C --string-table-count)'{-C,--string-table-count}'[search only via the string table, display a count of references]' \
      '(-f --pattern-file)'{-f+,--pattern-file=}'[get patterns from a file, one per line]:file:_files' \
      '(-F --fixed-strings)'{-F,--fixed-strings}'[pattern is a set of fixed strings]' \
      '(-H -h --with-filename --without-filename)'{-H,--with-filename}'[print the filename for each match]' \
      '(-H -h --with-filename --without-filename)'{-h,--without-filename}'[do not print the filename for each match]' \
      '(-i --ignore-case)'{-i,--ignore-case}'[ignore differences in letter case]' \
      '(-l --files-with-matches)'{-l,--files-with-matches}'[print filenames with matches]' \
      '(-L --files-without-matches)'{-L,--files-without-matches}'[print filenames without matches]' \
      '(-n --print-locus)'{-n,--print-locus}'[print the location of each match]' \
      '(-q --quiet)'{-q,--quiet}'[suppress all normal output]' \
      '(-R --search-results)'{-R,--search-results}'[search results of expressions too]' \
      '(-T --print-type)'{-T,--print-type}'[print the location type of each match]' \
      '(-v --invert-match)'{-v,--invert-match}'[search for cells that do NOT match]' \
      '(-V --version)'{-V,--version}'[display program version]' \
      '(-w --word-regexp)'{-w,--word-regexp}'[match only whole words]' \
      '--recalc[recalculate all cells]' \
      '1:pattern (omit if --pattern-file given):' \
      '*:spreadsheet file:_files -g "*.(gnumeric|xlsx|xls|ods|csv)"'
    ;;

  ssdiff)
    _arguments -s -S \
      '(-v --version)'{-v,--version}'[display program version]' \
      '(-o --output)'{-o+,--output=}'[send output to file]:file:_files' \
      '(-h --highlight)'{-h,--highlight}'[emit a copy of the original with differences highlighted]' \
      '(-x --xml)'{-x,--xml}'[output in XML format]' \
      '1:left/old spreadsheet:_files -g "*.(gnumeric|xlsx|xls|ods|csv)"' \
      '2:right/new spreadsheet:_files -g "*.(gnumeric|xlsx|xls|ods|csv)"'
    ;;

esac
