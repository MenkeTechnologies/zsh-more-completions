#compdef yandex-tank
# _yandex-tank — Yandex yandex-tank load testing tool unified interface for Phantom JMeter Pandora generators (yandex team, Python); argparse
# upstream: https://github.com/yandex/yandex-tank

_yandex-tank() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.ini"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.ini"' \
        '-o+[option override]:str:' \
        '--option=+[option override]:str:' \
        '-p+[default ammo file]:file:_files' \
        '--patch=+[option patch file]:file:_files' \
        '-i[no autostart]' \
        '--no-autostart[no autostart]' \
        '-l+[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--log-level=+[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '-m+[manual start]:str:' \
        '--manual-start=+[manual start]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--lock-dir=+[lock dir]:dir:_files -/' \
        '--ignore-lock[ignore lock]' \
        '--no-rc[ignore rc files]' \
        '--scheduled-start=+[time]:str:' \
        '--target=+[host:port]:str:' \
        '--ammo-file=+[ammo file]:file:_files' \
        '--rps-schedule=+[schedule]:str:' \
        '--instances-schedule=+[schedule]:str:' \
        '--load-profile=+[profile]:str:' \
        '*:plugin override:'
}

_yandex-tank "$@"
