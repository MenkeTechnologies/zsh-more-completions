#compdef smemstat
# Documentation: https://github.com/ColinIanKing/smemstat/blob/master/smemstat.8
# Reference accessed: 2026-05-21
# Verified: upstream man page at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-a[show memory size change with up/down arrows]' \
  '-c[get command info from process comm field]' \
  '-d[strip directory basename off command information]' \
  '-g[report memory in gigabytes]' \
  '-k[report memory in kilobytes]' \
  '-l[show long (full) command information]' \
  '-m[report memory in megabytes]' \
  '-o+[output data into a JSON formatted file]:file:_files' \
  '-p+[comma-separated list of processes (PIDs or names) to monitor]:proclist:' \
  '-q[run quietly, useful with -o]' \
  '-s[show short command information]' \
  '-t[top mode: show top changes of memory]' \
  '-T[top mode: show top consumers of memory]' \
  '*:delay count:' && ret=0

return ret
