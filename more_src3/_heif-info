#compdef heif-info
# Documentation: heif-info --help (libheif 1.23.0)
# Source: print structural information about a HEIF / AVIF file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-d --dump-boxes)'{-d,--dump-boxes}'[low-level dump of all MP4 boxes]' \
    '--disable-limits[disable all security limits (development only)]' \
    '*:heif file:_files -g "*.(heic|heif|avif)"' \
    && ret=0

return ret
