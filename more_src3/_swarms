#compdef swarms
# Documentation: https://github.com/kyegomez/swarms
# Reference accessed: 2026-05-22
# Verified: swarms/cli/main.py COMMAND_CHOICES and argparse options.

# Zsh completion for swarms - multi-agent orchestration CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--yaml-file[agents YAML file]:file:_files' \
  '--markdown-path[markdown agent file or directory]:path:_files' \
  '--concurrent[load markdown agents concurrently]' \
  '--name[custom agent name]:name:' \
  '--description[custom agent description]:text:' \
  '--system-prompt[custom agent system prompt]:text:' \
  '--model-name[model name]:model:' \
  '--model[model for autoswarm]:model:' \
  '--task[task for agent]:task:' \
  '--temperature[temperature 0.0-2.0]:float:' \
  '--max-loops[max agent loops]:loops:' \
  '--loops-per-agent[loops per agent for heavy-swarm]:n:' \
  '--verbose[verbose output]' \
  '--no-run[write autoswarm file without executing]' \
  '(-o --output)'{-o,--output}'[autoswarm output file]:file:_files' \
  '(-d --output-dir)'{-d,--output-dir}'[autoswarm output directory]:directory:_directories' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'swarms command' \
      'init[scaffold project with agents.yaml]' \
      'onboarding[environment setup check]' \
      'get-api-key[open browser for API key]' \
      'check-login[verify authentication]' \
      'run-agents[run agents from YAML]' \
      'load-markdown[load agents from markdown]' \
      'agent[create and run custom agent]' \
      'chat[interactive chat agent]' \
      'upgrade[upgrade Swarms package]' \
      'autoswarm[generate and run autonomous swarm]' \
      'setup-check[comprehensive setup check]' \
      'llm-council[LLM council collaboration]' \
      'heavy-swarm[HeavySwarm complex tasks]' \
      'tips[show usage tips]' \
      'models[list available models]' && ret=0
    ;;
esac

return ret
