#compdef hv_set_ifconfig hv-set-ifconfig
# _hv-set-ifconfig — Linux hv_set_ifconfig (helper script called by hv_kvp_daemon when the Hyper-V host pushes a new static IP config to the guest; positional argument is the on-disk ifcfg-* path; rewrites and reloads NetworkManager / sysconfig interfaces accordingly)
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git (tools/hv)
# Argument shape from kernel tools/hv/hv_set_ifconfig.sh on tip.

_hv-set-ifconfig() {
    _arguments \
        '1:ifcfg file:_files'
}

_hv-set-ifconfig "$@"
