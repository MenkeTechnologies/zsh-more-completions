#compdef ios_webkit_debug_proxy
# Documentation: https://github.com/google/ios-webkit-debug-proxy/blob/master/src/ios_webkit_debug_proxy_main.c
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iOS WebKit remote-debugging proxy

_arguments -s -S \
  '(-u --udid)'{-u,--udid}'+[device UDID (or :PORT for first device)]:udid:' \
  '(-c --config)'{-c,--config}'+[device-to-port assignment rules]:config:' \
  '(-f --frontend)'{-f,--frontend}'+[DevTools UI URL (must end in .html)]:url:' \
  '-F[disable the frontend proxy]' \
  '--no-frontend[disable the frontend proxy]' \
  '-s+[simulator webinspector socket address]:addr:' \
  '(-d --debug)'{-d,--debug}'[enable verbose debug output]' \
  '(-h --help)'{-h,--help}'[print usage information]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '*::args:_default' && return 0
