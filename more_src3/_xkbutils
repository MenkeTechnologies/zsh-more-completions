#compdef xkbbell xkbvleds xkbwatch
# Documentation: https://man.archlinux.org/man/xkbbell.1.en
# Reference accessed: 2026-05-21
# Verified: upstream Arch manpage for xkbbell; xkbvleds/xkbwatch share the X
# toolkit option set documented in the same x11-xkb-utils package.

local curcontext="$curcontext" ret=1

case $service in
  (xkbbell)
    _arguments \
      '-display+[X display]:display:' \
      '-synch[turn on synchronization]' \
      '-dev+[device id]:id:' \
      '-force[force audible bell]' \
      '-nobeep[suppress server bell, event only]' \
      '-bf+[bell feedback id]:id:' \
      '-kf+[keyboard feedback id]:id:' \
      '-v+[volume]:vol:' \
      '-w+[window id]:id:' \
      '-help[print list of options and exit]' \
      '-version[print program version and exit]' && ret=0 ;;
  (xkbvleds)
    _arguments \
      '-display+[X display]:display:' \
      '-synch[turn on synchronization]' \
      '-help[print list of options and exit]' \
      '-version[print program version and exit]' && ret=0 ;;
  (xkbwatch)
    _arguments \
      '-display+[X display]:display:' \
      '-synch[turn on synchronization]' \
      '-help[print list of options and exit]' \
      '-version[print program version and exit]' && ret=0 ;;
esac

return ret
