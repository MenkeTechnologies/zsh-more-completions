#compdef telescope-cli
# _telescope-cli — Mohamed Said Laravel Telescope debug assistant CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/telescope

_telescope-cli() {
    local -a sub=(
        'telescope:install:install telescope'
        'telescope:publish:publish telescope assets'
        'telescope:clear:clear telescope entries'
        'telescope:prune:prune old entries'
        'telescope:pause:pause recording'
        'telescope:resume:resume recording'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'telescope subcommand' sub ;;
        args)
            case $words[1] in
                telescope:prune) _arguments \
                    '--hours=+[hours]:n:' \
                    '--keep-exceptions[keep exception records]' ;;
            esac
            ;;
    esac
}

_telescope-cli "$@"
