#compdef statsprocessor sp64
# _statsprocessor — Jens Atom Steube hashcat statsprocessor Markov-based password candidate generator using language statistics (hashcat team, C); custom argparse
# upstream: https://github.com/hashcat/statsprocessor

_statsprocessor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-1+[charset 1]:str:' \
        '--custom-charset1=+[charset 1]:str:' \
        '-2+[charset 2]:str:' \
        '--custom-charset2=+[charset 2]:str:' \
        '-3+[charset 3]:str:' \
        '--custom-charset3=+[charset 3]:str:' \
        '-4+[charset 4]:str:' \
        '--custom-charset4=+[charset 4]:str:' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '--pw-min=+[min password length]:n:' \
        '--pw-max=+[max password length]:n:' \
        '--threshold=+[Markov threshold]:n:' \
        '--markov-disable[disable Markov]' \
        '--markov-classic[classic Markov]' \
        '--markov-hcstat=+[hcstat file]:file:_files -g "*.hcstat *.hcstat2"' \
        '--hcstat=+[hcstat file]:file:_files -g "*.hcstat *.hcstat2"' \
        '-s+[skip n elements]:n:' \
        '--skip=+[skip n elements]:n:' \
        '-l+[limit n elements]:n:' \
        '--limit=+[limit n elements]:n:' \
        '*:mask:'
}

_statsprocessor "$@"
