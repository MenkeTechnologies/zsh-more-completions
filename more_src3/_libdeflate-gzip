#compdef libdeflate-gzip libdeflate-gunzip
# Documentation: libdeflate-gzip -h
# Source: fast gzip/gunzip via libdeflate.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show version]' \
    '-1[fastest compression]' \
    '-2[level 2]' \
    '-3[level 3]' \
    '-4[level 4]' \
    '-5[level 5]' \
    '-6[medium compression (default)]' \
    '-7[level 7]' \
    '-8[level 8]' \
    '-9[level 9]' \
    '-10[level 10]' \
    '-11[level 11]' \
    '-12[best compression]' \
    '-c[write to stdout]' \
    '-d[decompress]' \
    '-f[force; overwrite/follow hardlinks]' \
    '-k[keep input files]' \
    '-q[suppress warnings]' \
    '-S+[suffix instead of .gz]:suffix:' \
    '-t[test integrity]' \
    '*:file:_files' \
    && ret=0

return ret
