#compdef sprocket
# Documentation: https://github.com/stjude-rust-labs/sprocket
# Reference accessed: 2026-05-21
# Verified: README subcommands section.
# Replaced: prior file modeled the deprecated wdl-gauntlet behavior;
# current sprocket is a WDL toolkit with run/check/lint/format/etc subcommands.

# Zsh completion for sprocket - WDL bioinformatics toolkit (stjude-rust-labs/sprocket)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:execute a WDL task or workflow'
  'check:perform static analysis on WDL documents'
  'lint:run linting on WDL documents (extra validation)'
  'format:auto-format WDL documents'
  'validate:validate inputs against task/workflow specifications'
  'inputs:generate template input files (JSON/YAML)'
  'explain:explain validation and linting rules'
  'analyzer:run as LSP server for IDE integration'
  'dev:experimental developer commands'
  'completions:generate shell completion scripts'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[info logging]' \
  '(-q --quiet)'{-q,--quiet}'[errors-only logging]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sprocket command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
      run|check|lint|format|validate|inputs)
        _arguments '*:WDL file:_files -g "*.(wdl|json|yaml|yml)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
