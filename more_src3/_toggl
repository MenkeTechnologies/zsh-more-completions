#compdef toggl
# Documentation: https://github.com/AuHau/toggl-cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. AuHau/toggl-cli ships a click
# completion handler driven by `_TOGGL_COMPLETE=complete-zsh`; defer to
# upstream-shipped completion to avoid fabricating a flag set.

_toggl() {
  local IFS=$'\n'
  local -a reply
  reply=( $(env COMMANDLINE="${words[1,$CURRENT]}" _TOGGL_COMPLETE=complete-zsh toggl 2>/dev/null) )
  _describe -t toggl-args 'toggl args' reply
}

compdef _toggl toggl
