#compdef likwid-bench
# _likwid-bench — HPC microbenchmark driver from LIKWID (RRZE-HPC/likwid)
# upstream: https://github.com/RRZE-HPC/likwid
# Flags from bench/likwid-bench.c (getopt_long).

_likwid-bench() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-a --all)'{-a,--all}'[list all available benchmark kernels]'
        '(-p --printdomains)'{-p,--printdomains}'[print available affinity domains]'
        '(-d --delim)'{-d+,--delim=}'[output delimiter]:delim:'
        '(-s --runtime)'{-s+,--runtime=}'[target runtime in seconds]:seconds:'
        '(-i --iters)'{-i+,--iters=}'[explicit iteration count]:n:'
        '(-l --list)'{-l+,--list=}'[show details for a specific kernel]:kernel:'
        '(-t --test)'{-t+,--test=}'[benchmark kernel name]:kernel:'
        '*'{-w+,--workgroup=}'[workgroup spec, e.g. S0:1GB:4 (repeatable)]:spec:'
        '-W+[domain workgroup spec, same form as -w]:spec:'
        '(-f --tempdir)'{-f+,--tempdir=}'[directory for generated assembly]:dir:_files -/'
        '(-o --asmout)'{-o+,--asmout=}'[write generated assembly to this file]:file:_files'
    )
    _arguments -s $args
}

_likwid-bench "$@"
