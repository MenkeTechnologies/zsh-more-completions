#compdef ipfs-pinner
# _ipfs-pinner — pin files/directories to IPFS pinning services (wabarc/ipfs-pinner)
# upstream: https://github.com/wabarc/ipfs-pinner
# Flags from cmd/ipfs-pinner/main.go.

_ipfs-pinner() {
    _arguments \
        '-t+[pinner service]:pinner:(infura pinata nftstorage web3storage)' \
        '-u+[pinner API key or username]:key:' \
        '-p+[pinner secret or password]:secret:' \
        '*:path:_files'
}

_ipfs-pinner "$@"
