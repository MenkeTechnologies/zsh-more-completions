#compdef user
# _user — OpenBSD user(8) frontend (sysadmin tool wrapping useradd/usermod/userdel/userinfo via add/mod/del/info subcommands; -D form on add/del sets defaults in /etc/usermgmt.conf)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Subcommands + flags from usr.sbin/user/user.8 on tip.

_user() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'user subcommand' \
                '(add:create a new user mod:modify an existing user del:delete a user info:show user info)'
            ;;
        args)
            case $line[1] in
                add)
                    _arguments \
                        '-D[set defaults in /etc/usermgmt.conf]' \
                        '-m[create home directory]' \
                        '-o[allow duplicate uid]' \
                        '-v[verbose]' \
                        '-b+[base directory]:dir:_files -/' \
                        '-c+[GECOS comment]:comment:' \
                        '-d+[home directory]:dir:_files -/' \
                        '-e+[expiry time]:date:' \
                        '-f+[inactive time]:date:' \
                        '-G+[secondary groups]:groups:_groups' \
                        '-g+[primary gid|name|=uid]:gid/name:' \
                        '-k+[skel directory]:dir:_files -/' \
                        '-L+[login class]:class:' \
                        '-p+[password (encrypted)]:password:' \
                        '-r+[uid range low..high]:range:' \
                        '-s+[shell]:shell:_files -g "*"' \
                        '-u+[uid]:uid:' \
                        '1:user:_users'
                    ;;
                mod)
                    _arguments \
                        '-m[move home dir]' '-o[allow duplicate uid]' '-v[verbose]' \
                        '-c+[GECOS comment]:comment:' \
                        '-d+[home directory]:dir:_files -/' \
                        '-e+[expiry time]:date:' '-f+[inactive time]:date:' \
                        '-G+[secondary groups]:groups:_groups' \
                        '-g+[primary gid|name|=uid]:gid/name:' \
                        '-L+[login class]:class:' \
                        '-l+[new login name]:newlogin:' \
                        '-p+[password (encrypted)]:password:' \
                        '-s+[shell]:shell:_files' \
                        '-u+[uid]:uid:' \
                        '1:user:_users'
                    ;;
                del)
                    _arguments \
                        '-D[set defaults in /etc/usermgmt.conf]' \
                        '-p[preserve home]' '-r[remove home]' '-v[verbose]' \
                        '1:user:_users'
                    ;;
                info)
                    _arguments '-e[exit-status only (check existence)]' '1:user:_users'
                    ;;
            esac
            ;;
    esac
}

_user "$@"
