#compdef timoni
# Documentation: https://timoni.sh/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for timoni (Kubernetes package manager powered by CUE)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:install or upgrade a module instance'
  'build:build a module instance'
  'bundle:manage bundles'
  'completion:generate shell completion scripts'
  'delete:delete an instance'
  'inspect:inspect an instance'
  'list:list instances'
  'mod:manage modules'
  'runtime:manage runtime'
  'status:display the status of an instance'
  'registry:manage registry authentication'
  'artifact:manage OCI artifacts'
  'version:print version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'timoni command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (mod)
        local -a mod_cmds=(
          'init:initialize a new module'
          'lint:lint a module'
          'list:list module versions'
          'pull:pull a module from a registry'
          'push:push a module to a registry'
          'vet:validate a module'
          'vendor:vendor dependencies'
        )
        _describe -t mod_cmds 'mod command' mod_cmds && ret=0
        ;;
      (bundle)
        local -a bundle_cmds=(
          'apply:apply a bundle'
          'build:build a bundle'
          'delete:delete a bundle'
          'status:show bundle status'
          'vet:validate a bundle'
        )
        _describe -t bundle_cmds 'bundle command' bundle_cmds && ret=0
        ;;
      (inspect)
        local -a inspect_cmds=(
          'module:inspect module info'
          'values:inspect instance values'
          'resources:inspect instance resources'
        )
        _describe -t inspect_cmds 'inspect command' inspect_cmds && ret=0
        ;;
      (runtime)
        _values 'runtime command' build && ret=0
        ;;
      (registry)
        _values 'registry command' login logout && ret=0
        ;;
      (artifact)
        _values 'artifact command' list push pull tag && ret=0
        ;;
    esac
    ;;
esac

return ret
