#compdef velero-plugin-for-microsoft-azure
# _velero-plugin-for-microsoft-azure — Velero Azure provider plugin (registers velero.io/azure ObjectStore + VolumeSnapshotter)
# upstream: https://github.com/vmware-tanzu/velero-plugin-for-microsoft-azure
# Plugins are run as go-plugin gRPC servers by velero; framework Config exposes --log-level and --features. The blob storage account, resource group, key vault, MSI client id come from the BackupStorageLocation / VolumeSnapshotLocation spec.

_velero-plugin-for-microsoft-azure() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[plugin log level]:level:(trace debug info warning error fatal panic)' \
        '--features=[csv of velero feature flags]:csv:'
}

_velero-plugin-for-microsoft-azure "$@"
