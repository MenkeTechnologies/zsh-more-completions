#compdef tuc
# Documentation: https://github.com/riquito/tuc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tuc - cut text with delimiters

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --delimiter)'{-d,--delimiter}'[delimiter character(s)]:delimiter:' \
  '(-f --fields)'{-f,--fields}'[field ranges to select]:ranges:' \
  '(-b --bytes)'{-b,--bytes}'[byte ranges to select]:ranges:' \
  '(-c --characters)'{-c,--characters}'[character ranges to select (UTF-8)]:ranges:' \
  '(-l --lines)'{-l,--lines}'[line ranges to select]:ranges:' \
  '(-p --compress-delimiter)'{-p,--compress-delimiter}'[merge consecutive delimiters before cutting]' \
  '(-g --greedy-delimiter)'{-g,--greedy-delimiter}'[treat consecutive delimiters as one]' \
  '(-e --regex)'{-e,--regex}'[use delimiter as a regex]' \
  '(-r --replace-delimiter)'{-r,--replace-delimiter}'[replace delimiter with new text]:string:' \
  '(-t --trim)'{-t,--trim}'[trim delimiter]:mode:(left right both)' \
  '(-j --join)'{-j,--join}'[output selected parts with delimiter between them]' \
  '--no-join[disable automatic joining]' \
  '(-m --complement)'{-m,--complement}'[invert field selection]' \
  '--json[output as JSON]' \
  '(-s --only-delimited)'{-s,--only-delimited}'[only print lines containing delimiter]' \
  '(-z --zero-terminated)'{-z,--zero-terminated}'[use NUL as line delimiter]' \
  '(-M --fixed-memory)'{-M,--fixed-memory}'[read input in chunks (KB)]:kb:' \
  '--no-mmap[disable memory mapping]' \
  '*:file:_files' && ret=0

return ret
