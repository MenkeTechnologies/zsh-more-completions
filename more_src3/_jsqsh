#compdef jsqsh
# Documentation: https://github.com/scgray/jsqsh/blob/master/jsqsh-dist/dist/unix/jsqsh.1
# Reference accessed: 2026-05-19
# Verified: upstream jsqsh(1) man page at the URL above.

_arguments -s \
  '(-S --setup)'{-S,--setup}'[start the connection setup wizard]' \
  '(-d --driver)'{-d+,--driver=}'[jsqsh driver definition name]:driver:' \
  '--server=[server name (\$\{server\})]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[server port (\$\{port\})]:port:' \
  '(-D --database)'{-D+,--database=}'[database/catalog (\$\{db\})]:db:' \
  '(-U --username)'{-U+,--username=}'[username (\$\{user\})]:user:' \
  '(-P --password)'{-P+,--password=}'[password (\$\{password\})]:password:' \
  '(-u --jdbc-url)'{-u+,--jdbc-url=}'[explicit JDBC URL]:url:' \
  '(-c --jdbc-class)'{-c+,--jdbc-class=}'[JDBC driver class for direct URL]:class:' \
  '(-w --domain)'{-w+,--domain=}'[Windows auth domain (\$\{domain\})]:domain:' \
  '*'{-O+,--prop=}'[set a JDBC driver property name=value]:KEY=VALUE:' \
  '*'{-C+,--config-dir=}'[additional jsqsh config directory]:dir:_files -/' \
  '(-e --echo)'{-e,--echo}'[echo all input to the screen]' \
  '*'{-i+,--input-file=}'[read input from file (- for stdin)]:file:_files' \
  '(-n --non-interactive)'{-n,--non-interactive}'[force non-interactive behavior]' \
  '(-o --output-file)'{-o+,--output-file=}'[redirect output to a file]:file:_files' \
  '*'{-R+,--drivers=}'[load additional JDBC driver definition file]:file:_files' \
  '*'{-v+,--var=}'[set or define a jsqsh variable name=value]:VAR=VAL:' \
  '(-X --exit)'{-X+,--exit=}'[exit status mode]:mode:(total last)' \
  '*:connection name:' \
  && return 0
