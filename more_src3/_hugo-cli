#compdef hugo-cli
# _hugo-cli — Hugo static site generator CLI alias (gohugoio, Go); spf13/cobra
# upstream: https://github.com/gohugoio/hugo

_hugo-cli() {
    local -a sub=(
        'completion:generate shell completion'
        'config:print site config'
        'convert:convert content to another format'
        'deploy:deploy site to remote'
        'env:print env info'
        'gen:generate documentation'
        'import:import site from another platform'
        'list:list content'
        'mod:Hugo modules'
        'new:create new content/site'
        'release:release Hugo (maintainers only)'
        'server:start dev server'
        'serve:start dev server (alias)'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
        '--configDir=+[config dir]:dir:_files -/' \
        '--source=+[source dir]:dir:_files -/' \
        '-s+[source dir]:dir:_files -/' \
        '--destination=+[destination]:dir:_files -/' \
        '-d+[destination]:dir:_files -/' \
        '--themesDir=+[themes dir]:dir:_files -/' \
        '--theme=+[theme name]:str:' \
        '-t+[theme name]:str:' \
        '--cacheDir=+[cache dir]:dir:_files -/' \
        '--logLevel=+[log level]:level:(debug info warn error)' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--noBuildLock[no build lock]' \
        '--cleanDestinationDir[clean destination dir]' \
        '--minify[minify output]' \
        '--gc[run gc]' \
        '--ignoreCache[ignore cache]' \
        '--noTimes[no times]' \
        '--noChmod[no chmod]' \
        '--printI18nWarnings[print i18n warnings]' \
        '--printPathWarnings[print path warnings]' \
        '--printUnusedTemplates[print unused templates]' \
        '--enableGitInfo[enable git info]' \
        '--templateMetrics[template metrics]' \
        '--templateMetricsHints[template metrics hints]' \
        '--buildDrafts[include drafts]' \
        '-D[include drafts]' \
        '--buildExpired[include expired]' \
        '-E[include expired]' \
        '--buildFuture[include future]' \
        '-F[include future]' \
        '--ignoreVendorPaths=+[ignore vendor paths]:list:' \
        '--watch[watch]' \
        '-w[watch]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hugo subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:thing:(content site theme)' \
                    '2:path-or-name:_files' \
                    '--kind=+[kind]:str:' \
                    '-k+[kind]:str:' \
                    '--editor=+[editor]:str:' \
                    '-e+[editor]:str:' \
                    '--force[force]' \
                    '-f[force]' ;;
                server|serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--bind=+[bind]:host:_hosts' \
                    '--baseURL=+[base url]:url:_urls' \
                    '-b+[base url]:url:_urls' \
                    '--liveReloadPort=+[live reload port]:port:' \
                    '--navigateToChanged[navigate to changed]' \
                    '--disableFastRender[disable fast render]' \
                    '--disableLiveReload[disable live reload]' \
                    '--noHTTPCache[no http cache]' \
                    '--openBrowser[open browser]' \
                    '-O[open browser]' \
                    '--renderToDisk[render to disk]' \
                    '--memstats=+[memstats interval]:dur:' ;;
                config) _arguments \
                    '1:cmd:(mounts)' \
                    '*:arg:' ;;
                mod) _arguments \
                    '1:cmd:(clean get graph init npm tidy vendor verify)' \
                    '*:arg:' ;;
                gen) _arguments \
                    '1:cmd:(chromastyles doc man)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                list) _arguments \
                    '1:cmd:(drafts expired future all published)' \
                    '*:arg:' ;;
                convert) _arguments \
                    '1:cmd:(toJSON toTOML toYAML)' \
                    '--output=+[output]:dir:_files -/' \
                    '-o+[output]:dir:_files -/' \
                    '--unsafe[unsafe]' ;;
                deploy) _arguments \
                    '--target=+[target]:str:' \
                    '--confirm[confirm]' \
                    '--dryRun[dry run]' \
                    '--force[force]' \
                    '--invalidateCDN[invalidate CDN]' \
                    '--maxDeletes=+[max deletes]:n:' ;;
            esac
            ;;
    esac
}

_hugo-cli "$@"
