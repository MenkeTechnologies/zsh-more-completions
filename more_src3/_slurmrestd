#compdef slurmrestd
# Documentation: https://slurm.schedmd.com/slurmrestd.html
# Reference accessed: 2026-05-21
# Verified: upstream slurmrestd(8) man page.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[print version]' \
  '*-a+[authentication plugins]:plugin' \
  '*-d+[data_parser plugins for output format]:plugin' \
  '*-s+[OpenAPI plugins]:plugin' \
  '-f+[Slurm config file]:file:_files' \
  '-g+[group id]:group:_groups' \
  '-u+[user id]:user:_users' \
  '-t+[thread count]:n:' \
  '--max-connections=[max concurrent connections (default 124)]:n:' \
  '--generate-openapi-spec[output JSON OpenAPI spec to stdout and exit]' \
  '*-v[increase verbosity (up to -vvvvvv)]' \
  '*:listener:' && ret=0

return ret
