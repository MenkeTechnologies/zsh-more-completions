#compdef swift-cache-tool
# Documentation: https://raw.githubusercontent.com/swiftlang/swift/main/include/swift/Option/Options.td
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cas-path, cas-plugin-path,
# cas-plugin-option confirmed in Options.td; -cache-tool-action and its
# action values not confirmed in upstream master and left freeform).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[display available options]' \
  '-cache-tool-action[Swift Cache Tool action kind]:action:' \
  '-cas-path[path to CAS]:path:_files -/' \
  '-cas-plugin-option[option to pass to CAS plugin]:name=option:' \
  '-cas-plugin-path[path to CAS plugin]:path:_files' && ret=0

return ret
