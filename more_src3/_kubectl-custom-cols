#compdef kubectl-custom-cols
# Documentation: https://github.com/webofmars/kubectl-custom-cols
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-custom-cols (webofmars): wraps `kubectl get` with named column
# templates. Invoked as `kubectl custom-cols -o <template name> <args>`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-o[output template preset name]:template:' \
  '*:kubectl arguments:_default'
