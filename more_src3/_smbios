#compdef smbios-sys-info smbios-token-ctl smbios-passwd smbios-thermal-ctl smbios-wakeup-ctl smbios-keyboard-ctl smbios-battery-ctl
# _smbios — Dell smbios-utils SMBIOS DMI interface utilities for Dell laptops and servers (dell team, Python); custom argparse
# upstream: https://github.com/dell/libsmbios

_smbios() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-m+[memory file]:file:_files' \
        '--memory-dat-file=+[memory file]:file:_files' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-t+[token name]:str:' \
        '--token=+[token name]:str:' \
        '--get-active[get active value]' \
        '--get-string[get string value]' \
        '--activate[activate token]' \
        '--password=+[admin password]:str:' \
        '--password-utf16=+[admin password utf16]:str:' \
        '--new-password=+[new password]:str:' \
        '--new-password-utf16=+[new password utf16]:str:' \
        '--info[show system info]' \
        '--list-tokens[list tokens]' \
        '--bootorder[show boot order]' \
        '--set-wol=+[bool]:b:(0 1)' \
        '--keyboard-backlight=+[level]:n:' \
        '--get-thermal=+[mode]:str:' \
        '--set-thermal=+[mode]:m:(balanced cool-bottom quiet performance)' \
        '--get-battery=+[mode]:str:' \
        '--set-battery=+[mode]:m:(standard expressCharge primarilyACUse adaptive custom)' \
        '--start-charging-percent=+[N]:n:' \
        '--stop-charging-percent=+[N]:n:' \
        '--get-wakeup=+[mode]:str:' \
        '--set-wakeup-acpower=+[bool]:b:(0 1)' \
        '--set-wakeup-lan=+[bool]:b:(0 1)'
}

_smbios "$@"
