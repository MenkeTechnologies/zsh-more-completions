#compdef hostnamectl
# _hostnamectl-bin — systemd-hostnamed control client; query and set hostname / chassis / location / deployment / icon
# upstream: https://github.com/systemd/systemd

_hostnamectl-bin() {
    local -a sub=(
        'status:show current hostname info'
        'hostname:get/set the hostname'
        'icon-name:get/set the icon name'
        'chassis:get/set the chassis type'
        'deployment:get/set the deployment'
        'location:get/set the location'
        'set-hostname:set the static hostname'
        'set-icon-name:set the icon name'
        'set-chassis:set the chassis type'
        'set-deployment:set the deployment'
        'set-location:set the location'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--no-ask-password[do not prompt for password]' \
        '--static[only static hostname]' \
        '--transient[only transient hostname]' \
        '--pretty[only pretty hostname]' \
        '(-H --host)'{-H,--host}'+[remote host]:host:_hosts' \
        '(-M --machine)'{-M,--machine}'+[container]:machine:' \
        '--json+[json output]:mode:(pretty short off)' \
        '(-j)-j[short json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hostnamectl subcommand' sub ;;
        args)
            case $words[1] in
                set-chassis|chassis) _arguments '1:chassis:(desktop laptop server tablet handset watch embedded vm container)' ;;
                set-hostname|hostname|set-icon-name|icon-name|set-deployment|deployment|set-location|location) _arguments '1:value:' ;;
            esac
            ;;
    esac
}

_hostnamectl-bin "$@"
