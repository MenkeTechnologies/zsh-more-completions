#compdef zipgrep
# Documentation: https://man.archlinux.org/man/zipgrep.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. zipgrep passes pre-archive options
# through to egrep(1); only -x is zipgrep-specific.

local -a arguments

arguments=(
    '-i[case insensitive (passed to egrep)]'
    '-c[count matches (passed to egrep)]'
    '-l[list matching files (passed to egrep)]'
    '-h[suppress filename prefix (passed to egrep)]'
    '-n[show line numbers (passed to egrep)]'
    '-v[invert match (passed to egrep)]'
    '-e+[specify pattern (passed to egrep)]:pattern'
    '-x+[exclude archive members]:exclude pattern'
    '1:pattern:'
    '2:zip file:_files -g "*.zip"'
    '*:member:'
)

_arguments -s -S $arguments
