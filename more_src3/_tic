#compdef tic
# Documentation: tic usage line (ncurses)
# Source: terminfo entry-description compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-1[format translation output one capability per line]' \
    '-a[retain commented-out capabilities (sets -x)]' \
    '(-I -L -K)-C[translate entries to termcap source form]' \
    '-D[print tic database locations]' \
    '-c[check only; validate input]' \
    '-e+[translate/compile only named entries (CSV)]:names:' \
    '-f[format complex strings for readability]' \
    '(-g)-G[format %{number} to %char]' \
    '(-G)-g[format %char to %{number}]' \
    '(-C -L -K)-I[translate entries to terminfo source form]' \
    '(-C -I -L)-K[translate to termcap source with BSD syntax]' \
    '(-C -I -K)-L[translate entries to full terminfo source form]' \
    '-N[disable smart defaults for source translation]' \
    '-o+[output directory for compiled entries]:dir:_files -/' \
    '-R+[restrict to given terminfo/termcap version]:version:(BSD AT&T HP SVr1 SVr2 SVr3 SVr4 4.2BSD 4.3BSD 4.4BSD)' \
    '-r[force resolution of all use entries]' \
    '-s[print summary statistics]' \
    '-T[remove size restrictions on compiled description]' \
    '-t[suppress commented-out capabilities]' \
    '-U[suppress post-processing of entries]' \
    '-v-[set verbosity level]::n:' \
    '-w-[set format width]::cols:' \
    '-x[treat unknown capabilities as user-defined]' \
    ':source file:_files -g "*.(ti|src|info|terminfo)"' \
    && ret=0

return ret
