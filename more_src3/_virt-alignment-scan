#compdef virt-alignment-scan
# _virt-alignment-scan — libguestfs virt-alignment-scan (report partition + LV alignment of every guest known to libvirt; -a disk, -d domain, -c URI, --csv CSV, --uuid include UUID, --quiet only mention bad alignments; useful for finding partitions misaligned for 4K-sector storage)
# upstream: https://github.com/libguestfs/libguestfs (alignment-scan)
# Flags from libguestfs alignment-scan/alignment_scan.ml on tip.

_virt-alignment-scan() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '--csv[CSV output]' \
        '--uuid[include UUID]' \
        '--quiet[only print bad alignments]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)'
}

_virt-alignment-scan "$@"
