#compdef storage_broker
# _storage_broker — Neon storage broker (gRPC pub/sub hub that propagates safekeeper timeline info to pageservers + safekeepers)
# upstream: https://github.com/neondatabase/neon
# Flags from storage_broker/src/bin/storage_broker.rs on tip (clap-derive); at least one of --listen-addr / --listen-https-addr is required.

_storage_broker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-l --listen-addr)'{-l+,--listen-addr=}'[HTTP listen address (host:port)]:hostport:' \
        '--listen-https-addr=[HTTPS listen address (host:port)]:hostport:' \
        '--timeline-chan-size=[per-timeline subscriber queue size]:n:' \
        '--all-keys-chan-size=[all-keys subscriber queue size]:n:' \
        '--http2-keepalive-interval=[HTTP/2 keepalive interval]:dur:' \
        '--log-format=[log format]:fmt:(plain json)' \
        '--ssl-key-file=[HTTPS private key path]:file:_files' \
        '--ssl-cert-file=[HTTPS X.509 cert path]:file:_files' \
        '--ssl-cert-reload-period=[cert + key reload interval]:dur:'
}

_storage_broker "$@"
