#compdef sphtriangulate
# Documentation: https://docs.generic-mapping-tools.org/latest/sphtriangulate.html
# Source: GenericMappingTools/gmt src/sphtriangulate.c — Delaunay/Voronoi triangulation on a sphere (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[compute triangle/polygon areas]' \
    '-C[conserve memory]' \
    '-D[delete duplicate points]' \
    '-L+[area units]:unit:(d e f k m M n)' \
    '-N+[node coords output]:file:_files' \
    '-Q+[output type]:type:(d v)' \
    '-T[write arcs instead of polygons]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-di+[input nodata↔NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-j+[spherical distance mode]:mode:(e f g)' \
    '-qi+[record selection]:cols:_default' \
    '-s+[skip records with NaN]:cols:_default' \
    '*:input table:_files' \
    && ret=0

return ret
