#compdef xeyes
# _xeyes — X.Org xeyes classic X11 demo following-eyes utility (X.Org team, C); custom argparse
# upstream: https://gitlab.freedesktop.org/xorg/app/xeyes

_xeyes() {
    _arguments \
        '-help[show help]' \
        '-display+[X display]:display:' \
        '-geometry+[window geometry]:geom:' \
        '-fg+[foreground color]:color:' \
        '-bg+[background color]:color:' \
        '-outline+[outline color]:color:' \
        '-center+[center color]:color:' \
        '-shape[shaped window]' \
        '-noshape[non-shaped window]' \
        '-bd+[border color]:color:' \
        '-bw+[border width]:n:' \
        '-distance[distance mode]' \
        '-name+[wm name]:str:' \
        '-title+[title]:str:' \
        '-xrm+[xrm resource]:str:' \
        '-biblicallyAccurate[many eyes]'
}

_xeyes "$@"
