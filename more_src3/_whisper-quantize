#compdef whisper-quantize
# Documentation: https://github.com/ggml-org/whisper.cpp/blob/master/examples/quantize/quantize.cpp
# Reference accessed: 2026-05-27
# Verified: upstream main() in examples/quantize/quantize.cpp (ggml-org/whisper.cpp).
# Usage: whisper-quantize model-f32.bin model-quant.bin type
# No option flags; three positional args. ftype names come from
# ggml_parse_ftype() in examples/common-ggml.cpp.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:input model (f32):_files -g "*.(bin|gguf)(-.)"' \
  '2:output model (quantized):_files' \
  '3:quantization type:(q4_0 q4_1 q5_0 q5_1 q8_0)' && ret=0

return ret
