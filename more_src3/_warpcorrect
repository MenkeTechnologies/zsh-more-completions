#compdef warpcorrect
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/warpcorrect.html
# Source: MRtrix3/mrtrix3 cmd/warpcorrect.cpp — replace out-of-FOV warp voxels with NaN (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-marker+[coordinate(s) marking out-of-bounds voxels]:coordinates:_default' \
    '-tolerance+[L2 matrix norm tolerance]:value:_default' \
    '1:in (input warp):_files -g "*.{nii,nii.gz,mif}"' \
    '2:out (output warp):_files' \
    && ret=0

return ret
