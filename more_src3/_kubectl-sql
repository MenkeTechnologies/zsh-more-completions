#compdef kubectl-sql
# kubectl-sql (krew plugin): query Kubernetes resources using SQL
# https://github.com/yaacov/kubectl-sql

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml name)' \
  '--no-headers[do not print headers]' \
  '1:resource type' \
  '2:SQL WHERE clause'
