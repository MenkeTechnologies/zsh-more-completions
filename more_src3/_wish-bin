#compdef wish
# _wish-bin — Tk Tcl windowing shell (Tk team, ActiveState); interactive Tcl + Tk GUI shell
# upstream: https://www.tcl.tk

_wish-bin() {
    _arguments \
        '-encoding+[encoding]:encoding:(ascii utf-8 latin1 iso8859-1)' \
        '-colormap+[colormap]:colormap:(new)' \
        '-display+[X display]:display:' \
        '-geometry+[geometry]:geom:' \
        '-name+[name]:name:' \
        '-sync[sync mode]' \
        '-use+[wrap embed window]:id:' \
        '-visual+[visual]:visual:' \
        '*:script:_files -g "*.tcl"'
}

_wish-bin "$@"
