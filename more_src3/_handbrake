#compdef handbrake ghb
# Documentation: https://handbrake.fr/docs/en/latest/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Note: the HandBrake GUI accepts very few CLI flags; the CLI tool is
# HandBrakeCLI (separate completion file).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:video:_files' && ret=0

return ret
