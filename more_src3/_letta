#compdef letta
# Documentation: https://github.com/letta-ai/letta
# Reference accessed: 2026-05-22
# Verified: letta/cli/cli.py server command and letta/main.py Typer entry.

# Zsh completion for letta - Letta agents with long-term memory (server CLI)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'letta command' \
      'server[start Letta REST API server]' && ret=0
    ;;
  args)
    case $line[1] in
      server)
        _arguments \
          '--type[server type]:type:(rest websocket)' \
          '--port[listen port]:port:' \
          '--host[listen host]:host:' \
          '--debug[enable debug output]' \
          '--reload[enable hot reload]' \
          '--ade[allow remote access]' \
          '--secure[add simple security access]' \
          '--localhttps[setup local https]' && ret=0
        ;;
    esac
    ;;
esac

return ret
