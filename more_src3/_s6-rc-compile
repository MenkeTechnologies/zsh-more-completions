#compdef s6-rc-compile
# Documentation: https://skarnet.org/software/s6-rc/s6-rc-compile.html
# Reference accessed: 2026-05-30
# s6-rc-compile — compile s6-rc service definitions into a binary service database.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-v+[verbosity (default 1; 0=silent, 2=detailed, 3+=debug)]:level:(0 1 2 3 4)' \
  '-h+[run s6-fdholder-daemon as this user (default supervision tree owner)]:user:_users' \
  '-b[make s6-rc-oneshot-run wait instead of fail on lock contention]' \
  '1:compiled output directory:_directories' \
  '*:source directory:_directories' \
  && ret=0

return ret
