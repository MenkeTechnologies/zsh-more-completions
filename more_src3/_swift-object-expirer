#compdef swift-object-expirer
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/obj/expirer.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '--processes=[number of worker processes for expiration]:n:' \
  '--process=[process number for this instance]:n:' \
  '*:CONFIG file:_files -g "*.conf"' && ret=0
return ret
