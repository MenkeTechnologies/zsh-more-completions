#compdef sriov-network-operator-config-cleanup
# _sriov-network-operator-config-cleanup — SR-IoV operator uninstall hook (k8snetworkplumbingwg/sriov-network-operator)
# upstream: https://github.com/k8snetworkplumbingwg/sriov-network-operator
# Flags from cmd/sriov-network-operator-config-cleanup/main.go on tip.

_sriov-network-operator-config-cleanup() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-n --namespace)'{-n,--namespace=}'[SR-IoV operator namespace]:ns:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_sriov-network-operator-config-cleanup "$@"
