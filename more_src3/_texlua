#compdef texlua texluajitc texluac texluajit
# Documentation: texlua --help (shares LuaTeX core; subset of luatex flags)
# Source: TeX texlua — standalone Lua interpreter from LuaTeX.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--cnf-line=[parse STRING as configuration line]:string:' \
    '(- *)--credits[show credits]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*-e+[execute Lua code]:chunk:' \
    '*-l+[require library]:library:' \
    '-i[interactive mode after running script]' \
    '-v[verbose]' \
    '-E[disable LUA_INIT environment variable]' \
    '--lua=[script (compat with luatex)]:file:_files -g "*.lua"' \
    '--luaonly[force lua-only mode (no TeX engine)]' \
    '--luaconly[byte-compile lua file then exit]' \
    '--luahashchars[show Lua string-hash bit count]' \
    '*:Lua script:_files -g "*.lua"' \
    && ret=0

return ret
