#compdef itamae
# _itamae — lightweight configuration management tool
# upstream: https://github.com/itamae-kitchen/itamae

_itamae() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'local:execute recipes locally'
                'ssh:execute recipes on remote host via SSH'
                'docker:execute recipes inside a Docker container'
                'generate:generate a new cookbook'
                'init:create an Itamae project skeleton'
                'version:show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                local)
                    _arguments \
                        '(-j --node-json)'{-j,--node-json=}'[node attributes JSON file]:file:_files -g "*.json"' \
                        '(-y --node-yaml)'{-y,--node-yaml=}'[node attributes YAML file]:file:_files -g "*.(yml|yaml)"' \
                        '(-l --log-level)'{-l,--log-level=}'[log level]:level:(debug info warn error fatal)' \
                        '--color[force colored output]' \
                        '--no-color[disable colored output]' \
                        '--dry-run[show what would be done]' \
                        '--shell=[shell to use]:shell:' \
                        '--ohai[use Ohai for node attributes]' \
                        '--vagrant[use Vagrant for provisioning]' \
                        '*:recipe files:_files -g "*.rb"'
                    ;;
                ssh)
                    _arguments \
                        '(-j --node-json)'{-j,--node-json=}'[node attributes JSON file]:file:_files -g "*.json"' \
                        '(-y --node-yaml)'{-y,--node-yaml=}'[node attributes YAML file]:file:_files -g "*.(yml|yaml)"' \
                        '(-l --log-level)'{-l,--log-level=}'[log level]:level:(debug info warn error fatal)' \
                        '(-h --host)'{-h,--host=}'[remote host]:host:_hosts' \
                        '(-u --user)'{-u,--user=}'[SSH user]:user:' \
                        '(-i --key)'{-i,--key=}'[SSH key file]:file:_files' \
                        '(-p --port)'{-p,--port=}'[SSH port]:port:' \
                        '--ask-password[prompt for SSH password]' \
                        '--sudo[use sudo]' \
                        '--dry-run[show what would be done]' \
                        '*:recipe files:_files -g "*.rb"'
                    ;;
                docker)
                    _arguments \
                        '--image=[Docker image]:image:' \
                        '--container=[container name or ID]:container:' \
                        '--tls-verify-peer[verify Docker TLS peer]' \
                        '*:recipe files:_files -g "*.rb"'
                    ;;
                generate)
                    _arguments \
                        '1:cookbook name:'
                    ;;
            esac
            ;;
    esac
}

_itamae "$@"
