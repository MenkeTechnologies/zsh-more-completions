#compdef start-master.sh stop-master.sh spark-master start-worker.sh stop-worker.sh spark-worker
# _spark-master — Apache Spark standalone cluster launchers (start-master.sh/start-worker.sh manage the Spark standalone scheduler; -h/--host bind host, -p/--port communication port, --webui-port web UI port, --properties-file alternate spark-defaults.conf, --cores total cores (worker), --memory memory cap (worker); worker also takes the master URL as positional arg)
# upstream: https://github.com/apache/spark
# Flags from Apache Spark core/src/main/scala/org/apache/spark/deploy/master+worker on tip.

_spark-master() {
    _arguments \
        '--help[show help]' \
        '-h+[bind host]:host:_hosts' \
        '--host+[bind host]:host:_hosts' \
        '-i+[bind host]:host:_hosts' \
        '--ip+[bind host]:host:_hosts' \
        '-p+[port]:port:' \
        '--port+[port]:port:' \
        '--webui-port+[web UI port]:port:' \
        '--properties-file+[properties file]:file:_files' \
        '-c+[cores]:n:' \
        '--cores+[cores]:n:' \
        '-m+[memory]:size:' \
        '--memory+[memory]:size:' \
        '-d+[working dir]:dir:_files -/' \
        '--work-dir+[working dir]:dir:_files -/' \
        '1::master URL:'
}

_spark-master "$@"
