#compdef idl2json
# _idl2json — convert Candid textual values to JSON (dfinity/idl2json)
# upstream: https://github.com/dfinity/idl2json
# Flags from src/idl2json_cli/src/lib.rs (clap derive).

_idl2json() {
    local -a args
    args=(
        '*'{-d+,--did=}'[.did file containing type definitions (repeatable)]:file:_files -g "*.did"'
        '(-t --typ)'{-t+,--typ=}'[name of a type in the provided .did file]:type name:'
        '(-i --init)'{-i,--init}'[use the service init argument type from the .did file (requires --did)]'
        '(-b --bytes-as)'{-b+,--bytes-as=}'[how to display bytes]:format:(numbers hex sha256)'
        '(-c --compact)'{-c,--compact}'[print compact (single-line) JSON]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
    )
    _arguments -s -S $args
}

_idl2json "$@"
