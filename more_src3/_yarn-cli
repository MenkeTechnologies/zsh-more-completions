#compdef yarn-cli
# _yarn-cli — Yarn JavaScript package manager (Yarn / Berry team, JavaScript); custom argparse
# upstream: https://github.com/yarnpkg/berry

_yarn-cli() {
    local -a sub=(
        'add:add a dependency'
        'audit:run npm audit'
        'autoclean:legacy autoclean'
        'bin:print bin path'
        'cache:cache commands'
        'check:check (legacy)'
        'config:manage configuration'
        'constraints:manage workspace constraints'
        'create:create a project'
        'dedupe:dedupe packages'
        'exec:exec a command'
        'explain:explain why a package is installed'
        'global:global commands (legacy)'
        'help:show help'
        'import:import a project'
        'info:show package info'
        'init:scaffold project'
        'install:install dependencies'
        'licenses:list licenses'
        'link:link a package'
        'list:list installed packages'
        'lockfile:lockfile commands'
        'login:login to registry'
        'logout:logout'
        'node:run node with PnP support'
        'npm:npm-style commands'
        'outdated:show outdated packages'
        'owner:owner commands'
        'pack:create npm tarball'
        'patch:create patch file'
        'patch-commit:commit patch file'
        'plugin:plugin commands'
        'policies:check applied policies'
        'publish:publish package'
        'rebuild:rebuild dependencies'
        'remove:remove dependency'
        'run:run a script'
        'search:search registry'
        'set:set config'
        'stage:stage modified files'
        'tag:tag commands'
        'team:team commands'
        'unlink:unlink'
        'unplug:unplug'
        'up:upgrade dependency'
        'upgrade:upgrade dependency (alias)'
        'upgrade-interactive:interactive upgrade'
        'version:set/bump version'
        'versions:show versions'
        'why:why is a package installed'
        'workspace:workspace commands'
        'workspaces:workspaces commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g ".yarnrc.yml *.yml"' \
        '--no-immutable[no immutable]' \
        '--immutable[immutable]' \
        '--immutable-cache[immutable cache]' \
        '--check-resolutions[check resolutions]' \
        '--inline-builds[inline builds]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yarn subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--dev[dev dep]' \
                    '-D[dev dep]' \
                    '--peer[peer dep]' \
                    '-P[peer dep]' \
                    '--optional[optional dep]' \
                    '-O[optional dep]' \
                    '--prefer-dev[prefer dev]' \
                    '--mode=+[mode]:m:(skip-build update-lockfile)' \
                    '*:package:' ;;
                up|upgrade) _arguments \
                    '--exact[exact version]' \
                    '-E[exact version]' \
                    '--caret[caret range]' \
                    '-C[caret range]' \
                    '--recursive[recursive]' \
                    '-R[recursive]' \
                    '--interactive[interactive]' \
                    '-i[interactive]' \
                    '*:package:' ;;
                remove) _arguments '*:package:' ;;
                workspace) _arguments \
                    '1:workspace:' \
                    '*:cmd:_command_names -e' ;;
                workspaces) _arguments \
                    '1:cmd:(focus foreach list)' \
                    '*:arg:' ;;
                run) _arguments '*:script:' ;;
                install) _arguments \
                    '--immutable[immutable]' \
                    '--immutable-cache[immutable cache]' \
                    '--check-resolutions[check resolutions]' \
                    '--inline-builds[inline builds]' \
                    '--refresh-lockfile[refresh lockfile]' \
                    '--check-cache[check cache]' \
                    '--mode=+[mode]:m:(skip-build update-lockfile)' ;;
                set) _arguments \
                    '1:cmd:(version resolution)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set unset list)' \
                    '*:arg:' ;;
                cache) _arguments \
                    '1:cmd:(clean)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_yarn-cli "$@"
