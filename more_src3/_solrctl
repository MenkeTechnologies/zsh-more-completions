#compdef solrctl
# _solrctl — Cloudera solrctl (operator wrapper around Solr Admin API + ZooKeeper for the Cloudera Search distribution; subcommands: init, instancedir, config, collection, core, cluster, sentry, sshmig; positional argument is the subcommand object then per-object action (--create/--delete/--list/--update/--copy/--diff))
# upstream: https://github.com/cloudera/search (solrctl)
# Subcommands from solrctl Bash on tip.

_solrctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--zk+[zookeeper connect string]:zk:' \
        '--solr+[solr base URL]:url:' \
        '1: :->object' \
        '*::action:->args'
    case $state in
        object) _describe -t commands 'solrctl object' '(init instancedir config collection core cluster sentry sshmig)' ;;
        args) _arguments '*:argument:' ;;
    esac
}

_solrctl "$@"
