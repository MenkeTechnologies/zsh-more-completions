#compdef kfp-cli
# Documentation: https://kubeflow-pipelines.readthedocs.io/en/stable/source/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. There is no separate
# `kfp-cli` binary documented upstream; the CLI is `kfp` (handled by
# the _kfp completion). Corrected from prior file: removed the
# `#compdef kfp` collision with _kfp; removed fabricated job/components/
# dsl-compile/dsl-compile-deprecated/output/k8s command groups. The
# real command groups are component, diagnose-me, dsl, experiment,
# pipeline, recurring-run, run.

# kfp-cli: alias of the Kubeflow Pipelines CLI (kfp)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'component:build shareable containerized components'
  'diagnose-me:run KFP environment diagnostic'
  'dsl:compile DSL to Pipeline Spec'
  'experiment:manage experiments'
  'pipeline:manage pipelines'
  'recurring-run:manage recurring runs'
  'run:manage runs'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--endpoint=[Kubeflow Pipelines endpoint]:url:' \
  '--iap-client-id=[IAP client id]:id:' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:ns:' \
  '--other-client-id=[other client id]:id:' \
  '--other-client-secret=[other client secret]:secret:' \
  '--existing-token=[direct authentication token]:token:' \
  '--output=[output format]:fmt:(table json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kfp command' commands && ret=0 ;;
esac
return ret
