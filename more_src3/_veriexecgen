#compdef veriexecgen
# Documentation: man veriexecgen(8)
# Source: netbsd/src usr.sbin/veriexecgen — generate Veriexec fingerprint db (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[append to output file]' \
    '-a[include non-executable files]' \
    '-D[search standard system directories]' \
    '*-d+[scan directory (repeatable)]:dir:_files -/' \
    '-f+[read file list (- for stdin)]:file:_files' \
    '(- *)-h[display help screen]' \
    '-o+[output fingerprint database]:fingerprintdb:_files' \
    '-p+[strip leading prefix from pathnames]:prefix:_default' \
    '-r[scan directories recursively]' \
    '-S[set immutable flag on signatures file]' \
    '-T[add timestamp to generated file]' \
    '-t+[hashing algorithm]:algorithm:(sha256 sha384 sha512)' \
    '-v[verbose output]' \
    '-W[treat errors as warnings]' \
    && ret=0

return ret
