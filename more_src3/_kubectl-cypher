#compdef kubectl-cypher
# Documentation: https://github.com/AvitalTamir/cyphernetes/blob/main/cmd/cyphernetes/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-cypher (cyphernetes, AvitalTamir): run a Cypher-inspired query.
# Positional argument is the query string.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version and exit]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace to query against]:namespace:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
  '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:(debug info warn error fatal panic)' \
  '--no-color[disable colored output]' \
  '--dry-run[enable dry-run mode for all operations]' \
  '*:query:_default'
