#compdef termux-open
# Documentation: https://github.com/termux/termux-tools/blob/master/scripts/termux-open.in
# Reference accessed: 2026-05-27
# Verified: upstream termux-tools scripts/termux-open.in show_usage()/getopts.


# Open a file or URL in an external app

_arguments \
  '-h[show this help]' \
  '--send[if the file should be shared for sending]' \
  '--view[if the file should be shared for viewing (default)]' \
  '--chooser[if an app chooser should always be shown]' \
  '--content-type=[specify the content type to use]:type:'
